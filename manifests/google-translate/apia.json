{
  "apia": "1.0",
  "service": {
    "id": "google-translate",
    "name": "Google Cloud Translation API",
    "description_for_ai": "Google Translate API. 135+ languages. Detect language, translate text, translate documents. Free: 500K chars/month. More languages than DeepL but lower quality for European languages.",
    "url": "https://cloud.google.com/translate",
    "api_base": "https://translation.googleapis.com/language/translate/v2",
    "category": "nlp",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://cloud.google.com/translate/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Enable Translation API at https://console.cloud.google.com",
    "cost": "Free: 500K chars/month. Then $20/1M chars"
  },
  "capabilities": [
    {
      "id": "translate_text",
      "description_for_ai": "Translate text between 133+ languages with Google Translate.",
      "intent": [
        "translate text",
        "Google Translate API",
        "language translation",
        "перевести текст Google"
      ],
      "endpoint": "POST https://translation.googleapis.com/language/translate/v2",
      "input": {
        "q": {
          "type": "string or array",
          "description": "Text to translate. Can be array for batch.",
          "required": true
        },
        "target": {
          "type": "string",
          "description": "Target language ISO 639-1: en, ru, de, fr, es, zh, ja, ar",
          "required": true
        },
        "source": {
          "type": "string",
          "description": "Source language. Auto-detected if omitted.",
          "required": false
        },
        "format": {
          "type": "string",
          "description": "text or html",
          "default": "text"
        }
      },
      "output": {
        "type": "translation",
        "fields": [
          "data.translations[0].translatedText",
          "data.translations[0].detectedSourceLanguage"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_language",
      "description_for_ai": "Detect the language of a text.",
      "intent": [
        "detect language",
        "language detection",
        "what language is this",
        "определить язык текста"
      ],
      "endpoint": "POST https://translation.googleapis.com/language/translate/v2/detect",
      "input": {
        "q": {
          "type": "string or array",
          "description": "Text(s) to detect language of",
          "required": true
        }
      },
      "output": {
        "type": "detection",
        "fields": [
          "data.detections[0][0].language",
          "data.detections[0][0].confidence (0-1)",
          "data.detections[0][0].isReliable"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_languages",
      "description_for_ai": "List all supported language codes with names.",
      "intent": [
        "supported languages",
        "language list",
        "Google Translate languages",
        "список языков перевода"
      ],
      "endpoint": "GET https://translation.googleapis.com/language/translate/v2/languages",
      "input": {
        "target": {
          "type": "string",
          "description": "Get language names in this language: en, ru",
          "required": false
        },
        "model": {
          "type": "string",
          "description": "nmt (neural) or base",
          "required": false
        }
      },
      "output": {
        "type": "list<language>",
        "fields": [
          "data.languages[0].language",
          "data.languages[0].name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "translate_with_glossary",
      "description_for_ai": "Translate using a custom glossary for domain-specific terminology.",
      "intent": [
        "glossary translation",
        "custom terms translation",
        "domain translation",
        "перевод с глоссарием"
      ],
      "endpoint": "POST https://translation.googleapis.com/v3/projects/{project}:translateText",
      "input": {
        "project": {
          "type": "string",
          "required": true
        },
        "contents": {
          "type": "array",
          "required": true
        },
        "targetLanguageCode": {
          "type": "string",
          "required": true
        },
        "sourceLanguageCode": {
          "type": "string",
          "required": false
        },
        "glossaryConfig": {
          "type": "object",
          "description": "{glossary: 'projects/PROJECT/locations/us-central1/glossaries/GLOSSARY_ID', ignoreCase: false}",
          "required": false
        }
      },
      "output": {
        "type": "translation",
        "fields": [
          "translations[0].translatedText",
          "translations[0].glossaryTranslations[0].translatedText"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "batch_translate",
      "description_for_ai": "Translate large volumes of text asynchronously from Cloud Storage.",
      "intent": [
        "batch translate",
        "bulk translation",
        "large file translation",
        "массовый перевод"
      ],
      "endpoint": "POST https://translation.googleapis.com/v3/projects/{project}/locations/{location}:batchTranslateText",
      "input": {
        "project": {
          "type": "string",
          "required": true
        },
        "location": {
          "type": "string",
          "default": "us-central1"
        },
        "sourceLanguageCode": {
          "type": "string",
          "required": true
        },
        "targetLanguageCodes": {
          "type": "array",
          "required": true
        },
        "inputConfigs": {
          "type": "array",
          "description": "[{gcsSource: {inputUri: 'gs://bucket/input'}, mimeType: 'text/html'}]",
          "required": true
        },
        "outputConfig": {
          "type": "object",
          "description": "{gcsDestination: {outputUriPrefix: 'gs://bucket/output/'}}",
          "required": true
        }
      },
      "output": {
        "type": "operation",
        "fields": [
          "name (long-running operation ID)",
          "metadata.state"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}