{
  "apia": "1.0",
  "service": {
    "id": "google-translate",
    "name": "Google Cloud Translation API",
    "description_for_ai": "Google Translate API. 135+ languages. Detect language, translate text, translate documents. Free: 500K chars/month. More languages than DeepL but lower quality for European languages.",
    "url": "https://cloud.google.com/translate",
    "api_base": "https://translation.googleapis.com/language/translate/v2",
    "category": "nlp",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://cloud.google.com/translate/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Enable Translation API at https://console.cloud.google.com",
    "cost": "Free: 500K chars/month. Then $20/1M chars"
  },
  "capabilities": [
    {
      "id": "translate",
      "description_for_ai": "Translate text between 133 languages using Google Translate. Fast and supports many languages including rare ones.",
      "intent": [
        "translate google",
        "google translate",
        "translate text",
        "перевести google",
        "гугл переводчик"
      ],
      "endpoint": "POST https://translation.googleapis.com/language/translate/v2",
      "input": {
        "q": {
          "type": "string or array",
          "description": "Text(s) to translate",
          "required": true
        },
        "target": {
          "type": "string",
          "description": "Target language code: en, ru, de, fr, zh, ar, ja, es, pt, ko, hi, it",
          "required": true
        },
        "source": {
          "type": "string",
          "description": "Source language (auto-detected if omitted)",
          "required": false
        },
        "format": {
          "type": "string",
          "description": "text or html",
          "default": "html"
        }
      },
      "output": {
        "type": "translation",
        "fields": [
          "data.translations[0].translatedText",
          "data.translations[0].detectedSourceLanguage"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_language",
      "description_for_ai": "Detect the language of text. Returns language code and confidence score.",
      "intent": [
        "detect language",
        "what language",
        "language detection",
        "определить язык",
        "какой язык"
      ],
      "endpoint": "POST https://translation.googleapis.com/language/translate/v2/detect",
      "input": {
        "q": {
          "type": "string or array",
          "description": "Text(s) to detect",
          "required": true
        }
      },
      "output": {
        "type": "detection",
        "fields": [
          "data.detections[0][0].language",
          "data.detections[0][0].confidence",
          "data.detections[0][0].isReliable"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_languages",
      "description_for_ai": "Get all 133 supported languages with codes and names.",
      "intent": [
        "google translate languages",
        "supported languages",
        "language list",
        "языки google translate"
      ],
      "endpoint": "GET https://translation.googleapis.com/language/translate/v2/languages",
      "input": {
        "target": {
          "type": "string",
          "description": "Return language names in this language e.g. ru",
          "required": false
        }
      },
      "output": {
        "type": "list<language>",
        "fields": [
          "data.languages[0].language",
          "data.languages[0].name"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "translate_document",
      "description_for_ai": "Translate a document (DOCX, PDF, PPTX) while preserving formatting via Google Cloud Translation v3.",
      "intent": [
        "translate document google",
        "translate PDF google",
        "document translation",
        "перевести документ google"
      ],
      "endpoint": "POST https://translation.googleapis.com/v3/projects/{project}/translateDocument",
      "input": {
        "parent": {
          "type": "string",
          "description": "projects/{project_id}/locations/global",
          "required": true
        },
        "sourceLanguageCode": {
          "type": "string",
          "required": false
        },
        "targetLanguageCode": {
          "type": "string",
          "required": true
        },
        "documentInputConfig": {
          "type": "object",
          "description": "{content: 'base64_encoded', mimeType: 'application/pdf'}",
          "required": true
        }
      },
      "output": {
        "type": "document_translation",
        "fields": [
          "documentTranslation.byteStreamOutputs[0] (base64)",
          "documentTranslation.mimeType"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}