{
  "apia": "1.0",
  "service": {
    "id": "openai",
    "name": "OpenAI API",
    "description_for_ai": "OpenAI flagship AI API. Access GPT models for text generation, code, vision, reasoning. DALL-E for image generation. Whisper for speech-to-text. TTS for text-to-speech. Embeddings for semantic search. The most widely used AI API with the largest ecosystem of integrations and SDKs.",
    "url": "https://openai.com",
    "api_base": "https://api.openai.com/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.openai.com/docs"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer sk-...",
    "how_to_get": "Register at https://platform.openai.com — $5 free credit on signup",
    "cost": "GPT-4o-mini: $0.15/$0.60 per 1M tokens. GPT-5.2: $1.75/$14 per 1M tokens"
  },
  "capabilities": [
    {
      "id": "chat_completion",
      "description_for_ai": "Generate text with GPT models. Supports conversation history, system prompts, function calling, JSON mode, vision (images in messages).",
      "intent": [
        "ask GPT",
        "AI text generation",
        "ChatGPT API",
        "generate text",
        "AI assistant",
        "спросить GPT",
        "ИИ генерация"
      ],
      "endpoint": "POST https://api.openai.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "description": "gpt-4o (best), gpt-4o-mini (fast/cheap), o1 (reasoning), o3-mini (reasoning cheap)",
          "required": true
        },
        "messages": {
          "type": "array",
          "description": "[{role: system|user|assistant, content: string or array for vision}]",
          "required": true
        },
        "temperature": {
          "type": "float",
          "description": "0=deterministic, 1=creative, 2=very random",
          "default": 1.0
        },
        "max_tokens": {
          "type": "integer",
          "required": false
        },
        "tools": {
          "type": "array",
          "description": "Function definitions for tool use",
          "required": false
        },
        "tool_choice": {
          "type": "string",
          "description": "auto, none, required, or {type:function,function:{name}}",
          "required": false
        },
        "response_format": {
          "type": "object",
          "description": "{type: json_object} for guaranteed JSON output",
          "required": false
        },
        "stream": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "choices[0].finish_reason",
          "usage.prompt_tokens",
          "usage.completion_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "embeddings",
      "description_for_ai": "Convert text to vector embeddings for semantic search, clustering, classification, and RAG. text-embedding-3-small is cheapest.",
      "intent": [
        "text embeddings",
        "vector embeddings",
        "semantic search",
        "RAG",
        "text similarity",
        "векторные представления"
      ],
      "endpoint": "POST https://api.openai.com/v1/embeddings",
      "input": {
        "model": {
          "type": "string",
          "description": "text-embedding-3-small ($0.02/1M), text-embedding-3-large (best quality)",
          "required": true
        },
        "input": {
          "type": "string or array",
          "description": "Text or array of texts to embed",
          "required": true
        },
        "dimensions": {
          "type": "integer",
          "description": "Output dimensions. 3-small: up to 1536, 3-large: up to 3072",
          "required": false
        }
      },
      "output": {
        "type": "embeddings",
        "fields": [
          "data[0].embedding (float array)",
          "data[0].index",
          "usage.total_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "speech_to_text",
      "description_for_ai": "Transcribe audio to text using Whisper. Supports MP3, WAV, M4A, FLAC, WEBM. $0.006 per minute. 97%+ accuracy across 100+ languages.",
      "intent": [
        "transcribe audio",
        "speech to text",
        "voice to text",
        "audio transcription",
        "whisper",
        "транскрибация аудио"
      ],
      "endpoint": "POST https://api.openai.com/v1/audio/transcriptions",
      "input": {
        "file": {
          "type": "file",
          "description": "Audio file (max 25MB). Supported: mp3, mp4, mpeg, mpga, m4a, wav, webm",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "whisper-1"
        },
        "language": {
          "type": "string",
          "description": "ISO 639-1 code e.g. en, ru, de. Auto-detected if omitted.",
          "required": false
        },
        "prompt": {
          "type": "string",
          "description": "Hints for domain-specific vocabulary",
          "required": false
        },
        "response_format": {
          "type": "string",
          "description": "json, text, srt, verbose_json, vtt",
          "default": "json"
        },
        "temperature": {
          "type": "float",
          "default": 0
        }
      },
      "output": {
        "type": "transcription",
        "fields": [
          "text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "text_to_speech",
      "description_for_ai": "Convert text to natural-sounding speech. 6 voices, 24kHz audio. $15 per 1M characters.",
      "intent": [
        "text to speech",
        "TTS",
        "voice generation",
        "read text aloud",
        "speech synthesis",
        "озвучить текст",
        "синтез речи"
      ],
      "endpoint": "POST https://api.openai.com/v1/audio/speech",
      "input": {
        "model": {
          "type": "string",
          "description": "tts-1 (fast, lower quality) or tts-1-hd (slower, studio quality)",
          "required": true
        },
        "input": {
          "type": "string",
          "description": "Text to synthesize, max 4096 chars",
          "required": true
        },
        "voice": {
          "type": "string",
          "description": "alloy, echo, fable, onyx, nova, shimmer",
          "required": true
        },
        "response_format": {
          "type": "string",
          "description": "mp3, opus, aac, flac, wav, pcm",
          "default": "mp3"
        },
        "speed": {
          "type": "float",
          "description": "Speed 0.25-4.0",
          "default": 1.0
        }
      },
      "output": {
        "type": "audio binary",
        "fields": [
          "audio file bytes"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "generate_image",
      "description_for_ai": "Generate images with DALL-E 3. High quality photorealistic or artistic images from text. $0.04-$0.12 per image.",
      "intent": [
        "generate image",
        "create image",
        "DALL-E",
        "text to image",
        "AI art",
        "создать изображение",
        "нарисовать"
      ],
      "endpoint": "POST https://api.openai.com/v1/images/generations",
      "input": {
        "model": {
          "type": "string",
          "default": "dall-e-3"
        },
        "prompt": {
          "type": "string",
          "description": "Detailed image description. DALL-E 3 rewrites for safety.",
          "required": true
        },
        "size": {
          "type": "string",
          "description": "1024x1024, 1792x1024 (landscape), 1024x1792 (portrait)",
          "default": "1024x1024"
        },
        "quality": {
          "type": "string",
          "description": "standard or hd",
          "default": "standard"
        },
        "style": {
          "type": "string",
          "description": "vivid (dramatic) or natural (realistic)",
          "default": "vivid"
        },
        "n": {
          "type": "integer",
          "description": "Number of images (DALL-E 3: always 1)",
          "default": 1
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "data[0].url",
          "data[0].revised_prompt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "moderation",
      "description_for_ai": "Check if text violates OpenAI usage policies — violence, hate, sexual content, self-harm. Free to use.",
      "intent": [
        "content moderation",
        "safe content check",
        "is this safe",
        "toxic text",
        "проверка контента"
      ],
      "endpoint": "POST https://api.openai.com/v1/moderations",
      "input": {
        "input": {
          "type": "string or array",
          "description": "Text to check",
          "required": true
        },
        "model": {
          "type": "string",
          "description": "text-moderation-latest or text-moderation-stable",
          "default": "text-moderation-latest"
        }
      },
      "output": {
        "type": "moderation",
        "fields": [
          "results[0].flagged",
          "results[0].categories.violence",
          "results[0].categories.sexual",
          "results[0].categories.hate",
          "results[0].category_scores"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_models",
      "description_for_ai": "List all available OpenAI models you have access to. Use to check which models are available for your API key.",
      "intent": [
        "available models",
        "list openai models",
        "what models exist",
        "model list",
        "список моделей openai"
      ],
      "endpoint": "GET https://api.openai.com/v1/models",
      "input": {},
      "output": {
        "type": "list<model>",
        "fields": [
          "data[0].id",
          "data[0].created",
          "data[0].owned_by"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_assistant",
      "description_for_ai": "Create an AI assistant with custom instructions, tools (code_interpreter, file_search, function), and knowledge files. Persistent across conversations.",
      "intent": [
        "create assistant",
        "AI agent",
        "custom GPT",
        "assistant with tools",
        "chatbot with memory",
        "создать ИИ ассистента"
      ],
      "endpoint": "POST https://api.openai.com/v1/assistants",
      "input": {
        "model": {
          "type": "string",
          "required": true
        },
        "name": {
          "type": "string",
          "required": false
        },
        "instructions": {
          "type": "string",
          "description": "System prompt / personality for the assistant",
          "required": false
        },
        "tools": {
          "type": "array",
          "description": "[{type: code_interpreter}, {type: file_search}, {type: function, function: {...}}]",
          "required": false
        },
        "tool_resources": {
          "type": "object",
          "description": "{file_search: {vector_store_ids: [...]}} to attach knowledge files",
          "required": false
        },
        "temperature": {
          "type": "float",
          "required": false
        }
      },
      "output": {
        "type": "assistant",
        "fields": [
          "id",
          "name",
          "model",
          "instructions",
          "tools",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "model_choice": "gpt-4o-mini for cheap tasks ($0.15/$0.60). gpt-4o for balanced quality/cost. o3-mini for complex reasoning. Use mini by default, upgrade only when quality is insufficient.",
    "tool_use": "Define tools as JSON Schema functions. Model decides when to call them. Essential for agentic workflows.",
    "vision": "Pass images as base64 or URL in message content: {type: image_url, image_url: {url: ...}}. Works with gpt-4o and gpt-4o-mini.",
    "batch_api": "Use Batch API for 50% discount on non-urgent tasks: submit job, get results within 24h.",
    "token_counting": "1 token ≈ 4 chars in English, ≈ 2 chars in Russian/CJK. Input is cheaper than output."
  },
  "limits": {
    "commercial_use": true,
    "attribution_required": false,
    "free_credit_usd": 5
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}