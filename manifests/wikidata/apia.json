{
  "apia": "1.0",
  "service": {
    "id": "wikidata",
    "name": "Wikidata API",
    "description_for_ai": "Free, open, collaborative knowledge base. 100M+ items: people, places, organizations, species, chemical compounds, artworks. Structured data behind Wikipedia. SPARQL queries for complex knowledge graph traversal. No API key needed.",
    "url": "https://wikidata.org",
    "api_base": "https://www.wikidata.org/w/api.php",
    "category": "science",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.wikidata.org/wiki/Wikidata:Data_access"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free forever"
  },
  "capabilities": [
    {
      "id": "search_entities",
      "description_for_ai": "Search Wikidata for entities (people, places, concepts) by label.",
      "intent": [
        "Wikidata search",
        "find entity",
        "knowledge graph search",
        "поиск Wikidata"
      ],
      "endpoint": "GET https://www.wikidata.org/w/api.php",
      "input": {
        "action": {
          "type": "string",
          "default": "wbsearchentities"
        },
        "search": {
          "type": "string",
          "required": true
        },
        "language": {
          "type": "string",
          "description": "en, ru, de, fr, zh",
          "default": "en"
        },
        "type": {
          "type": "string",
          "description": "item or property",
          "default": "item"
        },
        "limit": {
          "type": "integer",
          "default": 10
        },
        "format": {
          "type": "string",
          "default": "json"
        }
      },
      "output": {
        "type": "list<entity>",
        "fields": [
          "search[0].id",
          "search[0].label",
          "search[0].description",
          "search[0].url"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_entity",
      "description_for_ai": "Get all properties and claims for a Wikidata entity by its Q-number.",
      "intent": [
        "Wikidata entity",
        "entity details",
        "Q-number lookup",
        "сущность Wikidata"
      ],
      "endpoint": "GET https://www.wikidata.org/wiki/Special:EntityData/{entity_id}.json",
      "input": {
        "entity_id": {
          "type": "string",
          "description": "Q-number e.g. Q76 (Barack Obama), Q42 (Douglas Adams), Q183 (Germany)",
          "required": true
        }
      },
      "output": {
        "type": "entity",
        "fields": [
          "entities.{id}.labels.en.value",
          "entities.{id}.descriptions.en.value",
          "entities.{id}.claims (all properties)",
          "entities.{id}.sitelinks.enwiki.title"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "sparql_query",
      "description_for_ai": "Run SPARQL queries against the Wikidata knowledge graph. Extremely powerful for structured knowledge extraction.",
      "intent": [
        "SPARQL query",
        "knowledge graph query",
        "Wikidata query",
        "запрос Wikidata SPARQL"
      ],
      "endpoint": "GET https://query.wikidata.org/sparql",
      "input": {
        "query": {
          "type": "string",
          "description": "SPARQL query. Example: SELECT ?person ?personLabel WHERE { ?person wdt:P106 wd:Q33999. SERVICE wikibase:label { bd:serviceParam wikibase:language 'en'. } } LIMIT 10",
          "required": true
        },
        "format": {
          "type": "string",
          "description": "json, xml, csv, tsv",
          "default": "json"
        }
      },
      "output": {
        "type": "sparql_result",
        "fields": [
          "results.bindings[0].person.value",
          "results.bindings[0].personLabel.value"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_item_by_property",
      "description_for_ai": "Find Wikidata items that have a specific property value.",
      "intent": [
        "find by property Wikidata",
        "entity lookup",
        "property value search",
        "поиск по свойству Wikidata"
      ],
      "endpoint": "GET https://www.wikidata.org/w/api.php",
      "input": {
        "action": {
          "type": "string",
          "default": "wbgetentities"
        },
        "ids": {
          "type": "string",
          "description": "Q-numbers pipe-separated: Q76|Q42",
          "required": true
        },
        "languages": {
          "type": "string",
          "description": "en|ru|de",
          "default": "en"
        },
        "props": {
          "type": "string",
          "description": "labels|descriptions|claims|sitelinks",
          "default": "labels|descriptions"
        },
        "format": {
          "type": "string",
          "default": "json"
        }
      },
      "output": {
        "type": "entities",
        "fields": [
          "entities.{id}.labels.en.value",
          "entities.{id}.descriptions.en.value"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_property_info",
      "description_for_ai": "Look up a Wikidata property by its P-number.",
      "intent": [
        "Wikidata property",
        "P-number lookup",
        "property definition",
        "свойство Wikidata"
      ],
      "endpoint": "GET https://www.wikidata.org/w/api.php",
      "input": {
        "action": {
          "type": "string",
          "default": "wbgetentities"
        },
        "ids": {
          "type": "string",
          "description": "P-numbers: P31 (instance of), P279 (subclass of), P580 (start time)",
          "required": true
        },
        "format": {
          "type": "string",
          "default": "json"
        }
      },
      "output": {
        "type": "property",
        "fields": [
          "entities.{id}.labels.en.value",
          "entities.{id}.descriptions.en.value",
          "entities.{id}.datatype"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "common_properties": "P31=instance of, P279=subclass of, P17=country, P18=image, P569=birth date, P570=death date, P21=sex, P106=occupation",
    "wikidata_ids": "Q1=Universe, Q5=human, Q6256=country, Q515=city, Q146=cat, Q23=George Washington",
    "label_service": "Always add: SERVICE wikibase:label {bd:serviceParam wikibase:language en.} to get human-readable labels"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}