{
  "apia": "1.0",
  "service": {
    "id": "wikidata",
    "name": "Wikidata API",
    "description_for_ai": "Free, open, collaborative knowledge base. 100M+ items: people, places, organizations, species, chemical compounds, artworks. Structured data behind Wikipedia. SPARQL queries for complex knowledge graph traversal. No API key needed.",
    "url": "https://wikidata.org",
    "api_base": "https://www.wikidata.org/w/api.php",
    "category": "science",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.wikidata.org/wiki/Wikidata:Data_access"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free forever"
  },
  "capabilities": [
    {
      "id": "search_entities",
      "description_for_ai": "Search Wikidata entities (people, places, concepts) by name.",
      "intent": [
        "wikidata search",
        "entity search",
        "linked data",
        "поиск wikidata"
      ],
      "endpoint": "GET https://www.wikidata.org/w/api.php",
      "input": {
        "action": {
          "type": "string",
          "default": "wbsearchentities"
        },
        "search": {
          "type": "string",
          "required": true
        },
        "language": {
          "type": "string",
          "default": "en"
        },
        "limit": {
          "type": "integer",
          "default": 10
        },
        "type": {
          "type": "string",
          "description": "item or property",
          "default": "item"
        },
        "format": {
          "type": "string",
          "default": "json"
        }
      },
      "output": {
        "type": "entities",
        "fields": [
          "search[0].id (Q-number)",
          "search[0].label",
          "search[0].description",
          "search[0].url"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_entity",
      "description_for_ai": "Get full entity data: labels, descriptions, claims (properties) in all languages.",
      "intent": [
        "wikidata entity",
        "Q-number lookup",
        "structured data",
        "данные wikidata"
      ],
      "endpoint": "GET https://www.wikidata.org/wiki/Special:EntityData/{id}.json",
      "input": {
        "id": {
          "type": "string",
          "description": "Wikidata entity ID e.g. Q42 (Douglas Adams), Q64 (Berlin)",
          "required": true
        }
      },
      "output": {
        "type": "entity",
        "fields": [
          "entities.{id}.labels.en.value",
          "entities.{id}.descriptions.en.value",
          "entities.{id}.claims (property-value pairs)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "sparql_query",
      "description_for_ai": "Run SPARQL query on Wikidata knowledge graph. Get structured data about any topic.",
      "intent": [
        "wikidata sparql",
        "knowledge graph query",
        "structured knowledge",
        "SPARQL запрос wikidata"
      ],
      "endpoint": "GET https://query.wikidata.org/sparql",
      "input": {
        "query": {
          "type": "string",
          "description": "SPARQL query. Example: SELECT ?item ?itemLabel WHERE { ?item wdt:P31 wd:Q515. ?item wdt:P17 wd:Q159. SERVICE wikibase:label { bd:serviceParam wikibase:language 'en'. } } LIMIT 10 — cities in Russia",
          "required": true
        },
        "format": {
          "type": "string",
          "description": "json, csv, tsv, xml",
          "default": "json"
        }
      },
      "output": {
        "type": "results",
        "fields": [
          "results.bindings[0].{var}.value"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_sitelinks",
      "description_for_ai": "Get links from a Wikidata entity to Wikipedia articles in all languages.",
      "intent": [
        "wikidata sitelinks",
        "wikipedia links",
        "entity in languages",
        "ссылки wikidata"
      ],
      "endpoint": "GET https://www.wikidata.org/wiki/Special:EntityData/{id}.json",
      "input": {
        "id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "sitelinks",
        "fields": [
          "entities.{id}.sitelinks.enwiki.title",
          "entities.{id}.sitelinks.ruwiki.title",
          "entities.{id}.sitelinks.dewiki.title"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "common_properties": "P31=instance of, P279=subclass of, P17=country, P18=image, P569=birth date, P570=death date, P21=sex, P106=occupation",
    "wikidata_ids": "Q1=Universe, Q5=human, Q6256=country, Q515=city, Q146=cat, Q23=George Washington",
    "label_service": "Always add: SERVICE wikibase:label {bd:serviceParam wikibase:language en.} to get human-readable labels"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}