{
  "apia": "1.0",
  "service": {
    "id": "wikidata",
    "name": "Wikidata API",
    "description_for_ai": "Free, open, collaborative knowledge base. 100M+ items: people, places, organizations, species, chemical compounds, artworks. Structured data behind Wikipedia. SPARQL queries for complex knowledge graph traversal. No API key needed.",
    "url": "https://wikidata.org",
    "api_base": "https://www.wikidata.org/w/api.php",
    "category": "science",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.wikidata.org/wiki/Wikidata:Data_access"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free forever"
  },
  "capabilities": [
    {
      "id": "search_entities",
      "description_for_ai": "Search Wikidata entities (items and properties) by label.",
      "intent": [
        "Wikidata search",
        "find entity Wikidata",
        "knowledge base search",
        "поиск Wikidata"
      ],
      "endpoint": "GET https://www.wikidata.org/w/api.php?action=wbsearchentities",
      "input": {
        "search": {
          "type": "string",
          "description": "Search query",
          "required": true
        },
        "language": {
          "type": "string",
          "description": "Language code: en, ru, de, fr",
          "default": "en"
        },
        "type": {
          "type": "string",
          "description": "item or property",
          "default": "item"
        },
        "limit": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<entity>",
        "fields": [
          "search[0].id (Qxxx)",
          "search[0].label",
          "search[0].description",
          "search[0].url"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_entity",
      "description_for_ai": "Get full Wikidata entity data by ID: labels, descriptions, claims (facts).",
      "intent": [
        "Wikidata entity",
        "get facts Wikidata",
        "knowledge graph",
        "данные Wikidata"
      ],
      "endpoint": "GET https://www.wikidata.org/w/api.php?action=wbgetentities",
      "input": {
        "ids": {
          "type": "string",
          "description": "Wikidata IDs: Q42 (Douglas Adams), Q95 (Google), Q7259 (Ada Lovelace)",
          "required": true
        },
        "languages": {
          "type": "string",
          "description": "Pipe-separated: en|ru",
          "default": "en"
        },
        "props": {
          "type": "string",
          "description": "labels|descriptions|claims|sitelinks",
          "default": "labels|descriptions|claims"
        }
      },
      "output": {
        "type": "entity",
        "fields": [
          "entities.Q42.labels.en.value",
          "entities.Q42.descriptions.en.value",
          "entities.Q42.claims.P569 (date of birth)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "sparql_query",
      "description_for_ai": "Run SPARQL query against Wikidata to get structured knowledge.",
      "intent": [
        "SPARQL query Wikidata",
        "knowledge query",
        "structured data Wikidata",
        "запрос SPARQL Wikidata"
      ],
      "endpoint": "GET https://query.wikidata.org/sparql",
      "input": {
        "query": {
          "type": "string",
          "description": "SPARQL query. Example: SELECT ?item ?itemLabel WHERE { ?item wdt:P31 wd:Q146. SERVICE wikibase:label { bd:serviceParam wikibase:language 'en'. } } LIMIT 10",
          "required": true
        },
        "format": {
          "type": "string",
          "default": "json"
        }
      },
      "output": {
        "type": "sparql_results",
        "fields": [
          "results.bindings[0].item.value",
          "results.bindings[0].itemLabel.value"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_property",
      "description_for_ai": "Get a Wikidata property definition by property ID.",
      "intent": [
        "Wikidata property",
        "property definition",
        "P-number Wikidata",
        "свойство Wikidata"
      ],
      "endpoint": "GET https://www.wikidata.org/w/api.php?action=wbgetentities",
      "input": {
        "ids": {
          "type": "string",
          "description": "Property ID: P31 (instance of), P569 (date of birth), P18 (image)",
          "required": true
        }
      },
      "output": {
        "type": "property",
        "fields": [
          "entities.P31.labels.en.value (property name)",
          "entities.P31.descriptions.en.value"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_claim_statements",
      "description_for_ai": "Get specific claims (facts) for a Wikidata entity.",
      "intent": [
        "entity claims Wikidata",
        "facts about entity",
        "statements Wikidata",
        "факты Wikidata"
      ],
      "endpoint": "GET https://www.wikidata.org/w/api.php?action=wbgetclaims",
      "input": {
        "entity": {
          "type": "string",
          "description": "Entity ID: Q42",
          "required": true
        },
        "property": {
          "type": "string",
          "description": "Filter by property: P31, P569, P19",
          "required": false
        }
      },
      "output": {
        "type": "claims",
        "fields": [
          "claims.P31[0].mainsnak.datavalue.value.id",
          "claims.P569[0].mainsnak.datavalue.value.time"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_revision_history",
      "description_for_ai": "Get edit history for a Wikidata item.",
      "intent": [
        "Wikidata history",
        "edit history",
        "revisions Wikidata",
        "история правок Wikidata"
      ],
      "endpoint": "GET https://www.wikidata.org/w/api.php?action=query&prop=revisions",
      "input": {
        "titles": {
          "type": "string",
          "description": "Entity title: Q42 or Q7259",
          "required": true
        },
        "rvlimit": {
          "type": "integer",
          "default": 10
        },
        "rvprop": {
          "type": "string",
          "description": "ids|flags|timestamp|user|size|comment",
          "default": "ids|timestamp|user|comment"
        }
      },
      "output": {
        "type": "revisions",
        "fields": [
          "query.pages[0].revisions[0].timestamp",
          "query.pages[0].revisions[0].user",
          "query.pages[0].revisions[0].comment"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "common_properties": "P31=instance of, P279=subclass of, P17=country, P18=image, P569=birth date, P570=death date, P21=sex, P106=occupation",
    "wikidata_ids": "Q1=Universe, Q5=human, Q6256=country, Q515=city, Q146=cat, Q23=George Washington",
    "label_service": "Always add: SERVICE wikibase:label {bd:serviceParam wikibase:language en.} to get human-readable labels"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}