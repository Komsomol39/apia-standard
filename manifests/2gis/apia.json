{
  "apia": "1.0",
  "service": {
    "id": "2gis",
    "name": "2GIS",
    "description_for_ai": "Справочник организаций и карты России и СНГ. Лучший источник для поиска компаний, магазинов, кафе, аптек, банков рядом с пользователем. Содержит часы работы, телефоны, рейтинги. Особенно силён в регионах России где Google Maps слабее.",
    "url": "https://2gis.ru",
    "api_base": "https://catalog.api.2gis.com/3.0",
    "category": "maps",
    "geo": [
      "RU",
      "BY",
      "KZ",
      "KG",
      "UZ",
      "AE",
      "CZ",
      "CL",
      "IT",
      "CY"
    ],
    "language": "ru",
    "docs": "https://docs.2gis.com/en/api/search/overview"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Зарегистрироваться на https://dev.2gis.ru и создать ключ в Platform Manager",
    "cost": "демо-ключ бесплатно на месяц, далее по тарифу"
  },
  "capabilities": [
    {
      "id": "geocode",
      "description_for_ai": "Forward and reverse geocoding for Russia and CIS countries with 2GIS.",
      "intent": [
        "2GIS geocode",
        "адрес координаты 2ГИС",
        "координаты адреса Россия",
        "геокодинг 2ГИС"
      ],
      "endpoint": "GET https://catalog.api.2gis.com/3.0/items/geocode",
      "input": {
        "q": {
          "type": "string",
          "description": "Address query",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "items.point,items.address_name,items.full_name",
          "required": false
        },
        "key": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "geocode",
        "fields": [
          "result.items[0].point.lat",
          "result.items[0].point.lon",
          "result.items[0].full_name",
          "result.items[0].address_name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_places",
      "description_for_ai": "Search for places, businesses, and organizations in 2GIS catalog.",
      "intent": [
        "2GIS search",
        "поиск мест 2ГИС",
        "найти организацию 2ГИС",
        "search 2GIS"
      ],
      "endpoint": "GET https://catalog.api.2gis.com/3.0/items",
      "input": {
        "q": {
          "type": "string",
          "description": "Search query",
          "required": true
        },
        "point": {
          "type": "string",
          "description": "Center point: lon,lat e.g. 37.617635,55.755814",
          "required": false
        },
        "radius": {
          "type": "integer",
          "description": "Search radius in meters",
          "required": false
        },
        "type": {
          "type": "string",
          "description": "branch or building",
          "required": false
        },
        "key": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<place>",
        "fields": [
          "result.items[0].id",
          "result.items[0].name",
          "result.items[0].address_name",
          "result.items[0].point.lat"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_routing",
      "description_for_ai": "Get driving, cycling, or walking directions in Russia with 2GIS.",
      "intent": [
        "маршрут 2ГИС",
        "directions Russia",
        "route calculation 2GIS",
        "проложить маршрут 2ГИС"
      ],
      "endpoint": "GET https://routing.api.2gis.com/carrouting/6.0.0/global",
      "input": {
        "points": {
          "type": "array",
          "description": "[{x: lon, y: lat}, {x: lon, y: lat}]",
          "required": true
        },
        "output": {
          "type": "string",
          "description": "Result type: routing_path,polyline",
          "default": "routing_path"
        },
        "key": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "route",
        "fields": [
          "result[0].total_distance",
          "result[0].total_duration",
          "result[0].maneuvers[0].outcoming_path.points"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_place_details",
      "description_for_ai": "Get detailed info about a 2GIS place: hours, phones, photos, reviews.",
      "intent": [
        "place details 2GIS",
        "organization info 2ГИС",
        "business info Russia",
        "детали организации 2ГИС"
      ],
      "endpoint": "GET https://catalog.api.2gis.com/3.0/items/byid",
      "input": {
        "id": {
          "type": "string",
          "description": "2GIS object ID",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "items.schedule,items.contact_groups,items.reviews,items.photos",
          "required": false
        },
        "key": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "place",
        "fields": [
          "result.items[0].name",
          "result.items[0].schedule.Mon.working_hours[0].from",
          "result.items[0].contact_groups[0].contacts[0].value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "suggest",
      "description_for_ai": "Autocomplete address and place queries for search inputs in 2GIS.",
      "intent": [
        "address autocomplete 2GIS",
        "place suggest Russia",
        "автодополнение адреса 2ГИС"
      ],
      "endpoint": "GET https://suggest.api.2gis.com/2.0/suggest",
      "input": {
        "q": {
          "type": "string",
          "description": "Partial search query",
          "required": true
        },
        "locale": {
          "type": "string",
          "description": "ru_RU, en_RU, de_RU",
          "default": "ru_RU"
        },
        "key": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<suggestion>",
        "fields": [
          "result.items[0].name",
          "result.items[0].full_name",
          "result.items[0].type"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "geo_flow": "Всегда передавай координаты пользователя в point='lng,lat' и sort=distance — результаты будут отсортированы по близости.",
    "schedule_tip": "Чтобы получить часы работы добавь fields=items.schedule. Без этого поля расписание не возвращается.",
    "coords_format": "2GIS использует формат 'longitude,latitude' (сначала долгота) — это отличается от стандарта lat,lng. Не перепутай!",
    "regions": "2GIS особенно хорош в регионах России — Сибирь, Урал, Дальний Восток — где другие карты менее полны."
  },
  "limits": {
    "demo_requests": "500 объектов (5 страниц по 10)",
    "commercial_use": true,
    "attribution_required": true,
    "attribution_text": "Данные предоставлены 2GIS",
    "contact": "https://dev.2gis.ru"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}