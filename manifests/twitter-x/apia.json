{
  "apia": "1.0",
  "service": {
    "id": "twitter-x",
    "name": "X (Twitter) API v2",
    "description_for_ai": "X (formerly Twitter) social platform API. Search tweets, get user profiles, post tweets, get timelines, stream real-time tweets. 350M+ users. Use for social listening, tweet analysis, posting, monitoring mentions.",
    "url": "https://twitter.com",
    "api_base": "https://api.twitter.com/2",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.twitter.com/en/docs/twitter-api"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Developer account at https://developer.twitter.com",
    "cost": "Free Basic: 1500 tweets/month. Basic: $100/month. Pro: $5000/month"
  },
  "capabilities": [
    {
      "id": "search_tweets",
      "description_for_ai": "Search recent tweets (last 7 days free, historical requires Academic). Filter by keyword, hashtag, user, language, date.",
      "intent": [
        "search tweets",
        "twitter search",
        "find tweets",
        "twitter mentions",
        "hashtag search",
        "поиск twitter"
      ],
      "endpoint": "GET https://api.twitter.com/2/tweets/search/recent",
      "input": {
        "query": {
          "type": "string",
          "description": "Query with operators: 'OpenAI', '#AI', 'from:elonmusk', '-is:retweet lang:en', '(AI OR GPT)'",
          "required": true
        },
        "max_results": {
          "type": "integer",
          "description": "10-100",
          "default": 10
        },
        "tweet.fields": {
          "type": "string",
          "description": "created_at,public_metrics,author_id,lang,entities",
          "required": false
        },
        "expansions": {
          "type": "string",
          "description": "author_id to get user info",
          "required": false
        },
        "start_time": {
          "type": "string",
          "description": "ISO 8601 start time",
          "required": false
        },
        "end_time": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<tweet>",
        "fields": [
          "data[0].id",
          "data[0].text",
          "data[0].created_at",
          "data[0].public_metrics.like_count",
          "data[0].public_metrics.retweet_count",
          "meta.result_count"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "post_tweet",
      "description_for_ai": "Post a new tweet. Supports text, media, polls, replies, and quote tweets.",
      "intent": [
        "post tweet",
        "tweet",
        "publish twitter",
        "post on X",
        "написать твит"
      ],
      "endpoint": "POST https://api.twitter.com/2/tweets",
      "input": {
        "text": {
          "type": "string",
          "description": "Tweet text, max 280 chars",
          "required": true
        },
        "reply": {
          "type": "object",
          "description": "{in_reply_to_tweet_id: '...'}",
          "required": false
        },
        "quote_tweet_id": {
          "type": "string",
          "required": false
        },
        "media": {
          "type": "object",
          "description": "{media_ids: ['id1']}",
          "required": false
        },
        "poll": {
          "type": "object",
          "description": "{duration_minutes: 1440, options: ['Yes', 'No']}",
          "required": false
        }
      },
      "output": {
        "type": "tweet",
        "fields": [
          "data.id",
          "data.text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_user",
      "description_for_ai": "Get Twitter/X user profile by username or ID. Returns followers, following, bio, metrics.",
      "intent": [
        "twitter user",
        "user profile twitter",
        "twitter account info",
        "followers count",
        "профиль twitter"
      ],
      "endpoint": "GET https://api.twitter.com/2/users/by/username/{username}",
      "input": {
        "username": {
          "type": "string",
          "description": "Twitter username without @",
          "required": true
        },
        "user.fields": {
          "type": "string",
          "description": "description,public_metrics,profile_image_url,location,created_at,verified",
          "required": false
        }
      },
      "output": {
        "type": "user",
        "fields": [
          "data.id",
          "data.name",
          "data.username",
          "data.description",
          "data.public_metrics.followers_count",
          "data.public_metrics.tweet_count",
          "data.verified"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_user_tweets",
      "description_for_ai": "Get recent tweets from a specific user timeline.",
      "intent": [
        "user tweets",
        "twitter timeline",
        "user timeline",
        "tweets from user",
        "твиты пользователя"
      ],
      "endpoint": "GET https://api.twitter.com/2/users/{id}/tweets",
      "input": {
        "id": {
          "type": "string",
          "description": "User ID (get from get_user)",
          "required": true
        },
        "max_results": {
          "type": "integer",
          "description": "5-100",
          "default": 10
        },
        "tweet.fields": {
          "type": "string",
          "description": "created_at,public_metrics,entities",
          "required": false
        },
        "exclude": {
          "type": "string",
          "description": "retweets,replies",
          "required": false
        }
      },
      "output": {
        "type": "list<tweet>",
        "fields": [
          "data[0].id",
          "data[0].text",
          "data[0].created_at",
          "data[0].public_metrics"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "like_tweet",
      "description_for_ai": "Like a tweet on behalf of an authenticated user.",
      "intent": [
        "like tweet",
        "favorite tweet",
        "twitter like",
        "лайк twitter"
      ],
      "endpoint": "POST https://api.twitter.com/2/users/{id}/likes",
      "input": {
        "id": {
          "type": "string",
          "description": "User ID of the liker",
          "required": true
        },
        "tweet_id": {
          "type": "string",
          "description": "Tweet to like",
          "required": true
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "data.liked"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_tweet",
      "description_for_ai": "Get a single tweet by ID with full metrics, entities, and author info.",
      "intent": [
        "get tweet",
        "tweet details",
        "single tweet",
        "tweet by id",
        "получить твит"
      ],
      "endpoint": "GET https://api.twitter.com/2/tweets/{id}",
      "input": {
        "id": {
          "type": "string",
          "required": true
        },
        "tweet.fields": {
          "type": "string",
          "description": "created_at,public_metrics,author_id,lang,entities,context_annotations",
          "required": false
        },
        "expansions": {
          "type": "string",
          "description": "author_id,attachments.media_keys",
          "required": false
        }
      },
      "output": {
        "type": "tweet",
        "fields": [
          "data.id",
          "data.text",
          "data.public_metrics",
          "data.created_at",
          "data.lang"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "api_tiers": "Free: 1500 tweets/month write only, no search. Basic ($100/month): 10K tweets/month write, 500K read. Pro ($5000/month): higher limits.",
    "search_operators": "Powerful operators: from:user, to:user, @mention, #hashtag, is:retweet, is:verified, lang:ru, has:images, has:links, place_country:US",
    "rate_limits": "Basic tier: 1 request/15min for search. Cache results and avoid polling too frequently."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}