{
  "apia": "1.0",
  "service": {
    "id": "twitter-x",
    "name": "X (Twitter) API v2",
    "description_for_ai": "X (formerly Twitter) social platform API. Search tweets, get user profiles, post tweets, get timelines, stream real-time tweets. 350M+ users. Use for social listening, tweet analysis, posting, monitoring mentions.",
    "url": "https://twitter.com",
    "api_base": "https://api.twitter.com/2",
    "category": "social_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.twitter.com/en/docs/twitter-api"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Developer account at https://developer.twitter.com",
    "cost": "Free Basic: 1500 tweets/month. Basic: $100/month. Pro: $5000/month"
  },
  "capabilities": [
    {
      "id": "search_tweets",
      "description_for_ai": "Search recent tweets by keyword, hashtag, or from a user. Returns text, author, engagement metrics.",
      "intent": [
        "search tweets",
        "twitter search",
        "find tweets",
        "twitter mentions",
        "hashtag search",
        "twitter sentiment"
      ],
      "endpoint": "GET https://api.twitter.com/2/tweets/search/recent",
      "input": {
        "query": {
          "type": "string",
          "description": "Search query e.g. from:user, #hashtag, keyword -is:retweet lang:en",
          "required": true
        },
        "max_results": {
          "type": "integer",
          "default": 10,
          "max": 100
        },
        "tweet.fields": {
          "type": "string",
          "description": "created_at,public_metrics,author_id,lang",
          "required": false
        },
        "expansions": {
          "type": "string",
          "description": "author_id for user info",
          "required": false
        }
      },
      "output": {
        "type": "list<tweet>",
        "fields": [
          "id",
          "text",
          "created_at",
          "public_metrics.like_count",
          "public_metrics.retweet_count",
          "author_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "post_tweet",
      "description_for_ai": "Post a new tweet. Returns tweet ID and text.",
      "intent": [
        "post tweet",
        "tweet",
        "publish on twitter",
        "share on X",
        "tweet something"
      ],
      "endpoint": "POST https://api.twitter.com/2/tweets",
      "input": {
        "text": {
          "type": "string",
          "description": "Tweet text max 280 chars",
          "required": true
        },
        "reply": {
          "type": "object",
          "description": "{in_reply_to_tweet_id: id} for replies",
          "required": false
        },
        "media": {
          "type": "object",
          "description": "{media_ids: [id]} for media attachments",
          "required": false
        }
      },
      "output": {
        "type": "tweet",
        "fields": [
          "data.id",
          "data.text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "api_v2": "Always use v2 API. v1.1 is deprecated.",
    "rate_limits": "Free tier very limited. Basic tier $100/month gives 500K tweets read/month.",
    "search_operators": "Powerful operators: from:user, to:user, #hashtag, is:retweet, lang:ru, -is:retweet"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}