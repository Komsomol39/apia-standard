{
  "apia": "1.0",
  "service": {
    "id": "gitlab",
    "name": "GitLab API",
    "description_for_ai": "Git repository hosting with built-in CI/CD, issue tracking, container registry. 30M+ users. Alternative to GitHub. Free self-hosted. Use for repository management, CI/CD pipelines, DevOps automation.",
    "url": "https://gitlab.com",
    "api_base": "https://gitlab.com/api/v4",
    "category": "developer_tools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.gitlab.com/ee/api/rest/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": true,
    "anonymous_limits": "Public repos only",
    "header": "Authorization: Bearer {token}",
    "how_to_get": "User Settings → Access Tokens",
    "cost": "Free. Premium: $29/user/month"
  },
  "capabilities": [
    {
      "id": "list_projects",
      "description_for_ai": "List GitLab projects/repositories. Filter by membership, visibility, search.",
      "intent": [
        "gitlab repos",
        "list projects",
        "find repository",
        "gitlab search"
      ],
      "endpoint": "GET https://gitlab.com/api/v4/projects",
      "input": {
        "membership": {
          "type": "boolean",
          "description": "Only show projects user is member of",
          "default": false
        },
        "search": {
          "type": "string",
          "required": false,
          "description": "Search keywords or query string"
        },
        "order_by": {
          "type": "string",
          "description": "id, name, created_at, updated_at, last_activity_at, stars_count",
          "default": "created_at"
        },
        "per_page": {
          "type": "integer",
          "default": 20,
          "description": "Results per page. Check API docs for maximum allowed."
        }
      },
      "output": {
        "type": "list<project>",
        "fields": [
          "id",
          "name",
          "description",
          "web_url",
          "star_count",
          "forks_count",
          "last_activity_at",
          "visibility"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_issue",
      "description_for_ai": "Create a new issue in a GitLab project with title, description, labels, assignees, milestone, and due date.",
      "intent": [
        "create gitlab issue",
        "new bug",
        "add task",
        "gitlab ticket"
      ],
      "endpoint": "POST https://gitlab.com/api/v4/projects/{id}/issues",
      "input": {
        "id": {
          "type": "string",
          "description": "Project ID (integer) or URL-encoded path e.g. 'username%2Fproject'",
          "required": true
        },
        "title": {
          "type": "string",
          "description": "Title or name string",
          "required": true
        },
        "description": {
          "type": "string",
          "description": "Issue description (supports GitLab Flavored Markdown)",
          "required": false
        },
        "labels": {
          "type": "string",
          "description": "Comma-separated label names e.g. 'bug,high-priority,backend'",
          "required": false
        },
        "assignee_ids": {
          "type": "array",
          "description": "Array of user IDs to assign the issue to",
          "required": false
        },
        "milestone_id": {
          "type": "integer",
          "description": "Milestone ID to associate with",
          "required": false
        },
        "due_date": {
          "type": "string",
          "description": "Due date in YYYY-MM-DD format",
          "required": false
        },
        "issue_type": {
          "type": "string",
          "description": "issue, incident, or task",
          "default": "issue"
        }
      },
      "output": {
        "type": "issue",
        "fields": [
          "id",
          "iid",
          "title",
          "web_url",
          "state"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_pipelines",
      "description_for_ai": "Get CI/CD pipeline runs for a project. Filter by status, branch, or trigger source. Use for build monitoring and deployment tracking.",
      "intent": [
        "CI status",
        "pipeline status",
        "build status",
        "deployment status",
        "gitlab CI"
      ],
      "endpoint": "GET https://gitlab.com/api/v4/projects/{id}/pipelines",
      "input": {
        "id": {
          "type": "string",
          "description": "Project ID or path",
          "required": true
        },
        "status": {
          "type": "string",
          "description": "Pipeline status: created, waiting_for_resource, preparing, pending, running, success, failed, canceled, skipped, manual, scheduled",
          "required": false
        },
        "ref": {
          "type": "string",
          "description": "Branch or tag name to filter by",
          "required": false
        },
        "sha": {
          "type": "string",
          "description": "Git commit SHA",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 20,
          "description": "Results per page. Check API docs for maximum allowed."
        },
        "order_by": {
          "type": "string",
          "description": "id, status, ref, updated_at, user_id",
          "default": "id"
        },
        "sort": {
          "type": "string",
          "description": "Sort field and direction e.g. 'created_at:desc' or 'name'",
          "default": "desc"
        }
      },
      "output": {
        "type": "list<pipeline>",
        "fields": [
          "id",
          "status",
          "ref",
          "sha",
          "created_at",
          "updated_at",
          "web_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "auth": "Personal access token or OAuth2. Create at gitlab.com/-/user_settings/personal_access_tokens. Scopes: api, read_api.",
    "self_hosted": "Base URL changes for self-hosted: https://gitlab.yourcompany.com/api/v4. Same API.",
    "project_id": "Get project ID from: project page → Settings → General (shown at top). Or URL-encode the path: group%2Fsubgroup%2Fproject."
  }
}