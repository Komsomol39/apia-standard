{
  "apia": "1.0",
  "service": {
    "id": "gitlab",
    "name": "GitLab API",
    "description_for_ai": "Git repository hosting with built-in CI/CD, issue tracking, container registry. 30M+ users. Alternative to GitHub. Free self-hosted. Use for repository management, CI/CD pipelines, DevOps automation.",
    "url": "https://gitlab.com",
    "api_base": "https://gitlab.com/api/v4",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.gitlab.com/ee/api/rest/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": true,
    "anonymous_limits": "Public repos only",
    "header": "Authorization: Bearer {token}",
    "how_to_get": "User Settings → Access Tokens",
    "cost": "Free. Premium: $29/user/month"
  },
  "capabilities": [
    {
      "id": "list_projects",
      "description_for_ai": "List GitLab projects (repos) you have access to. Filter by search, visibility, owned.",
      "intent": [
        "gitlab projects",
        "list repos GitLab",
        "my projects GitLab",
        "список проектов GitLab"
      ],
      "endpoint": "GET https://gitlab.com/api/v4/projects",
      "input": {
        "search": {
          "type": "string",
          "required": false
        },
        "owned": {
          "type": "boolean",
          "description": "Only your own projects",
          "required": false
        },
        "membership": {
          "type": "boolean",
          "description": "Projects you are member of",
          "required": false
        },
        "visibility": {
          "type": "string",
          "description": "public, internal, private",
          "required": false
        },
        "order_by": {
          "type": "string",
          "description": "id, name, path, created_at, updated_at, last_activity_at, star_count",
          "default": "created_at"
        },
        "per_page": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<project>",
        "fields": [
          "[0].id",
          "[0].name",
          "[0].path_with_namespace",
          "[0].http_url_to_repo",
          "[0].star_count",
          "[0].last_activity_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_issue",
      "description_for_ai": "Create an issue in a GitLab project.",
      "intent": [
        "create issue GitLab",
        "report bug GitLab",
        "new ticket GitLab",
        "задача GitLab"
      ],
      "endpoint": "POST https://gitlab.com/api/v4/projects/{id}/issues",
      "input": {
        "id": {
          "type": "string",
          "description": "Project ID or URL-encoded path e.g. group%2Fproject",
          "required": true
        },
        "title": {
          "type": "string",
          "required": true
        },
        "description": {
          "type": "string",
          "required": false
        },
        "labels": {
          "type": "string",
          "description": "Comma-separated labels",
          "required": false
        },
        "assignee_ids": {
          "type": "array",
          "required": false
        },
        "milestone_id": {
          "type": "integer",
          "required": false
        },
        "due_date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        }
      },
      "output": {
        "type": "issue",
        "fields": [
          "iid",
          "title",
          "web_url",
          "state",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_merge_requests",
      "description_for_ai": "List merge requests (pull requests) in a project.",
      "intent": [
        "merge requests GitLab",
        "MR list",
        "code review GitLab",
        "мёрж реквесты GitLab"
      ],
      "endpoint": "GET https://gitlab.com/api/v4/projects/{id}/merge_requests",
      "input": {
        "id": {
          "type": "string",
          "required": true
        },
        "state": {
          "type": "string",
          "description": "opened, closed, locked, merged",
          "default": "opened"
        },
        "author_id": {
          "type": "integer",
          "required": false
        },
        "labels": {
          "type": "string",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<mr>",
        "fields": [
          "[0].iid",
          "[0].title",
          "[0].state",
          "[0].author.name",
          "[0].web_url",
          "[0].created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_file",
      "description_for_ai": "Get content of a file from a GitLab repository.",
      "intent": [
        "read file GitLab",
        "get source code GitLab",
        "repository file",
        "файл из репозитория GitLab"
      ],
      "endpoint": "GET https://gitlab.com/api/v4/projects/{id}/repository/files/{file_path}",
      "input": {
        "id": {
          "type": "string",
          "required": true
        },
        "file_path": {
          "type": "string",
          "description": "URL-encoded path e.g. src%2Fmain.py",
          "required": true
        },
        "ref": {
          "type": "string",
          "description": "Branch, tag, or commit",
          "default": "main"
        }
      },
      "output": {
        "type": "file",
        "fields": [
          "file_name",
          "file_path",
          "content (base64)",
          "encoding",
          "last_commit_id",
          "size"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_commit",
      "description_for_ai": "Create a commit with multiple file changes in one request. Create, update, or delete files.",
      "intent": [
        "commit GitLab",
        "push files GitLab",
        "create files repo",
        "коммит GitLab"
      ],
      "endpoint": "POST https://gitlab.com/api/v4/projects/{id}/repository/commits",
      "input": {
        "id": {
          "type": "string",
          "required": true
        },
        "branch": {
          "type": "string",
          "required": true
        },
        "commit_message": {
          "type": "string",
          "required": true
        },
        "actions": {
          "type": "array",
          "description": "[{action: 'create'|'update'|'delete'|'move', file_path: 'path', content: 'file content'}]",
          "required": true
        }
      },
      "output": {
        "type": "commit",
        "fields": [
          "id",
          "short_id",
          "title",
          "web_url",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "run_pipeline",
      "description_for_ai": "Trigger a CI/CD pipeline in a GitLab project.",
      "intent": [
        "run pipeline GitLab",
        "trigger CI",
        "run tests GitLab",
        "запустить пайплайн GitLab"
      ],
      "endpoint": "POST https://gitlab.com/api/v4/projects/{id}/pipeline",
      "input": {
        "id": {
          "type": "string",
          "required": true
        },
        "ref": {
          "type": "string",
          "description": "Branch or tag to run pipeline on",
          "required": true
        },
        "variables": {
          "type": "array",
          "description": "[{key: 'ENV', value: 'production', variable_type: 'env_var'}]",
          "required": false
        }
      },
      "output": {
        "type": "pipeline",
        "fields": [
          "id",
          "status",
          "web_url",
          "ref",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_code",
      "description_for_ai": "Search code across all accessible GitLab projects.",
      "intent": [
        "search code GitLab",
        "find code",
        "code search",
        "поиск кода GitLab"
      ],
      "endpoint": "GET https://gitlab.com/api/v4/search",
      "input": {
        "scope": {
          "type": "string",
          "description": "projects, issues, merge_requests, blobs (code), commits, users",
          "required": true
        },
        "search": {
          "type": "string",
          "required": true
        },
        "per_page": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<result>",
        "fields": [
          "[0].id",
          "[0].data (code snippet)",
          "[0].path",
          "[0].project_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "auth": "Personal access token or OAuth2. Create at gitlab.com/-/user_settings/personal_access_tokens. Scopes: api, read_api.",
    "self_hosted": "Base URL changes for self-hosted: https://gitlab.yourcompany.com/api/v4. Same API.",
    "project_id": "Get project ID from: project page → Settings → General (shown at top). Or URL-encode the path: group%2Fsubgroup%2Fproject."
  }
}