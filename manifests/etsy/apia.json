{
  "apia": "1.0",
  "service": {
    "id": "etsy",
    "name": "Etsy API",
    "description_for_ai": "Etsy marketplace API for handmade, vintage, and craft products. 90M+ active buyers, 7M+ sellers. Manage listings, process orders, track shop analytics. Strong for unique, custom, and personalized products. Used by craft sellers and print-on-demand businesses.",
    "url": "https://etsy.com",
    "api_base": "https://openapi.etsy.com/v3",
    "category": "ecommerce",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.etsy.com/documentation"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Register at https://www.etsy.com/developers",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "search_listings",
      "description_for_ai": "Search Etsy marketplace for handmade items, vintage goods, and unique products.",
      "intent": [
        "Etsy search",
        "handmade items",
        "find Etsy products",
        "поиск Etsy"
      ],
      "endpoint": "GET https://openapi.etsy.com/v3/application/listings/active",
      "input": {
        "keywords": {
          "type": "string",
          "required": true
        },
        "sort_on": {
          "type": "string",
          "description": "created, price, updated, score",
          "default": "score"
        },
        "sort_order": {
          "type": "string",
          "description": "asc, desc",
          "default": "desc"
        },
        "min_price": {
          "type": "float",
          "required": false
        },
        "max_price": {
          "type": "float",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 25
        }
      },
      "output": {
        "type": "list<listing>",
        "fields": [
          "results[0].listing_id",
          "results[0].title",
          "results[0].price.amount",
          "results[0].currency_code",
          "results[0].url",
          "results[0].tags"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_listing",
      "description_for_ai": "Get full details of an Etsy listing with images and seller info.",
      "intent": [
        "Etsy listing",
        "product details Etsy",
        "item info Etsy",
        "товар Etsy"
      ],
      "endpoint": "GET https://openapi.etsy.com/v3/application/listings/{listing_id}",
      "input": {
        "listing_id": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "listing",
        "fields": [
          "listing_id",
          "title",
          "description",
          "price.amount",
          "quantity",
          "tags",
          "materials",
          "shop_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_shop",
      "description_for_ai": "Get Etsy shop details: name, announcement, ratings, reviews.",
      "intent": [
        "Etsy shop",
        "seller profile Etsy",
        "shop info",
        "магазин Etsy"
      ],
      "endpoint": "GET https://openapi.etsy.com/v3/application/shops/{shop_id}",
      "input": {
        "shop_id": {
          "type": "integer",
          "required": false
        },
        "shop_name": {
          "type": "string",
          "description": "Alternatively use shop name",
          "required": false
        }
      },
      "output": {
        "type": "shop",
        "fields": [
          "shop_id",
          "shop_name",
          "url",
          "sale_message",
          "review_count",
          "review_average"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_shop_listings",
      "description_for_ai": "Get all active listings from a specific Etsy shop.",
      "intent": [
        "Etsy shop listings",
        "seller products",
        "shop items",
        "листинги магазина Etsy"
      ],
      "endpoint": "GET https://openapi.etsy.com/v3/application/shops/{shop_id}/listings/active",
      "input": {
        "shop_id": {
          "type": "integer",
          "required": true
        },
        "limit": {
          "type": "integer",
          "default": 25
        }
      },
      "output": {
        "type": "list<listing>",
        "fields": [
          "results[0].listing_id",
          "results[0].title",
          "results[0].price.amount",
          "results[0].url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_listing_images",
      "description_for_ai": "Get images for an Etsy listing.",
      "intent": [
        "Etsy listing images",
        "product photos",
        "item photos Etsy",
        "фото листинга Etsy"
      ],
      "endpoint": "GET https://openapi.etsy.com/v3/application/listings/{listing_id}/images",
      "input": {
        "listing_id": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "list<image>",
        "fields": [
          "results[0].listing_image_id",
          "results[0].url_fullxfull",
          "results[0].url_170x135",
          "results[0].rank"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}