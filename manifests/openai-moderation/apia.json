{
  "apia": "1.0",
  "service": {
    "id": "openai-moderation",
    "name": "OpenAI Moderation API",
    "description_for_ai": "Free content moderation API from OpenAI. Detect hate speech, harassment, self-harm, violence, sexual content in text. No cost. Use for moderating user-generated content before publishing.",
    "url": "https://openai.com",
    "api_base": "https://api.openai.com/v1",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.openai.com/docs/guides/moderation"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "Same OpenAI API key",
    "cost": "Free — included with OpenAI API account"
  },
  "capabilities": [
    {
      "id": "moderate_text",
      "description_for_ai": "Check text for policy violations: hate, harassment, self-harm, violence, sexual content.",
      "intent": [
        "content moderation OpenAI",
        "text moderation",
        "check policy violations",
        "модерация контента OpenAI"
      ],
      "endpoint": "POST https://api.openai.com/v1/moderations",
      "input": {
        "input": {
          "type": "string or array",
          "description": "Text(s) to moderate",
          "required": true
        },
        "model": {
          "type": "string",
          "description": "omni-moderation-latest (default), text-moderation-latest",
          "default": "omni-moderation-latest"
        }
      },
      "output": {
        "type": "moderation",
        "fields": [
          "results[0].flagged (bool)",
          "results[0].categories.hate",
          "results[0].categories.harassment",
          "results[0].categories.sexual",
          "results[0].categories.violence",
          "results[0].categories.self-harm",
          "results[0].category_scores.hate"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "batch_moderate",
      "description_for_ai": "Moderate multiple texts in one request with OpenAI Moderation API.",
      "intent": [
        "bulk moderation",
        "batch content check",
        "multiple texts moderate",
        "массовая модерация OpenAI"
      ],
      "endpoint": "POST https://api.openai.com/v1/moderations",
      "input": {
        "input": {
          "type": "array",
          "description": "Array of strings to moderate (up to 100 at once)",
          "required": true
        }
      },
      "output": {
        "type": "list<result>",
        "fields": [
          "results[0].flagged",
          "results[0].categories",
          "results[0].category_scores"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "check_sexual_content",
      "description_for_ai": "Specifically check for sexual or adult content.",
      "intent": [
        "sexual content check",
        "adult content moderation",
        "NSFW detection",
        "проверка на взрослый контент"
      ],
      "endpoint": "POST https://api.openai.com/v1/moderations",
      "input": {
        "input": {
          "type": "string",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "omni-moderation-latest"
        }
      },
      "output": {
        "type": "moderation",
        "fields": [
          "results[0].categories.sexual (bool)",
          "results[0].categories.sexual/minors (bool)",
          "results[0].category_scores.sexual"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "check_violence",
      "description_for_ai": "Specifically check for violent or threatening content.",
      "intent": [
        "violence detection",
        "threat detection",
        "violent content check",
        "обнаружение насилия OpenAI"
      ],
      "endpoint": "POST https://api.openai.com/v1/moderations",
      "input": {
        "input": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "moderation",
        "fields": [
          "results[0].categories.violence (bool)",
          "results[0].categories.violence/graphic (bool)",
          "results[0].categories.harassment/threatening (bool)",
          "results[0].category_scores.violence"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "check_self_harm",
      "description_for_ai": "Check text for self-harm or suicide-related content.",
      "intent": [
        "self-harm detection",
        "suicide content check",
        "crisis content",
        "обнаружение суицидального контента"
      ],
      "endpoint": "POST https://api.openai.com/v1/moderations",
      "input": {
        "input": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "moderation",
        "fields": [
          "results[0].categories.self-harm (bool)",
          "results[0].categories.self-harm/intent",
          "results[0].categories.self-harm/instructions",
          "results[0].category_scores.self-harm"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "free": "This endpoint is FREE even with paid plan. Use liberally.",
    "threshold": "flagged=true means content violates policy. category_scores give confidence 0-1.",
    "languages": "Works across many languages, not just English."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}