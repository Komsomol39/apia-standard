{
  "apia": "1.0",
  "service": {
    "id": "openai-moderation",
    "name": "OpenAI Moderation API",
    "description_for_ai": "Free content moderation API from OpenAI. Detect hate speech, harassment, self-harm, violence, sexual content in text. No cost. Use for moderating user-generated content before publishing.",
    "url": "https://openai.com",
    "api_base": "https://api.openai.com/v1",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.openai.com/docs/guides/moderation"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "Same OpenAI API key",
    "cost": "Free — included with OpenAI API account"
  },
  "capabilities": [
    {
      "id": "moderate_text",
      "description_for_ai": "Check text for violations using OpenAI Moderation API (free).",
      "intent": [
        "content moderation openai",
        "text safety check",
        "harmful content detection",
        "модерация контента openai"
      ],
      "endpoint": "POST https://api.openai.com/v1/moderations",
      "input": {
        "input": {
          "type": "string or array",
          "description": "Text or list of texts to moderate",
          "required": true
        },
        "model": {
          "type": "string",
          "description": "omni-moderation-latest (multilingual+images), text-moderation-latest",
          "default": "omni-moderation-latest"
        }
      },
      "output": {
        "type": "moderation",
        "fields": [
          "results[0].flagged (boolean)",
          "results[0].categories.hate",
          "results[0].categories.sexual",
          "results[0].categories.violence",
          "results[0].categories.self-harm",
          "results[0].category_scores.hate"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "moderate_image",
      "description_for_ai": "Moderate image content using OpenAI omni-moderation model.",
      "intent": [
        "image moderation openai",
        "safe image check",
        "NSFW detection openai",
        "модерация изображений openai"
      ],
      "endpoint": "POST https://api.openai.com/v1/moderations",
      "input": {
        "input": {
          "type": "array",
          "description": "[{type: 'image_url', image_url: {url: 'https://...' or 'data:image/jpeg;base64,...'}}]",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "omni-moderation-latest"
        }
      },
      "output": {
        "type": "moderation",
        "fields": [
          "results[0].flagged",
          "results[0].categories.sexual/minors",
          "results[0].categories.violence/graphic",
          "results[0].category_scores"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "batch_moderate",
      "description_for_ai": "Moderate multiple texts at once with OpenAI Moderation.",
      "intent": [
        "batch moderation",
        "bulk text check",
        "moderate many texts",
        "массовая модерация openai"
      ],
      "endpoint": "POST https://api.openai.com/v1/moderations",
      "input": {
        "input": {
          "type": "array",
          "description": "Array of strings to moderate",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "omni-moderation-latest"
        }
      },
      "output": {
        "type": "list<result>",
        "fields": [
          "results[0].flagged",
          "results[0].categories",
          "results[0].category_scores"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "check_hate_speech",
      "description_for_ai": "Check specifically for hate speech in text.",
      "intent": [
        "hate speech detection",
        "hate content check",
        "offensive text detection",
        "обнаружение ненависти openai"
      ],
      "endpoint": "POST https://api.openai.com/v1/moderations",
      "input": {
        "input": {
          "type": "string",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "omni-moderation-latest"
        }
      },
      "output": {
        "type": "moderation",
        "fields": [
          "results[0].categories.hate",
          "results[0].categories.hate/threatening",
          "results[0].category_scores.hate",
          "results[0].flagged"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "check_self_harm",
      "description_for_ai": "Detect self-harm or suicide-related content using OpenAI Moderation.",
      "intent": [
        "self harm detection",
        "suicide content check",
        "mental health safety",
        "обнаружение самоповреждений openai"
      ],
      "endpoint": "POST https://api.openai.com/v1/moderations",
      "input": {
        "input": {
          "type": "string",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "omni-moderation-latest"
        }
      },
      "output": {
        "type": "moderation",
        "fields": [
          "results[0].categories.self-harm",
          "results[0].categories.self-harm/intent",
          "results[0].categories.self-harm/instructions",
          "results[0].flagged"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "free": "This endpoint is FREE even with paid plan. Use liberally.",
    "threshold": "flagged=true means content violates policy. category_scores give confidence 0-1.",
    "languages": "Works across many languages, not just English."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}