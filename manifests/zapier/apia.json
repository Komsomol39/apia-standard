{
  "apia": "1.0",
  "service": {
    "id": "zapier",
    "name": "Zapier NLA API",
    "description_for_ai": "Connect 6000+ apps through natural language. Execute actions in Gmail, Slack, Trello, Notion, Google Sheets, CRM systems using plain English instructions via AI. No-code automation for AI agents.",
    "url": "https://zapier.com",
    "api_base": "https://nla.zapier.com/api/v1",
    "category": "productivity",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://nla.zapier.com/docs/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "X-API-Key: ...",
    "how_to_get": "Enable NLA at https://nla.zapier.com/get-started/",
    "cost": "Free tier included in Zapier plans from $29.99/month"
  },
  "capabilities": [
    {
      "id": "list_actions",
      "description_for_ai": "List available Zapier actions user has enabled. Returns actions for connected apps like Gmail, Slack, etc.",
      "intent": [
        "what can zapier do",
        "available actions",
        "zapier capabilities",
        "automation options"
      ],
      "endpoint": "GET https://nla.zapier.com/api/v1/dynamic/exposed/",
      "input": {},
      "output": {
        "type": "list<action>",
        "fields": [
          "id",
          "description",
          "params"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "execute_action",
      "description_for_ai": "Execute a Zapier action using natural language. Send email, post to Slack, create Trello card, add to spreadsheet.",
      "intent": [
        "send email via zapier",
        "post to slack",
        "create task",
        "automation action",
        "connect apps"
      ],
      "endpoint": "POST https://nla.zapier.com/api/v1/dynamic/exposed/{action_id}/execute/",
      "input": {
        "action_id": {
          "type": "string",
          "description": "Action ID from list_actions",
          "required": true
        },
        "instructions": {
          "type": "string",
          "description": "Natural language instruction e.g. Send email to john@example.com with subject Hello",
          "required": true
        }
      },
      "output": {
        "type": "action_result",
        "fields": [
          "id",
          "status",
          "review_url",
          "result"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "trigger_zap",
      "description_for_ai": "Trigger a Zapier webhook to start an automation (Zap).",
      "intent": [
        "trigger zap",
        "webhook zapier",
        "automation trigger",
        "триггер zapier"
      ],
      "endpoint": "POST https://hooks.zapier.com/hooks/catch/{hook_id}/",
      "input": {
        "data": {
          "type": "object",
          "description": "Any JSON payload — Zapier maps it to downstream actions",
          "required": true
        }
      },
      "output": {
        "type": "status",
        "fields": [
          "status: 'success'",
          "id (webhook event ID)",
          "attempt"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "list_zaps",
      "description_for_ai": "List all Zaps in a Zapier account via the Partner API.",
      "intent": [
        "list zaps",
        "my automations",
        "zapier zaps",
        "список zapier"
      ],
      "endpoint": "GET https://api.zapier.com/v1/zaps",
      "input": {
        "status": {
          "type": "string",
          "description": "enabled, disabled, draft, paused",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<zap>",
        "fields": [
          "objects[0].id",
          "objects[0].title",
          "objects[0].state",
          "objects[0].steps[0].app.title"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "run_action",
      "description_for_ai": "Run a Zapier action (e.g. send Gmail, post to Slack) via Natural Language Actions API.",
      "intent": [
        "zapier action",
        "NLA run",
        "AI automation zapier",
        "действие zapier NLA"
      ],
      "endpoint": "POST https://nla.zapier.com/api/v1/dynamic/exposed/{action_id}/execute/",
      "input": {
        "action_id": {
          "type": "string",
          "required": true
        },
        "instructions": {
          "type": "string",
          "description": "Natural language instructions for the action",
          "required": true
        },
        "preview_only": {
          "type": "boolean",
          "description": "True to preview without executing",
          "default": false
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "action_used",
          "result",
          "status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "nla_setup": "Enable NLA at nla.zapier.com. User must connect their Zapier account and enable specific actions.",
    "action_ids": "Use list_actions first to get available action IDs for the connected user.",
    "natural_language": "Instructions are natural language: 'Send email to john@example.com with subject Hello and body Hi there'",
    "alternatives": "For programmatic automation without user interaction, consider Zapier's Interfaces or Tables APIs instead."
  }
}