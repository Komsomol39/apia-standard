{
  "apia": "1.0",
  "service": {
    "id": "zapier",
    "name": "Zapier NLA API",
    "description_for_ai": "Connect 6000+ apps through natural language. Execute actions in Gmail, Slack, Trello, Notion, Google Sheets, CRM systems using plain English instructions via AI. No-code automation for AI agents.",
    "url": "https://zapier.com",
    "api_base": "https://nla.zapier.com/api/v1",
    "category": "productivity",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://nla.zapier.com/docs/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "X-API-Key: ...",
    "how_to_get": "Enable NLA at https://nla.zapier.com/get-started/",
    "cost": "Free tier included in Zapier plans from $29.99/month"
  },
  "capabilities": [
    {
      "id": "trigger_zap",
      "description_for_ai": "Trigger a Zapier Zap via a Webhook (Catch Hook) to start an automation.",
      "intent": [
        "trigger Zapier",
        "run Zap",
        "automation Zapier",
        "запустить Zapier"
      ],
      "endpoint": "POST https://hooks.zapier.com/hooks/catch/{hook_id}/",
      "input": {
        "hook_id": {
          "type": "string",
          "description": "Your Zapier webhook ID from the Zapier dashboard",
          "required": true
        },
        "data": {
          "type": "object",
          "description": "Any JSON payload to pass to the Zap",
          "required": true
        }
      },
      "output": {
        "type": "status",
        "fields": [
          "status: success",
          "attempt: 'hook_id'"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "list_zaps",
      "description_for_ai": "List all Zaps in a Zapier account via the API.",
      "intent": [
        "list Zaps",
        "my Zaps",
        "Zapier automations",
        "список Zap"
      ],
      "endpoint": "GET https://api.zapier.com/v1/zaps",
      "input": {
        "status": {
          "type": "string",
          "description": "on or off",
          "required": false
        }
      },
      "output": {
        "type": "list<zap>",
        "fields": [
          "objects[0].id",
          "objects[0].title",
          "objects[0].status",
          "objects[0].modified_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_zap",
      "description_for_ai": "Get details of a specific Zapier Zap including trigger and action steps.",
      "intent": [
        "Zap details",
        "Zap info",
        "automation details",
        "детали Zap"
      ],
      "endpoint": "GET https://api.zapier.com/v1/zaps/{zap_id}",
      "input": {
        "zap_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "zap",
        "fields": [
          "id",
          "title",
          "status",
          "steps[0].type_of",
          "steps[0].app.slug",
          "steps[0].action"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "enable_disable_zap",
      "description_for_ai": "Enable or disable a Zapier Zap.",
      "intent": [
        "enable Zap",
        "disable Zap",
        "turn off Zapier",
        "включить выключить Zap"
      ],
      "endpoint": "PATCH https://api.zapier.com/v1/zaps/{zap_id}",
      "input": {
        "zap_id": {
          "type": "string",
          "required": true
        },
        "status": {
          "type": "string",
          "description": "on or off",
          "required": true
        }
      },
      "output": {
        "type": "zap",
        "fields": [
          "id",
          "title",
          "status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "use_natural_language_action",
      "description_for_ai": "Use Zapier NLA (Natural Language Actions) to trigger any supported app action via natural language.",
      "intent": [
        "Zapier NLA",
        "natural language action",
        "AI to Zapier",
        "Zapier из AI"
      ],
      "endpoint": "POST https://nla.zapier.com/api/v1/dynamic/openapi/actions/{action_id}/run/",
      "input": {
        "action_id": {
          "type": "string",
          "description": "Action ID from list NLA actions",
          "required": true
        },
        "instructions": {
          "type": "string",
          "description": "Natural language instruction: 'Send an email to john@example.com about the meeting tomorrow'",
          "required": true
        },
        "preview_only": {
          "type": "boolean",
          "description": "Preview without running",
          "default": false
        }
      },
      "output": {
        "type": "action_result",
        "fields": [
          "action_used",
          "result.status",
          "result.action_attempted"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "nla_setup": "Enable NLA at nla.zapier.com. User must connect their Zapier account and enable specific actions.",
    "action_ids": "Use list_actions first to get available action IDs for the connected user.",
    "natural_language": "Instructions are natural language: 'Send email to john@example.com with subject Hello and body Hi there'",
    "alternatives": "For programmatic automation without user interaction, consider Zapier's Interfaces or Tables APIs instead."
  }
}