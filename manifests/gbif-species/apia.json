{
  "apia": "1.0",
  "service": {
    "id": "gbif-species",
    "name": "GBIF Species API",
    "description_for_ai": "Detailed taxonomy and species information from GBIF. Backbone taxonomy covering all life on Earth. Common names in 100+ languages, synonyms, higher classification, media (images, sounds). No API key needed.",
    "url": "https://gbif.org",
    "api_base": "https://api.gbif.org/v1",
    "category": "biodiversity",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.gbif.org/developer/species"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free forever"
  },
  "capabilities": [
    {
      "id": "search_species",
      "description_for_ai": "Search species by scientific or common name. Returns taxonomy, status, common names in multiple languages.",
      "intent": [
        "species info",
        "animal taxonomy",
        "plant species",
        "what is this animal",
        "species classification",
        "latin name",
        "common name species"
      ],
      "endpoint": "GET https://api.gbif.org/v1/species/search",
      "input": {
        "q": {
          "type": "string",
          "description": "Scientific or common name",
          "required": true
        },
        "rank": {
          "type": "string",
          "description": "SPECIES, GENUS, FAMILY, ORDER, CLASS, PHYLUM, KINGDOM",
          "required": false
        },
        "status": {
          "type": "string",
          "description": "ACCEPTED, SYNONYM, DOUBTFUL",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<species>",
        "fields": [
          "canonicalName",
          "vernacularName",
          "kingdom",
          "phylum",
          "class",
          "order",
          "family",
          "genus",
          "taxonomicStatus",
          "rank"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_species",
      "description_for_ai": "Get full species details including common names in all languages and media.",
      "intent": [
        "species details",
        "animal common name",
        "plant image",
        "species media",
        "sound of animal"
      ],
      "endpoint": "GET https://api.gbif.org/v1/species/{usageKey}",
      "input": {
        "usageKey": {
          "type": "integer",
          "description": "GBIF taxon key",
          "required": true
        }
      },
      "output": {
        "type": "species",
        "fields": [
          "canonicalName",
          "vernacularNames",
          "kingdom",
          "phylum",
          "media[0].identifier",
          "media[0].license"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}