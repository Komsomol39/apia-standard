{
  "apia": "1.0",
  "service": {
    "id": "gbif-species",
    "name": "GBIF Species API",
    "description_for_ai": "GBIF Species API — comprehensive taxonomy database covering all life on Earth. 3M+ species with full taxonomic classification, vernacular names in 100+ languages, synonyms, and media. Powers biodiversity research globally. Completely free and open data.",
    "url": "https://gbif.org",
    "api_base": "https://api.gbif.org/v1",
    "category": "science",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.gbif.org/developer/species"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free forever"
  },
  "capabilities": [
    {
      "id": "search_species",
      "description_for_ai": "Search species by scientific or common name. Returns taxonomy, status, common names in multiple languages.",
      "intent": [
        "plant species",
        "wildlife taxonomy",
        "what is this animal",
        "animal taxonomy",
        "latin name lookup",
        "species info",
        "biodiversity",
        "what is this species",
        "common name species",
        "species classification",
        "latin name"
      ],
      "endpoint": "GET https://api.gbif.org/v1/species/search",
      "input": {
        "q": {
          "type": "string",
          "description": "Scientific or common name",
          "required": true
        },
        "rank": {
          "type": "string",
          "description": "SPECIES, GENUS, FAMILY, ORDER, CLASS, PHYLUM, KINGDOM",
          "required": false
        },
        "status": {
          "type": "string",
          "description": "ACCEPTED, SYNONYM, DOUBTFUL",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 20,
          "description": "Maximum number of results to return"
        }
      },
      "output": {
        "type": "list<species>",
        "fields": [
          "canonicalName",
          "vernacularName",
          "kingdom",
          "phylum",
          "class",
          "order",
          "family",
          "genus",
          "taxonomicStatus",
          "rank"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_species",
      "description_for_ai": "Get full species details including common names in all languages and media.",
      "intent": [
        "species details",
        "plant image",
        "animal common name",
        "sound of animal",
        "species media",
        "plant species info",
        "common name",
        "animal info"
      ],
      "endpoint": "GET https://api.gbif.org/v1/species/{usageKey}",
      "input": {
        "usageKey": {
          "type": "integer",
          "description": "GBIF taxon key",
          "required": true
        }
      },
      "output": {
        "type": "species",
        "fields": [
          "canonicalName",
          "vernacularNames",
          "kingdom",
          "phylum",
          "media[0].identifier",
          "media[0].license"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_species",
      "description_for_ai": "Get species details from GBIF taxonomy: name, rank, kingdom, vernacular names.",
      "intent": [
        "species info GBIF",
        "taxonomy species",
        "scientific name lookup"
      ],
      "endpoint": "GET https://api.gbif.org/v1/species/{key}",
      "input": {
        "key": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "species",
        "fields": [
          "key",
          "scientificName",
          "canonicalName",
          "kingdom",
          "phylum",
          "class",
          "order",
          "family",
          "genus",
          "vernacularNames[0].vernacularName"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "search_species",
      "description_for_ai": "Search GBIF species by name, kingdom, rank.",
      "intent": [
        "search species",
        "find species GBIF",
        "taxonomic search"
      ],
      "endpoint": "GET https://api.gbif.org/v1/species/search",
      "input": {
        "q": {
          "type": "string",
          "required": false
        },
        "kingdom": {
          "type": "string",
          "description": "ANIMALIA, PLANTAE, FUNGI, BACTERIA, ARCHAEA",
          "required": false
        },
        "rank": {
          "type": "string",
          "description": "SPECIES, GENUS, FAMILY, ORDER, CLASS, PHYLUM, KINGDOM",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<species>",
        "fields": [
          "results[0].key",
          "results[0].scientificName",
          "results[0].rank",
          "results[0].kingdom"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_vernacular_names",
      "description_for_ai": "Get vernacular (common) names for a species in multiple languages.",
      "intent": [
        "common name species",
        "vernacular name",
        "popular name animal"
      ],
      "endpoint": "GET https://api.gbif.org/v1/species/{key}/vernacularNames",
      "input": {
        "key": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "list<name>",
        "fields": [
          "results[0].vernacularName",
          "results[0].language",
          "results[0].source"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}