{
  "apia": "1.0",
  "service": {
    "id": "serpapi",
    "name": "SerpAPI — Search Engine Results API",
    "description_for_ai": "Scrape Google, Bing, Yahoo, DuckDuckGo, Baidu search results programmatically. JSON results from any search engine. Also: Google Maps, Shopping, Jobs, News, Images. 100 free searches/month.",
    "url": "https://serpapi.com",
    "api_base": "https://serpapi.com/search",
    "category": "business",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://serpapi.com/search-api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "api_key",
    "param_location": "query",
    "how_to_get": "Register at https://serpapi.com",
    "cost": "Free: 100/month. Basic: $50/month 5000 searches"
  },
  "capabilities": [
    {
      "id": "google_search",
      "description_for_ai": "Scrape Google search results. Organic, knowledge panel, featured snippets, related searches.",
      "intent": [
        "Google search API",
        "SERP data",
        "search results",
        "результаты поиска Google SerpAPI"
      ],
      "endpoint": "GET https://serpapi.com/search",
      "input": {
        "q": {
          "type": "string",
          "description": "Search query",
          "required": true
        },
        "engine": {
          "type": "string",
          "description": "google, bing, duckduckgo, yahoo, youtube, google_news, google_images",
          "default": "google"
        },
        "location": {
          "type": "string",
          "description": "Location: 'Austin, Texas, United States', 'Moscow, Russia'",
          "required": false
        },
        "gl": {
          "type": "string",
          "description": "Country code: us, ru, gb, de",
          "required": false
        },
        "hl": {
          "type": "string",
          "description": "Language: en, ru, de",
          "required": false
        },
        "num": {
          "type": "integer",
          "description": "Number of results 10-100",
          "default": 10
        }
      },
      "output": {
        "type": "serp",
        "fields": [
          "organic_results[0].position",
          "organic_results[0].title",
          "organic_results[0].link",
          "organic_results[0].snippet",
          "knowledge_graph.title",
          "answer_box.answer"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "google_news",
      "description_for_ai": "Get Google News search results for a topic.",
      "intent": [
        "Google news search",
        "news results",
        "news API",
        "новости Google"
      ],
      "endpoint": "GET https://serpapi.com/search",
      "input": {
        "q": {
          "type": "string",
          "required": true
        },
        "engine": {
          "type": "string",
          "default": "google_news"
        },
        "gl": {
          "type": "string",
          "required": false
        },
        "hl": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "news",
        "fields": [
          "news_results[0].title",
          "news_results[0].link",
          "news_results[0].source",
          "news_results[0].date",
          "news_results[0].snippet"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "google_images",
      "description_for_ai": "Get Google Images search results with thumbnail URLs.",
      "intent": [
        "image search API",
        "Google images",
        "search images",
        "поиск изображений Google"
      ],
      "endpoint": "GET https://serpapi.com/search",
      "input": {
        "q": {
          "type": "string",
          "required": true
        },
        "engine": {
          "type": "string",
          "default": "google_images"
        },
        "ijn": {
          "type": "integer",
          "description": "Page number (0=first)",
          "default": 0
        }
      },
      "output": {
        "type": "images",
        "fields": [
          "images_results[0].title",
          "images_results[0].original",
          "images_results[0].thumbnail",
          "images_results[0].source"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "youtube_search",
      "description_for_ai": "Search YouTube videos via SerpApi.",
      "intent": [
        "YouTube search API",
        "YouTube results",
        "video search",
        "поиск YouTube SerpAPI"
      ],
      "endpoint": "GET https://serpapi.com/search",
      "input": {
        "q": {
          "type": "string",
          "required": true
        },
        "engine": {
          "type": "string",
          "default": "youtube"
        },
        "sp": {
          "type": "string",
          "description": "YouTube filter parameter",
          "required": false
        }
      },
      "output": {
        "type": "list<video>",
        "fields": [
          "video_results[0].title",
          "video_results[0].link",
          "video_results[0].snippet",
          "video_results[0].views",
          "video_results[0].length"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "google_shopping",
      "description_for_ai": "Search Google Shopping for product listings with prices.",
      "intent": [
        "Google shopping",
        "product search",
        "price comparison",
        "цены на товары Google"
      ],
      "endpoint": "GET https://serpapi.com/search",
      "input": {
        "q": {
          "type": "string",
          "required": true
        },
        "engine": {
          "type": "string",
          "default": "google_shopping"
        },
        "gl": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<product>",
        "fields": [
          "shopping_results[0].title",
          "shopping_results[0].price",
          "shopping_results[0].source",
          "shopping_results[0].link",
          "shopping_results[0].rating"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}