{
  "apia": "1.0",
  "service": {
    "id": "serpapi",
    "name": "SerpAPI — Search Engine Results API",
    "description_for_ai": "Scrape Google, Bing, Yahoo, DuckDuckGo, Baidu search results programmatically. JSON results from any search engine. Also: Google Maps, Shopping, Jobs, News, Images. 100 free searches/month.",
    "url": "https://serpapi.com",
    "api_base": "https://serpapi.com/search",
    "category": "business",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://serpapi.com/search-api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "api_key",
    "param_location": "query",
    "how_to_get": "Register at https://serpapi.com",
    "cost": "Free: 100/month. Basic: $50/month 5000 searches"
  },
  "capabilities": [
    {
      "id": "google_search",
      "description_for_ai": "Scrape Google search results: organic results, ads, featured snippets, knowledge panels.",
      "intent": [
        "google search results",
        "SERP data",
        "search scraping",
        "результаты google поиск"
      ],
      "endpoint": "GET https://serpapi.com/search",
      "input": {
        "engine": {
          "type": "string",
          "default": "google"
        },
        "q": {
          "type": "string",
          "description": "Search query",
          "required": true
        },
        "gl": {
          "type": "string",
          "description": "Country code: us, ru, de, gb",
          "default": "us"
        },
        "hl": {
          "type": "string",
          "description": "Language: en, ru, de",
          "default": "en"
        },
        "num": {
          "type": "integer",
          "description": "Results per page 10-100",
          "default": 10
        },
        "location": {
          "type": "string",
          "description": "Geolocation: 'Austin, Texas, United States'",
          "required": false
        },
        "device": {
          "type": "string",
          "description": "desktop, tablet, mobile",
          "default": "desktop"
        }
      },
      "output": {
        "type": "search_results",
        "fields": [
          "organic_results[0].position",
          "organic_results[0].title",
          "organic_results[0].link",
          "organic_results[0].snippet",
          "answer_box.answer",
          "knowledge_graph.title"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "google_maps_search",
      "description_for_ai": "Scrape Google Maps local business results with ratings, reviews, and contact info.",
      "intent": [
        "google maps results",
        "local business search",
        "maps scraping",
        "поиск google maps serpapi"
      ],
      "endpoint": "GET https://serpapi.com/search",
      "input": {
        "engine": {
          "type": "string",
          "default": "google_maps"
        },
        "q": {
          "type": "string",
          "required": true
        },
        "ll": {
          "type": "string",
          "description": "Coordinates: @40.7455096,-74.0083012,15.1z",
          "required": false
        },
        "type": {
          "type": "string",
          "description": "search or place",
          "default": "search"
        }
      },
      "output": {
        "type": "maps_results",
        "fields": [
          "local_results[0].title",
          "local_results[0].rating",
          "local_results[0].reviews",
          "local_results[0].address",
          "local_results[0].phone"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "google_shopping",
      "description_for_ai": "Scrape Google Shopping results with prices, stores, and product details.",
      "intent": [
        "google shopping",
        "product prices",
        "price comparison",
        "цены google shopping"
      ],
      "endpoint": "GET https://serpapi.com/search",
      "input": {
        "engine": {
          "type": "string",
          "default": "google_shopping"
        },
        "q": {
          "type": "string",
          "required": true
        },
        "gl": {
          "type": "string",
          "default": "us"
        },
        "hl": {
          "type": "string",
          "default": "en"
        }
      },
      "output": {
        "type": "shopping_results",
        "fields": [
          "shopping_results[0].title",
          "shopping_results[0].price",
          "shopping_results[0].source",
          "shopping_results[0].link",
          "shopping_results[0].rating"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "google_news",
      "description_for_ai": "Scrape Google News search results for a keyword.",
      "intent": [
        "google news serpapi",
        "news search results",
        "news SERP",
        "новости google serpapi"
      ],
      "endpoint": "GET https://serpapi.com/search",
      "input": {
        "engine": {
          "type": "string",
          "default": "google_news"
        },
        "q": {
          "type": "string",
          "required": true
        },
        "gl": {
          "type": "string",
          "required": false
        },
        "hl": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "news_results",
        "fields": [
          "news_results[0].title",
          "news_results[0].link",
          "news_results[0].source.name",
          "news_results[0].date",
          "news_results[0].snippet"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}