{
  "apia": "1.0",
  "service": {
    "id": "serpapi",
    "name": "SerpAPI — Search Engine Results API",
    "description_for_ai": "Scrape Google, Bing, Yahoo, DuckDuckGo, Baidu search results programmatically. JSON results from any search engine. Also: Google Maps, Shopping, Jobs, News, Images. 100 free searches/month.",
    "url": "https://serpapi.com",
    "api_base": "https://serpapi.com/search",
    "category": "business",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://serpapi.com/search-api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "api_key",
    "param_location": "query",
    "how_to_get": "Register at https://serpapi.com",
    "cost": "Free: 100/month. Basic: $50/month 5000 searches"
  },
  "capabilities": [
    {
      "id": "google_search",
      "description_for_ai": "Search Google and get structured results: organic, featured snippets, ads, knowledge graph.",
      "intent": [
        "google search api",
        "search results",
        "google scraping",
        "serpapi search",
        "результаты google"
      ],
      "endpoint": "GET https://serpapi.com/search",
      "input": {
        "engine": {
          "type": "string",
          "default": "google"
        },
        "q": {
          "type": "string",
          "required": true
        },
        "location": {
          "type": "string",
          "description": "Austin, Texas, United States",
          "required": false
        },
        "hl": {
          "type": "string",
          "description": "Language: en, ru, de",
          "default": "en"
        },
        "gl": {
          "type": "string",
          "description": "Country: us, ru, de",
          "default": "us"
        },
        "num": {
          "type": "integer",
          "description": "Results count 1-100",
          "default": 10
        }
      },
      "output": {
        "type": "search_results",
        "fields": [
          "organic_results[0].title",
          "organic_results[0].link",
          "organic_results[0].snippet",
          "knowledge_graph.title",
          "answer_box.answer",
          "shopping_results"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "google_maps_search",
      "description_for_ai": "Search Google Maps for local businesses and places via SerpAPI.",
      "intent": [
        "google maps search",
        "local business search",
        "places google",
        "поиск места google maps"
      ],
      "endpoint": "GET https://serpapi.com/search",
      "input": {
        "engine": {
          "type": "string",
          "default": "google_maps"
        },
        "q": {
          "type": "string",
          "required": true
        },
        "ll": {
          "type": "string",
          "description": "@latitude,longitude,zoom e.g. @40.7455096,-74.0083012,14z",
          "required": false
        },
        "type": {
          "type": "string",
          "description": "search or place",
          "default": "search"
        }
      },
      "output": {
        "type": "list<place>",
        "fields": [
          "local_results[0].title",
          "local_results[0].rating",
          "local_results[0].reviews",
          "local_results[0].address",
          "local_results[0].phone"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "google_news",
      "description_for_ai": "Get Google News results for a topic or query.",
      "intent": [
        "google news api",
        "news search",
        "latest news serpapi",
        "новости google"
      ],
      "endpoint": "GET https://serpapi.com/search",
      "input": {
        "engine": {
          "type": "string",
          "default": "google_news"
        },
        "q": {
          "type": "string",
          "required": true
        },
        "hl": {
          "type": "string",
          "default": "en"
        },
        "gl": {
          "type": "string",
          "default": "us"
        },
        "num": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<news>",
        "fields": [
          "news_results[0].title",
          "news_results[0].link",
          "news_results[0].source.name",
          "news_results[0].date"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "google_shopping",
      "description_for_ai": "Search Google Shopping for products with prices and merchants.",
      "intent": [
        "google shopping",
        "product search",
        "price comparison",
        "цены google shopping"
      ],
      "endpoint": "GET https://serpapi.com/search",
      "input": {
        "engine": {
          "type": "string",
          "default": "google_shopping"
        },
        "q": {
          "type": "string",
          "required": true
        },
        "gl": {
          "type": "string",
          "default": "us"
        },
        "hl": {
          "type": "string",
          "default": "en"
        },
        "num": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<product>",
        "fields": [
          "shopping_results[0].title",
          "shopping_results[0].price",
          "shopping_results[0].source",
          "shopping_results[0].link",
          "shopping_results[0].rating"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "youtube_search",
      "description_for_ai": "Search YouTube videos via SerpAPI and get structured results.",
      "intent": [
        "youtube search serpapi",
        "video search",
        "find youtube videos",
        "поиск youtube через api"
      ],
      "endpoint": "GET https://serpapi.com/search",
      "input": {
        "engine": {
          "type": "string",
          "default": "youtube"
        },
        "search_query": {
          "type": "string",
          "required": true
        },
        "gl": {
          "type": "string",
          "default": "us"
        },
        "hl": {
          "type": "string",
          "default": "en"
        }
      },
      "output": {
        "type": "list<video>",
        "fields": [
          "video_results[0].title",
          "video_results[0].link",
          "video_results[0].views",
          "video_results[0].channel.name",
          "video_results[0].published_date"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}