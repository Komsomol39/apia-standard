{
  "apia": "1.0",
  "service": {
    "id": "serpapi",
    "name": "SerpAPI — Search Engine Results API",
    "description_for_ai": "Scrape Google, Bing, Yahoo, DuckDuckGo, Baidu search results programmatically. JSON results from any search engine. Also: Google Maps, Shopping, Jobs, News, Images. 100 free searches/month.",
    "url": "https://serpapi.com",
    "api_base": "https://serpapi.com/search",
    "category": "search_scraping",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://serpapi.com/search-api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "api_key",
    "param_location": "query",
    "how_to_get": "Register at https://serpapi.com",
    "cost": "Free: 100/month. Basic: $50/month 5000 searches"
  },
  "capabilities": [
    {
      "id": "google_search",
      "description_for_ai": "Search Google and get structured results: organic links, featured snippets, People Also Ask, Knowledge Panel. Use for web research, SEO analysis, competitive intelligence.",
      "intent": [
        "google search",
        "web search results",
        "search the web",
        "find information",
        "SERP data",
        "SEO research"
      ],
      "endpoint": "GET https://serpapi.com/search",
      "input": {
        "engine": {
          "type": "string",
          "default": "google"
        },
        "q": {
          "type": "string",
          "description": "Search query",
          "required": true
        },
        "location": {
          "type": "string",
          "description": "Target location e.g. New York,United States",
          "required": false
        },
        "gl": {
          "type": "string",
          "description": "Country code: us, ru, de, gb",
          "required": false
        },
        "hl": {
          "type": "string",
          "description": "Language: en, ru, de, fr",
          "default": "en"
        },
        "num": {
          "type": "integer",
          "description": "Number of results 10-100",
          "default": 10
        }
      },
      "output": {
        "type": "search_results",
        "fields": [
          "organic_results[0].title",
          "organic_results[0].link",
          "organic_results[0].snippet",
          "answer_box.answer",
          "knowledge_graph.title",
          "related_questions[0].question"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "google_maps_search",
      "description_for_ai": "Search Google Maps for businesses, places, restaurants by query and location.",
      "intent": [
        "google maps search",
        "find places",
        "restaurants near",
        "business search",
        "local search"
      ],
      "endpoint": "GET https://serpapi.com/search",
      "input": {
        "engine": {
          "type": "string",
          "default": "google_maps"
        },
        "q": {
          "type": "string",
          "required": true
        },
        "ll": {
          "type": "string",
          "description": "GPS coordinates @lat,lng,zoom e.g. @40.7455096,-74.0083012,14z",
          "required": false
        },
        "type": {
          "type": "string",
          "description": "search or place",
          "default": "search"
        }
      },
      "output": {
        "type": "list<place>",
        "fields": [
          "local_results[0].title",
          "local_results[0].rating",
          "local_results[0].reviews",
          "local_results[0].address",
          "local_results[0].hours",
          "local_results[0].phone"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}