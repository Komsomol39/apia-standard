{
  "apia": "1.0",
  "service": {
    "id": "yandex-disk",
    "name": "Яндекс.Диск API",
    "description_for_ai": "Облачное хранилище Яндекса. Загрузка, скачивание, управление файлами и папками. 10 ГБ бесплатно. Интеграция с экосистемой Яндекса. Популярно в России как альтернатива Google Drive.",
    "url": "https://disk.yandex.ru",
    "api_base": "https://cloud-api.yandex.net/v1/disk",
    "category": "devtools",
    "geo": [
      "RU",
      "GLOBAL"
    ],
    "language": "ru",
    "docs": "https://yandex.ru/dev/disk/api/"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "OAuth токен через https://oauth.yandex.ru",
    "cost": "Бесплатно: 10 ГБ. Платно: от 99 руб/мес за 100 ГБ"
  },
  "capabilities": [
    {
      "id": "get_disk_info",
      "description_for_ai": "Get Яндекс.Диск quota info: total space, used space, trash size, and system folder paths.",
      "intent": [
        "место на диске",
        "свободное место Яндекс Диск",
        "информация о диске"
      ],
      "endpoint": "GET https://cloud-api.yandex.net/v1/disk",
      "input": {
        "fields": {
          "type": "string",
          "description": "Comma-separated fields to return: is_paid, revision, trash_size, total_space, used_space, system_folders",
          "required": false
        }
      },
      "output": {
        "type": "disk",
        "fields": [
          "total_space",
          "used_space",
          "trash_size",
          "system_folders"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "upload_file",
      "description_for_ai": "Get a pre-signed upload URL for uploading a file to Яндекс.Диск. Then PUT the file to the returned href URL.",
      "intent": [
        "загрузить файл",
        "сохранить на Яндекс Диск",
        "upload Яндекс",
        "хранение файлов Россия"
      ],
      "endpoint": "GET https://cloud-api.yandex.net/v1/disk/resources/upload",
      "input": {
        "path": {
          "type": "string",
          "description": "Destination path on disk, e.g. /Загрузки/report.pdf. Create folders first with /resources if needed.",
          "required": true
        },
        "overwrite": {
          "type": "boolean",
          "description": "Overwrite if file exists",
          "default": false
        }
      },
      "output": {
        "type": "upload",
        "fields": [
          "href",
          "method",
          "templated"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_files",
      "description_for_ai": "List files and folders at a path on Яндекс.Диск. Returns metadata: name, type, size, modified date, download URL.",
      "intent": [
        "список файлов",
        "файлы на диске",
        "мои файлы Яндекс"
      ],
      "endpoint": "GET https://cloud-api.yandex.net/v1/disk/resources",
      "input": {
        "path": {
          "type": "string",
          "description": "Путь к папке, например /Документы",
          "default": "/"
        },
        "limit": {
          "type": "integer",
          "default": 20,
          "description": "Maximum number of results to return"
        },
        "offset": {
          "type": "integer",
          "default": 0,
          "description": "Number of records to skip for pagination"
        }
      },
      "output": {
        "type": "resources",
        "fields": [
          "_embedded.items[0].name",
          "_embedded.items[0].type",
          "_embedded.items[0].size",
          "_embedded.items[0].modified"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_folder",
      "description_for_ai": "Create a new folder on Yandex.Disk.",
      "intent": [
        "создать папку яндекс диск",
        "new folder yandex disk",
        "mkdir yandex disk"
      ],
      "endpoint": "PUT https://cloud-api.yandex.net/v1/disk/resources",
      "input": {
        "path": {
          "type": "string",
          "description": "Path for new folder e.g. disk:/MyFolder",
          "required": true
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "201 Created with Location header"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_download_link",
      "description_for_ai": "Get a direct download link for a file on Yandex.Disk.",
      "intent": [
        "скачать файл яндекс диск",
        "download link yandex",
        "ссылка на файл"
      ],
      "endpoint": "GET https://cloud-api.yandex.net/v1/disk/resources/download",
      "input": {
        "path": {
          "type": "string",
          "description": "File path on disk",
          "required": true
        }
      },
      "output": {
        "type": "link",
        "fields": [
          "href (direct download URL)",
          "method",
          "templated"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "upload_flow": "1) GET /disk/resources/upload?path=... to get upload URL. 2) PUT file binary to returned href. 3) Verify with GET /disk/resources?path=...",
    "path_encoding": "Paths must be URL-encoded. Use /disk as root. All paths start with /.",
    "quota": "Free: 10GB. Paid from 99 RUB/month for 100GB."
  }
}