{
  "apia": "1.0",
  "service": {
    "id": "datadog",
    "name": "Datadog API",
    "description_for_ai": "Cloud monitoring and observability platform. Metrics, logs, traces, dashboards, alerts. Monitor infrastructure, applications, databases. Used by 27K+ companies. Use for infrastructure monitoring, alerting, log analysis.",
    "url": "https://datadoghq.com",
    "api_base": "https://api.datadoghq.com/api/v1",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.datadoghq.com/api/latest/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "DD-API-KEY + DD-APPLICATION-KEY",
    "how_to_get": "Organization Settings → API Keys",
    "cost": "Free 14-day trial. Pro: $15/host/month"
  },
  "capabilities": [
    {
      "id": "submit_metrics",
      "description_for_ai": "Send custom metrics to Datadog for monitoring dashboards and alerts.",
      "intent": [
        "send metrics datadog",
        "custom metrics",
        "monitoring data",
        "метрики datadog"
      ],
      "endpoint": "POST https://api.datadoghq.com/api/v2/series",
      "input": {
        "series": {
          "type": "array",
          "description": "[{metric: 'app.requests', points: [{timestamp: 1609459200, value: 42.0}], type: 1, tags: ['env:prod', 'service:api'], unit: 'request', host: 'server-01'}]. Types: 0=unspecified, 1=count, 2=rate, 3=gauge",
          "required": true
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "errors"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "query_metrics",
      "description_for_ai": "Query Datadog metrics for dashboards, analysis, or alerting.",
      "intent": [
        "query metrics datadog",
        "get metrics",
        "datadog data",
        "данные мониторинга datadog"
      ],
      "endpoint": "GET https://api.datadoghq.com/api/v1/query",
      "input": {
        "from": {
          "type": "integer",
          "description": "Unix timestamp start",
          "required": true
        },
        "to": {
          "type": "integer",
          "description": "Unix timestamp end",
          "required": true
        },
        "query": {
          "type": "string",
          "description": "Datadog query e.g. avg:system.cpu.user{*} or sum:app.requests{env:prod}",
          "required": true
        }
      },
      "output": {
        "type": "timeseries",
        "fields": [
          "series[0].metric",
          "series[0].pointlist",
          "series[0].scope"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "create_event",
      "description_for_ai": "Create a Datadog event: deployment marker, incident note, alert.",
      "intent": [
        "datadog event",
        "deployment event",
        "incident datadog",
        "событие datadog"
      ],
      "endpoint": "POST https://api.datadoghq.com/api/v1/events",
      "input": {
        "title": {
          "type": "string",
          "required": true
        },
        "text": {
          "type": "string",
          "required": true
        },
        "tags": {
          "type": "array",
          "description": "['env:prod', 'version:1.2.3']",
          "required": false
        },
        "alert_type": {
          "type": "string",
          "description": "info, warning, error, success",
          "default": "info"
        },
        "source_type_name": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "event",
        "fields": [
          "event.id",
          "event.title",
          "event.url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_logs",
      "description_for_ai": "Search and retrieve logs from Datadog Log Management.",
      "intent": [
        "search logs datadog",
        "application logs",
        "error logs",
        "логи datadog"
      ],
      "endpoint": "POST https://api.datadoghq.com/api/v2/logs/events/search",
      "input": {
        "filter": {
          "type": "object",
          "description": "{query: 'service:api status:error', from: '2024-01-15T00:00:00Z', to: '2024-01-15T23:59:59Z'}",
          "required": false
        },
        "page": {
          "type": "object",
          "description": "{limit: 100}",
          "required": false
        },
        "sort": {
          "type": "string",
          "description": "timestamp or -timestamp",
          "default": "-timestamp"
        }
      },
      "output": {
        "type": "list<log>",
        "fields": [
          "data[0].attributes.message",
          "data[0].attributes.service",
          "data[0].attributes.status",
          "data[0].attributes.timestamp"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "api_app_keys": "Need both API key (DD-API-KEY header) and Application key (DD-APPLICATION-KEY header). API key for sending data, App key for querying.",
    "site": "EU customers: use api.datadoghq.eu instead of api.datadoghq.com",
    "metrics_format": "Metric names: lowercase, dots and underscores ok. E.g. myapp.api.response_time",
    "tags": "Always add env, service, version tags: ['env:prod', 'service:api', 'version:1.2.3']"
  }
}