{"apia":"1.0","service":{"id":"datadog","name":"Datadog API","description_for_ai":"Cloud monitoring and observability platform. Metrics, logs, traces, dashboards, alerts. Monitor infrastructure, applications, databases. Used by 27K+ companies. Use for infrastructure monitoring, alerting, log analysis.","url":"https://datadoghq.com","api_base":"https://api.datadoghq.com/api/v1","category":"developer_monitoring","geo":["GLOBAL"],"language":"en","docs":"https://docs.datadoghq.com/api/latest/"},"auth":{"type":"apikey","anonymous_access":false,"header":"DD-API-KEY + DD-APPLICATION-KEY","how_to_get":"Organization Settings → API Keys","cost":"Free 14-day trial. Pro: $15/host/month"},"capabilities":[{"id":"submit_metrics","description_for_ai":"Send custom metrics to Datadog for monitoring and alerting.","intent":["send metrics","monitor service","track performance","submit data","custom metrics"],"endpoint":"POST https://api.datadoghq.com/api/v1/series","input":{"series":{"type":"array","description":"[{metric: my.metric, points: [[timestamp, value]], tags: [env:prod]}]","required":true}},"output":{"type":"success","fields":["status"]},"realtime":true,"requires_auth":true},{"id":"query_metrics","description_for_ai":"Query historical metrics data with aggregation. Get timeseries for dashboards and analysis.","intent":["query metrics","get performance data","monitoring data","timeseries","infrastructure metrics"],"endpoint":"GET https://api.datadoghq.com/api/v1/query","input":{"from":{"type":"integer","description":"Unix timestamp start","required":true},"to":{"type":"integer","description":"Unix timestamp end","required":true},"query":{"type":"string","description":"Datadog query e.g. avg:system.cpu.user{host:web01}","required":true}},"output":{"type":"timeseries","fields":["series[0].metric","series[0].pointlist","series[0].scope"]},"realtime":false,"requires_auth":true},{"id":"create_event","description_for_ai":"Post event to Datadog event stream. Use for deployment tracki