{
  "apia": "1.0",
  "service": {
    "id": "datadog",
    "name": "Datadog API",
    "description_for_ai": "Cloud monitoring and observability platform. Metrics, logs, traces, dashboards, alerts. Monitor infrastructure, applications, databases. Used by 27K+ companies. Use for infrastructure monitoring, alerting, log analysis.",
    "url": "https://datadoghq.com",
    "api_base": "https://api.datadoghq.com/api/v1",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.datadoghq.com/api/latest/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "DD-API-KEY + DD-APPLICATION-KEY",
    "how_to_get": "Organization Settings → API Keys",
    "cost": "Free 14-day trial. Pro: $15/host/month"
  },
  "capabilities": [
    {
      "id": "submit_metrics",
      "description_for_ai": "Send custom metrics to Datadog for monitoring and dashboards.",
      "intent": [
        "send metrics datadog",
        "custom metrics",
        "monitoring data",
        "метрики datadog"
      ],
      "endpoint": "POST https://api.datadoghq.com/api/v2/series",
      "input": {
        "series": {
          "type": "array",
          "description": "[{metric: 'myapp.requests', type: 0 (unspecified)|1 (count)|2 (rate)|3 (gauge), points: [{timestamp: 1234567890, value: 42.0}], tags: ['env:prod', 'service:api']}]",
          "required": true
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "errors"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "query_metrics",
      "description_for_ai": "Query metric time series data with aggregation functions.",
      "intent": [
        "query datadog metrics",
        "metric data",
        "graph data",
        "данные метрик datadog"
      ],
      "endpoint": "GET https://api.datadoghq.com/api/v1/query",
      "input": {
        "from": {
          "type": "integer",
          "description": "Unix timestamp for start",
          "required": true
        },
        "to": {
          "type": "integer",
          "description": "Unix timestamp for end",
          "required": true
        },
        "query": {
          "type": "string",
          "description": "Datadog metric query: avg:system.cpu.user{*}, sum:myapp.errors{env:prod}.rollup(sum, 60)",
          "required": true
        }
      },
      "output": {
        "type": "series",
        "fields": [
          "series[0].metric",
          "series[0].pointlist (array of [timestamp, value] pairs)",
          "series[0].scope",
          "status"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "create_monitor",
      "description_for_ai": "Create an alert monitor that triggers when metrics cross thresholds.",
      "intent": [
        "datadog alert",
        "create monitor",
        "metric alert",
        "алерт datadog"
      ],
      "endpoint": "POST https://api.datadoghq.com/api/v1/monitor",
      "input": {
        "type": {
          "type": "string",
          "description": "metric alert, service check, event alert, log alert, composite",
          "required": true
        },
        "query": {
          "type": "string",
          "description": "e.g. avg(last_5m):avg:system.cpu.user{*} > 90",
          "required": true
        },
        "name": {
          "type": "string",
          "description": "Monitor name",
          "required": true
        },
        "message": {
          "type": "string",
          "description": "Alert notification message with @mentions: @slack-channel @user@example.com",
          "required": false
        },
        "thresholds": {
          "type": "object",
          "description": "{critical: 90, warning: 80, ok: 70}",
          "required": false
        },
        "tags": {
          "type": "array",
          "description": "Monitor tags",
          "required": false
        }
      },
      "output": {
        "type": "monitor",
        "fields": [
          "id",
          "name",
          "status",
          "created",
          "org_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_logs",
      "description_for_ai": "Search and filter application logs in Datadog.",
      "intent": [
        "datadog logs",
        "search logs",
        "log query",
        "поиск логов datadog"
      ],
      "endpoint": "POST https://api.datadoghq.com/api/v2/logs/events/search",
      "input": {
        "filter": {
          "type": "object",
          "description": "{query: 'service:api status:error', from: '2024-01-15T00:00:00Z', to: '2024-01-15T23:59:59Z', indexes: ['main']}",
          "required": true
        },
        "page": {
          "type": "object",
          "description": "{limit: 25}",
          "required": false
        },
        "sort": {
          "type": "string",
          "description": "timestamp or -timestamp (newest first)",
          "default": "-timestamp"
        }
      },
      "output": {
        "type": "logs",
        "fields": [
          "data[0].id",
          "data[0].attributes.message",
          "data[0].attributes.status",
          "data[0].attributes.service",
          "data[0].attributes.timestamp"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "api_app_keys": "Need both API key (DD-API-KEY header) and Application key (DD-APPLICATION-KEY header). API key for sending data, App key for querying.",
    "site": "EU customers: use api.datadoghq.eu instead of api.datadoghq.com",
    "metrics_format": "Metric names: lowercase, dots and underscores ok. E.g. myapp.api.response_time",
    "tags": "Always add env, service, version tags: ['env:prod', 'service:api', 'version:1.2.3']"
  }
}