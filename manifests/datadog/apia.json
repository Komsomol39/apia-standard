{
  "apia": "1.0",
  "service": {
    "id": "datadog",
    "name": "Datadog API",
    "description_for_ai": "Cloud monitoring and observability platform. Metrics, logs, traces, dashboards, alerts. Monitor infrastructure, applications, databases. Used by 27K+ companies. Use for infrastructure monitoring, alerting, log analysis.",
    "url": "https://datadoghq.com",
    "api_base": "https://api.datadoghq.com/api/v1",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.datadoghq.com/api/latest/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "DD-API-KEY + DD-APPLICATION-KEY",
    "how_to_get": "Organization Settings → API Keys",
    "cost": "Free 14-day trial. Pro: $15/host/month"
  },
  "capabilities": [
    {
      "id": "query_metrics",
      "description_for_ai": "Query time series metrics from Datadog. Get CPU, memory, requests per second, latency, and custom metrics.",
      "intent": [
        "Datadog metrics",
        "query metrics",
        "server monitoring",
        "performance data",
        "метрики Datadog"
      ],
      "endpoint": "GET https://api.datadoghq.com/api/v1/query",
      "input": {
        "from": {
          "type": "integer",
          "description": "Unix timestamp start",
          "required": true
        },
        "to": {
          "type": "integer",
          "description": "Unix timestamp end",
          "required": true
        },
        "query": {
          "type": "string",
          "description": "Datadog metric query: avg:system.cpu.user{host:web01}, sum:http.requests{service:api}.rollup(sum, 60)",
          "required": true
        }
      },
      "output": {
        "type": "timeseries",
        "fields": [
          "series[0].metric",
          "series[0].pointlist [[timestamp, value], ...]",
          "series[0].scope"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_event",
      "description_for_ai": "Create a Datadog event to mark deployments, alerts, or milestones.",
      "intent": [
        "Datadog event",
        "deployment marker",
        "incident event",
        "событие Datadog"
      ],
      "endpoint": "POST https://api.datadoghq.com/api/v1/events",
      "input": {
        "title": {
          "type": "string",
          "required": true
        },
        "text": {
          "type": "string",
          "description": "Event description. Supports markdown.",
          "required": true
        },
        "tags": {
          "type": "array",
          "description": "['env:prod', 'service:api', 'team:backend']",
          "required": false
        },
        "alert_type": {
          "type": "string",
          "description": "error, warning, info, success, user_update, recommendation, snapshot",
          "default": "info"
        },
        "priority": {
          "type": "string",
          "description": "normal or low",
          "default": "normal"
        },
        "host": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "event",
        "fields": [
          "event.id",
          "event.url",
          "status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_monitors",
      "description_for_ai": "List all Datadog monitors (alerts) and their current status.",
      "intent": [
        "Datadog monitors",
        "list alerts",
        "alert status",
        "мониторы Datadog"
      ],
      "endpoint": "GET https://api.datadoghq.com/api/v1/monitor",
      "input": {
        "tags": {
          "type": "string",
          "description": "Filter by tags: env:prod,service:api",
          "required": false
        },
        "monitor_tags": {
          "type": "string",
          "description": "Filter monitors by their tags",
          "required": false
        },
        "name": {
          "type": "string",
          "description": "Search by name",
          "required": false
        }
      },
      "output": {
        "type": "list<monitor>",
        "fields": [
          "[0].id",
          "[0].name",
          "[0].type",
          "[0].overall_state",
          "[0].tags"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_logs",
      "description_for_ai": "Search application logs in Datadog. Filter by service, status, time range.",
      "intent": [
        "search logs Datadog",
        "application logs",
        "error logs",
        "поиск логов Datadog"
      ],
      "endpoint": "POST https://api.datadoghq.com/api/v2/logs/events/search",
      "input": {
        "filter": {
          "type": "object",
          "description": "{query: 'service:api status:error', from: '2024-01-15T00:00:00Z', to: '2024-01-15T23:59:59Z'}",
          "required": true
        },
        "sort": {
          "type": "string",
          "description": "timestamp or -timestamp",
          "default": "-timestamp"
        },
        "page": {
          "type": "object",
          "description": "{limit: 50}",
          "required": false
        }
      },
      "output": {
        "type": "list<log>",
        "fields": [
          "data[0].id",
          "data[0].attributes.timestamp",
          "data[0].attributes.service",
          "data[0].attributes.status",
          "data[0].attributes.message"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_dashboard",
      "description_for_ai": "Create a Datadog dashboard with metrics widgets.",
      "intent": [
        "create dashboard Datadog",
        "monitoring dashboard",
        "metrics dashboard",
        "дашборд Datadog"
      ],
      "endpoint": "POST https://api.datadoghq.com/api/v1/dashboard",
      "input": {
        "title": {
          "type": "string",
          "required": true
        },
        "layout_type": {
          "type": "string",
          "description": "ordered or free",
          "default": "ordered"
        },
        "widgets": {
          "type": "array",
          "description": "[{definition: {type: 'timeseries', requests: [{q: 'avg:system.cpu.user{*}', display_type: 'line'}], title: 'CPU Usage'}}]",
          "required": true
        },
        "description": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "dashboard",
        "fields": [
          "id",
          "url",
          "title",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_host_info",
      "description_for_ai": "Get host info and metadata from Datadog — tags, aliases, active integrations.",
      "intent": [
        "host info Datadog",
        "server details",
        "host metadata",
        "информация о хосте Datadog"
      ],
      "endpoint": "GET https://api.datadoghq.com/api/v1/hosts",
      "input": {
        "filter": {
          "type": "string",
          "description": "Filter by hostname or tag",
          "required": false
        },
        "sort_field": {
          "type": "string",
          "description": "status, apps, mute, name, last_reported_time",
          "required": false
        },
        "count": {
          "type": "integer",
          "default": 100
        }
      },
      "output": {
        "type": "hosts",
        "fields": [
          "host_list[0].name",
          "host_list[0].tags_by_source",
          "host_list[0].last_reported_time",
          "host_list[0].apps"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "api_app_keys": "Need both API key (DD-API-KEY header) and Application key (DD-APPLICATION-KEY header). API key for sending data, App key for querying.",
    "site": "EU customers: use api.datadoghq.eu instead of api.datadoghq.com",
    "metrics_format": "Metric names: lowercase, dots and underscores ok. E.g. myapp.api.response_time",
    "tags": "Always add env, service, version tags: ['env:prod', 'service:api', 'version:1.2.3']"
  }
}