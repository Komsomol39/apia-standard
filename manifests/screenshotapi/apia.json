{
  "apia": "1.0",
  "service": {
    "id": "screenshotapi",
    "name": "ScreenshotAPI",
    "description_for_ai": "Capture website screenshots via API. Full page, viewport, mobile/desktop. Convert URLs to PNG/JPEG/PDF. Used for website monitoring, thumbnails, content archiving. 100 screenshots/month free.",
    "url": "https://screenshotapi.net",
    "api_base": "https://shot.screenshotapi.net",
    "category": "utilities",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://screenshotapi.net/documentation"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "token",
    "param_location": "query",
    "how_to_get": "Register at https://screenshotapi.net",
    "cost": "Free: 100/month. Basic: $19/month 500 screenshots"
  },
  "capabilities": [
    {
      "id": "take_screenshot",
      "description_for_ai": "Take a screenshot of any website URL.",
      "intent": [
        "screenshot website",
        "capture webpage",
        "website thumbnail",
        "скриншот сайта"
      ],
      "endpoint": "GET https://shot.screenshotapi.net/screenshot",
      "input": {
        "url": {
          "type": "string",
          "description": "URL to screenshot",
          "required": true
        },
        "width": {
          "type": "integer",
          "default": 1920
        },
        "height": {
          "type": "integer",
          "default": 1080
        },
        "output": {
          "type": "string",
          "description": "image, base64, json",
          "default": "image"
        },
        "fresh": {
          "type": "boolean",
          "description": "Force fresh capture (not cached)",
          "default": false
        },
        "delay": {
          "type": "integer",
          "description": "Wait milliseconds after load",
          "default": 0
        }
      },
      "output": {
        "type": "image or json",
        "fields": [
          "Binary PNG image, or JSON with screenshot URL"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "screenshot_full_page",
      "description_for_ai": "Capture a full-page screenshot (including content below the fold).",
      "intent": [
        "full page screenshot",
        "long page capture",
        "scroll screenshot",
        "скриншот всей страницы"
      ],
      "endpoint": "GET https://shot.screenshotapi.net/screenshot",
      "input": {
        "url": {
          "type": "string",
          "required": true
        },
        "full_page": {
          "type": "boolean",
          "default": true
        },
        "output": {
          "type": "string",
          "default": "image"
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "Full-height PNG image"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "screenshot_mobile",
      "description_for_ai": "Take a mobile viewport screenshot of a website.",
      "intent": [
        "mobile screenshot",
        "phone view website",
        "responsive check",
        "мобильный скриншот"
      ],
      "endpoint": "GET https://shot.screenshotapi.net/screenshot",
      "input": {
        "url": {
          "type": "string",
          "required": true
        },
        "width": {
          "type": "integer",
          "default": 375
        },
        "height": {
          "type": "integer",
          "default": 812
        },
        "device_scale_factor": {
          "type": "number",
          "default": 2.0
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "Mobile viewport PNG image"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "screenshot_with_wait",
      "description_for_ai": "Take a screenshot after waiting for a specific element to load.",
      "intent": [
        "wait element screenshot",
        "dynamic page capture",
        "JavaScript screenshot",
        "скриншот динамической страницы"
      ],
      "endpoint": "GET https://shot.screenshotapi.net/screenshot",
      "input": {
        "url": {
          "type": "string",
          "required": true
        },
        "wait_for_event": {
          "type": "string",
          "description": "load, domcontentloaded, networkidle0, networkidle2",
          "default": "load"
        },
        "delay": {
          "type": "integer",
          "description": "Additional wait in ms",
          "default": 2000
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "PNG screenshot after rendering"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "pdf_export",
      "description_for_ai": "Export a webpage as a PDF document.",
      "intent": [
        "website to PDF",
        "webpage PDF",
        "print website",
        "сайт в PDF"
      ],
      "endpoint": "GET https://shot.screenshotapi.net/screenshot",
      "input": {
        "url": {
          "type": "string",
          "required": true
        },
        "output": {
          "type": "string",
          "default": "pdf"
        },
        "full_page": {
          "type": "boolean",
          "default": true
        }
      },
      "output": {
        "type": "pdf",
        "fields": [
          "Binary PDF document"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}