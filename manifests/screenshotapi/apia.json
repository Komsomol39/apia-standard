{
  "apia": "1.0",
  "service": {
    "id": "screenshotapi",
    "name": "ScreenshotAPI",
    "description_for_ai": "Capture website screenshots via API. Full page, viewport, mobile/desktop. Convert URLs to PNG/JPEG/PDF. Used for website monitoring, thumbnails, content archiving. 100 screenshots/month free.",
    "url": "https://screenshotapi.net",
    "api_base": "https://shot.screenshotapi.net",
    "category": "utilities",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://screenshotapi.net/documentation"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "token",
    "param_location": "query",
    "how_to_get": "Register at https://screenshotapi.net",
    "cost": "Free: 100/month. Basic: $19/month 500 screenshots"
  },
  "capabilities": [
    {
      "id": "take_screenshot",
      "description_for_ai": "Take a screenshot of any URL with customizable viewport.",
      "intent": [
        "screenshot URL",
        "web page screenshot",
        "website screenshot API",
        "скриншот сайта"
      ],
      "endpoint": "GET https://shot.screenshotapi.net/screenshot",
      "input": {
        "token": {
          "type": "string",
          "description": "API token",
          "required": true
        },
        "url": {
          "type": "string",
          "description": "URL to screenshot",
          "required": true
        },
        "width": {
          "type": "integer",
          "default": 1920
        },
        "height": {
          "type": "integer",
          "default": 1080
        },
        "output": {
          "type": "string",
          "description": "image or json",
          "default": "image"
        },
        "full_page": {
          "type": "boolean",
          "description": "Capture full page length",
          "default": false
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "PNG/JPEG screenshot binary or JSON with screenshot URL"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "mobile_screenshot",
      "description_for_ai": "Take a mobile device screenshot of a URL.",
      "intent": [
        "mobile screenshot",
        "responsive screenshot",
        "phone screenshot",
        "мобильный скриншот сайта"
      ],
      "endpoint": "GET https://shot.screenshotapi.net/screenshot",
      "input": {
        "token": {
          "type": "string",
          "required": true
        },
        "url": {
          "type": "string",
          "required": true
        },
        "width": {
          "type": "integer",
          "default": 390
        },
        "height": {
          "type": "integer",
          "default": 844
        },
        "user_agent": {
          "type": "string",
          "description": "Mobile UA string",
          "required": false
        },
        "delay": {
          "type": "integer",
          "description": "Wait ms before screenshot",
          "default": 0
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "Mobile viewport screenshot"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "pdf_from_url",
      "description_for_ai": "Convert a web page URL to PDF.",
      "intent": [
        "URL to PDF",
        "webpage PDF",
        "print page PDF",
        "PDF из URL"
      ],
      "endpoint": "GET https://shot.screenshotapi.net/screenshot",
      "input": {
        "token": {
          "type": "string",
          "required": true
        },
        "url": {
          "type": "string",
          "required": true
        },
        "output": {
          "type": "string",
          "default": "pdf"
        },
        "full_page": {
          "type": "boolean",
          "default": true
        }
      },
      "output": {
        "type": "pdf",
        "fields": [
          "PDF binary"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "screenshot_with_delay",
      "description_for_ai": "Take screenshot after waiting for JS rendering or animations.",
      "intent": [
        "delayed screenshot",
        "wait for JS",
        "dynamic content screenshot",
        "скриншот с задержкой"
      ],
      "endpoint": "GET https://shot.screenshotapi.net/screenshot",
      "input": {
        "token": {
          "type": "string",
          "required": true
        },
        "url": {
          "type": "string",
          "required": true
        },
        "delay": {
          "type": "integer",
          "description": "Wait in ms before capturing: 2000 for SPAs",
          "required": true
        },
        "lazy_load": {
          "type": "boolean",
          "description": "Scroll to load lazy images",
          "default": false
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "Screenshot after delay"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "batch_screenshots",
      "description_for_ai": "Take screenshots of multiple URLs efficiently.",
      "intent": [
        "batch screenshots",
        "multiple URLs screenshot",
        "bulk screenshots",
        "скриншоты пакетом"
      ],
      "endpoint": "GET https://shot.screenshotapi.net/screenshot",
      "input": {
        "token": {
          "type": "string",
          "required": true
        },
        "url": {
          "type": "string",
          "description": "URL to capture (call repeatedly for batch)",
          "required": true
        },
        "output": {
          "type": "string",
          "default": "json"
        }
      },
      "output": {
        "type": "json",
        "fields": [
          "screenshot (CDN URL to image)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}