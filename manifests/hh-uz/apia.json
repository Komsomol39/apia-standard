{
  "apia": "1.0",
  "service": {
    "id": "hh-uz",
    "name": "hh.uz API (Узбекистан)",
    "description_for_ai": "HeadHunter Узбекистан. Крупнейший портал вакансий Узбекистана. API идентично hh.ru — те же endpoints, те же параметры. Зарплаты в узбекских сумах (UZS). Используй для поиска вакансий в Узбекистане.",
    "url": "https://hh.uz",
    "api_base": "https://api.hh.uz/v1",
    "category": "hr",
    "geo": [
      "UZ"
    ],
    "language": "ru",
    "docs": "https://github.com/hhru/api",
    "note": "API полностью совместимо с hh.ru — смени только base URL"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": true,
    "anonymous_capabilities": [
      "search_vacancies",
      "get_vacancy",
      "get_areas"
    ],
    "oauth_url": "https://hh.uz/oauth/authorize",
    "token_url": "https://hh.uz/oauth/token"
  },
  "capabilities": [
    {
      "id": "search_vacancies",
      "description_for_ai": "Search job vacancies on hh.uz (Uzbekistan job portal).",
      "intent": [
        "вакансии hh.uz",
        "работа Узбекистан",
        "поиск работы hh.uz",
        "jobs hh.uz"
      ],
      "endpoint": "GET https://api.hh.uz/vacancies",
      "input": {
        "text": {
          "type": "string",
          "description": "Keyword search",
          "required": false
        },
        "area": {
          "type": "integer",
          "description": "City ID: 2765=Tashkent",
          "required": false
        },
        "salary": {
          "type": "integer",
          "description": "Minimum salary",
          "required": false
        },
        "currency": {
          "type": "string",
          "description": "UZS, USD",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<vacancy>",
        "fields": [
          "items[0].id",
          "items[0].name",
          "items[0].employer.name",
          "items[0].salary.from",
          "items[0].salary.to",
          "items[0].area.name"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_vacancy",
      "description_for_ai": "Get full vacancy details from hh.uz.",
      "intent": [
        "вакансия hh.uz",
        "описание вакансии",
        "подробности работы hh.uz",
        "vacancy details hh.uz"
      ],
      "endpoint": "GET https://api.hh.uz/vacancies/{vacancy_id}",
      "input": {
        "vacancy_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "vacancy",
        "fields": [
          "id",
          "name",
          "employer.name",
          "salary.from",
          "salary.to",
          "description",
          "key_skills[0].name",
          "experience.name",
          "employment.name"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "search_resumes",
      "description_for_ai": "Search resumes on hh.uz.",
      "intent": [
        "резюме hh.uz",
        "кандидаты Узбекистан",
        "поиск резюме hh.uz",
        "resumes hh.uz"
      ],
      "endpoint": "GET https://api.hh.uz/resumes",
      "input": {
        "text": {
          "type": "string",
          "required": false
        },
        "area": {
          "type": "integer",
          "required": false
        },
        "salary_from": {
          "type": "integer",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<resume>",
        "fields": [
          "items[0].id",
          "items[0].title",
          "items[0].area.name",
          "items[0].salary.amount",
          "items[0].salary.currency"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_employer",
      "description_for_ai": "Get employer/company info on hh.uz.",
      "intent": [
        "работодатель hh.uz",
        "компания hh.uz",
        "информация об организации",
        "employer hh.uz"
      ],
      "endpoint": "GET https://api.hh.uz/employers/{employer_id}",
      "input": {
        "employer_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "employer",
        "fields": [
          "id",
          "name",
          "description",
          "site_url",
          "open_vacancies",
          "area.name",
          "industries[0].name"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_regions",
      "description_for_ai": "Get list of regions/cities for filtering on hh.uz.",
      "intent": [
        "города hh.uz",
        "регионы Узбекистан",
        "area IDs hh.uz",
        "регионы hh.uz"
      ],
      "endpoint": "GET https://api.hh.uz/areas",
      "input": {},
      "output": {
        "type": "list<area>",
        "fields": [
          "[0].id",
          "[0].name",
          "[0].areas[0].id",
          "[0].areas[0].name"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}