{
  "apia": "1.0",
  "service": {
    "id": "hh-uz",
    "name": "hh.uz API (Узбекистан)",
    "description_for_ai": "HeadHunter Узбекистан. Крупнейший портал вакансий Узбекистана. API идентично hh.ru — те же endpoints, те же параметры. Зарплаты в узбекских сумах (UZS). Используй для поиска вакансий в Узбекистане.",
    "url": "https://hh.uz",
    "api_base": "https://api.hh.uz/v1",
    "category": "hr",
    "geo": [
      "UZ"
    ],
    "language": "ru",
    "docs": "https://github.com/hhru/api",
    "note": "API полностью совместимо с hh.ru — смени только base URL"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": true,
    "anonymous_capabilities": [
      "search_vacancies",
      "get_vacancy",
      "get_areas"
    ],
    "oauth_url": "https://hh.uz/oauth/authorize",
    "token_url": "https://hh.uz/oauth/token"
  },
  "capabilities": [
    {
      "id": "search_vacancies",
      "description_for_ai": "Search job vacancies on hh.uz (Uzbekistan job board).",
      "intent": [
        "вакансии hh.uz",
        "работа узбекистан",
        "hh uz jobs"
      ],
      "endpoint": "GET https://api.hh.uz/vacancies",
      "input": {
        "text": {
          "type": "string",
          "required": false
        },
        "area": {
          "type": "integer",
          "description": "Region: 97=Tashkent",
          "required": false
        },
        "salary": {
          "type": "integer",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<vacancy>",
        "fields": [
          "items[0].id",
          "items[0].name",
          "items[0].salary.from",
          "items[0].employer.name",
          "items[0].area.name"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_vacancy",
      "description_for_ai": "Get full vacancy details from hh.uz.",
      "intent": [
        "вакансия hh.uz",
        "детали вакансии узбекистан"
      ],
      "endpoint": "GET https://api.hh.uz/vacancies/{id}",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "vacancy",
        "fields": [
          "id",
          "name",
          "description",
          "salary",
          "employer.name",
          "schedule.name",
          "experience.name"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_areas",
      "description_for_ai": "Get list of regions/cities in Uzbekistan for job search.",
      "intent": [
        "регионы узбекистан",
        "города hh.uz",
        "areas uzbekistan"
      ],
      "endpoint": "GET https://api.hh.uz/areas",
      "input": {},
      "output": {
        "type": "list<area>",
        "fields": [
          "[0].id",
          "[0].name",
          "[0].areas[0].name"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "search_employers",
      "description_for_ai": "Search companies posting jobs on hh.uz.",
      "intent": [
        "работодатели hh.uz",
        "компании узбекистан",
        "employers hh uz"
      ],
      "endpoint": "GET https://api.hh.uz/employers",
      "input": {
        "text": {
          "type": "string",
          "required": false
        },
        "area": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "list<employer>",
        "fields": [
          "items[0].id",
          "items[0].name",
          "items[0].area.name",
          "items[0].open_vacancies"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_employer",
      "description_for_ai": "Get details about an employer on hh.uz.",
      "intent": [
        "работодатель hh.uz",
        "компания узбекистан",
        "employer details hh uz"
      ],
      "endpoint": "GET https://api.hh.uz/employers/{id}",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "employer",
        "fields": [
          "id",
          "name",
          "description",
          "site_url",
          "area.name",
          "open_vacancies"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}