{
  "apia": "1.0",
  "service": {
    "id": "perplexity",
    "name": "Perplexity AI API",
    "description_for_ai": "AI with real-time web search built-in. Answers questions with citations from current web sources. Best for: current events, research with sources, factual questions needing up-to-date info. OpenAI-compatible.",
    "url": "https://perplexity.ai",
    "api_base": "https://api.perplexity.ai",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.perplexity.ai"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "https://www.perplexity.ai/settings/api",
    "cost": "$5/1M tokens for sonar models"
  },
  "capabilities": [
    {
      "id": "search_chat",
      "description_for_ai": "Chat with Perplexity AI which searches the web in real-time for current information. Returns cited answers.",
      "intent": [
        "Perplexity AI",
        "web search AI",
        "cited answers",
        "real-time AI search",
        "поиск с AI Perplexity"
      ],
      "endpoint": "POST https://api.perplexity.ai/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "description": "sonar (fast search), sonar-pro (deep research), sonar-reasoning (deep thinking + search)",
          "required": true
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "return_citations": {
          "type": "boolean",
          "description": "Include source URLs in response",
          "default": true
        },
        "search_domain_filter": {
          "type": "array",
          "description": "Limit search to specific domains: ['reuters.com', 'bbc.com']",
          "required": false
        },
        "search_recency_filter": {
          "type": "string",
          "description": "month, week, day, hour — limit to recent results",
          "required": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "citations (source URLs array)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "deep_research",
      "description_for_ai": "Use sonar-pro for comprehensive, deep research on complex topics. Multiple searches, long detailed answers.",
      "intent": [
        "deep research AI",
        "comprehensive research",
        "sonar pro",
        "глубокое исследование AI"
      ],
      "endpoint": "POST https://api.perplexity.ai/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "sonar-pro"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "max_tokens": {
          "type": "integer",
          "description": "Increase for detailed reports",
          "default": 4000
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "citations"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "structured_search",
      "description_for_ai": "Get structured JSON answers from Perplexity web search.",
      "intent": [
        "structured AI search",
        "JSON search results",
        "structured research",
        "структурированный поиск AI"
      ],
      "endpoint": "POST https://api.perplexity.ai/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "sonar"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "response_format": {
          "type": "object",
          "description": "{type: 'json_object'}",
          "required": false
        }
      },
      "output": {
        "type": "json",
        "fields": [
          "choices[0].message.content (JSON)",
          "citations"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "reasoning_search",
      "description_for_ai": "Combine web search with deep reasoning using sonar-reasoning model.",
      "intent": [
        "reason with search",
        "AI reasoning search",
        "think and search",
        "рассуждение с поиском AI"
      ],
      "endpoint": "POST https://api.perplexity.ai/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "sonar-reasoning-pro"
        },
        "messages": {
          "type": "array",
          "required": true
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "choices[0].message.reasoning (thinking steps)",
          "citations"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "domain_filtered_search",
      "description_for_ai": "Search the web restricted to specific trusted domains. Good for news, academic, or company-specific queries.",
      "intent": [
        "filtered search",
        "domain search AI",
        "news search AI",
        "поиск по домену"
      ],
      "endpoint": "POST https://api.perplexity.ai/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "sonar"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "search_domain_filter": {
          "type": "array",
          "description": "List of domains to search: ['nytimes.com', 'nature.com', 'arxiv.org']",
          "required": true
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "citations"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "citations": "Response includes citations array with URLs — always show sources to users.",
    "vs_rag": "Use Perplexity when you need current web info. Use RAG when you have your own documents."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}