{
  "apia": "1.0",
  "service": {
    "id": "perplexity",
    "name": "Perplexity AI API",
    "description_for_ai": "AI with real-time web search built-in. Answers questions with citations from current web sources. Best for: current events, research with sources, factual questions needing up-to-date info. OpenAI-compatible.",
    "url": "https://perplexity.ai",
    "api_base": "https://api.perplexity.ai",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.perplexity.ai"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "https://www.perplexity.ai/settings/api",
    "cost": "$5/1M tokens for sonar models"
  },
  "capabilities": [
    {
      "id": "search_chat",
      "description_for_ai": "Chat with real-time web search. Returns answer with citations. Models: sonar (fast), sonar-pro (best), sonar-reasoning (thinking+search).",
      "intent": [
        "perplexity search",
        "AI web search",
        "answer with sources",
        "current events AI",
        "поиск с ИИ perplexity"
      ],
      "endpoint": "POST https://api.perplexity.ai/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "description": "sonar (cheap, fast), sonar-pro (best quality), sonar-reasoning (thinking)",
          "required": true
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "search_recency_filter": {
          "type": "string",
          "description": "month, week, day, hour — filter search results by date",
          "required": false
        },
        "return_citations": {
          "type": "boolean",
          "description": "Include source citations in response",
          "default": true
        },
        "return_images": {
          "type": "boolean",
          "description": "Include relevant images",
          "default": false
        },
        "search_domain_filter": {
          "type": "array",
          "description": "Whitelist domains e.g. ['wikipedia.org', 'arxiv.org']",
          "required": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "citations[0]",
          "usage.prompt_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "deep_research",
      "description_for_ai": "Deep research mode with extensive web search. Returns comprehensive report with many citations. Use for research tasks.",
      "intent": [
        "deep research AI",
        "comprehensive research",
        "detailed analysis web",
        "глубокое исследование perplexity"
      ],
      "endpoint": "POST https://api.perplexity.ai/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "description": "sonar-deep-research for comprehensive multi-source research",
          "required": true
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "return_citations": {
          "type": "boolean",
          "default": true
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "citations"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "sonar_reasoning",
      "description_for_ai": "Think + search combined. Shows reasoning chain then searches web. Best for complex questions requiring both reasoning and current info.",
      "intent": [
        "think and search",
        "reasoning with web",
        "sonar reasoning",
        "размышление с поиском perplexity"
      ],
      "endpoint": "POST https://api.perplexity.ai/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "sonar-reasoning"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "search_recency_filter": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "citations",
          "choices[0].delta.reasoning_content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "structured_output",
      "description_for_ai": "Get search results as structured JSON. Enforce schema with response_format.",
      "intent": [
        "perplexity JSON",
        "structured search results",
        "extract data web",
        "структурированный ответ perplexity"
      ],
      "endpoint": "POST https://api.perplexity.ai/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "sonar"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "response_format": {
          "type": "object",
          "description": "{type: 'json_schema', json_schema: {schema: {...your JSON schema...}}}",
          "required": true
        }
      },
      "output": {
        "type": "json",
        "fields": [
          "choices[0].message.content (JSON string)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "citations": "Response includes citations array with URLs — always show sources to users.",
    "vs_rag": "Use Perplexity when you need current web info. Use RAG when you have your own documents."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}