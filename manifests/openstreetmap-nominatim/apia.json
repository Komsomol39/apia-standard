{
  "apia": "1.0",
  "service": {
    "id": "openstreetmap-nominatim",
    "name": "Nominatim (OpenStreetMap Geocoder)",
    "description_for_ai": "Free, open-source geocoder using OpenStreetMap data. No API key required. Global coverage. Use for address lookup, reverse geocoding, place search. Rate limit: 1 req/sec. Perfect for development and low-volume production.",
    "url": "https://nominatim.openstreetmap.org",
    "api_base": "https://nominatim.openstreetmap.org",
    "category": "maps",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://nominatim.org/release-docs/develop/api/Overview/"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "note": "Free, no key required. Respect rate limit of 1 req/sec. Set User-Agent header.",
    "cost": "Free forever"
  },
  "capabilities": [
    {
      "id": "search",
      "description_for_ai": "Search for places, addresses, landmarks worldwide. Free, open-source, no API key required.",
      "intent": [
        "search address",
        "find place",
        "geocode free",
        "найти адрес",
        "поиск на карте бесплатно"
      ],
      "endpoint": "GET https://nominatim.openstreetmap.org/search",
      "input": {
        "q": {
          "type": "string",
          "description": "Free-text query: address, city, landmark, POI",
          "required": true
        },
        "format": {
          "type": "string",
          "default": "json"
        },
        "limit": {
          "type": "integer",
          "default": 10
        },
        "countrycodes": {
          "type": "string",
          "description": "Comma-separated ISO codes to restrict: ru,by,kz",
          "required": false
        },
        "addressdetails": {
          "type": "integer",
          "description": "1 to include address breakdown",
          "default": 0
        },
        "accept-language": {
          "type": "string",
          "description": "Language for results: ru, en, de",
          "required": false
        }
      },
      "output": {
        "type": "list<place>",
        "fields": [
          "[0].display_name",
          "[0].lat",
          "[0].lon",
          "[0].type",
          "[0].address"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "reverse",
      "description_for_ai": "Reverse geocode coordinates to address. Free, open-source.",
      "intent": [
        "reverse geocode free",
        "coordinates to address",
        "what is at location",
        "адрес по координатам"
      ],
      "endpoint": "GET https://nominatim.openstreetmap.org/reverse",
      "input": {
        "lat": {
          "type": "float",
          "required": true
        },
        "lon": {
          "type": "float",
          "required": true
        },
        "format": {
          "type": "string",
          "default": "json"
        },
        "zoom": {
          "type": "integer",
          "description": "Level of detail: 3=country, 8=city, 14=suburb, 18=street",
          "default": 18
        },
        "accept-language": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "address",
        "fields": [
          "display_name",
          "address.road",
          "address.city",
          "address.country",
          "address.postcode"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "lookup",
      "description_for_ai": "Look up details for a specific OSM object by its ID.",
      "intent": [
        "osm object",
        "openstreetmap lookup",
        "place details osm"
      ],
      "endpoint": "GET https://nominatim.openstreetmap.org/lookup",
      "input": {
        "osm_ids": {
          "type": "string",
          "description": "Comma-separated OSM IDs: N123,W456,R789 (N=node, W=way, R=relation)",
          "required": true
        },
        "format": {
          "type": "string",
          "default": "json"
        },
        "addressdetails": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<place>",
        "fields": [
          "[0].display_name",
          "[0].lat",
          "[0].lon",
          "[0].address"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "details",
      "description_for_ai": "Get detailed information about a specific Nominatim place including hierarchy and extra tags.",
      "intent": [
        "place details nominatim",
        "osm details",
        "детали места osm"
      ],
      "endpoint": "GET https://nominatim.openstreetmap.org/details",
      "input": {
        "osmtype": {
          "type": "string",
          "description": "N, W, or R",
          "required": true
        },
        "osmid": {
          "type": "integer",
          "required": true
        },
        "format": {
          "type": "string",
          "default": "json"
        }
      },
      "output": {
        "type": "place_details",
        "fields": [
          "localname",
          "addresstags",
          "hierarchy",
          "extratags"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "rate_limit": "Max 1 request/second. Add User-Agent: YourApp/1.0 header — required by OSM policy.",
    "self_host": "For high volume self-host Nominatim using OSM planet dump — no rate limits."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}