{
  "apia": "1.0",
  "service": {
    "id": "themealdb",
    "name": "TheMealDB API",
    "description_for_ai": "Free recipe database. 300+ recipes with ingredients, instructions, photos, YouTube videos. Search by name, ingredient, category, or area/cuisine. No API key needed for basic access.",
    "url": "https://themealdb.com",
    "api_base": "https://www.themealdb.com/api/json/v1/1",
    "category": "food_recipes",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.themealdb.com/api.php"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_key": "1 (test key)",
    "how_to_get": "Patreon supporter for full API key",
    "cost": "Free for test key. Patreon for production."
  },
  "capabilities": [
    {
      "id": "search_meal",
      "description_for_ai": "Search recipes by name. Returns ingredients, instructions, photo, YouTube video.",
      "intent": [
        "find recipe",
        "cook what",
        "meal ideas",
        "recipe for",
        "how to cook",
        "что приготовить",
        "рецепт"
      ],
      "endpoint": "GET https://www.themealdb.com/api/json/v1/1/search.php",
      "input": {
        "s": {
          "type": "string",
          "description": "Meal name search term e.g. chicken, pasta, soup",
          "required": false
        },
        "f": {
          "type": "string",
          "description": "First letter search",
          "required": false
        }
      },
      "output": {
        "type": "list<meal>",
        "fields": [
          "idMeal",
          "strMeal",
          "strCategory",
          "strArea",
          "strInstructions",
          "strMealThumb",
          "strYoutube",
          "strIngredient1",
          "strMeasure1"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_random",
      "description_for_ai": "Get a random recipe. Use for meal inspiration, what to cook today.",
      "intent": [
        "random recipe",
        "surprise meal",
        "what to cook",
        "random dinner idea"
      ],
      "endpoint": "GET https://www.themealdb.com/api/json/v1/1/random.php",
      "input": {},
      "output": {
        "type": "meal",
        "fields": [
          "strMeal",
          "strCategory",
          "strInstructions",
          "strMealThumb",
          "strYoutube"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "filter_by_ingredient",
      "description_for_ai": "Find all recipes that use a specific ingredient.",
      "intent": [
        "recipes with ingredient",
        "what can I make with",
        "use up ingredient",
        "ingredient recipes"
      ],
      "endpoint": "GET https://www.themealdb.com/api/json/v1/1/filter.php",
      "input": {
        "i": {
          "type": "string",
          "description": "Ingredient name e.g. chicken_breast, egg, tomato",
          "required": true
        }
      },
      "output": {
        "type": "list<meal>",
        "fields": [
          "strMeal",
          "strMealThumb",
          "idMeal"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}