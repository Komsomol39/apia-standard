{
  "apia": "1.0",
  "service": {
    "id": "themealdb",
    "name": "TheMealDB API",
    "description_for_ai": "Free recipe database. 300+ recipes with ingredients, instructions, photos, YouTube videos. Search by name, ingredient, category, or area/cuisine. No API key needed for basic access.",
    "url": "https://themealdb.com",
    "api_base": "https://www.themealdb.com/api/json/v1/1",
    "category": "food",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.themealdb.com/api.php"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_key": "1 (test key)",
    "how_to_get": "Patreon supporter for full API key",
    "cost": "Free for test key. Patreon for production."
  },
  "capabilities": [
    {
      "id": "search_meal",
      "description_for_ai": "Search recipes by name. Returns ingredients, instructions, photo, YouTube video.",
      "intent": [
        "find recipe",
        "cook what",
        "meal ideas",
        "recipe for",
        "how to cook",
        "что приготовить",
        "рецепт"
      ],
      "endpoint": "GET https://www.themealdb.com/api/json/v1/1/search.php",
      "input": {
        "s": {
          "type": "string",
          "description": "Meal name search term e.g. chicken, pasta, soup",
          "required": false
        },
        "f": {
          "type": "string",
          "description": "First letter search",
          "required": false
        }
      },
      "output": {
        "type": "list<meal>",
        "fields": [
          "idMeal",
          "strMeal",
          "strCategory",
          "strArea",
          "strInstructions",
          "strMealThumb",
          "strYoutube",
          "strIngredient1",
          "strMeasure1"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_random",
      "description_for_ai": "Get a completely random recipe. Ideal for meal inspiration, 'what should I cook today', daily recipe features.",
      "intent": [
        "random recipe",
        "surprise meal",
        "what to cook",
        "random dinner idea"
      ],
      "endpoint": "GET https://www.themealdb.com/api/json/v1/1/random.php",
      "input": {},
      "output": {
        "type": "meal",
        "fields": [
          "strMeal",
          "strCategory",
          "strInstructions",
          "strMealThumb",
          "strYoutube"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "filter_by_ingredient",
      "description_for_ai": "Find all recipes containing a specific ingredient. Returns list of matching meals with thumbnails. Use to suggest what to cook with available ingredients.",
      "intent": [
        "recipes with ingredient",
        "what can I make with",
        "use up ingredient",
        "ingredient recipes"
      ],
      "endpoint": "GET https://www.themealdb.com/api/json/v1/1/filter.php",
      "input": {
        "i": {
          "type": "string",
          "description": "Ingredient name (use underscores for spaces): chicken_breast, salmon, garlic, tomato, pasta, cheese",
          "required": true
        }
      },
      "output": {
        "type": "list<meal>",
        "fields": [
          "strMeal",
          "strMealThumb",
          "idMeal"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "search_by_ingredient",
      "description_for_ai": "Search recipes by main ingredient.",
      "intent": [
        "recipe by ingredient",
        "meal by ingredient",
        "что приготовить из"
      ],
      "endpoint": "GET https://www.themealdb.com/api/json/v1/1/filter.php",
      "input": {
        "i": {
          "type": "string",
          "description": "Ingredient name e.g. chicken",
          "required": true
        }
      },
      "output": {
        "type": "list<meal>",
        "fields": [
          "meals[0].idMeal",
          "meals[0].strMeal",
          "meals[0].strMealThumb"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_meal_details",
      "description_for_ai": "Get full recipe details by meal ID: ingredients, measurements, instructions.",
      "intent": [
        "recipe details",
        "meal instructions",
        "полный рецепт",
        "recipe ingredients"
      ],
      "endpoint": "GET https://www.themealdb.com/api/json/v1/1/lookup.php",
      "input": {
        "i": {
          "type": "string",
          "description": "Meal ID",
          "required": true
        }
      },
      "output": {
        "type": "meal",
        "fields": [
          "meals[0].strMeal",
          "meals[0].strInstructions",
          "meals[0].strIngredient1..20",
          "meals[0].strMeasure1..20",
          "meals[0].strYoutube"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "free_tier": "Test key '1' gives access to all endpoints. Full API key from Patreon unlocks search by category/area.",
    "image_url": "Meal thumbnail: strMealThumb. Append /preview for smaller version.",
    "categories": "Available categories: Beef, Chicken, Dessert, Lamb, Miscellaneous, Pasta, Pork, Seafood, Side, Starter, Vegan, Vegetarian, Breakfast, Goat",
    "youtube": "strYoutube field contains YouTube URL for cooking video when available."
  }
}