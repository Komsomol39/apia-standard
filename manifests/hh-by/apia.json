{
  "apia": "1.0",
  "service": {
    "id": "hh-by",
    "name": "HeadHunter Беларусь (hh.by / rabota.by)",
    "description_for_ai": "Крупнейшая биржа труда Беларуси. API идентично hh.ru — те же endpoints, те же параметры. Зарплаты в белорусских рублях (BYN). Используй для поиска вакансий в Беларуси.",
    "url": "https://hh.by",
    "api_base": "https://api.hh.by/v1",
    "category": "employment",
    "geo": ["BY"],
    "language": "ru",
    "docs": "https://github.com/hhru/api",
    "note": "API полностью совместимо с hh.ru. rabota.by — то же самое под другим доменом."
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": true,
    "anonymous_capabilities": ["search_vacancies", "get_vacancy", "get_areas"],
    "oauth_url": "https://hh.by/oauth/authorize",
    "token_url": "https://hh.by/oauth/token",
    "contact": "+375 17 336 03 02"
  },
  "capabilities": [
    {
      "id": "search_vacancies",
      "description_for_ai": "Поиск вакансий в Беларуси по ключевому слову и городу. Зарплаты в BYN (белорусских рублях). Используй для запросов 'работа в Минске', 'вакансии в Беларуси', 'найди работу разработчика в Гомеле'.",
      "intent": [
        "работа в Беларуси", "вакансии в Минске", "работа в Гомеле",
        "найти работу в BY", "вакансии в Беларуси"
      ],
      "endpoint": "GET https://api.hh.by/vacancies",
      "input": {
        "text": { "type": "string", "description": "Поисковый запрос", "required": false },
        "area": { "type": "integer", "description": "ID города. Минск=1. Получить через get_areas", "required": false },
        "salary": { "type": "integer", "description": "Минимальная зарплата в BYN", "required": false },
        "currency": { "type": "string", "default": "BYR" },
        "experience": { "type": "string", "description": "noExperience, between1And3, between3And6, moreThan6", "required": false },
        "per_page": { "type": "integer", "default": 20, "max": 100 },
        "page": { "type": "integer", "default": 0 }
      },
      "output": {
        "type": "list<vacancy>",
        "fields": ["id", "name", "area.name", "salary.from", "salary.to", "salary.currency", "employer.name", "url"]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_vacancy",
      "description_for_ai": "Полное описание вакансии по ID.",
      "intent": ["подробнее о вакансии BY", "описание вакансии Беларусь"],
      "endpoint": "GET https://api.hh.by/vacancies/{vacancy_id}",
      "input": {
        "vacancy_id": { "type": "string", "required": true }
      },
      "output": {
        "type": "vacancy",
        "fields": ["name", "description", "key_skills", "employer.name", "salary", "address.raw"]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_areas",
      "description_for_ai": "Список городов Беларуси с ID.",
      "intent": ["города Беларуси", "ID Минска"],
      "endpoint": "GET https://api.hh.by/areas",
      "input": {},
      "output": { "type": "list<area>", "fields": ["id", "name", "areas"] },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "salary_tip": "Зарплаты в BYN (белорусский рубль). 1 USD ≈ 3.2 BYN.",
    "cities": "Минск=1 (столица), Гомель=21, Могилёв=26, Витебск=22, Гродно=23.",
    "same_api": "API идентично hh.ru. Просто смени base URL на api.hh.by."
  },
  "contributor_notes": {
    "useful_links": [
      "https://github.com/hhru/api",
      "https://dev.hh.by/"
    ]
  },
  "limits": {
    "requests_per_day": 1000,
    "commercial_use": false,
    "attribution_required": true
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}