{
  "apia": "1.0",
  "service": {
    "id": "hh-by",
    "name": "HeadHunter Беларусь (hh.by / rabota.by)",
    "description_for_ai": "Крупнейшая биржа труда Беларуси. API идентично hh.ru — те же endpoints, те же параметры. Зарплаты в белорусских рублях (BYN). Используй для поиска вакансий в Беларуси.",
    "url": "https://hh.by",
    "api_base": "https://api.hh.by/v1",
    "category": "hr",
    "geo": [
      "BY"
    ],
    "language": "ru",
    "docs": "https://github.com/hhru/api",
    "note": "API полностью совместимо с hh.ru. rabota.by — то же самое под другим доменом."
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": true,
    "anonymous_capabilities": [
      "search_vacancies",
      "get_vacancy",
      "get_areas"
    ],
    "oauth_url": "https://hh.by/oauth/authorize",
    "token_url": "https://hh.by/oauth/token",
    "contact": "+375 17 336 03 02"
  },
  "capabilities": [
    {
      "id": "search_vacancies",
      "description_for_ai": "Поиск вакансий в Беларуси по ключевому слову и городу. Зарплаты в BYN (белорусских рублях). Используй для запросов 'работа в Минске', 'вакансии в Беларуси', 'найди работу разработчика в Гомеле'.",
      "intent": [
        "работа в Беларуси",
        "вакансии в Минске",
        "работа в Гомеле",
        "найти работу в BY",
        "вакансии в Беларуси"
      ],
      "endpoint": "GET https://api.hh.by/vacancies",
      "input": {
        "text": {
          "type": "string",
          "description": "Поисковый запрос",
          "required": false
        },
        "area": {
          "type": "integer",
          "description": "ID города. Минск=1. Получить через get_areas",
          "required": false
        },
        "salary": {
          "type": "integer",
          "description": "Минимальная зарплата в BYN",
          "required": false
        },
        "currency": {
          "type": "string",
          "default": "BYR",
          "description": "ISO 4217 currency code: USD, EUR, GBP, RUB"
        },
        "experience": {
          "type": "string",
          "description": "noExperience, between1And3, between3And6, moreThan6",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 20,
          "max": 100,
          "description": "Results per page. Check API docs for maximum allowed."
        },
        "page": {
          "type": "integer",
          "default": 0,
          "description": "Page number for pagination (1-indexed)"
        }
      },
      "output": {
        "type": "list<vacancy>",
        "fields": [
          "id",
          "name",
          "area.name",
          "salary.from",
          "salary.to",
          "salary.currency",
          "employer.name",
          "url"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_vacancy",
      "description_for_ai": "Get full vacancy details: title, company, salary range, requirements, responsibilities, employer contacts. Returns structured data in Russian.",
      "intent": [
        "вакансия BY",
        "работа Беларусь",
        "вакансии Минск",
        "зарплата Беларусь",
        "job Belarus"
      ],
      "endpoint": "GET https://api.hh.by/vacancies/{vacancy_id}",
      "input": {
        "id": {
          "type": "string",
          "description": "Vacancy ID from search results",
          "required": true
        },
        "locale": {
          "type": "string",
          "description": "Response language: RU or EN",
          "default": "RU"
        }
      },
      "output": {
        "type": "vacancy",
        "fields": [
          "name",
          "description",
          "key_skills",
          "employer.name",
          "salary",
          "address.raw"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_areas",
      "description_for_ai": "Get list of geographic areas/cities available for job search in Belarus with their IDs.",
      "intent": [
        "города Беларуси",
        "ID Минска"
      ],
      "endpoint": "GET https://api.hh.by/areas",
      "input": {
        "locale": {
          "type": "string",
          "default": "RU",
          "description": "Locale code: en-US, ru-RU, de-DE, fr-FR, etc."
        }
      },
      "output": {
        "type": "list<area>",
        "fields": [
          "id",
          "name",
          "areas"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "search_vacancies",
      "description_for_ai": "Search job vacancies on hh.by (Belarus job board).",
      "intent": [
        "hh.by вакансии",
        "работа беларусь",
        "вакансии hh by"
      ],
      "endpoint": "GET https://api.hh.by/vacancies",
      "input": {
        "text": {
          "type": "string",
          "required": false
        },
        "area": {
          "type": "integer",
          "description": "Region: 1=Minsk",
          "required": false
        },
        "salary": {
          "type": "integer",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<vacancy>",
        "fields": [
          "items[0].id",
          "items[0].name",
          "items[0].salary.from",
          "items[0].employer.name",
          "items[0].area.name"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_vacancy",
      "description_for_ai": "Get full vacancy details from hh.by.",
      "intent": [
        "вакансия hh.by",
        "детали вакансии беларусь"
      ],
      "endpoint": "GET https://api.hh.by/vacancies/{vacancy_id}",
      "input": {
        "vacancy_id": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "vacancy",
        "fields": [
          "id",
          "name",
          "description",
          "salary",
          "employer.name",
          "schedule.name",
          "experience.name"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "base_url": "API identical to hh.ru — change base_url to api.hh.by for Belarus-specific results",
    "areas": "Belarus area ID: 16. Minsk ID: 153. Get full list from /areas endpoint.",
    "currency": "Salaries in BYR (Belarusian rubles). 1 USD ≈ 3.2 BYR (2024)."
  },
  "contributor_notes": {
    "useful_links": [
      "https://github.com/hhru/api",
      "https://dev.hh.by/"
    ]
  },
  "limits": {
    "requests_per_day": 1000,
    "commercial_use": false,
    "attribution_required": true
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}