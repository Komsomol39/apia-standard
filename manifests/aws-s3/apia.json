{
  "apia": "1.0",
  "service": {
    "id": "aws-s3",
    "name": "Amazon S3 API",
    "description_for_ai": "World leading cloud object storage. Store files, images, videos, backups. Highly durable, globally available. 5GB free first year. Use for file uploads, static hosting, backups, media storage.",
    "url": "https://aws.amazon.com/s3",
    "api_base": "https://s3.amazonaws.com",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.aws.amazon.com/s3"
  },
  "auth": {
    "type": "aws_sig_v4",
    "anonymous_access": false,
    "how_to_get": "AWS account at https://aws.amazon.com — 5GB free tier",
    "cost": "Free: 5GB, 20K GET, 2K PUT. Then $0.023/GB/month"
  },
  "capabilities": [
    {
      "id": "put_object",
      "description_for_ai": "Upload a file to S3. Set permissions, content type, metadata, and server-side encryption.",
      "intent": [
        "upload to S3",
        "store file AWS",
        "S3 upload",
        "загрузить файл S3"
      ],
      "endpoint": "PUT https://{bucket}.s3.{region}.amazonaws.com/{key}",
      "input": {
        "Bucket": {
          "type": "string",
          "required": true
        },
        "Key": {
          "type": "string",
          "description": "Object path e.g. images/photo.jpg",
          "required": true
        },
        "Body": {
          "type": "binary",
          "description": "File content",
          "required": true
        },
        "ContentType": {
          "type": "string",
          "description": "MIME type: image/jpeg, application/pdf, text/plain",
          "required": false
        },
        "ACL": {
          "type": "string",
          "description": "private (default), public-read, authenticated-read",
          "required": false
        },
        "Metadata": {
          "type": "object",
          "description": "Custom key-value metadata",
          "required": false
        },
        "ServerSideEncryption": {
          "type": "string",
          "description": "AES256 or aws:kms",
          "required": false
        }
      },
      "output": {
        "type": "put_result",
        "fields": [
          "ETag",
          "VersionId",
          "ServerSideEncryption"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_object",
      "description_for_ai": "Download a file from S3. Returns file content.",
      "intent": [
        "download from S3",
        "get S3 file",
        "read S3 object",
        "скачать файл S3"
      ],
      "endpoint": "GET https://{bucket}.s3.{region}.amazonaws.com/{key}",
      "input": {
        "Bucket": {
          "type": "string",
          "required": true
        },
        "Key": {
          "type": "string",
          "required": true
        },
        "Range": {
          "type": "string",
          "description": "Partial content: bytes=0-1023",
          "required": false
        },
        "VersionId": {
          "type": "string",
          "description": "Specific version",
          "required": false
        }
      },
      "output": {
        "type": "object",
        "fields": [
          "Body (file content)",
          "ContentType",
          "ContentLength",
          "LastModified",
          "ETag",
          "Metadata"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_objects",
      "description_for_ai": "List files in an S3 bucket with size, last modified, and storage class.",
      "intent": [
        "list S3 files",
        "S3 bucket contents",
        "list objects",
        "файлы в S3 bucket"
      ],
      "endpoint": "GET https://{bucket}.s3.{region}.amazonaws.com/",
      "input": {
        "Bucket": {
          "type": "string",
          "required": true
        },
        "Prefix": {
          "type": "string",
          "description": "Filter by key prefix e.g. images/",
          "required": false
        },
        "MaxKeys": {
          "type": "integer",
          "description": "Max results 1-1000",
          "default": 1000
        },
        "ContinuationToken": {
          "type": "string",
          "description": "Pagination token",
          "required": false
        },
        "Delimiter": {
          "type": "string",
          "description": "Group keys by delimiter e.g. / for folder-like listing",
          "required": false
        }
      },
      "output": {
        "type": "list",
        "fields": [
          "Contents[0].Key",
          "Contents[0].Size",
          "Contents[0].LastModified",
          "Contents[0].StorageClass",
          "IsTruncated",
          "NextContinuationToken"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "generate_presigned_url",
      "description_for_ai": "Generate a temporary URL to access a private S3 object. Set expiration time. Use for download links without exposing AWS credentials.",
      "intent": [
        "S3 download link",
        "presigned URL",
        "share S3 file",
        "временная ссылка S3"
      ],
      "endpoint": "GET https://{bucket}.s3.{region}.amazonaws.com/{key}?X-Amz-Signature=...",
      "input": {
        "Bucket": {
          "type": "string",
          "required": true
        },
        "Key": {
          "type": "string",
          "required": true
        },
        "ExpiresIn": {
          "type": "integer",
          "description": "URL validity in seconds. Default 1 hour. Max 7 days.",
          "default": 3600
        },
        "ResponseContentDisposition": {
          "type": "string",
          "description": "attachment; filename=file.pdf — forces download",
          "required": false
        }
      },
      "output": {
        "type": "url",
        "fields": [
          "presigned URL string with embedded auth parameters"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "sdk": "Use AWS SDK (boto3 for Python, aws-sdk for JS) instead of raw HTTP — handles auth automatically.",
    "public_url": "For public objects: https://{bucket}.s3.{region}.amazonaws.com/{key}",
    "presigned": "Use presigned URLs for temporary access without exposing credentials."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}