{
  "apia": "1.0",
  "service": {
    "id": "aws-s3",
    "name": "Amazon S3 API",
    "description_for_ai": "World leading cloud object storage. Store files, images, videos, backups. Highly durable, globally available. 5GB free first year. Use for file uploads, static hosting, backups, media storage.",
    "url": "https://aws.amazon.com/s3",
    "api_base": "https://s3.amazonaws.com",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.aws.amazon.com/s3"
  },
  "auth": {
    "type": "aws_sig_v4",
    "anonymous_access": false,
    "how_to_get": "AWS account at https://aws.amazon.com — 5GB free tier",
    "cost": "Free: 5GB, 20K GET, 2K PUT. Then $0.023/GB/month"
  },
  "capabilities": [
    {
      "id": "put_object",
      "description_for_ai": "Upload a file to S3 bucket. Supports any content type, metadata, and access control.",
      "intent": [
        "upload to S3",
        "store file S3",
        "AWS S3 upload",
        "загрузить файл S3"
      ],
      "endpoint": "PUT https://{bucket}.s3.{region}.amazonaws.com/{key}",
      "input": {
        "bucket": {
          "type": "string",
          "required": true
        },
        "key": {
          "type": "string",
          "description": "File path in bucket e.g. images/photo.jpg",
          "required": true
        },
        "body": {
          "type": "binary",
          "description": "File content",
          "required": true
        },
        "ContentType": {
          "type": "string",
          "description": "MIME type: image/jpeg, application/json, etc.",
          "required": false
        },
        "ACL": {
          "type": "string",
          "description": "private, public-read, public-read-write",
          "default": "private"
        },
        "Metadata": {
          "type": "object",
          "description": "Custom key-value metadata",
          "required": false
        }
      },
      "output": {
        "type": "upload",
        "fields": [
          "ETag",
          "VersionId (if versioning enabled)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_object",
      "description_for_ai": "Download a file from S3 bucket.",
      "intent": [
        "download from S3",
        "get file S3",
        "read S3 object",
        "скачать из S3"
      ],
      "endpoint": "GET https://{bucket}.s3.{region}.amazonaws.com/{key}",
      "input": {
        "bucket": {
          "type": "string",
          "required": true
        },
        "key": {
          "type": "string",
          "required": true
        },
        "range": {
          "type": "string",
          "description": "Byte range: bytes=0-999",
          "required": false
        }
      },
      "output": {
        "type": "object",
        "fields": [
          "body (binary)",
          "ContentType",
          "ContentLength",
          "LastModified",
          "Metadata"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_objects",
      "description_for_ai": "List objects in an S3 bucket with optional prefix filter.",
      "intent": [
        "list S3 files",
        "S3 bucket contents",
        "list files S3",
        "список файлов S3"
      ],
      "endpoint": "GET https://{bucket}.s3.{region}.amazonaws.com/?list-type=2",
      "input": {
        "bucket": {
          "type": "string",
          "required": true
        },
        "prefix": {
          "type": "string",
          "description": "Filter by prefix e.g. images/",
          "required": false
        },
        "delimiter": {
          "type": "string",
          "description": "/ to list like directories",
          "required": false
        },
        "max-keys": {
          "type": "integer",
          "default": 1000
        },
        "continuation-token": {
          "type": "string",
          "description": "Pagination token",
          "required": false
        }
      },
      "output": {
        "type": "list",
        "fields": [
          "Contents[0].Key",
          "Contents[0].Size",
          "Contents[0].LastModified",
          "IsTruncated",
          "NextContinuationToken"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "delete_object",
      "description_for_ai": "Delete an object from S3 bucket.",
      "intent": [
        "delete S3 file",
        "remove object S3",
        "удалить файл S3"
      ],
      "endpoint": "DELETE https://{bucket}.s3.{region}.amazonaws.com/{key}",
      "input": {
        "bucket": {
          "type": "string",
          "required": true
        },
        "key": {
          "type": "string",
          "required": true
        },
        "versionId": {
          "type": "string",
          "description": "Specific version to delete",
          "required": false
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "204 No Content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "presigned_url",
      "description_for_ai": "Generate a pre-signed URL for temporary access to an S3 object without AWS credentials.",
      "intent": [
        "S3 presigned URL",
        "share file link",
        "temporary URL S3",
        "временная ссылка S3"
      ],
      "endpoint": "SDK method (not REST)",
      "input": {
        "bucket": {
          "type": "string",
          "required": true
        },
        "key": {
          "type": "string",
          "required": true
        },
        "operation": {
          "type": "string",
          "description": "GetObject (download) or PutObject (upload)",
          "required": true
        },
        "expires_in": {
          "type": "integer",
          "description": "Seconds until expiry, max 604800 (7 days)",
          "default": 3600
        }
      },
      "output": {
        "type": "url",
        "fields": [
          "presignedUrl (string)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "multipart_upload",
      "description_for_ai": "Upload large files (>100MB) to S3 using multipart upload for reliability.",
      "intent": [
        "large file upload S3",
        "multipart S3",
        "upload big file",
        "загрузка большого файла S3"
      ],
      "endpoint": "POST https://{bucket}.s3.{region}.amazonaws.com/{key}?uploads",
      "input": {
        "bucket": {
          "type": "string",
          "required": true
        },
        "key": {
          "type": "string",
          "required": true
        },
        "ContentType": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "multipart",
        "fields": [
          "UploadId (use to upload parts and complete)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "sdk": "Use AWS SDK (boto3 for Python, aws-sdk for JS) instead of raw HTTP — handles auth automatically.",
    "public_url": "For public objects: https://{bucket}.s3.{region}.amazonaws.com/{key}",
    "presigned": "Use presigned URLs for temporary access without exposing credentials."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}