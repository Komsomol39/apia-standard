{
  "apia": "1.0",
  "service": {
    "id": "edamam",
    "name": "Edamam API",
    "description_for_ai": "Food and nutrition API. Recipe search with 2.3M+ recipes, food database, nutrition analysis. Supports diet labels (balanced, low-carb, paleo), health labels (vegan, vegetarian, kosher). 5 min free req.",
    "url": "https://edamam.com",
    "api_base": "https://api.edamam.com",
    "category": "healthcare",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.edamam.com/edamam-docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_names": "app_id + app_key",
    "how_to_get": "Register at https://developer.edamam.com",
    "cost": "Free: 5 req/min, 10K req/month. Basic: $19/month"
  },
  "capabilities": [
    {
      "id": "search_recipes",
      "description_for_ai": "Search recipes with diet and health filters. Returns ingredients, nutrition, calories per serving.",
      "intent": [
        "recipe search",
        "diet recipe",
        "healthy recipe",
        "vegan recipe",
        "low carb",
        "keto",
        "gluten free recipe"
      ],
      "endpoint": "GET https://api.edamam.com/api/recipes/v2",
      "input": {
        "q": {
          "type": "string",
          "description": "Search query e.g. chicken salad, pasta",
          "required": true
        },
        "type": {
          "type": "string",
          "default": "public",
          "description": "Filter or specify item type"
        },
        "diet": {
          "type": "string",
          "description": "balanced, high-protein, low-carb, low-fat, low-sodium",
          "required": false
        },
        "health": {
          "type": "string",
          "description": "vegan, vegetarian, paleo, keto-friendly, kosher, gluten-free",
          "required": false
        },
        "calories": {
          "type": "string",
          "description": "Range e.g. 200-500",
          "required": false
        },
        "cuisineType": {
          "type": "string",
          "description": "american, italian, mexican, chinese, french",
          "required": false
        }
      },
      "output": {
        "type": "list<recipe>",
        "fields": [
          "hits[0].recipe.label",
          "hits[0].recipe.calories",
          "hits[0].recipe.totalNutrients",
          "hits[0].recipe.ingredientLines",
          "hits[0].recipe.url",
          "hits[0].recipe.image"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "analyze_nutrition",
      "description_for_ai": "Analyze nutritional content of a recipe or ingredient list.",
      "intent": [
        "nutrition analysis",
        "calories count",
        "macro nutrients",
        "food nutrients",
        "analyze ingredients"
      ],
      "endpoint": "POST https://api.edamam.com/api/nutrition-details",
      "input": {
        "title": {
          "type": "string",
          "required": true,
          "description": "Title or name string"
        },
        "ingr": {
          "type": "array",
          "description": "List of ingredients with quantities e.g. 1 cup rice",
          "required": true
        }
      },
      "output": {
        "type": "nutrition",
        "fields": [
          "calories",
          "totalNutrients.PROCNT.quantity",
          "totalNutrients.FAT.quantity",
          "totalNutrients.CHOCDF.quantity",
          "totalNutrients.FIBTG.quantity"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "nutrition_data",
      "description_for_ai": "Get nutrition data for a food or recipe.",
      "intent": [
        "nutrition data",
        "calories food",
        "food nutrients",
        "калории еды"
      ],
      "endpoint": "GET https://api.edamam.com/api/nutrition-data",
      "input": {
        "ingr": {
          "type": "string",
          "description": "Ingredient + amount: '2 cups coffee with milk'",
          "required": true
        }
      },
      "output": {
        "type": "nutrition",
        "fields": [
          "calories",
          "totalNutrients.PROCNT.quantity (protein)",
          "totalNutrients.FAT.quantity",
          "totalNutrients.CHOCDF.quantity (carbs)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "food_database",
      "description_for_ai": "Search Edamam food database for nutritional info.",
      "intent": [
        "food search edamam",
        "nutrition database",
        "калории продукт"
      ],
      "endpoint": "GET https://api.edamam.com/api/food-database/v2/parser",
      "input": {
        "ingr": {
          "type": "string",
          "description": "Food name to search",
          "required": true
        }
      },
      "output": {
        "type": "list<food>",
        "fields": [
          "parsed[0].food.label",
          "parsed[0].food.nutrients.ENERC_KCAL",
          "parsed[0].food.nutrients.PROCNT",
          "parsed[0].food.category"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "meal_planner",
      "description_for_ai": "Get meal plan suggestions based on dietary preferences.",
      "intent": [
        "meal plan edamam",
        "weekly menu",
        "diet plan",
        "план питания edamam"
      ],
      "endpoint": "POST https://api.edamam.com/api/meal-planner/v1/{app_id}/select",
      "input": {
        "plan": {
          "type": "object",
          "description": "{accept: {all: [{health: ['DAIRY_FREE'], diet: ['BALANCED']}]}, fit: {ENERC_KCAL: {min: 1800, max: 2200}}, sections: {Breakfast: {accept: {all: [{meal: ['breakfast']}]}}}, size: 7}",
          "required": true
        }
      },
      "output": {
        "type": "plan",
        "fields": [
          "selection[0].sections.Breakfast.assigned",
          "selection[0].sections.Lunch.assigned"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "app_id": "Need separate app_id and app_key for Recipe API, Food Database, and Nutrition API — they're different products",
    "recipe_fields": "Request specific fields to reduce response size: ?field=uri&field=label&field=calories&field=totalNutrients",
    "nutrition_analysis": "Natural language works well: '2 cups cooked rice', '1 large egg', '100g chicken breast'",
    "diet_labels": "Diet labels: balanced, high-fiber, high-protein, low-carb, low-fat, low-sodium"
  }
}