{
  "apia": "1.0",
  "service": {
    "id": "odds-api",
    "name": "The Odds API",
    "description_for_ai": "Real-time sports betting odds from 40+ bookmakers worldwide. NFL, NBA, soccer, tennis, MMA odds. Compare odds across bookmakers to find best value. Free: 500 requests/month.",
    "url": "https://the-odds-api.com",
    "api_base": "https://api.the-odds-api.com/v4",
    "category": "sports",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://the-odds-api.com/liveapi/guides/v4/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "apiKey",
    "param_location": "query",
    "how_to_get": "Free key at https://the-odds-api.com",
    "cost": "Free: 500 req/month. Paid from $79/month"
  },
  "capabilities": [
    {
      "id": "get_odds",
      "description_for_ai": "Get sports betting odds for live and upcoming matches.",
      "intent": [
        "betting odds",
        "sports odds",
        "match odds",
        "коэффициенты ставок"
      ],
      "endpoint": "GET https://api.the-odds-api.com/v4/sports/{sport}/odds",
      "input": {
        "sport": {
          "type": "string",
          "description": "soccer_epl, basketball_nba, americanfootball_nfl, tennis_atp_french_open",
          "required": true
        },
        "regions": {
          "type": "string",
          "description": "us, uk, eu, au",
          "default": "us"
        },
        "markets": {
          "type": "string",
          "description": "h2h (moneyline), spreads, totals",
          "default": "h2h"
        },
        "oddsFormat": {
          "type": "string",
          "description": "american, decimal, fractional",
          "default": "decimal"
        }
      },
      "output": {
        "type": "list<game>",
        "fields": [
          "[0].home_team",
          "[0].away_team",
          "[0].commence_time",
          "[0].bookmakers[0].title",
          "[0].bookmakers[0].markets[0].outcomes[0].price"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_sports",
      "description_for_ai": "Get list of available sports for betting odds.",
      "intent": [
        "sports list odds",
        "available sports",
        "betting sports",
        "виды спорта ставки"
      ],
      "endpoint": "GET https://api.the-odds-api.com/v4/sports",
      "input": {
        "all": {
          "type": "boolean",
          "description": "Include out-of-season sports",
          "default": false
        }
      },
      "output": {
        "type": "list<sport>",
        "fields": [
          "[0].key",
          "[0].title",
          "[0].description",
          "[0].active",
          "[0].has_outrights"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_event_odds",
      "description_for_ai": "Get odds for a specific event ID.",
      "intent": [
        "event odds",
        "game odds",
        "match betting lines",
        "коэффициенты матча"
      ],
      "endpoint": "GET https://api.the-odds-api.com/v4/sports/{sport}/events/{eventId}/odds",
      "input": {
        "sport": {
          "type": "string",
          "required": true
        },
        "eventId": {
          "type": "string",
          "required": true
        },
        "regions": {
          "type": "string",
          "default": "us"
        },
        "markets": {
          "type": "string",
          "default": "h2h,spreads,totals"
        }
      },
      "output": {
        "type": "event",
        "fields": [
          "id",
          "sport_key",
          "home_team",
          "away_team",
          "bookmakers[0].markets[0].outcomes[0].price"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_historical_odds",
      "description_for_ai": "Get historical betting odds for past events.",
      "intent": [
        "historical odds",
        "past odds",
        "betting history",
        "исторические коэффициенты"
      ],
      "endpoint": "GET https://api.the-odds-api.com/v4/historical/sports/{sport}/odds",
      "input": {
        "sport": {
          "type": "string",
          "required": true
        },
        "date": {
          "type": "string",
          "description": "ISO 8601 datetime: 2024-01-15T00:00:00Z",
          "required": true
        },
        "regions": {
          "type": "string",
          "default": "us"
        }
      },
      "output": {
        "type": "list<game>",
        "fields": [
          "data[0].home_team",
          "data[0].away_team",
          "data[0].bookmakers[0].markets[0].outcomes[0].price",
          "timestamp"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_scores",
      "description_for_ai": "Get live and recent sports scores.",
      "intent": [
        "live scores odds API",
        "game scores",
        "sports results",
        "счёт матча odds API"
      ],
      "endpoint": "GET https://api.the-odds-api.com/v4/sports/{sport}/scores",
      "input": {
        "sport": {
          "type": "string",
          "required": true
        },
        "daysFrom": {
          "type": "integer",
          "description": "Days back for completed games (1-3)",
          "default": 1
        }
      },
      "output": {
        "type": "list<game>",
        "fields": [
          "[0].home_team",
          "[0].away_team",
          "[0].scores[0].score",
          "[0].completed",
          "[0].last_update"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}