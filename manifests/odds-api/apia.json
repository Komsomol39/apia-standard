{
  "apia": "1.0",
  "service": {
    "id": "odds-api",
    "name": "The Odds API",
    "description_for_ai": "Real-time sports betting odds from 40+ bookmakers worldwide. NFL, NBA, soccer, tennis, MMA odds. Compare odds across bookmakers to find best value. Free: 500 requests/month.",
    "url": "https://the-odds-api.com",
    "api_base": "https://api.the-odds-api.com/v4",
    "category": "sports",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://the-odds-api.com/liveapi/guides/v4/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "apiKey",
    "param_location": "query",
    "how_to_get": "Free key at https://the-odds-api.com",
    "cost": "Free: 500 req/month. Paid from $79/month"
  },
  "capabilities": [
    {
      "id": "get_odds",
      "description_for_ai": "Get live betting odds for sports events from multiple bookmakers.",
      "intent": [
        "betting odds",
        "sports odds",
        "bookmaker odds",
        "ставки коэффициенты"
      ],
      "endpoint": "GET https://api.the-odds-api.com/v4/sports/{sport}/odds",
      "input": {
        "sport": {
          "type": "string",
          "description": "soccer_epl, basketball_nba, americanfootball_nfl, icehockey_nhl, tennis_atp",
          "required": true
        },
        "regions": {
          "type": "string",
          "description": "us, uk, eu, au (comma-separated)",
          "default": "us"
        },
        "markets": {
          "type": "string",
          "description": "h2h (moneyline), spreads, totals, outrights",
          "default": "h2h"
        },
        "oddsFormat": {
          "type": "string",
          "description": "decimal, american, fractional",
          "default": "decimal"
        },
        "dateFrom": {
          "type": "string",
          "description": "ISO 8601",
          "required": false
        }
      },
      "output": {
        "type": "list<event>",
        "fields": [
          "[0].id",
          "[0].home_team",
          "[0].away_team",
          "[0].commence_time",
          "[0].bookmakers[0].title",
          "[0].bookmakers[0].markets[0].outcomes[0].price"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_sports",
      "description_for_ai": "Get all available sports and leagues for odds.",
      "intent": [
        "available sports odds",
        "sports list",
        "leagues odds API",
        "виды спорта коэффициенты"
      ],
      "endpoint": "GET https://api.the-odds-api.com/v4/sports",
      "input": {
        "all": {
          "type": "boolean",
          "description": "Include out-of-season sports",
          "default": false
        }
      },
      "output": {
        "type": "list<sport>",
        "fields": [
          "[0].key",
          "[0].group",
          "[0].title",
          "[0].description",
          "[0].active",
          "[0].has_outrights"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_scores",
      "description_for_ai": "Get historical and live game scores.",
      "intent": [
        "scores odds API",
        "game scores",
        "live scores betting",
        "результаты матчей"
      ],
      "endpoint": "GET https://api.the-odds-api.com/v4/sports/{sport}/scores",
      "input": {
        "sport": {
          "type": "string",
          "required": true
        },
        "daysFrom": {
          "type": "integer",
          "description": "Scores from N days ago (max 3)",
          "default": 1
        }
      },
      "output": {
        "type": "list<score>",
        "fields": [
          "[0].id",
          "[0].home_team",
          "[0].away_team",
          "[0].commence_time",
          "[0].completed",
          "[0].scores[0].name",
          "[0].scores[0].score"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_events",
      "description_for_ai": "Get upcoming events/fixtures for a sport.",
      "intent": [
        "sports events",
        "upcoming fixtures",
        "games schedule odds",
        "предстоящие матчи"
      ],
      "endpoint": "GET https://api.the-odds-api.com/v4/sports/{sport}/events",
      "input": {
        "sport": {
          "type": "string",
          "required": true
        },
        "commenceTimeFrom": {
          "type": "string",
          "description": "ISO 8601 datetime",
          "required": false
        },
        "commenceTimeTo": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<event>",
        "fields": [
          "[0].id",
          "[0].home_team",
          "[0].away_team",
          "[0].commence_time"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_event_odds",
      "description_for_ai": "Get all odds for a specific event ID.",
      "intent": [
        "odds for event",
        "specific game odds",
        "event betting lines",
        "коэффициенты матча"
      ],
      "endpoint": "GET https://api.the-odds-api.com/v4/sports/{sport}/events/{eventId}/odds",
      "input": {
        "sport": {
          "type": "string",
          "required": true
        },
        "eventId": {
          "type": "string",
          "required": true
        },
        "regions": {
          "type": "string",
          "default": "us,uk"
        },
        "markets": {
          "type": "string",
          "default": "h2h,spreads,totals"
        }
      },
      "output": {
        "type": "event",
        "fields": [
          "home_team",
          "away_team",
          "bookmakers[0].title",
          "bookmakers[0].markets[0].key",
          "bookmakers[0].markets[0].outcomes"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}