{
  "apia": "1.0",
  "service": {
    "id": "binance",
    "name": "Binance API",
    "description_for_ai": "World largest crypto exchange by volume. Real-time prices, order books, trading history for 2000+ crypto pairs. Free market data, no key needed for public endpoints. Use for crypto prices, market data, trading automation.",
    "url": "https://binance.com",
    "api_base": "https://api.binance.com",
    "category": "finance",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://binance-docs.github.io/apidocs/spot/en/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_capabilities": [
      "get_price",
      "get_orderbook",
      "get_klines"
    ],
    "how_to_get": "Register at https://binance.com for trading endpoints",
    "cost": "Free for market data. Trading: 0.1% per trade"
  },
  "capabilities": [
    {
      "id": "get_ticker_price",
      "description_for_ai": "Get current price for one or all trading pairs on Binance.",
      "intent": [
        "crypto price Binance",
        "BTC price",
        "trading pair price",
        "цена криптовалюты Binance"
      ],
      "endpoint": "GET https://api.binance.com/api/v3/ticker/price",
      "input": {
        "symbol": {
          "type": "string",
          "description": "Trading pair e.g. BTCUSDT, ETHUSDT. Omit for all pairs.",
          "required": false
        }
      },
      "output": {
        "type": "price",
        "fields": [
          "symbol",
          "price"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_klines",
      "description_for_ai": "Get candlestick/OHLCV data for a trading pair. Use for charts and technical analysis.",
      "intent": [
        "candlestick data",
        "OHLCV Binance",
        "price history",
        "исторические данные Binance"
      ],
      "endpoint": "GET https://api.binance.com/api/v3/klines",
      "input": {
        "symbol": {
          "type": "string",
          "required": true
        },
        "interval": {
          "type": "string",
          "description": "1m, 3m, 5m, 15m, 30m, 1h, 2h, 4h, 6h, 8h, 12h, 1d, 3d, 1w, 1M",
          "required": true
        },
        "limit": {
          "type": "integer",
          "description": "Number of candles 1-1000",
          "default": 500
        },
        "startTime": {
          "type": "integer",
          "description": "Start Unix timestamp ms",
          "required": false
        },
        "endTime": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "list<candle>",
        "fields": [
          "[0][0] open_time",
          "[0][1] open",
          "[0][2] high",
          "[0][3] low",
          "[0][4] close",
          "[0][5] volume"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_order_book",
      "description_for_ai": "Get order book depth (bids and asks) for a trading pair.",
      "intent": [
        "order book Binance",
        "bid ask",
        "market depth",
        "стакан заявок Binance"
      ],
      "endpoint": "GET https://api.binance.com/api/v3/depth",
      "input": {
        "symbol": {
          "type": "string",
          "required": true
        },
        "limit": {
          "type": "integer",
          "description": "5, 10, 20, 50, 100, 500, 1000",
          "default": 100
        }
      },
      "output": {
        "type": "orderbook",
        "fields": [
          "bids[0] [price, qty]",
          "asks[0] [price, qty]",
          "lastUpdateId"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_account",
      "description_for_ai": "Get account balances and trading permissions.",
      "intent": [
        "Binance account",
        "crypto balance",
        "wallet balance Binance",
        "баланс Binance"
      ],
      "endpoint": "GET https://api.binance.com/api/v3/account",
      "input": {},
      "output": {
        "type": "account",
        "fields": [
          "balances[0].asset",
          "balances[0].free",
          "balances[0].locked",
          "canTrade",
          "canDeposit",
          "canWithdraw"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "place_order",
      "description_for_ai": "Place a buy or sell order on Binance.",
      "intent": [
        "buy crypto",
        "sell crypto",
        "place order Binance",
        "торговля Binance"
      ],
      "endpoint": "POST https://api.binance.com/api/v3/order",
      "input": {
        "symbol": {
          "type": "string",
          "required": true
        },
        "side": {
          "type": "string",
          "description": "BUY or SELL",
          "required": true
        },
        "type": {
          "type": "string",
          "description": "LIMIT, MARKET, STOP_LOSS_LIMIT, TAKE_PROFIT_LIMIT",
          "required": true
        },
        "quantity": {
          "type": "string",
          "required": true
        },
        "price": {
          "type": "string",
          "description": "Required for LIMIT orders",
          "required": false
        },
        "timeInForce": {
          "type": "string",
          "description": "GTC, IOC, FOK (required for LIMIT)",
          "required": false
        }
      },
      "output": {
        "type": "order",
        "fields": [
          "orderId",
          "status",
          "symbol",
          "side",
          "price",
          "executedQty",
          "transactTime"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_24hr_ticker",
      "description_for_ai": "Get 24-hour statistics: price change, volume, high, low for trading pairs.",
      "intent": [
        "24h stats crypto",
        "trading volume",
        "price change 24h",
        "статистика за 24ч Binance"
      ],
      "endpoint": "GET https://api.binance.com/api/v3/ticker/24hr",
      "input": {
        "symbol": {
          "type": "string",
          "description": "Single pair or omit for all",
          "required": false
        }
      },
      "output": {
        "type": "stats",
        "fields": [
          "symbol",
          "priceChange",
          "priceChangePercent",
          "weightedAvgPrice",
          "volume",
          "quoteVolume",
          "highPrice",
          "lowPrice"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}