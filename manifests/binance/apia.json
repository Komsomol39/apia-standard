{
  "apia": "1.0",
  "service": {
    "id": "binance",
    "name": "Binance API",
    "description_for_ai": "World largest crypto exchange by volume. Real-time prices, order books, trading history for 2000+ crypto pairs. Free market data, no key needed for public endpoints. Use for crypto prices, market data, trading automation.",
    "url": "https://binance.com",
    "api_base": "https://api.binance.com",
    "category": "finance",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://binance-docs.github.io/apidocs/spot/en/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_capabilities": [
      "get_price",
      "get_orderbook",
      "get_klines"
    ],
    "how_to_get": "Register at https://binance.com for trading endpoints",
    "cost": "Free for market data. Trading: 0.1% per trade"
  },
  "capabilities": [
    {
      "id": "get_price",
      "description_for_ai": "Get current price of any crypto pair. Real-time, no auth required.",
      "intent": [
        "bitcoin price",
        "crypto price",
        "BTC price",
        "цена биткоина",
        "курс крипты"
      ],
      "endpoint": "GET https://api.binance.com/api/v3/ticker/price",
      "input": {
        "symbol": {
          "type": "string",
          "description": "Trading pair e.g. BTCUSDT, ETHUSDT, BNBUSDT",
          "required": true
        }
      },
      "output": {
        "type": "price",
        "fields": [
          "symbol",
          "price"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_24h_stats",
      "description_for_ai": "Get 24h price change, high, low, volume for a trading pair.",
      "intent": [
        "24h stats",
        "price change",
        "crypto volume",
        "daily stats",
        "изменение цены за сутки"
      ],
      "endpoint": "GET https://api.binance.com/api/v3/ticker/24hr",
      "input": {
        "symbol": {
          "type": "string",
          "description": "e.g. BTCUSDT",
          "required": false
        }
      },
      "output": {
        "type": "stats",
        "fields": [
          "symbol",
          "priceChange",
          "priceChangePercent",
          "highPrice",
          "lowPrice",
          "volume",
          "quoteVolume"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_klines",
      "description_for_ai": "Get OHLCV candlestick data for chart analysis. Supports intervals from 1m to 1M.",
      "intent": [
        "candlestick data",
        "OHLCV",
        "price history crypto",
        "klines",
        "исторические цены крипты"
      ],
      "endpoint": "GET https://api.binance.com/api/v3/klines",
      "input": {
        "symbol": {
          "type": "string",
          "required": true
        },
        "interval": {
          "type": "string",
          "description": "1m, 5m, 15m, 1h, 4h, 1d, 1w, 1M",
          "required": true
        },
        "limit": {
          "type": "integer",
          "description": "Number of candles, max 1000",
          "default": 500
        },
        "startTime": {
          "type": "integer",
          "description": "Unix ms timestamp",
          "required": false
        },
        "endTime": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "list<candle>",
        "fields": [
          "[open_time, open, high, low, close, volume, close_time]"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_order_book",
      "description_for_ai": "Get order book (bids and asks) for a trading pair. Shows market depth.",
      "intent": [
        "order book",
        "bids asks",
        "market depth",
        "книга ордеров"
      ],
      "endpoint": "GET https://api.binance.com/api/v3/depth",
      "input": {
        "symbol": {
          "type": "string",
          "required": true
        },
        "limit": {
          "type": "integer",
          "description": "5, 10, 20, 50, 100, 500, 1000, 5000",
          "default": 100
        }
      },
      "output": {
        "type": "order_book",
        "fields": [
          "bids[0] ([price, quantity])",
          "asks[0] ([price, quantity])"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}