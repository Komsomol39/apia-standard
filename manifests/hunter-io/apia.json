{
  "apia": "1.0",
  "service": {
    "id": "hunter-io",
    "name": "Hunter.io API",
    "description_for_ai": "Hunter.io — email finder and verification API for B2B outreach. Find verified professional email addresses from domain names, full names, or LinkedIn profiles. Email validation with deliverability check. 25 free searches/month. Used by 3M+ sales and marketing professionals.",
    "url": "https://hunter.io",
    "api_base": "https://api.hunter.io/v2",
    "category": "business",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://hunter.io/api-documentation"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "api_key",
    "param_location": "query",
    "how_to_get": "Register at https://hunter.io — 25 searches/month free",
    "cost": "Free: 25/month. Starter: $49/month 500 searches"
  },
  "capabilities": [
    {
      "id": "domain_search",
      "description_for_ai": "Find all publicly known email addresses at a company domain. Returns emails with name, job title, and LinkedIn when available.",
      "intent": [
        "find company emails",
        "company contacts",
        "email prospecting",
        "sales leads",
        "find decision maker",
        "B2B emails"
      ],
      "endpoint": "GET https://api.hunter.io/v2/domain-search",
      "input": {
        "domain": {
          "type": "string",
          "description": "Company domain without http/www e.g. stripe.com, google.com, microsoft.com",
          "required": true
        },
        "company": {
          "type": "string",
          "description": "Company name as alternative to domain (less reliable)",
          "required": false
        },
        "limit": {
          "type": "integer",
          "description": "Max results per page, max 100",
          "default": 10
        },
        "offset": {
          "type": "integer",
          "description": "Pagination offset",
          "default": 0
        },
        "type": {
          "type": "string",
          "description": "Filter by email type: personal (first.last@) or generic (info@, support@, sales@)",
          "required": false
        },
        "seniority": {
          "type": "string",
          "description": "Filter by seniority level: junior, senior, executive",
          "required": false
        },
        "department": {
          "type": "string",
          "description": "Filter by department: executive, it, finance, management, sales, legal, support, hr, marketing, communication",
          "required": false
        }
      },
      "output": {
        "type": "domain_search",
        "fields": [
          "data.emails[0].value",
          "data.emails[0].first_name",
          "data.emails[0].last_name",
          "data.emails[0].position",
          "data.emails[0].department",
          "data.emails[0].seniority",
          "data.emails[0].linkedin",
          "data.organization",
          "meta.total"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "email_finder",
      "description_for_ai": "Find email address for a specific person at a company given their name and domain.",
      "intent": [
        "find email",
        "person email",
        "contact email",
        "email lookup",
        "find professional email"
      ],
      "endpoint": "GET https://api.hunter.io/v2/email-finder",
      "input": {
        "domain": {
          "type": "string",
          "required": true
        },
        "first_name": {
          "type": "string",
          "required": true
        },
        "last_name": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "email",
        "fields": [
          "data.email",
          "data.score",
          "data.first_name",
          "data.last_name",
          "data.sources[0].domain"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "verify_email",
      "description_for_ai": "Verify if an email address is valid and deliverable. Checks MX records, SMTP, disposable email.",
      "intent": [
        "verify email",
        "check email valid",
        "email validation",
        "is email deliverable"
      ],
      "endpoint": "GET https://api.hunter.io/v2/email-verifier",
      "input": {
        "email": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "verification",
        "fields": [
          "data.result",
          "data.score",
          "data.regexp",
          "data.gibberish",
          "data.disposable",
          "data.webmail",
          "data.mx_records",
          "data.smtp_server",
          "data.smtp_check"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}