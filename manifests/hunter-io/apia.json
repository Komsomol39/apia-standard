{
  "apia": "1.0",
  "service": {
    "id": "hunter-io",
    "name": "Hunter.io API",
    "description_for_ai": "Hunter.io — email finder and verification API for B2B outreach. Find verified professional email addresses from domain names, full names, or LinkedIn profiles. Email validation with deliverability check. 25 free searches/month. Used by 3M+ sales and marketing professionals.",
    "url": "https://hunter.io",
    "api_base": "https://api.hunter.io/v2",
    "category": "business",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://hunter.io/api-documentation"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "api_key",
    "param_location": "query",
    "how_to_get": "Register at https://hunter.io — 25 searches/month free",
    "cost": "Free: 25/month. Starter: $49/month 500 searches"
  },
  "capabilities": [
    {
      "id": "domain_search",
      "description_for_ai": "Find all professional email addresses for a company domain.",
      "intent": [
        "find emails Hunter",
        "company emails",
        "domain emails",
        "найти email Hunter.io"
      ],
      "endpoint": "GET https://api.hunter.io/v2/domain-search",
      "input": {
        "domain": {
          "type": "string",
          "description": "Company domain: google.com, microsoft.com",
          "required": true
        },
        "limit": {
          "type": "integer",
          "default": 10
        },
        "offset": {
          "type": "integer",
          "default": 0
        },
        "type": {
          "type": "string",
          "description": "personal or generic",
          "required": false
        },
        "department": {
          "type": "string",
          "description": "executive, finance, hr, it, marketing, sales, support",
          "required": false
        }
      },
      "output": {
        "type": "domain",
        "fields": [
          "data.emails[0].value",
          "data.emails[0].first_name",
          "data.emails[0].last_name",
          "data.emails[0].type",
          "data.emails[0].confidence",
          "data.organization"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "email_finder",
      "description_for_ai": "Find a person's professional email by name and company domain.",
      "intent": [
        "find email person",
        "email finder",
        "guess email",
        "найти email по имени"
      ],
      "endpoint": "GET https://api.hunter.io/v2/email-finder",
      "input": {
        "domain": {
          "type": "string",
          "required": true
        },
        "first_name": {
          "type": "string",
          "required": true
        },
        "last_name": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "email",
        "fields": [
          "data.email",
          "data.score (0-100 confidence)",
          "data.position",
          "data.first_name",
          "data.last_name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "email_verifier",
      "description_for_ai": "Verify if an email address is valid and deliverable.",
      "intent": [
        "verify email Hunter",
        "email validation",
        "check email validity",
        "проверить email Hunter"
      ],
      "endpoint": "GET https://api.hunter.io/v2/email-verifier",
      "input": {
        "email": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "verification",
        "fields": [
          "data.status (valid/invalid/accept_all/webmail/unknown)",
          "data.score",
          "data.disposable",
          "data.webmail",
          "data.smtp_server_accepts_all"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_account_info",
      "description_for_ai": "Get Hunter.io account info: plan, requests used/remaining.",
      "intent": [
        "Hunter account",
        "API quota",
        "requests remaining Hunter",
        "квота Hunter.io"
      ],
      "endpoint": "GET https://api.hunter.io/v2/account",
      "input": {},
      "output": {
        "type": "account",
        "fields": [
          "data.email",
          "data.plan_name",
          "data.requests.searches.used",
          "data.requests.searches.available",
          "data.requests.verifications.used"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "bulk_email_finder",
      "description_for_ai": "Find emails for multiple people in bulk (requires LEADS plan).",
      "intent": [
        "bulk email finder",
        "mass email find",
        "list email lookup",
        "массовый поиск email"
      ],
      "endpoint": "POST https://api.hunter.io/v2/bulk-email-finder",
      "input": {
        "people": {
          "type": "array",
          "description": "[{first_name: 'John', last_name: 'Doe', domain: 'google.com', company: 'Google'}]",
          "required": true
        }
      },
      "output": {
        "type": "list<email>",
        "fields": [
          "data[0].email",
          "data[0].score",
          "data[0].first_name",
          "data[0].last_name"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}