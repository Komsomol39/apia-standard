{
  "apia": "1.0",
  "service": {
    "id": "sentry",
    "name": "Sentry API",
    "description_for_ai": "Error tracking and performance monitoring. Captures exceptions, crashes, slow transactions. 4M+ developers use it. Use for error monitoring, crash reporting, performance profiling in apps.",
    "url": "https://sentry.io",
    "api_base": "https://sentry.io/api/0",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.sentry.io/api/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer {token}",
    "how_to_get": "Settings → Account → API Tokens",
    "cost": "Free: 5K errors/month. Team: $26/month"
  },
  "capabilities": [
    {
      "id": "list_issues",
      "description_for_ai": "List error issues in a Sentry project. Filter by status, priority, assignee, and tags.",
      "intent": [
        "Sentry issues",
        "error list",
        "bug tracking Sentry",
        "ошибки Sentry"
      ],
      "endpoint": "GET https://sentry.io/api/0/projects/{organization_slug}/{project_slug}/issues/",
      "input": {
        "organization_slug": {
          "type": "string",
          "required": true
        },
        "project_slug": {
          "type": "string",
          "required": true
        },
        "query": {
          "type": "string",
          "description": "Filter query: is:unresolved, level:error, assigned:me, !has:release",
          "default": "is:unresolved"
        },
        "sort": {
          "type": "string",
          "description": "date, new, priority, freq, trends",
          "default": "date"
        },
        "limit": {
          "type": "integer",
          "default": 25
        }
      },
      "output": {
        "type": "list<issue>",
        "fields": [
          "[0].id",
          "[0].title",
          "[0].culprit",
          "[0].level",
          "[0].count",
          "[0].userCount",
          "[0].firstSeen",
          "[0].lastSeen",
          "[0].status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_issue",
      "description_for_ai": "Get full details of a Sentry issue including stack trace, tags, and affected users.",
      "intent": [
        "issue details Sentry",
        "error details",
        "stack trace",
        "детали ошибки Sentry"
      ],
      "endpoint": "GET https://sentry.io/api/0/issues/{issue_id}/",
      "input": {
        "issue_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "issue",
        "fields": [
          "id",
          "title",
          "culprit",
          "level",
          "count",
          "userCount",
          "lastSeen",
          "tags",
          "assignedTo"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_issue",
      "description_for_ai": "Resolve, ignore, or assign a Sentry issue.",
      "intent": [
        "resolve Sentry issue",
        "assign error",
        "ignore error",
        "обновить ошибку Sentry"
      ],
      "endpoint": "PUT https://sentry.io/api/0/issues/{issue_id}/",
      "input": {
        "issue_id": {
          "type": "string",
          "required": true
        },
        "status": {
          "type": "string",
          "description": "resolved, unresolved, ignored",
          "required": false
        },
        "assignedTo": {
          "type": "string",
          "description": "Username or email to assign to",
          "required": false
        },
        "hasSeen": {
          "type": "boolean",
          "required": false
        }
      },
      "output": {
        "type": "issue",
        "fields": [
          "id",
          "status",
          "assignedTo"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_events",
      "description_for_ai": "List recent error events for a specific issue with full stack traces.",
      "intent": [
        "Sentry events",
        "error events",
        "error occurrences",
        "события ошибки Sentry"
      ],
      "endpoint": "GET https://sentry.io/api/0/issues/{issue_id}/events/",
      "input": {
        "issue_id": {
          "type": "string",
          "required": true
        },
        "limit": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<event>",
        "fields": [
          "[0].id",
          "[0].dateCreated",
          "[0].message",
          "[0].entries[0].data.values[0].stacktrace"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_project",
      "description_for_ai": "Create a new Sentry project for a platform/language.",
      "intent": [
        "create Sentry project",
        "new project monitoring",
        "add project Sentry",
        "новый проект Sentry"
      ],
      "endpoint": "POST https://sentry.io/api/0/teams/{organization_slug}/{team_slug}/projects/",
      "input": {
        "organization_slug": {
          "type": "string",
          "required": true
        },
        "team_slug": {
          "type": "string",
          "required": true
        },
        "name": {
          "type": "string",
          "required": true
        },
        "platform": {
          "type": "string",
          "description": "python, node, javascript, react, vue, django, flask, nextjs, etc.",
          "required": false
        }
      },
      "output": {
        "type": "project",
        "fields": [
          "id",
          "slug",
          "name",
          "platform",
          "dsn.public (SDK key)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "query_discover",
      "description_for_ai": "Run Discover queries to analyze errors and performance across projects.",
      "intent": [
        "Sentry analytics",
        "discover query",
        "performance analysis",
        "аналитика Sentry"
      ],
      "endpoint": "GET https://sentry.io/api/0/organizations/{organization_slug}/events/",
      "input": {
        "organization_slug": {
          "type": "string",
          "required": true
        },
        "field": {
          "type": "array",
          "description": "['transaction', 'count()', 'p95(transaction.duration)', 'error_rate()']",
          "required": true
        },
        "query": {
          "type": "string",
          "description": "Filter: event.type:error, has:user.email",
          "required": false
        },
        "sort": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "discover",
        "fields": [
          "data[0].transaction",
          "data[0].count()",
          "meta.fields"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}