{
  "apia": "1.0",
  "service": {
    "id": "sentry",
    "name": "Sentry API",
    "description_for_ai": "Error tracking and performance monitoring. Captures exceptions, crashes, slow transactions. 4M+ developers use it. Use for error monitoring, crash reporting, performance profiling in apps.",
    "url": "https://sentry.io",
    "api_base": "https://sentry.io/api/0",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.sentry.io/api/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer {token}",
    "how_to_get": "Settings → Account → API Tokens",
    "cost": "Free: 5K errors/month. Team: $26/month"
  },
  "capabilities": [
    {
      "id": "list_issues",
      "description_for_ai": "List Sentry error issues for a project with filters.",
      "intent": [
        "sentry errors",
        "sentry issues",
        "application errors",
        "ошибки sentry"
      ],
      "endpoint": "GET https://sentry.io/api/0/projects/{organization}/{project}/issues/",
      "input": {
        "organization": {
          "type": "string",
          "required": true
        },
        "project": {
          "type": "string",
          "required": true
        },
        "query": {
          "type": "string",
          "description": "Search: is:unresolved, level:error, browser:Chrome, user.email:user@example.com",
          "required": false
        },
        "sort": {
          "type": "string",
          "description": "date, freq, new, priority",
          "default": "date"
        },
        "limit": {
          "type": "integer",
          "default": 25
        }
      },
      "output": {
        "type": "list<issue>",
        "fields": [
          "[0].id",
          "[0].title",
          "[0].culprit",
          "[0].count",
          "[0].userCount",
          "[0].firstSeen",
          "[0].lastSeen",
          "[0].level"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_issue",
      "description_for_ai": "Get details of a specific Sentry issue with stack trace and event data.",
      "intent": [
        "sentry issue details",
        "error details sentry",
        "stack trace sentry",
        "детали ошибки sentry"
      ],
      "endpoint": "GET https://sentry.io/api/0/issues/{issue_id}/",
      "input": {
        "issue_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "issue",
        "fields": [
          "id",
          "title",
          "culprit",
          "metadata.filename",
          "count",
          "userCount",
          "firstSeen",
          "lastSeen",
          "tags"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "resolve_issue",
      "description_for_ai": "Resolve or ignore a Sentry issue.",
      "intent": [
        "resolve sentry issue",
        "close error sentry",
        "ignore error",
        "исправить ошибку sentry"
      ],
      "endpoint": "PUT https://sentry.io/api/0/issues/{issue_id}/",
      "input": {
        "issue_id": {
          "type": "string",
          "required": true
        },
        "status": {
          "type": "string",
          "description": "resolved, resolvedInNextRelease, ignored, unresolved",
          "required": true
        },
        "assignedTo": {
          "type": "string",
          "description": "Username or email to assign",
          "required": false
        }
      },
      "output": {
        "type": "issue",
        "fields": [
          "id",
          "status",
          "assignedTo"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_release",
      "description_for_ai": "Create a Sentry release to track deployments and associate errors with versions.",
      "intent": [
        "sentry release",
        "deployment sentry",
        "track version sentry",
        "релиз sentry"
      ],
      "endpoint": "POST https://sentry.io/api/0/organizations/{organization}/releases/",
      "input": {
        "organization": {
          "type": "string",
          "required": true
        },
        "version": {
          "type": "string",
          "description": "Release version e.g. 1.0.0 or git SHA",
          "required": true
        },
        "projects": {
          "type": "array",
          "description": "Project slugs",
          "required": true
        },
        "ref": {
          "type": "string",
          "description": "Git commit reference",
          "required": false
        },
        "url": {
          "type": "string",
          "description": "Release URL",
          "required": false
        }
      },
      "output": {
        "type": "release",
        "fields": [
          "version",
          "projects",
          "dateCreated",
          "url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}