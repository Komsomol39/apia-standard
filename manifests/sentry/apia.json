{
  "apia": "1.0",
  "service": {
    "id": "sentry",
    "name": "Sentry API",
    "description_for_ai": "Error tracking and performance monitoring. Captures exceptions, crashes, slow transactions. 4M+ developers use it. Use for error monitoring, crash reporting, performance profiling in apps.",
    "url": "https://sentry.io",
    "api_base": "https://sentry.io/api/0",
    "category": "developer_monitoring",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.sentry.io/api/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer {token}",
    "how_to_get": "Settings → Account → API Tokens",
    "cost": "Free: 5K errors/month. Team: $26/month"
  },
  "capabilities": [
    {
      "id": "list_issues",
      "description_for_ai": "Get Sentry error issues for a project. Filter by status, assignee, priority, or search query. Use for error monitoring dashboards and triage.",
      "intent": [
        "application errors",
        "exception tracking",
        "crash reports",
        "exception list",
        "sentry errors",
        "bug monitoring",
        "error monitoring",
        "error log",
        "production errors"
      ],
      "endpoint": "GET https://sentry.io/api/0/projects/{org}/{project}/issues/",
      "input": {
        "org": {
          "type": "string",
          "description": "Your Sentry organization slug (from URL: sentry.io/{ORG}/)",
          "required": true
        },
        "project": {
          "type": "string",
          "description": "Project slug to query",
          "required": true
        },
        "query": {
          "type": "string",
          "description": "Sentry query syntax: 'is:unresolved' (default), 'is:unresolved assigned:me', 'level:error has:browser.name', 'times_seen:>100'",
          "default": "is:unresolved"
        },
        "limit": {
          "type": "integer",
          "description": "Results per page, max 100",
          "default": 25
        },
        "cursor": {
          "type": "string",
          "description": "Pagination cursor from Link header",
          "required": false
        },
        "sort": {
          "type": "string",
          "description": "date (newest), new (first seen), priority, freq (most frequent), user (most users affected)",
          "default": "date"
        },
        "environment": {
          "type": "string",
          "description": "Filter by environment: production, staging, development",
          "required": false
        }
      },
      "output": {
        "type": "list<issue>",
        "fields": [
          "id",
          "title",
          "culprit",
          "count (total events)",
          "userCount",
          "firstSeen",
          "lastSeen",
          "status",
          "level",
          "assignedTo.email",
          "permalink"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "capture_event",
      "description_for_ai": "Send an error event to Sentry manually via HTTP. In production always use official Sentry SDK instead for better performance and context.",
      "intent": [
        "report error",
        "report exception",
        "send to sentry",
        "capture exception",
        "log error",
        "error reporting"
      ],
      "endpoint": "POST https://sentry.io/api/{project_id}/store/",
      "input": {
        "event_id": {
          "type": "string",
          "description": "UUID4 without dashes: e.g. 'fc6d8c0c43fc4630ad850ee518f1b9d0'",
          "required": true
        },
        "message": {
          "type": "string",
          "description": "Error message",
          "required": true
        },
        "level": {
          "type": "string",
          "description": "Severity: fatal, error, warning, info, debug",
          "default": "error"
        },
        "timestamp": {
          "type": "string",
          "description": "ISO 8601 event time e.g. '2024-01-15T10:00:00.000Z'",
          "required": false
        },
        "platform": {
          "type": "string",
          "description": "Platform: python, javascript, java, ruby, etc.",
          "default": "other"
        },
        "exception": {
          "type": "object",
          "description": "{values: [{type: 'ValueError', value: 'message', stacktrace: {frames: [{filename, lineno, function, context_line}]}}]}",
          "required": false
        },
        "tags": {
          "type": "object",
          "description": "Key-value tags: {environment: 'production', version: '1.2.3'}",
          "required": false
        },
        "user": {
          "type": "object",
          "description": "{id: 'user123', email: 'user@example.com', username: 'johndoe'}",
          "required": false
        }
      },
      "output": {
        "type": "event",
        "fields": [
          "id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}