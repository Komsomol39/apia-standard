{
  "apia": "1.0",
  "service": {
    "id": "sentry",
    "name": "Sentry API",
    "description_for_ai": "Error tracking and performance monitoring. Captures exceptions, crashes, slow transactions. 4M+ developers use it. Use for error monitoring, crash reporting, performance profiling in apps.",
    "url": "https://sentry.io",
    "api_base": "https://sentry.io/api/0",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.sentry.io/api/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer {token}",
    "how_to_get": "Settings → Account → API Tokens",
    "cost": "Free: 5K errors/month. Team: $26/month"
  },
  "capabilities": [
    {
      "id": "list_issues",
      "description_for_ai": "List error issues in Sentry with filters by status, assignee, and date.",
      "intent": [
        "sentry errors",
        "bug tracking sentry",
        "production errors",
        "ошибки sentry"
      ],
      "endpoint": "GET https://sentry.io/api/0/projects/{organization_slug}/{project_slug}/issues/",
      "input": {
        "organization_slug": {
          "type": "string",
          "required": true
        },
        "project_slug": {
          "type": "string",
          "required": true
        },
        "query": {
          "type": "string",
          "description": "Sentry query: is:unresolved, assigned:me, level:error, browser:Chrome",
          "required": false
        },
        "status": {
          "type": "string",
          "description": "resolved, unresolved, ignored",
          "default": "unresolved"
        },
        "limit": {
          "type": "integer",
          "default": 25
        }
      },
      "output": {
        "type": "list<issue>",
        "fields": [
          "[0].id",
          "[0].title",
          "[0].culprit",
          "[0].status",
          "[0].count",
          "[0].firstSeen",
          "[0].lastSeen"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_issue",
      "description_for_ai": "Get full Sentry issue details including stack trace and tags.",
      "intent": [
        "sentry issue details",
        "error details",
        "stack trace sentry",
        "детали ошибки sentry"
      ],
      "endpoint": "GET https://sentry.io/api/0/issues/{issue_id}/",
      "input": {
        "issue_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "issue",
        "fields": [
          "id",
          "title",
          "culprit",
          "status",
          "count",
          "userCount",
          "tags",
          "firstSeen",
          "lastSeen"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "resolve_issue",
      "description_for_ai": "Update Sentry issue status: resolve, ignore, or assign to team member.",
      "intent": [
        "resolve sentry issue",
        "close error",
        "ignore error sentry",
        "закрыть ошибку sentry"
      ],
      "endpoint": "PUT https://sentry.io/api/0/issues/{issue_id}/",
      "input": {
        "issue_id": {
          "type": "string",
          "required": true
        },
        "status": {
          "type": "string",
          "description": "resolved, unresolved, ignored",
          "required": true
        },
        "assignedTo": {
          "type": "string",
          "description": "Username or team slug to assign",
          "required": false
        }
      },
      "output": {
        "type": "issue",
        "fields": [
          "id",
          "status",
          "assignedTo"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_release",
      "description_for_ai": "Create a Sentry release to track deployments and associate errors with versions.",
      "intent": [
        "sentry release",
        "deployment tracking",
        "version release sentry",
        "релиз sentry"
      ],
      "endpoint": "POST https://sentry.io/api/0/organizations/{organization_slug}/releases/",
      "input": {
        "organization_slug": {
          "type": "string",
          "required": true
        },
        "version": {
          "type": "string",
          "description": "Release version: 1.0.0 or git SHA",
          "required": true
        },
        "projects": {
          "type": "array",
          "description": "Project slugs to associate",
          "required": true
        },
        "url": {
          "type": "string",
          "description": "URL with release info",
          "required": false
        },
        "dateReleased": {
          "type": "string",
          "description": "ISO 8601 datetime",
          "required": false
        }
      },
      "output": {
        "type": "release",
        "fields": [
          "version",
          "url",
          "projects[0].slug",
          "dateCreated"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}