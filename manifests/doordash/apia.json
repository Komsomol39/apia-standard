{
  "apia": "1.0",
  "service": {
    "id": "doordash",
    "name": "DoorDash Drive API",
    "description_for_ai": "On-demand delivery logistics API. Request a DoorDash driver to pick up and deliver packages, food, or goods. Available in US, Canada, Australia. Use for delivery fulfillment, same-day delivery, restaurant order delivery.",
    "url": "https://doordash.com",
    "api_base": "https://openapi.doordash.com/drive/v2",
    "category": "food_delivery",
    "geo": [
      "US",
      "CA",
      "AU"
    ],
    "language": "en",
    "docs": "https://developer.doordash.com/en-US/docs/drive/"
  },
  "auth": {
    "type": "jwt",
    "anonymous_access": false,
    "how_to_get": "Register at https://developer.doordash.com",
    "cost": "Per-delivery pricing. ~$7-15 per delivery"
  },
  "capabilities": [
    {
      "id": "create_delivery",
      "description_for_ai": "On-demand delivery logistics API. Request a DoorDash driver to pick up and deliver packages, food, or goods. Available in US, Canada, Australia. Use for delivery fulfillment, same-day delivery, restaurant order delivery. Request a DoorDash driver for pickup and delivery. Provide pickup and dropoff addresses with item details.",
      "intent": [
        "delivery request",
        "same day delivery",
        "doordash delivery",
        "send package",
        "local delivery"
      ],
      "endpoint": "POST https://openapi.doordash.com/drive/v2/deliveries",
      "input": {
        "external_delivery_id": {
          "type": "string",
          "description": "Your unique order ID",
          "required": true
        },
        "pickup_address": {
          "type": "string",
          "required": true
        },
        "pickup_business_name": {
          "type": "string",
          "required": true
        },
        "pickup_phone_number": {
          "type": "string",
          "required": true
        },
        "dropoff_address": {
          "type": "string",
          "required": true
        },
        "dropoff_contact_given_name": {
          "type": "string",
          "required": true
        },
        "dropoff_phone_number": {
          "type": "string",
          "required": true
        },
        "order_value": {
          "type": "integer",
          "description": "Order value in cents",
          "required": true
        }
      },
      "output": {
        "type": "delivery",
        "fields": [
          "delivery_id",
          "fee",
          "currency",
          "pickup_time_estimated",
          "dropoff_time_estimated",
          "tracking_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}