{
  "apia": "1.0",
  "service": {
    "id": "doordash",
    "name": "DoorDash Drive API",
    "description_for_ai": "On-demand delivery logistics API. Request a DoorDash driver to pick up and deliver packages, food, or goods. Available in US, Canada, Australia. Use for delivery fulfillment, same-day delivery, restaurant order delivery.",
    "url": "https://doordash.com",
    "api_base": "https://openapi.doordash.com/drive/v2",
    "category": "food",
    "geo": [
      "US",
      "CA",
      "AU"
    ],
    "language": "en",
    "docs": "https://developer.doordash.com/en-US/docs/drive/"
  },
  "auth": {
    "type": "jwt",
    "anonymous_access": false,
    "how_to_get": "Register at https://developer.doordash.com",
    "cost": "Per-delivery pricing. ~$7-15 per delivery"
  },
  "capabilities": [
    {
      "id": "search_restaurants",
      "description_for_ai": "Search DoorDash restaurants near a location.",
      "intent": [
        "DoorDash restaurants",
        "food delivery",
        "order food",
        "доставка еды DoorDash"
      ],
      "endpoint": "GET https://openapi.doordash.com/drive/v1/deliveries/quote",
      "input": {
        "pickup_address": {
          "type": "string",
          "description": "Pickup location",
          "required": true
        },
        "dropoff_address": {
          "type": "string",
          "description": "Delivery address",
          "required": true
        }
      },
      "output": {
        "type": "quote",
        "fields": [
          "external_delivery_id",
          "fee",
          "currency",
          "pickup_time_estimated",
          "dropoff_time_estimated"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_delivery",
      "description_for_ai": "Create a DoorDash Drive delivery (white-label delivery service for businesses).",
      "intent": [
        "DoorDash delivery",
        "create delivery",
        "delivery order",
        "заказ доставки DoorDash"
      ],
      "endpoint": "POST https://openapi.doordash.com/drive/v1/deliveries",
      "input": {
        "external_delivery_id": {
          "type": "string",
          "description": "Your unique delivery ID",
          "required": true
        },
        "pickup_address": {
          "type": "string",
          "required": true
        },
        "pickup_business_name": {
          "type": "string",
          "required": false
        },
        "pickup_phone_number": {
          "type": "string",
          "required": true
        },
        "pickup_instructions": {
          "type": "string",
          "required": false
        },
        "dropoff_address": {
          "type": "string",
          "required": true
        },
        "dropoff_contact_given_name": {
          "type": "string",
          "required": true
        },
        "dropoff_contact_phone_number": {
          "type": "string",
          "required": true
        },
        "order_value": {
          "type": "integer",
          "description": "Order value in cents",
          "required": true
        }
      },
      "output": {
        "type": "delivery",
        "fields": [
          "external_delivery_id",
          "delivery_status",
          "fee",
          "pickup_time_estimated",
          "dropoff_time_estimated",
          "tracking_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_delivery_status",
      "description_for_ai": "Track status of a DoorDash delivery.",
      "intent": [
        "delivery status DoorDash",
        "track delivery",
        "отследить доставку DoorDash"
      ],
      "endpoint": "GET https://openapi.doordash.com/drive/v1/deliveries/{external_delivery_id}",
      "input": {
        "external_delivery_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "delivery",
        "fields": [
          "delivery_status",
          "dasher_name",
          "dasher_location.lat",
          "dasher_location.lng",
          "dropoff_time_estimated",
          "tracking_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "cancel_delivery",
      "description_for_ai": "Cancel a DoorDash delivery before it is picked up.",
      "intent": [
        "cancel DoorDash",
        "cancel delivery",
        "отменить доставку DoorDash"
      ],
      "endpoint": "PUT https://openapi.doordash.com/drive/v1/deliveries/{external_delivery_id}/cancel",
      "input": {
        "external_delivery_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "delivery",
        "fields": [
          "external_delivery_id",
          "delivery_status (cancelled)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_delivery",
      "description_for_ai": "Update dropoff details for an in-progress DoorDash delivery.",
      "intent": [
        "update delivery",
        "change delivery address",
        "изменить доставку DoorDash"
      ],
      "endpoint": "PATCH https://openapi.doordash.com/drive/v1/deliveries/{external_delivery_id}",
      "input": {
        "external_delivery_id": {
          "type": "string",
          "required": true
        },
        "dropoff_address": {
          "type": "string",
          "required": false
        },
        "dropoff_instructions": {
          "type": "string",
          "required": false
        },
        "tip": {
          "type": "integer",
          "description": "Tip in cents",
          "required": false
        }
      },
      "output": {
        "type": "delivery",
        "fields": [
          "external_delivery_id",
          "delivery_status",
          "dropoff_time_estimated"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}