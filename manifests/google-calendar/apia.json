{
  "apia": "1.0",
  "service": {
    "id": "google-calendar",
    "name": "Google Calendar API",
    "description_for_ai": "Read and write Google Calendar events. Create meetings, check availability, list events, manage calendars. 1B+ users. Use for scheduling apps, meeting management, availability checking.",
    "url": "https://calendar.google.com",
    "api_base": "https://www.googleapis.com/calendar/v3",
    "category": "productivity",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.google.com/calendar/api/v3/reference"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Enable Calendar API at https://console.cloud.google.com",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "list_events",
      "description_for_ai": "Get upcoming or past calendar events with full details. Filter by date range, search query, or calendar. Supports recurring events.",
      "intent": [
        "calendar events",
        "my schedule",
        "upcoming meetings",
        "what is on calendar",
        "free slots",
        "busy times",
        "meeting list",
        "расписание",
        "встречи"
      ],
      "endpoint": "GET https://www.googleapis.com/calendar/v3/calendars/{calendarId}/events",
      "input": {
        "calendarId": {
          "type": "string",
          "description": "Calendar ID. Use 'primary' for main calendar, or full calendar ID like user@gmail.com",
          "default": "primary"
        },
        "timeMin": {
          "type": "string",
          "description": "Lower bound for event end time, ISO 8601 format with timezone. E.g. 2024-01-15T00:00:00Z",
          "required": false
        },
        "timeMax": {
          "type": "string",
          "description": "Upper bound for event start time, ISO 8601 format. E.g. 2024-01-22T23:59:59Z",
          "required": false
        },
        "q": {
          "type": "string",
          "description": "Free-text search query matching event title, description, location, attendees",
          "required": false
        },
        "maxResults": {
          "type": "integer",
          "description": "Max events to return, default 250, max 2500",
          "default": 10
        },
        "orderBy": {
          "type": "string",
          "description": "startTime (requires singleEvents=true) or updated",
          "default": "startTime"
        },
        "singleEvents": {
          "type": "boolean",
          "description": "Expand recurring events into individual instances. Required for orderBy=startTime",
          "default": true
        },
        "showDeleted": {
          "type": "boolean",
          "description": "Include deleted events in results",
          "default": false
        }
      },
      "output": {
        "type": "list<event>",
        "fields": [
          "items[0].id",
          "items[0].summary",
          "items[0].start.dateTime",
          "items[0].end.dateTime",
          "items[0].location",
          "items[0].description",
          "items[0].attendees",
          "items[0].htmlLink",
          "items[0].status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_event",
      "description_for_ai": "Create a new calendar event with title, time, location, attendees, reminders, and recurrence rules.",
      "intent": [
        "create meeting",
        "add to calendar",
        "schedule event",
        "book appointment",
        "set reminder",
        "новая встреча",
        "добавить в календарь",
        "запланировать"
      ],
      "endpoint": "POST https://www.googleapis.com/calendar/v3/calendars/{calendarId}/events",
      "input": {
        "calendarId": {
          "type": "string",
          "description": "Target calendar ID, use 'primary' for main",
          "default": "primary"
        },
        "summary": {
          "type": "string",
          "description": "Event title",
          "required": true
        },
        "start": {
          "type": "object",
          "description": "{dateTime: '2024-01-15T14:00:00', timeZone: 'Europe/Moscow'} for timed events, or {date: '2024-01-15'} for all-day",
          "required": true
        },
        "end": {
          "type": "object",
          "description": "{dateTime: '2024-01-15T15:00:00', timeZone: 'Europe/Moscow'} or {date: '2024-01-16'} for all-day",
          "required": true
        },
        "location": {
          "type": "string",
          "description": "Physical location or meeting URL",
          "required": false
        },
        "description": {
          "type": "string",
          "description": "Event description/notes (supports some HTML)",
          "required": false
        },
        "attendees": {
          "type": "array",
          "description": "[{email: 'user@example.com', optional: false}] — invites guests and sends emails",
          "required": false
        },
        "reminders": {
          "type": "object",
          "description": "{useDefault: false, overrides: [{method: 'email'|'popup', minutes: 30}]}",
          "required": false
        },
        "recurrence": {
          "type": "array",
          "description": "['RRULE:FREQ=WEEKLY;BYDAY=MO,WE,FR'] for recurring events",
          "required": false
        },
        "conferenceData": {
          "type": "object",
          "description": "{createRequest: {requestId: 'unique-id', conferenceSolutionKey: {type: 'hangoutsMeet'}}} to auto-create Google Meet",
          "required": false
        },
        "sendUpdates": {
          "type": "string",
          "description": "all (notify all attendees), externalOnly, or none. Default none.",
          "required": false
        }
      },
      "output": {
        "type": "event",
        "fields": [
          "id",
          "htmlLink",
          "summary",
          "start.dateTime",
          "end.dateTime",
          "hangoutLink",
          "conferenceData.entryPoints[0].uri"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}