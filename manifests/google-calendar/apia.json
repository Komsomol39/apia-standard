{
  "apia": "1.0",
  "service": {
    "id": "google-calendar",
    "name": "Google Calendar API",
    "description_for_ai": "Read and write Google Calendar events. Create meetings, check availability, list events, manage calendars. 1B+ users. Use for scheduling apps, meeting management, availability checking.",
    "url": "https://calendar.google.com",
    "api_base": "https://www.googleapis.com/calendar/v3",
    "category": "productivity",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.google.com/calendar/api/v3/reference"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Enable Calendar API at https://console.cloud.google.com",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "list_events",
      "description_for_ai": "Get calendar events in a time range. Filter by search query, attendee, or calendar.",
      "intent": [
        "calendar events",
        "my schedule",
        "upcoming meetings",
        "what is on calendar",
        "расписание",
        "встречи"
      ],
      "endpoint": "GET https://www.googleapis.com/calendar/v3/calendars/{calendarId}/events",
      "input": {
        "calendarId": {
          "type": "string",
          "default": "primary"
        },
        "timeMin": {
          "type": "string",
          "description": "ISO 8601 start time e.g. 2024-01-15T00:00:00Z",
          "required": false
        },
        "timeMax": {
          "type": "string",
          "required": false
        },
        "q": {
          "type": "string",
          "description": "Search query",
          "required": false
        },
        "maxResults": {
          "type": "integer",
          "default": 10
        },
        "singleEvents": {
          "type": "boolean",
          "description": "Expand recurring events",
          "default": true
        },
        "orderBy": {
          "type": "string",
          "default": "startTime"
        }
      },
      "output": {
        "type": "list<event>",
        "fields": [
          "items[0].id",
          "items[0].summary",
          "items[0].start.dateTime",
          "items[0].end.dateTime",
          "items[0].location",
          "items[0].attendees",
          "items[0].htmlLink"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_event",
      "description_for_ai": "Create a calendar event with title, time, location, attendees, reminders, Google Meet link, and recurrence.",
      "intent": [
        "create meeting",
        "add to calendar",
        "schedule event",
        "new event",
        "новая встреча",
        "добавить в календарь"
      ],
      "endpoint": "POST https://www.googleapis.com/calendar/v3/calendars/{calendarId}/events",
      "input": {
        "calendarId": {
          "type": "string",
          "default": "primary"
        },
        "summary": {
          "type": "string",
          "description": "Event title",
          "required": true
        },
        "start": {
          "type": "object",
          "description": "{dateTime: '2024-01-15T14:00:00', timeZone: 'Europe/Moscow'} or {date: '2024-01-15'} for all-day",
          "required": true
        },
        "end": {
          "type": "object",
          "required": true
        },
        "location": {
          "type": "string",
          "required": false
        },
        "description": {
          "type": "string",
          "required": false
        },
        "attendees": {
          "type": "array",
          "description": "[{email: 'user@example.com'}]",
          "required": false
        },
        "reminders": {
          "type": "object",
          "description": "{useDefault: false, overrides: [{method: 'popup', minutes: 15}]}",
          "required": false
        },
        "recurrence": {
          "type": "array",
          "description": "['RRULE:FREQ=WEEKLY;BYDAY=MO,WE']",
          "required": false
        },
        "conferenceData": {
          "type": "object",
          "description": "{createRequest: {requestId: 'unique', conferenceSolutionKey: {type: 'hangoutsMeet'}}}",
          "required": false
        },
        "sendUpdates": {
          "type": "string",
          "description": "all, externalOnly, none",
          "required": false
        }
      },
      "output": {
        "type": "event",
        "fields": [
          "id",
          "htmlLink",
          "hangoutLink",
          "conferenceData.entryPoints[0].uri",
          "summary",
          "start.dateTime"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_event",
      "description_for_ai": "Update an existing calendar event. Change time, location, title, attendees, or description.",
      "intent": [
        "update meeting",
        "reschedule event",
        "change meeting time",
        "edit event",
        "перенести встречу"
      ],
      "endpoint": "PATCH https://www.googleapis.com/calendar/v3/calendars/{calendarId}/events/{eventId}",
      "input": {
        "calendarId": {
          "type": "string",
          "default": "primary"
        },
        "eventId": {
          "type": "string",
          "required": true
        },
        "summary": {
          "type": "string",
          "required": false
        },
        "start": {
          "type": "object",
          "required": false
        },
        "end": {
          "type": "object",
          "required": false
        },
        "location": {
          "type": "string",
          "required": false
        },
        "description": {
          "type": "string",
          "required": false
        },
        "attendees": {
          "type": "array",
          "required": false
        },
        "sendUpdates": {
          "type": "string",
          "description": "all — sends update emails to guests",
          "required": false
        }
      },
      "output": {
        "type": "event",
        "fields": [
          "id",
          "summary",
          "start.dateTime",
          "updated"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "delete_event",
      "description_for_ai": "Delete a calendar event. Optionally notify attendees.",
      "intent": [
        "delete event",
        "cancel meeting",
        "remove from calendar",
        "удалить встречу",
        "отменить событие"
      ],
      "endpoint": "DELETE https://www.googleapis.com/calendar/v3/calendars/{calendarId}/events/{eventId}",
      "input": {
        "calendarId": {
          "type": "string",
          "default": "primary"
        },
        "eventId": {
          "type": "string",
          "required": true
        },
        "sendUpdates": {
          "type": "string",
          "description": "all to notify attendees of cancellation",
          "required": false
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "204 No Content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_calendars",
      "description_for_ai": "List all calendars in the user's account with IDs. Use calendar IDs in other methods.",
      "intent": [
        "list calendars",
        "all calendars",
        "calendar list",
        "список календарей"
      ],
      "endpoint": "GET https://www.googleapis.com/calendar/v3/users/me/calendarList",
      "input": {
        "showHidden": {
          "type": "boolean",
          "default": false
        },
        "showDeleted": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "list<calendar>",
        "fields": [
          "items[0].id",
          "items[0].summary",
          "items[0].primary",
          "items[0].backgroundColor",
          "items[0].accessRole"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_freebusy",
      "description_for_ai": "Check free/busy availability for calendars within a time range. Use for scheduling assistants.",
      "intent": [
        "check availability",
        "free slots",
        "busy times",
        "when is free",
        "когда свободен"
      ],
      "endpoint": "POST https://www.googleapis.com/calendar/v3/freeBusy",
      "input": {
        "timeMin": {
          "type": "string",
          "description": "ISO 8601 start time",
          "required": true
        },
        "timeMax": {
          "type": "string",
          "description": "ISO 8601 end time",
          "required": true
        },
        "items": {
          "type": "array",
          "description": "[{id: 'primary'}, {id: 'user@example.com'}] — calendars to check",
          "required": true
        },
        "timeZone": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "freebusy",
        "fields": [
          "calendars.primary.busy[0].start",
          "calendars.primary.busy[0].end"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}