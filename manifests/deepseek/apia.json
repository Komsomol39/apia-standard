{
  "apia": "1.0",
  "service": {
    "id": "deepseek",
    "name": "DeepSeek API",
    "description_for_ai": "Chinese AI lab with cheapest frontier-quality models. DeepSeek V3 and R1 offer near-GPT-4 quality at 10-50x lower cost. OpenAI-compatible API. Best for high-volume, cost-sensitive applications. DeepSeek R1 has strong reasoning/math. Note: servers in China — consider latency and data privacy.",
    "url": "https://deepseek.com",
    "api_base": "https://api.deepseek.com/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.deepseek.com/docs"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer sk-...",
    "how_to_get": "Register at https://platform.deepseek.com — free $5 credit",
    "cost": "DeepSeek V4 Flash: $0.14/$0.28 per 1M tokens. DeepSeek R1: $0.55/$2.19. Cache hits: $0.014/$0.028"
  },
  "capabilities": [
    {
      "id": "chat_completion",
      "description_for_ai": "Chat with DeepSeek models. Chinese-developed AI, strong at coding and math. OpenAI-compatible API.",
      "intent": [
        "DeepSeek chat",
        "Chinese AI",
        "cheap AI",
        "DeepSeek API",
        "чат DeepSeek"
      ],
      "endpoint": "POST https://api.deepseek.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "description": "deepseek-chat (V3, general), deepseek-reasoner (R1, reasoning)",
          "required": true
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "temperature": {
          "type": "float",
          "default": 1.0
        },
        "max_tokens": {
          "type": "integer",
          "required": false
        },
        "stream": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "usage.prompt_tokens",
          "usage.completion_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "reasoning_r1",
      "description_for_ai": "Use DeepSeek-R1 for complex reasoning, math, and logic. Shows chain-of-thought thinking before answering.",
      "intent": [
        "DeepSeek reasoning",
        "R1 model",
        "math AI",
        "chain of thought",
        "рассуждение DeepSeek R1"
      ],
      "endpoint": "POST https://api.deepseek.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "deepseek-reasoner"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "max_tokens": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.reasoning_content (thinking)",
          "choices[0].message.content (answer)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "code_generation",
      "description_for_ai": "Generate, complete, and review code. DeepSeek V3 is top-ranked on coding benchmarks.",
      "intent": [
        "code generation DeepSeek",
        "DeepSeek coder",
        "write code AI",
        "программирование DeepSeek"
      ],
      "endpoint": "POST https://api.deepseek.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "deepseek-chat"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "temperature": {
          "type": "float",
          "description": "0.0 for deterministic code",
          "default": 0.0
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "prefix_caching",
      "description_for_ai": "Use DeepSeek with prefix caching for repeated prompts — saves cost when system prompt is reused.",
      "intent": [
        "prefix caching",
        "cache prompt",
        "reduce AI cost",
        "кэш промптов"
      ],
      "endpoint": "POST https://api.deepseek.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "required": true
        },
        "messages": {
          "type": "array",
          "required": true
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "usage.prompt_cache_hit_tokens",
          "usage.prompt_cache_miss_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "json_mode",
      "description_for_ai": "Force DeepSeek to output strict JSON. Reliable structured extraction.",
      "intent": [
        "JSON mode DeepSeek",
        "structured output",
        "extract JSON",
        "структурированный вывод DeepSeek"
      ],
      "endpoint": "POST https://api.deepseek.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "required": true
        },
        "messages": {
          "type": "array",
          "description": "Include 'Output JSON' in system prompt",
          "required": true
        },
        "response_format": {
          "type": "object",
          "description": "{type: 'json_object'}",
          "required": true
        }
      },
      "output": {
        "type": "json",
        "fields": [
          "choices[0].message.content (valid JSON string)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_balance",
      "description_for_ai": "Check your DeepSeek API account balance and usage.",
      "intent": [
        "DeepSeek balance",
        "API credits",
        "account balance",
        "баланс DeepSeek"
      ],
      "endpoint": "GET https://api.deepseek.com/user/balance",
      "input": {},
      "output": {
        "type": "balance",
        "fields": [
          "is_available",
          "balance_infos[0].total_balance",
          "balance_infos[0].currency"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "price_tip": "DeepSeek V4 Flash at $0.14/$0.28 is 10-50x cheaper than GPT-4o for similar quality tasks.",
    "reasoner": "deepseek-reasoner (R1) shows chain-of-thought in reasoning_content field before final answer. Best for math, code, logic.",
    "openai_compat": "Drop-in OpenAI replacement: change base URL + model name. No other code changes needed.",
    "cache_discount": "Cache hit pricing is 100x cheaper — structure prompts to maximize cache reuse.",
    "data_privacy": "Servers in China. Do not send sensitive personal data or confidential business information.",
    "stability": "DeepSeek has had reliability issues during peak demand. Add retry logic and consider fallback to OpenAI/Gemini."
  },
  "limits": {
    "commercial_use": true,
    "attribution_required": false,
    "free_credit_usd": 5
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}