{
  "apia": "1.0",
  "service": {
    "id": "pexels",
    "name": "Pexels API",
    "description_for_ai": "Free stock photos and videos API. 4M+ high-quality photos and videos. No attribution required for most uses. 200 req/hr free. Alternative to Unsplash. Use for adding visual content to apps, websites, presentations.",
    "url": "https://pexels.com",
    "api_base": "https://api.pexels.com",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.pexels.com/api/documentation/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: {api_key}",
    "how_to_get": "Register at https://www.pexels.com/api/ — free",
    "cost": "Free: 200 req/hr, 20K req/month"
  },
  "capabilities": [
    {
      "id": "search_photos",
      "description_for_ai": "Search free stock photos on Pexels by keyword.",
      "intent": [
        "search photos Pexels",
        "free stock photos",
        "image search Pexels",
        "поиск фото Pexels"
      ],
      "endpoint": "GET https://api.pexels.com/v1/search",
      "input": {
        "query": {
          "type": "string",
          "required": true
        },
        "per_page": {
          "type": "integer",
          "default": 15
        },
        "page": {
          "type": "integer",
          "default": 1
        },
        "orientation": {
          "type": "string",
          "description": "landscape, portrait, square",
          "required": false
        },
        "size": {
          "type": "string",
          "description": "large (24MP+), medium (12MP+), small",
          "required": false
        },
        "locale": {
          "type": "string",
          "description": "en-US, ru-RU, de-DE, fr-FR, etc.",
          "required": false
        }
      },
      "output": {
        "type": "list<photo>",
        "fields": [
          "photos[0].id",
          "photos[0].url",
          "photos[0].photographer",
          "photos[0].src.original",
          "photos[0].src.large2x",
          "photos[0].src.medium",
          "photos[0].alt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_photo",
      "description_for_ai": "Get details and download URLs for a specific Pexels photo by ID.",
      "intent": [
        "photo details Pexels",
        "download photo",
        "Pexels image URL",
        "фото Pexels по ID"
      ],
      "endpoint": "GET https://api.pexels.com/v1/photos/{id}",
      "input": {
        "id": {
          "type": "integer",
          "description": "Pexels photo ID",
          "required": true
        }
      },
      "output": {
        "type": "photo",
        "fields": [
          "id",
          "photographer",
          "url",
          "src.original",
          "src.large",
          "src.medium",
          "src.small",
          "alt",
          "width",
          "height"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_videos",
      "description_for_ai": "Search free stock videos on Pexels.",
      "intent": [
        "search videos Pexels",
        "free stock video",
        "video footage Pexels",
        "поиск видео Pexels"
      ],
      "endpoint": "GET https://api.pexels.com/videos/search",
      "input": {
        "query": {
          "type": "string",
          "required": true
        },
        "per_page": {
          "type": "integer",
          "default": 15
        },
        "min_duration": {
          "type": "integer",
          "description": "Minimum duration in seconds",
          "required": false
        },
        "max_duration": {
          "type": "integer",
          "required": false
        },
        "orientation": {
          "type": "string",
          "description": "landscape, portrait, square",
          "required": false
        }
      },
      "output": {
        "type": "list<video>",
        "fields": [
          "videos[0].id",
          "videos[0].url",
          "videos[0].video_files[0].link",
          "videos[0].video_files[0].quality",
          "videos[0].duration"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_curated_photos",
      "description_for_ai": "Get Pexels' curated collection of high-quality photos.",
      "intent": [
        "curated photos",
        "featured photos Pexels",
        "best photos Pexels",
        "лучшие фото Pexels"
      ],
      "endpoint": "GET https://api.pexels.com/v1/curated",
      "input": {
        "per_page": {
          "type": "integer",
          "default": 15
        },
        "page": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<photo>",
        "fields": [
          "photos[0].id",
          "photos[0].photographer",
          "photos[0].src.large2x",
          "photos[0].alt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_popular_videos",
      "description_for_ai": "Get the most popular videos on Pexels.",
      "intent": [
        "popular videos Pexels",
        "trending videos",
        "video library",
        "популярные видео Pexels"
      ],
      "endpoint": "GET https://api.pexels.com/videos/popular",
      "input": {
        "per_page": {
          "type": "integer",
          "default": 15
        },
        "min_width": {
          "type": "integer",
          "required": false
        },
        "min_height": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "list<video>",
        "fields": [
          "videos[0].id",
          "videos[0].url",
          "videos[0].duration",
          "videos[0].user.name",
          "videos[0].video_files[0].link"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "attribution": "Photos technically require attribution but Pexels allows free use without it for most purposes. Always credit photographer when possible.",
    "sizes": "src.original=full size, src.large=1920px, src.medium=1280px, src.small=640px, src.tiny=280px"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}