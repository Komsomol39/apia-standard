{
  "apia": "1.0",
  "service": {
    "id": "pexels",
    "name": "Pexels API",
    "description_for_ai": "Free stock photos and videos API. 4M+ high-quality photos and videos. No attribution required for most uses. 200 req/hr free. Alternative to Unsplash. Use for adding visual content to apps, websites, presentations.",
    "url": "https://pexels.com",
    "api_base": "https://api.pexels.com",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.pexels.com/api/documentation/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: {api_key}",
    "how_to_get": "Register at https://www.pexels.com/api/ — free",
    "cost": "Free: 200 req/hr, 20K req/month"
  },
  "capabilities": [
    {
      "id": "search_photos",
      "description_for_ai": "Search Pexels for free stock photos. Returns high-res images with photographer credits.",
      "intent": [
        "pexels photos",
        "stock photos pexels",
        "free images pexels",
        "фото pexels"
      ],
      "endpoint": "GET https://api.pexels.com/v1/search",
      "input": {
        "query": {
          "type": "string",
          "required": true
        },
        "per_page": {
          "type": "integer",
          "default": 15
        },
        "page": {
          "type": "integer",
          "default": 1
        },
        "orientation": {
          "type": "string",
          "description": "landscape, portrait, square",
          "required": false
        },
        "size": {
          "type": "string",
          "description": "large (>24MP), medium, small",
          "required": false
        },
        "color": {
          "type": "string",
          "description": "Hex (#ffffff) or color name: red, orange, yellow, green, turquoise, blue, violet, pink, brown, black, gray, white",
          "required": false
        }
      },
      "output": {
        "type": "list<photo>",
        "fields": [
          "photos[0].id",
          "photos[0].url",
          "photos[0].src.original",
          "photos[0].src.medium",
          "photos[0].photographer",
          "total_results"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_videos",
      "description_for_ai": "Search Pexels for free stock videos. Returns MP4 with multiple quality levels.",
      "intent": [
        "pexels video",
        "stock video pexels",
        "free video footage",
        "видео pexels"
      ],
      "endpoint": "GET https://api.pexels.com/videos/search",
      "input": {
        "query": {
          "type": "string",
          "required": true
        },
        "per_page": {
          "type": "integer",
          "default": 15
        },
        "orientation": {
          "type": "string",
          "description": "landscape, portrait, square",
          "required": false
        },
        "size": {
          "type": "string",
          "description": "large, medium, small",
          "required": false
        }
      },
      "output": {
        "type": "list<video>",
        "fields": [
          "videos[0].id",
          "videos[0].url",
          "videos[0].video_files[0].link",
          "videos[0].video_files[0].quality",
          "videos[0].user.name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_curated_photos",
      "description_for_ai": "Get Pexels curated collection of top photos updated daily. Good for default imagery.",
      "intent": [
        "curated photos",
        "popular pexels",
        "trending photos",
        "популярные фото pexels"
      ],
      "endpoint": "GET https://api.pexels.com/v1/curated",
      "input": {
        "per_page": {
          "type": "integer",
          "default": 15
        },
        "page": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<photo>",
        "fields": [
          "photos[0].src.medium",
          "photos[0].photographer",
          "photos[0].alt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_photo",
      "description_for_ai": "Get a specific Pexels photo by ID with all resolution sizes.",
      "intent": [
        "get pexels photo",
        "photo by id pexels",
        "конкретное фото pexels"
      ],
      "endpoint": "GET https://api.pexels.com/v1/photos/{id}",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "photo",
        "fields": [
          "id",
          "url",
          "src.original",
          "src.large2x",
          "src.medium",
          "src.small",
          "photographer"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "attribution": "Photos technically require attribution but Pexels allows free use without it for most purposes. Always credit photographer when possible.",
    "sizes": "src.original=full size, src.large=1920px, src.medium=1280px, src.small=640px, src.tiny=280px"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}