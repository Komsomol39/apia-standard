{
  "apia": "1.0",
  "service": {
    "id": "pexels",
    "name": "Pexels API",
    "description_for_ai": "Free stock photos and videos API. 4M+ high-quality photos and videos. No attribution required for most uses. 200 req/hr free. Alternative to Unsplash. Use for adding visual content to apps, websites, presentations.",
    "url": "https://pexels.com",
    "api_base": "https://api.pexels.com",
    "category": "media_images",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.pexels.com/api/documentation/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: {api_key}",
    "how_to_get": "Register at https://www.pexels.com/api/ — free",
    "cost": "Free: 200 req/hr, 20K req/month"
  },
  "capabilities": [
    {
      "id": "search_photos",
      "description_for_ai": "Search Pexels free stock photos by keyword. Returns high-resolution images with multiple size options and photographer credit.",
      "intent": [
        "free photos",
        "stock images",
        "find images",
        "photo search",
        "background photo",
        "free images",
        "стоковые фото"
      ],
      "endpoint": "GET https://api.pexels.com/v1/search",
      "input": {
        "query": {
          "type": "string",
          "description": "Search term e.g. 'mountains sunset', 'business meeting', 'abstract background'",
          "required": true
        },
        "per_page": {
          "type": "integer",
          "description": "Results per page, max 80",
          "default": 15
        },
        "page": {
          "type": "integer",
          "description": "Page number for pagination",
          "default": 1
        },
        "orientation": {
          "type": "string",
          "description": "landscape, portrait, or square",
          "required": false
        },
        "size": {
          "type": "string",
          "description": "large (min 24MP), medium (min 12MP), or small (min 4MP)",
          "required": false
        },
        "color": {
          "type": "string",
          "description": "Filter by color: red, orange, yellow, green, turquoise, blue, violet, pink, brown, black, gray, white",
          "required": false
        },
        "locale": {
          "type": "string",
          "description": "Search language locale e.g. en-US, es-ES, fr-FR, de-DE, ru-RU",
          "default": "en-US"
        }
      },
      "output": {
        "type": "list<photo>",
        "fields": [
          "photos[0].id",
          "photos[0].photographer",
          "photos[0].photographer_url",
          "photos[0].src.original",
          "photos[0].src.large2x",
          "photos[0].src.large",
          "photos[0].src.medium",
          "photos[0].src.small",
          "photos[0].alt",
          "total_results"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "search_videos",
      "description_for_ai": "Search Pexels free stock videos by keyword. Returns MP4 video files in multiple resolutions.",
      "intent": [
        "free video",
        "stock footage",
        "background video",
        "video clip",
        "B-roll"
      ],
      "endpoint": "GET https://api.pexels.com/videos/search",
      "input": {
        "query": {
          "type": "string",
          "description": "Search term for videos",
          "required": true
        },
        "per_page": {
          "type": "integer",
          "description": "Results per page, max 80",
          "default": 15
        },
        "page": {
          "type": "integer",
          "default": 1,
          "description": "Page number for pagination (1-indexed)"
        },
        "orientation": {
          "type": "string",
          "description": "landscape, portrait, or square",
          "required": false
        },
        "size": {
          "type": "string",
          "description": "large, medium, or small minimum resolution",
          "required": false
        },
        "locale": {
          "type": "string",
          "default": "en-US",
          "description": "Locale code: en-US, ru-RU, de-DE, fr-FR, etc."
        }
      },
      "output": {
        "type": "list<video>",
        "fields": [
          "videos[0].id",
          "videos[0].url",
          "videos[0].image (thumbnail)",
          "videos[0].duration (seconds)",
          "videos[0].user.name",
          "videos[0].video_files[0].link",
          "videos[0].video_files[0].quality",
          "videos[0].video_files[0].width"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "attribution": "Photos technically require attribution but Pexels allows free use without it for most purposes. Always credit photographer when possible.",
    "sizes": "src.original=full size, src.large=1920px, src.medium=1280px, src.small=640px, src.tiny=280px"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}