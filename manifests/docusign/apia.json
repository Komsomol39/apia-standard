{
  "apia": "1.0",
  "service": {
    "id": "docusign",
    "name": "DocuSign eSignature API",
    "description_for_ai": "DocuSign eSignature API — world's #1 electronic signature platform. Legally binding in 180+ countries. Send documents for digital signature via email or embedded signing. Track signature status, auto-remind signers, download signed PDFs. 1M+ customers including 15 of Fortune 100.",
    "url": "https://docusign.com",
    "api_base": "https://demo.docusign.net/restapi/v2.1",
    "category": "legal",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.docusign.com/docs/esign-rest-api/"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Register at https://developers.docusign.com/sandbox",
    "cost": "Free sandbox. Personal: $15/month. Standard: $45/month"
  },
  "capabilities": [
    {
      "id": "send_envelope",
      "description_for_ai": "Send document for electronic signature. Returns envelope ID to track status.",
      "intent": [
        "document signing",
        "send for signature",
        "eSign document",
        "contract signature",
        "отправить на подпись",
        "contract signing",
        "digital signature",
        "sign document",
        "подпись документа",
        "esign"
      ],
      "endpoint": "POST https://demo.docusign.net/restapi/v2.1/accounts/{accountId}/envelopes",
      "input": {
        "accountId": {
          "type": "string",
          "required": true
        },
        "emailSubject": {
          "type": "string",
          "required": true
        },
        "documents": {
          "type": "array",
          "description": "[{documentBase64, name, fileExtension, documentId}]",
          "required": true
        },
        "recipients": {
          "type": "object",
          "description": "{signers: [{email, name, recipientId, routingOrder, tabs}]}",
          "required": true
        },
        "status": {
          "type": "string",
          "description": "sent or created (draft)",
          "default": "sent"
        }
      },
      "output": {
        "type": "envelope",
        "fields": [
          "envelopeId",
          "status",
          "statusDateTime",
          "uri"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_envelope",
      "description_for_ai": "Check the signing status of a DocuSign envelope. Returns completed timestamp when all parties have signed.",
      "intent": [
        "signing status",
        "document signed",
        "envelope progress",
        "signature status",
        "signing progress",
        "envelope status"
      ],
      "endpoint": "GET https://demo.docusign.net/restapi/v2.1/accounts/{accountId}/envelopes/{envelopeId}",
      "input": {
        "accountId": {
          "type": "string",
          "required": true
        },
        "envelopeId": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "envelope",
        "fields": [
          "envelopeId",
          "status",
          "completedDateTime",
          "recipients"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_envelope",
      "description_for_ai": "Create and send a DocuSign envelope for e-signature.",
      "intent": [
        "docusign envelope",
        "send for signature",
        "e-sign document",
        "электронная подпись docusign"
      ],
      "endpoint": "POST https://demo.docusign.net/restapi/v2.1/accounts/{accountId}/envelopes",
      "input": {
        "accountId": {
          "type": "string",
          "required": true
        },
        "emailSubject": {
          "type": "string",
          "required": true
        },
        "documents": {
          "type": "array",
          "description": "[{documentBase64: 'base64', name: 'Contract.pdf', documentId: '1'}]",
          "required": true
        },
        "recipients": {
          "type": "object",
          "description": "{signers: [{email, name, recipientId: '1', routingOrder: '1', tabs: {signHereTabs: [{xPosition: 100, yPosition: 100, documentId: '1', pageNumber: '1'}]}}]}",
          "required": true
        },
        "status": {
          "type": "string",
          "description": "sent or created (draft)",
          "required": true
        }
      },
      "output": {
        "type": "envelope",
        "fields": [
          "envelopeId",
          "status",
          "statusDateTime",
          "uri"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_envelope_status",
      "description_for_ai": "Get status of a DocuSign envelope: sent, delivered, completed, declined.",
      "intent": [
        "docusign status",
        "signature status",
        "envelope status",
        "статус подписи docusign"
      ],
      "endpoint": "GET https://demo.docusign.net/restapi/v2.1/accounts/{accountId}/envelopes/{envelopeId}",
      "input": {
        "accountId": {
          "type": "string",
          "required": true
        },
        "envelopeId": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "envelope",
        "fields": [
          "envelopeId",
          "status",
          "emailSubject",
          "sentDateTime",
          "completedDateTime",
          "recipients.signers[0].status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "download_document",
      "description_for_ai": "Download a signed document from a completed DocuSign envelope.",
      "intent": [
        "download signed document",
        "get signed PDF",
        "скачать подписанный документ"
      ],
      "endpoint": "GET https://demo.docusign.net/restapi/v2.1/accounts/{accountId}/envelopes/{envelopeId}/documents/{documentId}",
      "input": {
        "accountId": {
          "type": "string",
          "required": true
        },
        "envelopeId": {
          "type": "string",
          "required": true
        },
        "documentId": {
          "type": "string",
          "description": "Document ID or 'combined' for all docs",
          "required": true
        }
      },
      "output": {
        "type": "file",
        "fields": [
          "PDF binary content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "sandbox": "Test at https://demo.docusign.net — all test envelopes are free. Production at https://www.docusign.net",
    "envelope_flow": "1) Create envelope with documents + recipients. 2) Send (status=sent). 3) Signer receives email. 4) Poll for status=completed. 5) Download signed PDF.",
    "tab_types": "Use tabs to define signature/initial/date fields: signHereTabs, initialHereTabs, dateSignedTabs, textTabs",
    "embedded_signing": "For in-app signing: create envelope, then POST /recipient_view to get signing URL. Embed in iframe."
  }
}