{"apia":"1.0","service":{"id":"docusign","name":"DocuSign eSignature API","description_for_ai":"Electronic signature platform. Send documents for signature, track status, download signed docs. Legally binding in 180+ countries. Used by 1M+ customers. Use for contract signing, document workflows, agreement automation.","url":"https://docusign.com","api_base":"https://demo.docusign.net/restapi/v2.1","category":"legal_esign","geo":["GLOBAL"],"language":"en","docs":"https://developers.docusign.com/docs/esign-rest-api/"},"auth":{"type":"oauth2","anonymous_access":false,"how_to_get":"Register at https://developers.docusign.com/sandbox","cost":"Free sandbox. Personal: $15/month. Standard: $45/month"},"capabilities":[{"id":"send_envelope","description_for_ai":"Send document for electronic signature. Returns envelope ID to track status.","intent":["send for signature","document signing","esign","contract signature","sign document","подпись документа"],"endpoint":"POST https://demo.docusign.net/restapi/v2.1/accounts/{accountId}/envelopes","input":{"accountId":{"type":"string","required":true},"emailSubject":{"type":"string","required":true},"documents":{"type":"array","description":"[{documentBase64, name, fileExtension, documentId}]","required":true},"recipients":{"type":"object","description":"{signers: [{email, name, recipientId, routingOrder, tabs}]}","required":true},"status":{"type":"string","description":"sent or created (draft)","default":"sent"}},"output":{"type":"envelope","fields":["envelopeId","status","statusDateTime","uri"]},"realtime":true,"requires_auth":true},{"id":"get_envelope","description_for_ai":"Get envelope status and signing progress.","intent":["signature status","document signed","envelope status","signing progress"],"endpoint":"GET https://demo.docusign.net/restapi/v2.1/accounts/{accountId}/envelopes/{envelopeId}","input":{"accountId":{"type":"string","required":true},"envelopeId":{"type":"string","required":true}},"output":{"type":"envelope","fields":["envelopeId","status","completedDateTime","recipients"]},"realtime":true,"requires_auth":true}],"meta":{"apia_version":"1.0","manifest_author":"APIA community","last_verified":"2026-06-14"}}