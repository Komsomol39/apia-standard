{
  "apia": "1.0",
  "service": {
    "id": "openai-fine-tuning",
    "name": "OpenAI Fine-Tuning API",
    "description_for_ai": "Train custom versions of GPT models on your data. Better accuracy for specific tasks, consistent output format, fewer prompt tokens needed. Fine-tune gpt-4o-mini for $0.008/1K training tokens.",
    "url": "https://openai.com",
    "api_base": "https://api.openai.com/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.openai.com/docs/guides/fine-tuning"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "OpenAI API key",
    "cost": "Training: $0.008/1K tokens for gpt-4o-mini. Inference: $0.30/$1.20 per 1M tokens for fine-tuned"
  },
  "capabilities": [
    {
      "id": "create_fine_tuning_job",
      "description_for_ai": "Create a fine-tuning job to train a custom OpenAI model on your data.",
      "intent": [
        "fine tune OpenAI",
        "custom GPT model",
        "train AI model",
        "дообучение OpenAI"
      ],
      "endpoint": "POST https://api.openai.com/v1/fine_tuning/jobs",
      "input": {
        "training_file": {
          "type": "string",
          "description": "File ID of JSONL training data (uploaded with /v1/files, purpose=fine-tune)",
          "required": true
        },
        "model": {
          "type": "string",
          "description": "gpt-4o-mini-2024-07-18, gpt-4o-2024-08-06, gpt-3.5-turbo",
          "required": true
        },
        "validation_file": {
          "type": "string",
          "description": "Optional validation file ID",
          "required": false
        },
        "hyperparameters": {
          "type": "object",
          "description": "{n_epochs: 3, batch_size: 'auto', learning_rate_multiplier: 'auto'}",
          "required": false
        },
        "suffix": {
          "type": "string",
          "description": "Custom model name suffix (max 40 chars)",
          "required": false
        }
      },
      "output": {
        "type": "job",
        "fields": [
          "id",
          "model",
          "status",
          "created_at",
          "training_file"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_job_status",
      "description_for_ai": "Get the status and progress of a fine-tuning job.",
      "intent": [
        "fine-tuning status",
        "training progress",
        "model training status",
        "статус дообучения OpenAI"
      ],
      "endpoint": "GET https://api.openai.com/v1/fine_tuning/jobs/{job_id}",
      "input": {
        "job_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "job",
        "fields": [
          "id",
          "status (validating_files/queued/running/succeeded/failed/cancelled)",
          "fine_tuned_model",
          "trained_tokens",
          "estimated_finish"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_jobs",
      "description_for_ai": "List all fine-tuning jobs.",
      "intent": [
        "list fine-tuning jobs",
        "my models OpenAI",
        "training jobs",
        "задания дообучения OpenAI"
      ],
      "endpoint": "GET https://api.openai.com/v1/fine_tuning/jobs",
      "input": {
        "limit": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<job>",
        "fields": [
          "data[0].id",
          "data[0].model",
          "data[0].status",
          "data[0].fine_tuned_model",
          "data[0].created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_checkpoints",
      "description_for_ai": "Get training checkpoints for a fine-tuning job.",
      "intent": [
        "fine-tuning checkpoints",
        "training snapshots",
        "model checkpoints",
        "чекпоинты дообучения"
      ],
      "endpoint": "GET https://api.openai.com/v1/fine_tuning/jobs/{job_id}/checkpoints",
      "input": {
        "job_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<checkpoint>",
        "fields": [
          "data[0].id",
          "data[0].step_number",
          "data[0].metrics.train_loss",
          "data[0].metrics.valid_loss",
          "data[0].fine_tuned_model_checkpoint"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "cancel_job",
      "description_for_ai": "Cancel a running fine-tuning job.",
      "intent": [
        "cancel fine-tuning",
        "stop training",
        "abort fine-tune",
        "отменить дообучение OpenAI"
      ],
      "endpoint": "POST https://api.openai.com/v1/fine_tuning/jobs/{job_id}/cancel",
      "input": {
        "job_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "job",
        "fields": [
          "id",
          "status (cancelled)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "training_format": "JSONL format: each line is {messages: [{role: system, content: ...}, {role: user, content: ...}, {role: assistant, content: ...}]}",
    "min_examples": "Minimum 10 examples, recommend 50-100+ for good results.",
    "use_cases": "Response format consistency, domain-specific knowledge, specialized tone, instruction following improvement."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}