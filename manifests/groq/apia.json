{
  "apia": "1.0",
  "service": {
    "id": "groq",
    "name": "Groq API",
    "description_for_ai": "Ultra-fast AI inference using custom LPU hardware. Llama 3, Mixtral, Gemma at 300-800 tokens/second — fastest available. OpenAI-compatible. Free tier generous. Use when speed matters: real-time chat, voice assistants, interactive apps.",
    "url": "https://groq.com",
    "api_base": "https://api.groq.com/openai/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://console.groq.com/docs"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "Free API key at https://console.groq.com",
    "cost": "Free tier: 6000 tokens/min. Paid from $0.05/1M tokens"
  },
  "capabilities": [
    {
      "id": "chat_completion",
      "description_for_ai": "Ultra-fast AI inference with Groq LPU hardware. Llama, Mixtral, Gemma available. OpenAI-compatible API. 1000+ tokens/sec.",
      "intent": [
        "fast AI",
        "Groq inference",
        "LLM fast",
        "Groq API",
        "быстрый AI Groq"
      ],
      "endpoint": "POST https://api.groq.com/openai/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "description": "llama-3.1-70b-versatile (best), llama-3.1-8b-instant (fastest), mixtral-8x7b-32768 (32k context), gemma2-9b-it",
          "required": true
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "temperature": {
          "type": "float",
          "default": 1.0
        },
        "max_tokens": {
          "type": "integer",
          "required": false
        },
        "stream": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "usage.prompt_tokens",
          "usage.completion_tokens",
          "x_groq.id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "speech_to_text",
      "description_for_ai": "Fast speech transcription with Whisper on Groq hardware. Much faster than OpenAI Whisper.",
      "intent": [
        "transcribe Groq",
        "fast STT",
        "audio to text Groq",
        "транскрипция Groq"
      ],
      "endpoint": "POST https://api.groq.com/openai/v1/audio/transcriptions",
      "input": {
        "file": {
          "type": "file",
          "description": "Audio file (mp3, mp4, mpeg, mpga, m4a, wav, webm, max 25MB)",
          "required": true
        },
        "model": {
          "type": "string",
          "description": "whisper-large-v3, whisper-large-v3-turbo, distil-whisper-large-v3-en",
          "required": true
        },
        "language": {
          "type": "string",
          "required": false
        },
        "response_format": {
          "type": "string",
          "description": "json, text, srt, vtt",
          "default": "json"
        }
      },
      "output": {
        "type": "transcription",
        "fields": [
          "text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "function_calling",
      "description_for_ai": "Use Groq with function calling for agents. Fast tool execution on LPU hardware.",
      "intent": [
        "Groq tools",
        "function calling",
        "agent Groq",
        "инструменты Groq"
      ],
      "endpoint": "POST https://api.groq.com/openai/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "required": true
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "tools": {
          "type": "array",
          "description": "[{type: 'function', function: {name, description, parameters}}]",
          "required": true
        },
        "tool_choice": {
          "type": "string",
          "default": "auto"
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.tool_calls[0].function.name",
          "choices[0].message.tool_calls[0].function.arguments"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "vision",
      "description_for_ai": "Analyze images with Llama 3.2 Vision on Groq. Fast image understanding.",
      "intent": [
        "Groq vision",
        "image analysis Groq",
        "LLaMA vision",
        "анализ изображения Groq"
      ],
      "endpoint": "POST https://api.groq.com/openai/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "description": "llama-3.2-11b-vision-preview or llama-3.2-90b-vision-preview",
          "required": true
        },
        "messages": {
          "type": "array",
          "description": "[{role: 'user', content: [{type: 'image_url', image_url: {url: '...'}}, {type: 'text', text: 'question'}]}]",
          "required": true
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_models",
      "description_for_ai": "List all models available on Groq with context windows and speeds.",
      "intent": [
        "Groq models",
        "available models",
        "список моделей Groq"
      ],
      "endpoint": "GET https://api.groq.com/openai/v1/models",
      "input": {},
      "output": {
        "type": "list<model>",
        "fields": [
          "data[0].id",
          "data[0].context_window",
          "data[0].owned_by"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "speed": "Groq returns 300-800 tok/sec vs 30-60 tok/sec for OpenAI. Use for latency-sensitive apps.",
    "rate_limits": "Free tier: 6000 tokens/min, 30 req/min. Higher on paid plans.",
    "openai_compat": "100% compatible — change base_url to https://api.groq.com/openai/v1"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}