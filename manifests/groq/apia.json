{
  "apia": "1.0",
  "service": {
    "id": "groq",
    "name": "Groq API",
    "description_for_ai": "Ultra-fast AI inference using custom LPU hardware. Llama 3, Mixtral, Gemma at 300-800 tokens/second — fastest available. OpenAI-compatible. Free tier generous. Use when speed matters: real-time chat, voice assistants, interactive apps.",
    "url": "https://groq.com",
    "api_base": "https://api.groq.com/openai/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://console.groq.com/docs"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "Free API key at https://console.groq.com",
    "cost": "Free tier: 6000 tokens/min. Paid from $0.05/1M tokens"
  },
  "capabilities": [
    {
      "id": "chat",
      "description_for_ai": "Ultra-fast LLM inference on Groq LPU hardware. 300+ tokens/sec. Llama 3, Mixtral, Gemma. Free tier 6000 tokens/min. Best for latency-critical apps.",
      "intent": [
        "groq fast AI",
        "fastest LLM",
        "low latency AI",
        "быстрый ИИ groq",
        "groq llama"
      ],
      "endpoint": "POST https://api.groq.com/openai/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "description": "llama-3.3-70b-versatile (best), llama-3.1-8b-instant (fastest), mixtral-8x7b-32768 (32K context)",
          "required": true
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "temperature": {
          "type": "float",
          "default": 1.0
        },
        "max_tokens": {
          "type": "integer",
          "required": false
        },
        "stream": {
          "type": "boolean",
          "default": false
        },
        "stop": {
          "type": "array",
          "description": "Stop sequences",
          "required": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "usage.prompt_tokens",
          "usage.completion_tokens",
          "x_groq.usage.queue_time"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "speech_to_text",
      "description_for_ai": "Fast Whisper STT on Groq. Faster than OpenAI Whisper. Free tier available.",
      "intent": [
        "groq whisper",
        "fast transcription",
        "speech to text groq",
        "транскрибация groq"
      ],
      "endpoint": "POST https://api.groq.com/openai/v1/audio/transcriptions",
      "input": {
        "file": {
          "type": "file",
          "description": "Audio file: mp3, mp4, mpeg, mpga, m4a, wav, webm (max 25MB)",
          "required": true
        },
        "model": {
          "type": "string",
          "description": "whisper-large-v3 or whisper-large-v3-turbo (faster)",
          "default": "whisper-large-v3"
        },
        "language": {
          "type": "string",
          "description": "ISO 639-1 language code. Auto-detected if omitted.",
          "required": false
        },
        "response_format": {
          "type": "string",
          "description": "json, text, srt, vtt, verbose_json",
          "default": "json"
        }
      },
      "output": {
        "type": "transcription",
        "fields": [
          "text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_models",
      "description_for_ai": "List all available Groq models with context window sizes.",
      "intent": [
        "groq models",
        "available models groq",
        "модели groq"
      ],
      "endpoint": "GET https://api.groq.com/openai/v1/models",
      "input": {},
      "output": {
        "type": "list<model>",
        "fields": [
          "data[0].id",
          "data[0].context_window",
          "data[0].owned_by"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "vision",
      "description_for_ai": "Vision model on Groq — analyze images at Groq speed. Send image URL or base64.",
      "intent": [
        "groq vision",
        "image analysis groq",
        "fast image AI",
        "анализ изображения groq"
      ],
      "endpoint": "POST https://api.groq.com/openai/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "description": "llama-4-scout-17b-16e-instruct or meta-llama/llama-4-maverick-17b-128e-instruct-fp8",
          "required": true
        },
        "messages": {
          "type": "array",
          "description": "[{role: user, content: [{type: image_url, image_url: {url: 'https://...'}}, {type: text, text: 'Describe this'}]}]",
          "required": true
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "speed": "Groq returns 300-800 tok/sec vs 30-60 tok/sec for OpenAI. Use for latency-sensitive apps.",
    "rate_limits": "Free tier: 6000 tokens/min, 30 req/min. Higher on paid plans.",
    "openai_compat": "100% compatible — change base_url to https://api.groq.com/openai/v1"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}