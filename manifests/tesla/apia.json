{
  "apia": "1.0",
  "service": {
    "id": "tesla",
    "name": "Tesla Fleet API",
    "description_for_ai": "Official Tesla vehicle API. Get vehicle state, location, charging status. Control: lock/unlock, climate, horn, lights, charging. Requires Tesla account and vehicle access.",
    "url": "https://developer.tesla.com",
    "api_base": "https://fleet-api.prd.na.vn.cloud.tesla.com/api/1",
    "category": "iot",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.tesla.com/docs/fleet-api"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Register at https://developer.tesla.com",
    "cost": "Free for personal use. Commercial requires approval"
  },
  "capabilities": [
    {
      "id": "get_vehicle_data",
      "description_for_ai": "Get comprehensive Tesla vehicle data: location, speed, battery level, charging state, climate, lock status, odometer.",
      "intent": [
        "tesla battery",
        "car location",
        "vehicle status",
        "charging status",
        "is car locked",
        "tesla data",
        "заряд машины"
      ],
      "endpoint": "GET https://fleet-api.prd.na.vn.cloud.tesla.com/api/1/vehicles/{id}/vehicle_data",
      "input": {
        "id": {
          "type": "string",
          "description": "Vehicle ID from list_vehicles",
          "required": true
        },
        "endpoints": {
          "type": "string",
          "description": "Comma-separated data categories: charge_state,climate_state,drive_state,location_data,vehicle_state",
          "required": false
        }
      },
      "output": {
        "type": "vehicle_data",
        "fields": [
          "charge_state.battery_level",
          "charge_state.charging_state",
          "drive_state.latitude",
          "drive_state.longitude",
          "drive_state.speed",
          "climate_state.inside_temp",
          "vehicle_state.locked",
          "vehicle_state.odometer"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_command",
      "description_for_ai": "Send command to Tesla vehicle: lock/unlock, honk horn, flash lights, start/stop climate, open trunk.",
      "intent": [
        "lock tesla",
        "unlock car",
        "remote start",
        "climate control",
        "flash lights",
        "honk horn",
        "open trunk"
      ],
      "endpoint": "POST https://fleet-api.prd.na.vn.cloud.tesla.com/api/1/vehicles/{id}/command/{command}",
      "input": {
        "id": {
          "type": "string",
          "required": true,
          "description": "Unique identifier"
        },
        "command": {
          "type": "string",
          "description": "door_lock, door_unlock, honk_horn, flash_lights, remote_start_drive, auto_conditioning_start, auto_conditioning_stop, charge_start, charge_stop",
          "required": true
        }
      },
      "output": {
        "type": "command_result",
        "fields": [
          "result",
          "reason"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_vehicles",
      "description_for_ai": "List all Tesla vehicles in the account.",
      "intent": [
        "Tesla vehicles",
        "my Tesla",
        "list cars Tesla",
        "мои Tesla"
      ],
      "endpoint": "GET https://owner-api.teslamotors.com/api/1/vehicles",
      "input": {},
      "output": {
        "type": "list<vehicle>",
        "fields": [
          "response[0].id",
          "response[0].vin",
          "response[0].display_name",
          "response[0].state",
          "response[0].option_codes"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_vehicle_state",
      "description_for_ai": "Get current state of a Tesla vehicle: battery, location, climate.",
      "intent": [
        "Tesla state",
        "vehicle status Tesla",
        "battery Tesla",
        "состояние Tesla"
      ],
      "endpoint": "GET https://owner-api.teslamotors.com/api/1/vehicles/{id}/vehicle_data",
      "input": {
        "id": {
          "type": "integer",
          "description": "Vehicle ID from list_vehicles",
          "required": true
        }
      },
      "output": {
        "type": "state",
        "fields": [
          "response.charge_state.battery_level",
          "response.charge_state.est_battery_range",
          "response.drive_state.latitude",
          "response.drive_state.longitude",
          "response.climate_state.inside_temp",
          "response.vehicle_state.locked"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_command",
      "description_for_ai": "Send a command to a Tesla: flash lights, honk, lock/unlock, climate on/off.",
      "intent": [
        "Tesla command",
        "control Tesla",
        "unlock Tesla",
        "команда Tesla"
      ],
      "endpoint": "POST https://owner-api.teslamotors.com/api/1/vehicles/{id}/command/{command}",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        },
        "command": {
          "type": "string",
          "description": "flash_lights, honk_horn, door_lock, door_unlock, auto_conditioning_start, auto_conditioning_stop, charge_start, charge_stop",
          "required": true
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "response.result",
          "response.reason"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "wake": "Vehicle may be asleep — call /wake_up first if commands fail.",
    "polling": "Real-time streaming available via WebSocket at streaming.vn.teslamotors.com"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}