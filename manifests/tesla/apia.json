{
  "apia": "1.0",
  "service": {
    "id": "tesla",
    "name": "Tesla Fleet API",
    "description_for_ai": "Official Tesla vehicle API. Get vehicle state, location, charging status. Control: lock/unlock, climate, horn, lights, charging. Requires Tesla account and vehicle access.",
    "url": "https://developer.tesla.com",
    "api_base": "https://fleet-api.prd.na.vn.cloud.tesla.com/api/1",
    "category": "iot",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.tesla.com/docs/fleet-api"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Register at https://developer.tesla.com",
    "cost": "Free for personal use. Commercial requires approval"
  },
  "capabilities": [
    {
      "id": "get_vehicles",
      "description_for_ai": "Get all Tesla vehicles associated with the account.",
      "intent": [
        "Tesla vehicles",
        "my Tesla",
        "car list Tesla",
        "автомобили Tesla"
      ],
      "endpoint": "GET https://owner-api.teslamotors.com/api/1/vehicles",
      "input": {},
      "output": {
        "type": "list<vehicle>",
        "fields": [
          "response[0].id",
          "response[0].vehicle_id",
          "response[0].display_name",
          "response[0].state",
          "response[0].vin"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_vehicle_state",
      "description_for_ai": "Get current Tesla vehicle state: charge level, location, locked status, climate.",
      "intent": [
        "Tesla state",
        "car status Tesla",
        "Tesla charge",
        "состояние Tesla"
      ],
      "endpoint": "GET https://owner-api.teslamotors.com/api/1/vehicles/{id}/vehicle_data",
      "input": {
        "id": {
          "type": "string",
          "description": "Vehicle ID from list_vehicles",
          "required": true
        }
      },
      "output": {
        "type": "vehicle_data",
        "fields": [
          "response.charge_state.battery_level",
          "response.charge_state.charging_state",
          "response.drive_state.latitude",
          "response.drive_state.longitude",
          "response.climate_state.inside_temp",
          "response.vehicle_state.locked"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_command",
      "description_for_ai": "Send a command to a Tesla vehicle: lock/unlock, flash lights, honk, start charging.",
      "intent": [
        "Tesla command",
        "unlock Tesla",
        "lock Tesla",
        "команда Tesla"
      ],
      "endpoint": "POST https://owner-api.teslamotors.com/api/1/vehicles/{id}/command/{command}",
      "input": {
        "id": {
          "type": "string",
          "required": true
        },
        "command": {
          "type": "string",
          "description": "door_lock, door_unlock, flash_lights, honk_horn, charge_start, charge_stop, set_charge_limit, auto_conditioning_start, auto_conditioning_stop",
          "required": true
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "response.result (true/false)",
          "response.reason"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "wake_up",
      "description_for_ai": "Wake up a sleeping Tesla vehicle before sending commands.",
      "intent": [
        "wake Tesla",
        "Tesla wake up",
        "activate Tesla",
        "разбудить Tesla"
      ],
      "endpoint": "POST https://owner-api.teslamotors.com/api/1/vehicles/{id}/wake_up",
      "input": {
        "id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "vehicle",
        "fields": [
          "response.id",
          "response.state (online/asleep)",
          "response.display_name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_charge_history",
      "description_for_ai": "Get Tesla charging history and energy costs.",
      "intent": [
        "Tesla charging history",
        "charge sessions",
        "energy usage Tesla",
        "история зарядки Tesla"
      ],
      "endpoint": "GET https://owner-api.teslamotors.com/api/1/vehicles/{id}/charge_history",
      "input": {
        "id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "charge_history",
        "fields": [
          "response[0].charger_voltage",
          "response[0].charge_energy_added",
          "response[0].charge_miles_added_rated",
          "response[0].timestamp"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "wake": "Vehicle may be asleep — call /wake_up first if commands fail.",
    "polling": "Real-time streaming available via WebSocket at streaming.vn.teslamotors.com"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}