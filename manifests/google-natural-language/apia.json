{
  "apia": "1.0",
  "service": {
    "id": "google-natural-language",
    "name": "Google Cloud Natural Language API",
    "description_for_ai": "NLP analysis by Google. Sentiment analysis, entity extraction, syntax analysis, content classification, entity sentiment. 5000 units/month free. Use for text classification, sentiment analysis of customer feedback, entity recognition.",
    "url": "https://cloud.google.com/natural-language",
    "api_base": "https://language.googleapis.com/v1",
    "category": "nlp",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://cloud.google.com/natural-language/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Enable Natural Language API at https://console.cloud.google.com",
    "cost": "Free: 5000 units/month. Then $1/1000 for sentiment, $2/1000 for entities"
  },
  "capabilities": [
    {
      "id": "analyze_sentiment",
      "description_for_ai": "Analyze sentiment of text or documents. Returns overall and per-sentence sentiment.",
      "intent": [
        "sentiment analysis Google",
        "text sentiment NLP",
        "positive negative text",
        "анализ тональности Google NLP"
      ],
      "endpoint": "POST https://language.googleapis.com/v1/documents:analyzeSentiment",
      "input": {
        "document": {
          "type": "object",
          "description": "{type: 'PLAIN_TEXT'|'HTML', content: 'text', language: 'en'}",
          "required": true
        },
        "encodingType": {
          "type": "string",
          "description": "UTF8, UTF16, UTF32",
          "default": "UTF8"
        }
      },
      "output": {
        "type": "sentiment",
        "fields": [
          "documentSentiment.score (-1.0 to 1.0)",
          "documentSentiment.magnitude (0.0+)",
          "sentences[0].text.content",
          "sentences[0].sentiment.score"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "analyze_entities",
      "description_for_ai": "Extract named entities from text with Wikipedia links and salience scores.",
      "intent": [
        "entity extraction Google",
        "named entities NLP",
        "NER Google Cloud",
        "извлечение сущностей Google NLP"
      ],
      "endpoint": "POST https://language.googleapis.com/v1/documents:analyzeEntities",
      "input": {
        "document": {
          "type": "object",
          "description": "{type: 'PLAIN_TEXT', content: 'text'}",
          "required": true
        }
      },
      "output": {
        "type": "entities",
        "fields": [
          "entities[0].name",
          "entities[0].type (PERSON|LOCATION|ORGANIZATION|EVENT|WORK_OF_ART|CONSUMER_GOOD)",
          "entities[0].salience",
          "entities[0].metadata.wikipedia_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "classify_content",
      "description_for_ai": "Classify text into 700+ content categories using Google's taxonomy.",
      "intent": [
        "classify text Google",
        "content categories",
        "topic classification NLP",
        "классификация контента Google NLP"
      ],
      "endpoint": "POST https://language.googleapis.com/v1/documents:classifyText",
      "input": {
        "document": {
          "type": "object",
          "description": "{type: 'PLAIN_TEXT', content: 'text (min 20 tokens)'}",
          "required": true
        },
        "classificationModelOptions": {
          "type": "object",
          "description": "{v2Model: {contentCategoriesVersion: 'V2'}}",
          "required": false
        }
      },
      "output": {
        "type": "categories",
        "fields": [
          "categories[0].name (/Finance/Banking)",
          "categories[0].confidence"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "analyze_syntax",
      "description_for_ai": "Parse text into tokens with part-of-speech and dependency analysis.",
      "intent": [
        "syntax analysis Google",
        "POS tagging",
        "parse text",
        "синтаксический анализ Google NLP"
      ],
      "endpoint": "POST https://language.googleapis.com/v1/documents:analyzeSyntax",
      "input": {
        "document": {
          "type": "object",
          "description": "{type: 'PLAIN_TEXT', content: 'text'}",
          "required": true
        },
        "encodingType": {
          "type": "string",
          "default": "UTF8"
        }
      },
      "output": {
        "type": "syntax",
        "fields": [
          "tokens[0].text.content",
          "tokens[0].partOfSpeech.tag (NOUN|VERB|ADJ...)",
          "tokens[0].dependencyEdge.label (NSUBJ|DOBJ...)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "annotate_text",
      "description_for_ai": "Run all NLP analyses in one call: sentiment, entities, syntax, categories.",
      "intent": [
        "full NLP analysis",
        "all annotations Google",
        "comprehensive text analysis",
        "полный анализ текста Google NLP"
      ],
      "endpoint": "POST https://language.googleapis.com/v1/documents:annotateText",
      "input": {
        "document": {
          "type": "object",
          "required": true
        },
        "features": {
          "type": "object",
          "description": "{extractSyntax: true, extractEntities: true, extractDocumentSentiment: true, classifyText: true}",
          "required": true
        }
      },
      "output": {
        "type": "annotations",
        "fields": [
          "documentSentiment.score",
          "entities[0].name",
          "tokens[0].text.content",
          "categories[0].name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}