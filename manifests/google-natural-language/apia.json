{
  "apia": "1.0",
  "service": {
    "id": "google-natural-language",
    "name": "Google Cloud Natural Language API",
    "description_for_ai": "NLP analysis by Google. Sentiment analysis, entity extraction, syntax analysis, content classification, entity sentiment. 5000 units/month free. Use for text classification, sentiment analysis of customer feedback, entity recognition.",
    "url": "https://cloud.google.com/natural-language",
    "api_base": "https://language.googleapis.com/v1",
    "category": "nlp",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://cloud.google.com/natural-language/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Enable Natural Language API at https://console.cloud.google.com",
    "cost": "Free: 5000 units/month. Then $1/1000 for sentiment, $2/1000 for entities"
  },
  "capabilities": [
    {
      "id": "analyze_sentiment",
      "description_for_ai": "Analyze sentiment (positive/negative/neutral) of text.",
      "intent": [
        "sentiment analysis",
        "text sentiment",
        "opinion mining",
        "анализ тональности текста"
      ],
      "endpoint": "POST https://language.googleapis.com/v1/documents:analyzeSentiment",
      "input": {
        "document": {
          "type": "object",
          "description": "{type: 'PLAIN_TEXT', content: 'text here'} or {type: 'HTML', content: '<p>...</p>'}",
          "required": true
        },
        "encodingType": {
          "type": "string",
          "default": "UTF8"
        }
      },
      "output": {
        "type": "sentiment",
        "fields": [
          "documentSentiment.score (-1.0 to 1.0)",
          "documentSentiment.magnitude",
          "sentences[0].sentiment.score"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "analyze_entities",
      "description_for_ai": "Extract named entities (people, organizations, places, dates) from text.",
      "intent": [
        "entity extraction",
        "NER",
        "named entities",
        "извлечение сущностей NLP"
      ],
      "endpoint": "POST https://language.googleapis.com/v1/documents:analyzeEntities",
      "input": {
        "document": {
          "type": "object",
          "description": "{type: 'PLAIN_TEXT', content: 'Google LLC was founded by Larry Page in Menlo Park.'}",
          "required": true
        }
      },
      "output": {
        "type": "entities",
        "fields": [
          "entities[0].name",
          "entities[0].type (PERSON/ORG/LOCATION/EVENT/DATE)",
          "entities[0].salience (0-1 importance)",
          "entities[0].mentions[0].type"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "classify_content",
      "description_for_ai": "Classify text into 700+ content categories (IAB taxonomy). Good for ad targeting and content filtering.",
      "intent": [
        "text classification",
        "content categories",
        "topic detection",
        "классификация текста Google NLP"
      ],
      "endpoint": "POST https://language.googleapis.com/v1/documents:classifyText",
      "input": {
        "document": {
          "type": "object",
          "description": "{type: 'PLAIN_TEXT', content: 'text with at least 20 words'}",
          "required": true
        }
      },
      "output": {
        "type": "categories",
        "fields": [
          "categories[0].name (IAB taxonomy path)",
          "categories[0].confidence (0-1)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "analyze_syntax",
      "description_for_ai": "Analyze grammar and syntax: tokenize, POS tagging, dependency tree.",
      "intent": [
        "syntax analysis",
        "POS tagging",
        "tokenize text",
        "синтаксический анализ текста"
      ],
      "endpoint": "POST https://language.googleapis.com/v1/documents:analyzeSyntax",
      "input": {
        "document": {
          "type": "object",
          "required": true
        },
        "encodingType": {
          "type": "string",
          "default": "UTF8"
        }
      },
      "output": {
        "type": "syntax",
        "fields": [
          "tokens[0].text.content",
          "tokens[0].partOfSpeech.tag (NOUN/VERB/ADJ...)",
          "tokens[0].dependencyEdge.label"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "annotate_all",
      "description_for_ai": "Run all NLP analyses (sentiment, entities, syntax, categories) in a single request.",
      "intent": [
        "full NLP analysis",
        "all annotations",
        "comprehensive text analysis",
        "полный анализ текста Google NLP"
      ],
      "endpoint": "POST https://language.googleapis.com/v1/documents:annotateText",
      "input": {
        "document": {
          "type": "object",
          "required": true
        },
        "features": {
          "type": "object",
          "description": "{extractSyntax: true, extractEntities: true, extractDocumentSentiment: true, classifyText: true, moderateText: true}",
          "required": true
        }
      },
      "output": {
        "type": "annotations",
        "fields": [
          "sentences",
          "tokens",
          "entities",
          "documentSentiment",
          "categories",
          "moderationCategories"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}