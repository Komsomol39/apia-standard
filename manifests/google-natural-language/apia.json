{
  "apia": "1.0",
  "service": {
    "id": "google-natural-language",
    "name": "Google Cloud Natural Language API",
    "description_for_ai": "NLP analysis by Google. Sentiment analysis, entity extraction, syntax analysis, content classification, entity sentiment. 5000 units/month free. Use for text classification, sentiment analysis of customer feedback, entity recognition.",
    "url": "https://cloud.google.com/natural-language",
    "api_base": "https://language.googleapis.com/v1",
    "category": "nlp",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://cloud.google.com/natural-language/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Enable Natural Language API at https://console.cloud.google.com",
    "cost": "Free: 5000 units/month. Then $1/1000 for sentiment, $2/1000 for entities"
  },
  "capabilities": [
    {
      "id": "analyze_sentiment",
      "description_for_ai": "Analyze overall and per-sentence sentiment: positive/negative/neutral score (-1 to 1) and magnitude.",
      "intent": [
        "sentiment analysis",
        "is text positive",
        "customer sentiment",
        "тональность текста",
        "анализ тональности"
      ],
      "endpoint": "POST https://language.googleapis.com/v1/documents:analyzeSentiment",
      "input": {
        "document": {
          "type": "object",
          "description": "{type: PLAIN_TEXT or HTML, content: 'text to analyze', language: 'en'}",
          "required": true
        },
        "encodingType": {
          "type": "string",
          "default": "UTF8"
        }
      },
      "output": {
        "type": "sentiment",
        "fields": [
          "documentSentiment.score (-1 to 1)",
          "documentSentiment.magnitude (0 to inf)",
          "sentences[0].sentiment.score",
          "sentences[0].text.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "analyze_entities",
      "description_for_ai": "Extract named entities: people, organizations, locations, dates, events. Returns Wikipedia links and salience scores.",
      "intent": [
        "named entity recognition",
        "NER",
        "extract entities",
        "find people in text",
        "организации в тексте"
      ],
      "endpoint": "POST https://language.googleapis.com/v1/documents:analyzeEntities",
      "input": {
        "document": {
          "type": "object",
          "description": "{type: PLAIN_TEXT, content: text, language: 'en'}",
          "required": true
        },
        "encodingType": {
          "type": "string",
          "default": "UTF8"
        }
      },
      "output": {
        "type": "entities",
        "fields": [
          "entities[0].name",
          "entities[0].type (PERSON|ORGANIZATION|LOCATION|EVENT|DATE)",
          "entities[0].salience",
          "entities[0].metadata.wikipedia_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "classify_content",
      "description_for_ai": "Classify text into 700+ content categories (IAB taxonomy). For content routing, ad targeting, topic detection.",
      "intent": [
        "classify text",
        "content category",
        "topic detection",
        "content classification",
        "классификация контента"
      ],
      "endpoint": "POST https://language.googleapis.com/v1/documents:classifyText",
      "input": {
        "document": {
          "type": "object",
          "description": "{type: PLAIN_TEXT, content: 'text at least 20 words'}",
          "required": true
        },
        "classificationModelOptions": {
          "type": "object",
          "description": "{v2Model: {contentCategoriesVersion: V2}} for 1000+ categories",
          "required": false
        }
      },
      "output": {
        "type": "categories",
        "fields": [
          "categories[0].name",
          "categories[0].confidence"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "analyze_syntax",
      "description_for_ai": "Parse text syntax: tokens, part-of-speech tags, dependency tree, lemmas. For NLP pipelines.",
      "intent": [
        "syntax analysis",
        "POS tagging",
        "parse text",
        "dependency parsing",
        "синтаксический анализ"
      ],
      "endpoint": "POST https://language.googleapis.com/v1/documents:analyzeSyntax",
      "input": {
        "document": {
          "type": "object",
          "description": "{type: PLAIN_TEXT, content: text, language: 'en'}",
          "required": true
        },
        "encodingType": {
          "type": "string",
          "default": "UTF8"
        }
      },
      "output": {
        "type": "syntax",
        "fields": [
          "tokens[0].text.content",
          "tokens[0].partOfSpeech.tag (NOUN|VERB|ADJ...)",
          "tokens[0].lemma",
          "tokens[0].dependencyEdge.label"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}