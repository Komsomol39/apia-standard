{
  "apia": "1.0",
  "service": {
    "id": "openai-tts",
    "name": "OpenAI Text-to-Speech API",
    "description_for_ai": "High-quality text-to-speech. 6 voices, fast generation. $15/1M chars. Natural sounding speech in many languages. Use for reading text aloud, voice assistants, audiobook narration.",
    "url": "https://openai.com",
    "api_base": "https://api.openai.com/v1",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.openai.com/docs/guides/text-to-speech"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "OpenAI API key",
    "cost": "tts-1: $15/1M chars. tts-1-hd: $30/1M chars"
  },
  "capabilities": [
    {
      "id": "create_speech",
      "description_for_ai": "Convert text to speech with OpenAI TTS. 6 voices, multiple formats.",
      "intent": [
        "text to speech OpenAI",
        "TTS API",
        "voice synthesis OpenAI",
        "синтез речи OpenAI TTS"
      ],
      "endpoint": "POST https://api.openai.com/v1/audio/speech",
      "input": {
        "model": {
          "type": "string",
          "description": "tts-1 (fast), tts-1-hd (better quality)",
          "required": true
        },
        "input": {
          "type": "string",
          "description": "Text to speak, max 4096 chars",
          "required": true
        },
        "voice": {
          "type": "string",
          "description": "alloy (neutral), echo (male), fable (male UK), onyx (deep male), nova (female), shimmer (female soft)",
          "required": true
        },
        "response_format": {
          "type": "string",
          "description": "mp3, opus, aac, flac, wav, pcm",
          "default": "mp3"
        },
        "speed": {
          "type": "float",
          "description": "0.25-4.0, 1.0 normal speed",
          "default": 1.0
        }
      },
      "output": {
        "type": "audio",
        "fields": [
          "audio binary stream (mp3 by default)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "stream_speech",
      "description_for_ai": "Stream TTS output for real-time playback without waiting for full generation.",
      "intent": [
        "stream TTS",
        "real-time speech",
        "streaming voice",
        "потоковый синтез речи"
      ],
      "endpoint": "POST https://api.openai.com/v1/audio/speech",
      "input": {
        "model": {
          "type": "string",
          "default": "tts-1"
        },
        "input": {
          "type": "string",
          "required": true
        },
        "voice": {
          "type": "string",
          "required": true
        },
        "response_format": {
          "type": "string",
          "description": "For streaming use pcm or opus",
          "default": "opus"
        },
        "stream": {
          "type": "boolean",
          "description": "Set streaming header Accept: audio/mpeg",
          "default": true
        }
      },
      "output": {
        "type": "audio_stream",
        "fields": [
          "chunked audio binary stream"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "pick_voice",
      "description_for_ai": "Reference guide for choosing the right OpenAI TTS voice for your use case.",
      "intent": [
        "choose TTS voice",
        "voice guide OpenAI",
        "voice selection",
        "выбор голоса OpenAI"
      ],
      "endpoint": "reference",
      "input": {},
      "output": {
        "type": "guide",
        "fields": [
          "alloy: neutral, versatile",
          "echo: male, natural",
          "fable: British male, warm",
          "onyx: deep authoritative male",
          "nova: energetic female",
          "shimmer: soft female"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "batch_tts",
      "description_for_ai": "Generate multiple TTS segments efficiently for long content.",
      "intent": [
        "batch TTS",
        "long text speech",
        "book narration",
        "пакетный синтез речи"
      ],
      "endpoint": "POST https://api.openai.com/v1/audio/speech",
      "input": {
        "model": {
          "type": "string",
          "default": "tts-1"
        },
        "input": {
          "type": "string",
          "description": "Split text into 4096-char chunks and call for each chunk",
          "required": true
        },
        "voice": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "audio",
        "fields": [
          "audio binary (concatenate chunks for full narration)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "check_tts_pricing",
      "description_for_ai": "Reference pricing: tts-1 = $0.015/1K chars, tts-1-hd = $0.030/1K chars.",
      "intent": [
        "TTS pricing",
        "speech cost",
        "voice API cost",
        "стоимость TTS OpenAI"
      ],
      "endpoint": "reference",
      "input": {},
      "output": {
        "type": "pricing",
        "fields": [
          "tts-1: $0.015 per 1000 characters",
          "tts-1-hd: $0.030 per 1000 characters",
          "6 voices: alloy, echo, fable, onyx, nova, shimmer"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "voice_guide": "alloy=neutral balanced, echo=male warm, fable=British accent, onyx=deep authoritative, nova=friendly female, shimmer=soft female",
    "streaming": "Response is streaming audio binary. For web: create Blob URL from response.",
    "length": "Max 4096 chars per request. Split longer text into chunks."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}