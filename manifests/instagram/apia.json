{
  "apia": "1.0",
  "service": {
    "id": "instagram",
    "name": "Instagram Graph API",
    "description_for_ai": "Instagram business and creator API. Get posts, stories, insights, comments. Publish content, reply to DMs, manage business accounts. 2B+ users. Requires Instagram Business/Creator account.",
    "url": "https://instagram.com",
    "api_base": "https://graph.instagram.com",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.facebook.com/docs/instagram-api"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Facebook Developer account → Instagram Basic Display or Graph API app",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "get_user_media",
      "description_for_ai": "Get Instagram media (photos/videos) for a connected Business/Creator account.",
      "intent": [
        "Instagram posts",
        "user media",
        "get photos Instagram",
        "публикации Instagram"
      ],
      "endpoint": "GET https://graph.instagram.com/me/media",
      "input": {
        "fields": {
          "type": "string",
          "description": "id,caption,media_type,media_url,thumbnail_url,permalink,timestamp,like_count,comments_count",
          "default": "id,caption,media_type,media_url,permalink,timestamp"
        },
        "limit": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<media>",
        "fields": [
          "data[0].id",
          "data[0].caption",
          "data[0].media_type",
          "data[0].media_url",
          "data[0].permalink",
          "data[0].timestamp"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "publish_photo",
      "description_for_ai": "Publish a photo to Instagram. Two-step: create container then publish.",
      "intent": [
        "post to Instagram",
        "publish photo Instagram",
        "Instagram post",
        "опубликовать фото Instagram"
      ],
      "endpoint": "POST https://graph.instagram.com/{user-id}/media",
      "input": {
        "image_url": {
          "type": "string",
          "description": "Public URL of image to post",
          "required": true
        },
        "caption": {
          "type": "string",
          "description": "Post caption with hashtags",
          "required": false
        },
        "user_action": {
          "type": "string",
          "description": "Step 1: POST to /media to create container. Step 2: POST to /media_publish with creation_id from step 1.",
          "required": false
        }
      },
      "output": {
        "type": "media",
        "fields": [
          "id (creation_id for publishing)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_insights",
      "description_for_ai": "Get engagement insights for Instagram account or specific media posts.",
      "intent": [
        "Instagram insights",
        "engagement data",
        "Instagram analytics",
        "аналитика Instagram"
      ],
      "endpoint": "GET https://graph.instagram.com/{media-id}/insights",
      "input": {
        "media_id": {
          "type": "string",
          "required": true
        },
        "metric": {
          "type": "string",
          "description": "impressions, reach, engagement, saved, video_views, profile_visits, follows",
          "required": true
        }
      },
      "output": {
        "type": "insights",
        "fields": [
          "data[0].name",
          "data[0].values[0].value",
          "data[0].period"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_account_info",
      "description_for_ai": "Get Instagram Business/Creator account details: followers, biography, website.",
      "intent": [
        "Instagram profile",
        "account info",
        "followers count",
        "профиль Instagram"
      ],
      "endpoint": "GET https://graph.instagram.com/me",
      "input": {
        "fields": {
          "type": "string",
          "description": "id,name,biography,followers_count,media_count,profile_picture_url,website",
          "default": "id,name,biography,followers_count,media_count"
        }
      },
      "output": {
        "type": "account",
        "fields": [
          "id",
          "name",
          "biography",
          "followers_count",
          "media_count",
          "website"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "reply_to_comment",
      "description_for_ai": "Reply to a comment on an Instagram media post.",
      "intent": [
        "reply Instagram comment",
        "comment reply",
        "respond Instagram",
        "ответ на комментарий Instagram"
      ],
      "endpoint": "POST https://graph.instagram.com/{comment-id}/replies",
      "input": {
        "comment_id": {
          "type": "string",
          "required": true
        },
        "message": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "reply",
        "fields": [
          "id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_hashtag_media",
      "description_for_ai": "Search recent or top media by hashtag on Instagram.",
      "intent": [
        "Instagram hashtag",
        "hashtag search",
        "find by hashtag",
        "поиск по хэштегу Instagram"
      ],
      "endpoint": "GET https://graph.instagram.com/{hashtag-id}/recent_media",
      "input": {
        "hashtag_id": {
          "type": "string",
          "description": "Get ID first from /ig_hashtag_search?q=hashtag",
          "required": true
        },
        "user_id": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "id,media_url,permalink,caption,media_type",
          "required": false
        }
      },
      "output": {
        "type": "list<media>",
        "fields": [
          "data[0].id",
          "data[0].permalink",
          "data[0].caption"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}