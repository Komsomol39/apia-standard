{
  "apia": "1.0",
  "service": {
    "id": "instagram",
    "name": "Instagram Graph API",
    "description_for_ai": "Instagram business and creator API. Get posts, stories, insights, comments. Publish content, reply to DMs, manage business accounts. 2B+ users. Requires Instagram Business/Creator account.",
    "url": "https://instagram.com",
    "api_base": "https://graph.instagram.com",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.facebook.com/docs/instagram-api"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Facebook Developer account → Instagram Basic Display or Graph API app",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "get_user_profile",
      "description_for_ai": "Get Instagram Business/Creator account info: followers, media count, bio.",
      "intent": [
        "instagram profile",
        "instagram account",
        "followers instagram",
        "профиль instagram"
      ],
      "endpoint": "GET https://graph.instagram.com/me",
      "input": {
        "fields": {
          "type": "string",
          "description": "id,username,name,biography,followers_count,media_count,profile_picture_url,website",
          "required": false
        },
        "access_token": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "user",
        "fields": [
          "id",
          "username",
          "biography",
          "followers_count",
          "media_count"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_media",
      "description_for_ai": "Get list of Instagram posts (media) for a Business/Creator account.",
      "intent": [
        "instagram posts",
        "instagram media",
        "get posts instagram",
        "посты instagram"
      ],
      "endpoint": "GET https://graph.instagram.com/me/media",
      "input": {
        "fields": {
          "type": "string",
          "description": "id,caption,media_type,media_url,permalink,thumbnail_url,timestamp,like_count,comments_count",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 20
        },
        "access_token": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<media>",
        "fields": [
          "data[0].id",
          "data[0].caption",
          "data[0].media_type",
          "data[0].media_url",
          "data[0].timestamp",
          "data[0].like_count"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_post",
      "description_for_ai": "Publish a photo or video post to Instagram Business account (2-step: create container then publish).",
      "intent": [
        "post instagram",
        "publish instagram",
        "instagram photo post",
        "опубликовать instagram"
      ],
      "endpoint": "POST https://graph.instagram.com/me/media",
      "input": {
        "image_url": {
          "type": "string",
          "description": "Public image URL for photo post",
          "required": false
        },
        "video_url": {
          "type": "string",
          "description": "Public video URL for video post",
          "required": false
        },
        "caption": {
          "type": "string",
          "description": "Post caption with hashtags",
          "required": false
        },
        "media_type": {
          "type": "string",
          "description": "IMAGE, VIDEO, REELS, CAROUSEL_ALBUM",
          "default": "IMAGE"
        },
        "access_token": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "media_container",
        "fields": [
          "id (use to publish via /me/media_publish)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_insights",
      "description_for_ai": "Get insights/analytics for Instagram Business account: reach, impressions, profile views.",
      "intent": [
        "instagram analytics",
        "instagram insights",
        "instagram stats",
        "статистика instagram"
      ],
      "endpoint": "GET https://graph.instagram.com/me/insights",
      "input": {
        "metric": {
          "type": "string",
          "description": "reach,impressions,profile_views,follower_count,email_contacts,phone_call_clicks,website_clicks",
          "required": true
        },
        "period": {
          "type": "string",
          "description": "day, week, days_28, month",
          "required": true
        },
        "access_token": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "insights",
        "fields": [
          "data[0].name",
          "data[0].values[0].value",
          "data[0].values[0].end_time"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}