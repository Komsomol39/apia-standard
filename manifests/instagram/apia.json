{
  "apia": "1.0",
  "service": {
    "id": "instagram",
    "name": "Instagram Graph API",
    "description_for_ai": "Instagram business and creator API. Get posts, stories, insights, comments. Publish content, reply to DMs, manage business accounts. 2B+ users. Requires Instagram Business/Creator account.",
    "url": "https://instagram.com",
    "api_base": "https://graph.instagram.com",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.facebook.com/docs/instagram-api"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Facebook Developer account → Instagram Basic Display or Graph API app",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "get_media",
      "description_for_ai": "Get Instagram posts, images, videos, reels for authenticated account.",
      "intent": [
        "instagram posts",
        "my instagram",
        "social media content",
        "instagram feed",
        "instagram photos"
      ],
      "endpoint": "GET https://graph.instagram.com/me/media",
      "input": {
        "fields": {
          "type": "string",
          "description": "id,caption,media_type,media_url,permalink,thumbnail_url,timestamp",
          "default": "id,caption,media_type,timestamp"
        },
        "limit": {
          "type": "integer",
          "default": 12,
          "description": "Maximum number of results to return"
        }
      },
      "output": {
        "type": "list<media>",
        "fields": [
          "id",
          "caption",
          "media_type",
          "media_url",
          "permalink",
          "timestamp"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_insights",
      "description_for_ai": "Get Instagram account analytics: impressions, reach, profile views, follower count.",
      "intent": [
        "instagram analytics",
        "instagram insights",
        "follower count",
        "reach",
        "impressions",
        "social stats"
      ],
      "endpoint": "GET https://graph.instagram.com/{media_id}/insights",
      "input": {
        "metric": {
          "type": "string",
          "description": "impressions,reach,likes,comments,shares,saved",
          "required": true
        },
        "period": {
          "type": "string",
          "description": "day, week, days_28, month",
          "default": "day"
        }
      },
      "output": {
        "type": "insights",
        "fields": [
          "data[0].name",
          "data[0].values[0].value"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}