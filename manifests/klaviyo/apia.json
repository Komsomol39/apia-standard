{
  "apia": "1.0",
  "service": {
    "id": "klaviyo",
    "name": "Klaviyo API",
    "description_for_ai": "Email and SMS marketing platform for e-commerce. 150K+ brands use it. Segments, flows (automation), campaigns, profiles, events, metrics. Deep Shopify integration. Use for e-commerce email marketing automation.",
    "url": "https://klaviyo.com",
    "api_base": "https://a.klaviyo.com/api",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.klaviyo.com/en/reference/api_overview"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Klaviyo-API-Key {key}",
    "how_to_get": "Account → Settings → API Keys",
    "cost": "Free: up to 500 contacts. Paid from $20/month"
  },
  "capabilities": [
    {
      "id": "get_profiles",
      "description_for_ai": "Get customer profiles from Klaviyo CRM.",
      "intent": [
        "Klaviyo profiles",
        "email subscribers",
        "customer profiles Klaviyo",
        "профили Klaviyo"
      ],
      "endpoint": "GET https://a.klaviyo.com/api/profiles/",
      "input": {
        "page[size]": {
          "type": "integer",
          "default": 20
        },
        "filter": {
          "type": "string",
          "description": "Filter: equals(email,'user@example.com') or greater-than(created,'2024-01-01T00:00:00+00:00')",
          "required": false
        }
      },
      "output": {
        "type": "list<profile>",
        "fields": [
          "data[0].id",
          "data[0].attributes.email",
          "data[0].attributes.first_name",
          "data[0].attributes.last_name",
          "data[0].attributes.properties"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_profile",
      "description_for_ai": "Create or update a Klaviyo profile.",
      "intent": [
        "create profile Klaviyo",
        "add subscriber Klaviyo",
        "upsert contact Klaviyo",
        "добавить профиль Klaviyo"
      ],
      "endpoint": "POST https://a.klaviyo.com/api/profile-import/",
      "input": {
        "data": {
          "type": "object",
          "description": "{type: 'profile', attributes: {email: 'user@example.com', first_name: 'John', properties: {plan: 'pro'}}}",
          "required": true
        }
      },
      "output": {
        "type": "profile",
        "fields": [
          "data.id",
          "data.attributes.email",
          "data.attributes.created"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "track_event",
      "description_for_ai": "Track a custom event for a profile in Klaviyo for automation triggers.",
      "intent": [
        "track event Klaviyo",
        "trigger automation Klaviyo",
        "event Klaviyo",
        "событие Klaviyo"
      ],
      "endpoint": "POST https://a.klaviyo.com/api/events/",
      "input": {
        "data": {
          "type": "object",
          "description": "{type: 'event', attributes: {profile: {email: 'user@example.com'}, metric: {name: 'Purchase'}, properties: {value: 29.99, product: 'Pro Plan'}}}",
          "required": true
        }
      },
      "output": {
        "type": "status",
        "fields": [
          "202 Accepted"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_lists",
      "description_for_ai": "Get all email lists and segments in Klaviyo.",
      "intent": [
        "Klaviyo lists",
        "email segments",
        "subscriber lists Klaviyo",
        "списки Klaviyo"
      ],
      "endpoint": "GET https://a.klaviyo.com/api/lists/",
      "input": {
        "page[size]": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<list>",
        "fields": [
          "data[0].id",
          "data[0].attributes.name",
          "data[0].attributes.created",
          "data[0].attributes.profile_count"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_email_campaign",
      "description_for_ai": "Create and send an email campaign via Klaviyo.",
      "intent": [
        "send campaign Klaviyo",
        "email campaign",
        "newsletter Klaviyo",
        "рассылка Klaviyo"
      ],
      "endpoint": "POST https://a.klaviyo.com/api/campaign-send-jobs/",
      "input": {
        "data": {
          "type": "object",
          "description": "{type: 'campaign-send-job', relationships: {campaign: {data: {type: 'campaign', id: 'campaign_id'}}}}",
          "required": true
        }
      },
      "output": {
        "type": "send_job",
        "fields": [
          "data.id",
          "data.attributes.status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}