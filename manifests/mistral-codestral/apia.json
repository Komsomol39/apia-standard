{
  "apia": "1.0",
  "service": {
    "id": "mistral-codestral",
    "name": "Codestral API (Mistral)",
    "description_for_ai": "Best code completion model from Mistral. Fill-in-the-middle (FIM) completion for 80+ programming languages. Integrated in VS Code, JetBrains, Cursor. $0.30/$0.90 per 1M tokens. Use for code autocomplete, code generation, code explanation.",
    "url": "https://mistral.ai",
    "api_base": "https://codestral.mistral.ai/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.mistral.ai/capabilities/code_generation/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "https://console.mistral.ai — separate Codestral API key",
    "cost": "$0.30/$0.90 per 1M tokens"
  },
  "capabilities": [
    {
      "id": "fim_completion",
      "description_for_ai": "Fill-in-the-middle code completion. Provide code before cursor as prompt and code after cursor as suffix. Returns the missing code that fits between them. Best for IDE autocomplete integration.",
      "intent": [
        "code completion",
        "autocomplete",
        "code generation",
        "fill in code",
        "programming assistant",
        "IDE completion"
      ],
      "endpoint": "POST https://codestral.mistral.ai/v1/fim/completions",
      "input": {
        "model": {
          "type": "string",
          "description": "codestral-latest (recommended) or codestral-2405",
          "default": "codestral-latest"
        },
        "prompt": {
          "type": "string",
          "description": "Code before the cursor position — context for what comes before the completion",
          "required": true
        },
        "suffix": {
          "type": "string",
          "description": "Code after the cursor position — what the completion needs to connect to. Can be empty string for end-of-file completion.",
          "required": false
        },
        "max_tokens": {
          "type": "integer",
          "description": "Maximum tokens to generate for the completion",
          "default": 1024
        },
        "temperature": {
          "type": "float",
          "description": "Creativity 0.0-1.0. Use 0.0 for deterministic completions in code",
          "default": 0.0
        },
        "stop": {
          "type": "array",
          "description": "Stop sequences that end generation: ['\\n\\n', '```', 'def '] etc.",
          "required": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "choices[0].finish_reason",
          "usage.prompt_tokens",
          "usage.completion_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "chat_code",
      "description_for_ai": "Chat with Codestral for code-focused tasks: explain code, debug errors, suggest improvements, generate code from description, review code quality.",
      "intent": [
        "explain code",
        "debug code",
        "code review",
        "programming help",
        "coding assistant"
      ],
      "endpoint": "POST https://codestral.mistral.ai/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "codestral-latest",
          "description": "AI/ML model identifier to use for this request"
        },
        "messages": {
          "type": "array",
          "description": "Conversation: [{role: 'user'|'assistant', content: 'message'}]",
          "required": true
        },
        "temperature": {
          "type": "float",
          "description": "0.0 for precise code, higher for creative solutions",
          "default": 0.0
        },
        "max_tokens": {
          "type": "integer",
          "required": false,
          "description": "Maximum number of tokens to generate in response"
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "usage"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "code_generation",
      "description_for_ai": "Generate code with Codestral. Optimized for coding tasks.",
      "intent": [
        "Codestral",
        "code generation Mistral",
        "write code AI",
        "программирование Codestral"
      ],
      "endpoint": "POST https://codestral.mistral.ai/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "codestral-latest"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "temperature": {
          "type": "float",
          "default": 0.0
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "fill_in_middle",
      "description_for_ai": "Fill-in-the-middle code completion. Give prefix and suffix, Codestral fills the gap.",
      "intent": [
        "FIM completion",
        "code completion Codestral",
        "fill code Mistral"
      ],
      "endpoint": "POST https://codestral.mistral.ai/v1/fim/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "codestral-latest"
        },
        "prompt": {
          "type": "string",
          "description": "Code before cursor",
          "required": true
        },
        "suffix": {
          "type": "string",
          "description": "Code after cursor",
          "required": false
        },
        "temperature": {
          "type": "float",
          "default": 0.0
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "code_review",
      "description_for_ai": "Review code for bugs, security issues, and improvements with Codestral.",
      "intent": [
        "code review AI",
        "bug detection",
        "security review code",
        "проверка кода Codestral"
      ],
      "endpoint": "POST https://codestral.mistral.ai/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "codestral-latest"
        },
        "messages": {
          "type": "array",
          "description": "[{role: 'user', content: 'Review this code:\\n```python\\n...\\n```'}]",
          "required": true
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}