{
  "apia": "1.0",
  "service": {
    "id": "kontur-focus",
    "name": "Контур.Фокус API",
    "description_for_ai": "Проверка контрагентов и бизнес-аналитика. Данные по 20 млн организаций России: финансовая отчётность, арбитражные дела, исполнительные производства, аффилированные лица, госконтракты. Незаменим для B2B KYC в России.",
    "url": "https://focus.kontur.ru",
    "api_base": "https://focus-api.kontur.ru",
    "category": "business",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://developer.kontur.ru/doc/focus"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Подать заявку на developer.kontur.ru",
    "cost": "Платный. Демо-доступ доступен"
  },
  "capabilities": [
    {
      "id": "get_requisites",
      "description_for_ai": "Получить реквизиты организации по ИНН: название, ОГРН, адрес, руководитель, дата регистрации, уставный капитал.",
      "intent": [
        "реквизиты компании",
        "проверить контрагента",
        "ИНН организации",
        "данные компании Россия",
        "KYC Россия"
      ],
      "endpoint": "GET https://focus-api.kontur.ru/api3/req",
      "input": {
        "inn": {
          "type": "string",
          "description": "ИНН организации (10 или 12 цифр)",
          "required": true
        }
      },
      "output": {
        "type": "requisites",
        "fields": [
          "inn",
          "ogrn",
          "fullName",
          "shortName",
          "legalAddress",
          "leaders[0].fio",
          "leaders[0].position",
          "registrationDate",
          "status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_financial",
      "description_for_ai": "Получить финансовую отчётность организации: выручка, прибыль, активы из бухгалтерской отчётности ФНС.",
      "intent": [
        "финансы компании",
        "выручка организации",
        "прибыль компании",
        "бухгалтерская отчётность",
        "финансовый анализ"
      ],
      "endpoint": "GET https://focus-api.kontur.ru/api3/finanses",
      "input": {
        "inn": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "financials",
        "fields": [
          "period",
          "revenue",
          "netProfit",
          "assets",
          "netAssets"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "search_company",
      "description_for_ai": "Search Russian companies in Kontur.Focus database.",
      "intent": [
        "kontur focus поиск",
        "проверить компанию kontur",
        "найти ИНН kontur"
      ],
      "endpoint": "GET https://focus-api.kontur.ru/api3/search",
      "input": {
        "query": {
          "type": "string",
          "description": "Company name, INN, or OGRN",
          "required": true
        }
      },
      "output": {
        "type": "list<company>",
        "fields": [
          "items[0].focus.inn",
          "items[0].focus.ogrn",
          "items[0].focus.shortName",
          "items[0].focus.registrationDate"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_requisites",
      "description_for_ai": "Get full company requisites (bank, legal address, management) from Kontur.Focus.",
      "intent": [
        "реквизиты компании",
        "kontur focus реквизиты",
        "данные об организации"
      ],
      "endpoint": "GET https://focus-api.kontur.ru/api3/req",
      "input": {
        "innList": {
          "type": "string",
          "description": "INN(s) comma-separated",
          "required": true
        }
      },
      "output": {
        "type": "list<company>",
        "fields": [
          "items[0].focus.shortName",
          "items[0].focus.addresses[0].value",
          "items[0].focus.heads[0].fio",
          "items[0].focus.status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "check_counterparty",
      "description_for_ai": "Check counterparty risk score and financial health in Kontur.Focus.",
      "intent": [
        "проверить контрагента",
        "kontur focus риски",
        "надёжность контрагента"
      ],
      "endpoint": "GET https://focus-api.kontur.ru/api3/analytics",
      "input": {
        "inn": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "analytics",
        "fields": [
          "risks.level",
          "financials.revenue",
          "financials.netProfit",
          "employees.count"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}