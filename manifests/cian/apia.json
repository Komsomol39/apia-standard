{
  "apia": "1.0",
  "service": {
    "id": "cian",
    "name": "ЦИАН API (Россия)",
    "description_for_ai": "Крупнейший портал недвижимости России. Поиск квартир, домов, коммерческой недвижимости для покупки и аренды. Официальный API через партнёрскую программу. Более 20M объявлений. Используй для поиска жилья в России, проверки цен на недвижимость.",
    "url": "https://cian.ru",
    "api_base": "https://public-api.cian.ru",
    "category": "real_estate",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://www.cian.ru/help/about/partners-api/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "Подать заявку на партнёрство: https://www.cian.ru/help/about/partners-api/",
    "cost": "Партнёрский договор"
  },
  "capabilities": [
    {
      "id": "search_listings",
      "description_for_ai": "Search real estate listings on CIAN by city and parameters.",
      "intent": [
        "CIAN недвижимость",
        "cian аренда",
        "cian купить квартиру",
        "cian search"
      ],
      "endpoint": "POST https://api.cian.ru/search-offers/v1/search-offers-desktop/",
      "input": {
        "jsonQuery": {
          "type": "object",
          "description": "{_type: 'flatsale', engine_version: {type: 'term', value: 2}, region: {type: 'terms', value: [1]}, room: {type: 'terms', value: [1,2,3]}}",
          "required": true
        }
      },
      "output": {
        "type": "list<offer>",
        "fields": [
          "offersSerialized[0].id",
          "offersSerialized[0].fullUrl",
          "offersSerialized[0].bargainTerms.price",
          "offersSerialized[0].totalArea",
          "offersSerialized[0].floorsCount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_listing",
      "description_for_ai": "Get full CIAN listing details by offer ID.",
      "intent": [
        "объявление CIAN",
        "cian offer details",
        "квартира cian"
      ],
      "endpoint": "GET https://api.cian.ru/offer-card/v1/get-offer-data-by-id/",
      "input": {
        "offerId": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "offer",
        "fields": [
          "offerData.offer.id",
          "offerData.offer.totalArea",
          "offerData.offer.bargainTerms.price",
          "offerData.offer.phones[0].number",
          "offerData.offer.description"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_price_map",
      "description_for_ai": "Get average price per sqm heatmap for an area on CIAN.",
      "intent": [
        "цена CIAN карта",
        "средняя цена CIAN",
        "heatmap cian"
      ],
      "endpoint": "POST https://api.cian.ru/price-map/v1/get-price-map/",
      "input": {
        "region": {
          "type": "integer",
          "description": "Region ID: 1=Moscow",
          "required": true
        },
        "dealType": {
          "type": "string",
          "description": "sale or rent",
          "required": true
        },
        "objectType": {
          "type": "string",
          "description": "flat, house",
          "required": true
        }
      },
      "output": {
        "type": "price_map",
        "fields": [
          "items[0].pricePerMeter",
          "items[0].location"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_building_info",
      "description_for_ai": "Get building information for a CIAN address.",
      "intent": [
        "дом CIAN",
        "здание CIAN",
        "building info cian"
      ],
      "endpoint": "GET https://api.cian.ru/building/v1/get-building-summary/",
      "input": {
        "buildingId": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "building",
        "fields": [
          "name",
          "address",
          "floors",
          "material",
          "buildYear",
          "heatingType"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "similar_offers",
      "description_for_ai": "Get similar listings to a CIAN offer.",
      "intent": [
        "похожие CIAN",
        "similar cian",
        "аналоги CIAN"
      ],
      "endpoint": "GET https://api.cian.ru/recommendation/v1/get-similar-offers/",
      "input": {
        "offerId": {
          "type": "integer",
          "required": true
        },
        "limit": {
          "type": "integer",
          "default": 5
        }
      },
      "output": {
        "type": "list<offer>",
        "fields": [
          "offers[0].id",
          "offers[0].bargainTerms.price",
          "offers[0].totalArea",
          "offers[0].fullUrl"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "partnership": "API доступен только для партнёров ЦИАН. Подать заявку: cian.ru/help/about/partners-api/",
    "regions": "Регионы: 1=Москва, 2=Санкт-Петербург. Остальные регионы смотри в справочнике регионов API.",
    "alternative": "Для парсинга без партнёрства используется неофициальный API через мобильное приложение (нестабильно).",
    "metro": "ID метро получи через справочный эндпоинт /v1/geo/metros/{region_id}"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}