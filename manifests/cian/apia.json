{
  "apia": "1.0",
  "service": {
    "id": "cian",
    "name": "ЦИАН API (Россия)",
    "description_for_ai": "Крупнейший портал недвижимости России. Поиск квартир, домов, коммерческой недвижимости для покупки и аренды. Официальный API через партнёрскую программу. Более 20M объявлений. Используй для поиска жилья в России, проверки цен на недвижимость.",
    "url": "https://cian.ru",
    "api_base": "https://public-api.cian.ru",
    "category": "real_estate",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://www.cian.ru/help/about/partners-api/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "Подать заявку на партнёрство: https://www.cian.ru/help/about/partners-api/",
    "cost": "Партнёрский договор"
  },
  "capabilities": [
    {
      "id": "search_apartments",
      "description_for_ai": "Search apartments for rent or sale on CIAN (Russian real estate).",
      "intent": [
        "поиск квартир ЦИАН",
        "аренда квартир",
        "купить квартиру ЦИАН",
        "CIAN apartments"
      ],
      "endpoint": "POST https://api.cian.ru/search-offers/v2/search-offers-desktop/",
      "input": {
        "offerType": {
          "type": "string",
          "description": "flat (квартира), suburban (загородная), commercial",
          "required": true
        },
        "dealType": {
          "type": "string",
          "description": "sale or rent",
          "required": true
        },
        "engine_version": {
          "type": "integer",
          "default": 2
        },
        "page": {
          "type": "integer",
          "default": 1
        },
        "region": {
          "type": "integer",
          "description": "1=Moscow, 2=Saint Petersburg, 4593=Moscow region",
          "required": false
        }
      },
      "output": {
        "type": "list<offer>",
        "fields": [
          "offersSerialized[0].cianId",
          "offersSerialized[0].fullUrl",
          "offersSerialized[0].priceTotalRur",
          "offersSerialized[0].roomsCount",
          "offersSerialized[0].totalArea"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_offer",
      "description_for_ai": "Get full CIAN real estate listing details.",
      "intent": [
        "объявление ЦИАН",
        "листинг ЦИАН",
        "квартира ЦИАН по ID",
        "CIAN listing"
      ],
      "endpoint": "GET https://api.cian.ru/v1/get-offer-card/",
      "input": {
        "id": {
          "type": "integer",
          "description": "CIAN offer ID",
          "required": true
        }
      },
      "output": {
        "type": "offer",
        "fields": [
          "id",
          "fullUrl",
          "priceTotalRur",
          "pricePerMeterRur",
          "roomsCount",
          "totalArea",
          "floor",
          "floorsCount",
          "description",
          "address"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_price_analytics",
      "description_for_ai": "Get real estate price analytics for a Moscow region area.",
      "intent": [
        "цены на квартиры ЦИАН",
        "аналитика цен ЦИАН",
        "рынок недвижимости",
        "CIAN price analytics"
      ],
      "endpoint": "POST https://api.cian.ru/price-estimates/v1/get-estimates/",
      "input": {
        "offerType": {
          "type": "string",
          "required": true
        },
        "dealType": {
          "type": "string",
          "required": true
        },
        "coordinates": {
          "type": "object",
          "description": "{lat: 55.75, lng: 37.62}",
          "required": false
        },
        "totalArea": {
          "type": "number",
          "required": false
        },
        "roomsCount": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "estimates",
        "fields": [
          "priceEstimate",
          "pricePerMeterEstimate",
          "priceRange.min",
          "priceRange.max"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_metro_stations",
      "description_for_ai": "Get Moscow metro stations list for real estate search.",
      "intent": [
        "метро ЦИАН",
        "станции метро Москва",
        "метро поиск ЦИАН",
        "metro CIAN"
      ],
      "endpoint": "GET https://api.cian.ru/v1/get-metro-stations/",
      "input": {
        "regionId": {
          "type": "integer",
          "description": "1=Moscow, 2=Saint Petersburg",
          "default": 1
        }
      },
      "output": {
        "type": "list<station>",
        "fields": [
          "[0].id",
          "[0].name",
          "[0].lat",
          "[0].lng",
          "[0].lineColor"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_newbuildings",
      "description_for_ai": "Search new building (новостройки) listings on CIAN.",
      "intent": [
        "новостройки ЦИАН",
        "ЖК ЦИАН",
        "купить новостройку",
        "new buildings CIAN"
      ],
      "endpoint": "POST https://api.cian.ru/search-offers/v2/search-offers-desktop/",
      "input": {
        "offerType": {
          "type": "string",
          "default": "newobject"
        },
        "dealType": {
          "type": "string",
          "default": "sale"
        },
        "region": {
          "type": "integer",
          "required": false
        },
        "page": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<newbuilding>",
        "fields": [
          "offersSerialized[0].cianId",
          "offersSerialized[0].fullUrl",
          "offersSerialized[0].newbuilding.name",
          "offersSerialized[0].priceTotalRur"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "partnership": "API доступен только для партнёров ЦИАН. Подать заявку: cian.ru/help/about/partners-api/",
    "regions": "Регионы: 1=Москва, 2=Санкт-Петербург. Остальные регионы смотри в справочнике регионов API.",
    "alternative": "Для парсинга без партнёрства используется неофициальный API через мобильное приложение (нестабильно).",
    "metro": "ID метро получи через справочный эндпоинт /v1/geo/metros/{region_id}"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}