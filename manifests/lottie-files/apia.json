{
  "apia": "1.0",
  "service": {
    "id": "lottie-files",
    "name": "LottieFiles API",
    "description_for_ai": "Animation platform. Access 200K+ free Lottie animations (JSON-based vector animations). Search animations by keyword. Used to add beautiful animations to apps and websites. Animations are lightweight, scalable, and work everywhere.",
    "url": "https://lottiefiles.com",
    "api_base": "https://graphql.lottiefiles.com",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.lottiefiles.com/api/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Bearer {token}",
    "how_to_get": "Register at https://app.lottiefiles.com — free",
    "cost": "Free access to public animations. Pro for private."
  },
  "capabilities": [
    {
      "id": "search_animations",
      "description_for_ai": "Search free Lottie animations by keyword.",
      "intent": [
        "search animations Lottie",
        "free animations",
        "Lottie JSON",
        "поиск анимаций Lottie"
      ],
      "endpoint": "GET https://publicapi.lottiefiles.com/v1/animations/search",
      "input": {
        "q": {
          "type": "string",
          "required": true
        },
        "limit": {
          "type": "integer",
          "default": 10
        },
        "page": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<animation>",
        "fields": [
          "data[0].id",
          "data[0].title",
          "data[0].lottie_url",
          "data[0].preview_url",
          "data[0].width",
          "data[0].height",
          "data[0].bg_color"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_animation",
      "description_for_ai": "Get a specific Lottie animation by ID including its JSON data URL.",
      "intent": [
        "get animation Lottie",
        "download Lottie",
        "animation details",
        "анимация Lottie по ID"
      ],
      "endpoint": "GET https://publicapi.lottiefiles.com/v1/animations/{animation_id}",
      "input": {
        "animation_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "animation",
        "fields": [
          "id",
          "title",
          "lottie_url",
          "preview_url",
          "width",
          "height",
          "colors",
          "creator.username"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_featured",
      "description_for_ai": "Get featured/trending Lottie animations.",
      "intent": [
        "featured animations",
        "trending Lottie",
        "popular animations",
        "трендовые анимации Lottie"
      ],
      "endpoint": "GET https://publicapi.lottiefiles.com/v1/animations/featured",
      "input": {
        "limit": {
          "type": "integer",
          "default": 10
        },
        "page": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<animation>",
        "fields": [
          "data[0].id",
          "data[0].title",
          "data[0].lottie_url",
          "data[0].preview_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_collections",
      "description_for_ai": "Get curated Lottie animation collections.",
      "intent": [
        "animation collections",
        "Lottie packs",
        "animation categories",
        "коллекции Lottie"
      ],
      "endpoint": "GET https://publicapi.lottiefiles.com/v1/collections",
      "input": {
        "limit": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<collection>",
        "fields": [
          "data[0].id",
          "data[0].title",
          "data[0].animations_count",
          "data[0].preview_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "convert_animation",
      "description_for_ai": "Convert a Lottie animation to GIF, MP4, or WebM via the API.",
      "intent": [
        "convert Lottie",
        "Lottie to GIF",
        "export animation",
        "конвертировать Lottie"
      ],
      "endpoint": "POST https://publicapi.lottiefiles.com/v1/renders",
      "input": {
        "animation_id": {
          "type": "string",
          "required": true
        },
        "format": {
          "type": "string",
          "description": "gif, mp4, webm",
          "required": true
        },
        "quality": {
          "type": "string",
          "description": "low, medium, high",
          "default": "medium"
        }
      },
      "output": {
        "type": "render",
        "fields": [
          "id",
          "status",
          "url (download when status=done)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "usage": "Download lottieUrl JSON and use with lottie-web library: lottie.loadAnimation({container, renderer: svg, loop: true, autoplay: true, path: lottieUrl})",
    "free_alternatives": "Many common animations (loading, success, error) available free at lottiefiles.com/search"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}