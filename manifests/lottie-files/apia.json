{
  "apia": "1.0",
  "service": {
    "id": "lottie-files",
    "name": "LottieFiles API",
    "description_for_ai": "Animation platform. Access 200K+ free Lottie animations (JSON-based vector animations). Search animations by keyword. Used to add beautiful animations to apps and websites. Animations are lightweight, scalable, and work everywhere.",
    "url": "https://lottiefiles.com",
    "api_base": "https://graphql.lottiefiles.com",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.lottiefiles.com/api/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Bearer {token}",
    "how_to_get": "Register at https://app.lottiefiles.com — free",
    "cost": "Free access to public animations. Pro for private."
  },
  "capabilities": [
    {
      "id": "search_animations",
      "description_for_ai": "Search Lottie animations by keyword on LottieFiles.",
      "intent": [
        "lottie animation",
        "lottiefiles search",
        "animated icons",
        "анимации lottie"
      ],
      "endpoint": "GET https://api.lottiefiles.com/api/animations/public",
      "input": {
        "search": {
          "type": "string",
          "required": false
        },
        "page": {
          "type": "integer",
          "default": 1
        },
        "per_page": {
          "type": "integer",
          "default": 20
        },
        "category": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<animation>",
        "fields": [
          "data[0].id",
          "data[0].title",
          "data[0].lottie_url",
          "data[0].preview_url",
          "data[0].tags"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_animation",
      "description_for_ai": "Get a specific Lottie animation by ID with download URL.",
      "intent": [
        "get lottie",
        "download animation",
        "animation details",
        "получить анимацию lottie"
      ],
      "endpoint": "GET https://api.lottiefiles.com/api/animations/{id}",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "animation",
        "fields": [
          "id",
          "title",
          "lottie_url",
          "preview_url",
          "tags",
          "description"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_categories",
      "description_for_ai": "Get list of LottieFiles animation categories.",
      "intent": [
        "lottie categories",
        "animation types",
        "categories lottiefiles"
      ],
      "endpoint": "GET https://api.lottiefiles.com/api/categories",
      "input": {},
      "output": {
        "type": "list<category>",
        "fields": [
          "data[0].id",
          "data[0].title",
          "data[0].slug"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "featured_animations",
      "description_for_ai": "Get featured/popular Lottie animations from LottieFiles.",
      "intent": [
        "popular animations",
        "featured lottie",
        "trending animations",
        "популярные анимации lottie"
      ],
      "endpoint": "GET https://api.lottiefiles.com/api/animations/featured",
      "input": {
        "page": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<animation>",
        "fields": [
          "data[0].id",
          "data[0].title",
          "data[0].lottie_url",
          "data[0].preview_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "user_animations",
      "description_for_ai": "Get animations uploaded by a specific LottieFiles user.",
      "intent": [
        "user animations lottie",
        "creator animations",
        "my lottie files",
        "анимации пользователя lottie"
      ],
      "endpoint": "GET https://api.lottiefiles.com/api/users/{username}/animations",
      "input": {
        "username": {
          "type": "string",
          "required": true
        },
        "page": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<animation>",
        "fields": [
          "data[0].id",
          "data[0].title",
          "data[0].lottie_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "usage": "Download lottieUrl JSON and use with lottie-web library: lottie.loadAnimation({container, renderer: svg, loop: true, autoplay: true, path: lottieUrl})",
    "free_alternatives": "Many common animations (loading, success, error) available free at lottiefiles.com/search"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}