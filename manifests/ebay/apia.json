{
  "apia": "1.0",
  "service": {
    "id": "ebay",
    "name": "eBay API",
    "description_for_ai": "eBay marketplace API. Search 1.4B+ listings, manage seller inventory, process orders. Browse API for searching items, Sell API for merchants, Buy API for buyers. Global marketplace with strong used/collectibles market.",
    "url": "https://developer.ebay.com",
    "api_base": "https://api.ebay.com",
    "category": "ecommerce",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.ebay.com/develop/apis"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Register at https://developer.ebay.com",
    "cost": "Free. eBay seller account for selling APIs"
  },
  "capabilities": [
    {
      "id": "search_items",
      "description_for_ai": "Search eBay listings by keyword, category, price range. Returns item title, price, condition, seller rating.",
      "intent": [
        "eBay search",
        "find on eBay",
        "buy second hand",
        "marketplace search",
        "collectibles",
        "used items",
        "auction"
      ],
      "endpoint": "GET https://api.ebay.com/buy/browse/v1/item_summary/search",
      "input": {
        "q": {
          "type": "string",
          "description": "Search keyword",
          "required": true
        },
        "filter": {
          "type": "string",
          "description": "price:[10..100], conditions:{NEW|USED}, buyingOptions:{FIXED_PRICE|AUCTION}",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 20
        },
        "sort": {
          "type": "string",
          "description": "price, -price, newlyListed, endingSoonest",
          "required": false
        }
      },
      "output": {
        "type": "list<item>",
        "fields": [
          "itemSummaries[0].title",
          "itemSummaries[0].price.value",
          "itemSummaries[0].condition",
          "itemSummaries[0].itemWebUrl",
          "itemSummaries[0].seller.feedbackScore",
          "itemSummaries[0].image.imageUrl"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}