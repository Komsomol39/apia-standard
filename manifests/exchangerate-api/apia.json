{
  "apia": "1.0",
  "service": {
    "id": "exchangerate-api",
    "name": "ExchangeRate-API",
    "description_for_ai": "Real-time and historical currency exchange rates for 160+ currencies. Free tier: 1500 requests/month, no credit card. Use for currency conversion, showing prices in local currency, financial calculations.",
    "url": "https://exchangerate-api.com",
    "api_base": "https://v6.exchangerate-api.com/v6",
    "category": "finance",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.exchangerate-api.com/docs/overview"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_location": "path",
    "how_to_get": "Register at https://www.exchangerate-api.com — free tier, no credit card",
    "cost": "Free: 1500 requests/month. Pro: from $9.99/month"
  },
  "capabilities": [
    {
      "id": "get_latest_rates",
      "description_for_ai": "Get current exchange rates from a base currency to all 161 supported currencies.",
      "intent": [
        "exchange rates",
        "currency conversion",
        "forex rates",
        "курсы валют",
        "конвертация валют"
      ],
      "endpoint": "GET https://v6.exchangerate-api.com/v6/{api_key}/latest/{base_currency}",
      "input": {
        "base_currency": {
          "type": "string",
          "description": "ISO 4217 code e.g. USD, EUR, RUB, CNY",
          "required": true
        }
      },
      "output": {
        "type": "rates",
        "fields": [
          "base_code",
          "conversion_rates.EUR",
          "conversion_rates.RUB",
          "conversion_rates.USD",
          "time_last_update_utc"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "convert",
      "description_for_ai": "Convert a specific amount from one currency to another.",
      "intent": [
        "convert currency",
        "currency convert",
        "USD to EUR",
        "конвертировать валюту",
        "перевести рубли в доллары"
      ],
      "endpoint": "GET https://v6.exchangerate-api.com/v6/{api_key}/pair/{from}/{to}/{amount}",
      "input": {
        "from": {
          "type": "string",
          "description": "Source currency code e.g. USD",
          "required": true
        },
        "to": {
          "type": "string",
          "description": "Target currency code e.g. EUR",
          "required": true
        },
        "amount": {
          "type": "number",
          "description": "Amount to convert",
          "required": true
        }
      },
      "output": {
        "type": "conversion",
        "fields": [
          "base_code",
          "target_code",
          "conversion_rate",
          "conversion_result",
          "time_last_update_utc"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_historical",
      "description_for_ai": "Get historical exchange rates for a specific date going back to 1990.",
      "intent": [
        "historical rates",
        "past exchange rates",
        "historical forex",
        "исторические курсы валют"
      ],
      "endpoint": "GET https://v6.exchangerate-api.com/v6/{api_key}/history/{base}/{year}/{month}/{day}",
      "input": {
        "base": {
          "type": "string",
          "required": true
        },
        "year": {
          "type": "integer",
          "required": true
        },
        "month": {
          "type": "integer",
          "required": true
        },
        "day": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "historical_rates",
        "fields": [
          "base_code",
          "year",
          "month",
          "day",
          "conversion_rates"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "list_currencies",
      "description_for_ai": "Get list of all 161 supported currency codes and their full names.",
      "intent": [
        "list currencies",
        "supported currencies",
        "currency codes",
        "список валют"
      ],
      "endpoint": "GET https://v6.exchangerate-api.com/v6/{api_key}/codes",
      "input": {},
      "output": {
        "type": "list<currency>",
        "fields": [
          "supported_codes [[code, name]]"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "historical_range",
      "description_for_ai": "Get exchange rates for a range of dates.",
      "intent": [
        "historical exchange rates",
        "rate range",
        "исторические курсы диапазон"
      ],
      "endpoint": "GET https://v6.exchangerate-api.com/v6/{api_key}/history/{base}/{year}/{month}/{day}",
      "input": {
        "base": {
          "type": "string",
          "required": true
        },
        "year": {
          "type": "integer",
          "required": true
        },
        "month": {
          "type": "integer",
          "required": true
        },
        "day": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "rates",
        "fields": [
          "conversion_rates",
          "time_last_update_utc"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "common_codes": "USD=US Dollar, EUR=Euro, RUB=Russian Ruble, GBP=British Pound, JPY=Japanese Yen, CNY=Chinese Yuan, KZT=Kazakhstani Tenge, BYN=Belarusian Ruble, UAH=Ukrainian Hryvnia",
    "update_frequency": "Rates updated every 24 hours on free tier, every hour on Pro.",
    "calculation_tip": "To convert: result = amount * conversion_rate. E.g. 100 USD * 89.5 = 8950 RUB"
  },
  "limits": {
    "free_requests_per_month": 1500,
    "commercial_use": true,
    "attribution_required": false
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}