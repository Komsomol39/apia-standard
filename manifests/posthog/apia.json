{
  "apia": "1.0",
  "service": {
    "id": "posthog",
    "name": "PostHog API",
    "description_for_ai": "Open-source product analytics. Events, feature flags, session recordings, A/B tests, funnels, cohorts. Self-hostable. 1M events/month free on cloud. Privacy-friendly alternative to Mixpanel.",
    "url": "https://posthog.com",
    "api_base": "https://app.posthog.com",
    "category": "analytics",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://posthog.com/docs/api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Bearer {personal_api_key}",
    "how_to_get": "Settings → API keys",
    "cost": "Free: 1M events/month. Paid: $0.00005/event"
  },
  "capabilities": [
    {
      "id": "capture_event",
      "description_for_ai": "Capture a user event in PostHog for product analytics.",
      "intent": [
        "posthog event",
        "capture analytics",
        "track posthog",
        "аналитика posthog"
      ],
      "endpoint": "POST https://app.posthog.com/capture/",
      "input": {
        "api_key": {
          "type": "string",
          "required": true
        },
        "event": {
          "type": "string",
          "description": "Event name e.g. 'button_clicked', 'page_viewed'",
          "required": true
        },
        "distinct_id": {
          "type": "string",
          "description": "Unique user identifier",
          "required": true
        },
        "properties": {
          "type": "object",
          "description": "Event properties: {$current_url, $browser, plan, amount}",
          "required": false
        },
        "timestamp": {
          "type": "string",
          "description": "ISO 8601 timestamp. Default: now",
          "required": false
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "status (1=success)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "identify_user",
      "description_for_ai": "Identify a user in PostHog and set their profile properties.",
      "intent": [
        "identify user posthog",
        "set user properties",
        "user profile posthog"
      ],
      "endpoint": "POST https://app.posthog.com/capture/",
      "input": {
        "api_key": {
          "type": "string",
          "required": true
        },
        "event": {
          "type": "string",
          "default": "$identify"
        },
        "distinct_id": {
          "type": "string",
          "required": true
        },
        "$set": {
          "type": "object",
          "description": "{email: 'user@example.com', name: 'John', plan: 'pro', company: 'Acme'}",
          "required": false
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "query_insights",
      "description_for_ai": "Query PostHog insights: event trends, funnels, retention, and user paths.",
      "intent": [
        "posthog insights",
        "event trends",
        "funnel posthog",
        "аналитика воронки posthog"
      ],
      "endpoint": "POST https://app.posthog.com/api/projects/{project_id}/insights/trend/",
      "input": {
        "project_id": {
          "type": "string",
          "required": true
        },
        "events": {
          "type": "array",
          "description": "[{id: 'button_clicked', type: 'events', math: 'dau'}]",
          "required": true
        },
        "date_from": {
          "type": "string",
          "description": "-7d, -30d, -90d, or YYYY-MM-DD",
          "default": "-7d"
        },
        "interval": {
          "type": "string",
          "description": "day, week, month",
          "default": "day"
        }
      },
      "output": {
        "type": "insights",
        "fields": [
          "result[0].data (array of values)",
          "result[0].labels (date labels)",
          "result[0].count"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_feature_flags",
      "description_for_ai": "Get all feature flags and decide which are enabled for a user.",
      "intent": [
        "feature flags posthog",
        "A/B test posthog",
        "feature toggle",
        "флаги фич posthog"
      ],
      "endpoint": "POST https://app.posthog.com/decide/",
      "input": {
        "api_key": {
          "type": "string",
          "required": true
        },
        "distinct_id": {
          "type": "string",
          "required": true
        },
        "person_properties": {
          "type": "object",
          "description": "User properties for flag evaluation",
          "required": false
        }
      },
      "output": {
        "type": "flags",
        "fields": [
          "featureFlags (dict of flag_name: true/false/variant)",
          "featureFlagPayloads"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}