{
  "apia": "1.0",
  "service": {
    "id": "posthog",
    "name": "PostHog API",
    "description_for_ai": "Open-source product analytics. Events, feature flags, session recordings, A/B tests, funnels, cohorts. Self-hostable. 1M events/month free on cloud. Privacy-friendly alternative to Mixpanel.",
    "url": "https://posthog.com",
    "api_base": "https://app.posthog.com",
    "category": "analytics",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://posthog.com/docs/api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Bearer {personal_api_key}",
    "how_to_get": "Settings → API keys",
    "cost": "Free: 1M events/month. Paid: $0.00005/event"
  },
  "capabilities": [
    {
      "id": "capture_event",
      "description_for_ai": "Track a user event in PostHog. Send custom events with properties for analytics.",
      "intent": [
        "track event PostHog",
        "analytics event",
        "user tracking",
        "аналитика PostHog"
      ],
      "endpoint": "POST https://app.posthog.com/capture/",
      "input": {
        "api_key": {
          "type": "string",
          "description": "Project API key (public, starts with phc_)",
          "required": true
        },
        "event": {
          "type": "string",
          "description": "Event name: 'button_clicked', 'purchase_completed'",
          "required": true
        },
        "distinct_id": {
          "type": "string",
          "description": "User identifier",
          "required": true
        },
        "properties": {
          "type": "object",
          "description": "Custom properties: {plan: 'pro', value: 49.99, page: '/checkout'}",
          "required": false
        },
        "timestamp": {
          "type": "string",
          "description": "ISO 8601 datetime. Omit for current time.",
          "required": false
        }
      },
      "output": {
        "type": "status",
        "fields": [
          "status: 1 (success)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "identify_user",
      "description_for_ai": "Set user properties in PostHog (name, email, plan, etc.).",
      "intent": [
        "identify user PostHog",
        "user properties",
        "set user traits",
        "идентификация пользователя PostHog"
      ],
      "endpoint": "POST https://app.posthog.com/capture/",
      "input": {
        "api_key": {
          "type": "string",
          "required": true
        },
        "event": {
          "type": "string",
          "default": "$identify"
        },
        "distinct_id": {
          "type": "string",
          "required": true
        },
        "properties": {
          "type": "object",
          "description": "{$set: {email: 'user@example.com', name: 'John', plan: 'pro'}, $set_once: {created_at: '2024-01-01'}}",
          "required": true
        }
      },
      "output": {
        "type": "status",
        "fields": [
          "status: 1"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_insights",
      "description_for_ai": "Query analytics insights from PostHog: trends, funnels, retention, paths.",
      "intent": [
        "PostHog insights",
        "analytics query",
        "funnel analysis",
        "аналитика событий PostHog"
      ],
      "endpoint": "GET https://app.posthog.com/api/projects/{project_id}/insights",
      "input": {
        "project_id": {
          "type": "string",
          "required": true
        },
        "insight": {
          "type": "string",
          "description": "TRENDS, FUNNELS, RETENTION, PATHS",
          "required": false
        },
        "events": {
          "type": "string",
          "description": "JSON filter for events",
          "required": false
        }
      },
      "output": {
        "type": "insights",
        "fields": [
          "results[0].data",
          "results[0].labels",
          "results[0].count"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "feature_flags",
      "description_for_ai": "Check which feature flags are enabled for a user.",
      "intent": [
        "feature flags PostHog",
        "A/B test",
        "feature toggle",
        "флаги функций PostHog"
      ],
      "endpoint": "POST https://app.posthog.com/decide/",
      "input": {
        "api_key": {
          "type": "string",
          "required": true
        },
        "distinct_id": {
          "type": "string",
          "required": true
        },
        "groups": {
          "type": "object",
          "description": "Optional group memberships",
          "required": false
        }
      },
      "output": {
        "type": "flags",
        "fields": [
          "featureFlags (object: flag_name → bool)",
          "featureFlagPayloads (object: flag_name → payload)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_persons",
      "description_for_ai": "Get list of users (persons) with their properties from PostHog.",
      "intent": [
        "users PostHog",
        "person list",
        "user database PostHog",
        "пользователи PostHog"
      ],
      "endpoint": "GET https://app.posthog.com/api/projects/{project_id}/persons/",
      "input": {
        "project_id": {
          "type": "string",
          "required": true
        },
        "search": {
          "type": "string",
          "description": "Filter by name or email",
          "required": false
        },
        "properties": {
          "type": "string",
          "description": "JSON property filter",
          "required": false
        }
      },
      "output": {
        "type": "list<person>",
        "fields": [
          "results[0].id",
          "results[0].distinct_ids",
          "results[0].properties.email",
          "results[0].created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_cohort",
      "description_for_ai": "Create a user cohort based on behavioral filters for segmentation.",
      "intent": [
        "PostHog cohort",
        "user segment",
        "audience cohort",
        "когорта пользователей PostHog"
      ],
      "endpoint": "POST https://app.posthog.com/api/projects/{project_id}/cohorts/",
      "input": {
        "project_id": {
          "type": "string",
          "required": true
        },
        "name": {
          "type": "string",
          "required": true
        },
        "filters": {
          "type": "object",
          "description": "{properties: {type: 'AND', values: [{type: 'person', key: 'plan', value: 'pro', operator: 'exact'}]}}",
          "required": true
        }
      },
      "output": {
        "type": "cohort",
        "fields": [
          "id",
          "name",
          "count",
          "is_calculating"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}