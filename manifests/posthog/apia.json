{
  "apia": "1.0",
  "service": {
    "id": "posthog",
    "name": "PostHog API",
    "description_for_ai": "Open-source product analytics. Events, feature flags, session recordings, A/B tests, funnels, cohorts. Self-hostable. 1M events/month free on cloud. Privacy-friendly alternative to Mixpanel.",
    "url": "https://posthog.com",
    "api_base": "https://app.posthog.com",
    "category": "product_analytics",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://posthog.com/docs/api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Bearer {personal_api_key}",
    "how_to_get": "Settings → API keys",
    "cost": "Free: 1M events/month. Paid: $0.00005/event"
  },
  "capabilities": [
    {
      "id": "capture_event",
      "description_for_ai": "Track user event in PostHog. Records user actions for analytics.",
      "intent": [
        "track event",
        "analytics",
        "user action",
        "posthog capture",
        "product analytics"
      ],
      "endpoint": "POST https://app.posthog.com/capture/",
      "input": {
        "api_key": {
          "type": "string",
          "description": "Project API key",
          "required": true
        },
        "event": {
          "type": "string",
          "required": true
        },
        "distinct_id": {
          "type": "string",
          "description": "User identifier",
          "required": true
        },
        "properties": {
          "type": "object",
          "required": false
        },
        "timestamp": {
          "type": "string",
          "description": "ISO 8601",
          "required": false
        }
      },
      "output": {
        "type": "success",
        "fields": [
          "status"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_feature_flag",
      "description_for_ai": "Check if a feature flag is enabled for a user. Use for gradual rollouts, A/B tests.",
      "intent": [
        "feature flag",
        "A/B test",
        "feature rollout",
        "toggle feature",
        "experiment"
      ],
      "endpoint": "POST https://app.posthog.com/decide/",
      "input": {
        "api_key": {
          "type": "string",
          "required": true
        },
        "distinct_id": {
          "type": "string",
          "required": true
        },
        "groups": {
          "type": "object",
          "required": false
        }
      },
      "output": {
        "type": "flags",
        "fields": [
          "featureFlags",
          "featureFlagPayloads"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}