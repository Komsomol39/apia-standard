{
  "apia": "1.0",
  "service": {
    "id": "posthog",
    "name": "PostHog API",
    "description_for_ai": "Open-source product analytics. Events, feature flags, session recordings, A/B tests, funnels, cohorts. Self-hostable. 1M events/month free on cloud. Privacy-friendly alternative to Mixpanel.",
    "url": "https://posthog.com",
    "api_base": "https://app.posthog.com",
    "category": "analytics",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://posthog.com/docs/api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Bearer {personal_api_key}",
    "how_to_get": "Settings → API keys",
    "cost": "Free: 1M events/month. Paid: $0.00005/event"
  },
  "capabilities": [
    {
      "id": "capture_event",
      "description_for_ai": "Capture a product analytics event with user properties. Free up to 1M events/month.",
      "intent": [
        "posthog event",
        "track event posthog",
        "product analytics",
        "отслеживание posthog"
      ],
      "endpoint": "POST https://app.posthog.com/capture/",
      "input": {
        "api_key": {
          "type": "string",
          "description": "PostHog project API key (public, not secret)",
          "required": true
        },
        "event": {
          "type": "string",
          "description": "Event name",
          "required": true
        },
        "distinct_id": {
          "type": "string",
          "description": "Unique user identifier",
          "required": true
        },
        "properties": {
          "type": "object",
          "description": "Event properties. Special: $current_url, $referrer, $os, $browser",
          "required": false
        },
        "timestamp": {
          "type": "string",
          "description": "ISO 8601 for historical import. Default: now",
          "required": false
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "status"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "identify_user",
      "description_for_ai": "Identify a user with properties for segmentation and cohort analysis.",
      "intent": [
        "posthog identify",
        "user identification",
        "set user properties posthog",
        "идентификация пользователя posthog"
      ],
      "endpoint": "POST https://app.posthog.com/capture/",
      "input": {
        "api_key": {
          "type": "string",
          "required": true
        },
        "event": {
          "type": "string",
          "description": "Always '$identify' for user identification",
          "default": "$identify"
        },
        "distinct_id": {
          "type": "string",
          "required": true
        },
        "$set": {
          "type": "object",
          "description": "User properties: {email, name, plan, company, created_at}",
          "required": false
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "status"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "check_feature_flag",
      "description_for_ai": "Check if a feature flag is enabled for a user. Use for A/B testing and gradual rollouts.",
      "intent": [
        "feature flag posthog",
        "A/B test",
        "rollout feature",
        "фичефлаг posthog"
      ],
      "endpoint": "POST https://app.posthog.com/decide/",
      "input": {
        "api_key": {
          "type": "string",
          "required": true
        },
        "distinct_id": {
          "type": "string",
          "required": true
        },
        "groups": {
          "type": "object",
          "description": "Group keys for group-based flags: {organization: 'org_id'}",
          "required": false
        }
      },
      "output": {
        "type": "flags",
        "fields": [
          "featureFlags (object key-value)",
          "featureFlagPayloads (JSON payloads per flag)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "query_insights",
      "description_for_ai": "Run analytics queries: trends, funnels, retention, paths using PostHog API.",
      "intent": [
        "posthog analytics",
        "query insights",
        "trend analysis posthog",
        "аналитика posthog"
      ],
      "endpoint": "POST https://app.posthog.com/api/projects/{project_id}/insights/trend/",
      "input": {
        "project_id": {
          "type": "string",
          "description": "PostHog project ID",
          "required": true
        },
        "events": {
          "type": "array",
          "description": "[{id: 'pageview', name: 'Pageview', type: 'events'}]",
          "required": true
        },
        "date_from": {
          "type": "string",
          "description": "-30d, -7d, or YYYY-MM-DD",
          "required": false
        },
        "date_to": {
          "type": "string",
          "required": false
        },
        "breakdown": {
          "type": "string",
          "description": "Property to break down by e.g. $browser",
          "required": false
        }
      },
      "output": {
        "type": "insights",
        "fields": [
          "result[0].label",
          "result[0].data (array of values)",
          "result[0].labels (array of dates)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}