{
  "apia": "1.0",
  "service": {
    "id": "semantic-scholar",
    "name": "Semantic Scholar API",
    "description_for_ai": "Free academic paper search with AI-powered recommendations. 220M+ papers, citations graph, author profiles, paper recommendations, research trends. Better discovery than Google Scholar. No API key for basic use.",
    "url": "https://semanticscholar.org",
    "api_base": "https://api.semanticscholar.org/graph/v1",
    "category": "science",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://api.semanticscholar.org/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_limits": "100 req/5min",
    "header": "x-api-key: ...",
    "how_to_get": "Request key at https://www.semanticscholar.org/product/api",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "search_papers",
      "description_for_ai": "Search 220M+ academic papers. Filter by year, field of study, open access.",
      "intent": [
        "semantic scholar search",
        "find paper",
        "academic search S2",
        "поиск статей semantic scholar"
      ],
      "endpoint": "GET https://api.semanticscholar.org/graph/v1/paper/search",
      "input": {
        "query": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "paperId,title,abstract,year,citationCount,authors,externalIds,openAccessPdf",
          "default": "paperId,title,year,citationCount"
        },
        "limit": {
          "type": "integer",
          "default": 10
        },
        "offset": {
          "type": "integer",
          "default": 0
        },
        "year": {
          "type": "string",
          "description": "Year range: 2020-2024 or exact year 2023",
          "required": false
        },
        "fieldsOfStudy": {
          "type": "string",
          "description": "Computer Science, Medicine, Biology, Physics",
          "required": false
        },
        "openAccessPdf": {
          "type": "boolean",
          "description": "Only papers with free PDF",
          "required": false
        }
      },
      "output": {
        "type": "list<paper>",
        "fields": [
          "data[0].paperId",
          "data[0].title",
          "data[0].year",
          "data[0].citationCount",
          "data[0].abstract"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_paper",
      "description_for_ai": "Get full paper details: abstract, authors, citations, references, PDF URL.",
      "intent": [
        "paper details S2",
        "semantic scholar paper",
        "citation data",
        "детали статьи semantic scholar"
      ],
      "endpoint": "GET https://api.semanticscholar.org/graph/v1/paper/{paper_id}",
      "input": {
        "paper_id": {
          "type": "string",
          "description": "S2 paper ID, DOI: DOI:10.1000/xyz, arXiv: ARXIV:2001.00001",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "paperId,title,abstract,authors,year,citationCount,references,citations,externalIds,openAccessPdf",
          "default": "paperId,title,abstract,year,citationCount"
        }
      },
      "output": {
        "type": "paper",
        "fields": [
          "paperId",
          "title",
          "abstract",
          "year",
          "citationCount",
          "openAccessPdf.url"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_citations",
      "description_for_ai": "Get papers that cite a given paper.",
      "intent": [
        "paper citations S2",
        "who cited this",
        "citation list",
        "кто цитирует статью"
      ],
      "endpoint": "GET https://api.semanticscholar.org/graph/v1/paper/{paper_id}/citations",
      "input": {
        "paper_id": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "string",
          "default": "paperId,title,year,citationCount"
        },
        "limit": {
          "type": "integer",
          "default": 100
        }
      },
      "output": {
        "type": "citations",
        "fields": [
          "data[0].citingPaper.paperId",
          "data[0].citingPaper.title",
          "data[0].citingPaper.year"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_author",
      "description_for_ai": "Get researcher profile: papers, citations, h-index.",
      "intent": [
        "researcher profile S2",
        "author papers",
        "h-index lookup",
        "профиль исследователя semantic scholar"
      ],
      "endpoint": "GET https://api.semanticscholar.org/graph/v1/author/{author_id}",
      "input": {
        "author_id": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "string",
          "default": "authorId,name,paperCount,citationCount,hIndex,affiliations"
        }
      },
      "output": {
        "type": "author",
        "fields": [
          "authorId",
          "name",
          "paperCount",
          "citationCount",
          "hIndex",
          "affiliations[0].name"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}