{
  "apia": "1.0",
  "service": {
    "id": "semantic-scholar",
    "name": "Semantic Scholar API",
    "description_for_ai": "Free academic paper search with AI-powered recommendations. 220M+ papers, citations graph, author profiles, paper recommendations, research trends. Better discovery than Google Scholar. No API key for basic use.",
    "url": "https://semanticscholar.org",
    "api_base": "https://api.semanticscholar.org/graph/v1",
    "category": "science",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://api.semanticscholar.org/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_limits": "100 req/5min",
    "header": "x-api-key: ...",
    "how_to_get": "Request key at https://www.semanticscholar.org/product/api",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "search_papers",
      "description_for_ai": "Search 200M+ academic papers across all disciplines with AI-powered relevance.",
      "intent": [
        "academic search",
        "find papers",
        "Semantic Scholar search",
        "поиск научных статей"
      ],
      "endpoint": "GET https://api.semanticscholar.org/graph/v1/paper/search",
      "input": {
        "query": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "title,abstract,authors,year,citationCount,openAccessPdf,venue",
          "default": "title,year,citationCount"
        },
        "limit": {
          "type": "integer",
          "default": 10
        },
        "offset": {
          "type": "integer",
          "default": 0
        }
      },
      "output": {
        "type": "list<paper>",
        "fields": [
          "data[0].paperId",
          "data[0].title",
          "data[0].year",
          "data[0].citationCount",
          "data[0].openAccessPdf.url",
          "data[0].abstract"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_paper",
      "description_for_ai": "Get detailed information about a paper by its ID, DOI, or ArXiv ID.",
      "intent": [
        "paper details",
        "paper info",
        "research paper",
        "детали статьи"
      ],
      "endpoint": "GET https://api.semanticscholar.org/graph/v1/paper/{paper_id}",
      "input": {
        "paper_id": {
          "type": "string",
          "description": "S2 ID, DOI (DOI:10.1038/...), or ArXiv ID (ARXIV:2303.08774)",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "title,abstract,authors,year,citationCount,references,citations,openAccessPdf",
          "required": false
        }
      },
      "output": {
        "type": "paper",
        "fields": [
          "paperId",
          "title",
          "abstract",
          "authors[0].name",
          "year",
          "citationCount",
          "openAccessPdf.url"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_author",
      "description_for_ai": "Get author profile: papers, h-index, citation count.",
      "intent": [
        "author profile",
        "researcher info",
        "scientist papers",
        "профиль исследователя"
      ],
      "endpoint": "GET https://api.semanticscholar.org/graph/v1/author/{author_id}",
      "input": {
        "author_id": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "name,paperCount,citationCount,hIndex,papers",
          "default": "name,paperCount,citationCount,hIndex"
        }
      },
      "output": {
        "type": "author",
        "fields": [
          "authorId",
          "name",
          "paperCount",
          "citationCount",
          "hIndex"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_citations",
      "description_for_ai": "Get papers that cite a given paper.",
      "intent": [
        "paper citations",
        "citing papers",
        "who cited",
        "цитирования статьи"
      ],
      "endpoint": "GET https://api.semanticscholar.org/graph/v1/paper/{paper_id}/citations",
      "input": {
        "paper_id": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "title,year,citationCount,authors",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 100
        },
        "offset": {
          "type": "integer",
          "default": 0
        }
      },
      "output": {
        "type": "list<citation>",
        "fields": [
          "data[0].citingPaper.paperId",
          "data[0].citingPaper.title",
          "data[0].citingPaper.year",
          "total (total count)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_references",
      "description_for_ai": "Get papers referenced by a given paper.",
      "intent": [
        "paper references",
        "paper bibliography",
        "cited works",
        "список литературы статьи"
      ],
      "endpoint": "GET https://api.semanticscholar.org/graph/v1/paper/{paper_id}/references",
      "input": {
        "paper_id": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "title,year,authors",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 100
        }
      },
      "output": {
        "type": "list<reference>",
        "fields": [
          "data[0].citedPaper.paperId",
          "data[0].citedPaper.title",
          "data[0].citedPaper.year"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "batch_paper_details",
      "description_for_ai": "Get details for up to 500 papers in a single request by paper IDs.",
      "intent": [
        "bulk papers",
        "batch query papers",
        "multiple papers at once",
        "пакетный запрос статей"
      ],
      "endpoint": "POST https://api.semanticscholar.org/graph/v1/paper/batch",
      "input": {
        "ids": {
          "type": "array",
          "description": "Up to 500 paper IDs: ['DOI:...', 'ARXIV:...', 'S2PaperId']",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "title,year,citationCount,authors,abstract",
          "required": false
        }
      },
      "output": {
        "type": "list<paper>",
        "fields": [
          "[0].paperId",
          "[0].title",
          "[0].year",
          "[0].citationCount"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}