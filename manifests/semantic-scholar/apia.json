{
  "apia": "1.0",
  "service": {
    "id": "semantic-scholar",
    "name": "Semantic Scholar API",
    "description_for_ai": "Free academic paper search with AI-powered recommendations. 220M+ papers, citations graph, author profiles, paper recommendations, research trends. Better discovery than Google Scholar. No API key for basic use.",
    "url": "https://semanticscholar.org",
    "api_base": "https://api.semanticscholar.org/graph/v1",
    "category": "science",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://api.semanticscholar.org/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_limits": "100 req/5min",
    "header": "x-api-key: ...",
    "how_to_get": "Request key at https://www.semanticscholar.org/product/api",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "search_papers",
      "description_for_ai": "Search 220M+ academic papers by keyword. Returns title, abstract, citation count, authors, and open access PDF links.",
      "intent": [
        "find research paper",
        "academic search",
        "citations",
        "paper lookup",
        "research topic",
        "study findings"
      ],
      "endpoint": "GET https://api.semanticscholar.org/graph/v1/paper/search",
      "input": {
        "query": {
          "type": "string",
          "description": "Search query — supports natural language: 'transformer attention mechanism', 'COVID vaccine efficacy', 'reinforcement learning robotics'",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "Comma-separated fields: title,abstract,authors,year,citationCount,openAccessPdf,externalIds,venue,referenceCount,s2FieldsOfStudy",
          "default": "title,abstract,year,citationCount"
        },
        "limit": {
          "type": "integer",
          "description": "Results per page, max 100",
          "default": 10
        },
        "offset": {
          "type": "integer",
          "description": "Pagination offset",
          "default": 0
        },
        "publicationTypes": {
          "type": "string",
          "description": "Filter by type: JournalArticle, Conference, Review, Book, Dataset",
          "required": false
        },
        "year": {
          "type": "string",
          "description": "Year filter: '2023', '2020-2024', '-2020' (before 2020), '2020-' (after 2020)",
          "required": false
        },
        "openAccessPdf": {
          "type": "string",
          "description": "Pass empty string to filter only open access papers with free PDF",
          "required": false
        }
      },
      "output": {
        "type": "list<paper>",
        "fields": [
          "data[0].paperId",
          "data[0].title",
          "data[0].abstract",
          "data[0].year",
          "data[0].citationCount",
          "data[0].openAccessPdf.url",
          "data[0].authors[0].name",
          "total"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_paper_recommendations",
      "description_for_ai": "Get AI-powered paper recommendations similar to given papers. Excellent for literature discovery and finding related work.",
      "intent": [
        "similar papers",
        "related research",
        "paper recommendations",
        "find more like this"
      ],
      "endpoint": "POST https://api.semanticscholar.org/recommendations/v1/papers",
      "input": {
        "positivePaperIds": {
          "type": "array",
          "description": "Semantic Scholar paper IDs to base recommendations on. Pass 1-5 papers you want similar papers to.",
          "required": true
        },
        "negativePaperIds": {
          "type": "array",
          "description": "Paper IDs to EXCLUDE from recommendations — papers you don't want similar to",
          "required": false
        },
        "limit": {
          "type": "integer",
          "description": "Number of recommendations to return, max 100",
          "default": 10
        },
        "fields": {
          "type": "string",
          "description": "Fields to include in results",
          "default": "title,abstract,year,citationCount"
        }
      },
      "output": {
        "type": "list<paper>",
        "fields": [
          "recommendedPapers[0].paperId",
          "recommendedPapers[0].title",
          "recommendedPapers[0].abstract",
          "recommendedPapers[0].citationCount"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}