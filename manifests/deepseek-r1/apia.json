{
  "apia": "1.0",
  "service": {
    "id": "deepseek-r1",
    "name": "DeepSeek R1 Reasoning API",
    "description_for_ai": "DeepSeek reasoning model — shows chain-of-thought thinking before final answer. Comparable to OpenAI o1/o3 in math, coding, and complex reasoning tasks. 10-50x cheaper than OpenAI o3. Best open reasoning model available.",
    "url": "https://platform.deepseek.com",
    "api_base": "https://api.deepseek.com/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.deepseek.com/docs"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "https://platform.deepseek.com — $5 free credit",
    "cost": "$0.55/$2.19 per 1M tokens (I/O). Cache hits: 10x cheaper"
  },
  "capabilities": [
    {
      "id": "reasoning",
      "description_for_ai": "Use DeepSeek-R1 for complex reasoning with visible chain-of-thought. Math, science, logic.",
      "intent": [
        "DeepSeek R1",
        "chain of thought",
        "reasoning AI",
        "рассуждение DeepSeek R1"
      ],
      "endpoint": "POST https://api.deepseek.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "deepseek-reasoner"
        },
        "messages": {
          "type": "array",
          "required": true
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.reasoning_content",
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "math_solver",
      "description_for_ai": "Solve mathematical problems step by step with DeepSeek-R1.",
      "intent": [
        "solve math",
        "math problem AI",
        "equations solver",
        "решение задач математика"
      ],
      "endpoint": "POST https://api.deepseek.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "deepseek-reasoner"
        },
        "messages": {
          "type": "array",
          "description": "[{role: 'user', content: 'Solve: ...'}]",
          "required": true
        },
        "temperature": {
          "type": "float",
          "default": 0.0
        }
      },
      "output": {
        "type": "solution",
        "fields": [
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "code_reasoning",
      "description_for_ai": "Reason about complex code problems with DeepSeek-R1. Debugging, algorithm design.",
      "intent": [
        "debug code R1",
        "algorithm design",
        "code reasoning",
        "отладка кода R1"
      ],
      "endpoint": "POST https://api.deepseek.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "deepseek-reasoner"
        },
        "messages": {
          "type": "array",
          "required": true
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.reasoning_content",
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "structured_reasoning",
      "description_for_ai": "Get structured JSON output from DeepSeek-R1 reasoning model.",
      "intent": [
        "structured output R1",
        "JSON reasoning",
        "extract data R1",
        "структурированный вывод R1"
      ],
      "endpoint": "POST https://api.deepseek.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "deepseek-reasoner"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "response_format": {
          "type": "object",
          "description": "{type: 'json_object'}",
          "required": false
        }
      },
      "output": {
        "type": "json",
        "fields": [
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "distil_model",
      "description_for_ai": "Use distilled DeepSeek-R1 variants for faster, cheaper reasoning: R1-Distill-Qwen-7B etc.",
      "intent": [
        "fast reasoning",
        "distilled model",
        "cheap reasoning",
        "дистиллированная модель R1"
      ],
      "endpoint": "POST https://api.deepseek.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "description": "deepseek-r1-distill-qwen-7b (cheapest), deepseek-r1-distill-qwen-32b (best balance)",
          "required": true
        },
        "messages": {
          "type": "array",
          "required": true
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "reasoning_content": "reasoning_content contains the internal thinking process — show to users for transparency.",
    "vs_deepseek_chat": "Use deepseek-reasoner for hard problems (math, algorithms, logic). Use deepseek-chat (V3) for everyday tasks at 4x lower cost.",
    "pricing": "With cache hits: $0.055/$0.219 per 1M tokens — ultra cheap for cached prompts."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}