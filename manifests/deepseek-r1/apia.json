{
  "apia": "1.0",
  "service": {
    "id": "deepseek-r1",
    "name": "DeepSeek R1 Reasoning API",
    "description_for_ai": "DeepSeek reasoning model — shows chain-of-thought thinking before final answer. Comparable to OpenAI o1/o3 in math, coding, and complex reasoning tasks. 10-50x cheaper than OpenAI o3. Best open reasoning model available.",
    "url": "https://platform.deepseek.com",
    "api_base": "https://api.deepseek.com/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.deepseek.com/docs"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "https://platform.deepseek.com — $5 free credit",
    "cost": "$0.55/$2.19 per 1M tokens (I/O). Cache hits: 10x cheaper"
  },
  "capabilities": [
    {
      "id": "reason",
      "description_for_ai": "Chain-of-thought reasoning. Returns reasoning_content (thinking) + content (answer). Best for math, logic, algorithm design.",
      "intent": [
        "deepseek reasoning",
        "R1 model",
        "chain of thought",
        "hard math problem",
        "логические задачи deepseek"
      ],
      "endpoint": "POST https://api.deepseek.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "deepseek-reasoner"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "max_tokens": {
          "type": "integer",
          "required": false
        },
        "stream": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.reasoning_content",
          "choices[0].message.content",
          "usage.reasoning_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "reason_with_context",
      "description_for_ai": "Multi-turn reasoning conversation. Pass previous reasoning steps in conversation history for complex multi-step problems.",
      "intent": [
        "multi-step reasoning",
        "complex analysis AI",
        "iterative thinking",
        "сложный анализ deepseek"
      ],
      "endpoint": "POST https://api.deepseek.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "deepseek-reasoner"
        },
        "messages": {
          "type": "array",
          "description": "Full conversation including prior assistant reasoning. Do not inject reasoning_content into context — only use content.",
          "required": true
        },
        "max_tokens": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.reasoning_content",
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "code_generation",
      "description_for_ai": "Generate and debug code with reasoning. R1 explains its approach before writing code.",
      "intent": [
        "code with reasoning",
        "algorithm implementation",
        "debug with reasoning",
        "код с объяснением deepseek"
      ],
      "endpoint": "POST https://api.deepseek.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "deepseek-reasoner"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "max_tokens": {
          "type": "integer",
          "default": 8192
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.reasoning_content",
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "math_solver",
      "description_for_ai": "Solve mathematical problems step by step. Competition math, calculus, statistics, proofs.",
      "intent": [
        "solve math",
        "math problem",
        "calculus",
        "statistics",
        "proof",
        "решить задачу математика"
      ],
      "endpoint": "POST https://api.deepseek.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "deepseek-reasoner"
        },
        "messages": {
          "type": "array",
          "description": "[{role: user, content: 'Solve: integral of x^2 from 0 to 3'}]",
          "required": true
        },
        "temperature": {
          "type": "float",
          "description": "Use 0 for math for deterministic answers",
          "default": 0
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.reasoning_content",
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "reasoning_content": "reasoning_content contains the internal thinking process — show to users for transparency.",
    "vs_deepseek_chat": "Use deepseek-reasoner for hard problems (math, algorithms, logic). Use deepseek-chat (V3) for everyday tasks at 4x lower cost.",
    "pricing": "With cache hits: $0.055/$0.219 per 1M tokens — ultra cheap for cached prompts."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}