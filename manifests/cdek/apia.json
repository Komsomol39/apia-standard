{
  "apia": "1.0",
  "service": {
    "id": "cdek",
    "name": "СДЭК API",
    "description_for_ai": "Крупнейшая курьерская служба России и СНГ. Доставка в 2000+ городов России, Казахстана, Беларуси. Расчёт стоимости, создание заказов, отслеживание посылок. Обязательна для российских интернет-магазинов.",
    "url": "https://sdek.ru",
    "api_base": "https://api.cdek.ru/v2",
    "category": "logistics",
    "geo": [
      "RU",
      "BY",
      "KZ",
      "KG",
      "UZ"
    ],
    "language": "ru",
    "docs": "https://api-docs.cdek.ru/"
  },
  "auth": {
    "type": "oauth2_client_credentials",
    "anonymous_access": false,
    "token_url": "https://api.cdek.ru/v2/oauth/token",
    "how_to_get": "Личный кабинет СДЭК → Настройки → Интеграция",
    "cost": "По тарифам СДЭК"
  },
  "capabilities": [
    {
      "id": "calculate_tariff",
      "description_for_ai": "Рассчитать стоимость и срок доставки СДЭК между двумя городами для заданных параметров посылки.",
      "intent": [
        "расчёт СДЭК",
        "стоимость доставки СДЭК",
        "сдэк тариф",
        "cdek calculate",
        "сколько стоит cdek"
      ],
      "endpoint": "POST https://api.cdek.ru/v2/calculator/tariff",
      "input": {
        "from_location": {
          "type": "object",
          "description": "{code: 44, city: 'Москва'} — код города СДЭК",
          "required": true
        },
        "to_location": {
          "type": "object",
          "description": "{code: 137, city: 'Санкт-Петербург'}",
          "required": true
        },
        "packages": {
          "type": "array",
          "description": "[{height: 10, length: 20, weight: 500, width: 15}] — размеры в см, вес в г",
          "required": true
        },
        "tariff_code": {
          "type": "integer",
          "description": "136=Посылка склад-склад, 137=дверь, 139=дверь-дверь",
          "required": false
        }
      },
      "output": {
        "type": "tariff",
        "fields": [
          "total_sum",
          "delivery_sum",
          "period_min",
          "period_max",
          "currency_code",
          "tariff_code",
          "tariff_name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_order",
      "description_for_ai": "Создать заказ на доставку в СДЭК. Возвращает трек-номер для отслеживания.",
      "intent": [
        "создать заказ СДЭК",
        "отправить СДЭК",
        "cdek order",
        "сдэк отправление"
      ],
      "endpoint": "POST https://api.cdek.ru/v2/orders",
      "input": {
        "tariff_code": {
          "type": "integer",
          "required": true
        },
        "from_location": {
          "type": "object",
          "description": "{address: 'Москва, Тверская 1'}",
          "required": true
        },
        "to_location": {
          "type": "object",
          "description": "{address: 'СПб, Невский 1'}",
          "required": true
        },
        "recipient": {
          "type": "object",
          "description": "{name: 'Иван Иванов', phones: [{number: '+79001234567'}]}",
          "required": true
        },
        "packages": {
          "type": "array",
          "description": "[{number: '1', weight: 1000, height: 10, length: 20, width: 15, items: [{name: 'Товар', cost: 1000, amount: 1, weight: 1000}]}]",
          "required": true
        }
      },
      "output": {
        "type": "order",
        "fields": [
          "entity.uuid",
          "requests[0].state",
          "errors"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "track_order",
      "description_for_ai": "Отследить статус заказа СДЭК по UUID или трек-номеру.",
      "intent": [
        "отследить СДЭК",
        "трекинг СДЭК",
        "cdek track",
        "статус посылки СДЭК"
      ],
      "endpoint": "GET https://api.cdek.ru/v2/orders/{uuid}",
      "input": {
        "uuid": {
          "type": "string",
          "description": "UUID заказа из create_order",
          "required": false
        },
        "cdek_number": {
          "type": "string",
          "description": "Трек-номер СДЭК",
          "required": false
        },
        "im_number": {
          "type": "string",
          "description": "Ваш номер заказа",
          "required": false
        }
      },
      "output": {
        "type": "order",
        "fields": [
          "entity.status.code",
          "entity.status.name",
          "entity.cdek_number",
          "entity.statuses[-1].name",
          "entity.delivery_detail.delivery_sum"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_offices",
      "description_for_ai": "Получить список офисов (ПВЗ) СДЭК в городе с адресами и режимом работы.",
      "intent": [
        "офисы СДЭК",
        "ПВЗ СДЭК",
        "пункты выдачи СДЭК",
        "cdek offices",
        "cdek pickup"
      ],
      "endpoint": "GET https://api.cdek.ru/v2/deliverypoints",
      "input": {
        "city_code": {
          "type": "integer",
          "description": "Код города СДЭК (получить через /location/cities)",
          "required": false
        },
        "country_code": {
          "type": "string",
          "description": "RU, KZ, BY, KG, UZ",
          "required": false
        },
        "type": {
          "type": "string",
          "description": "ALL, PVZ (пункт выдачи), POSTAMAT (постамат)",
          "default": "ALL"
        }
      },
      "output": {
        "type": "list<office>",
        "fields": [
          "[0].code",
          "[0].name",
          "[0].location.address",
          "[0].work_time",
          "[0].phones[0].number",
          "[0].type"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "calculate_tariff",
      "description_for_ai": "Calculate СДЭК delivery cost between cities with package parameters.",
      "intent": [
        "тариф СДЭК",
        "стоимость доставки СДЭК",
        "расчёт СДЭК"
      ],
      "endpoint": "POST https://api.cdek.ru/v2/calculator/tariff",
      "input": {
        "tariff_code": {
          "type": "integer",
          "description": "136=до двери, 137=до склада, 368=посылка стандарт",
          "required": true
        },
        "from_location": {
          "type": "object",
          "description": "{postal_code: '101000'} or {city: 'Москва'}",
          "required": true
        },
        "to_location": {
          "type": "object",
          "required": true
        },
        "packages": {
          "type": "array",
          "description": "[{weight: 1000, height: 10, width: 10, length: 10}] weight in grams",
          "required": true
        }
      },
      "output": {
        "type": "tariff",
        "fields": [
          "total_sum",
          "period_min",
          "period_max",
          "currency"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "oauth": "Get token: POST https://api.cdek.ru/v2/oauth/token with grant_type=client_credentials + client_id + client_secret",
    "test": "Test environment: api.edu.cdek.ru/v2. Test credentials: clientId=EMscd6r9JnFiQ3bLoyjJY6eM78JV9wbo, clientSecret=PjLZkKBHEiLK3Qdv3cjmczNkCa2F8VU0",
    "tariff_codes": "Common tariffs: 136=Посылка склад-склад, 137=Посылка склад-дверь, 138=Посылка дверь-склад, 139=Посылка дверь-дверь",
    "cities": "Get city codes from GET /location/cities?country_codes=RU&city=Москва. Use code field in from_location/to_location."
  }
}