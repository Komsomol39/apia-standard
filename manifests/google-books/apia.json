{
  "apia": "1.0",
  "service": {
    "id": "google-books",
    "name": "Google Books API",
    "description_for_ai": "Search 40M+ books. Get book metadata: title, author, publisher, description, cover image, ISBN, page count, categories. Preview links. No API key needed for basic search.",
    "url": "https://books.google.com",
    "api_base": "https://www.googleapis.com/books/v1",
    "category": "education_books",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.google.com/books/docs/v1/using"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_limits": "1000 req/day",
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Enable Books API at https://console.cloud.google.com",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "search_books",
      "description_for_ai": "Search 40M+ books by title, author, ISBN, or keyword. Returns metadata with cover thumbnails and preview links.",
      "intent": [
        "find book",
        "book info",
        "author books",
        "ISBN lookup",
        "book search",
        "книга информация",
        "найти книгу"
      ],
      "endpoint": "GET https://www.googleapis.com/books/v1/volumes",
      "input": {
        "q": {
          "type": "string",
          "description": "Search query. Qualifiers: intitle:'Harry Potter', inauthor:'Tolkien', inpublisher:'O Reilly', isbn:9780141439518, subject:fiction",
          "required": true
        },
        "maxResults": {
          "type": "integer",
          "description": "Results per page, max 40",
          "default": 10
        },
        "startIndex": {
          "type": "integer",
          "description": "Pagination offset (0-indexed)",
          "default": 0
        },
        "langRestrict": {
          "type": "string",
          "description": "Restrict to language: en, ru, de, fr, es, zh, ja, ko",
          "required": false
        },
        "printType": {
          "type": "string",
          "description": "books (books only), magazines (magazines only), or all",
          "default": "books"
        },
        "orderBy": {
          "type": "string",
          "description": "relevance (default) or newest",
          "default": "relevance"
        },
        "filter": {
          "type": "string",
          "description": "ebooks (eBooks), free-ebooks (free), partial (preview), full (full view), paid-ebooks (paid)",
          "required": false
        }
      },
      "output": {
        "type": "list<book>",
        "fields": [
          "items[0].id",
          "items[0].volumeInfo.title",
          "items[0].volumeInfo.authors",
          "items[0].volumeInfo.publishedDate",
          "items[0].volumeInfo.description",
          "items[0].volumeInfo.imageLinks.thumbnail",
          "items[0].volumeInfo.previewLink",
          "items[0].volumeInfo.pageCount",
          "totalItems"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_book",
      "description_for_ai": "Get complete details for a specific book by its Google Books Volume ID.",
      "intent": [
        "book details",
        "get book by ID",
        "full book info",
        "book metadata",
        "read book preview"
      ],
      "endpoint": "GET https://www.googleapis.com/books/v1/volumes/{volumeId}",
      "input": {
        "volumeId": {
          "type": "string",
          "description": "Google Books volume ID from search results (e.g. 'zyTCAlFPjgYC')",
          "required": true
        },
        "projection": {
          "type": "string",
          "description": "lite for abbreviated info, or omit for full details",
          "required": false
        }
      },
      "output": {
        "type": "book",
        "fields": [
          "volumeInfo.title",
          "volumeInfo.authors",
          "volumeInfo.description",
          "volumeInfo.imageLinks.thumbnail",
          "volumeInfo.previewLink",
          "volumeInfo.categories",
          "volumeInfo.averageRating",
          "accessInfo.epub.isAvailable"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}