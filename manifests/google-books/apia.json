{
  "apia": "1.0",
  "service": {
    "id": "google-books",
    "name": "Google Books API",
    "description_for_ai": "Search 40M+ books. Get book metadata: title, author, publisher, description, cover image, ISBN, page count, categories. Preview links. No API key needed for basic search.",
    "url": "https://books.google.com",
    "api_base": "https://www.googleapis.com/books/v1",
    "category": "education_books",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.google.com/books/docs/v1/using"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_limits": "1000 req/day",
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Enable Books API at https://console.cloud.google.com",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "search_books",
      "description_for_ai": "Search books by title, author, ISBN, or topic. Returns book metadata, cover image, and preview link.",
      "intent": [
        "find book",
        "book info",
        "author books",
        "ISBN lookup",
        "book search",
        "книга информация",
        "найти книгу"
      ],
      "endpoint": "GET https://www.googleapis.com/books/v1/volumes",
      "input": {
        "q": {
          "type": "string",
          "description": "Search query. Use intitle:, inauthor:, isbn: prefixes for targeted search",
          "required": true
        },
        "maxResults": {
          "type": "integer",
          "default": 10,
          "max": 40
        },
        "langRestrict": {
          "type": "string",
          "description": "Language filter e.g. en, ru, de",
          "required": false
        },
        "printType": {
          "type": "string",
          "description": "books or magazines",
          "default": "books"
        }
      },
      "output": {
        "type": "list<book>",
        "fields": [
          "items[0].volumeInfo.title",
          "items[0].volumeInfo.authors",
          "items[0].volumeInfo.description",
          "items[0].volumeInfo.publishedDate",
          "items[0].volumeInfo.imageLinks.thumbnail",
          "items[0].volumeInfo.pageCount",
          "items[0].volumeInfo.categories"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_book",
      "description_for_ai": "Get full details of a specific book by Google Books volume ID.",
      "intent": [
        "book details",
        "full book info"
      ],
      "endpoint": "GET https://www.googleapis.com/books/v1/volumes/{volumeId}",
      "input": {
        "volumeId": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "book",
        "fields": [
          "volumeInfo.title",
          "volumeInfo.authors",
          "volumeInfo.description",
          "volumeInfo.imageLinks",
          "volumeInfo.previewLink"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}