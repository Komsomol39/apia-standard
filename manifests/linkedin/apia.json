{
  "apia": "1.0",
  "service": {
    "id": "linkedin",
    "name": "LinkedIn API",
    "description_for_ai": "Professional network API. 1B+ professionals. Access user profiles, company pages, job postings, share content. Use for professional profile lookup, job search integration, company info, B2B use cases.",
    "url": "https://linkedin.com",
    "api_base": "https://api.linkedin.com/v2",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://learn.microsoft.com/en-us/linkedin/"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Create app at https://www.linkedin.com/developers/ — requires company page",
    "oauth_url": "https://www.linkedin.com/oauth/v2/authorization",
    "token_url": "https://www.linkedin.com/oauth/v2/accessToken",
    "cost": "Free basic access. Some endpoints require LinkedIn partnership."
  },
  "capabilities": [
    {
      "id": "share_post",
      "description_for_ai": "Publish a post to LinkedIn on behalf of a user or organization page.",
      "intent": [
        "post to linkedin",
        "linkedin publish",
        "share on linkedin",
        "опубликовать linkedin"
      ],
      "endpoint": "POST https://api.linkedin.com/v2/ugcPosts",
      "input": {
        "author": {
          "type": "string",
          "description": "urn:li:person:{person_id} or urn:li:organization:{org_id}",
          "required": true
        },
        "text": {
          "type": "string",
          "description": "Post text content",
          "required": true
        },
        "visibility": {
          "type": "string",
          "description": "PUBLIC or CONNECTIONS",
          "default": "PUBLIC"
        },
        "article_url": {
          "type": "string",
          "description": "URL to share as article with preview",
          "required": false
        },
        "article_title": {
          "type": "string",
          "description": "Title for shared article",
          "required": false
        }
      },
      "output": {
        "type": "post",
        "fields": [
          "id",
          "ugcPost.id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_profile",
      "description_for_ai": "Get LinkedIn user profile: name, headline, current positions, education, location.",
      "intent": [
        "linkedin profile",
        "user profile linkedin",
        "professional info",
        "профиль linkedin"
      ],
      "endpoint": "GET https://api.linkedin.com/v2/people/(id:{personId})",
      "input": {
        "personId": {
          "type": "string",
          "description": "LinkedIn person ID (or ~me for current user)",
          "required": true
        },
        "projection": {
          "type": "string",
          "description": "(id,firstName,lastName,headline,profilePicture,positions,educations,location)",
          "required": false
        }
      },
      "output": {
        "type": "profile",
        "fields": [
          "firstName.localized",
          "lastName.localized",
          "headline.localized",
          "profilePicture.displayImage"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_company",
      "description_for_ai": "Get LinkedIn company/organization profile: description, employee count, website, industry, locations.",
      "intent": [
        "company linkedin",
        "organization profile linkedin",
        "company info linkedin",
        "компания linkedin"
      ],
      "endpoint": "GET https://api.linkedin.com/v2/organizations/{organizationId}",
      "input": {
        "organizationId": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "Requested fields projection",
          "required": false
        }
      },
      "output": {
        "type": "company",
        "fields": [
          "name.localized",
          "description.localized",
          "staffCount",
          "websiteUrl",
          "specialties",
          "foundedOn.year"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_analytics",
      "description_for_ai": "Get analytics for LinkedIn company page posts: impressions, clicks, engagement, followers gained.",
      "intent": [
        "linkedin analytics",
        "company page analytics",
        "post performance linkedin",
        "аналитика linkedin"
      ],
      "endpoint": "GET https://api.linkedin.com/v2/organizationalEntityShareStatistics",
      "input": {
        "organizationalEntity": {
          "type": "string",
          "description": "urn:li:organization:{org_id}",
          "required": true
        },
        "timeIntervals.timeGranularityType": {
          "type": "string",
          "description": "DAY, MONTH",
          "required": true
        },
        "timeIntervals.timeRange.start": {
          "type": "integer",
          "description": "Unix timestamp ms",
          "required": true
        },
        "timeIntervals.timeRange.end": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "analytics",
        "fields": [
          "elements[0].totalShareStatistics.impressionCount",
          "elements[0].totalShareStatistics.clickCount",
          "elements[0].totalShareStatistics.likeCount",
          "elements[0].totalShareStatistics.shareCount"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "restricted": "LinkedIn API is significantly more restricted than other social APIs. Many endpoints require LinkedIn partnership approval.",
    "oauth_scope": "Common scopes: openid profile email (for login), w_member_social (for posting), r_liteprofile (for profile reading).",
    "urn_format": "LinkedIn uses URN identifiers: urn:li:person:abc123 for users, urn:li:organization:123456 for companies.",
    "best_use": "LinkedIn API is best for: OAuth social login, sharing company updates, basic profile info. Job search API requires partnership."
  },
  "limits": {
    "daily_member_data_requests": 500,
    "commercial_use": true,
    "attribution_required": false
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}