{
  "apia": "1.0",
  "service": {
    "id": "linkedin",
    "name": "LinkedIn API",
    "description_for_ai": "Professional network API. 1B+ professionals. Access user profiles, company pages, job postings, share content. Use for professional profile lookup, job search integration, company info, B2B use cases.",
    "url": "https://linkedin.com",
    "api_base": "https://api.linkedin.com/v2",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://learn.microsoft.com/en-us/linkedin/"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Create app at https://www.linkedin.com/developers/ — requires company page",
    "oauth_url": "https://www.linkedin.com/oauth/v2/authorization",
    "token_url": "https://www.linkedin.com/oauth/v2/accessToken",
    "cost": "Free basic access. Some endpoints require LinkedIn partnership."
  },
  "capabilities": [
    {
      "id": "get_profile",
      "description_for_ai": "Get authenticated user's LinkedIn profile: name, headline, location, summary.",
      "intent": [
        "linkedin profile",
        "my linkedin",
        "linkedin user",
        "профиль linkedin"
      ],
      "endpoint": "GET https://api.linkedin.com/v2/userinfo",
      "input": {},
      "output": {
        "type": "profile",
        "fields": [
          "sub",
          "name",
          "given_name",
          "family_name",
          "email",
          "picture",
          "locale"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_post",
      "description_for_ai": "Publish a text post or article to LinkedIn as a person or organization.",
      "intent": [
        "post linkedin",
        "share linkedin",
        "linkedin update",
        "опубликовать linkedin"
      ],
      "endpoint": "POST https://api.linkedin.com/v2/ugcPosts",
      "input": {
        "author": {
          "type": "string",
          "description": "urn:li:person:{personId} or urn:li:organization:{orgId}",
          "required": true
        },
        "commentary": {
          "type": "string",
          "description": "Post text, max 3000 chars",
          "required": true
        },
        "visibility": {
          "type": "string",
          "description": "PUBLIC or CONNECTIONS",
          "default": "PUBLIC"
        },
        "media_category": {
          "type": "string",
          "description": "NONE, ARTICLE, IMAGE, VIDEO",
          "default": "NONE"
        }
      },
      "output": {
        "type": "post",
        "fields": [
          "id",
          "created.time"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_people",
      "description_for_ai": "Search LinkedIn for people by keywords, company, title (requires Marketing API access).",
      "intent": [
        "linkedin search",
        "find person linkedin",
        "company employees",
        "поиск linkedin"
      ],
      "endpoint": "GET https://api.linkedin.com/v2/search",
      "input": {
        "q": {
          "type": "string",
          "default": "people"
        },
        "keywords": {
          "type": "string",
          "required": false
        },
        "facetCurrentCompany": {
          "type": "string",
          "description": "Company URN",
          "required": false
        },
        "count": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<person>",
        "fields": [
          "elements[0].id",
          "elements[0].firstName",
          "elements[0].lastName"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_message",
      "description_for_ai": "Send a direct message to a LinkedIn connection.",
      "intent": [
        "linkedin message",
        "DM linkedin",
        "message connection",
        "сообщение linkedin"
      ],
      "endpoint": "POST https://api.linkedin.com/v2/messages",
      "input": {
        "recipients": {
          "type": "array",
          "description": "[{person: {urn: 'urn:li:person:id'}}]",
          "required": true
        },
        "subject": {
          "type": "string",
          "required": false
        },
        "body": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "id",
          "createdAt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "restricted": "LinkedIn API is significantly more restricted than other social APIs. Many endpoints require LinkedIn partnership approval.",
    "oauth_scope": "Common scopes: openid profile email (for login), w_member_social (for posting), r_liteprofile (for profile reading).",
    "urn_format": "LinkedIn uses URN identifiers: urn:li:person:abc123 for users, urn:li:organization:123456 for companies.",
    "best_use": "LinkedIn API is best for: OAuth social login, sharing company updates, basic profile info. Job search API requires partnership."
  },
  "limits": {
    "daily_member_data_requests": 500,
    "commercial_use": true,
    "attribution_required": false
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}