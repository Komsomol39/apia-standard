{
  "apia": "1.0",
  "service": {
    "id": "linkedin",
    "name": "LinkedIn API",
    "description_for_ai": "Professional network API. 1B+ professionals. Access user profiles, company pages, job postings, share content. Use for professional profile lookup, job search integration, company info, B2B use cases.",
    "url": "https://linkedin.com",
    "api_base": "https://api.linkedin.com/v2",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://learn.microsoft.com/en-us/linkedin/"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Create app at https://www.linkedin.com/developers/ — requires company page",
    "oauth_url": "https://www.linkedin.com/oauth/v2/authorization",
    "token_url": "https://www.linkedin.com/oauth/v2/accessToken",
    "cost": "Free basic access. Some endpoints require LinkedIn partnership."
  },
  "capabilities": [
    {
      "id": "get_profile",
      "description_for_ai": "Get LinkedIn user profile: name, headline, industry, location, education, experience.",
      "intent": [
        "LinkedIn profile",
        "user info LinkedIn",
        "professional profile",
        "профиль LinkedIn"
      ],
      "endpoint": "GET https://api.linkedin.com/v2/userinfo",
      "input": {},
      "output": {
        "type": "profile",
        "fields": [
          "sub",
          "name",
          "given_name",
          "family_name",
          "email",
          "picture",
          "locale"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_post",
      "description_for_ai": "Publish a post on LinkedIn (text, article, or with image).",
      "intent": [
        "post on LinkedIn",
        "LinkedIn share",
        "publish LinkedIn",
        "опубликовать LinkedIn"
      ],
      "endpoint": "POST https://api.linkedin.com/v2/ugcPosts",
      "input": {
        "author": {
          "type": "string",
          "description": "urn:li:person:{id} or urn:li:organization:{id}",
          "required": true
        },
        "text": {
          "type": "string",
          "description": "Post content",
          "required": true
        },
        "visibility": {
          "type": "string",
          "description": "PUBLIC or CONNECTIONS",
          "default": "PUBLIC"
        },
        "media": {
          "type": "object",
          "description": "{status: 'READY', originalUrl: 'https://...', title: 'Article Title'} for link posts",
          "required": false
        }
      },
      "output": {
        "type": "post",
        "fields": [
          "id",
          "created.time",
          "lifecycleState"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_companies",
      "description_for_ai": "Search LinkedIn companies by name, industry, location.",
      "intent": [
        "search companies LinkedIn",
        "find company LinkedIn",
        "LinkedIn company",
        "поиск компаний LinkedIn"
      ],
      "endpoint": "GET https://api.linkedin.com/v2/organizationalEntitySearch",
      "input": {
        "q": {
          "type": "string",
          "description": "Search query type: search",
          "required": true
        },
        "keywords": {
          "type": "string",
          "description": "Company name keywords",
          "required": false
        }
      },
      "output": {
        "type": "list<company>",
        "fields": [
          "elements[0].id",
          "elements[0].localizedName",
          "elements[0].industries"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_message",
      "description_for_ai": "Send a LinkedIn message via LinkedIn Messaging API.",
      "intent": [
        "LinkedIn message",
        "InMail",
        "send message LinkedIn",
        "сообщение LinkedIn"
      ],
      "endpoint": "POST https://api.linkedin.com/v2/messages",
      "input": {
        "recipients": {
          "type": "array",
          "description": "[{person: {urn: 'urn:li:person:id'}}]",
          "required": true
        },
        "subject": {
          "type": "string",
          "required": false
        },
        "body": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "id",
          "createdAt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_company_updates",
      "description_for_ai": "Get recent posts and updates from a LinkedIn company page.",
      "intent": [
        "company posts LinkedIn",
        "brand content LinkedIn",
        "LinkedIn feed company",
        "обновления компании LinkedIn"
      ],
      "endpoint": "GET https://api.linkedin.com/v2/ugcPosts",
      "input": {
        "q": {
          "type": "string",
          "default": "authors"
        },
        "authors": {
          "type": "string",
          "description": "urn:li:organization:{id}",
          "required": true
        },
        "count": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<post>",
        "fields": [
          "elements[0].id",
          "elements[0].specificContent.com.linkedin.ugc.ShareContent.shareCommentary.text",
          "elements[0].created.time"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_post_analytics",
      "description_for_ai": "Get analytics for LinkedIn posts: impressions, clicks, engagement.",
      "intent": [
        "LinkedIn analytics",
        "post stats",
        "LinkedIn metrics",
        "аналитика поста LinkedIn"
      ],
      "endpoint": "GET https://api.linkedin.com/v2/socialActions/{ugcPostUrn}/statistics",
      "input": {
        "ugcPostUrn": {
          "type": "string",
          "description": "UGC post URN: urn:li:ugcPost:id",
          "required": true
        }
      },
      "output": {
        "type": "stats",
        "fields": [
          "likeCount",
          "commentCount",
          "shareCount",
          "clickCount",
          "impressionCount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "restricted": "LinkedIn API is significantly more restricted than other social APIs. Many endpoints require LinkedIn partnership approval.",
    "oauth_scope": "Common scopes: openid profile email (for login), w_member_social (for posting), r_liteprofile (for profile reading).",
    "urn_format": "LinkedIn uses URN identifiers: urn:li:person:abc123 for users, urn:li:organization:123456 for companies.",
    "best_use": "LinkedIn API is best for: OAuth social login, sharing company updates, basic profile info. Job search API requires partnership."
  },
  "limits": {
    "daily_member_data_requests": 500,
    "commercial_use": true,
    "attribution_required": false
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}