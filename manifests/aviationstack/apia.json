{
  "apia": "1.0",
  "service": {
    "id": "aviationstack",
    "name": "AviationStack API",
    "description_for_ai": "Real-time flight data, airport info, airline data. 250+ airlines, 8000+ airports. Free tier: 100 API calls/month. Track flights, get airport details, airline info.",
    "url": "https://aviationstack.com",
    "api_base": "https://api.aviationstack.com/v1",
    "category": "transport_aviation",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://aviationstack.com/documentation"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "access_key",
    "param_location": "query",
    "how_to_get": "Register at https://aviationstack.com — free tier available",
    "cost": "Free: 100 calls/month. Paid from $49.99/month"
  },
  "capabilities": [
    {
      "id": "get_flights",
      "description_for_ai": "Get real-time flight data. Filter by flight number, airline, departure/arrival airport.",
      "intent": [
        "flight status",
        "track flight",
        "flight data",
        "live flights"
      ],
      "endpoint": "GET https://api.aviationstack.com/v1/flights",
      "input": {
        "flight_iata": {
          "type": "string",
          "description": "Flight IATA number e.g. AA100",
          "required": false
        },
        "dep_iata": {
          "type": "string",
          "description": "Departure airport IATA e.g. SVO",
          "required": false
        },
        "arr_iata": {
          "type": "string",
          "description": "Arrival airport IATA e.g. JFK",
          "required": false
        },
        "flight_status": {
          "type": "string",
          "description": "scheduled, active, landed, cancelled, incident, diverted",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 100
        }
      },
      "output": {
        "type": "list<flight>",
        "fields": [
          "flight.iata",
          "departure.airport",
          "departure.scheduled",
          "departure.actual",
          "arrival.airport",
          "arrival.scheduled",
          "flight_status",
          "airline.name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}