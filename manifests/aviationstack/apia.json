{
  "apia": "1.0",
  "service": {
    "id": "aviationstack",
    "name": "AviationStack API",
    "description_for_ai": "Real-time flight data, airport info, airline data. 250+ airlines, 8000+ airports. Free tier: 100 API calls/month. Track flights, get airport details, airline info.",
    "url": "https://aviationstack.com",
    "api_base": "https://api.aviationstack.com/v1",
    "category": "transport",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://aviationstack.com/documentation"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "access_key",
    "param_location": "query",
    "how_to_get": "Register at https://aviationstack.com — free tier available",
    "cost": "Free: 100 calls/month. Paid from $49.99/month"
  },
  "capabilities": [
    {
      "id": "get_flights",
      "description_for_ai": "Get real-time flight data: status, delays, gate, aircraft.",
      "intent": [
        "flight status",
        "live flight",
        "track flight Aviationstack",
        "статус рейса"
      ],
      "endpoint": "GET https://api.aviationstack.com/v1/flights",
      "input": {
        "flight_iata": {
          "type": "string",
          "description": "IATA flight number: AA100, BA302",
          "required": false
        },
        "dep_iata": {
          "type": "string",
          "description": "Departure airport IATA: JFK, LHR",
          "required": false
        },
        "arr_iata": {
          "type": "string",
          "description": "Arrival airport IATA",
          "required": false
        },
        "flight_status": {
          "type": "string",
          "description": "scheduled, active, landed, cancelled, incident, diverted",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<flight>",
        "fields": [
          "data[0].flight.iata",
          "data[0].departure.airport",
          "data[0].departure.actual",
          "data[0].arrival.airport",
          "data[0].arrival.estimated",
          "data[0].flight_status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_airports",
      "description_for_ai": "Search airports by name, IATA code, or city.",
      "intent": [
        "airport info",
        "find airport",
        "airport IATA",
        "информация об аэропорте"
      ],
      "endpoint": "GET https://api.aviationstack.com/v1/airports",
      "input": {
        "search": {
          "type": "string",
          "description": "Airport name or IATA: JFK, London",
          "required": false
        },
        "iata_code": {
          "type": "string",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<airport>",
        "fields": [
          "data[0].airport_name",
          "data[0].iata_code",
          "data[0].icao_code",
          "data[0].city_iata_code",
          "data[0].country_name",
          "data[0].latitude",
          "data[0].longitude"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_airlines",
      "description_for_ai": "Get airline information: name, country, IATA/ICAO code.",
      "intent": [
        "airline info",
        "airline lookup",
        "find airline",
        "информация об авиакомпании"
      ],
      "endpoint": "GET https://api.aviationstack.com/v1/airlines",
      "input": {
        "search": {
          "type": "string",
          "description": "Airline name or code: Delta, AA",
          "required": false
        },
        "iata_code": {
          "type": "string",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<airline>",
        "fields": [
          "data[0].airline_name",
          "data[0].iata_code",
          "data[0].icao_code",
          "data[0].country_name",
          "data[0].fleet_size"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_flight_history",
      "description_for_ai": "Get historical flight data for analysis.",
      "intent": [
        "flight history",
        "past flights",
        "historical aviation",
        "история рейсов"
      ],
      "endpoint": "GET https://api.aviationstack.com/v1/flightsFuture",
      "input": {
        "flight_iata": {
          "type": "string",
          "required": false
        },
        "dep_iata": {
          "type": "string",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<flight>",
        "fields": [
          "data[0].flight.iata",
          "data[0].departure.airport",
          "data[0].arrival.airport",
          "data[0].departure.scheduled"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_routes",
      "description_for_ai": "Get flight routes between airports.",
      "intent": [
        "flight routes",
        "routes between airports",
        "direct flights",
        "маршруты рейсов"
      ],
      "endpoint": "GET https://api.aviationstack.com/v1/routes",
      "input": {
        "dep_iata": {
          "type": "string",
          "required": false
        },
        "arr_iata": {
          "type": "string",
          "required": false
        },
        "airline_iata": {
          "type": "string",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<route>",
        "fields": [
          "data[0].airline.name",
          "data[0].departure.airport",
          "data[0].arrival.airport",
          "data[0].aircraft.iata"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}