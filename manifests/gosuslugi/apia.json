{
  "apia": "1.0",
  "service": {
    "id": "gosuslugi",
    "name": "Госуслуги (ЕПГУ)",
    "description_for_ai": "Единый портал государственных услуг России. Потенциально даёт доступ к статусу заявлений, данным профиля гражданина, записи к врачу, штрафам ГИБДД. Доступ ТОЛЬКО для аккредитованных организаций через СМЭВ/ЕСИА — публичного open API нет.",
    "url": "https://gosuslugi.ru",
    "api_base": "https://esia-portal1.test.gosuslugi.ru/esia-rs/api",
    "category": "legal",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://partners.gosuslugi.ru/catalog/api_for_gu",
    "access_note": "⚠️ Закрытый API. Требует официальной аккредитации Минцифры и СМЭВ. Не подходит для публичных приложений."
  },
  "auth": {
    "type": "oauth2_esia",
    "anonymous_access": false,
    "note": "Используется ЕСИА (Единая система идентификации и аутентификации). Требует получения API-Key от Госуслуг для организаций и подписи запросов PKCS#7.",
    "how_to_get": "Подать заявку через partners.gosuslugi.ru — только для юридических лиц с СМЭВ-подключением",
    "cost": "Требует официального соглашения с Минцифры"
  },
  "capabilities": [
    {
      "id": "get_services",
      "description_for_ai": "Get list of available government services on Gosuslugi (EPGU).",
      "intent": [
        "госуслуги сервисы",
        "gosuslugi services",
        "государственные услуги api",
        "список госуслуг"
      ],
      "endpoint": "GET https://esia.gosuslugi.ru/api/public/v1/services",
      "input": {
        "category": {
          "type": "string",
          "description": "Service category ID",
          "required": false
        },
        "query": {
          "type": "string",
          "description": "Service name search",
          "required": false
        }
      },
      "output": {
        "type": "list<service>",
        "fields": [
          "services[0].id",
          "services[0].title",
          "services[0].shortDescription",
          "services[0].gosNumber"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "check_document",
      "description_for_ai": "Check authenticity of a Russian official document via Gosuslugi API.",
      "intent": [
        "проверить документ госуслуги",
        "gosuslugi document check",
        "verify document Russia",
        "подлинность документа"
      ],
      "endpoint": "POST https://api.gosuslugi.ru/api/public/v1/check_document",
      "input": {
        "documentType": {
          "type": "string",
          "description": "passport, snils, inn, driverLicense",
          "required": true
        },
        "documentNumber": {
          "type": "string",
          "required": true
        },
        "documentSeries": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "check",
        "fields": [
          "isValid (boolean)",
          "status",
          "message"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_mvd_fines",
      "description_for_ai": "Get traffic fines from GIBDD (traffic police) via Gosuslugi.",
      "intent": [
        "штрафы ГИБДД",
        "traffic fines Russia",
        "gosuslugi fines",
        "штрафы ПДД"
      ],
      "endpoint": "POST https://api.gosuslugi.ru/api/mvd/v1/get_fines",
      "input": {
        "sts": {
          "type": "string",
          "description": "Registration certificate number (СТС)",
          "required": true
        },
        "govRegSign": {
          "type": "string",
          "description": "License plate: A001AA77",
          "required": true
        }
      },
      "output": {
        "type": "list<fine>",
        "fields": [
          "fines[0].amount",
          "fines[0].date",
          "fines[0].article",
          "fines[0].description",
          "fines[0].paymentStatus"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_tax_debt",
      "description_for_ai": "Check tax debt for an individual using INN via Gosuslugi.",
      "intent": [
        "налоговая задолженность",
        "tax debt gosuslugi",
        "задолженность ФНС",
        "долг по налогам"
      ],
      "endpoint": "POST https://api.gosuslugi.ru/api/fns/v1/get_debt",
      "input": {
        "inn": {
          "type": "string",
          "description": "Individual INN (12 digits)",
          "required": true
        }
      },
      "output": {
        "type": "debt",
        "fields": [
          "totalDebt",
          "taxDebt",
          "penaltyDebt",
          "fineDebt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "book_appointment",
      "description_for_ai": "Book an appointment at a government office via Gosuslugi MFC.",
      "intent": [
        "записаться МФЦ",
        "booking gosuslugi",
        "госуслуги запись",
        "appointment MFC Russia"
      ],
      "endpoint": "POST https://api.gosuslugi.ru/api/public/v1/appointments",
      "input": {
        "serviceId": {
          "type": "string",
          "required": true
        },
        "officeId": {
          "type": "string",
          "required": true
        },
        "date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "time": {
          "type": "string",
          "description": "HH:MM",
          "required": true
        }
      },
      "output": {
        "type": "appointment",
        "fields": [
          "confirmationCode",
          "date",
          "time",
          "officeName",
          "address"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "contributor_notes": {
    "status": "Нужен контрибьютор с опытом СМЭВ/ЕСИА",
    "complexity": "Высокая — требует государственной аккредитации",
    "useful_links": [
      "https://partners.gosuslugi.ru/catalog/api_for_gu",
      "https://info.gosuslugi.ru/articles/",
      "https://github.com/nicholasgasior/gostok"
    ],
    "what_to_document": "Методы получения данных о штрафах, записи к врачу, статусов заявлений"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14",
    "completeness": "partial"
  }
}