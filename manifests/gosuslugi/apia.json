{
  "apia": "1.0",
  "service": {
    "id": "gosuslugi",
    "name": "Госуслуги (ЕПГУ)",
    "description_for_ai": "Единый портал государственных услуг России. Потенциально даёт доступ к статусу заявлений, данным профиля гражданина, записи к врачу, штрафам ГИБДД. Доступ ТОЛЬКО для аккредитованных организаций через СМЭВ/ЕСИА — публичного open API нет.",
    "url": "https://gosuslugi.ru",
    "api_base": "https://esia-portal1.test.gosuslugi.ru/esia-rs/api",
    "category": "legal",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://partners.gosuslugi.ru/catalog/api_for_gu",
    "access_note": "⚠️ Закрытый API. Требует официальной аккредитации Минцифры и СМЭВ. Не подходит для публичных приложений."
  },
  "auth": {
    "type": "oauth2_esia",
    "anonymous_access": false,
    "note": "Используется ЕСИА (Единая система идентификации и аутентификации). Требует получения API-Key от Госуслуг для организаций и подписи запросов PKCS#7.",
    "how_to_get": "Подать заявку через partners.gosuslugi.ru — только для юридических лиц с СМЭВ-подключением",
    "cost": "Требует официального соглашения с Минцифры"
  },
  "capabilities": [
    {
      "id": "get_services",
      "description_for_ai": "Get list of available government services on Gosuslugi (Russian e-government portal).",
      "intent": [
        "госуслуги сервисы",
        "государственные услуги",
        "госуслуги API",
        "gosuslugi services"
      ],
      "endpoint": "GET https://esia.gosuslugi.ru/api/public/v1/services",
      "input": {
        "page": {
          "type": "integer",
          "default": 1
        },
        "size": {
          "type": "integer",
          "default": 20
        },
        "search": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<service>",
        "fields": [
          "[0].id",
          "[0].title",
          "[0].shortDescription",
          "[0].department.title",
          "[0].url"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_service_details",
      "description_for_ai": "Get detailed information about a specific government service.",
      "intent": [
        "госуслуга подробно",
        "инструкция госуслуги",
        "как подать заявление",
        "service details gosuslugi"
      ],
      "endpoint": "GET https://esia.gosuslugi.ru/api/public/v1/services/{serviceId}",
      "input": {
        "serviceId": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "service",
        "fields": [
          "id",
          "title",
          "description",
          "documents",
          "processingTime",
          "statePayment.amount",
          "url"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_departments",
      "description_for_ai": "Get list of government departments and their services.",
      "intent": [
        "ведомства госуслуги",
        "министерства API",
        "органы власти",
        "government departments"
      ],
      "endpoint": "GET https://esia.gosuslugi.ru/api/public/v1/departments",
      "input": {
        "page": {
          "type": "integer",
          "default": 1
        },
        "size": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<department>",
        "fields": [
          "[0].id",
          "[0].title",
          "[0].shortTitle",
          "[0].code",
          "[0].url"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "check_service_status",
      "description_for_ai": "Check the status of a submitted government service application.",
      "intent": [
        "статус заявления госуслуги",
        "проверить заявку",
        "результат заявления",
        "application status gosuslugi"
      ],
      "endpoint": "GET https://lk.gosuslugi.ru/api/orders/{orderId}",
      "input": {
        "orderId": {
          "type": "string",
          "description": "Application order ID",
          "required": true
        }
      },
      "output": {
        "type": "order",
        "fields": [
          "id",
          "status",
          "title",
          "createdDate",
          "lastModifiedDate",
          "statusTitle"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_life_situations",
      "description_for_ai": "Get government services grouped by life situations (birth, marriage, etc.).",
      "intent": [
        "жизненные ситуации госуслуги",
        "услуги при рождении",
        "услуги при браке",
        "life situations gosuslugi"
      ],
      "endpoint": "GET https://esia.gosuslugi.ru/api/public/v1/life-situations",
      "input": {},
      "output": {
        "type": "list<situation>",
        "fields": [
          "[0].id",
          "[0].title",
          "[0].services[0].id",
          "[0].services[0].title"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "contributor_notes": {
    "status": "Нужен контрибьютор с опытом СМЭВ/ЕСИА",
    "complexity": "Высокая — требует государственной аккредитации",
    "useful_links": [
      "https://partners.gosuslugi.ru/catalog/api_for_gu",
      "https://info.gosuslugi.ru/articles/",
      "https://github.com/nicholasgasior/gostok"
    ],
    "what_to_document": "Методы получения данных о штрафах, записи к врачу, статусов заявлений"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14",
    "completeness": "partial"
  }
}