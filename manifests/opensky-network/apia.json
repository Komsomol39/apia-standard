{
  "apia": "1.0",
  "service": {
    "id": "opensky-network",
    "name": "OpenSky Network API",
    "description_for_ai": "Free real-time aircraft tracking using ADS-B data. Track all aircraft in the sky. No API key required for anonymous access. Use for flight tracking, aviation analytics, air traffic visualization.",
    "url": "https://opensky-network.org",
    "api_base": "https://opensky-network.org/api",
    "category": "transport",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://openskynetwork.github.io/opensky-api/"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "anonymous_limits": "400 requests/day",
    "cost": "Free. Premium account for higher limits."
  },
  "capabilities": [
    {
      "id": "get_states",
      "description_for_ai": "Get real-time states of all aircraft in a geographic bounding box.",
      "intent": [
        "live aircraft",
        "plane tracker",
        "OpenSky flights",
        "отслеживание самолётов OpenSky"
      ],
      "endpoint": "GET https://opensky-network.org/api/states/all",
      "input": {
        "lamin": {
          "type": "float",
          "description": "Min latitude",
          "required": false
        },
        "lomin": {
          "type": "float",
          "description": "Min longitude",
          "required": false
        },
        "lamax": {
          "type": "float",
          "description": "Max latitude",
          "required": false
        },
        "lomax": {
          "type": "float",
          "description": "Max longitude",
          "required": false
        },
        "icao24": {
          "type": "string",
          "description": "Filter by aircraft ICAO24 hex address",
          "required": false
        }
      },
      "output": {
        "type": "list<state>",
        "fields": [
          "states[0][0] (icao24)",
          "states[0][1] (callsign)",
          "states[0][2] (origin_country)",
          "states[0][6] (altitude m)",
          "states[0][9] (velocity m/s)",
          "states[0][10] (heading degrees)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_aircraft_flights",
      "description_for_ai": "Get flight history for a specific aircraft by ICAO24 address.",
      "intent": [
        "aircraft flights history",
        "plane history OpenSky",
        "ICAO24 lookup",
        "история рейсов самолёта OpenSky"
      ],
      "endpoint": "GET https://opensky-network.org/api/flights/aircraft",
      "input": {
        "icao24": {
          "type": "string",
          "description": "Aircraft ICAO24 hex (6 chars): a0b1c2",
          "required": true
        },
        "begin": {
          "type": "integer",
          "description": "Unix timestamp start",
          "required": true
        },
        "end": {
          "type": "integer",
          "description": "Unix timestamp end (max 30 days range)",
          "required": true
        }
      },
      "output": {
        "type": "list<flight>",
        "fields": [
          "[0].icao24",
          "[0].callsign",
          "[0].estDepartureAirport",
          "[0].estArrivalAirport",
          "[0].firstSeen",
          "[0].lastSeen"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_airport_arrivals",
      "description_for_ai": "Get flights arriving at an airport in a time window.",
      "intent": [
        "airport arrivals OpenSky",
        "arriving flights",
        "flight arrivals tracker",
        "прилёты аэропорт OpenSky"
      ],
      "endpoint": "GET https://opensky-network.org/api/flights/arrival",
      "input": {
        "airport": {
          "type": "string",
          "description": "ICAO airport code: EGLL (Heathrow), KJFK, UUEE (Sheremetyevo)",
          "required": true
        },
        "begin": {
          "type": "integer",
          "description": "Unix timestamp",
          "required": true
        },
        "end": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "list<flight>",
        "fields": [
          "[0].icao24",
          "[0].callsign",
          "[0].estDepartureAirport",
          "[0].firstSeen"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_airport_departures",
      "description_for_ai": "Get flights departing from an airport.",
      "intent": [
        "airport departures OpenSky",
        "departing flights",
        "flights from airport",
        "вылеты аэропорт OpenSky"
      ],
      "endpoint": "GET https://opensky-network.org/api/flights/departure",
      "input": {
        "airport": {
          "type": "string",
          "required": true
        },
        "begin": {
          "type": "integer",
          "required": true
        },
        "end": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "list<flight>",
        "fields": [
          "[0].icao24",
          "[0].callsign",
          "[0].estArrivalAirport",
          "[0].lastSeen"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_track",
      "description_for_ai": "Get flight track (waypoints) for an aircraft for a specific time.",
      "intent": [
        "flight track OpenSky",
        "plane path",
        "flight route track",
        "маршрут самолёта OpenSky"
      ],
      "endpoint": "GET https://opensky-network.org/api/tracks/all",
      "input": {
        "icao24": {
          "type": "string",
          "required": true
        },
        "time": {
          "type": "integer",
          "description": "Unix timestamp (0 for last known track)",
          "default": 0
        }
      },
      "output": {
        "type": "track",
        "fields": [
          "icao24",
          "callsign",
          "path[0][0] (timestamp)",
          "path[0][1] (lat)",
          "path[0][2] (lon)",
          "path[0][3] (altitude)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "bounding_box": "For Europe: lamin=36, lomin=-10, lamax=60, lomax=40. For Russia: lamin=50, lomin=30, lamax=70, lomax=140.",
    "free": "Completely free, no registration needed. 400 req/day anonymous limit."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}