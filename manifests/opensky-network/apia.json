{
  "apia": "1.0",
  "service": {
    "id": "opensky-network",
    "name": "OpenSky Network API",
    "description_for_ai": "Free real-time aircraft tracking using ADS-B data. Track all aircraft in the sky. No API key required for anonymous access. Use for flight tracking, aviation analytics, air traffic visualization.",
    "url": "https://opensky-network.org",
    "api_base": "https://opensky-network.org/api",
    "category": "transport",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://openskynetwork.github.io/opensky-api/"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "anonymous_limits": "400 requests/day",
    "cost": "Free. Premium account for higher limits."
  },
  "capabilities": [
    {
      "id": "get_all_states",
      "description_for_ai": "Get real-time state of all aircraft tracked by OpenSky Network.",
      "intent": [
        "live flights OpenSky",
        "aircraft tracking",
        "real-time aviation",
        "слежение за самолётами OpenSky"
      ],
      "endpoint": "GET https://opensky-network.org/api/states/all",
      "input": {
        "lamin": {
          "type": "number",
          "description": "Bounding box min latitude",
          "required": false
        },
        "lomin": {
          "type": "number",
          "description": "Min longitude",
          "required": false
        },
        "lamax": {
          "type": "number",
          "description": "Max latitude",
          "required": false
        },
        "lomax": {
          "type": "number",
          "description": "Max longitude",
          "required": false
        },
        "icao24": {
          "type": "string",
          "description": "ICAO24 transponder address",
          "required": false
        }
      },
      "output": {
        "type": "aircraft_states",
        "fields": [
          "states[0][0] (icao24)",
          "states[0][1] (callsign)",
          "states[0][5] (longitude)",
          "states[0][6] (latitude)",
          "states[0][7] (baro_altitude m)",
          "states[0][9] (velocity m/s)",
          "states[0][11] (geo_altitude m)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_own_aircraft",
      "description_for_ai": "Get states for aircraft from your own receivers.",
      "intent": [
        "my aircraft OpenSky",
        "own receivers",
        "personal tracking",
        "мои самолёты OpenSky"
      ],
      "endpoint": "GET https://opensky-network.org/api/states/own",
      "input": {},
      "output": {
        "type": "aircraft_states",
        "fields": [
          "states[0][0] (icao24)",
          "states[0][1] (callsign)",
          "states[0][5] (longitude)",
          "states[0][6] (latitude)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_arrivals",
      "description_for_ai": "Get all arrivals at an airport in a time interval.",
      "intent": [
        "airport arrivals OpenSky",
        "flight arrivals",
        "landed flights",
        "прилёты в аэропорт OpenSky"
      ],
      "endpoint": "GET https://opensky-network.org/api/flights/arrival",
      "input": {
        "airport": {
          "type": "string",
          "description": "ICAO airport code: EDDF, KLAX, UUEE",
          "required": true
        },
        "begin": {
          "type": "integer",
          "description": "Unix timestamp start",
          "required": true
        },
        "end": {
          "type": "integer",
          "description": "Unix timestamp end (max 7 days span)",
          "required": true
        }
      },
      "output": {
        "type": "list<flight>",
        "fields": [
          "[0].icao24",
          "[0].callsign",
          "[0].estDepartureAirport",
          "[0].firstSeen",
          "[0].lastSeen",
          "[0].estArrivalAirportHorizDistance"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_departures",
      "description_for_ai": "Get all departures from an airport in a time interval.",
      "intent": [
        "airport departures OpenSky",
        "flight departures",
        "takeoffs",
        "вылеты из аэропорта OpenSky"
      ],
      "endpoint": "GET https://opensky-network.org/api/flights/departure",
      "input": {
        "airport": {
          "type": "string",
          "required": true
        },
        "begin": {
          "type": "integer",
          "required": true
        },
        "end": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "list<flight>",
        "fields": [
          "[0].icao24",
          "[0].callsign",
          "[0].estArrivalAirport",
          "[0].firstSeen",
          "[0].lastSeen"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_track",
      "description_for_ai": "Get the trajectory of an aircraft as a series of waypoints.",
      "intent": [
        "aircraft track OpenSky",
        "flight path",
        "trajectory",
        "траектория самолёта OpenSky"
      ],
      "endpoint": "GET https://opensky-network.org/api/tracks/all",
      "input": {
        "icao24": {
          "type": "string",
          "description": "ICAO24 transponder hex address",
          "required": true
        },
        "time": {
          "type": "integer",
          "description": "Unix timestamp (0 for current)",
          "default": 0
        }
      },
      "output": {
        "type": "track",
        "fields": [
          "icao24",
          "callsign",
          "startTime",
          "endTime",
          "path[0][0] (time)",
          "path[0][1] (lat)",
          "path[0][2] (lon)",
          "path[0][3] (altitude)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "bounding_box": "For Europe: lamin=36, lomin=-10, lamax=60, lomax=40. For Russia: lamin=50, lomin=30, lamax=70, lomax=140.",
    "free": "Completely free, no registration needed. 400 req/day anonymous limit."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}