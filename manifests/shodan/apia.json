{
  "apia": "1.0",
  "service": {
    "id": "shodan",
    "name": "Shodan API",
    "description_for_ai": "Search engine for internet-connected devices. Find exposed servers, cameras, databases, IoT devices by IP, port, service, or location. Used by security researchers and pentesters. Free: 1 search credit/month.",
    "url": "https://shodan.io",
    "api_base": "https://api.shodan.io",
    "category": "security",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.shodan.io/api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Register at https://account.shodan.io",
    "cost": "Free: 1 credit/month. Membership: $49 one-time for 100 credits"
  },
  "capabilities": [
    {
      "id": "search",
      "description_for_ai": "Search Shodan for internet-exposed devices by port, service, country, or vulnerability.",
      "intent": [
        "shodan search",
        "exposed devices",
        "internet scan",
        "IoT security",
        "поиск shodan"
      ],
      "endpoint": "GET https://api.shodan.io/shodan/host/search",
      "input": {
        "query": {
          "type": "string",
          "description": "Shodan query: port:22 country:RU, product:nginx vuln:CVE-2021-44228, org:'Google'",
          "required": true
        },
        "facets": {
          "type": "string",
          "description": "Comma-separated facets: country, port, org",
          "required": false
        },
        "page": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "results",
        "fields": [
          "matches[0].ip_str",
          "matches[0].port",
          "matches[0].org",
          "matches[0].country_code",
          "matches[0].product",
          "matches[0].version",
          "total"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_host",
      "description_for_ai": "Get all open ports and services for a specific IP address.",
      "intent": [
        "ip lookup shodan",
        "host info shodan",
        "open ports IP",
        "порты IP shodan"
      ],
      "endpoint": "GET https://api.shodan.io/shodan/host/{ip}",
      "input": {
        "ip": {
          "type": "string",
          "description": "IP address to look up",
          "required": true
        },
        "history": {
          "type": "boolean",
          "description": "Include historical data",
          "default": false
        }
      },
      "output": {
        "type": "host",
        "fields": [
          "ip_str",
          "ports",
          "org",
          "country_name",
          "data[0].port",
          "data[0].product",
          "data[0].version",
          "vulns"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_myip",
      "description_for_ai": "Get your own public IP address and info as seen from Shodan.",
      "intent": [
        "my IP address",
        "public IP",
        "what is my IP",
        "мой IP адрес shodan"
      ],
      "endpoint": "GET https://api.shodan.io/tools/myip",
      "input": {},
      "output": {
        "type": "ip",
        "fields": [
          "IP address string"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_facets",
      "description_for_ai": "Get aggregated stats for a search: top countries, ports, organizations, products.",
      "intent": [
        "shodan stats",
        "search facets",
        "internet stats",
        "статистика shodan"
      ],
      "endpoint": "GET https://api.shodan.io/shodan/host/count",
      "input": {
        "query": {
          "type": "string",
          "required": true
        },
        "facets": {
          "type": "string",
          "description": "country:10, port:10, org:10, product:10",
          "required": false
        }
      },
      "output": {
        "type": "facets",
        "fields": [
          "total",
          "facets.country[0].value",
          "facets.country[0].count",
          "facets.port[0].value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "legal": "Only use for authorized security research. Do not scan systems you do not own.",
    "credits": "Each search costs 1 credit. Host lookups are free. Free account gets 1 credit/month."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}