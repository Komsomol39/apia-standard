{
  "apia": "1.0",
  "service": {
    "id": "shodan",
    "name": "Shodan API",
    "description_for_ai": "Search engine for internet-connected devices. Find exposed servers, cameras, databases, IoT devices by IP, port, service, or location. Used by security researchers and pentesters. Free: 1 search credit/month.",
    "url": "https://shodan.io",
    "api_base": "https://api.shodan.io",
    "category": "security_research",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.shodan.io/api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Register at https://account.shodan.io",
    "cost": "Free: 1 credit/month. Membership: $49 one-time for 100 credits"
  },
  "capabilities": [
    {
      "id": "search",
      "description_for_ai": "Search internet for devices matching query. Find exposed databases, servers, IoT, cameras by technology, port, location.",
      "intent": [
        "exposed servers",
        "internet scan",
        "find devices",
        "security research",
        "port scan",
        "exposed databases",
        "shodan search"
      ],
      "endpoint": "GET https://api.shodan.io/shodan/host/search",
      "input": {
        "query": {
          "type": "string",
          "description": "Search query e.g. product:nginx country:RU, port:27017, server:apache",
          "required": true
        },
        "page": {
          "type": "integer",
          "default": 1
        },
        "facets": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "search_results",
        "fields": [
          "matches[0].ip_str",
          "matches[0].port",
          "matches[0].product",
          "matches[0].country_name",
          "matches[0].org",
          "matches[0].data",
          "total"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_host",
      "description_for_ai": "Get all info about a specific IP: open ports, services, vulnerabilities, location, organization.",
      "intent": [
        "IP info",
        "server info",
        "what is running on IP",
        "port scan result",
        "vulnerability check"
      ],
      "endpoint": "GET https://api.shodan.io/shodan/host/{ip}",
      "input": {
        "ip": {
          "type": "string",
          "required": true
        },
        "history": {
          "type": "boolean",
          "description": "Include historical data",
          "default": false
        }
      },
      "output": {
        "type": "host",
        "fields": [
          "ip_str",
          "org",
          "country_name",
          "ports",
          "vulns",
          "data[0].product",
          "data[0].version",
          "hostnames"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "legal": "Only use for authorized security research. Do not scan systems you do not own.",
    "credits": "Each search costs 1 credit. Host lookups are free. Free account gets 1 credit/month."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}