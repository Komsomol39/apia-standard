{
  "apia": "1.0",
  "service": {
    "id": "shodan",
    "name": "Shodan API",
    "description_for_ai": "Search engine for internet-connected devices. Find exposed servers, cameras, databases, IoT devices by IP, port, service, or location. Used by security researchers and pentesters. Free: 1 search credit/month.",
    "url": "https://shodan.io",
    "api_base": "https://api.shodan.io",
    "category": "security",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.shodan.io/api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Register at https://account.shodan.io",
    "cost": "Free: 1 credit/month. Membership: $49 one-time for 100 credits"
  },
  "capabilities": [
    {
      "id": "search_hosts",
      "description_for_ai": "Search internet-connected devices by service, software, location, or port.",
      "intent": [
        "Shodan search",
        "find devices internet",
        "exposed services",
        "поиск устройств Shodan"
      ],
      "endpoint": "GET https://api.shodan.io/shodan/host/search",
      "input": {
        "query": {
          "type": "string",
          "description": "Shodan dork: apache city:Moscow, port:22 country:US, has_vuln:CVE-2021-44228",
          "required": true
        },
        "facets": {
          "type": "string",
          "description": "Statistics facets: country,org,port",
          "required": false
        },
        "page": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<host>",
        "fields": [
          "matches[0].ip_str",
          "matches[0].port",
          "matches[0].org",
          "matches[0].country_name",
          "matches[0].product",
          "matches[0].data",
          "total"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_host_info",
      "description_for_ai": "Get full information about a specific IP address: open ports, services, CVEs.",
      "intent": [
        "IP info Shodan",
        "host scan results",
        "open ports",
        "информация об IP Shodan"
      ],
      "endpoint": "GET https://api.shodan.io/shodan/host/{ip}",
      "input": {
        "ip": {
          "type": "string",
          "description": "IPv4 address to look up",
          "required": true
        },
        "history": {
          "type": "boolean",
          "description": "Include historical scan results",
          "default": false
        }
      },
      "output": {
        "type": "host",
        "fields": [
          "ip_str",
          "org",
          "country_name",
          "os",
          "ports",
          "data[0].port",
          "data[0].product",
          "vulns (CVE IDs if any)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_count",
      "description_for_ai": "Count Shodan search results without using credits.",
      "intent": [
        "count Shodan",
        "how many devices",
        "exposed services count",
        "количество устройств Shodan"
      ],
      "endpoint": "GET https://api.shodan.io/shodan/host/count",
      "input": {
        "query": {
          "type": "string",
          "required": true
        },
        "facets": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "count",
        "fields": [
          "total",
          "facets"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_protocols",
      "description_for_ai": "Get list of protocols that Shodan crawls.",
      "intent": [
        "Shodan protocols",
        "available protocols",
        "what Shodan scans"
      ],
      "endpoint": "GET https://api.shodan.io/shodan/protocols",
      "input": {},
      "output": {
        "type": "protocols",
        "fields": [
          "protocol_name: description"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_my_ip",
      "description_for_ai": "Get your current external IP address from Shodan.",
      "intent": [
        "my IP address",
        "external IP",
        "current IP",
        "мой IP адрес"
      ],
      "endpoint": "GET https://api.shodan.io/tools/myip",
      "input": {},
      "output": {
        "type": "ip",
        "fields": [
          "IP address string"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "legal": "Only use for authorized security research. Do not scan systems you do not own.",
    "credits": "Each search costs 1 credit. Host lookups are free. Free account gets 1 credit/month."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}