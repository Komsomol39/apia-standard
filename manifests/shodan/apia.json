{
  "apia": "1.0",
  "service": {
    "id": "shodan",
    "name": "Shodan API",
    "description_for_ai": "Search engine for internet-connected devices. Find exposed servers, cameras, databases, IoT devices by IP, port, service, or location. Used by security researchers and pentesters. Free: 1 search credit/month.",
    "url": "https://shodan.io",
    "api_base": "https://api.shodan.io",
    "category": "security",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.shodan.io/api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Register at https://account.shodan.io",
    "cost": "Free: 1 credit/month. Membership: $49 one-time for 100 credits"
  },
  "capabilities": [
    {
      "id": "search_hosts",
      "description_for_ai": "Search Shodan for internet-connected devices, servers, and services.",
      "intent": [
        "Shodan search",
        "internet search",
        "scan devices",
        "поиск устройств Shodan"
      ],
      "endpoint": "GET https://api.shodan.io/shodan/host/search",
      "input": {
        "query": {
          "type": "string",
          "description": "Shodan query: 'port:22 country:US', 'product:Apache', 'org:Google', 'vuln:CVE-2021-44228'",
          "required": true
        },
        "facets": {
          "type": "string",
          "description": "Comma-separated facets for stats: country,org,port",
          "required": false
        },
        "page": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "results",
        "fields": [
          "matches[0].ip_str",
          "matches[0].ports",
          "matches[0].hostnames",
          "matches[0].org",
          "matches[0].country_name",
          "matches[0].data (banner)",
          "total"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_host_info",
      "description_for_ai": "Get all information about a specific IP address from Shodan.",
      "intent": [
        "IP lookup Shodan",
        "host info",
        "IP scan Shodan",
        "информация об IP Shodan"
      ],
      "endpoint": "GET https://api.shodan.io/shodan/host/{ip}",
      "input": {
        "ip": {
          "type": "string",
          "description": "IP address to look up",
          "required": true
        },
        "history": {
          "type": "boolean",
          "description": "Include historical banners",
          "default": false
        },
        "minify": {
          "type": "boolean",
          "description": "Return minimal host data",
          "default": false
        }
      },
      "output": {
        "type": "host",
        "fields": [
          "ip_str",
          "org",
          "country_name",
          "ports",
          "hostnames",
          "os",
          "data[0].transport",
          "data[0].port",
          "data[0].data (banner)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "dns_lookup",
      "description_for_ai": "Look up DNS records for a domain: A, AAAA, MX, etc.",
      "intent": [
        "DNS lookup Shodan",
        "domain DNS",
        "IP for domain",
        "DNS домена Shodan"
      ],
      "endpoint": "GET https://api.shodan.io/dns/resolve",
      "input": {
        "hostnames": {
          "type": "string",
          "description": "Comma-separated hostnames: google.com,github.com",
          "required": true
        }
      },
      "output": {
        "type": "dns",
        "fields": [
          "hostname → ip_address"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_vulnerabilities",
      "description_for_ai": "Get known vulnerabilities for a CVE or list of CVEs.",
      "intent": [
        "CVE lookup Shodan",
        "vulnerability info",
        "exploit info",
        "информация CVE Shodan"
      ],
      "endpoint": "GET https://cvedb.shodan.io/cve/{cve_id}",
      "input": {
        "cve_id": {
          "type": "string",
          "description": "CVE ID: CVE-2021-44228",
          "required": true
        }
      },
      "output": {
        "type": "cve",
        "fields": [
          "cve_id",
          "cvss",
          "summary",
          "references",
          "published_time"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_account_info",
      "description_for_ai": "Get your Shodan account info: plan, credits remaining, scan credits.",
      "intent": [
        "Shodan account",
        "API credits Shodan",
        "scan credits",
        "аккаунт Shodan"
      ],
      "endpoint": "GET https://api.shodan.io/account/profile",
      "input": {},
      "output": {
        "type": "account",
        "fields": [
          "member",
          "credits",
          "display_name",
          "created"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "legal": "Only use for authorized security research. Do not scan systems you do not own.",
    "credits": "Each search costs 1 credit. Host lookups are free. Free account gets 1 credit/month."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}