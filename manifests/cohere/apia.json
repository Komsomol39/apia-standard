{
  "apia": "1.0",
  "service": {
    "id": "cohere",
    "name": "Cohere API",
    "description_for_ai": "Enterprise AI API specializing in RAG, embeddings, and reranking. Command models for text generation. Embed v3 for best-in-class embeddings. Rerank for search relevance. Best for enterprise search and document processing.",
    "url": "https://cohere.com",
    "api_base": "https://api.cohere.ai/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.cohere.com"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: bearer ...",
    "how_to_get": "Register at https://dashboard.cohere.com",
    "cost": "Trial key free. Command R: $0.15/$0.60 per 1M tokens"
  },
  "capabilities": [
    {
      "id": "chat",
      "description_for_ai": "Chat with Cohere Command models. Optional web search connector, document grounding, and citations.",
      "intent": [
        "cohere chat",
        "command R",
        "enterprise LLM",
        "cohere AI",
        "чат cohere"
      ],
      "endpoint": "POST https://api.cohere.ai/v2/chat",
      "input": {
        "model": {
          "type": "string",
          "description": "command-r-plus-08-2024 (best), command-r-08-2024 (balanced), command-light (fast)",
          "required": true
        },
        "messages": {
          "type": "array",
          "description": "[{role: user|assistant|system, content: string}]",
          "required": true
        },
        "documents": {
          "type": "array",
          "description": "[{id, data: {text: '...', title: '...'}}] for RAG grounding",
          "required": false
        },
        "tools": {
          "type": "array",
          "description": "Tool definitions for function calling",
          "required": false
        },
        "connectors": {
          "type": "array",
          "description": "[{id: web-search}] for live web search",
          "required": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "message.content[0].text",
          "citations",
          "usage.tokens.input_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "embed",
      "description_for_ai": "Create text embeddings for semantic search, clustering, RAG. Multilingual support.",
      "intent": [
        "cohere embeddings",
        "embed text",
        "semantic search cohere",
        "эмбеддинги cohere"
      ],
      "endpoint": "POST https://api.cohere.ai/v2/embed",
      "input": {
        "texts": {
          "type": "array",
          "description": "Array of strings to embed (max 96)",
          "required": true
        },
        "model": {
          "type": "string",
          "description": "embed-v4.0, embed-multilingual-v3.0",
          "required": true
        },
        "input_type": {
          "type": "string",
          "description": "search_document, search_query, classification, clustering",
          "required": true
        },
        "embedding_types": {
          "type": "array",
          "description": "['float', 'int8', 'uint8', 'binary', 'ubinary']",
          "required": false
        },
        "truncate": {
          "type": "string",
          "description": "NONE, START, END",
          "default": "END"
        }
      },
      "output": {
        "type": "embeddings",
        "fields": [
          "embeddings.float[0]",
          "meta.billed_units.input_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "rerank",
      "description_for_ai": "Rerank a list of documents by relevance to a query. Essential for RAG pipelines to improve retrieval quality.",
      "intent": [
        "rerank documents",
        "relevance ranking",
        "RAG reranking",
        "improve search results",
        "перерасположить документы cohere"
      ],
      "endpoint": "POST https://api.cohere.ai/v2/rerank",
      "input": {
        "model": {
          "type": "string",
          "description": "rerank-v3.5 or rerank-multilingual-v3.0",
          "required": true
        },
        "query": {
          "type": "string",
          "description": "The search query",
          "required": true
        },
        "documents": {
          "type": "array",
          "description": "List of strings or objects {text: '...'} to rerank. Max 1000.",
          "required": true
        },
        "top_n": {
          "type": "integer",
          "description": "Number of top results to return. Default returns all.",
          "required": false
        },
        "return_documents": {
          "type": "boolean",
          "description": "Include document text in response",
          "default": false
        }
      },
      "output": {
        "type": "reranked",
        "fields": [
          "results[0].index",
          "results[0].relevance_score",
          "results[0].document.text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "classify",
      "description_for_ai": "Classify text into custom categories using few-shot examples. No model training needed.",
      "intent": [
        "classify text cohere",
        "text classification",
        "sentiment categories",
        "content categorization",
        "классификация текста cohere"
      ],
      "endpoint": "POST https://api.cohere.ai/v1/classify",
      "input": {
        "inputs": {
          "type": "array",
          "description": "List of texts to classify",
          "required": true
        },
        "examples": {
          "type": "array",
          "description": "[{text: 'example text', label: 'category'}] — at least 2 per category",
          "required": true
        },
        "model": {
          "type": "string",
          "description": "embed-multilingual-v2.0",
          "required": false
        }
      },
      "output": {
        "type": "classifications",
        "fields": [
          "classifications[0].input",
          "classifications[0].prediction",
          "classifications[0].confidence"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}