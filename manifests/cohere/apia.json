{
  "apia": "1.0",
  "service": {
    "id": "cohere",
    "name": "Cohere API",
    "description_for_ai": "Enterprise AI API specializing in RAG, embeddings, and reranking. Command models for text generation. Embed v3 for best-in-class embeddings. Rerank for search relevance. Best for enterprise search and document processing.",
    "url": "https://cohere.com",
    "api_base": "https://api.cohere.ai/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.cohere.com"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: bearer ...",
    "how_to_get": "Register at https://dashboard.cohere.com",
    "cost": "Trial key free. Command R: $0.15/$0.60 per 1M tokens"
  },
  "capabilities": [
    {
      "id": "chat",
      "description_for_ai": "Chat with Command R+ for reasoning and tool use, or Command R for efficient RAG.",
      "intent": [
        "Cohere chat",
        "Command R",
        "enterprise AI",
        "Cohere API",
        "чат Cohere"
      ],
      "endpoint": "POST https://api.cohere.com/v2/chat",
      "input": {
        "model": {
          "type": "string",
          "description": "command-r-plus-08-2024 (best), command-r-08-2024 (RAG-optimized), command-r7b-12-2024 (fast)",
          "required": true
        },
        "messages": {
          "type": "array",
          "description": "[{role: 'user'|'assistant'|'system', content: string}]",
          "required": true
        },
        "temperature": {
          "type": "float",
          "default": 0.3
        },
        "max_tokens": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "message.content[0].text",
          "usage.tokens.input_tokens",
          "usage.tokens.output_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "tool_use",
      "description_for_ai": "Use Cohere with tools/functions. Command R+ excels at multi-step tool use.",
      "intent": [
        "Cohere tools",
        "function calling Cohere",
        "agent Cohere",
        "инструменты Cohere"
      ],
      "endpoint": "POST https://api.cohere.com/v2/chat",
      "input": {
        "model": {
          "type": "string",
          "required": true
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "tools": {
          "type": "array",
          "description": "[{type: 'function', function: {name, description, parameters: {type, properties, required}}}]",
          "required": true
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "message.tool_calls[0].function.name",
          "message.tool_calls[0].function.arguments"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "embeddings",
      "description_for_ai": "Generate multilingual embeddings with Cohere Embed v3. State-of-art for RAG.",
      "intent": [
        "Cohere embeddings",
        "multilingual embeddings",
        "RAG Cohere",
        "эмбеддинги Cohere"
      ],
      "endpoint": "POST https://api.cohere.com/v2/embed",
      "input": {
        "model": {
          "type": "string",
          "description": "embed-multilingual-v3.0 (100+ languages), embed-english-v3.0 (best for English)",
          "required": true
        },
        "texts": {
          "type": "array",
          "description": "Array of strings to embed",
          "required": true
        },
        "input_type": {
          "type": "string",
          "description": "search_document (for storing), search_query (for querying), classification, clustering",
          "required": true
        }
      },
      "output": {
        "type": "embeddings",
        "fields": [
          "embeddings.float[0] (float array)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "rerank",
      "description_for_ai": "Rerank a list of documents by relevance to a query. Improves RAG retrieval quality significantly.",
      "intent": [
        "rerank results",
        "RAG reranking",
        "improve search",
        "ранжирование Cohere"
      ],
      "endpoint": "POST https://api.cohere.com/v2/rerank",
      "input": {
        "model": {
          "type": "string",
          "description": "rerank-english-v3.0 or rerank-multilingual-v3.0",
          "required": true
        },
        "query": {
          "type": "string",
          "required": true
        },
        "documents": {
          "type": "array",
          "description": "List of strings or {text} objects to rerank",
          "required": true
        },
        "top_n": {
          "type": "integer",
          "description": "Return only top N documents",
          "required": false
        }
      },
      "output": {
        "type": "rerank",
        "fields": [
          "results[0].index",
          "results[0].relevance_score",
          "results[0].document.text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "classify",
      "description_for_ai": "Classify text into categories using few-shot examples. No model training needed.",
      "intent": [
        "text classification",
        "classify Cohere",
        "categorize text",
        "классификация текста Cohere"
      ],
      "endpoint": "POST https://api.cohere.com/v1/classify",
      "input": {
        "inputs": {
          "type": "array",
          "description": "Texts to classify",
          "required": true
        },
        "examples": {
          "type": "array",
          "description": "[{text: 'example text', label: 'category'}] — provide 2-5 examples per class",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "embed-multilingual-v3.0"
        }
      },
      "output": {
        "type": "classifications",
        "fields": [
          "classifications[0].prediction",
          "classifications[0].confidence",
          "classifications[0].labels"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "generate_text",
      "description_for_ai": "Use Cohere Generate for simple text completion (legacy, use chat for new projects).",
      "intent": [
        "text completion Cohere",
        "generate text",
        "completion API",
        "генерация текста Cohere"
      ],
      "endpoint": "POST https://api.cohere.com/v1/generate",
      "input": {
        "model": {
          "type": "string",
          "default": "command"
        },
        "prompt": {
          "type": "string",
          "required": true
        },
        "max_tokens": {
          "type": "integer",
          "default": 300
        },
        "temperature": {
          "type": "float",
          "default": 0.9
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "generations[0].text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}