{
  "apia": "1.0",
  "service": {
    "id": "elsevier-scopus",
    "name": "Elsevier Scopus API",
    "description_for_ai": "World largest abstract and citation database. 87M+ records from 24K+ journals. Article search, author profiles, journal metrics, citation analysis, h-index, affiliation data. Used by researchers and librarians worldwide. Requires institutional access or developer key.",
    "url": "https://scopus.com",
    "api_base": "https://api.elsevier.com/content",
    "category": "science",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://dev.elsevier.com/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "X-ELS-APIKey: {api_key}",
    "how_to_get": "Register at https://dev.elsevier.com — free developer key, institutional IP required for full access",
    "cost": "Free developer key. Full access requires Scopus subscription"
  },
  "capabilities": [
    {
      "id": "search_articles",
      "description_for_ai": "Search academic articles in Scopus by keyword, author, journal, or year.",
      "intent": [
        "academic search Scopus",
        "research papers",
        "scientific articles",
        "поиск статей Scopus"
      ],
      "endpoint": "GET https://api.elsevier.com/content/search/scopus",
      "input": {
        "query": {
          "type": "string",
          "description": "Scopus query: TITLE(neural networks) AND PUBYEAR>2020 AND AUTH(LeCun)",
          "required": true
        },
        "count": {
          "type": "integer",
          "default": 10
        },
        "start": {
          "type": "integer",
          "default": 0
        },
        "field": {
          "type": "string",
          "description": "Return fields: dc:title,prism:doi,dc:creator,prism:coverDate",
          "required": false
        },
        "sort": {
          "type": "string",
          "description": "-pubyear (newest first), citedby-count (most cited)",
          "required": false
        }
      },
      "output": {
        "type": "list<article>",
        "fields": [
          "entry[0].dc:title",
          "entry[0].prism:doi",
          "entry[0].dc:creator",
          "entry[0].prism:coverDate",
          "entry[0].citedby-count",
          "entry[0].prism:publicationName"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_article_abstract",
      "description_for_ai": "Get abstract and full metadata for a Scopus article by DOI or Scopus ID.",
      "intent": [
        "article abstract",
        "paper details Scopus",
        "DOI lookup",
        "аннотация статьи Scopus"
      ],
      "endpoint": "GET https://api.elsevier.com/content/abstract/doi/{doi}",
      "input": {
        "doi": {
          "type": "string",
          "description": "Article DOI: 10.1016/j.neunet.2021.01.001",
          "required": true
        }
      },
      "output": {
        "type": "article",
        "fields": [
          "dc:title",
          "dc:description (abstract)",
          "dc:creator",
          "prism:coverDate",
          "citedby-count",
          "prism:publicationName"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_author_profile",
      "description_for_ai": "Get Scopus author profile: publications count, h-index, affiliations.",
      "intent": [
        "author profile Scopus",
        "researcher stats",
        "h-index",
        "профиль автора Scopus"
      ],
      "endpoint": "GET https://api.elsevier.com/content/author/author_id/{author_id}",
      "input": {
        "author_id": {
          "type": "string",
          "description": "Scopus Author ID",
          "required": true
        }
      },
      "output": {
        "type": "author",
        "fields": [
          "author-profile.preferred-name.given-name",
          "author-profile.preferred-name.surname",
          "author-profile.publication-range",
          "h-index",
          "document-count",
          "cited-by-count"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_citations",
      "description_for_ai": "Get all articles that cite a given Scopus article.",
      "intent": [
        "citations Scopus",
        "cited by",
        "paper citations",
        "цитирования статьи Scopus"
      ],
      "endpoint": "GET https://api.elsevier.com/content/search/scopus",
      "input": {
        "query": {
          "type": "string",
          "description": "REFEID(SCOPUS_ID) to find citing articles",
          "required": true
        },
        "count": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<article>",
        "fields": [
          "entry[0].dc:title",
          "entry[0].prism:doi",
          "entry[0].prism:coverDate"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_journal_metrics",
      "description_for_ai": "Get journal metrics: CiteScore, SJR, SNIP, h-index.",
      "intent": [
        "journal metrics Scopus",
        "CiteScore",
        "SJR journal",
        "метрики журнала Scopus"
      ],
      "endpoint": "GET https://api.elsevier.com/content/serial/title/issn/{issn}",
      "input": {
        "issn": {
          "type": "string",
          "description": "Journal ISSN: 0169-2070",
          "required": true
        }
      },
      "output": {
        "type": "journal",
        "fields": [
          "dc:title",
          "citeScoreYearInfoList.citeScoreCurrentMetric",
          "SJRList.SJR[0].@_fa",
          "SNIPList.SNIP[0].@_fa",
          "citescoreYearInfoList.citeScoreYearInfo[0].$"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}