{
  "apia": "1.0",
  "service": {
    "id": "plaid",
    "name": "Plaid API",
    "description_for_ai": "Connect to 12,000+ bank accounts. Access transactions, balances, identity, income verification. Powers apps like Venmo, Robinhood, Betterment. Use for personal finance apps, expense tracking, bank account linking.",
    "url": "https://plaid.com",
    "api_base": "https://production.plaid.com",
    "category": "finance",
    "geo": [
      "US",
      "CA",
      "GB",
      "IE",
      "FR",
      "ES",
      "NL"
    ],
    "language": "en",
    "docs": "https://plaid.com/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "Register at https://dashboard.plaid.com",
    "cost": "Free sandbox. Production from $500/month"
  },
  "capabilities": [
    {
      "id": "create_link_token",
      "description_for_ai": "Create a link token to initialize Plaid Link UI for connecting a bank account.",
      "intent": [
        "connect bank account",
        "Plaid Link",
        "bank connection",
        "подключить банк Plaid"
      ],
      "endpoint": "POST https://production.plaid.com/link/token/create",
      "input": {
        "user": {
          "type": "object",
          "description": "{client_user_id: 'unique_user_id'}",
          "required": true
        },
        "client_name": {
          "type": "string",
          "description": "Your app name shown in Plaid UI",
          "required": true
        },
        "products": {
          "type": "array",
          "description": "['transactions', 'auth', 'balance', 'identity', 'investments', 'liabilities']",
          "required": true
        },
        "country_codes": {
          "type": "array",
          "description": "['US', 'GB', 'CA', 'DE', 'FR', 'ES', 'NL', 'IT']",
          "required": true
        },
        "language": {
          "type": "string",
          "default": "en"
        }
      },
      "output": {
        "type": "link",
        "fields": [
          "link_token",
          "expiration"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "exchange_public_token",
      "description_for_ai": "Exchange the public_token from Plaid Link for a reusable access_token.",
      "intent": [
        "Plaid access token",
        "bank token exchange",
        "Plaid auth",
        "токен Plaid"
      ],
      "endpoint": "POST https://production.plaid.com/item/public_token/exchange",
      "input": {
        "public_token": {
          "type": "string",
          "description": "public_token from Plaid Link onSuccess callback",
          "required": true
        }
      },
      "output": {
        "type": "token",
        "fields": [
          "access_token (save securely)",
          "item_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_transactions",
      "description_for_ai": "Get bank account transactions for a connected account.",
      "intent": [
        "bank transactions",
        "spending history",
        "account transactions Plaid",
        "транзакции банка Plaid"
      ],
      "endpoint": "POST https://production.plaid.com/transactions/get",
      "input": {
        "access_token": {
          "type": "string",
          "required": true
        },
        "start_date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "end_date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "count": {
          "type": "integer",
          "default": 100
        }
      },
      "output": {
        "type": "list<transaction>",
        "fields": [
          "transactions[0].transaction_id",
          "transactions[0].name",
          "transactions[0].amount",
          "transactions[0].date",
          "transactions[0].category",
          "transactions[0].merchant_name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_balance",
      "description_for_ai": "Get real-time account balances for connected bank accounts.",
      "intent": [
        "bank balance",
        "account balance Plaid",
        "checking balance",
        "баланс счёта Plaid"
      ],
      "endpoint": "POST https://production.plaid.com/accounts/balance/get",
      "input": {
        "access_token": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "accounts",
        "fields": [
          "accounts[0].name",
          "accounts[0].type",
          "accounts[0].balances.current",
          "accounts[0].balances.available",
          "accounts[0].balances.iso_currency_code"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_auth",
      "description_for_ai": "Get bank account routing and account numbers for ACH transfers.",
      "intent": [
        "routing number",
        "account number",
        "ACH Plaid",
        "реквизиты счёта Plaid"
      ],
      "endpoint": "POST https://production.plaid.com/auth/get",
      "input": {
        "access_token": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "auth",
        "fields": [
          "accounts[0].account_id",
          "numbers.ach[0].account",
          "numbers.ach[0].routing",
          "numbers.ach[0].wire_routing"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_identity",
      "description_for_ai": "Get account holder identity info: name, address, email, phone from bank.",
      "intent": [
        "bank account owner",
        "identity Plaid",
        "account holder info",
        "владелец счёта Plaid"
      ],
      "endpoint": "POST https://production.plaid.com/identity/get",
      "input": {
        "access_token": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "identity",
        "fields": [
          "accounts[0].owners[0].names[0]",
          "accounts[0].owners[0].emails[0].data",
          "accounts[0].owners[0].addresses[0].data.street"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "sandbox": "Test with sandbox: https://sandbox.plaid.com. Use institution_id='ins_109508' and credentials user_good/pass_good.",
    "link_flow": "1) POST /link/token/create → get link_token. 2) Open Plaid Link UI with token. 3) Get public_token. 4) POST /item/public_token/exchange → get access_token. 5) Use access_token for data.",
    "products": "Products: transactions, auth (account/routing), identity, liabilities, investments. Request only what you need.",
    "webhooks": "Essential for production: transactions/DEFAULT_UPDATE fires when new transactions available."
  }
}