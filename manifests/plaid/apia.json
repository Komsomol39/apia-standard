{
  "apia": "1.0",
  "service": {
    "id": "plaid",
    "name": "Plaid API",
    "description_for_ai": "Connect to 12,000+ bank accounts. Access transactions, balances, identity, income verification. Powers apps like Venmo, Robinhood, Betterment. Use for personal finance apps, expense tracking, bank account linking.",
    "url": "https://plaid.com",
    "api_base": "https://production.plaid.com",
    "category": "finance",
    "geo": [
      "US",
      "CA",
      "GB",
      "IE",
      "FR",
      "ES",
      "NL"
    ],
    "language": "en",
    "docs": "https://plaid.com/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "Register at https://dashboard.plaid.com",
    "cost": "Free sandbox. Production from $500/month"
  },
  "capabilities": [
    {
      "id": "create_link_token",
      "description_for_ai": "Create a Plaid Link token to initialize the account connection flow. First step to link a bank account.",
      "intent": [
        "plaid link",
        "connect bank account",
        "bank integration plaid",
        "подключить банк plaid"
      ],
      "endpoint": "POST https://sandbox.plaid.com/link/token/create",
      "input": {
        "user": {
          "type": "object",
          "description": "{client_user_id: 'user-unique-id'}",
          "required": true
        },
        "client_name": {
          "type": "string",
          "description": "Your app name shown to user in Plaid Link UI",
          "required": true
        },
        "products": {
          "type": "array",
          "description": "['transactions', 'auth', 'balance', 'identity', 'investments', 'liabilities']",
          "required": true
        },
        "country_codes": {
          "type": "array",
          "description": "['US', 'GB', 'CA', 'DE', 'FR', 'ES', 'NL', 'IE', 'SE']",
          "required": true
        },
        "language": {
          "type": "string",
          "description": "en, fr, es, de, nl, ru",
          "required": true
        }
      },
      "output": {
        "type": "link_token",
        "fields": [
          "link_token",
          "expiration",
          "request_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "exchange_public_token",
      "description_for_ai": "Exchange the public_token from Plaid Link for a permanent access_token. Second step after user connects account.",
      "intent": [
        "plaid token exchange",
        "get access token plaid",
        "finalize plaid connection",
        "обмен токена plaid"
      ],
      "endpoint": "POST https://sandbox.plaid.com/item/public_token/exchange",
      "input": {
        "public_token": {
          "type": "string",
          "description": "Public token received after user completes Plaid Link flow",
          "required": true
        }
      },
      "output": {
        "type": "tokens",
        "fields": [
          "access_token",
          "item_id",
          "request_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_transactions",
      "description_for_ai": "Get transaction history for a linked bank account. Categorized transactions with merchant info.",
      "intent": [
        "bank transactions plaid",
        "transaction history",
        "spending data plaid",
        "история транзакций plaid"
      ],
      "endpoint": "POST https://sandbox.plaid.com/transactions/get",
      "input": {
        "access_token": {
          "type": "string",
          "description": "Access token from exchange_public_token",
          "required": true
        },
        "start_date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "end_date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "count": {
          "type": "integer",
          "description": "Number of transactions",
          "default": 100
        },
        "offset": {
          "type": "integer",
          "default": 0
        }
      },
      "output": {
        "type": "transactions",
        "fields": [
          "transactions[0].transaction_id",
          "transactions[0].amount",
          "transactions[0].date",
          "transactions[0].merchant_name",
          "transactions[0].category[0]",
          "accounts[0].balances.available"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_balance",
      "description_for_ai": "Get real-time bank account balances for all linked accounts.",
      "intent": [
        "bank balance plaid",
        "account balance",
        "checking balance plaid",
        "баланс счёта plaid"
      ],
      "endpoint": "POST https://sandbox.plaid.com/accounts/balance/get",
      "input": {
        "access_token": {
          "type": "string",
          "required": true
        },
        "options": {
          "type": "object",
          "description": "{account_ids: ['specific_account_id']} to filter accounts",
          "required": false
        }
      },
      "output": {
        "type": "accounts",
        "fields": [
          "accounts[0].account_id",
          "accounts[0].name",
          "accounts[0].type",
          "accounts[0].balances.available",
          "accounts[0].balances.current",
          "accounts[0].balances.iso_currency_code"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "sandbox": "Test with sandbox: https://sandbox.plaid.com. Use institution_id='ins_109508' and credentials user_good/pass_good.",
    "link_flow": "1) POST /link/token/create → get link_token. 2) Open Plaid Link UI with token. 3) Get public_token. 4) POST /item/public_token/exchange → get access_token. 5) Use access_token for data.",
    "products": "Products: transactions, auth (account/routing), identity, liabilities, investments. Request only what you need.",
    "webhooks": "Essential for production: transactions/DEFAULT_UPDATE fires when new transactions available."
  }
}