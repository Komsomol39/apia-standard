{
  "apia": "1.0",
  "service": {
    "id": "mos-ru-api",
    "name": "Mos.ru API (Официальный сайт Москвы)",
    "description_for_ai": "Mos.ru API — official Moscow city portal data and services. Open datasets for city infrastructure: hospitals, clinics, schools, parks, sports facilities, libraries. Appointment booking integration via ЕМИАС. Part of Moscow Smart City initiative. Free for developers.",
    "url": "https://mos.ru",
    "api_base": "https://api.mos.ru",
    "category": "legal",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://apidata.mos.ru/Docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "Регистрация на https://apidata.mos.ru",
    "cost": "Бесплатно"
  },
  "capabilities": [
    {
      "id": "get_services",
      "description_for_ai": "Get list of Moscow city government services available through mos.ru.",
      "intent": [
        "услуги mos.ru",
        "госуслуги Москва",
        "московские услуги",
        "moscow city services"
      ],
      "endpoint": "GET https://api.mos.ru/v1/datasets",
      "input": {
        "rows": {
          "type": "integer",
          "default": 20
        },
        "number": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<dataset>",
        "fields": [
          "[0].ID",
          "[0].Caption",
          "[0].ShortDescription",
          "[0].Count"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_dataset",
      "description_for_ai": "Get open data from Moscow city datasets (transport, ecology, health, etc.).",
      "intent": [
        "открытые данные Москва",
        "данные mos.ru",
        "датасет Москва",
        "moscow open data"
      ],
      "endpoint": "GET https://api.mos.ru/v1/datasets/{dataset_id}/rows",
      "input": {
        "dataset_id": {
          "type": "string",
          "required": true
        },
        "rows": {
          "type": "integer",
          "default": 20
        },
        "number": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<record>",
        "fields": [
          "Cells[0].Name",
          "Cells[0].Value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_datasets",
      "description_for_ai": "Search Moscow open data catalog by keyword.",
      "intent": [
        "поиск данных Москва",
        "каталог mos.ru",
        "датасет поиск",
        "search moscow data"
      ],
      "endpoint": "GET https://data.mos.ru/api/v1/opendata/search",
      "input": {
        "q": {
          "type": "string",
          "required": true
        },
        "pageSize": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<dataset>",
        "fields": [
          "[0].id",
          "[0].title",
          "[0].category",
          "[0].count"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_transport_stops",
      "description_for_ai": "Get public transport stops data in Moscow.",
      "intent": [
        "остановки транспорта Москва",
        "маршруты Москва",
        "транспорт mos.ru",
        "moscow transport stops"
      ],
      "endpoint": "GET https://api.mos.ru/v1/datasets/752/rows",
      "input": {
        "rows": {
          "type": "integer",
          "default": 50
        },
        "number": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<stop>",
        "fields": [
          "Cells[0].Name (stop name)",
          "Cells[0].Value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_moscow_districts",
      "description_for_ai": "Get Moscow administrative districts and regions data.",
      "intent": [
        "районы Москвы",
        "округа Москвы",
        "административные районы",
        "moscow districts"
      ],
      "endpoint": "GET https://api.mos.ru/v1/datasets/737/rows",
      "input": {
        "rows": {
          "type": "integer",
          "default": 50
        }
      },
      "output": {
        "type": "list<district>",
        "fields": [
          "Cells[0].Name",
          "Cells[0].Value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}