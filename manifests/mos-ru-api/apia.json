{
  "apia": "1.0",
  "service": {
    "id": "mos-ru-api",
    "name": "Mos.ru API (Официальный сайт Москвы)",
    "description_for_ai": "Открытые данные и сервисы официального портала Москвы. Запись к врачу, данные о городских объектах, расписания, государственные услуги Москвы. Интеграция с Единым личным кабинетом москвича.",
    "url": "https://mos.ru",
    "api_base": "https://api.mos.ru",
    "category": "gov_moscow",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://apidata.mos.ru/Docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "Регистрация на https://apidata.mos.ru",
    "cost": "Бесплатно"
  },
  "capabilities": [
    {
      "id": "get_datasets",
      "description_for_ai": "Получить открытые наборы данных Москвы: парки, библиотеки, поликлиники, школы, детские сады, спортивные объекты.",
      "intent": [
        "данные Москвы",
        "городские объекты",
        "поликлиники Москвы",
        "парки Москвы",
        "школы Москвы",
        "инфраструктура города"
      ],
      "endpoint": "GET https://apidata.mos.ru/v1/datasets",
      "input": {
        "categoryId": {
          "type": "integer",
          "description": "Категория данных",
          "required": false
        },
        "skip": {
          "type": "integer",
          "default": 0
        },
        "top": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<dataset>",
        "fields": [
          "Id",
          "Caption",
          "CategoryId",
          "ItemsCount",
          "LastChange"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}