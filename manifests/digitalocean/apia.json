{
  "apia": "1.0",
  "service": {
    "id": "digitalocean",
    "name": "DigitalOcean API",
    "description_for_ai": "Developer-friendly cloud platform. Droplets (VMs), Kubernetes, managed databases, App Platform, Spaces (S3-compatible storage). Simple pricing, great docs. $200 free credit for new users. Use for cloud hosting, VMs, managed services.",
    "url": "https://digitalocean.com",
    "api_base": "https://api.digitalocean.com/v2",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.digitalocean.com/reference/api/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer {token}",
    "how_to_get": "API → Tokens → Generate New Token",
    "cost": "$200 free credit for new users. Droplets from $4/month"
  },
  "capabilities": [
    {
      "id": "list_droplets",
      "description_for_ai": "List all cloud servers (Droplets) with status, IP, size, and region.",
      "intent": [
        "digitalocean servers",
        "list droplets",
        "VPS list",
        "серверы digitalocean"
      ],
      "endpoint": "GET https://api.digitalocean.com/v2/droplets",
      "input": {
        "per_page": {
          "type": "integer",
          "default": 20
        },
        "tag_name": {
          "type": "string",
          "description": "Filter by tag",
          "required": false
        },
        "page": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<droplet>",
        "fields": [
          "droplets[0].id",
          "droplets[0].name",
          "droplets[0].status",
          "droplets[0].networks.v4[0].ip_address",
          "droplets[0].size.slug",
          "droplets[0].region.slug"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_droplet",
      "description_for_ai": "Create a new cloud server with specified OS, region, and size.",
      "intent": [
        "create server digitalocean",
        "new VPS",
        "spin up droplet",
        "создать сервер digitalocean"
      ],
      "endpoint": "POST https://api.digitalocean.com/v2/droplets",
      "input": {
        "name": {
          "type": "string",
          "description": "Hostname for the Droplet",
          "required": true
        },
        "region": {
          "type": "string",
          "description": "nyc3, sfo3, lon1, fra1, sgp1, ams3, blr1, tor1, syd1",
          "required": true
        },
        "size": {
          "type": "string",
          "description": "s-1vcpu-1gb ($6/mo), s-2vcpu-2gb ($18/mo), s-2vcpu-4gb ($24/mo)",
          "required": true
        },
        "image": {
          "type": "string",
          "description": "ubuntu-24-04-x64, debian-12-x64, fedora-41-x64, centos-stream-9-x64",
          "required": true
        },
        "ssh_keys": {
          "type": "array",
          "description": "SSH key IDs (get from /v2/account/keys)",
          "required": false
        },
        "tags": {
          "type": "array",
          "description": "Tags for organization",
          "required": false
        },
        "backups": {
          "type": "boolean",
          "description": "Enable automatic weekly backups (+20% cost)",
          "default": false
        }
      },
      "output": {
        "type": "droplet",
        "fields": [
          "droplet.id",
          "droplet.name",
          "droplet.status",
          "droplet.networks"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "droplet_action",
      "description_for_ai": "Perform action on a Droplet: reboot, power_on, power_off, shutdown, rebuild, resize, snapshot.",
      "intent": [
        "reboot server",
        "restart droplet",
        "power off server",
        "перезагрузить сервер digitalocean"
      ],
      "endpoint": "POST https://api.digitalocean.com/v2/droplets/{droplet_id}/actions",
      "input": {
        "droplet_id": {
          "type": "integer",
          "required": true
        },
        "type": {
          "type": "string",
          "description": "reboot, power_on, power_off, shutdown, rebuild, resize, snapshot, enable_backups",
          "required": true
        },
        "size": {
          "type": "string",
          "description": "New size slug for resize action",
          "required": false
        }
      },
      "output": {
        "type": "action",
        "fields": [
          "action.id",
          "action.status",
          "action.type",
          "action.started_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "manage_databases",
      "description_for_ai": "Create or list managed databases: PostgreSQL, MySQL, Redis, MongoDB, Kafka.",
      "intent": [
        "managed database digitalocean",
        "create postgres",
        "managed redis",
        "база данных digitalocean"
      ],
      "endpoint": "GET https://api.digitalocean.com/v2/databases",
      "input": {
        "engine": {
          "type": "string",
          "description": "pg (PostgreSQL), mysql, redis, mongodb, kafka",
          "required": false
        }
      },
      "output": {
        "type": "list<database>",
        "fields": [
          "databases[0].id",
          "databases[0].name",
          "databases[0].engine",
          "databases[0].status",
          "databases[0].connection.uri"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "regions": "nyc1/nyc3=New York, sfo3=San Francisco, lon1=London, fra1=Frankfurt, sgp1=Singapore, ams3=Amsterdam, blr1=Bangalore, tor1=Toronto, syd1=Sydney",
    "sizes": "s-1vcpu-1gb=$6/mo, s-1vcpu-2gb=$12/mo, s-2vcpu-2gb=$18/mo, s-2vcpu-4gb=$24/mo",
    "ssh_keys": "Upload SSH public key via POST /v2/account/keys before creating droplet. Pass returned ID in ssh_keys array.",
    "floating_ip": "Use reserved IPs (floating IPs) for production — reassign between droplets without DNS changes."
  }
}