{
  "apia": "1.0",
  "service": {
    "id": "digitalocean",
    "name": "DigitalOcean API",
    "description_for_ai": "Developer-friendly cloud platform. Droplets (VMs), Kubernetes, managed databases, App Platform, Spaces (S3-compatible storage). Simple pricing, great docs. $200 free credit for new users. Use for cloud hosting, VMs, managed services.",
    "url": "https://digitalocean.com",
    "api_base": "https://api.digitalocean.com/v2",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.digitalocean.com/reference/api/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer {token}",
    "how_to_get": "API → Tokens → Generate New Token",
    "cost": "$200 free credit for new users. Droplets from $4/month"
  },
  "capabilities": [
    {
      "id": "list_droplets",
      "description_for_ai": "List all DigitalOcean Droplets (VMs) in your account with IPs and status.",
      "intent": [
        "DigitalOcean servers",
        "list VMs",
        "droplets list",
        "серверы DigitalOcean"
      ],
      "endpoint": "GET https://api.digitalocean.com/v2/droplets",
      "input": {
        "per_page": {
          "type": "integer",
          "default": 20
        },
        "page": {
          "type": "integer",
          "default": 1
        },
        "tag_name": {
          "type": "string",
          "description": "Filter by tag",
          "required": false
        }
      },
      "output": {
        "type": "list<droplet>",
        "fields": [
          "droplets[0].id",
          "droplets[0].name",
          "droplets[0].status",
          "droplets[0].networks.v4[0].ip_address",
          "droplets[0].size_slug",
          "droplets[0].region.name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_droplet",
      "description_for_ai": "Create a new DigitalOcean Droplet (virtual machine).",
      "intent": [
        "create server DigitalOcean",
        "new VM",
        "spin up droplet",
        "создать сервер DigitalOcean"
      ],
      "endpoint": "POST https://api.digitalocean.com/v2/droplets",
      "input": {
        "name": {
          "type": "string",
          "required": true
        },
        "region": {
          "type": "string",
          "description": "nyc1, nyc3, sfo3, ams3, sgp1, lon1, fra1, tor1, blr1, syd1",
          "required": true
        },
        "size": {
          "type": "string",
          "description": "s-1vcpu-1gb ($6/mo), s-2vcpu-4gb ($24/mo), c-4-8gib (CPU-opt)",
          "required": true
        },
        "image": {
          "type": "string",
          "description": "ubuntu-24-04-x64, debian-12-x64, fedora-40-x64, ubuntu-22-04-x64",
          "required": true
        },
        "ssh_keys": {
          "type": "array",
          "description": "SSH key IDs from your account",
          "required": false
        },
        "tags": {
          "type": "array",
          "required": false
        },
        "user_data": {
          "type": "string",
          "description": "Cloud-init script for setup",
          "required": false
        }
      },
      "output": {
        "type": "droplet",
        "fields": [
          "droplet.id",
          "droplet.name",
          "droplet.status",
          "links.actions[0].href"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "droplet_action",
      "description_for_ai": "Perform action on a Droplet: power_on, power_off, reboot, shutdown, snapshot.",
      "intent": [
        "reboot server",
        "power off VM",
        "restart droplet",
        "перезагрузить сервер DigitalOcean"
      ],
      "endpoint": "POST https://api.digitalocean.com/v2/droplets/{droplet_id}/actions",
      "input": {
        "droplet_id": {
          "type": "integer",
          "required": true
        },
        "type": {
          "type": "string",
          "description": "power_on, power_off, power_cycle, reboot, shutdown, rebuild, resize, snapshot",
          "required": true
        }
      },
      "output": {
        "type": "action",
        "fields": [
          "action.id",
          "action.status",
          "action.type",
          "action.completed_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_snapshot",
      "description_for_ai": "Create a snapshot of a Droplet or volume for backup/cloning.",
      "intent": [
        "snapshot DigitalOcean",
        "backup server",
        "create image",
        "снэпшот DigitalOcean"
      ],
      "endpoint": "POST https://api.digitalocean.com/v2/droplets/{droplet_id}/actions",
      "input": {
        "droplet_id": {
          "type": "integer",
          "required": true
        },
        "type": {
          "type": "string",
          "default": "snapshot"
        },
        "name": {
          "type": "string",
          "description": "Snapshot name",
          "required": false
        }
      },
      "output": {
        "type": "action",
        "fields": [
          "action.id",
          "action.status",
          "action.type"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_databases",
      "description_for_ai": "List managed database clusters (PostgreSQL, MySQL, Redis, MongoDB, Kafka).",
      "intent": [
        "DigitalOcean database",
        "managed DB",
        "database cluster",
        "базы данных DigitalOcean"
      ],
      "endpoint": "GET https://api.digitalocean.com/v2/databases",
      "input": {},
      "output": {
        "type": "list<database>",
        "fields": [
          "databases[0].id",
          "databases[0].name",
          "databases[0].engine",
          "databases[0].status",
          "databases[0].connection.uri"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "manage_domains",
      "description_for_ai": "Create and manage DNS domains and records in DigitalOcean.",
      "intent": [
        "DNS DigitalOcean",
        "domain records",
        "add domain",
        "DNS записи DigitalOcean"
      ],
      "endpoint": "POST https://api.digitalocean.com/v2/domains/{domain_name}/records",
      "input": {
        "domain_name": {
          "type": "string",
          "required": true
        },
        "type": {
          "type": "string",
          "description": "A, AAAA, CNAME, MX, TXT, NS, SOA, SRV",
          "required": true
        },
        "name": {
          "type": "string",
          "description": "Record name e.g. @ or www",
          "required": true
        },
        "data": {
          "type": "string",
          "description": "Record value e.g. IP address",
          "required": true
        },
        "ttl": {
          "type": "integer",
          "default": 1800
        }
      },
      "output": {
        "type": "domain_record",
        "fields": [
          "domain_record.id",
          "domain_record.type",
          "domain_record.name",
          "domain_record.data"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "regions": "nyc1/nyc3=New York, sfo3=San Francisco, lon1=London, fra1=Frankfurt, sgp1=Singapore, ams3=Amsterdam, blr1=Bangalore, tor1=Toronto, syd1=Sydney",
    "sizes": "s-1vcpu-1gb=$6/mo, s-1vcpu-2gb=$12/mo, s-2vcpu-2gb=$18/mo, s-2vcpu-4gb=$24/mo",
    "ssh_keys": "Upload SSH public key via POST /v2/account/keys before creating droplet. Pass returned ID in ssh_keys array.",
    "floating_ip": "Use reserved IPs (floating IPs) for production — reassign between droplets without DNS changes."
  }
}