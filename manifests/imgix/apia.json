{
  "apia": "1.0",
  "service": {
    "id": "imgix",
    "name": "imgix API",
    "description_for_ai": "Real-time image processing and CDN. Transform, optimize, and deliver images via URL parameters. Resize, crop, filters, format conversion. Enterprise image infrastructure used by SquareSpace, BuzzFeed, 500px. Pay per GB bandwidth.",
    "url": "https://imgix.com",
    "api_base": "https://{source}.imgix.net",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.imgix.com/apis/url"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "Register at https://imgix.com — free trial",
    "cost": "Free 10GB/month trial. Then from $10/month"
  },
  "capabilities": [
    {
      "id": "transform_image",
      "description_for_ai": "Transform images on the fly via imgix URL parameters: resize, crop, format, quality.",
      "intent": [
        "image resize imgix",
        "image transform",
        "CDN image optimization",
        "оптимизация изображений imgix"
      ],
      "endpoint": "GET https://{source}.imgix.net/{path}",
      "input": {
        "source": {
          "type": "string",
          "description": "Your imgix source subdomain",
          "required": true
        },
        "path": {
          "type": "string",
          "description": "Image path in your bucket",
          "required": true
        },
        "w": {
          "type": "integer",
          "description": "Width in pixels",
          "required": false
        },
        "h": {
          "type": "integer",
          "description": "Height in pixels",
          "required": false
        },
        "fit": {
          "type": "string",
          "description": "clip, crop, fill, fillmax, max, min, scale",
          "required": false
        },
        "fm": {
          "type": "string",
          "description": "Output format: jpg, png, webp, avif, gif, mp4",
          "required": false
        },
        "q": {
          "type": "integer",
          "description": "Quality 0-100",
          "default": 75
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "Binary image stream with transformed image"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "auto_optimize",
      "description_for_ai": "Auto-optimize image format, compression, and enhancements with imgix.",
      "intent": [
        "auto optimize image",
        "compress image",
        "best format image",
        "автооптимизация imgix"
      ],
      "endpoint": "GET https://{source}.imgix.net/{path}",
      "input": {
        "source": {
          "type": "string",
          "required": true
        },
        "path": {
          "type": "string",
          "required": true
        },
        "auto": {
          "type": "string",
          "description": "format (auto WebP/AVIF), compress, enhance, redeye",
          "required": true
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "Optimized image binary"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "smart_crop",
      "description_for_ai": "Smart crop images to focus on faces or key content.",
      "intent": [
        "smart crop",
        "face crop",
        "content-aware crop",
        "умная обрезка imgix"
      ],
      "endpoint": "GET https://{source}.imgix.net/{path}",
      "input": {
        "source": {
          "type": "string",
          "required": true
        },
        "path": {
          "type": "string",
          "required": true
        },
        "w": {
          "type": "integer",
          "required": true
        },
        "h": {
          "type": "integer",
          "required": true
        },
        "fit": {
          "type": "string",
          "default": "crop"
        },
        "crop": {
          "type": "string",
          "description": "faces, entropy, edges, focalpoint",
          "required": true
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "Cropped image binary"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "add_watermark",
      "description_for_ai": "Add a watermark or overlay to an image with imgix.",
      "intent": [
        "watermark image",
        "overlay image",
        "brand image",
        "водяной знак imgix"
      ],
      "endpoint": "GET https://{source}.imgix.net/{path}",
      "input": {
        "source": {
          "type": "string",
          "required": true
        },
        "path": {
          "type": "string",
          "required": true
        },
        "mark": {
          "type": "string",
          "description": "URL of watermark image",
          "required": true
        },
        "mark-pad": {
          "type": "integer",
          "description": "Padding around mark",
          "default": 10
        },
        "mark-alpha": {
          "type": "integer",
          "description": "Watermark opacity 0-100",
          "default": 80
        },
        "mark-align": {
          "type": "string",
          "description": "bottom,right",
          "default": "bottom,right"
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "Image with watermark"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "generate_srcset",
      "description_for_ai": "Generate responsive image srcset URLs for multiple screen sizes.",
      "intent": [
        "responsive images",
        "srcset imgix",
        "retina images",
        "адаптивные изображения imgix"
      ],
      "endpoint": "GET https://{source}.imgix.net/{path}?w=320 2x srcset",
      "input": {
        "source": {
          "type": "string",
          "required": true
        },
        "path": {
          "type": "string",
          "required": true
        },
        "w": {
          "type": "integer",
          "description": "Base width",
          "required": true
        },
        "widths": {
          "type": "string",
          "description": "Comma-separated widths: 320,640,1024,1920",
          "required": false
        },
        "dpr": {
          "type": "number",
          "description": "Device pixel ratio: 1, 2, 3",
          "required": false
        }
      },
      "output": {
        "type": "url",
        "fields": [
          "Responsive image URL string with DPR or width params"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}