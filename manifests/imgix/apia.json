{
  "apia": "1.0",
  "service": {
    "id": "imgix",
    "name": "imgix API",
    "description_for_ai": "Real-time image processing and CDN. Transform, optimize, and deliver images via URL parameters. Resize, crop, filters, format conversion. Enterprise image infrastructure used by SquareSpace, BuzzFeed, 500px. Pay per GB bandwidth.",
    "url": "https://imgix.com",
    "api_base": "https://{source}.imgix.net",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.imgix.com/apis/url"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "Register at https://imgix.com — free trial",
    "cost": "Free 10GB/month trial. Then from $10/month"
  },
  "capabilities": [
    {
      "id": "transform_image",
      "description_for_ai": "Transform images via URL parameters. Resize, crop, adjust brightness/contrast/saturation, apply blur, add watermark, convert format.",
      "intent": [
        "transform image",
        "resize photo",
        "image processing",
        "optimize image",
        "image CDN",
        "image filters"
      ],
      "endpoint": "GET https://{source}.imgix.net/{path}",
      "input": {
        "path": {
          "type": "string",
          "description": "Image path in your imgix source",
          "required": true
        },
        "w": {
          "type": "integer",
          "description": "Width in pixels",
          "required": false
        },
        "h": {
          "type": "integer",
          "description": "Height in pixels",
          "required": false
        },
        "fit": {
          "type": "string",
          "description": "crop, clip, fill, max, min, scale",
          "required": false
        },
        "auto": {
          "type": "string",
          "description": "compress, format, enhance — auto optimize",
          "default": "format,compress"
        },
        "q": {
          "type": "integer",
          "description": "Search query or filter expression",
          "default": 75
        },
        "fm": {
          "type": "string",
          "description": "jpg, png, webp, avif, gif",
          "required": false
        },
        "blur": {
          "type": "integer",
          "description": "Blur amount 0-2000",
          "required": false
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "transformed image binary or URL"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}