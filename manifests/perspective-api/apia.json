{
  "apia": "1.0",
  "service": {
    "id": "perspective-api",
    "name": "Perspective API (Google Jigsaw)",
    "description_for_ai": "Free content moderation API from Google. Detects toxic comments, threats, insults, profanity, identity attacks. 100+ languages. Free. Used by New York Times, Wikipedia. Use for comment moderation.",
    "url": "https://perspectiveapi.com",
    "api_base": "https://commentanalyzer.googleapis.com/v1alpha1",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.perspectiveapi.com/s/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Request access at https://developers.perspectiveapi.com/s/request-quota",
    "cost": "Free with quota"
  },
  "capabilities": [
    {
      "id": "analyze_comment",
      "description_for_ai": "Score text for toxicity, threats, insults, profanity, identity attacks. Returns 0-1 probability for each attribute. Free. 100+ languages.",
      "intent": [
        "toxicity check",
        "content moderation",
        "hate speech detection",
        "is comment toxic",
        "проверка токсичности"
      ],
      "endpoint": "POST https://commentanalyzer.googleapis.com/v1alpha1/comments:analyze",
      "input": {
        "comment": {
          "type": "object",
          "description": "{text: 'Comment text to analyze'}",
          "required": true
        },
        "requestedAttributes": {
          "type": "object",
          "description": "Attributes to score: {TOXICITY: {}, SEVERE_TOXICITY: {}, IDENTITY_ATTACK: {}, INSULT: {}, PROFANITY: {}, THREAT: {}, SEXUALLY_EXPLICIT: {}, FLIRTATION: {}}",
          "required": true
        },
        "languages": {
          "type": "array",
          "description": "['en', 'ru', 'de', 'fr', 'es', 'it', 'pt', 'zh']. Auto-detected if omitted.",
          "required": false
        },
        "doNotStore": {
          "type": "boolean",
          "description": "Prevent Google from storing comment. Set true for GDPR compliance.",
          "default": false
        }
      },
      "output": {
        "type": "scores",
        "fields": [
          "attributeScores.TOXICITY.summaryScore.value (0-1)",
          "attributeScores.SEVERE_TOXICITY.summaryScore.value",
          "attributeScores.IDENTITY_ATTACK.summaryScore.value",
          "attributeScores.INSULT.summaryScore.value",
          "attributeScores.THREAT.summaryScore.value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "batch_analyze",
      "description_for_ai": "Analyze multiple texts for toxicity in one API call to reduce latency.",
      "intent": [
        "batch moderation",
        "moderate multiple comments",
        "bulk toxicity check",
        "пакетная модерация"
      ],
      "endpoint": "POST https://commentanalyzer.googleapis.com/v1alpha1/comments:analyze",
      "input": {
        "comment": {
          "type": "object",
          "description": "{text: 'Comment text'}",
          "required": true
        },
        "requestedAttributes": {
          "type": "object",
          "description": "{TOXICITY: {scoreThreshold: 0.5}} — only return attributes exceeding threshold",
          "required": true
        },
        "sessionId": {
          "type": "string",
          "description": "Session ID to group related comments",
          "required": false
        },
        "communityId": {
          "type": "string",
          "description": "Community identifier for better context",
          "required": false
        }
      },
      "output": {
        "type": "scores",
        "fields": [
          "attributeScores.TOXICITY.summaryScore.value",
          "attributeScores.TOXICITY.spanScores"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "suggest_score",
      "description_for_ai": "Submit a human-provided score to improve model accuracy. Used for active learning.",
      "intent": [
        "submit feedback perspective",
        "improve toxicity model",
        "report score perspective",
        "улучшить модель perspective"
      ],
      "endpoint": "POST https://commentanalyzer.googleapis.com/v1alpha1/comments:suggestscore",
      "input": {
        "comment": {
          "type": "object",
          "description": "{text: 'Comment text'}",
          "required": true
        },
        "attributeScores": {
          "type": "object",
          "description": "{TOXICITY: {summaryScore: {value: 0.9, type: PROBABILITY}}}",
          "required": true
        },
        "communityId": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "{}"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_attribute_info",
      "description_for_ai": "Get information about available Perspective API attributes and which languages they support.",
      "intent": [
        "perspective attributes",
        "available toxicity models",
        "language support perspective",
        "список атрибутов perspective"
      ],
      "endpoint": "GET https://commentanalyzer.googleapis.com/v1alpha1/attributes",
      "input": {},
      "output": {
        "type": "attributes",
        "fields": [
          "Available attributes with supported languages"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "thresholds": "Common thresholds: score > 0.7 = block/reject, 0.5-0.7 = review queue, < 0.5 = allow. Adjust per your use case.",
    "free": "Completely free API with quota. Apply at https://perspectiveapi.com for production quota increase.",
    "languages": "TOXICITY works for 100+ languages. Other attributes have varying language support — check docs.",
    "privacy": "Set doNotStore: true for GDPR compliance. Comments with doNotStore are not used to train models."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}