{
  "apia": "1.0",
  "service": {
    "id": "perspective-api",
    "name": "Perspective API (Google Jigsaw)",
    "description_for_ai": "Free content moderation API from Google. Detects toxic comments, threats, insults, profanity, identity attacks. 100+ languages. Free. Used by New York Times, Wikipedia. Use for comment moderation.",
    "url": "https://perspectiveapi.com",
    "api_base": "https://commentanalyzer.googleapis.com/v1alpha1",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.perspectiveapi.com/s/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Request access at https://developers.perspectiveapi.com/s/request-quota",
    "cost": "Free with quota"
  },
  "capabilities": [
    {
      "id": "analyze_comment",
      "description_for_ai": "Analyze text toxicity with Perspective API. Detects hate speech, threats, insults, profanity.",
      "intent": [
        "toxicity detection",
        "hate speech check",
        "content moderation text",
        "обнаружение токсичности Perspective"
      ],
      "endpoint": "POST https://commentanalyzer.googleapis.com/v1alpha1/comments:analyze",
      "input": {
        "comment": {
          "type": "object",
          "description": "{text: 'Text to analyze'}",
          "required": true
        },
        "requestedAttributes": {
          "type": "object",
          "description": "{TOXICITY: {}, SEVERE_TOXICITY: {}, IDENTITY_ATTACK: {}, INSULT: {}, PROFANITY: {}, THREAT: {}, SEXUALLY_EXPLICIT: {}}",
          "required": true
        },
        "languages": {
          "type": "array",
          "description": "['en', 'ru', 'de', 'fr', 'es', 'it', 'pt', 'nl', 'ja', 'ko']",
          "required": false
        }
      },
      "output": {
        "type": "scores",
        "fields": [
          "attributeScores.TOXICITY.summaryScore.value (0-1)",
          "attributeScores.SEVERE_TOXICITY.summaryScore.value",
          "attributeScores.INSULT.summaryScore.value",
          "attributeScores.THREAT.summaryScore.value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "batch_analyze",
      "description_for_ai": "Analyze multiple texts for toxicity in a single API call.",
      "intent": [
        "batch toxicity",
        "bulk moderation",
        "multiple texts analysis",
        "массовая проверка токсичности"
      ],
      "endpoint": "POST https://commentanalyzer.googleapis.com/v1alpha1/comments:analyze",
      "input": {
        "comment": {
          "type": "object",
          "description": "{text: 'Analyze this text'}",
          "required": true
        },
        "requestedAttributes": {
          "type": "object",
          "description": "Attributes to score",
          "required": true
        },
        "context": {
          "type": "object",
          "description": "{entries: [{text: 'previous comment'}]} for conversation context",
          "required": false
        }
      },
      "output": {
        "type": "scores",
        "fields": [
          "attributeScores.TOXICITY.summaryScore.value",
          "attributeScores.TOXICITY.spanScores[0].score.value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "check_threat",
      "description_for_ai": "Check if text contains threats of violence against a person.",
      "intent": [
        "threat detection",
        "violence threat check",
        "threatening message",
        "обнаружение угроз Perspective"
      ],
      "endpoint": "POST https://commentanalyzer.googleapis.com/v1alpha1/comments:analyze",
      "input": {
        "comment": {
          "type": "object",
          "required": true
        },
        "requestedAttributes": {
          "type": "object",
          "default": {
            "THREAT": {}
          }
        }
      },
      "output": {
        "type": "scores",
        "fields": [
          "attributeScores.THREAT.summaryScore.value (threshold: 0.8+)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "check_identity_attack",
      "description_for_ai": "Detect identity attacks: slurs or attacks targeting race, religion, gender, nationality, sexual orientation.",
      "intent": [
        "identity attack detection",
        "slur detection",
        "discrimination detection",
        "обнаружение нападок на идентичность"
      ],
      "endpoint": "POST https://commentanalyzer.googleapis.com/v1alpha1/comments:analyze",
      "input": {
        "comment": {
          "type": "object",
          "required": true
        },
        "requestedAttributes": {
          "type": "object",
          "default": {
            "IDENTITY_ATTACK": {}
          }
        }
      },
      "output": {
        "type": "scores",
        "fields": [
          "attributeScores.IDENTITY_ATTACK.summaryScore.value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "multilingual_toxicity",
      "description_for_ai": "Detect toxicity in non-English languages. Supports 10+ languages.",
      "intent": [
        "Russian toxicity",
        "multilingual moderation",
        "toxic text other language",
        "токсичность на русском"
      ],
      "endpoint": "POST https://commentanalyzer.googleapis.com/v1alpha1/comments:analyze",
      "input": {
        "comment": {
          "type": "object",
          "required": true
        },
        "requestedAttributes": {
          "type": "object",
          "default": {
            "TOXICITY": {}
          }
        },
        "languages": {
          "type": "array",
          "description": "Specify language: ['ru'] for Russian, ['de'] for German",
          "required": true
        }
      },
      "output": {
        "type": "scores",
        "fields": [
          "attributeScores.TOXICITY.summaryScore.value",
          "detectedLanguages[0]"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "thresholds": "Common thresholds: score > 0.7 = block/reject, 0.5-0.7 = review queue, < 0.5 = allow. Adjust per your use case.",
    "free": "Completely free API with quota. Apply at https://perspectiveapi.com for production quota increase.",
    "languages": "TOXICITY works for 100+ languages. Other attributes have varying language support — check docs.",
    "privacy": "Set doNotStore: true for GDPR compliance. Comments with doNotStore are not used to train models."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}