{
  "apia": "1.0",
  "service": {
    "id": "perspective-api",
    "name": "Perspective API (Google Jigsaw)",
    "description_for_ai": "Free content moderation API from Google. Detects toxic comments, threats, insults, profanity, identity attacks. 100+ languages. Free. Used by New York Times, Wikipedia. Use for comment moderation.",
    "url": "https://perspectiveapi.com",
    "api_base": "https://commentanalyzer.googleapis.com/v1alpha1",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.perspectiveapi.com/s/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Request access at https://developers.perspectiveapi.com/s/request-quota",
    "cost": "Free with quota"
  },
  "capabilities": [
    {
      "id": "analyze_comment",
      "description_for_ai": "Analyze text for toxicity, insults, threats, and hate speech using Google Perspective API.",
      "intent": [
        "toxicity check",
        "content moderation",
        "hate speech detection",
        "проверка токсичности"
      ],
      "endpoint": "POST https://commentanalyzer.googleapis.com/v1alpha1/comments:analyze",
      "input": {
        "comment": {
          "type": "object",
          "description": "{text: 'comment to analyze'}",
          "required": true
        },
        "requestedAttributes": {
          "type": "object",
          "description": "{TOXICITY: {}, SEVERE_TOXICITY: {}, INSULT: {}, THREAT: {}, SEXUALLY_EXPLICIT: {}, IDENTITY_ATTACK: {}, PROFANITY: {}}",
          "required": true
        },
        "languages": {
          "type": "array",
          "description": "ISO codes: en, fr, de, es, it, pt, ru, ja, ko, zh, ar",
          "required": false
        }
      },
      "output": {
        "type": "scores",
        "fields": [
          "attributeScores.TOXICITY.summaryScore.value (0-1)",
          "attributeScores.INSULT.summaryScore.value",
          "attributeScores.THREAT.summaryScore.value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "batch_analyze",
      "description_for_ai": "Analyze multiple comments in a single request for content moderation pipeline.",
      "intent": [
        "batch moderation",
        "bulk toxicity check",
        "content filter batch",
        "пакетная модерация"
      ],
      "endpoint": "POST https://commentanalyzer.googleapis.com/v1alpha1/comments:analyze",
      "input": {
        "comment": {
          "type": "object",
          "description": "{text: 'text to moderate'}",
          "required": true
        },
        "requestedAttributes": {
          "type": "object",
          "description": "Multiple attributes: {TOXICITY: {}, SPAM: {}}",
          "required": true
        },
        "spanAnnotations": {
          "type": "boolean",
          "description": "Return per-span scores for sentence-level analysis",
          "default": false
        },
        "doNotStore": {
          "type": "boolean",
          "description": "Don't store comment for training",
          "default": true
        }
      },
      "output": {
        "type": "analysis",
        "fields": [
          "attributeScores.TOXICITY.summaryScore.value",
          "spanScores[0].begin",
          "spanScores[0].score.value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "suggest_score",
      "description_for_ai": "Submit a correction if Perspective scored a comment incorrectly (for model improvement).",
      "intent": [
        "correct moderation",
        "report false positive",
        "improve Perspective",
        "коррекция оценки модерации"
      ],
      "endpoint": "POST https://commentanalyzer.googleapis.com/v1alpha1/comments:suggestscore",
      "input": {
        "comment": {
          "type": "object",
          "description": "{text: 'comment text'}",
          "required": true
        },
        "attributeScores": {
          "type": "object",
          "description": "{TOXICITY: {summaryScore: {value: 0.9, type: 'PROBABILITY'}}}",
          "required": true
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "clientToken"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "model_reference",
      "description_for_ai": "Reference list of all Perspective API attributes and their descriptions.",
      "intent": [
        "Perspective attributes",
        "moderation categories",
        "available models Perspective",
        "категории модерации Perspective"
      ],
      "endpoint": "reference",
      "input": {},
      "output": {
        "type": "reference",
        "fields": [
          "TOXICITY: general harmful content",
          "SEVERE_TOXICITY: extreme harm",
          "IDENTITY_ATTACK: hate speech",
          "INSULT: disrespectful",
          "PROFANITY: obscene language",
          "THREAT: violent threats",
          "SEXUALLY_EXPLICIT: adult content",
          "FLIRTATION: unwanted flirtation",
          "SPAM: commercial spam"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "multilingual_moderation",
      "description_for_ai": "Moderate content in 30+ languages. Specify language for better accuracy.",
      "intent": [
        "multilingual moderation",
        "non-English toxicity",
        "Russian moderation",
        "модерация на русском"
      ],
      "endpoint": "POST https://commentanalyzer.googleapis.com/v1alpha1/comments:analyze",
      "input": {
        "comment": {
          "type": "object",
          "description": "{text: 'текст для модерации'}",
          "required": true
        },
        "requestedAttributes": {
          "type": "object",
          "description": "{TOXICITY: {}}",
          "required": true
        },
        "languages": {
          "type": "array",
          "description": "['ru'] — specify language for better accuracy",
          "required": true
        }
      },
      "output": {
        "type": "scores",
        "fields": [
          "attributeScores.TOXICITY.summaryScore.value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "thresholds": "Common thresholds: score > 0.7 = block/reject, 0.5-0.7 = review queue, < 0.5 = allow. Adjust per your use case.",
    "free": "Completely free API with quota. Apply at https://perspectiveapi.com for production quota increase.",
    "languages": "TOXICITY works for 100+ languages. Other attributes have varying language support — check docs.",
    "privacy": "Set doNotStore: true for GDPR compliance. Comments with doNotStore are not used to train models."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}