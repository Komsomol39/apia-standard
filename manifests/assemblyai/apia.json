{
  "apia": "1.0",
  "service": {
    "id": "assemblyai",
    "name": "AssemblyAI API",
    "description_for_ai": "AI-powered speech-to-text and audio intelligence. Transcribe audio files or streams. Speaker diarization, sentiment analysis, topic detection, PII redaction, content moderation, auto chapters. Best for processing audio content at scale.",
    "url": "https://assemblyai.com",
    "api_base": "https://api.assemblyai.com/v2",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.assemblyai.com/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: YOUR_API_KEY",
    "how_to_get": "Register at https://www.assemblyai.com — $50 free credit",
    "cost": "$0.37/hour audio. $0.13/hour for nano model"
  },
  "capabilities": [
    {
      "id": "transcribe_audio",
      "description_for_ai": "Transcribe audio to text with AssemblyAI. Supports speaker labels, timestamps, and custom vocabulary.",
      "intent": [
        "transcribe AssemblyAI",
        "speech to text",
        "audio transcription",
        "транскрипция AssemblyAI"
      ],
      "endpoint": "POST https://api.assemblyai.com/v2/transcript",
      "input": {
        "audio_url": {
          "type": "string",
          "description": "Public URL to audio/video file (mp3, mp4, wav, m4a, etc.)",
          "required": true
        },
        "speaker_labels": {
          "type": "boolean",
          "description": "Identify multiple speakers",
          "default": false
        },
        "language_code": {
          "type": "string",
          "description": "en, es, fr, de, it, pt, nl, ru, ja, ko, zh (auto-detected if omitted)",
          "required": false
        },
        "punctuate": {
          "type": "boolean",
          "default": true
        },
        "word_boost": {
          "type": "array",
          "description": "Custom vocabulary words to boost accuracy",
          "required": false
        }
      },
      "output": {
        "type": "transcript",
        "fields": [
          "id (poll status with this)",
          "status",
          "text",
          "words[0].text",
          "words[0].start",
          "words[0].confidence",
          "utterances[0].speaker",
          "utterances[0].text"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_transcript",
      "description_for_ai": "Poll or get results of a submitted AssemblyAI transcription.",
      "intent": [
        "get transcript AssemblyAI",
        "transcription status",
        "poll results AssemblyAI",
        "результаты транскрипции AssemblyAI"
      ],
      "endpoint": "GET https://api.assemblyai.com/v2/transcript/{transcript_id}",
      "input": {
        "transcript_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "transcript",
        "fields": [
          "id",
          "status (queued/processing/completed/error)",
          "text",
          "words",
          "utterances",
          "confidence"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "sentiment_analysis",
      "description_for_ai": "Transcribe audio and detect sentiment (positive/negative/neutral) per sentence.",
      "intent": [
        "audio sentiment",
        "speech sentiment analysis",
        "voice tone analysis",
        "анализ тональности речи AssemblyAI"
      ],
      "endpoint": "POST https://api.assemblyai.com/v2/transcript",
      "input": {
        "audio_url": {
          "type": "string",
          "required": true
        },
        "sentiment_analysis": {
          "type": "boolean",
          "default": true
        }
      },
      "output": {
        "type": "sentiment",
        "fields": [
          "sentiment_analysis_results[0].text",
          "sentiment_analysis_results[0].sentiment (POSITIVE/NEGATIVE/NEUTRAL)",
          "sentiment_analysis_results[0].confidence"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "speaker_diarization",
      "description_for_ai": "Transcribe multi-speaker audio with speaker identification.",
      "intent": [
        "speaker diarization",
        "speaker identification",
        "who said what",
        "идентификация говорящих AssemblyAI"
      ],
      "endpoint": "POST https://api.assemblyai.com/v2/transcript",
      "input": {
        "audio_url": {
          "type": "string",
          "required": true
        },
        "speaker_labels": {
          "type": "boolean",
          "default": true
        },
        "speakers_expected": {
          "type": "integer",
          "description": "Expected number of speakers (optional hint)",
          "required": false
        }
      },
      "output": {
        "type": "transcript",
        "fields": [
          "utterances[0].speaker (A/B/C...)",
          "utterances[0].text",
          "utterances[0].start",
          "utterances[0].end",
          "utterances[0].confidence"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "entity_detection",
      "description_for_ai": "Extract named entities from audio transcription: people, locations, dates, organizations.",
      "intent": [
        "entities in audio",
        "NER audio",
        "audio entity extraction",
        "извлечение сущностей AssemblyAI"
      ],
      "endpoint": "POST https://api.assemblyai.com/v2/transcript",
      "input": {
        "audio_url": {
          "type": "string",
          "required": true
        },
        "entity_detection": {
          "type": "boolean",
          "default": true
        }
      },
      "output": {
        "type": "entities",
        "fields": [
          "entities[0].entity_type (person_name/location/organization/date)",
          "entities[0].text",
          "entities[0].start",
          "entities[0].end"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "summarize_audio",
      "description_for_ai": "Automatically summarize audio content (meeting, podcast, call) with AI.",
      "intent": [
        "summarize audio",
        "podcast summary",
        "meeting summary AssemblyAI",
        "резюме аудио AssemblyAI"
      ],
      "endpoint": "POST https://api.assemblyai.com/v2/transcript",
      "input": {
        "audio_url": {
          "type": "string",
          "required": true
        },
        "summarization": {
          "type": "boolean",
          "default": true
        },
        "summary_model": {
          "type": "string",
          "description": "informative or conversational",
          "default": "informative"
        },
        "summary_type": {
          "type": "string",
          "description": "bullets, bullets_verbose, gist, headline, paragraph",
          "default": "bullets"
        }
      },
      "output": {
        "type": "summary",
        "fields": [
          "summary (formatted summary text)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "async_flow": "1) POST to /transcript with audio_url → get id. 2) Poll GET /transcript/{id} until status=completed. Usually 30-60s for 1h audio.",
    "streaming": "For real-time use WebSocket endpoint wss://api.assemblyai.com/v2/realtime/ws"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}