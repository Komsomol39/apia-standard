{
  "apia": "1.0",
  "service": {
    "id": "assemblyai",
    "name": "AssemblyAI API",
    "description_for_ai": "AI-powered speech-to-text and audio intelligence. Transcribe audio files or streams. Speaker diarization, sentiment analysis, topic detection, PII redaction, content moderation, auto chapters. Best for processing audio content at scale.",
    "url": "https://assemblyai.com",
    "api_base": "https://api.assemblyai.com/v2",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.assemblyai.com/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: YOUR_API_KEY",
    "how_to_get": "Register at https://www.assemblyai.com — $50 free credit",
    "cost": "$0.37/hour audio. $0.13/hour for nano model"
  },
  "capabilities": [
    {
      "id": "submit_transcription",
      "description_for_ai": "Submit audio for transcription. Returns job ID to poll. Supports 100+ languages, speaker diarization, auto chapters.",
      "intent": [
        "assemblyai transcribe",
        "submit audio",
        "async transcription",
        "транскрибация assemblyai"
      ],
      "endpoint": "POST https://api.assemblyai.com/v2/transcript",
      "input": {
        "audio_url": {
          "type": "string",
          "description": "Public URL of audio file",
          "required": true
        },
        "language_code": {
          "type": "string",
          "description": "en, ru, de, fr, es, etc. Auto-detected if omitted.",
          "required": false
        },
        "speaker_labels": {
          "type": "boolean",
          "description": "Identify different speakers",
          "default": false
        },
        "auto_chapters": {
          "type": "boolean",
          "description": "Auto-generate chapters with summaries",
          "default": false
        },
        "sentiment_analysis": {
          "type": "boolean",
          "default": false
        },
        "entity_detection": {
          "type": "boolean",
          "description": "Detect PII, names, dates, locations",
          "default": false
        },
        "iab_categories": {
          "type": "boolean",
          "description": "Classify content into IAB categories",
          "default": false
        }
      },
      "output": {
        "type": "job",
        "fields": [
          "id",
          "status",
          "language_code"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_transcript",
      "description_for_ai": "Get transcription result by job ID. Poll until status=completed.",
      "intent": [
        "get transcript result",
        "check transcription status",
        "poll transcription",
        "получить транскрипцию assemblyai"
      ],
      "endpoint": "GET https://api.assemblyai.com/v2/transcript/{id}",
      "input": {
        "id": {
          "type": "string",
          "description": "Transcript ID from submit_transcription",
          "required": true
        }
      },
      "output": {
        "type": "transcript",
        "fields": [
          "id",
          "status (queued|processing|completed|error)",
          "text",
          "words[0].text",
          "words[0].start",
          "words[0].speaker",
          "chapters[0].summary"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "lemur_task",
      "description_for_ai": "Use LeMUR to ask questions about audio content, generate summaries, extract insights from transcripts using LLMs.",
      "intent": [
        "audio Q&A",
        "summarize audio",
        "LeMUR",
        "ask questions about audio",
        "анализ аудио LLM assemblyai"
      ],
      "endpoint": "POST https://api.assemblyai.com/lemur/v3/request",
      "input": {
        "transcript_ids": {
          "type": "array",
          "description": "List of completed transcript IDs",
          "required": true
        },
        "prompt": {
          "type": "string",
          "description": "Question or task e.g. 'Summarize the main points'",
          "required": true
        },
        "final_model": {
          "type": "string",
          "description": "anthropic/claude-3-5-haiku (default), anthropic/claude-3-5-sonnet",
          "required": false
        },
        "max_output_size": {
          "type": "integer",
          "description": "Max output tokens",
          "default": 2048
        }
      },
      "output": {
        "type": "lemur",
        "fields": [
          "request_id",
          "response",
          "usage.input_tokens",
          "usage.output_tokens"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "realtime_transcription",
      "description_for_ai": "Real-time streaming transcription via WebSocket. Connect, stream audio, get partial and final transcripts.",
      "intent": [
        "real-time STT assemblyai",
        "live transcription",
        "streaming speech assemblyai",
        "потоковая транскрибация assemblyai"
      ],
      "endpoint": "WSS wss://api.assemblyai.com/v2/realtime/ws",
      "input": {
        "sample_rate": {
          "type": "integer",
          "description": "Audio sample rate in Hz e.g. 16000",
          "required": true
        },
        "word_boost": {
          "type": "array",
          "description": "Domain-specific words to boost accuracy",
          "required": false
        },
        "encoding": {
          "type": "string",
          "description": "pcm_s16le (default) or pcm_mulaw",
          "required": false
        }
      },
      "output": {
        "type": "streaming",
        "fields": [
          "text (partial)",
          "message_type (PartialTranscript|FinalTranscript)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "async_flow": "1) POST to /transcript with audio_url → get id. 2) Poll GET /transcript/{id} until status=completed. Usually 30-60s for 1h audio.",
    "streaming": "For real-time use WebSocket endpoint wss://api.assemblyai.com/v2/realtime/ws"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}