{
  "apia": "1.0",
  "service": {
    "id": "assemblyai",
    "name": "AssemblyAI API",
    "description_for_ai": "AI-powered speech-to-text and audio intelligence. Transcribe audio files or streams. Speaker diarization, sentiment analysis, topic detection, PII redaction, content moderation, auto chapters. Best for processing audio content at scale.",
    "url": "https://assemblyai.com",
    "api_base": "https://api.assemblyai.com/v2",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.assemblyai.com/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: YOUR_API_KEY",
    "how_to_get": "Register at https://www.assemblyai.com — $50 free credit",
    "cost": "$0.37/hour audio. $0.13/hour for nano model"
  },
  "capabilities": [
    {
      "id": "transcribe_audio",
      "description_for_ai": "Transcribe audio files with AssemblyAI. Speaker diarization, sentiment, entity detection included.",
      "intent": [
        "transcribe audio",
        "AssemblyAI STT",
        "speech to text AI",
        "транскрибация AssemblyAI"
      ],
      "endpoint": "POST https://api.assemblyai.com/v2/transcript",
      "input": {
        "audio_url": {
          "type": "string",
          "description": "Public URL of audio/video file",
          "required": true
        },
        "language_code": {
          "type": "string",
          "description": "en, ru, de, fr, es, it, pt, nl, hi, ja, zh. Auto-detected if omitted.",
          "required": false
        },
        "speaker_labels": {
          "type": "boolean",
          "description": "Enable speaker diarization",
          "default": false
        },
        "sentiment_analysis": {
          "type": "boolean",
          "description": "Sentiment per sentence",
          "default": false
        },
        "entity_detection": {
          "type": "boolean",
          "description": "Named entity recognition",
          "default": false
        },
        "auto_highlights": {
          "type": "boolean",
          "description": "Key phrases extraction",
          "default": false
        },
        "summarization": {
          "type": "boolean",
          "description": "Automatic summary",
          "default": false
        }
      },
      "output": {
        "type": "transcript",
        "fields": [
          "id",
          "status (polling required)",
          "text",
          "utterances[0].speaker",
          "utterances[0].text",
          "sentiment_analysis_results[0].sentiment"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_transcript",
      "description_for_ai": "Poll for transcript completion and get results.",
      "intent": [
        "get transcript",
        "transcript status",
        "poll transcription",
        "получить транскрипт"
      ],
      "endpoint": "GET https://api.assemblyai.com/v2/transcript/{transcript_id}",
      "input": {
        "transcript_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "transcript",
        "fields": [
          "id",
          "status (queued/processing/completed/error)",
          "text",
          "words[0].text",
          "words[0].start",
          "words[0].end",
          "words[0].confidence"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "lemur_qa",
      "description_for_ai": "Ask questions about audio content using LeMUR (LLM powered by your transcript).",
      "intent": [
        "audio Q&A",
        "LeMUR questions",
        "ask about recording",
        "вопросы по аудио AssemblyAI"
      ],
      "endpoint": "POST https://api.assemblyai.com/lemur/v3/generate/task",
      "input": {
        "prompt": {
          "type": "string",
          "description": "Question or instruction about the transcript",
          "required": true
        },
        "transcript_ids": {
          "type": "array",
          "description": "Transcript IDs to analyze",
          "required": true
        },
        "context": {
          "type": "string",
          "description": "Background context for better answers",
          "required": false
        },
        "final_model": {
          "type": "string",
          "description": "anthropic/claude-3-5-sonnet or anthropic/claude-3-haiku",
          "default": "anthropic/claude-3-5-sonnet"
        }
      },
      "output": {
        "type": "response",
        "fields": [
          "response",
          "usage.input_tokens",
          "usage.output_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_transcripts",
      "description_for_ai": "List all transcripts with status and creation time.",
      "intent": [
        "list transcripts",
        "transcript history",
        "список транскриптов"
      ],
      "endpoint": "GET https://api.assemblyai.com/v2/transcript",
      "input": {
        "limit": {
          "type": "integer",
          "default": 10
        },
        "status": {
          "type": "string",
          "description": "queued, processing, completed, error",
          "required": false
        }
      },
      "output": {
        "type": "list<transcript>",
        "fields": [
          "transcripts[0].id",
          "transcripts[0].status",
          "transcripts[0].created",
          "transcripts[0].audio_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "realtime_transcription",
      "description_for_ai": "Real-time streaming speech-to-text using AssemblyAI WebSocket API.",
      "intent": [
        "real-time transcription",
        "live STT",
        "streaming speech",
        "транскрибация в реальном времени"
      ],
      "endpoint": "WSS wss://api.assemblyai.com/v2/realtime/ws",
      "input": {
        "sample_rate": {
          "type": "integer",
          "description": "16000 Hz recommended",
          "required": true
        },
        "word_boost": {
          "type": "array",
          "description": "Custom vocabulary words",
          "required": false
        }
      },
      "output": {
        "type": "realtime_transcript",
        "fields": [
          "text (partial result on message_type=PartialTranscript)",
          "text (final on message_type=FinalTranscript)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "async_flow": "1) POST to /transcript with audio_url → get id. 2) Poll GET /transcript/{id} until status=completed. Usually 30-60s for 1h audio.",
    "streaming": "For real-time use WebSocket endpoint wss://api.assemblyai.com/v2/realtime/ws"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}