{
  "apia": "1.0",
  "service": {
    "id": "skyscanner",
    "name": "Skyscanner Flights API",
    "description_for_ai": "Flight price search across 1200+ airlines. Live prices, price calendars, route suggestions. Used by millions of travelers. Requires partnership for full access. Use for flight price comparison, cheapest dates, route search.",
    "url": "https://skyscanner.com",
    "api_base": "https://partners.api.skyscanner.net/apiservices/v3",
    "category": "transport",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.skyscanner.net/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "x-api-key: ...",
    "how_to_get": "Apply at https://developers.skyscanner.net",
    "cost": "Partnership required for production. Test environment available."
  },
  "capabilities": [
    {
      "id": "search_flights",
      "description_for_ai": "Search flight prices on Skyscanner via RapidAPI.",
      "intent": [
        "search flights Skyscanner",
        "cheap flights",
        "flight prices",
        "поиск рейсов Skyscanner"
      ],
      "endpoint": "GET https://skyscanner50.p.rapidapi.com/api/v1/searchFlights",
      "input": {
        "originSkyId": {
          "type": "string",
          "description": "Origin airport IATA: JFK",
          "required": true
        },
        "destinationSkyId": {
          "type": "string",
          "description": "Destination: LHR",
          "required": true
        },
        "originEntityId": {
          "type": "string",
          "description": "Skyscanner entity ID",
          "required": true
        },
        "destinationEntityId": {
          "type": "string",
          "required": true
        },
        "date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "returnDate": {
          "type": "string",
          "description": "YYYY-MM-DD for round trip",
          "required": false
        },
        "cabinClass": {
          "type": "string",
          "description": "economy, premium_economy, business, first",
          "default": "economy"
        },
        "adults": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<itinerary>",
        "fields": [
          "itineraries[0].price.formatted",
          "itineraries[0].legs[0].origin.displayCode",
          "itineraries[0].legs[0].destination.displayCode",
          "itineraries[0].legs[0].durationInMinutes",
          "itineraries[0].legs[0].carriers.marketing[0].name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_locations",
      "description_for_ai": "Search for airport/city identifiers to use in flight searches.",
      "intent": [
        "airport search Skyscanner",
        "city codes flights",
        "origin destination ID",
        "коды аэропортов Skyscanner"
      ],
      "endpoint": "GET https://skyscanner50.p.rapidapi.com/api/v1/searchAirport",
      "input": {
        "query": {
          "type": "string",
          "description": "City or airport name: London, New York",
          "required": true
        },
        "locale": {
          "type": "string",
          "default": "en-US"
        }
      },
      "output": {
        "type": "list<location>",
        "fields": [
          "data[0].entityId",
          "data[0].skyId",
          "data[0].presentation.title",
          "data[0].navigation.entityType (AIRPORT/CITY)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_price_calendar",
      "description_for_ai": "Get a month-view price calendar showing cheapest dates.",
      "intent": [
        "price calendar Skyscanner",
        "cheapest date flights",
        "flexible dates",
        "дешевые даты рейсов"
      ],
      "endpoint": "GET https://skyscanner50.p.rapidapi.com/api/v1/getCalendarMonthlyPrices",
      "input": {
        "originSkyId": {
          "type": "string",
          "required": true
        },
        "destinationSkyId": {
          "type": "string",
          "required": true
        },
        "year": {
          "type": "integer",
          "required": true
        },
        "month": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "calendar",
        "fields": [
          "Days[0].Day",
          "Days[0].Price",
          "Days[0].Direct"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_hotels",
      "description_for_ai": "Search hotels via Skyscanner.",
      "intent": [
        "hotels Skyscanner",
        "accommodation search",
        "hotel prices",
        "отели Skyscanner"
      ],
      "endpoint": "GET https://skyscanner50.p.rapidapi.com/api/v1/searchHotels",
      "input": {
        "entityId": {
          "type": "string",
          "description": "City entity ID",
          "required": true
        },
        "checkin": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "checkout": {
          "type": "string",
          "required": true
        },
        "adults": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<hotel>",
        "fields": [
          "results[0].name",
          "results[0].price.amount",
          "results[0].stars",
          "results[0].reviewScore"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_nearby_airports",
      "description_for_ai": "Find airports near a location by coordinates.",
      "intent": [
        "nearby airports",
        "airports near me",
        "closest airport",
        "аэропорты рядом Skyscanner"
      ],
      "endpoint": "GET https://skyscanner50.p.rapidapi.com/api/v1/getNearbyAirports",
      "input": {
        "lat": {
          "type": "number",
          "required": true
        },
        "lng": {
          "type": "number",
          "required": true
        }
      },
      "output": {
        "type": "list<airport>",
        "fields": [
          "current[0].navigation.entityId",
          "current[0].skyId",
          "current[0].presentation.title",
          "nearby[0].skyId",
          "nearby[0].presentation.title"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "iata_codes": "Use standard IATA codes: LHR=London Heathrow, JFK=New York, SVO=Moscow Sheremetyevo",
    "async": "Create session → poll with session token until status=RESULT_STATUS_COMPLETE"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}