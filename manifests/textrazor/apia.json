{
  "apia": "1.0",
  "service": {
    "id": "textrazor",
    "name": "TextRazor NLP API",
    "description_for_ai": "Deep NLP analysis. Entity extraction, relation detection, topic classification, sentiment, dependency parsing, coreference resolution. 500 req/day free. Use for text understanding, information extraction, document analysis.",
    "url": "https://textrazor.com",
    "api_base": "https://api.textrazor.com",
    "category": "nlp",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.textrazor.com/docs/rest"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "x-textrazor-key: ...",
    "how_to_get": "Register at https://www.textrazor.com/signup — 500 req/day free",
    "cost": "Free: 500/day. Basic: $200/month"
  },
  "capabilities": [
    {
      "id": "analyze_text",
      "description_for_ai": "Perform deep NLP analysis on text: entities, topics, relations, sentiment.",
      "intent": [
        "text analysis TextRazor",
        "NLP analysis",
        "entity extraction",
        "анализ текста TextRazor"
      ],
      "endpoint": "POST https://api.textrazor.com/",
      "input": {
        "text": {
          "type": "string",
          "description": "Text to analyze",
          "required": true
        },
        "extractors": {
          "type": "string",
          "description": "Comma-separated: entities, topics, words, phrases, dependency-trees, relations, entailments, senses",
          "default": "entities,topics"
        }
      },
      "output": {
        "type": "analysis",
        "fields": [
          "response.entities[0].matchedText",
          "response.entities[0].entityId (DBpedia/Wikidata)",
          "response.entities[0].type",
          "response.entities[0].relevanceScore",
          "response.topics[0].label",
          "response.topics[0].score"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "extract_entities",
      "description_for_ai": "Extract named entities linked to knowledge bases (DBpedia, Wikidata, Freebase).",
      "intent": [
        "entity linking TextRazor",
        "knowledge graph entities",
        "named entity recognition",
        "извлечение сущностей TextRazor"
      ],
      "endpoint": "POST https://api.textrazor.com/",
      "input": {
        "text": {
          "type": "string",
          "required": true
        },
        "extractors": {
          "type": "string",
          "default": "entities"
        },
        "entities.filterDbpediaTypes": {
          "type": "string",
          "description": "Filter: Person, Place, Organisation",
          "required": false
        }
      },
      "output": {
        "type": "entities",
        "fields": [
          "response.entities[0].matchedText",
          "response.entities[0].entityId",
          "response.entities[0].dbpediaTypes",
          "response.entities[0].wikidataId",
          "response.entities[0].freebaseId"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "classify_topics",
      "description_for_ai": "Classify text into IAB categories and custom taxonomy.",
      "intent": [
        "topic classification TextRazor",
        "content categorization",
        "IAB taxonomy",
        "классификация тем TextRazor"
      ],
      "endpoint": "POST https://api.textrazor.com/",
      "input": {
        "text": {
          "type": "string",
          "required": true
        },
        "extractors": {
          "type": "string",
          "default": "topics"
        },
        "classifiers": {
          "type": "string",
          "description": "textrazor_iab_taxonomy_2.0, textrazor_newscodes",
          "required": false
        }
      },
      "output": {
        "type": "topics",
        "fields": [
          "response.topics[0].label",
          "response.topics[0].score",
          "response.coarseTopics[0].label"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "analyze_relations",
      "description_for_ai": "Extract semantic relations and subject-verb-object triples from text.",
      "intent": [
        "relation extraction",
        "semantic triples",
        "subject verb object",
        "семантические отношения TextRazor"
      ],
      "endpoint": "POST https://api.textrazor.com/",
      "input": {
        "text": {
          "type": "string",
          "required": true
        },
        "extractors": {
          "type": "string",
          "default": "relations"
        }
      },
      "output": {
        "type": "relations",
        "fields": [
          "response.relations[0].predicatePositions[0].matchedText",
          "response.relations[0].params[0].relation (SUBJECT/OBJECT)",
          "response.relations[0].params[0].entityPositions"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "analyze_url",
      "description_for_ai": "Analyze a webpage URL directly with TextRazor.",
      "intent": [
        "analyze URL TextRazor",
        "webpage analysis NLP",
        "extract entities URL",
        "анализ URL TextRazor"
      ],
      "endpoint": "POST https://api.textrazor.com/",
      "input": {
        "url": {
          "type": "string",
          "description": "Webpage URL to fetch and analyze",
          "required": true
        },
        "extractors": {
          "type": "string",
          "default": "entities,topics"
        }
      },
      "output": {
        "type": "analysis",
        "fields": [
          "response.entities[0].matchedText",
          "response.topics[0].label",
          "response.cleanedText"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}