{
  "apia": "1.0",
  "service": {
    "id": "textrazor",
    "name": "TextRazor NLP API",
    "description_for_ai": "Deep NLP analysis. Entity extraction, relation detection, topic classification, sentiment, dependency parsing, coreference resolution. 500 req/day free. Use for text understanding, information extraction, document analysis.",
    "url": "https://textrazor.com",
    "api_base": "https://api.textrazor.com",
    "category": "nlp",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.textrazor.com/docs/rest"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "x-textrazor-key: ...",
    "how_to_get": "Register at https://www.textrazor.com/signup — 500 req/day free",
    "cost": "Free: 500/day. Basic: $200/month"
  },
  "capabilities": [
    {
      "id": "analyze_text",
      "description_for_ai": "Analyze text with TextRazor: extract entities, topics, relations, and sentiment.",
      "intent": [
        "textrazor analyze",
        "entity extraction",
        "text analysis NLP",
        "анализ текста textrazor"
      ],
      "endpoint": "POST https://api.textrazor.com",
      "input": {
        "text": {
          "type": "string",
          "required": true
        },
        "extractors": {
          "type": "string",
          "description": "Comma-separated: entities, topics, words, phrases, dependency-trees, relations, entailments, senses",
          "default": "entities,topics"
        }
      },
      "output": {
        "type": "analysis",
        "fields": [
          "response.entities[0].matchedText",
          "response.entities[0].entityId",
          "response.entities[0].type",
          "response.topics[0].label",
          "response.topics[0].score"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "extract_entities",
      "description_for_ai": "Extract named entities from text: people, places, organizations.",
      "intent": [
        "NER textrazor",
        "entity recognition",
        "extract names places",
        "извлечение сущностей textrazor"
      ],
      "endpoint": "POST https://api.textrazor.com",
      "input": {
        "text": {
          "type": "string",
          "required": true
        },
        "extractors": {
          "type": "string",
          "default": "entities"
        },
        "entities.filterDbpediaTypes": {
          "type": "string",
          "description": "Filter by type: Person, Place, Organisation",
          "required": false
        }
      },
      "output": {
        "type": "entities",
        "fields": [
          "response.entities[0].matchedText",
          "response.entities[0].entityId",
          "response.entities[0].type[0]",
          "response.entities[0].confidenceScore"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "classify_topics",
      "description_for_ai": "Classify text into IAB topics and custom categories.",
      "intent": [
        "topic classification textrazor",
        "content categorization",
        "text topics",
        "классификация тем textrazor"
      ],
      "endpoint": "POST https://api.textrazor.com",
      "input": {
        "text": {
          "type": "string",
          "required": true
        },
        "extractors": {
          "type": "string",
          "default": "topics"
        },
        "classifiers": {
          "type": "string",
          "description": "textrazor_iab_categories_1.0, textrazor_newscodes, custom classifiers",
          "required": false
        }
      },
      "output": {
        "type": "topics",
        "fields": [
          "response.topics[0].label",
          "response.topics[0].score (0-1)",
          "response.topics[0].wikiLink"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "analyze_relations",
      "description_for_ai": "Extract semantic relations (subject-verb-object) from text.",
      "intent": [
        "relations extraction textrazor",
        "SVO triples",
        "semantic relations",
        "семантические отношения textrazor"
      ],
      "endpoint": "POST https://api.textrazor.com",
      "input": {
        "text": {
          "type": "string",
          "required": true
        },
        "extractors": {
          "type": "string",
          "default": "relations,entities"
        }
      },
      "output": {
        "type": "relations",
        "fields": [
          "response.relations[0].predicate.matchedText",
          "response.relations[0].params[0].role",
          "response.relations[0].params[0].entity.matchedText"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "custom_rule_classifier",
      "description_for_ai": "Run custom TextRazor rules to extract domain-specific information.",
      "intent": [
        "custom rules textrazor",
        "domain extraction",
        "rule-based NLP",
        "пользовательские правила textrazor"
      ],
      "endpoint": "POST https://api.textrazor.com",
      "input": {
        "text": {
          "type": "string",
          "required": true
        },
        "rules": {
          "type": "string",
          "description": "TextRazor rules string",
          "required": true
        },
        "extractors": {
          "type": "string",
          "default": "entities,relations"
        }
      },
      "output": {
        "type": "custom",
        "fields": [
          "response.customAnnotations[0].contents"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}