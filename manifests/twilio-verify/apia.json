{
  "apia": "1.0",
  "service": {
    "id": "twilio-verify",
    "name": "Twilio Verify API",
    "description_for_ai": "Two-factor authentication API. Send OTP via SMS, WhatsApp, email, or voice call. Verify user phone numbers. Global delivery. Pay per verification. Replaces building your own OTP system.",
    "url": "https://twilio.com/verify",
    "api_base": "https://verify.twilio.com/v2",
    "category": "security",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.twilio.com/docs/verify/api"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "Account SID + Auth Token",
    "how_to_get": "Twilio Console → Verify → Services",
    "cost": "$0.05-0.10 per verification"
  },
  "capabilities": [
    {
      "id": "send_verification",
      "description_for_ai": "Send OTP verification code via SMS, WhatsApp, voice call, or email.",
      "intent": [
        "send OTP",
        "SMS verification",
        "two-factor auth",
        "отправить OTP код"
      ],
      "endpoint": "POST https://verify.twilio.com/v2/Services/{ServiceSid}/Verifications",
      "input": {
        "ServiceSid": {
          "type": "string",
          "description": "Twilio Verify service SID",
          "required": true
        },
        "To": {
          "type": "string",
          "description": "Phone number in E.164 format: +79001234567",
          "required": true
        },
        "Channel": {
          "type": "string",
          "description": "sms, whatsapp, call, email, totp",
          "required": true
        }
      },
      "output": {
        "type": "verification",
        "fields": [
          "sid",
          "status",
          "to",
          "channel",
          "date_created"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "check_verification",
      "description_for_ai": "Verify the OTP code entered by a user.",
      "intent": [
        "verify OTP",
        "check code",
        "validate SMS code",
        "проверить OTP код"
      ],
      "endpoint": "POST https://verify.twilio.com/v2/Services/{ServiceSid}/VerificationCheck",
      "input": {
        "ServiceSid": {
          "type": "string",
          "required": true
        },
        "To": {
          "type": "string",
          "description": "Phone number that received the code",
          "required": true
        },
        "Code": {
          "type": "string",
          "description": "6-digit code entered by user",
          "required": true
        }
      },
      "output": {
        "type": "verification",
        "fields": [
          "status (approved/pending/canceled)",
          "valid (boolean)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_service",
      "description_for_ai": "Create a new Twilio Verify service for your application.",
      "intent": [
        "create Verify service",
        "setup 2FA service",
        "Twilio Verify setup",
        "создать сервис верификации Twilio"
      ],
      "endpoint": "POST https://verify.twilio.com/v2/Services",
      "input": {
        "FriendlyName": {
          "type": "string",
          "description": "Your service name shown to users",
          "required": true
        },
        "CodeLength": {
          "type": "integer",
          "description": "OTP length 4-10",
          "default": 6
        },
        "LookupEnabled": {
          "type": "boolean",
          "description": "Validate phone number before sending",
          "default": true
        }
      },
      "output": {
        "type": "service",
        "fields": [
          "sid",
          "friendly_name",
          "code_length",
          "date_created"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_verification_attempts",
      "description_for_ai": "Get a log of all verification attempts for security monitoring.",
      "intent": [
        "verification log",
        "OTP attempts",
        "security audit 2FA",
        "журнал верификаций Twilio"
      ],
      "endpoint": "GET https://verify.twilio.com/v2/Attempts",
      "input": {
        "DateCreatedAfter": {
          "type": "string",
          "description": "ISO 8601 date filter",
          "required": false
        },
        "To": {
          "type": "string",
          "required": false
        },
        "Channel": {
          "type": "string",
          "required": false
        },
        "VerificationSid": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<attempt>",
        "fields": [
          "attempts[0].sid",
          "attempts[0].date_created",
          "attempts[0].channel_data.to",
          "attempts[0].conversion_status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "rate_limits",
      "description_for_ai": "Configure rate limits to prevent OTP abuse (too many requests from same IP/phone).",
      "intent": [
        "rate limit OTP",
        "prevent OTP abuse",
        "security rate limit",
        "лимит запросов OTP"
      ],
      "endpoint": "POST https://verify.twilio.com/v2/Services/{ServiceSid}/RateLimits",
      "input": {
        "ServiceSid": {
          "type": "string",
          "required": true
        },
        "UniqueName": {
          "type": "string",
          "description": "Rate limit name e.g. per-phone or per-ip",
          "required": true
        },
        "Description": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "rate_limit",
        "fields": [
          "sid",
          "unique_name",
          "service_sid",
          "date_created"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}