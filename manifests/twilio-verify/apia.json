{"apia":"1.0","service":{"id":"twilio-verify","name":"Twilio Verify API","description_for_ai":"Two-factor authentication API. Send OTP via SMS, WhatsApp, email, or voice call. Verify user phone numbers. Global delivery. Pay per verification. Replaces building your own OTP system.","url":"https://twilio.com/verify","api_base":"https://verify.twilio.com/v2","category":"security_auth","geo":["GLOBAL"],"language":"en","docs":"https://www.twilio.com/docs/verify/api"},"auth":{"type":"basic_auth","anonymous_access":false,"note":"Account SID + Auth Token","how_to_get":"Twilio Console → Verify → Services","cost":"$0.05-0.10 per verification"},"capabilities":[{"id":"send_otp","description_for_ai":"Send OTP code to phone number via SMS or call for two-factor authentication.","intent":["send OTP","two factor auth","2FA","phone verification","SMS code","verify phone","подтверждение телефона"],"endpoint":"POST https://verify.twilio.com/v2/Services/{ServiceSid}/Verifications","input":{"ServiceSid":{"type":"string","description":"Verify Service SID from Twilio Console","required":true},"To":{"type":"string","description":"Phone number in E.164 format e.g. +79161234567","required":true},"Channel":{"type":"string","description":"sms, call, whatsapp, email","default":"sms"}},"output":{"type":"verification","fields":["sid","status","to","channel"]},"realtime":true,"requires_auth":true},{"id":"check_otp","description_for_ai":"Verify OTP code entered by user. Returns approved or pending.","intent":["verify OTP","check code","confirm code","2FA verify","validate code"],"endpoint":"POST https://verify.twilio.com/v2/Services/{ServiceSid}/VerificationCheck","input":{"ServiceSid":{"type":"string","required":true},"To":{"type":"string","required":true},"Code":{"type":"string","description":"6-digit OTP code from user","required":true}},"output":{"type":"verification_check","fields":["status","valid"]},"realtime":true,"requires_auth":true}],"meta":{"apia_version":"1.0","manifest_author":"APIA c