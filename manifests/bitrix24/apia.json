{
  "apia": "1.0",
  "service": {
    "id": "bitrix24",
    "name": "Bitrix24 REST API",
    "description_for_ai": "Популярная платформа для бизнеса в России и СНГ. CRM, задачи, проекты, коммуникации, HR, документооборот. Бесплатный план до 5 пользователей. Используй для управления компанией, CRM, задачами.",
    "url": "https://bitrix24.ru",
    "api_base": "https://{portal}.bitrix24.ru/rest",
    "category": "business",
    "geo": [
      "RU",
      "BY",
      "KZ",
      "UA",
      "GLOBAL"
    ],
    "language": "ru",
    "docs": "https://apidocs.bitrix24.ru/"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Приложения → Добавить приложение → Вебхук или OAuth",
    "cost": "Бесплатно до 5 пользователей. Базовый от 2490 руб/мес"
  },
  "capabilities": [
    {
      "id": "crm_lead_list",
      "description_for_ai": "Get CRM leads from Bitrix24. Filter by status, responsible user, date. Returns ID, title, name, phone, email, status.",
      "intent": [
        "лиды Битрикс",
        "CRM Битрикс24",
        "сделки Битрикс",
        "клиенты Битрикс"
      ],
      "endpoint": "POST https://{portal}.bitrix24.ru/rest/crm.lead.list",
      "input": {
        "filter": {
          "type": "object",
          "description": "Filter by fields: {STATUS_ID: 'NEW', ASSIGNED_BY_ID: 1, >DATE_CREATE: '2024-01-01'}. Empty {} returns all.",
          "required": false
        },
        "select": {
          "type": "array",
          "description": "Fields to return: ['ID','TITLE','NAME','LAST_NAME','PHONE','EMAIL','STATUS_ID','ASSIGNED_BY_ID','DATE_CREATE']",
          "required": false
        },
        "order": {
          "type": "object",
          "description": "Sort: {DATE_CREATE: 'DESC'} or {TITLE: 'ASC'}",
          "required": false
        },
        "start": {
          "type": "integer",
          "description": "Pagination offset (50 per page)",
          "default": 0
        }
      },
      "output": {
        "type": "list<lead>",
        "fields": [
          "ID",
          "TITLE",
          "NAME",
          "LAST_NAME",
          "PHONE",
          "EMAIL",
          "STATUS_ID",
          "ASSIGNED_BY_ID"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "task_add",
      "description_for_ai": "Create a new task in Bitrix24. Assign to user, set deadline, add description and checklist items.",
      "intent": [
        "создать задачу",
        "добавить задачу Битрикс",
        "новая задача",
        "task Bitrix"
      ],
      "endpoint": "POST https://{portal}.bitrix24.ru/rest/tasks.task.add",
      "input": {
        "fields": {
          "type": "object",
          "description": "{TITLE: 'Task name' (required), RESPONSIBLE_ID: user_id, DESCRIPTION: 'Details', DEADLINE: '2024-12-31T18:00:00+03:00', PRIORITY: 0|1|2, GROUP_ID: group_id, PARENT_ID: parent_task_id}",
          "required": true
        }
      },
      "output": {
        "type": "task",
        "fields": [
          "task.id",
          "task.title"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_crm_leads",
      "description_for_ai": "List CRM leads in Bitrix24.",
      "intent": [
        "лиды bitrix24",
        "crm leads bitrix",
        "список лидов"
      ],
      "endpoint": "POST https://{portal}.bitrix24.ru/rest/crm.lead.list.json",
      "input": {
        "order": {
          "type": "object",
          "description": "{DATE_CREATE: DESC}",
          "required": false
        },
        "filter": {
          "type": "object",
          "description": "{ASSIGNED_BY_ID: 1}",
          "required": false
        },
        "select": {
          "type": "array",
          "description": "['ID', 'TITLE', 'STATUS_ID', 'DATE_CREATE']",
          "required": false
        }
      },
      "output": {
        "type": "list<lead>",
        "fields": [
          "result[0].ID",
          "result[0].TITLE",
          "result[0].STATUS_ID",
          "result[0].DATE_CREATE"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_task",
      "description_for_ai": "Create a task in Bitrix24.",
      "intent": [
        "задача bitrix24",
        "create task bitrix",
        "новая задача bitrix"
      ],
      "endpoint": "POST https://{portal}.bitrix24.ru/rest/tasks.task.add.json",
      "input": {
        "fields": {
          "type": "object",
          "description": "{TITLE: 'Task', RESPONSIBLE_ID: 1, DEADLINE: '2024-12-31T18:00:00'}",
          "required": true
        }
      },
      "output": {
        "type": "task",
        "fields": [
          "result.task.id",
          "result.task.title",
          "result.task.status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_message",
      "description_for_ai": "Send a message in Bitrix24 chat or notification.",
      "intent": [
        "сообщение bitrix24",
        "чат bitrix",
        "уведомление bitrix24"
      ],
      "endpoint": "POST https://{portal}.bitrix24.ru/rest/im.message.add.json",
      "input": {
        "DIALOG_ID": {
          "type": "string",
          "description": "User ID (U123) or chat ID (chat123)",
          "required": true
        },
        "MESSAGE": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "result (message ID)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "auth": "Use webhook or OAuth. Webhook: Settings → Developer resources → Inbound webhooks. Scope: task, crm.",
    "portal": "Replace {portal} with your Bitrix24 subdomain e.g. mycompany.bitrix24.ru",
    "pagination": "All list methods return 50 items max. Use start=50, 100, 150... to paginate.",
    "ru_market": "Most popular all-in-one business platform in Russia and CIS. Includes CRM, tasks, HR, documents, chat."
  }
}