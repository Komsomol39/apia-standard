{
  "apia": "1.0",
  "service": {
    "id": "bitrix24",
    "name": "Bitrix24 REST API",
    "description_for_ai": "Популярная платформа для бизнеса в России и СНГ. CRM, задачи, проекты, коммуникации, HR, документооборот. Бесплатный план до 5 пользователей. Используй для управления компанией, CRM, задачами.",
    "url": "https://bitrix24.ru",
    "api_base": "https://{portal}.bitrix24.ru/rest",
    "category": "crm_business",
    "geo": [
      "RU",
      "BY",
      "KZ",
      "UA",
      "GLOBAL"
    ],
    "language": "ru",
    "docs": "https://apidocs.bitrix24.ru/"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Приложения → Добавить приложение → Вебхук или OAuth",
    "cost": "Бесплатно до 5 пользователей. Базовый от 2490 руб/мес"
  },
  "capabilities": [
    {
      "id": "crm_lead_list",
      "description_for_ai": "Получить список лидов CRM Битрикс24.",
      "intent": [
        "лиды Битрикс",
        "CRM Битрикс24",
        "сделки Битрикс",
        "клиенты Битрикс"
      ],
      "endpoint": "POST https://{portal}.bitrix24.ru/rest/crm.lead.list",
      "input": {
        "filter": {
          "type": "object",
          "description": "{STATUS_ID: NEW, ASSIGNED_BY_ID: 1}",
          "required": false
        },
        "select": {
          "type": "array",
          "description": "Fields to return",
          "required": false
        },
        "order": {
          "type": "object",
          "description": "{DATE_CREATE: DESC}",
          "required": false
        }
      },
      "output": {
        "type": "list<lead>",
        "fields": [
          "ID",
          "TITLE",
          "NAME",
          "LAST_NAME",
          "PHONE",
          "EMAIL",
          "STATUS_ID",
          "ASSIGNED_BY_ID"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "task_add",
      "description_for_ai": "Создать задачу в Битрикс24.",
      "intent": [
        "создать задачу",
        "добавить задачу Битрикс",
        "новая задача",
        "task Bitrix"
      ],
      "endpoint": "POST https://{portal}.bitrix24.ru/rest/tasks.task.add",
      "input": {
        "fields": {
          "type": "object",
          "description": "{TITLE, DESCRIPTION, RESPONSIBLE_ID, DEADLINE}",
          "required": true
        }
      },
      "output": {
        "type": "task",
        "fields": [
          "task.id",
          "task.title"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}