{
  "apia": "1.0",
  "service": {
    "id": "woocommerce",
    "name": "WooCommerce REST API",
    "description_for_ai": "WooCommerce powers 30% of all online stores. REST API to manage products, orders, customers, inventory on any WordPress site with WooCommerce installed.",
    "url": "https://woocommerce.com",
    "api_base": "https://{domain}/wp-json/wc/v3",
    "category": "ecommerce",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://woocommerce.github.io/woocommerce-rest-api-docs/"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "Use Consumer Key and Consumer Secret generated in WooCommerce settings",
    "how_to_get": "WooCommerce → Settings → Advanced → REST API",
    "cost": "Free (part of WooCommerce plugin)"
  },
  "capabilities": [
    {
      "id": "list_products",
      "description_for_ai": "List WooCommerce products with filters.",
      "intent": [
        "WooCommerce products",
        "shop products",
        "list products WP",
        "товары WooCommerce"
      ],
      "endpoint": "GET https://{site}/wp-json/wc/v3/products",
      "input": {
        "status": {
          "type": "string",
          "description": "publish, draft, pending",
          "default": "publish"
        },
        "category": {
          "type": "string",
          "description": "Category ID",
          "required": false
        },
        "search": {
          "type": "string",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 20
        },
        "orderby": {
          "type": "string",
          "description": "date, modified, id, title, price, popularity, rating",
          "default": "date"
        }
      },
      "output": {
        "type": "list<product>",
        "fields": [
          "[0].id",
          "[0].name",
          "[0].price",
          "[0].stock_status",
          "[0].permalink",
          "[0].categories[0].name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_product",
      "description_for_ai": "Create a new WooCommerce product.",
      "intent": [
        "add product WooCommerce",
        "create product shop",
        "новый товар WooCommerce"
      ],
      "endpoint": "POST https://{site}/wp-json/wc/v3/products",
      "input": {
        "name": {
          "type": "string",
          "required": true
        },
        "type": {
          "type": "string",
          "description": "simple, variable, grouped, external",
          "default": "simple"
        },
        "regular_price": {
          "type": "string",
          "required": true
        },
        "description": {
          "type": "string",
          "required": false
        },
        "short_description": {
          "type": "string",
          "required": false
        },
        "categories": {
          "type": "array",
          "description": "[{id: 123}]",
          "required": false
        },
        "images": {
          "type": "array",
          "description": "[{src: 'https://...'}]",
          "required": false
        },
        "manage_stock": {
          "type": "boolean",
          "default": false
        },
        "stock_quantity": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "product",
        "fields": [
          "id",
          "name",
          "permalink",
          "status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_orders",
      "description_for_ai": "Get WooCommerce orders with status filtering.",
      "intent": [
        "WooCommerce orders",
        "shop orders",
        "заказы WooCommerce"
      ],
      "endpoint": "GET https://{site}/wp-json/wc/v3/orders",
      "input": {
        "status": {
          "type": "string",
          "description": "pending, processing, on-hold, completed, cancelled, refunded, failed",
          "default": "processing"
        },
        "after": {
          "type": "string",
          "description": "ISO 8601 date",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<order>",
        "fields": [
          "[0].id",
          "[0].status",
          "[0].total",
          "[0].billing.email",
          "[0].line_items[0].name",
          "[0].date_created"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_order_status",
      "description_for_ai": "Update WooCommerce order status (e.g., mark as shipped/completed).",
      "intent": [
        "update order WooCommerce",
        "complete order",
        "ship order",
        "статус заказа WooCommerce"
      ],
      "endpoint": "PUT https://{site}/wp-json/wc/v3/orders/{id}",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        },
        "status": {
          "type": "string",
          "description": "processing, completed, cancelled, on-hold, refunded",
          "required": true
        },
        "customer_note": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "order",
        "fields": [
          "id",
          "status",
          "date_modified"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "manage_coupons",
      "description_for_ai": "Create discount coupons for WooCommerce store.",
      "intent": [
        "WooCommerce coupon",
        "discount code",
        "promo code WooCommerce",
        "купон WooCommerce"
      ],
      "endpoint": "POST https://{site}/wp-json/wc/v3/coupons",
      "input": {
        "code": {
          "type": "string",
          "description": "Coupon code",
          "required": true
        },
        "discount_type": {
          "type": "string",
          "description": "percent, fixed_cart, fixed_product",
          "required": true
        },
        "amount": {
          "type": "string",
          "description": "Discount amount or percentage",
          "required": true
        },
        "expiry_date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        },
        "usage_limit": {
          "type": "integer",
          "required": false
        },
        "minimum_amount": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "coupon",
        "fields": [
          "id",
          "code",
          "discount_type",
          "amount",
          "expiry_date"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "auth": "Generate keys: WooCommerce → Settings → Advanced → REST API. Use Consumer Key + Secret as basic auth.",
    "domain": "Replace {domain} with your WordPress site domain e.g. myshop.com. HTTPS required for production.",
    "webhooks": "Set up order/product webhooks in WooCommerce → Settings → Advanced → Webhooks for real-time events.",
    "pagination": "Use page and per_page params. Total pages in X-WP-TotalPages response header."
  }
}