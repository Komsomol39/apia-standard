{
  "apia": "1.0",
  "service": {
    "id": "woocommerce",
    "name": "WooCommerce REST API",
    "description_for_ai": "WooCommerce powers 30% of all online stores. REST API to manage products, orders, customers, inventory on any WordPress site with WooCommerce installed.",
    "url": "https://woocommerce.com",
    "api_base": "https://{domain}/wp-json/wc/v3",
    "category": "ecommerce",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://woocommerce.github.io/woocommerce-rest-api-docs/"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "Use Consumer Key and Consumer Secret generated in WooCommerce settings",
    "how_to_get": "WooCommerce → Settings → Advanced → REST API",
    "cost": "Free (part of WooCommerce plugin)"
  },
  "capabilities": [
    {
      "id": "get_products",
      "description_for_ai": "Get products from WooCommerce store with prices, stock status, images, categories, and attributes.",
      "intent": [
        "woocommerce products",
        "wordpress store products",
        "get catalog"
      ],
      "endpoint": "GET https://{domain}/wp-json/wc/v3/products",
      "input": {
        "per_page": {
          "type": "integer",
          "description": "Results per page, max 100",
          "default": 20
        },
        "page": {
          "type": "integer",
          "default": 1
        },
        "status": {
          "type": "string",
          "description": "publish, draft, pending, private, trash",
          "default": "publish"
        },
        "search": {
          "type": "string",
          "description": "Search products by name or SKU",
          "required": false
        },
        "category": {
          "type": "string",
          "description": "Category ID to filter by",
          "required": false
        },
        "stock_status": {
          "type": "string",
          "description": "instock, outofstock, onbackorder",
          "required": false
        },
        "min_price": {
          "type": "string",
          "description": "Minimum price filter",
          "required": false
        },
        "max_price": {
          "type": "string",
          "description": "Maximum price filter",
          "required": false
        },
        "orderby": {
          "type": "string",
          "description": "date, title, price, popularity, rating",
          "default": "date"
        },
        "order": {
          "type": "string",
          "description": "asc or desc",
          "default": "desc"
        }
      },
      "output": {
        "type": "list<product>",
        "fields": [
          "id",
          "name",
          "price",
          "regular_price",
          "stock_status",
          "images[0].src",
          "categories"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_order",
      "description_for_ai": "Create a new WooCommerce order with customer info, line items, shipping, and payment method.",
      "intent": [
        "create order",
        "new order",
        "place order",
        "woocommerce order"
      ],
      "endpoint": "POST https://{domain}/wp-json/wc/v3/orders",
      "input": {
        "payment_method": {
          "type": "string",
          "description": "Payment method ID: bacs (bank transfer), cheque, cod (cash on delivery), stripe, paypal",
          "required": true
        },
        "payment_method_title": {
          "type": "string",
          "description": "Human-readable payment method name",
          "required": false
        },
        "set_paid": {
          "type": "boolean",
          "description": "true to mark order as paid immediately",
          "default": false
        },
        "billing": {
          "type": "object",
          "description": "{first_name, last_name, email, phone, address_1, city, state, postcode, country: 'US'}",
          "required": true
        },
        "shipping": {
          "type": "object",
          "description": "Same structure as billing, for delivery address",
          "required": false
        },
        "line_items": {
          "type": "array",
          "description": "[{product_id: 123, quantity: 2, variation_id: 456}]",
          "required": true
        },
        "shipping_lines": {
          "type": "array",
          "description": "[{method_id: 'flat_rate', method_title: 'Flat Rate', total: '5.00'}]",
          "required": false
        },
        "coupon_lines": {
          "type": "array",
          "description": "[{code: 'DISCOUNT10'}]",
          "required": false
        },
        "customer_id": {
          "type": "integer",
          "description": "Existing customer ID (0 for guest)",
          "default": 0
        }
      },
      "output": {
        "type": "order",
        "fields": [
          "id",
          "number",
          "total",
          "status",
          "order_key"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "auth": "Generate keys: WooCommerce → Settings → Advanced → REST API. Use Consumer Key + Secret as basic auth.",
    "domain": "Replace {domain} with your WordPress site domain e.g. myshop.com. HTTPS required for production.",
    "webhooks": "Set up order/product webhooks in WooCommerce → Settings → Advanced → Webhooks for real-time events.",
    "pagination": "Use page and per_page params. Total pages in X-WP-TotalPages response header."
  }
}