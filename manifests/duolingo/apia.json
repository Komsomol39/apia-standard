{
  "apia": "1.0",
  "service": {
    "id": "duolingo",
    "name": "Duolingo API (Unofficial)",
    "description_for_ai": "Duolingo language learning platform data. User stats, streak, XP, language progress, course info. Unofficial public API — no authentication needed for public profiles.",
    "url": "https://duolingo.com",
    "api_base": "https://www.duolingo.com",
    "category": "science",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://github.com/KartikTalwar/Duolingo",
    "access_note": "Unofficial API — may change without notice"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "get_user_profile",
      "description_for_ai": "Get Duolingo user profile: streak, XP, leagues, languages.",
      "intent": [
        "duolingo profile",
        "duolingo user stats",
        "language learning stats",
        "профиль duolingo"
      ],
      "endpoint": "GET https://www.duolingo.com/2017-06-30/users/{userId}",
      "input": {
        "userId": {
          "type": "integer",
          "description": "Duolingo user ID",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "Comma-separated fields: streak,courses,xpGains,leaderboardLeague,lingots,gems,totalXp",
          "required": false
        }
      },
      "output": {
        "type": "profile",
        "fields": [
          "username",
          "streak",
          "totalXp",
          "courses[0].title",
          "courses[0].xp",
          "learningLanguage",
          "fromLanguage"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_courses",
      "description_for_ai": "Get all available Duolingo courses (language pairs).",
      "intent": [
        "duolingo courses",
        "available languages duolingo",
        "language courses",
        "курсы duolingo"
      ],
      "endpoint": "GET https://www.duolingo.com/api/1/store/get_items?_=",
      "input": {},
      "output": {
        "type": "list<course>",
        "fields": [
          "courses[0].title",
          "courses[0].learning_language",
          "courses[0].from_language",
          "courses[0].num_learners"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_leaderboard",
      "description_for_ai": "Get Duolingo weekly XP leaderboard for a user's league.",
      "intent": [
        "duolingo leaderboard",
        "XP ranking",
        "league standings",
        "рейтинг duolingo"
      ],
      "endpoint": "GET https://duolingo-leaderboards-prod.duolingo.com/users/{userId}/leaderboards/7d7d7d7d-7d7d-7d7d-7d7d-7d7d7d7d7d7d/",
      "input": {
        "userId": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "leaderboard",
        "fields": [
          "active_cohort.rankings[0].user_id",
          "active_cohort.rankings[0].score",
          "active_cohort.rankings[0].rank"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_users",
      "description_for_ai": "Search for Duolingo users by username.",
      "intent": [
        "find duolingo user",
        "search duolingo",
        "duolingo username lookup",
        "найти пользователя duolingo"
      ],
      "endpoint": "GET https://www.duolingo.com/users/{username}",
      "input": {
        "username": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "profile",
        "fields": [
          "id",
          "username",
          "streak",
          "totalXp",
          "courses[0].title",
          "bio"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_daily_xp",
      "description_for_ai": "Get daily XP history for a Duolingo user.",
      "intent": [
        "duolingo XP history",
        "daily progress duolingo",
        "XP per day",
        "прогресс duolingo"
      ],
      "endpoint": "GET https://www.duolingo.com/2017-06-30/users/{userId}",
      "input": {
        "userId": {
          "type": "integer",
          "required": true
        },
        "fields": {
          "type": "string",
          "default": "xpGains"
        }
      },
      "output": {
        "type": "xp_history",
        "fields": [
          "xpGains[0].gainedXp",
          "xpGains[0].time",
          "xpGains[0].skillId"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "unofficial": "This is an unofficial API. Duolingo may change or block it. Use for read-only profile data only.",
    "username": "Duolingo username from profile URL: duolingo.com/profile/{username}"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}