{
  "apia": "1.0",
  "service": {
    "id": "duolingo",
    "name": "Duolingo API (Unofficial)",
    "description_for_ai": "Duolingo language learning platform data. User stats, streak, XP, language progress, course info. Unofficial public API — no authentication needed for public profiles.",
    "url": "https://duolingo.com",
    "api_base": "https://www.duolingo.com",
    "category": "science",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://github.com/KartikTalwar/Duolingo",
    "access_note": "Unofficial API — may change without notice"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "get_user_info",
      "description_for_ai": "Get Duolingo user profile: XP, streak, languages, courses.",
      "intent": [
        "Duolingo profile",
        "user stats Duolingo",
        "XP Duolingo",
        "профиль Duolingo"
      ],
      "endpoint": "GET https://www.duolingo.com/2017-06-30/users/{userId}",
      "input": {
        "userId": {
          "type": "integer",
          "description": "Duolingo user ID",
          "required": true
        }
      },
      "output": {
        "type": "user",
        "fields": [
          "id",
          "username",
          "name",
          "streak",
          "totalXp",
          "courses[0].learningLanguage",
          "courses[0].xp",
          "courses[0].crowns"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_streak",
      "description_for_ai": "Get Duolingo user streak calendar and current streak.",
      "intent": [
        "Duolingo streak",
        "daily streak",
        "learning streak",
        "серия Duolingo"
      ],
      "endpoint": "GET https://www.duolingo.com/2017-06-30/users/{userId}/xp_summaries",
      "input": {
        "userId": {
          "type": "integer",
          "required": true
        },
        "startDate": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        }
      },
      "output": {
        "type": "streak",
        "fields": [
          "streakData.currentStreak.length",
          "streakData.currentStreak.startDate",
          "xpSummaries[0].date",
          "xpSummaries[0].gainedXp"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_leaderboard",
      "description_for_ai": "Get the Duolingo weekly XP leaderboard (friends or global).",
      "intent": [
        "Duolingo leaderboard",
        "weekly ranking",
        "XP ranking",
        "лидерборд Duolingo"
      ],
      "endpoint": "GET https://duolingo-leaderboards-prod.duolingo.com/leaderboards/7d9f5dd1-8423-491a-91f2-2532052038ce/users/{userId}",
      "input": {
        "userId": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "leaderboard",
        "fields": [
          "active[0].display_name",
          "active[0].score",
          "active[0].rank"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_courses",
      "description_for_ai": "Get all available Duolingo language courses.",
      "intent": [
        "Duolingo courses",
        "available languages Duolingo",
        "language courses",
        "курсы Duolingo"
      ],
      "endpoint": "GET https://www.duolingo.com/api/1/version_info",
      "input": {},
      "output": {
        "type": "list<course>",
        "fields": [
          "supported_directions[0].learning_language_name",
          "supported_directions[0].from_language_name",
          "supported_directions[0].course_id"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_user_friends",
      "description_for_ai": "Get a Duolingo user's friends/followers list.",
      "intent": [
        "Duolingo friends",
        "Duolingo followers",
        "following Duolingo",
        "друзья Duolingo"
      ],
      "endpoint": "GET https://www.duolingo.com/2017-06-30/users/{userId}/friends",
      "input": {
        "userId": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "list<friend>",
        "fields": [
          "users[0].userId",
          "users[0].name",
          "users[0].username",
          "users[0].weeklyXp",
          "users[0].streak"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "unofficial": "This is an unofficial API. Duolingo may change or block it. Use for read-only profile data only.",
    "username": "Duolingo username from profile URL: duolingo.com/profile/{username}"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}