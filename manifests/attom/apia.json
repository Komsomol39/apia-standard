{
  "apia": "1.0",
  "service": {
    "id": "attom",
    "name": "ATTOM Property Data API",
    "description_for_ai": "ATTOM Property Data API — comprehensive US property intelligence. 155M+ properties with assessment values, ownership history, sales transactions, mortgage data, foreclosures, school ratings, natural hazard scores, and neighborhood demographics. Used by real estate, mortgage, and insurance companies.",
    "url": "https://attomdata.com",
    "api_base": "https://api.gateway.attomdata.com/propertyapi/v1.0.0",
    "category": "real_estate_data",
    "geo": [
      "US"
    ],
    "language": "en",
    "docs": "https://api.developer.attomdata.com/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "apikey: ...",
    "how_to_get": "Register at https://api.developer.attomdata.com",
    "cost": "Trial available. Paid plans from $199/month"
  },
  "capabilities": [
    {
      "id": "get_property_detail",
      "description_for_ai": "Get full property details: assessed value, tax info, lot size, year built, bedrooms, bathrooms, last sale price and date.",
      "intent": [
        "home assessment",
        "property tax info",
        "house info",
        "property history",
        "tax assessment",
        "home valuation",
        "US property data",
        "home value",
        "real estate data",
        "property details",
        "property data"
      ],
      "endpoint": "GET https://api.gateway.attomdata.com/propertyapi/v1.0.0/property/detail",
      "input": {
        "address1": {
          "type": "string",
          "description": "Street address",
          "required": true
        },
        "address2": {
          "type": "string",
          "description": "City State ZIP",
          "required": true
        }
      },
      "output": {
        "type": "property",
        "fields": [
          "identifier.attomId",
          "address.line1",
          "summary.proptype",
          "building.rooms.beds",
          "building.rooms.bathstotal",
          "building.size.universalsize",
          "assessment.assessed.assdttlvalue",
          "sale.amount.saleamt",
          "sale.salesearchdate"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}