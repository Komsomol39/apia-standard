{
  "apia": "1.0",
  "service": {
    "id": "attom",
    "name": "ATTOM Property Data API",
    "description_for_ai": "ATTOM Property Data API — comprehensive US property intelligence. 155M+ properties with assessment values, ownership history, sales transactions, mortgage data, foreclosures, school ratings, natural hazard scores, and neighborhood demographics. Used by real estate, mortgage, and insurance companies.",
    "url": "https://attomdata.com",
    "api_base": "https://api.gateway.attomdata.com/propertyapi/v1.0.0",
    "category": "real_estate",
    "geo": [
      "US"
    ],
    "language": "en",
    "docs": "https://api.developer.attomdata.com/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "apikey: ...",
    "how_to_get": "Register at https://api.developer.attomdata.com",
    "cost": "Trial available. Paid plans from $199/month"
  },
  "capabilities": [
    {
      "id": "property_detail",
      "description_for_ai": "Get full property details by address or AVM ID: beds, baths, sqft, year built.",
      "intent": [
        "property details ATTOM",
        "home info",
        "real estate data",
        "данные о недвижимости ATTOM"
      ],
      "endpoint": "GET https://api.gateway.attomdata.com/propertyapi/v1.0.0/property/detail",
      "input": {
        "address1": {
          "type": "string",
          "description": "Street address: 4529 Winona Court",
          "required": false
        },
        "address2": {
          "type": "string",
          "description": "City, state, zip: Denver CO 80212",
          "required": false
        },
        "attomid": {
          "type": "integer",
          "description": "ATTOM property ID (alternative to address)",
          "required": false
        }
      },
      "output": {
        "type": "property",
        "fields": [
          "property[0].identifier.attomId",
          "property[0].address.line1",
          "property[0].building.rooms.beds",
          "property[0].building.rooms.bathsfull",
          "property[0].building.size.livingsize",
          "property[0].summary.yearbuilt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "property_search",
      "description_for_ai": "Search properties in a ZIP code or city with ATTOM.",
      "intent": [
        "property search ATTOM",
        "homes in area",
        "real estate search",
        "поиск недвижимости ATTOM"
      ],
      "endpoint": "GET https://api.gateway.attomdata.com/propertyapi/v1.0.0/property/address",
      "input": {
        "postalcode": {
          "type": "string",
          "description": "ZIP code",
          "required": false
        },
        "address2": {
          "type": "string",
          "description": "City State: Austin TX",
          "required": false
        },
        "page": {
          "type": "integer",
          "default": 1
        },
        "pagesize": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<property>",
        "fields": [
          "property[0].address.line1",
          "property[0].address.postal1",
          "property[0].building.rooms.beds",
          "property[0].identifier.attomId"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "avm_detail",
      "description_for_ai": "Get automated valuation (AVM) estimate for a property.",
      "intent": [
        "property value ATTOM",
        "home value estimate",
        "AVM real estate",
        "оценка недвижимости ATTOM"
      ],
      "endpoint": "GET https://api.gateway.attomdata.com/propertyapi/v1.0.0/attomavm/detail",
      "input": {
        "address1": {
          "type": "string",
          "required": false
        },
        "address2": {
          "type": "string",
          "required": false
        },
        "attomid": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "avm",
        "fields": [
          "property[0].avm.amount.value",
          "property[0].avm.amount.high",
          "property[0].avm.amount.low",
          "property[0].avm.eventdate"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "sales_history",
      "description_for_ai": "Get sales transaction history for a property.",
      "intent": [
        "property sales history",
        "transaction history",
        "home sold prices",
        "история продаж ATTOM"
      ],
      "endpoint": "GET https://api.gateway.attomdata.com/propertyapi/v1.0.0/saleshistory/detail",
      "input": {
        "address1": {
          "type": "string",
          "required": false
        },
        "address2": {
          "type": "string",
          "required": false
        },
        "attomid": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "sales_history",
        "fields": [
          "property[0].salehistory[0].amount.saleamt",
          "property[0].salehistory[0].saleTransDate",
          "property[0].salehistory[0].calculation.priceperbed"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "community_profile",
      "description_for_ai": "Get neighborhood/community profile: schools, crime, demographics.",
      "intent": [
        "neighborhood data",
        "community profile",
        "schools near property",
        "район недвижимости ATTOM"
      ],
      "endpoint": "GET https://api.gateway.attomdata.com/propertyapi/v1.0.0/neighborhood/community",
      "input": {
        "address1": {
          "type": "string",
          "required": false
        },
        "address2": {
          "type": "string",
          "required": false
        },
        "radius": {
          "type": "number",
          "description": "Miles radius",
          "default": 3.0
        }
      },
      "output": {
        "type": "community",
        "fields": [
          "commV2[0].School[0].Name",
          "commV2[0].School[0].Rating",
          "commV2[0].CrimeIndex",
          "commV2[0].MedianHouseValue"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}