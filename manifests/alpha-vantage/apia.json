{
  "apia": "1.0",
  "service": {
    "id": "alpha-vantage",
    "name": "Alpha Vantage API",
    "description_for_ai": "Free stock market data API. Real-time and historical prices for stocks, ETFs, forex, crypto, and economic indicators. 25 API calls/day free. Use for portfolio tracking, price lookup, financial analysis.",
    "url": "https://alphavantage.co",
    "api_base": "https://www.alphavantage.co/query",
    "category": "finance_stocks",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.alphavantage.co/documentation/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "apikey",
    "param_location": "query",
    "how_to_get": "Free key at https://www.alphavantage.co/support/#api-key",
    "cost": "Free: 25 calls/day. Premium from $50/month"
  },
  "capabilities": [
    {
      "id": "get_stock_quote",
      "description_for_ai": "Get current stock price and daily stats for any ticker symbol. Use for stock price lookup, portfolio valuation.",
      "intent": [
        "stock price",
        "share price",
        "stock quote",
        "market price",
        "ticker price",
        "цена акции"
      ],
      "endpoint": "GET https://www.alphavantage.co/query",
      "input": {
        "function": {
          "type": "string",
          "default": "GLOBAL_QUOTE"
        },
        "symbol": {
          "type": "string",
          "description": "Stock ticker e.g. AAPL, MSFT, TSLA, GAZP",
          "required": true
        }
      },
      "output": {
        "type": "quote",
        "fields": [
          "Global Quote.05. price",
          "Global Quote.09. change",
          "Global Quote.10. change percent",
          "Global Quote.06. volume"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_daily_history",
      "description_for_ai": "Get daily OHLCV (open/high/low/close/volume) price history for a stock. Use for charts, trend analysis.",
      "intent": [
        "stock history",
        "price chart",
        "historical prices",
        "OHLCV data"
      ],
      "endpoint": "GET https://www.alphavantage.co/query",
      "input": {
        "function": {
          "type": "string",
          "default": "TIME_SERIES_DAILY"
        },
        "symbol": {
          "type": "string",
          "required": true
        },
        "outputsize": {
          "type": "string",
          "description": "compact (100 days) or full (20+ years)",
          "default": "compact"
        }
      },
      "output": {
        "type": "time_series",
        "fields": [
          "Time Series (Daily).{date}.1. open",
          "Time Series (Daily).{date}.4. close",
          "Time Series (Daily).{date}.5. volume"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}