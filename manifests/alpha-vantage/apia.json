{
  "apia": "1.0",
  "service": {
    "id": "alpha-vantage",
    "name": "Alpha Vantage API",
    "description_for_ai": "Free stock market data API. Real-time and historical prices for stocks, ETFs, forex, crypto, and economic indicators. 25 API calls/day free. Use for portfolio tracking, price lookup, financial analysis.",
    "url": "https://alphavantage.co",
    "api_base": "https://www.alphavantage.co/query",
    "category": "finance",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.alphavantage.co/documentation/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "apikey",
    "param_location": "query",
    "how_to_get": "Free key at https://www.alphavantage.co/support/#api-key",
    "cost": "Free: 25 calls/day. Premium from $50/month"
  },
  "capabilities": [
    {
      "id": "quote",
      "description_for_ai": "Get real-time (15-min delayed) stock price, volume, and change for a ticker symbol.",
      "intent": [
        "stock price",
        "stock quote",
        "ticker price",
        "share price",
        "цена акции"
      ],
      "endpoint": "GET https://www.alphavantage.co/query",
      "input": {
        "function": {
          "type": "string",
          "default": "GLOBAL_QUOTE"
        },
        "symbol": {
          "type": "string",
          "description": "Stock ticker: AAPL, GOOGL, TSLA, MSFT, AMZN",
          "required": true
        }
      },
      "output": {
        "type": "quote",
        "fields": [
          "Global Quote.05. price",
          "Global Quote.06. volume",
          "Global Quote.09. change",
          "Global Quote.10. change percent",
          "Global Quote.07. latest trading day"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "time_series_daily",
      "description_for_ai": "Get daily OHLCV (open, high, low, close, volume) price history for a stock. Up to 20 years of history.",
      "intent": [
        "stock history",
        "daily prices",
        "OHLCV data",
        "historical stock data",
        "история цен акции"
      ],
      "endpoint": "GET https://www.alphavantage.co/query",
      "input": {
        "function": {
          "type": "string",
          "default": "TIME_SERIES_DAILY"
        },
        "symbol": {
          "type": "string",
          "required": true
        },
        "outputsize": {
          "type": "string",
          "description": "compact (100 latest days) or full (20 years)",
          "default": "compact"
        },
        "datatype": {
          "type": "string",
          "description": "json or csv",
          "default": "json"
        }
      },
      "output": {
        "type": "time_series",
        "fields": [
          "Time Series (Daily).2024-01-15.1. open",
          "Time Series (Daily).2024-01-15.4. close",
          "Time Series (Daily).2024-01-15.5. volume"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "forex_rate",
      "description_for_ai": "Get real-time exchange rate between two currencies.",
      "intent": [
        "forex rate",
        "currency exchange rate",
        "FX rate",
        "exchange rate",
        "курс валют alpha vantage"
      ],
      "endpoint": "GET https://www.alphavantage.co/query",
      "input": {
        "function": {
          "type": "string",
          "default": "CURRENCY_EXCHANGE_RATE"
        },
        "from_currency": {
          "type": "string",
          "description": "Source currency: USD, EUR, GBP, RUB",
          "required": true
        },
        "to_currency": {
          "type": "string",
          "description": "Target currency",
          "required": true
        }
      },
      "output": {
        "type": "rate",
        "fields": [
          "Realtime Currency Exchange Rate.5. Exchange Rate",
          "Realtime Currency Exchange Rate.6. Last Refreshed",
          "Realtime Currency Exchange Rate.8. Bid Price"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "crypto_rate",
      "description_for_ai": "Get real-time cryptocurrency price in any currency.",
      "intent": [
        "crypto price alpha vantage",
        "bitcoin price",
        "ethereum price",
        "crypto exchange rate",
        "цена криптовалюты alpha vantage"
      ],
      "endpoint": "GET https://www.alphavantage.co/query",
      "input": {
        "function": {
          "type": "string",
          "default": "CURRENCY_EXCHANGE_RATE"
        },
        "from_currency": {
          "type": "string",
          "description": "Crypto symbol: BTC, ETH, BNB, SOL, XRP",
          "required": true
        },
        "to_currency": {
          "type": "string",
          "description": "Fiat currency: USD, EUR, RUB",
          "required": true
        }
      },
      "output": {
        "type": "rate",
        "fields": [
          "Realtime Currency Exchange Rate.5. Exchange Rate",
          "Realtime Currency Exchange Rate.6. Last Refreshed"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}