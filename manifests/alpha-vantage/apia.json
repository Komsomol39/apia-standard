{
  "apia": "1.0",
  "service": {
    "id": "alpha-vantage",
    "name": "Alpha Vantage API",
    "description_for_ai": "Free stock market data API. Real-time and historical prices for stocks, ETFs, forex, crypto, and economic indicators. 25 API calls/day free. Use for portfolio tracking, price lookup, financial analysis.",
    "url": "https://alphavantage.co",
    "api_base": "https://www.alphavantage.co/query",
    "category": "finance",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.alphavantage.co/documentation/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "apikey",
    "param_location": "query",
    "how_to_get": "Free key at https://www.alphavantage.co/support/#api-key",
    "cost": "Free: 25 calls/day. Premium from $50/month"
  },
  "capabilities": [
    {
      "id": "get_stock_quote",
      "description_for_ai": "Get real-time stock quote with price, change, and volume.",
      "intent": [
        "stock quote Alpha Vantage",
        "stock price",
        "real time stock",
        "цена акции Alpha Vantage"
      ],
      "endpoint": "GET https://www.alphavantage.co/query?function=GLOBAL_QUOTE",
      "input": {
        "symbol": {
          "type": "string",
          "description": "Stock ticker: AAPL, TSLA, MSFT",
          "required": true
        }
      },
      "output": {
        "type": "quote",
        "fields": [
          "Global Quote.05. price",
          "Global Quote.09. change",
          "Global Quote.10. change percent",
          "Global Quote.06. volume",
          "Global Quote.03. high",
          "Global Quote.04. low"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_daily_prices",
      "description_for_ai": "Get daily OHLCV (open, high, low, close, volume) price history for a stock.",
      "intent": [
        "stock history Alpha Vantage",
        "daily prices",
        "OHLCV stock",
        "история цен Alpha Vantage"
      ],
      "endpoint": "GET https://www.alphavantage.co/query?function=TIME_SERIES_DAILY",
      "input": {
        "symbol": {
          "type": "string",
          "required": true
        },
        "outputsize": {
          "type": "string",
          "description": "compact (100 days) or full (20+ years)",
          "default": "compact"
        },
        "datatype": {
          "type": "string",
          "description": "json or csv",
          "default": "json"
        }
      },
      "output": {
        "type": "timeseries",
        "fields": [
          "Time Series (Daily).2024-01-15.1. open",
          "Time Series (Daily).2024-01-15.4. close",
          "Time Series (Daily).2024-01-15.5. volume"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_symbols",
      "description_for_ai": "Search for stocks, ETFs, and other securities by keyword.",
      "intent": [
        "stock search Alpha Vantage",
        "find ticker",
        "symbol search",
        "поиск акции Alpha Vantage"
      ],
      "endpoint": "GET https://www.alphavantage.co/query?function=SYMBOL_SEARCH",
      "input": {
        "keywords": {
          "type": "string",
          "description": "Company name or symbol",
          "required": true
        }
      },
      "output": {
        "type": "list<match>",
        "fields": [
          "bestMatches[0].1. symbol",
          "bestMatches[0].2. name",
          "bestMatches[0].3. type",
          "bestMatches[0].4. region",
          "bestMatches[0].8. matchScore"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "forex_rate",
      "description_for_ai": "Get real-time forex exchange rate between two currencies.",
      "intent": [
        "forex rate Alpha Vantage",
        "currency exchange rate",
        "FX rate",
        "курс валют Alpha Vantage"
      ],
      "endpoint": "GET https://www.alphavantage.co/query?function=CURRENCY_EXCHANGE_RATE",
      "input": {
        "from_currency": {
          "type": "string",
          "description": "From currency: USD, EUR, GBP, BTC",
          "required": true
        },
        "to_currency": {
          "type": "string",
          "description": "To currency",
          "required": true
        }
      },
      "output": {
        "type": "forex",
        "fields": [
          "Realtime Currency Exchange Rate.5. Exchange Rate",
          "Realtime Currency Exchange Rate.6. Last Refreshed",
          "Realtime Currency Exchange Rate.1. From_Currency Code"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "technical_indicators",
      "description_for_ai": "Calculate technical indicators: SMA, EMA, RSI, MACD, Bollinger Bands.",
      "intent": [
        "technical analysis",
        "RSI stock",
        "MACD indicator",
        "технический анализ Alpha Vantage"
      ],
      "endpoint": "GET https://www.alphavantage.co/query?function={indicator}",
      "input": {
        "function": {
          "type": "string",
          "description": "SMA, EMA, WMA, DEMA, TEMA, RSI, MACD, BBANDS, STOCH, ADX, CCI, AROON, OBV",
          "required": true
        },
        "symbol": {
          "type": "string",
          "required": true
        },
        "interval": {
          "type": "string",
          "description": "1min, 5min, 15min, 30min, 60min, daily, weekly, monthly",
          "required": true
        },
        "time_period": {
          "type": "integer",
          "description": "Number of periods (14 for RSI, 20 for SMA)",
          "required": false
        }
      },
      "output": {
        "type": "indicator",
        "fields": [
          "Technical Analysis.{indicator}.2024-01-15.{indicator value}"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_crypto_price",
      "description_for_ai": "Get cryptocurrency daily price data.",
      "intent": [
        "crypto price Alpha Vantage",
        "Bitcoin price history",
        "ETH price",
        "история цен крипто Alpha Vantage"
      ],
      "endpoint": "GET https://www.alphavantage.co/query?function=DIGITAL_CURRENCY_DAILY",
      "input": {
        "symbol": {
          "type": "string",
          "description": "Crypto symbol: BTC, ETH, SOL",
          "required": true
        },
        "market": {
          "type": "string",
          "description": "Market currency: USD, EUR, CNY",
          "required": true
        }
      },
      "output": {
        "type": "timeseries",
        "fields": [
          "Time Series (Digital Currency Daily).2024-01-15.4a. close (USD)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}