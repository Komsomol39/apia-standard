{
  "apia": "1.0",
  "service": {
    "id": "alpha-vantage",
    "name": "Alpha Vantage API",
    "description_for_ai": "Free stock market data API. Real-time and historical prices for stocks, ETFs, forex, crypto, and economic indicators. 25 API calls/day free. Use for portfolio tracking, price lookup, financial analysis.",
    "url": "https://alphavantage.co",
    "api_base": "https://www.alphavantage.co/query",
    "category": "finance",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.alphavantage.co/documentation/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "apikey",
    "param_location": "query",
    "how_to_get": "Free key at https://www.alphavantage.co/support/#api-key",
    "cost": "Free: 25 calls/day. Premium from $50/month"
  },
  "capabilities": [
    {
      "id": "get_stock_quote",
      "description_for_ai": "Get real-time stock price quote with open, high, low, close, volume.",
      "intent": [
        "stock price",
        "stock quote",
        "AAPL price",
        "цена акции"
      ],
      "endpoint": "GET https://www.alphavantage.co/query",
      "input": {
        "function": {
          "type": "string",
          "default": "GLOBAL_QUOTE"
        },
        "symbol": {
          "type": "string",
          "description": "Stock ticker: AAPL, MSFT, TSLA, AMZN",
          "required": true
        },
        "apikey": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "quote",
        "fields": [
          "Global Quote.01. symbol",
          "Global Quote.05. price",
          "Global Quote.09. change",
          "Global Quote.10. change percent",
          "Global Quote.06. volume"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_daily_prices",
      "description_for_ai": "Get daily historical OHLCV data for a stock.",
      "intent": [
        "stock history",
        "daily prices",
        "historical stock data",
        "история цен акции"
      ],
      "endpoint": "GET https://www.alphavantage.co/query",
      "input": {
        "function": {
          "type": "string",
          "default": "TIME_SERIES_DAILY"
        },
        "symbol": {
          "type": "string",
          "required": true
        },
        "outputsize": {
          "type": "string",
          "description": "compact (100 days) or full (20 years)",
          "default": "compact"
        },
        "apikey": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "timeseries",
        "fields": [
          "Time Series (Daily).{date}.1. open",
          "{date}.4. close",
          "{date}.5. volume"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_forex_rate",
      "description_for_ai": "Get real-time foreign exchange rate between two currencies.",
      "intent": [
        "forex rate",
        "currency exchange",
        "EUR USD rate",
        "курс валют"
      ],
      "endpoint": "GET https://www.alphavantage.co/query",
      "input": {
        "function": {
          "type": "string",
          "default": "CURRENCY_EXCHANGE_RATE"
        },
        "from_currency": {
          "type": "string",
          "description": "Source currency: USD, EUR, GBP, RUB",
          "required": true
        },
        "to_currency": {
          "type": "string",
          "required": true
        },
        "apikey": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "exchange_rate",
        "fields": [
          "Realtime Currency Exchange Rate.5. Exchange Rate",
          "Realtime Currency Exchange Rate.7. Last Refreshed"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_technical_indicator",
      "description_for_ai": "Get technical indicators: RSI, MACD, SMA, EMA, Bollinger Bands.",
      "intent": [
        "technical analysis",
        "RSI indicator",
        "MACD stock",
        "технический анализ акции"
      ],
      "endpoint": "GET https://www.alphavantage.co/query",
      "input": {
        "function": {
          "type": "string",
          "description": "SMA, EMA, RSI, MACD, BBANDS, STOCH, ATR, ADX",
          "required": true
        },
        "symbol": {
          "type": "string",
          "required": true
        },
        "interval": {
          "type": "string",
          "description": "1min, 5min, 15min, 30min, 60min, daily, weekly, monthly",
          "required": true
        },
        "time_period": {
          "type": "integer",
          "description": "Time period for indicator e.g. 14 for RSI",
          "required": false
        },
        "apikey": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "indicator",
        "fields": [
          "Technical Analysis: {FUNCTION}.{date}.{FUNCTION} (indicator value)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_ticker",
      "description_for_ai": "Search for stock tickers by company name or keyword.",
      "intent": [
        "search stock ticker",
        "find stock symbol",
        "ticker lookup",
        "поиск тикера акции"
      ],
      "endpoint": "GET https://www.alphavantage.co/query",
      "input": {
        "function": {
          "type": "string",
          "default": "SYMBOL_SEARCH"
        },
        "keywords": {
          "type": "string",
          "description": "Company name or partial ticker",
          "required": true
        },
        "apikey": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<match>",
        "fields": [
          "bestMatches[0].1. symbol",
          "bestMatches[0].2. name",
          "bestMatches[0].3. type",
          "bestMatches[0].4. region"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}