{
  "apia": "1.0",
  "service": {
    "id": "ipapi",
    "name": "ip-api.com",
    "description_for_ai": "Free IP geolocation API. City, country, ISP, timezone, coordinates from IP address. No API key for non-commercial. 45 req/min free. Fastest free IP geolocation available.",
    "url": "https://ip-api.com",
    "api_base": "http://ip-api.com",
    "category": "maps",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://ip-api.com/docs/api:json"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "anonymous_limits": "45 req/min non-commercial",
    "how_to_get": "Pro key at https://members.ip-api.com for commercial use",
    "cost": "Free non-commercial. Pro: $15/month"
  },
  "capabilities": [
    {
      "id": "lookup_ip",
      "description_for_ai": "Get geolocation data for an IP address: country, city, ISP, timezone.",
      "intent": [
        "IP lookup",
        "IP geolocation",
        "where is IP",
        "геолокация IP"
      ],
      "endpoint": "GET https://ipapi.co/{ip}/{format}/",
      "input": {
        "ip": {
          "type": "string",
          "description": "IPv4 or IPv6 address",
          "required": true
        },
        "format": {
          "type": "string",
          "description": "json, jsonp, xml, csv, yaml",
          "default": "json"
        }
      },
      "output": {
        "type": "geolocation",
        "fields": [
          "ip",
          "city",
          "region",
          "country_name",
          "country_code",
          "latitude",
          "longitude",
          "timezone",
          "org",
          "asn"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_my_ip_info",
      "description_for_ai": "Get geolocation info for the current request's IP address.",
      "intent": [
        "my IP",
        "current location IP",
        "мой IP геолокация"
      ],
      "endpoint": "GET https://ipapi.co/json/",
      "input": {},
      "output": {
        "type": "geolocation",
        "fields": [
          "ip",
          "city",
          "region",
          "country_name",
          "latitude",
          "longitude",
          "timezone",
          "org"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "lookup_specific_field",
      "description_for_ai": "Get a single field for an IP (faster than full JSON).",
      "intent": [
        "IP country",
        "IP city",
        "IP timezone only",
        "страна по IP"
      ],
      "endpoint": "GET https://ipapi.co/{ip}/{field}/",
      "input": {
        "ip": {
          "type": "string",
          "required": true
        },
        "field": {
          "type": "string",
          "description": "city, country, country_code, region, latitude, longitude, timezone, org, asn, currency",
          "required": true
        }
      },
      "output": {
        "type": "string",
        "fields": [
          "Plain text field value"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "bulk_lookup",
      "description_for_ai": "Look up multiple IP addresses in a single request.",
      "intent": [
        "bulk IP lookup",
        "multiple IPs",
        "batch IP geolocation",
        "пакетная геолокация IP"
      ],
      "endpoint": "POST https://ipapi.co/json/",
      "input": {
        "ips": {
          "type": "array",
          "description": "Array of IP addresses to look up",
          "required": true
        }
      },
      "output": {
        "type": "list<geolocation>",
        "fields": [
          "[0].ip",
          "[0].city",
          "[0].country_name",
          "[0].latitude",
          "[0].longitude"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_currency",
      "description_for_ai": "Get the local currency for an IP address.",
      "intent": [
        "IP currency",
        "local currency by IP",
        "currency from IP",
        "валюта по IP"
      ],
      "endpoint": "GET https://ipapi.co/{ip}/currency/",
      "input": {
        "ip": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "string",
        "fields": [
          "currency code (e.g., USD, EUR, RUB)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "https": "Free tier uses HTTP only. HTTPS requires Pro key.",
    "commercial": "Non-commercial use only on free tier. Get Pro key for commercial apps.",
    "batch": "Pro supports batch lookups of up to 100 IPs per request."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}