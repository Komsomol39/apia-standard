{
  "apia": "1.0",
  "service": {
    "id": "nasa",
    "name": "NASA APIs",
    "description_for_ai": "Collection of NASA free APIs. Astronomy Picture of the Day, Mars Rover photos, Earth satellite imagery, Near Earth Objects, International Space Station location, Exoplanets database. All free with API key.",
    "url": "https://api.nasa.gov",
    "api_base": "https://api.nasa.gov",
    "category": "environment",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://api.nasa.gov/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_key": "DEMO_KEY (30 req/hr)",
    "param_name": "api_key",
    "param_location": "query",
    "how_to_get": "Free key at https://api.nasa.gov/#signUp",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "apod",
      "description_for_ai": "Get NASA's Astronomy Picture of the Day with explanation. Free, no auth needed.",
      "intent": [
        "NASA APOD",
        "astronomy picture",
        "space photo NASA",
        "астрономическое фото NASA"
      ],
      "endpoint": "GET https://api.nasa.gov/planetary/apod",
      "input": {
        "date": {
          "type": "string",
          "description": "YYYY-MM-DD for specific date. Omit for today.",
          "required": false
        },
        "start_date": {
          "type": "string",
          "description": "Start date for range (YYYY-MM-DD)",
          "required": false
        },
        "end_date": {
          "type": "string",
          "description": "End date for range",
          "required": false
        },
        "count": {
          "type": "integer",
          "description": "Get N random APODs",
          "required": false
        },
        "thumbs": {
          "type": "boolean",
          "description": "Return video thumbnail URLs",
          "default": false
        },
        "api_key": {
          "type": "string",
          "description": "Use DEMO_KEY for testing (30 req/hour)",
          "required": true
        }
      },
      "output": {
        "type": "apod",
        "fields": [
          "date",
          "title",
          "explanation",
          "url",
          "hdurl",
          "media_type (image/video)",
          "copyright"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "mars_rover_photos",
      "description_for_ai": "Get photos from NASA Mars rovers: Curiosity, Perseverance, Opportunity, Spirit.",
      "intent": [
        "Mars photos",
        "NASA rover",
        "space pictures",
        "фото Марса NASA"
      ],
      "endpoint": "GET https://api.nasa.gov/mars-photos/api/v1/rovers/{rover}/photos",
      "input": {
        "rover": {
          "type": "string",
          "description": "curiosity, perseverance, opportunity, spirit",
          "required": true
        },
        "sol": {
          "type": "integer",
          "description": "Martian sol (day) number. Sol 0 = landing day.",
          "required": false
        },
        "earth_date": {
          "type": "string",
          "description": "Earth date YYYY-MM-DD as alternative to sol",
          "required": false
        },
        "camera": {
          "type": "string",
          "description": "FHAZ, RHAZ, MAST, CHEMCAM, MAHLI, MARDI, NAVCAM, PANCAM, MINITES",
          "required": false
        },
        "api_key": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<photo>",
        "fields": [
          "photos[0].id",
          "photos[0].img_src",
          "photos[0].earth_date",
          "photos[0].camera.full_name",
          "photos[0].rover.name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "neo_feed",
      "description_for_ai": "Get Near Earth Objects (asteroids) approaching Earth in a date range.",
      "intent": [
        "asteroids NASA",
        "near earth objects",
        "NEO feed",
        "астероиды NASA"
      ],
      "endpoint": "GET https://api.nasa.gov/neo/rest/v1/feed",
      "input": {
        "start_date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "end_date": {
          "type": "string",
          "description": "YYYY-MM-DD (max 7 days after start)",
          "required": true
        },
        "api_key": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "neo_feed",
        "fields": [
          "near_earth_objects.{date}[0].name",
          "near_earth_objects.{date}[0].is_potentially_hazardous_asteroid",
          "near_earth_objects.{date}[0].close_approach_data[0].miss_distance.kilometers",
          "near_earth_objects.{date}[0].estimated_diameter.meters.estimated_diameter_max"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "earth_imagery",
      "description_for_ai": "Get Earth satellite imagery for any location via Landsat 8 imagery.",
      "intent": [
        "satellite image Earth",
        "aerial photo location",
        "NASA Earth",
        "спутниковое фото Земли"
      ],
      "endpoint": "GET https://api.nasa.gov/planetary/earth/imagery",
      "input": {
        "lon": {
          "type": "float",
          "description": "Longitude",
          "required": true
        },
        "lat": {
          "type": "float",
          "description": "Latitude",
          "required": true
        },
        "dim": {
          "type": "float",
          "description": "Width and height of image in degrees",
          "default": 0.025
        },
        "date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        },
        "api_key": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "PNG satellite image of the location"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_images",
      "description_for_ai": "Search NASA's image and video library.",
      "intent": [
        "NASA images",
        "space photos",
        "astronomy images search",
        "поиск изображений NASA"
      ],
      "endpoint": "GET https://images-api.nasa.gov/search",
      "input": {
        "q": {
          "type": "string",
          "description": "Search terms: 'Apollo 11', 'black hole', 'Hubble'",
          "required": false
        },
        "media_type": {
          "type": "string",
          "description": "image, video, audio",
          "required": false
        },
        "year_start": {
          "type": "string",
          "description": "YYYY",
          "required": false
        },
        "year_end": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<item>",
        "fields": [
          "collection.items[0].data[0].title",
          "collection.items[0].data[0].description",
          "collection.items[0].links[0].href (preview image URL)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "demo_key": "DEMO_KEY works for testing: 30 req/hr, 50 req/day. Get real key for production.",
    "all_apis": "See https://api.nasa.gov for full list: EPIC Earth images, Exoplanet Archive, Techport, GeneLab etc."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}