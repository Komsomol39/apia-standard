{
  "apia": "1.0",
  "service": {
    "id": "nasa",
    "name": "NASA APIs",
    "description_for_ai": "Collection of NASA free APIs. Astronomy Picture of the Day, Mars Rover photos, Earth satellite imagery, Near Earth Objects, International Space Station location, Exoplanets database. All free with API key.",
    "url": "https://api.nasa.gov",
    "api_base": "https://api.nasa.gov",
    "category": "space_science",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://api.nasa.gov/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_key": "DEMO_KEY (30 req/hr)",
    "param_name": "api_key",
    "param_location": "query",
    "how_to_get": "Free key at https://api.nasa.gov/#signUp",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "apod",
      "description_for_ai": "Get NASA Astronomy Picture of the Day with description by astronomer. Image or video with explanation.",
      "intent": [
        "astronomy picture",
        "space photo",
        "NASA image",
        "picture of day",
        "cosmos photo",
        "space image"
      ],
      "endpoint": "GET https://api.nasa.gov/planetary/apod",
      "input": {
        "date": {
          "type": "string",
          "description": "YYYY-MM-DD. Omit for today.",
          "required": false
        },
        "count": {
          "type": "integer",
          "description": "Random images count",
          "required": false
        },
        "thumbs": {
          "type": "boolean",
          "description": "Return video thumbnails",
          "default": false
        }
      },
      "output": {
        "type": "apod",
        "fields": [
          "title",
          "explanation",
          "url",
          "media_type",
          "date",
          "copyright"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "mars_photos",
      "description_for_ai": "Get photos from Mars rovers (Curiosity, Perseverance, Opportunity). Filter by sol (Martian day) or Earth date and camera.",
      "intent": [
        "mars photos",
        "Mars rover",
        "space exploration",
        "NASA Mars",
        "red planet photos"
      ],
      "endpoint": "GET https://api.nasa.gov/mars-photos/api/v1/rovers/{rover}/photos",
      "input": {
        "rover": {
          "type": "string",
          "description": "curiosity, perseverance, opportunity",
          "required": true
        },
        "sol": {
          "type": "integer",
          "description": "Martian sol (day) number",
          "required": false
        },
        "earth_date": {
          "type": "string",
          "description": "YYYY-MM-DD alternative to sol",
          "required": false
        },
        "camera": {
          "type": "string",
          "description": "FHAZ, RHAZ, MAST, CHEMCAM, MAHLI, MARDI, NAVCAM",
          "required": false
        },
        "page": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<photo>",
        "fields": [
          "id",
          "img_src",
          "earth_date",
          "camera.full_name",
          "rover.name"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "near_earth_objects",
      "description_for_ai": "Get asteroids and comets approaching Earth. Use for space awareness, educational apps.",
      "intent": [
        "asteroids",
        "near earth objects",
        "space rocks",
        "NEO",
        "asteroid approach"
      ],
      "endpoint": "GET https://api.nasa.gov/neo/rest/v1/feed",
      "input": {
        "start_date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        },
        "end_date": {
          "type": "string",
          "description": "YYYY-MM-DD, max 7 days from start",
          "required": false
        }
      },
      "output": {
        "type": "neo_feed",
        "fields": [
          "near_earth_objects.{date}[0].name",
          "near_earth_objects.{date}[0].close_approach_data[0].miss_distance.kilometers",
          "near_earth_objects.{date}[0].is_potentially_hazardous_asteroid"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "demo_key": "DEMO_KEY works for testing: 30 req/hr, 50 req/day. Get real key for production.",
    "all_apis": "See https://api.nasa.gov for full list: EPIC Earth images, Exoplanet Archive, Techport, GeneLab etc."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}