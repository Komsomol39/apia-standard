{
  "apia": "1.0",
  "service": {
    "id": "superjob-resumes",
    "name": "SuperJob — Резюме",
    "description_for_ai": "Поиск по базе резюме соискателей SuperJob. Используй когда работодатель хочет найти кандидатов по специальности, городу или опыту. Требует авторизации работодателя.",
    "url": "https://superjob.ru",
    "api_base": "https://api.superjob.ru/2.0",
    "category": "employment_resumes",
    "geo": ["RU", "BY", "KZ"],
    "language": "ru",
    "docs": "https://api.superjob.ru/"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "note": "Требует авторизации работодателя. Доступ к базе резюме платный.",
    "header_name": "X-Api-App-Id",
    "oauth_url": "https://www.superjob.ru/authorize/",
    "token_url": "https://api.superjob.ru/2.0/oauth2/access_token/"
  },
  "capabilities": [
    {
      "id": "search_resumes",
      "description_for_ai": "Поиск резюме соискателей по специальности, городу и опыту. Используй когда работодатель говорит 'найди мне кандидатов на должность Python разработчика в Москве с опытом от 3 лет'.",
      "intent": [
        "найти кандидатов", "поиск резюме", "найти соискателей",
        "кандидаты на вакансию", "резюме разработчика", "специалисты в городе"
      ],
      "endpoint": "GET https://api.superjob.ru/2.0/resumes/",
      "headers": { "X-Api-App-Id": "секретный ключ приложения" },
      "input": {
        "keyword": { "type": "string", "description": "Ключевые слова поиска", "required": false },
        "town": { "type": "integer", "description": "ID города", "required": false },
        "experience": { "type": "integer", "description": "1=без опыта, 2=1-3 года, 3=3-6 лет, 4=более 6 лет", "required": false },
        "gender": { "type": "integer", "description": "1=мужской, 2=женский", "required": false },
        "age_from": { "type": "integer", "description": "Возраст от", "required": false },
        "age_to": { "type": "integer", "description": "Возраст до", "required": false },
        "count": { "type": "integer", "default": 20, "max": 100 },
        "page": { "type": "integer", "default": 0 }
      },
      "output": {
        "type": "list<resume>",
        "fields": ["id", "profession", "town.title", "experience.title", "age", "gender.title", "link"]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_resume",
      "description_for_ai": "Полное резюме кандидата по ID включая опыт работы и контакты.",
      "intent": ["резюме кандидата", "контакты соискателя", "опыт работы кандидата"],
      "endpoint": "GET https://api.superjob.ru/2.0/resumes/{id}/",
      "headers": { "X-Api-App-Id": "секретный ключ" },
      "input": {
        "id": { "type": "integer", "description": "ID резюме из search_resumes", "required": true }
      },
      "output": {
        "type": "resume",
        "fields": ["profession", "experience", "education", "skills", "town.title", "phones", "email"]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "employer_only": "Этот манифест только для работодателей. Для поиска вакансий соискателями используй манифест superjob/apia.json.",
    "paid_access": "Доступ к базе резюме платный — нужна подписка SuperJob для работодателей.",
    "contacts_tip": "Контакты (телефон, email) доступны только при наличии активной подписки на базу резюме."
  },
  "limits": {
    "requests_per_minute": 120,
    "commercial_use": true,
    "attribution_required": true
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}