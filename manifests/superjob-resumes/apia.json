{
  "apia": "1.0",
  "service": {
    "id": "superjob-resumes",
    "name": "SuperJob — Резюме",
    "description_for_ai": "SuperJob API для работы с резюме кандидатов. Поиск резюме по профессии, зарплате, опыту, региону. Просмотр контактов кандидатов, история откликов, рекомендации. Один из ведущих HR-порталов России. Используется рекрутёрами и HR-отделами российских компаний.",
    "url": "https://superjob.ru",
    "api_base": "https://api.superjob.ru/2.0",
    "category": "hr",
    "geo": [
      "RU",
      "BY",
      "KZ"
    ],
    "language": "ru",
    "docs": "https://api.superjob.ru/"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "note": "Требует авторизации работодателя. Доступ к базе резюме платный.",
    "header_name": "X-Api-App-Id",
    "oauth_url": "https://www.superjob.ru/authorize/",
    "token_url": "https://api.superjob.ru/2.0/oauth2/access_token/"
  },
  "capabilities": [
    {
      "id": "search_resumes",
      "description_for_ai": "Search resumes on SuperJob by keyword, position, location, salary.",
      "intent": [
        "поиск резюме SuperJob",
        "кандидаты SuperJob",
        "база резюме",
        "SuperJob resumes"
      ],
      "endpoint": "GET https://api.superjob.ru/2.0/resumes/",
      "input": {
        "keyword": {
          "type": "string",
          "description": "Keywords to search",
          "required": false
        },
        "town": {
          "type": "integer",
          "description": "City ID: 4=Moscow, 14=Saint Petersburg",
          "required": false
        },
        "payment_from": {
          "type": "integer",
          "required": false
        },
        "age_from": {
          "type": "integer",
          "required": false
        },
        "age_to": {
          "type": "integer",
          "required": false
        },
        "count": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<resume>",
        "fields": [
          "objects[0].id",
          "objects[0].client.name",
          "objects[0].profession",
          "objects[0].town.title",
          "objects[0].payment_from",
          "objects[0].payment_to"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_resume",
      "description_for_ai": "Get full resume by ID from SuperJob.",
      "intent": [
        "резюме SuperJob",
        "анкета кандидата",
        "просмотр резюме",
        "resume SuperJob"
      ],
      "endpoint": "GET https://api.superjob.ru/2.0/resumes/{id}/",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "resume",
        "fields": [
          "id",
          "profession",
          "payment_from",
          "town.title",
          "education[0].name",
          "experience[0].firm_name",
          "experience[0].position"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_vacancies",
      "description_for_ai": "Search job vacancies on SuperJob.",
      "intent": [
        "поиск вакансий SuperJob",
        "вакансии",
        "работа SuperJob",
        "jobs SuperJob"
      ],
      "endpoint": "GET https://api.superjob.ru/2.0/vacancies/",
      "input": {
        "keyword": {
          "type": "string",
          "required": false
        },
        "town": {
          "type": "integer",
          "required": false
        },
        "payment_from": {
          "type": "integer",
          "required": false
        },
        "catalogues": {
          "type": "integer",
          "description": "Category ID",
          "required": false
        },
        "count": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<vacancy>",
        "fields": [
          "objects[0].id",
          "objects[0].profession",
          "objects[0].firm_name",
          "objects[0].town.title",
          "objects[0].payment_from",
          "objects[0].payment_to"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_vacancy",
      "description_for_ai": "Get full job vacancy details from SuperJob.",
      "intent": [
        "вакансия SuperJob",
        "описание вакансии",
        "вакансия подробно",
        "vacancy SuperJob"
      ],
      "endpoint": "GET https://api.superjob.ru/2.0/vacancies/{id}/",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "vacancy",
        "fields": [
          "id",
          "profession",
          "firm_name",
          "payment_from",
          "payment_to",
          "town.title",
          "work",
          "candidat",
          "vacancyRichText"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_catalogs",
      "description_for_ai": "Get SuperJob occupation/industry catalogs for filtering.",
      "intent": [
        "каталоги SuperJob",
        "отрасли SuperJob",
        "профессии SuperJob",
        "SuperJob categories"
      ],
      "endpoint": "GET https://api.superjob.ru/2.0/catalogues/",
      "input": {},
      "output": {
        "type": "list<catalog>",
        "fields": [
          "[0].title_rus",
          "[0].key",
          "[0].positions[0].title",
          "[0].positions[0].key"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "employer_only": "Этот манифест только для работодателей. Для поиска вакансий соискателями используй манифест superjob/apia.json.",
    "paid_access": "Доступ к базе резюме платный — нужна подписка SuperJob для работодателей.",
    "contacts_tip": "Контакты (телефон, email) доступны только при наличии активной подписки на базу резюме."
  },
  "limits": {
    "requests_per_minute": 120,
    "commercial_use": true,
    "attribution_required": true
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}