{
  "apia": "1.0",
  "service": {
    "id": "superjob-resumes",
    "name": "SuperJob — Резюме",
    "description_for_ai": "SuperJob API для работы с резюме кандидатов. Поиск резюме по профессии, зарплате, опыту, региону. Просмотр контактов кандидатов, история откликов, рекомендации. Один из ведущих HR-порталов России. Используется рекрутёрами и HR-отделами российских компаний.",
    "url": "https://superjob.ru",
    "api_base": "https://api.superjob.ru/2.0",
    "category": "hr",
    "geo": [
      "RU",
      "BY",
      "KZ"
    ],
    "language": "ru",
    "docs": "https://api.superjob.ru/"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "note": "Требует авторизации работодателя. Доступ к базе резюме платный.",
    "header_name": "X-Api-App-Id",
    "oauth_url": "https://www.superjob.ru/authorize/",
    "token_url": "https://api.superjob.ru/2.0/oauth2/access_token/"
  },
  "capabilities": [
    {
      "id": "search_resumes",
      "description_for_ai": "Поиск резюме соискателей по специальности, городу и опыту. Используй когда работодатель говорит 'найди мне кандидатов на должность Python разработчика в Москве с опытом от 3 лет'.",
      "intent": [
        "найти кандидатов",
        "поиск резюме",
        "найти соискателей",
        "кандидаты на вакансию",
        "резюме разработчика",
        "специалисты в городе"
      ],
      "endpoint": "GET https://api.superjob.ru/2.0/resumes/",
      "headers": {
        "X-Api-App-Id": "секретный ключ приложения"
      },
      "input": {
        "keyword": {
          "type": "string",
          "description": "Ключевые слова поиска",
          "required": false
        },
        "town": {
          "type": "integer",
          "description": "ID города",
          "required": false
        },
        "experience": {
          "type": "integer",
          "description": "1=без опыта, 2=1-3 года, 3=3-6 лет, 4=более 6 лет",
          "required": false
        },
        "gender": {
          "type": "integer",
          "description": "1=мужской, 2=женский",
          "required": false
        },
        "age_from": {
          "type": "integer",
          "description": "Возраст от",
          "required": false
        },
        "age_to": {
          "type": "integer",
          "description": "Возраст до",
          "required": false
        },
        "count": {
          "type": "integer",
          "default": 20,
          "max": 100,
          "description": "Number of items to return"
        },
        "page": {
          "type": "integer",
          "default": 0,
          "description": "Page number for pagination (1-indexed)"
        }
      },
      "output": {
        "type": "list<resume>",
        "fields": [
          "id",
          "profession",
          "town.title",
          "experience.title",
          "age",
          "gender.title",
          "link"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_resume",
      "description_for_ai": "Полное резюме кандидата по ID включая опыт работы и контакты.",
      "intent": [
        "резюме кандидата",
        "контакты соискателя",
        "опыт работы кандидата"
      ],
      "endpoint": "GET https://api.superjob.ru/2.0/resumes/{id}/",
      "headers": {
        "X-Api-App-Id": "секретный ключ"
      },
      "input": {
        "id": {
          "type": "integer",
          "description": "ID резюме из search_resumes",
          "required": true
        }
      },
      "output": {
        "type": "resume",
        "fields": [
          "profession",
          "experience",
          "education",
          "skills",
          "town.title",
          "phones",
          "email"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_resumes",
      "description_for_ai": "Search candidate resumes on SuperJob.",
      "intent": [
        "superjob резюме",
        "поиск кандидатов superjob",
        "resumes superjob"
      ],
      "endpoint": "GET https://api.superjob.ru/2.0/resumes/",
      "input": {
        "keyword": {
          "type": "string",
          "required": false
        },
        "age_from": {
          "type": "integer",
          "required": false
        },
        "age_to": {
          "type": "integer",
          "required": false
        },
        "experience": {
          "type": "integer",
          "description": "1=no exp, 2=1-3yr, 3=3-6yr, 4=6+yr",
          "required": false
        },
        "count": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<resume>",
        "fields": [
          "objects[0].id",
          "objects[0].fio",
          "objects[0].profession",
          "objects[0].experience[0].position",
          "objects[0].salary"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_resume",
      "description_for_ai": "Get a specific resume from SuperJob.",
      "intent": [
        "резюме superjob",
        "кандидат superjob",
        "cv superjob"
      ],
      "endpoint": "GET https://api.superjob.ru/2.0/resumes/{id}/",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "resume",
        "fields": [
          "id",
          "fio",
          "profession",
          "experience[0].position",
          "salary",
          "skills",
          "education[0].institution"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_contact",
      "description_for_ai": "Get contact details of a candidate on SuperJob.",
      "intent": [
        "контакты кандидата superjob",
        "телефон кандидата",
        "email кандидата superjob"
      ],
      "endpoint": "GET https://api.superjob.ru/2.0/resumes/{id}/contacts/",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "contacts",
        "fields": [
          "phone",
          "email"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_resumes",
      "description_for_ai": "Search candidate resumes on Superjob.",
      "intent": [
        "резюме superjob",
        "поиск кандидатов superjob",
        "resumes superjob"
      ],
      "endpoint": "GET https://api.superjob.ru/2.0/resumes/",
      "input": {
        "keyword": {
          "type": "string",
          "required": false
        },
        "town": {
          "type": "integer",
          "description": "1=Moscow, 2=SPb",
          "required": false
        },
        "experience": {
          "type": "integer",
          "description": "1=no exp, 2=1-3yr, 3=3-6yr, 4=6+yr",
          "required": false
        },
        "count": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<resume>",
        "fields": [
          "objects[0].id",
          "objects[0].profession",
          "objects[0].experience[0].position",
          "objects[0].age"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_resume",
      "description_for_ai": "Get full resume details from Superjob.",
      "intent": [
        "резюме детали superjob",
        "cv superjob",
        "get resume superjob"
      ],
      "endpoint": "GET https://api.superjob.ru/2.0/resumes/{id}",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "resume",
        "fields": [
          "id",
          "profession",
          "experience[0].position",
          "education[0].name",
          "skills",
          "salary_from"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "invite_candidate",
      "description_for_ai": "Invite a candidate to a vacancy on Superjob.",
      "intent": [
        "пригласить кандидата superjob",
        "invite resume superjob"
      ],
      "endpoint": "POST https://api.superjob.ru/2.0/resumes/invite/",
      "input": {
        "resume_id": {
          "type": "integer",
          "required": true
        },
        "vacancy_id": {
          "type": "integer",
          "required": true
        },
        "text": {
          "type": "string",
          "description": "Invitation message text",
          "required": false
        }
      },
      "output": {
        "type": "status",
        "fields": [
          "success (boolean)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "employer_only": "Этот манифест только для работодателей. Для поиска вакансий соискателями используй манифест superjob/apia.json.",
    "paid_access": "Доступ к базе резюме платный — нужна подписка SuperJob для работодателей.",
    "contacts_tip": "Контакты (телефон, email) доступны только при наличии активной подписки на базу резюме."
  },
  "limits": {
    "requests_per_minute": 120,
    "commercial_use": true,
    "attribution_required": true
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}