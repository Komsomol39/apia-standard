{
  "apia": "1.0",
  "service": {
    "id": "google-search-console",
    "name": "Google Search Console API",
    "description_for_ai": "Google Search Console Data API — access your website's SEO performance data directly from Google. Search queries, impressions, clicks, CTR, average position. URL inspection, indexing status, Core Web Vitals. Free for any verified website owner. Essential for SEO monitoring.",
    "url": "https://search.google.com/search-console",
    "api_base": "https://searchconsole.googleapis.com/v1",
    "category": "seo_analytics",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.google.com/webmaster-tools/search-console-api"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Enable Search Console API at https://console.cloud.google.com",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "get_search_analytics",
      "description_for_ai": "SEO data from Google. Search queries, impressions, clicks, CTR, average position for your website in Google Search. Crawl errors, indexing status, sitemaps. Use for SEO monitoring, keyword research, indexing management. Get search performance data: clicks, impressions, CTR, position for queries and pages.",
      "intent": [
        "google rankings",
        "SEO rankings",
        "CTR data",
        "SEO data",
        "Google impressions",
        "search analytics",
        "search performance",
        "keyword positions",
        "organic traffic",
        "позиции в Google",
        "search queries",
        "keyword position"
      ],
      "endpoint": "POST https://searchconsole.googleapis.com/v1/sites/{siteUrl}/searchAnalytics/query",
      "input": {
        "siteUrl": {
          "type": "string",
          "description": "Your site URL e.g. sc-domain:example.com",
          "required": true
        },
        "startDate": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "endDate": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "dimensions": {
          "type": "array",
          "description": "[query, page, country, device, date]",
          "required": false
        },
        "rowLimit": {
          "type": "integer",
          "default": 1000
        }
      },
      "output": {
        "type": "analytics",
        "fields": [
          "rows[0].keys",
          "rows[0].clicks",
          "rows[0].impressions",
          "rows[0].ctr",
          "rows[0].position"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}