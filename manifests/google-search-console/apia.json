{
  "apia": "1.0",
  "service": {
    "id": "google-search-console",
    "name": "Google Search Console API",
    "description_for_ai": "Google Search Console Data API — access your website's SEO performance data directly from Google. Search queries, impressions, clicks, CTR, average position. URL inspection, indexing status, Core Web Vitals. Free for any verified website owner. Essential for SEO monitoring.",
    "url": "https://search.google.com/search-console",
    "api_base": "https://searchconsole.googleapis.com/v1",
    "category": "analytics",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.google.com/webmaster-tools/search-console-api"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Enable Search Console API at https://console.cloud.google.com",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "query_search_analytics",
      "description_for_ai": "Get Google Search Console click, impression, CTR, position data by query, page, country.",
      "intent": [
        "Google Search Console data",
        "SEO clicks",
        "search queries GSC",
        "данные Search Console"
      ],
      "endpoint": "POST https://searchconsole.googleapis.com/webmasters/v3/sites/{siteUrl}/searchAnalytics/query",
      "input": {
        "siteUrl": {
          "type": "string",
          "description": "URL-encoded: https%3A%2F%2Fexample.com%2F",
          "required": true
        },
        "startDate": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "endDate": {
          "type": "string",
          "required": true
        },
        "dimensions": {
          "type": "array",
          "description": "['query', 'page', 'country', 'device', 'date']",
          "required": false
        },
        "rowLimit": {
          "type": "integer",
          "default": 1000
        },
        "startRow": {
          "type": "integer",
          "default": 0
        }
      },
      "output": {
        "type": "list<row>",
        "fields": [
          "rows[0].keys (dimension values)",
          "rows[0].clicks",
          "rows[0].impressions",
          "rows[0].ctr",
          "rows[0].position"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_sites",
      "description_for_ai": "List all sites/properties verified in Google Search Console.",
      "intent": [
        "GSC sites",
        "verified sites",
        "Search Console properties",
        "сайты Search Console"
      ],
      "endpoint": "GET https://searchconsole.googleapis.com/webmasters/v3/sites",
      "input": {},
      "output": {
        "type": "list<site>",
        "fields": [
          "siteEntry[0].siteUrl",
          "siteEntry[0].permissionLevel (siteOwner, siteFullUser, siteRestrictedUser)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_sitemaps",
      "description_for_ai": "Get sitemap submission status and errors in Google Search Console.",
      "intent": [
        "sitemap GSC",
        "sitemap status",
        "indexing sitemap",
        "карта сайта Search Console"
      ],
      "endpoint": "GET https://searchconsole.googleapis.com/webmasters/v3/sites/{siteUrl}/sitemaps",
      "input": {
        "siteUrl": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<sitemap>",
        "fields": [
          "sitemap[0].path",
          "sitemap[0].lastSubmitted",
          "sitemap[0].lastDownloaded",
          "sitemap[0].contents[0].type",
          "sitemap[0].contents[0].submitted",
          "sitemap[0].contents[0].indexed"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_url_inspection",
      "description_for_ai": "Inspect a URL's Google indexing status, mobile usability, and coverage.",
      "intent": [
        "URL inspection",
        "indexing status Google",
        "crawl status",
        "индексирование URL Google"
      ],
      "endpoint": "POST https://searchconsole.googleapis.com/v1/urlInspection/index:inspect",
      "input": {
        "inspectionUrl": {
          "type": "string",
          "required": true
        },
        "siteUrl": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "inspection",
        "fields": [
          "inspectionResult.indexStatusResult.coverageState",
          "inspectionResult.indexStatusResult.lastCrawlTime",
          "inspectionResult.mobileUsabilityResult.verdict",
          "inspectionResult.richResultsResult.verdict"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_crawl_errors",
      "description_for_ai": "Get crawl errors detected by Google: 404s, server errors, etc.",
      "intent": [
        "crawl errors Google",
        "404 errors GSC",
        "broken pages",
        "ошибки сканирования Google"
      ],
      "endpoint": "GET https://searchconsole.googleapis.com/webmasters/v3/sites/{siteUrl}/urlCrawlErrorsSamples",
      "input": {
        "siteUrl": {
          "type": "string",
          "required": true
        },
        "category": {
          "type": "string",
          "description": "notFound, authPermissions, manyToOneRedirect, notFollowed, other, roboted, serverError, soft404",
          "required": true
        },
        "platform": {
          "type": "string",
          "description": "mobile, smartphoneOnly, web",
          "required": true
        }
      },
      "output": {
        "type": "list<error>",
        "fields": [
          "urlCrawlErrorSample[0].pageUrl",
          "urlCrawlErrorSample[0].last_crawled",
          "urlCrawlErrorSample[0].responseCode"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}