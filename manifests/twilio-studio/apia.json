{
  "apia": "1.0",
  "service": {
    "id": "twilio-studio",
    "name": "Twilio Studio API",
    "description_for_ai": "Visual flow builder for phone and messaging automations. IVR (interactive voice response), SMS chatbots, WhatsApp bots without code. Execute flows via API to trigger automated conversations.",
    "url": "https://twilio.com/studio",
    "api_base": "https://studio.twilio.com/v2",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.twilio.com/docs/studio/rest-api/v2"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "how_to_get": "Twilio Console → Studio",
    "cost": "Free tier included. Per message/call pricing"
  },
  "capabilities": [
    {
      "id": "trigger_flow",
      "description_for_ai": "Trigger a Twilio Studio flow execution via REST API.",
      "intent": [
        "trigger Twilio flow",
        "start Studio flow",
        "Twilio automation",
        "запустить поток Twilio"
      ],
      "endpoint": "POST https://studio.twilio.com/v2/Flows/{FlowSid}/Executions",
      "input": {
        "FlowSid": {
          "type": "string",
          "description": "Flow SID: FWxxx",
          "required": true
        },
        "To": {
          "type": "string",
          "description": "Phone number to call/text",
          "required": true
        },
        "From": {
          "type": "string",
          "description": "Your Twilio number",
          "required": true
        },
        "Parameters": {
          "type": "object",
          "description": "Custom variables to pass to flow: {name: 'John', order_id: '123'}",
          "required": false
        }
      },
      "output": {
        "type": "execution",
        "fields": [
          "sid",
          "status",
          "flow_sid",
          "context.flow.variables"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_flows",
      "description_for_ai": "List all Twilio Studio flows in the account.",
      "intent": [
        "list flows Twilio",
        "Studio flows",
        "my Twilio flows",
        "потоки Twilio Studio"
      ],
      "endpoint": "GET https://studio.twilio.com/v2/Flows",
      "input": {},
      "output": {
        "type": "list<flow>",
        "fields": [
          "flows[0].sid",
          "flows[0].friendly_name",
          "flows[0].status",
          "flows[0].date_created"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_execution_status",
      "description_for_ai": "Get the status of a Twilio Studio flow execution.",
      "intent": [
        "execution status Twilio",
        "flow status",
        "call status Studio",
        "статус выполнения Twilio"
      ],
      "endpoint": "GET https://studio.twilio.com/v2/Flows/{FlowSid}/Executions/{ExecutionSid}",
      "input": {
        "FlowSid": {
          "type": "string",
          "required": true
        },
        "ExecutionSid": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "execution",
        "fields": [
          "sid",
          "status (active/ended)",
          "context",
          "date_created",
          "date_updated"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_sms_flow",
      "description_for_ai": "Use a Twilio Studio SMS flow to send contextual messages.",
      "intent": [
        "send SMS Twilio Studio",
        "SMS automation",
        "text flow Twilio",
        "SMS автоматизация Twilio"
      ],
      "endpoint": "POST https://studio.twilio.com/v2/Flows/{FlowSid}/Executions",
      "input": {
        "FlowSid": {
          "type": "string",
          "required": true
        },
        "To": {
          "type": "string",
          "description": "Recipient phone: +1234567890",
          "required": true
        },
        "From": {
          "type": "string",
          "required": true
        },
        "Parameters": {
          "type": "object",
          "description": "{message: 'Your order is ready', order_number: '12345'}",
          "required": false
        }
      },
      "output": {
        "type": "execution",
        "fields": [
          "sid",
          "status",
          "context"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_executions",
      "description_for_ai": "List all executions of a Twilio Studio flow.",
      "intent": [
        "Twilio executions",
        "flow history",
        "execution log Twilio",
        "история выполнений Twilio"
      ],
      "endpoint": "GET https://studio.twilio.com/v2/Flows/{FlowSid}/Executions",
      "input": {
        "FlowSid": {
          "type": "string",
          "required": true
        },
        "PageSize": {
          "type": "integer",
          "default": 50
        }
      },
      "output": {
        "type": "list<execution>",
        "fields": [
          "executions[0].sid",
          "executions[0].status",
          "executions[0].date_created",
          "executions[0].contact_channel_address"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}