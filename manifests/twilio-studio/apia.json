{
  "apia": "1.0",
  "service": {
    "id": "twilio-studio",
    "name": "Twilio Studio API",
    "description_for_ai": "Visual flow builder for phone and messaging automations. IVR (interactive voice response), SMS chatbots, WhatsApp bots without code. Execute flows via API to trigger automated conversations.",
    "url": "https://twilio.com/studio",
    "api_base": "https://studio.twilio.com/v2",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.twilio.com/docs/studio/rest-api/v2"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "how_to_get": "Twilio Console → Studio",
    "cost": "Free tier included. Per message/call pricing"
  },
  "capabilities": [
    {
      "id": "trigger_flow",
      "description_for_ai": "Trigger a Twilio Studio flow execution via REST API.",
      "intent": [
        "trigger studio flow",
        "start studio flow",
        "twilio automation",
        "запустить flow twilio studio"
      ],
      "endpoint": "POST https://studio.twilio.com/v2/Flows/{FlowSid}/Executions",
      "input": {
        "FlowSid": {
          "type": "string",
          "description": "Flow SID from Twilio Console",
          "required": true
        },
        "To": {
          "type": "string",
          "description": "Phone number to send to (E.164)",
          "required": true
        },
        "From": {
          "type": "string",
          "description": "Your Twilio number",
          "required": true
        },
        "Parameters": {
          "type": "object",
          "description": "Custom JSON params passed to flow",
          "required": false
        }
      },
      "output": {
        "type": "execution",
        "fields": [
          "sid",
          "status",
          "flow_sid",
          "date_created"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_execution",
      "description_for_ai": "Get status of a Twilio Studio flow execution.",
      "intent": [
        "execution status studio",
        "flow run status",
        "twilio studio status",
        "статус выполнения studio twilio"
      ],
      "endpoint": "GET https://studio.twilio.com/v2/Flows/{FlowSid}/Executions/{ExecutionSid}",
      "input": {
        "FlowSid": {
          "type": "string",
          "required": true
        },
        "ExecutionSid": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "execution",
        "fields": [
          "sid",
          "status",
          "date_created",
          "date_updated",
          "context"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_executions",
      "description_for_ai": "List executions of a Twilio Studio flow.",
      "intent": [
        "list studio executions",
        "flow history",
        "twilio studio logs",
        "история выполнений studio"
      ],
      "endpoint": "GET https://studio.twilio.com/v2/Flows/{FlowSid}/Executions",
      "input": {
        "FlowSid": {
          "type": "string",
          "required": true
        },
        "DateCreatedFrom": {
          "type": "string",
          "description": "ISO 8601 filter",
          "required": false
        },
        "PageSize": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<execution>",
        "fields": [
          "executions[0].sid",
          "executions[0].status",
          "executions[0].to",
          "executions[0].date_created"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_flows",
      "description_for_ai": "List all Twilio Studio flows in an account.",
      "intent": [
        "list studio flows",
        "my flows twilio",
        "studio automation list",
        "список flows twilio studio"
      ],
      "endpoint": "GET https://studio.twilio.com/v2/Flows",
      "input": {},
      "output": {
        "type": "list<flow>",
        "fields": [
          "flows[0].sid",
          "flows[0].friendly_name",
          "flows[0].status",
          "flows[0].date_created"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "end_execution",
      "description_for_ai": "End an active Twilio Studio flow execution.",
      "intent": [
        "end execution studio",
        "stop flow twilio",
        "cancel studio execution",
        "остановить flow twilio studio"
      ],
      "endpoint": "DELETE https://studio.twilio.com/v2/Flows/{FlowSid}/Executions/{ExecutionSid}",
      "input": {
        "FlowSid": {
          "type": "string",
          "required": true
        },
        "ExecutionSid": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "status",
        "fields": [
          "204 No Content on success"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}