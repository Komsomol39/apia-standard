{
  "apia": "1.0",
  "service": {
    "id": "adyen",
    "name": "Adyen API",
    "description_for_ai": "Adyen — enterprise global payments platform processing $1T+ annually. Accepts 200+ payment methods across 40 currencies in 70+ countries. Used by Uber, Microsoft, Spotify, McDonald's, Airbnb. Unified commerce: online, mobile, in-store. Advanced fraud prevention included.",
    "url": "https://adyen.com",
    "api_base": "https://checkout-test.adyen.com/v71",
    "category": "finance",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.adyen.com/api-explorer/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "X-API-Key: ...",
    "how_to_get": "Adyen Customer Area → Developers → API credentials",
    "cost": "Interchange++ pricing. Custom enterprise rates."
  },
  "capabilities": [
    {
      "id": "create_payment",
      "description_for_ai": "Process a payment with Adyen. Supports cards, wallets, BNPL, and local payment methods.",
      "intent": [
        "Adyen payment",
        "process payment",
        "charge card Adyen",
        "платёж Adyen"
      ],
      "endpoint": "POST https://checkout-test.adyen.com/v71/payments",
      "input": {
        "amount": {
          "type": "object",
          "description": "{currency: 'EUR', value: 1000} (value in minor units, 1000 = €10.00)",
          "required": true
        },
        "reference": {
          "type": "string",
          "description": "Your unique payment reference",
          "required": true
        },
        "paymentMethod": {
          "type": "object",
          "description": "{type: 'scheme', encryptedCardNumber, encryptedExpiryMonth, encryptedExpiryYear, encryptedSecurityCode, holderName} or {type: 'googlepay', googlePayToken}",
          "required": true
        },
        "merchantAccount": {
          "type": "string",
          "required": true
        },
        "returnUrl": {
          "type": "string",
          "description": "For redirect-based payment methods",
          "required": true
        },
        "shopperReference": {
          "type": "string",
          "description": "Customer ID for recurring payments",
          "required": false
        }
      },
      "output": {
        "type": "payment",
        "fields": [
          "pspReference",
          "resultCode (Authorised/Refused/Pending)",
          "amount.value",
          "paymentMethod.brand"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_refund",
      "description_for_ai": "Refund a payment fully or partially.",
      "intent": [
        "Adyen refund",
        "payment refund",
        "charge refund",
        "возврат средств Adyen"
      ],
      "endpoint": "POST https://pal-test.adyen.com/pal/servlet/Payment/v68/refund",
      "input": {
        "modificationAmount": {
          "type": "object",
          "description": "{currency: 'EUR', value: 500} — partial or full refund amount",
          "required": true
        },
        "originalReference": {
          "type": "string",
          "description": "PSP reference of original payment",
          "required": true
        },
        "merchantAccount": {
          "type": "string",
          "required": true
        },
        "reference": {
          "type": "string",
          "description": "Your refund reference",
          "required": false
        }
      },
      "output": {
        "type": "refund",
        "fields": [
          "pspReference",
          "response ([refund-received])"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_payment_methods",
      "description_for_ai": "Get available payment methods for a shopper's country and device.",
      "intent": [
        "available payment methods",
        "payment options",
        "local payments Adyen",
        "доступные методы оплаты Adyen"
      ],
      "endpoint": "POST https://checkout-test.adyen.com/v71/paymentMethods",
      "input": {
        "merchantAccount": {
          "type": "string",
          "required": true
        },
        "countryCode": {
          "type": "string",
          "description": "ISO 3166-1 country code: NL, US, DE",
          "required": true
        },
        "shopperLocale": {
          "type": "string",
          "description": "Locale: en-US, nl-NL, de-DE",
          "required": false
        },
        "amount": {
          "type": "object",
          "description": "{currency, value}",
          "required": false
        },
        "channel": {
          "type": "string",
          "description": "Web, iOS, Android",
          "default": "Web"
        }
      },
      "output": {
        "type": "payment_methods",
        "fields": [
          "paymentMethods[0].type",
          "paymentMethods[0].name",
          "paymentMethods[0].brands"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "capture_payment",
      "description_for_ai": "Capture a previously authorised payment (for two-step payment flows).",
      "intent": [
        "capture payment Adyen",
        "authorize and capture",
        "финализировать платёж Adyen"
      ],
      "endpoint": "POST https://pal-test.adyen.com/pal/servlet/Payment/v68/capture",
      "input": {
        "originalReference": {
          "type": "string",
          "required": true
        },
        "modificationAmount": {
          "type": "object",
          "description": "{currency, value}",
          "required": true
        },
        "merchantAccount": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "capture",
        "fields": [
          "pspReference",
          "response ([capture-received])"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_token",
      "description_for_ai": "Tokenize payment details for future recurring charges (one-click payments).",
      "intent": [
        "payment token Adyen",
        "save card",
        "recurring payment setup",
        "сохранить карту Adyen"
      ],
      "endpoint": "POST https://checkout-test.adyen.com/v71/payments",
      "input": {
        "amount": {
          "type": "object",
          "required": true
        },
        "paymentMethod": {
          "type": "object",
          "required": true
        },
        "merchantAccount": {
          "type": "string",
          "required": true
        },
        "shopperReference": {
          "type": "string",
          "description": "Customer ID",
          "required": true
        },
        "storePaymentMethod": {
          "type": "boolean",
          "description": "Set to true to tokenize",
          "default": true
        },
        "recurringProcessingModel": {
          "type": "string",
          "description": "CardOnFile or Subscription",
          "required": true
        }
      },
      "output": {
        "type": "payment",
        "fields": [
          "pspReference",
          "resultCode",
          "additionalData.recurring.recurringDetailReference (token)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}