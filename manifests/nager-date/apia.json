{
  "apia": "1.0",
  "service": {
    "id": "nager-date",
    "name": "Nager.Date Public Holidays API",
    "description_for_ai": "Free public holidays API for 100+ countries. No API key needed. Get national holidays, check if date is holiday, next public holiday. Use for business day calculations, scheduling apps.",
    "url": "https://date.nager.at",
    "api_base": "https://date.nager.at/api/v3",
    "category": "utilities",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://date.nager.at/swagger/index.html"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free forever"
  },
  "capabilities": [
    {
      "id": "get_public_holidays",
      "description_for_ai": "Get all public holidays for a country and year with local names, descriptions, and whether they're national/regional.",
      "intent": [
        "выходные дни",
        "public holidays",
        "national holidays",
        "праздники страны",
        "calendar holidays",
        "bank holidays",
        "days off",
        "праздничные дни"
      ],
      "endpoint": "GET https://date.nager.at/api/v3/PublicHolidays/{year}/{countryCode}",
      "input": {
        "year": {
          "type": "integer",
          "description": "Year e.g. 2026",
          "required": true
        },
        "countryCode": {
          "type": "string",
          "description": "ISO 2-letter code: RU, US, DE, FR, GB, CN, JP",
          "required": true
        }
      },
      "output": {
        "type": "list<holiday>",
        "fields": [
          "date",
          "localName",
          "name",
          "countryCode",
          "fixed",
          "global",
          "counties",
          "launchYear",
          "types"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "is_today_public_holiday",
      "description_for_ai": "Check if today is a public holiday in a specific country. Returns HTTP 200 if holiday, HTTP 204 if not.",
      "intent": [
        "holiday check",
        "working day check",
        "holiday today",
        "is today holiday",
        "working day",
        "is bank closed",
        "bank open today"
      ],
      "endpoint": "GET https://date.nager.at/api/v3/IsTodayPublicHoliday/{countryCode}",
      "input": {
        "countryCode": {
          "type": "string",
          "required": true
        },
        "countyCode": {
          "type": "string",
          "description": "State/county code for regional holidays",
          "required": false
        }
      },
      "output": {
        "type": "boolean",
        "fields": [
          "HTTP 200=yes holiday, HTTP 204=no holiday"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "next_public_holidays",
      "description_for_ai": "Get next upcoming public holidays from today for a country. Returns up to 5 upcoming holidays.",
      "intent": [
        "next holiday",
        "upcoming holidays",
        "when is next holiday"
      ],
      "endpoint": "GET https://date.nager.at/api/v3/NextPublicHolidays/{countryCode}",
      "input": {
        "countryCode": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<holiday>",
        "fields": [
          "date",
          "localName",
          "name"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_public_holidays",
      "description_for_ai": "Get public holidays for any country and year.",
      "intent": [
        "public holidays",
        "national holidays",
        "праздники страны",
        "выходные дни"
      ],
      "endpoint": "GET https://date.nager.at/api/v3/PublicHolidays/{year}/{countryCode}",
      "input": {
        "year": {
          "type": "integer",
          "description": "4-digit year",
          "required": true
        },
        "countryCode": {
          "type": "string",
          "description": "ISO 3166-1 alpha-2: US, DE, RU, FR",
          "required": true
        }
      },
      "output": {
        "type": "list<holiday>",
        "fields": [
          "[0].date",
          "[0].localName",
          "[0].name",
          "[0].countryCode",
          "[0].fixed",
          "[0].types"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "is_today_holiday",
      "description_for_ai": "Check if today is a public holiday in a given country.",
      "intent": [
        "is today holiday",
        "holiday check today",
        "выходной сегодня"
      ],
      "endpoint": "GET https://date.nager.at/api/v3/IsTodayPublicHoliday/{countryCode}",
      "input": {
        "countryCode": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "boolean",
        "fields": [
          "200=yes, 204=no"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "country_codes": "ISO 3166-1 alpha-2: US, GB, DE, FR, RU, CN, JP, AU, CA, BR, IN, ES, IT, NL, PL, UA, KZ, BY",
    "response_codes": "GET IsTodayPublicHoliday returns 200=holiday, 204=not a holiday, 400=bad country code",
    "free": "Completely free, no API key, no rate limits. Public holidays data from Nager.Date open source project.",
    "regional": "Some holidays vary by region (US states, German Bundesländer). Use countyCode param for regional holidays."
  }
}