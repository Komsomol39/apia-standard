{"apia":"1.0","service":{"id":"nager-date","name":"Nager.Date Public Holidays API","description_for_ai":"Free public holidays API for 100+ countries. No API key needed. Get national holidays, check if date is holiday, next public holiday. Use for business day calculations, scheduling apps.","url":"https://date.nager.at","api_base":"https://date.nager.at/api/v3","category":"utilities_calendar","geo":["GLOBAL"],"language":"en","docs":"https://date.nager.at/swagger/index.html"},"auth":{"type":"none","anonymous_access":true,"cost":"Free forever"},"capabilities":[{"id":"get_public_holidays","description_for_ai":"Get public holidays for a country and year. Returns all national holidays.","intent":["public holidays","national holidays","bank holidays","days off","выходные дни","праздники страны"],"endpoint":"GET https://date.nager.at/api/v3/PublicHolidays/{year}/{countryCode}","input":{"year":{"type":"integer","description":"Year e.g. 2026","required":true},"countryCode":{"type":"string","description":"ISO 2-letter code: RU, US, DE, FR, GB, CN, JP","required":true}},"output":{"type":"list<holiday>","fields":["date","localName","name","countryCode","fixed","global","counties","launchYear","types"]},"realtime":false,"requires_auth":false},{"id":"is_today_public_holiday","description_for_ai":"Check if today is a public holiday in a specific country.","intent":["is today holiday","is bank closed","holiday today","working day check"],"endpoint":"GET https://date.nager.at/api/v3/IsTodayPublicHoliday/{countryCode}","input":{"countryCode":{"type":"string","required":true},"countyCode":{"type":"string","description":"State/county code for regional holidays","required":false}},"output":{"type":"boolean","fields":["HTTP 200=yes holiday, HTTP 204=no holiday"]},"realtime":true,"requires_auth":false},{"id":"next_public_holidays","description_for_ai":"Get next upcoming public holidays in a country from today.","intent":["next holiday","upcoming holidays","when is next holiday"],"endpoint":"GET https://date.nager.at/api/v3/NextPublicHolidays/{countryCode}","input":{"countryCode":{"type":"string","required":true}},"output":{"type":"list<holiday>","fields":["date","localName","name"]},"realtime":true,"requires_auth":false}],"meta":{"apia_version":"1.0","manifest_author":"APIA community","last_verified":"2026-06-14"}}