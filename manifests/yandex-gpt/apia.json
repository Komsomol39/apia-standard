{
  "apia": "1.0",
  "service": {
    "id": "yandex-gpt",
    "name": "YandexGPT API (Yandex Cloud)",
    "description_for_ai": "Российская LLM от Яндекса. YandexGPT 5 Pro и Lite. Оптимизирован для русского языка. Доступен через Яндекс Облако. Для российских бизнесов — данные не покидают Россию. Также включает Yandex SpeechKit (TTS/STT) и embeddings.",
    "url": "https://yandex.cloud",
    "api_base": "https://llm.api.cloud.yandex.net",
    "category": "ai",
    "geo": [
      "RU",
      "GLOBAL"
    ],
    "language": "ru",
    "docs": "https://yandex.cloud/ru/docs/foundation-models/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Api-Key {api_key}",
    "how_to_get": "Яндекс Облако → Foundation Models → API ключи",
    "cost": "YandexGPT Lite бесплатно в рамках лимитов. Pro: 0.2 руб/1000 токенов"
  },
  "capabilities": [
    {
      "id": "completion",
      "description_for_ai": "Generate text with YandexGPT. Ideal for Russian-language tasks. Supports system prompts and multi-turn conversations.",
      "intent": [
        "yandex gpt",
        "ИИ яндекс",
        "нейросеть яндекс",
        "генерация текста яндекс",
        "yagpt"
      ],
      "endpoint": "POST https://llm.api.cloud.yandex.net/foundationModels/v1/completion",
      "input": {
        "modelUri": {
          "type": "string",
          "description": "gpt://{folder_id}/yandexgpt/latest or yandexgpt-lite/latest",
          "required": true
        },
        "completionOptions": {
          "type": "object",
          "description": "{stream: false, temperature: 0.6, maxTokens: 2000}",
          "required": false
        },
        "messages": {
          "type": "array",
          "description": "[{role: system|user|assistant, text: string}]",
          "required": true
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "result.alternatives[0].message.text",
          "result.alternatives[0].status",
          "result.usage.totalTokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "async_completion",
      "description_for_ai": "Async text generation for long tasks. Returns operation ID, poll for result.",
      "intent": [
        "async yandex gpt",
        "long generation",
        "асинхронная генерация яндекс"
      ],
      "endpoint": "POST https://llm.api.cloud.yandex.net/foundationModels/v1/completionAsync",
      "input": {
        "modelUri": {
          "type": "string",
          "required": true
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "completionOptions": {
          "type": "object",
          "required": false
        }
      },
      "output": {
        "type": "operation",
        "fields": [
          "id",
          "done",
          "response.alternatives[0].message.text"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "embeddings",
      "description_for_ai": "Get text embeddings with YandexGPT for semantic search and RAG in Russian.",
      "intent": [
        "yandex embeddings",
        "векторы яндекс",
        "семантический поиск яндекс",
        "RAG яндекс"
      ],
      "endpoint": "POST https://llm.api.cloud.yandex.net/foundationModels/v1/textEmbedding",
      "input": {
        "modelUri": {
          "type": "string",
          "description": "emb://{folder_id}/text-search-doc/latest or text-search-query/latest",
          "required": true
        },
        "text": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "embedding",
        "fields": [
          "embedding (float array)",
          "numTokens",
          "modelVersion"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "tokenize",
      "description_for_ai": "Count tokens before sending to estimate cost.",
      "intent": [
        "count tokens yandex",
        "токены яндекс gpt"
      ],
      "endpoint": "POST https://llm.api.cloud.yandex.net/foundationModels/v1/tokenize",
      "input": {
        "modelUri": {
          "type": "string",
          "required": true
        },
        "text": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "token_count",
        "fields": [
          "tokens",
          "modelVersion"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}