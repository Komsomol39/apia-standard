{
  "apia": "1.0",
  "service": {
    "id": "2gis-cis",
    "name": "2GIS — Беларусь, Казахстан и другие страны",
    "description_for_ai": "2GIS работает не только в России, но и в Беларуси, Казахстане, Кыргызстане, Узбекистане, ОАЭ, Чили, Италии, Кипре. API идентично российскому 2GIS — те же endpoints, тот же ключ. Используй когда пользователь ищет организации в этих странах.",
    "url": "https://2gis.com",
    "api_base": "https://catalog.api.2gis.com/3.0",
    "category": "maps_poi",
    "geo": ["BY", "KZ", "KG", "UZ", "AE", "CL", "IT", "CY", "CZ"],
    "language": "ru",
    "docs": "https://docs.2gis.com/en/api/search/overview",
    "note": "Это расширение манифеста 2gis/apia.json с акцентом на международное использование. API идентично."
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Один ключ работает для всех стран. Получить на https://dev.2gis.ru/",
    "cost": "демо-ключ бесплатно на месяц"
  },
  "capabilities": [
    {
      "id": "search_places_by",
      "description_for_ai": "Поиск организаций в Беларуси по координатам. Используй для запросов 'аптека в Минске', 'кафе рядом в Гомеле', 'банк в Беларуси'.",
      "intent": [
        "организации в Беларуси", "кафе в Минске", "аптека в Гомеле",
        "банк в Беларуси", "магазин в Минске"
      ],
      "endpoint": "GET https://catalog.api.2gis.com/3.0/items",
      "input": {
        "q": { "type": "string", "description": "Поисковый запрос", "required": true },
        "point": { "type": "string", "description": "Координаты 'lng,lat'. Минск: '27.5615,53.9045'", "required": false },
        "radius": { "type": "integer", "default": 500 },
        "sort": { "type": "string", "default": "distance" },
        "fields": { "type": "string", "description": "items.schedule,items.contact_groups", "required": false },
        "locale": { "type": "string", "default": "ru_RU" }
      },
      "output": {
        "type": "list<place>",
        "fields": ["id", "name", "address.name", "point.lat", "point.lon", "schedule", "contact_groups"]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_places_kz",
      "description_for_ai": "Поиск организаций в Казахстане по координатам. Используй для запросов 'аптека в Алматы', 'кафе в Астане', 'банк в Казахстане'.",
      "intent": [
        "организации в Казахстане", "кафе в Алматы", "аптека в Астане",
        "банк в Казахстане", "магазин в Алматы"
      ],
      "endpoint": "GET https://catalog.api.2gis.com/3.0/items",
      "input": {
        "q": { "type": "string", "required": true },
        "point": { "type": "string", "description": "Алматы: '76.9286,43.2567', Астана: '71.4306,51.1801'", "required": false },
        "radius": { "type": "integer", "default": 500 },
        "sort": { "type": "string", "default": "distance" },
        "fields": { "type": "string", "required": false },
        "locale": { "type": "string", "default": "ru_RU" }
      },
      "output": {
        "type": "list<place>",
        "fields": ["id", "name", "address.name", "point.lat", "point.lon", "schedule", "contact_groups"]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "city_coordinates": {
    "description_for_ai": "Центры городов для параметра point",
    "cities": {
      "Минск": "27.5615,53.9045",
      "Гомель": "30.9754,52.4412",
      "Алматы": "76.9286,43.2567",
      "Астана": "71.4306,51.1801",
      "Шымкент": "69.5901,42.3417",
      "Бишкек": "74.5698,42.8746",
      "Ташкент": "69.2401,41.2995",
      "Дубай": "55.2708,25.2048"
    }
  },
  "agent_hints": {
    "same_api": "API идентично российскому 2GIS. Один ключ, одни endpoints — просто другие координаты.",
    "language": "Для Беларуси и Казахстана используй locale=ru_RU. Данные на русском языке.",
    "coords_format": "Формат координат: 'longitude,latitude' (сначала долгота)."
  },
  "contributor_notes": {
    "useful_links": [
      "https://docs.2gis.com/en/api/search/overview",
      "https://docs.2gis.com/en/api/search/places/overview",
      "https://dev.2gis.ru/"
    ],
    "what_to_document": "Геокодер для BY/KZ адресов, специфика работы в разных странах"
  },
  "limits": {
    "demo_requests": 500,
    "commercial_use": true,
    "attribution_required": true,
    "attribution_text": "Данные предоставлены 2GIS"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
