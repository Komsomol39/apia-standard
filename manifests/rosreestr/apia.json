{
  "apia": "1.0",
  "service": {
    "id": "rosreestr",
    "name": "Росреестр API (ЕГРН)",
    "description_for_ai": "Федеральная служба государственной регистрации — данные о недвижимости России. Кадастровые данные, сведения о правообладателях, кадастровая стоимость, обременения. Необходим для сделок с недвижимостью в России.",
    "url": "https://rosreestr.gov.ru",
    "api_base": "https://pkk.rosreestr.ru/api",
    "category": "real_estate",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://rosreestr.gov.ru/api/online/fir_object/"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "note": "Публичные данные кадастровой карты доступны без авторизации. Расширенные сведения через Госуслуги или авторизованных посредников.",
    "cost": "Бесплатно для публичных данных"
  },
  "capabilities": [
    {
      "id": "get_object_info",
      "description_for_ai": "Get public real estate object information from Russian Rosreestr by cadastral number.",
      "intent": [
        "Росреестр объект",
        "кадастровый номер",
        "данные о недвижимости Росреестр",
        "rosreestr property"
      ],
      "endpoint": "GET https://pkk.rosreestr.ru/api/features/1",
      "input": {
        "id": {
          "type": "string",
          "description": "Cadastral number: 77:01:0001001:1",
          "required": true
        },
        "text": {
          "type": "string",
          "description": "Alternative: search by cadastral number as text",
          "required": false
        }
      },
      "output": {
        "type": "property",
        "fields": [
          "feature.attrs.id",
          "feature.attrs.address",
          "feature.attrs.area_value",
          "feature.attrs.cad_cost",
          "feature.attrs.date_cost",
          "feature.attrs.cn"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "search_by_address",
      "description_for_ai": "Search cadastral objects by address in Russian Rosreestr.",
      "intent": [
        "поиск по адресу Росреестр",
        "адрес кадастровый номер",
        "найти объект по адресу",
        "rosreestr address search"
      ],
      "endpoint": "GET https://pkk.rosreestr.ru/api/suggest/",
      "input": {
        "text": {
          "type": "string",
          "description": "Address: Москва, ул. Тверская, 1",
          "required": true
        },
        "limit": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<suggestion>",
        "fields": [
          "[0].value (address)",
          "[0].data.cn (cadastral number)",
          "[0].data.id"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_map_features",
      "description_for_ai": "Get cadastral objects in a map bounding box.",
      "intent": [
        "кадастровая карта",
        "объекты на карте Росреестр",
        "ПКК кадастр",
        "cadastral map rosreestr"
      ],
      "endpoint": "GET https://pkk.rosreestr.ru/api/features/1",
      "input": {
        "bbox": {
          "type": "string",
          "description": "West,South,East,North: 37.6,55.7,37.7,55.8",
          "required": true
        },
        "tolerance": {
          "type": "integer",
          "default": 30
        },
        "limit": {
          "type": "integer",
          "default": 40
        }
      },
      "output": {
        "type": "list<feature>",
        "fields": [
          "features[0].attrs.id",
          "features[0].attrs.cn",
          "features[0].attrs.address",
          "features[0].attrs.area_value"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "check_encumbrances",
      "description_for_ai": "Check encumbrances and restrictions on a property via Rosreestr public API.",
      "intent": [
        "обременения Росреестр",
        "ограничения недвижимость",
        "залог ипотека Росреестр",
        "encumbrances rosreestr"
      ],
      "endpoint": "GET https://rosreestr.gov.ru/api/online/fir_objects/{cadastralNumber}",
      "input": {
        "cadastralNumber": {
          "type": "string",
          "description": "Cadastral number: 77:01:0001001:1",
          "required": true
        }
      },
      "output": {
        "type": "property_info",
        "fields": [
          "objectId",
          "objectCn",
          "objectType",
          "encumbrances[0].type",
          "encumbrances[0].regDate"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_territory_zones",
      "description_for_ai": "Get territory planning zones (ГПЗУ) for a land plot.",
      "intent": [
        "зоны территории Росреестр",
        "ГПЗУ Росреестр",
        "зонирование земля",
        "territory zones rosreestr"
      ],
      "endpoint": "GET https://pkk.rosreestr.ru/api/features/5",
      "input": {
        "id": {
          "type": "string",
          "description": "Cadastral number of land plot",
          "required": true
        }
      },
      "output": {
        "type": "zones",
        "fields": [
          "feature.attrs.id",
          "feature.attrs.zone_name",
          "feature.attrs.permitted_use"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "cad_number_format": "Кадастровый номер: РР:КК:ССССССС:ПП (регион:квартал:массив:участок). Например: 77:01:0001001:1",
    "public_vs_full": "Публичный API даёт ограниченные данные. Для полной выписки ЕГРН нужна авторизация через Госуслуги или API посредника."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}