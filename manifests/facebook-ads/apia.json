{
  "apia": "1.0",
  "service": {
    "id": "facebook-ads",
    "name": "Meta Ads API (Facebook/Instagram Ads)",
    "description_for_ai": "Advertise on Facebook and Instagram. Create campaigns, ad sets, ads. Access detailed analytics. 3B+ users reach. Powerful audience targeting: interests, demographics, lookalikes, custom audiences.",
    "url": "https://developers.facebook.com/docs/marketing-apis",
    "api_base": "https://graph.facebook.com/v20.0",
    "category": "business",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.facebook.com/docs/marketing-api/reference/"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Create app at https://developers.facebook.com/apps — requires ad account",
    "cost": "Free API. Ad spend charged per campaign"
  },
  "capabilities": [
    {
      "id": "get_campaigns",
      "description_for_ai": "List Facebook Ads campaigns with spend and performance metrics.",
      "intent": [
        "facebook ads campaigns",
        "FB ads list",
        "advertising campaigns",
        "кампании facebook ads"
      ],
      "endpoint": "GET https://graph.facebook.com/v19.0/act_{ad_account_id}/campaigns",
      "input": {
        "ad_account_id": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "id,name,status,objective,spend_cap,budget_remaining",
          "default": "id,name,status"
        },
        "effective_status": {
          "type": "array",
          "description": "['ACTIVE', 'PAUSED', 'DELETED']",
          "required": false
        }
      },
      "output": {
        "type": "list<campaign>",
        "fields": [
          "data[0].id",
          "data[0].name",
          "data[0].status",
          "data[0].objective",
          "data[0].spend_cap"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_campaign",
      "description_for_ai": "Create a new Facebook Ads campaign.",
      "intent": [
        "create FB campaign",
        "new facebook ad",
        "launch campaign",
        "создать кампанию facebook"
      ],
      "endpoint": "POST https://graph.facebook.com/v19.0/act_{ad_account_id}/campaigns",
      "input": {
        "ad_account_id": {
          "type": "string",
          "required": true
        },
        "name": {
          "type": "string",
          "required": true
        },
        "objective": {
          "type": "string",
          "description": "OUTCOME_AWARENESS, OUTCOME_TRAFFIC, OUTCOME_ENGAGEMENT, OUTCOME_LEADS, OUTCOME_APP_PROMOTION, OUTCOME_SALES",
          "required": true
        },
        "status": {
          "type": "string",
          "description": "ACTIVE or PAUSED",
          "default": "PAUSED"
        },
        "special_ad_categories": {
          "type": "array",
          "description": "[] unless housing/employment/credit",
          "default": []
        }
      },
      "output": {
        "type": "campaign",
        "fields": [
          "id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_ad_insights",
      "description_for_ai": "Get Facebook Ads performance: impressions, clicks, CTR, CPC, ROAS, spend.",
      "intent": [
        "facebook ads insights",
        "ad performance",
        "CTR facebook",
        "эффективность facebook ads"
      ],
      "endpoint": "GET https://graph.facebook.com/v19.0/act_{ad_account_id}/insights",
      "input": {
        "ad_account_id": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "campaign_name,impressions,clicks,spend,ctr,cpc,actions,cost_per_action_type,roas",
          "required": true
        },
        "date_preset": {
          "type": "string",
          "description": "today, yesterday, last_7d, last_30d, this_month, last_month",
          "default": "last_7d"
        },
        "level": {
          "type": "string",
          "description": "account, campaign, adset, ad",
          "default": "campaign"
        }
      },
      "output": {
        "type": "insights",
        "fields": [
          "data[0].campaign_name",
          "data[0].impressions",
          "data[0].clicks",
          "data[0].spend",
          "data[0].ctr",
          "data[0].cpc"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_ad_set",
      "description_for_ai": "Create an Ad Set within a Facebook campaign (targeting + budget).",
      "intent": [
        "facebook ad set",
        "audience targeting fb",
        "create ad set",
        "настройка аудитории facebook"
      ],
      "endpoint": "POST https://graph.facebook.com/v19.0/act_{ad_account_id}/adsets",
      "input": {
        "ad_account_id": {
          "type": "string",
          "required": true
        },
        "campaign_id": {
          "type": "string",
          "required": true
        },
        "name": {
          "type": "string",
          "required": true
        },
        "daily_budget": {
          "type": "integer",
          "description": "In cents: 1000 = $10",
          "required": true
        },
        "targeting": {
          "type": "object",
          "description": "{geo_locations: {countries: ['US']}, age_min: 25, age_max: 55, interests: [{id: '6003139266461', name: 'Technology'}]}",
          "required": true
        },
        "billing_event": {
          "type": "string",
          "description": "IMPRESSIONS or LINK_CLICKS",
          "required": true
        },
        "optimization_goal": {
          "type": "string",
          "description": "REACH, LINK_CLICKS, CONVERSIONS, APP_INSTALLS",
          "required": true
        }
      },
      "output": {
        "type": "adset",
        "fields": [
          "id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_audiences",
      "description_for_ai": "Get Custom Audiences in a Facebook Ads account.",
      "intent": [
        "facebook custom audiences",
        "retargeting audiences",
        "lookalike audience",
        "аудитории facebook"
      ],
      "endpoint": "GET https://graph.facebook.com/v19.0/act_{ad_account_id}/customaudiences",
      "input": {
        "ad_account_id": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "string",
          "default": "id,name,subtype,approximate_count_lower_bound"
        }
      },
      "output": {
        "type": "list<audience>",
        "fields": [
          "data[0].id",
          "data[0].name",
          "data[0].subtype",
          "data[0].approximate_count_lower_bound"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}