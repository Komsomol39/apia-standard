{
  "apia": "1.0",
  "service": {
    "id": "facebook-ads",
    "name": "Meta Ads API (Facebook/Instagram Ads)",
    "description_for_ai": "Advertise on Facebook and Instagram. Create campaigns, ad sets, ads. Access detailed analytics. 3B+ users reach. Powerful audience targeting: interests, demographics, lookalikes, custom audiences.",
    "url": "https://developers.facebook.com/docs/marketing-apis",
    "api_base": "https://graph.facebook.com/v20.0",
    "category": "business",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.facebook.com/docs/marketing-api/reference/"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Create app at https://developers.facebook.com/apps — requires ad account",
    "cost": "Free API. Ad spend charged per campaign"
  },
  "capabilities": [
    {
      "id": "get_campaigns",
      "description_for_ai": "Get all Facebook/Meta ad campaigns for an ad account.",
      "intent": [
        "Facebook campaigns",
        "Meta ads",
        "ad campaigns Facebook",
        "кампании Facebook"
      ],
      "endpoint": "GET https://graph.facebook.com/v18.0/act_{ad_account_id}/campaigns",
      "input": {
        "ad_account_id": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "id,name,status,objective,daily_budget,lifetime_budget,start_time",
          "default": "id,name,status,objective"
        },
        "status": {
          "type": "array",
          "description": "ACTIVE, PAUSED, DELETED, ARCHIVED",
          "required": false
        }
      },
      "output": {
        "type": "list<campaign>",
        "fields": [
          "data[0].id",
          "data[0].name",
          "data[0].status",
          "data[0].objective",
          "data[0].daily_budget"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_insights",
      "description_for_ai": "Get ad performance metrics: impressions, clicks, spend, CTR, ROAS.",
      "intent": [
        "Facebook ads insights",
        "ad performance",
        "Meta ads ROI",
        "метрики рекламы Facebook"
      ],
      "endpoint": "GET https://graph.facebook.com/v18.0/act_{ad_account_id}/insights",
      "input": {
        "ad_account_id": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "impressions,clicks,spend,ctr,cpc,cpm,reach,frequency,roas",
          "required": true
        },
        "date_preset": {
          "type": "string",
          "description": "today, yesterday, last_7d, last_30d, last_90d, this_month",
          "default": "last_30d"
        },
        "level": {
          "type": "string",
          "description": "account, campaign, adset, ad",
          "default": "campaign"
        }
      },
      "output": {
        "type": "list<insight>",
        "fields": [
          "data[0].campaign_name",
          "data[0].impressions",
          "data[0].clicks",
          "data[0].spend",
          "data[0].ctr",
          "data[0].purchase_roas"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_campaign",
      "description_for_ai": "Create a new Facebook/Meta ad campaign.",
      "intent": [
        "create Facebook campaign",
        "new ad campaign",
        "Meta campaign",
        "создать кампанию Facebook"
      ],
      "endpoint": "POST https://graph.facebook.com/v18.0/act_{ad_account_id}/campaigns",
      "input": {
        "ad_account_id": {
          "type": "string",
          "required": true
        },
        "name": {
          "type": "string",
          "required": true
        },
        "objective": {
          "type": "string",
          "description": "OUTCOME_AWARENESS, OUTCOME_TRAFFIC, OUTCOME_ENGAGEMENT, OUTCOME_LEADS, OUTCOME_APP_PROMOTION, OUTCOME_SALES",
          "required": true
        },
        "status": {
          "type": "string",
          "default": "PAUSED"
        },
        "daily_budget": {
          "type": "integer",
          "description": "Budget in cents: 1000 = $10/day",
          "required": false
        }
      },
      "output": {
        "type": "campaign",
        "fields": [
          "id",
          "name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "manage_adsets",
      "description_for_ai": "Create or update Facebook ad sets with targeting and budget.",
      "intent": [
        "Facebook adset",
        "ad targeting",
        "audience targeting Meta",
        "таргетинг Facebook"
      ],
      "endpoint": "POST https://graph.facebook.com/v18.0/act_{ad_account_id}/adsets",
      "input": {
        "ad_account_id": {
          "type": "string",
          "required": true
        },
        "campaign_id": {
          "type": "string",
          "required": true
        },
        "name": {
          "type": "string",
          "required": true
        },
        "targeting": {
          "type": "object",
          "description": "{geo_locations: {countries: ['US']}, age_min: 25, age_max: 45, interests: [{id: '6003...', name: 'Technology'}]}",
          "required": true
        },
        "daily_budget": {
          "type": "integer",
          "required": true
        },
        "billing_event": {
          "type": "string",
          "default": "IMPRESSIONS"
        }
      },
      "output": {
        "type": "adset",
        "fields": [
          "id",
          "name",
          "status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_audiences",
      "description_for_ai": "Get custom audiences and saved audiences for targeting.",
      "intent": [
        "Facebook audiences",
        "custom audience Meta",
        "lookalike audience",
        "аудитории Facebook"
      ],
      "endpoint": "GET https://graph.facebook.com/v18.0/act_{ad_account_id}/customaudiences",
      "input": {
        "ad_account_id": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "string",
          "default": "id,name,subtype,approximate_count,delivery_status"
        }
      },
      "output": {
        "type": "list<audience>",
        "fields": [
          "data[0].id",
          "data[0].name",
          "data[0].subtype",
          "data[0].approximate_count",
          "data[0].delivery_status.code"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}