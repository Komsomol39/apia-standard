{
  "apia": "1.0",
  "service": {
    "id": "amocrm",
    "name": "amoCRM API (Россия/СНГ)",
    "description_for_ai": "Самая популярная CRM-система в России и СНГ. Сделки, контакты, компании, воронка продаж. Интеграция с мессенджерами и телефонией. Используй для управления продажами, лидами, клиентской базой в России.",
    "url": "https://amocrm.ru",
    "api_base": "https://{subdomain}.amocrm.ru/api/v4",
    "category": "business",
    "geo": [
      "RU",
      "BY",
      "KZ",
      "UA"
    ],
    "language": "ru",
    "docs": "https://www.amocrm.ru/developers/content/crm_platform/api-reference"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Создать интеграцию в настройках аккаунта amoCRM",
    "cost": "Базовый: 499 руб/пользователь/месяц. 14 дней бесплатно."
  },
  "capabilities": [
    {
      "id": "get_leads",
      "description_for_ai": "Get CRM leads (сделки) from amoCRM pipeline. Filter by status, pipeline, responsible manager, and date ranges.",
      "intent": [
        "сделки amoCRM",
        "воронка продаж",
        "лиды CRM",
        "клиенты amoCRM",
        "продажи России"
      ],
      "endpoint": "GET https://{subdomain}.amocrm.ru/api/v4/leads",
      "input": {
        "limit": {
          "type": "integer",
          "description": "Results per page, max 250",
          "default": 50
        },
        "page": {
          "type": "integer",
          "description": "Page number (1-indexed)",
          "default": 1
        },
        "with": {
          "type": "string",
          "description": "Related entities to include: contacts, companies, catalog_elements. Comma-separated.",
          "required": false
        },
        "filter[statuses][][pipeline_id]": {
          "type": "integer",
          "description": "Filter by pipeline ID",
          "required": false
        },
        "filter[statuses][][id]": {
          "type": "integer",
          "description": "Filter by specific status/stage ID",
          "required": false
        },
        "filter[responsible_user_id]": {
          "type": "array",
          "description": "Filter by responsible manager user IDs",
          "required": false
        },
        "filter[created_at][from]": {
          "type": "integer",
          "description": "Created after Unix timestamp",
          "required": false
        },
        "filter[created_at][to]": {
          "type": "integer",
          "description": "Created before Unix timestamp",
          "required": false
        },
        "order[created_at]": {
          "type": "string",
          "description": "Sort by creation date: asc or desc",
          "required": false
        }
      },
      "output": {
        "type": "list<lead>",
        "fields": [
          "_embedded.leads[0].id",
          "_embedded.leads[0].name",
          "_embedded.leads[0].price",
          "_embedded.leads[0].status_id",
          "_embedded.leads[0].pipeline_id",
          "_embedded.leads[0].responsible_user_id",
          "_embedded.leads[0].created_at",
          "_page_count"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_lead",
      "description_for_ai": "Create a new CRM deal (сделка) in amoCRM with name, budget, pipeline stage, responsible manager, and custom fields.",
      "intent": [
        "добавить сделку",
        "новый лид",
        "создать клиента",
        "добавить в CRM"
      ],
      "endpoint": "POST https://{subdomain}.amocrm.ru/api/v4/leads",
      "input": {
        "name": {
          "type": "string",
          "description": "Deal/lead name — should describe the opportunity",
          "required": true
        },
        "price": {
          "type": "integer",
          "description": "Deal value/budget amount in account currency",
          "required": false
        },
        "pipeline_id": {
          "type": "integer",
          "description": "Pipeline ID to create deal in. Default pipeline if not specified.",
          "required": false
        },
        "status_id": {
          "type": "integer",
          "description": "Stage/status ID within the pipeline",
          "required": false
        },
        "responsible_user_id": {
          "type": "integer",
          "description": "Manager user ID to assign deal to",
          "required": false
        },
        "custom_fields_values": {
          "type": "array",
          "description": "[{field_id: 123, values: [{value: 'Field value'}]}] for custom CRM fields",
          "required": false
        },
        "_embedded": {
          "type": "object",
          "description": "{contacts: [{id: contact_id}], companies: [{id: company_id}]} to link contacts/companies",
          "required": false
        }
      },
      "output": {
        "type": "list<lead>",
        "fields": [
          "_embedded.leads[0].id",
          "_embedded.leads[0].name",
          "_embedded.leads[0].price",
          "_embedded.leads[0].request_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_contacts",
      "description_for_ai": "List contacts in amoCRM with search.",
      "intent": [
        "amoCRM contacts",
        "crm contacts list",
        "контакты amoCRM"
      ],
      "endpoint": "GET https://{subdomain}.amocrm.ru/api/v4/contacts",
      "input": {
        "query": {
          "type": "string",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 50
        },
        "page": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<contact>",
        "fields": [
          "_embedded.contacts[0].id",
          "_embedded.contacts[0].name",
          "_embedded.contacts[0].first_name",
          "_embedded.contacts[0].last_name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_lead",
      "description_for_ai": "Create a new deal/lead in amoCRM pipeline.",
      "intent": [
        "новая сделка amoCRM",
        "create deal",
        "lead amoCRM",
        "добавить сделку"
      ],
      "endpoint": "POST https://{subdomain}.amocrm.ru/api/v4/leads",
      "input": {
        "name": {
          "type": "string",
          "required": true
        },
        "price": {
          "type": "integer",
          "required": false
        },
        "status_id": {
          "type": "integer",
          "required": false
        },
        "pipeline_id": {
          "type": "integer",
          "required": false
        },
        "contact_id": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "lead",
        "fields": [
          "_embedded.leads[0].id",
          "_embedded.leads[0].name",
          "_embedded.leads[0].status_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "add_note",
      "description_for_ai": "Add a note to a lead, contact or company in amoCRM.",
      "intent": [
        "заметка amoCRM",
        "note crm",
        "добавить комментарий amoCRM"
      ],
      "endpoint": "POST https://{subdomain}.amocrm.ru/api/v4/leads/{lead_id}/notes",
      "input": {
        "lead_id": {
          "type": "integer",
          "required": true
        },
        "note_type": {
          "type": "string",
          "description": "common, call_in, call_out, sms_in, sms_out",
          "default": "common"
        },
        "params": {
          "type": "object",
          "description": "{text: 'Note text'}",
          "required": true
        }
      },
      "output": {
        "type": "note",
        "fields": [
          "_embedded.notes[0].id",
          "_embedded.notes[0].created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "subdomain": "Replace {subdomain} with your amoCRM subdomain e.g. mycompany.amocrm.ru",
    "oauth": "Use OAuth2 long-lived token from account settings. Refresh tokens expire in 3 months.",
    "leads_vs_contacts": "amoCRM uses Leads (сделки) for sales pipeline and Contacts for people. Link them via associations.",
    "webhooks": "Configure webhooks in account for real-time updates on lead/contact changes."
  }
}