{
  "apia": "1.0",
  "service": {
    "id": "aws-comprehend",
    "name": "Amazon Comprehend",
    "description_for_ai": "AWS NLP service. Sentiment analysis, entity recognition, key phrase extraction, language detection, topic modeling, document classification. 50K units/month free first year. Supports 12 languages.",
    "url": "https://aws.amazon.com/comprehend",
    "api_base": "https://comprehend.{region}.amazonaws.com",
    "category": "nlp",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.aws.amazon.com/comprehend/"
  },
  "auth": {
    "type": "aws_sig_v4",
    "anonymous_access": false,
    "how_to_get": "AWS account",
    "cost": "Free: 50K units/month (1 year). Then $0.0001 per unit"
  },
  "capabilities": [
    {
      "id": "detect_sentiment",
      "description_for_ai": "Detect overall sentiment of text: POSITIVE, NEGATIVE, NEUTRAL, MIXED.",
      "intent": [
        "sentiment AWS",
        "text sentiment Comprehend",
        "opinion detection",
        "анализ тональности AWS"
      ],
      "endpoint": "POST https://comprehend.{region}.amazonaws.com/",
      "input": {
        "Text": {
          "type": "string",
          "description": "Text to analyze (max 5000 bytes)",
          "required": true
        },
        "LanguageCode": {
          "type": "string",
          "description": "en, es, fr, de, it, pt, ar, hi, ja, ko, zh, zh-TW",
          "required": true
        }
      },
      "output": {
        "type": "sentiment",
        "fields": [
          "Sentiment (POSITIVE/NEGATIVE/NEUTRAL/MIXED)",
          "SentimentScore.Positive (0-1)",
          "SentimentScore.Negative"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_entities",
      "description_for_ai": "Extract named entities from text: PERSON, LOCATION, ORGANIZATION, DATE, QUANTITY, etc.",
      "intent": [
        "entity detection AWS",
        "NER Comprehend",
        "extract names",
        "извлечение сущностей AWS"
      ],
      "endpoint": "POST https://comprehend.{region}.amazonaws.com/",
      "input": {
        "Text": {
          "type": "string",
          "required": true
        },
        "LanguageCode": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "entities",
        "fields": [
          "Entities[0].Text",
          "Entities[0].Type (PERSON/LOCATION/ORG/DATE/QUANTITY/TITLE/COMMERCIAL_ITEM)",
          "Entities[0].Score",
          "Entities[0].BeginOffset"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_key_phrases",
      "description_for_ai": "Extract key phrases (important concepts) from text.",
      "intent": [
        "key phrases",
        "topic extraction",
        "keyword extraction AWS",
        "ключевые фразы AWS"
      ],
      "endpoint": "POST https://comprehend.{region}.amazonaws.com/",
      "input": {
        "Text": {
          "type": "string",
          "required": true
        },
        "LanguageCode": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "key_phrases",
        "fields": [
          "KeyPhrases[0].Text",
          "KeyPhrases[0].Score (0-1)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_language",
      "description_for_ai": "Detect the dominant language of text (100+ languages).",
      "intent": [
        "detect language AWS",
        "language detection Comprehend",
        "what language",
        "определить язык AWS"
      ],
      "endpoint": "POST https://comprehend.{region}.amazonaws.com/",
      "input": {
        "Text": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "language",
        "fields": [
          "Languages[0].LanguageCode (ISO 639-1)",
          "Languages[0].Score (confidence 0-1)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "classify_document",
      "description_for_ai": "Classify documents using a custom trained Comprehend classifier.",
      "intent": [
        "document classification AWS",
        "custom classifier",
        "text categorization",
        "классификация документов AWS"
      ],
      "endpoint": "POST https://comprehend.{region}.amazonaws.com/",
      "input": {
        "Text": {
          "type": "string",
          "required": true
        },
        "EndpointArn": {
          "type": "string",
          "description": "ARN of your custom classifier endpoint",
          "required": true
        }
      },
      "output": {
        "type": "classification",
        "fields": [
          "Classes[0].Name",
          "Classes[0].Score"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}