{
  "apia": "1.0",
  "service": {
    "id": "aws-comprehend",
    "name": "Amazon Comprehend",
    "description_for_ai": "AWS NLP service. Sentiment analysis, entity recognition, key phrase extraction, language detection, topic modeling, document classification. 50K units/month free first year. Supports 12 languages.",
    "url": "https://aws.amazon.com/comprehend",
    "api_base": "https://comprehend.{region}.amazonaws.com",
    "category": "nlp",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.aws.amazon.com/comprehend/"
  },
  "auth": {
    "type": "aws_sig_v4",
    "anonymous_access": false,
    "how_to_get": "AWS account",
    "cost": "Free: 50K units/month (1 year). Then $0.0001 per unit"
  },
  "capabilities": [
    {
      "id": "detect_sentiment",
      "description_for_ai": "Detect sentiment (positive, negative, neutral, mixed) in text.",
      "intent": [
        "sentiment analysis",
        "text sentiment",
        "opinion mining",
        "анализ тональности текста"
      ],
      "endpoint": "POST https://comprehend.{region}.amazonaws.com/",
      "input": {
        "Text": {
          "type": "string",
          "description": "Text up to 5KB",
          "required": true
        },
        "LanguageCode": {
          "type": "string",
          "description": "en, es, fr, de, it, pt, ar, hi, ja, ko, zh, zh-TW",
          "required": true
        }
      },
      "output": {
        "type": "sentiment",
        "fields": [
          "Sentiment (POSITIVE|NEGATIVE|NEUTRAL|MIXED)",
          "SentimentScore.Positive",
          "SentimentScore.Negative",
          "SentimentScore.Neutral"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_entities",
      "description_for_ai": "Extract named entities from text: persons, locations, organizations, dates.",
      "intent": [
        "named entity recognition",
        "extract entities",
        "NER text",
        "распознавание сущностей текста"
      ],
      "endpoint": "POST https://comprehend.{region}.amazonaws.com/",
      "input": {
        "Text": {
          "type": "string",
          "required": true
        },
        "LanguageCode": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "entities",
        "fields": [
          "Entities[0].Text",
          "Entities[0].Type (PERSON|LOCATION|ORGANIZATION|DATE|QUANTITY)",
          "Entities[0].Score",
          "Entities[0].BeginOffset"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_key_phrases",
      "description_for_ai": "Extract key phrases and topics from text.",
      "intent": [
        "key phrases",
        "topic extraction",
        "text keywords",
        "ключевые фразы текста"
      ],
      "endpoint": "POST https://comprehend.{region}.amazonaws.com/",
      "input": {
        "Text": {
          "type": "string",
          "required": true
        },
        "LanguageCode": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "key_phrases",
        "fields": [
          "KeyPhrases[0].Text",
          "KeyPhrases[0].Score",
          "KeyPhrases[0].BeginOffset"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "classify_document",
      "description_for_ai": "Classify text using custom or pre-trained classifiers.",
      "intent": [
        "text classification",
        "document classifier",
        "classify text AWS",
        "классификация текста AWS"
      ],
      "endpoint": "POST https://comprehend.{region}.amazonaws.com/",
      "input": {
        "Text": {
          "type": "string",
          "required": true
        },
        "EndpointArn": {
          "type": "string",
          "description": "Custom classifier endpoint ARN",
          "required": true
        }
      },
      "output": {
        "type": "classification",
        "fields": [
          "Classes[0].Name",
          "Classes[0].Score"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_language",
      "description_for_ai": "Detect the language of text from 100 languages.",
      "intent": [
        "detect language AWS",
        "identify language",
        "language detection",
        "определить язык текста"
      ],
      "endpoint": "POST https://comprehend.{region}.amazonaws.com/",
      "input": {
        "Text": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "languages",
        "fields": [
          "Languages[0].LanguageCode",
          "Languages[0].Score"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}