{
  "apia": "1.0",
  "service": {
    "id": "github",
    "name": "GitHub API",
    "description_for_ai": "World's largest code hosting platform API. Search repositories, manage code, create issues, pull requests, read files. Used by every developer. Use for code search, repository management, CI/CD automation, and developer profile lookup.",
    "url": "https://github.com",
    "api_base": "https://api.github.com",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.github.com/en/rest"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": true,
    "anonymous_limits": "60 requests/hour",
    "auth_limits": "5000 requests/hour",
    "header": "Authorization: Bearer ghp_...",
    "how_to_get": "GitHub Settings → Developer Settings → Personal Access Tokens",
    "cost": "Free for public repos. GitHub Pro: $4/month"
  },
  "capabilities": [
    {
      "id": "search_repositories",
      "description_for_ai": "Search GitHub repositories by keyword, language, stars, topics. Returns repo list with metadata.",
      "intent": [
        "find github repo",
        "search code",
        "github search",
        "find open source",
        "найти репозиторий"
      ],
      "endpoint": "GET https://api.github.com/search/repositories",
      "input": {
        "q": {
          "type": "string",
          "description": "Search query with qualifiers: language:python, stars:>1000, topic:machine-learning, user:torvalds",
          "required": true
        },
        "sort": {
          "type": "string",
          "description": "stars, forks, help-wanted-issues, updated",
          "default": "best match"
        },
        "order": {
          "type": "string",
          "default": "desc"
        },
        "per_page": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<repo>",
        "fields": [
          "items[0].full_name",
          "items[0].description",
          "items[0].stargazers_count",
          "items[0].language",
          "items[0].html_url",
          "total_count"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_repository",
      "description_for_ai": "Get full repository details: description, stars, forks, language, topics, license, default branch, last push.",
      "intent": [
        "repo info",
        "repository details",
        "github repo",
        "project info",
        "информация о репозитории"
      ],
      "endpoint": "GET https://api.github.com/repos/{owner}/{repo}",
      "input": {
        "owner": {
          "type": "string",
          "required": true
        },
        "repo": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "repository",
        "fields": [
          "id",
          "full_name",
          "description",
          "stargazers_count",
          "forks_count",
          "language",
          "topics",
          "license.name",
          "default_branch",
          "pushed_at",
          "html_url"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "list_issues",
      "description_for_ai": "List repository issues with filters. Use for bug tracking, project management, seeing what needs work.",
      "intent": [
        "github issues",
        "repo bugs",
        "open issues",
        "feature requests",
        "задачи репозитория"
      ],
      "endpoint": "GET https://api.github.com/repos/{owner}/{repo}/issues",
      "input": {
        "owner": {
          "type": "string",
          "required": true
        },
        "repo": {
          "type": "string",
          "required": true
        },
        "state": {
          "type": "string",
          "description": "open, closed, all",
          "default": "open"
        },
        "labels": {
          "type": "string",
          "description": "Comma-separated labels: bug,enhancement",
          "required": false
        },
        "assignee": {
          "type": "string",
          "required": false
        },
        "sort": {
          "type": "string",
          "description": "created, updated, comments",
          "default": "created"
        },
        "per_page": {
          "type": "integer",
          "default": 30
        }
      },
      "output": {
        "type": "list<issue>",
        "fields": [
          "[0].number",
          "[0].title",
          "[0].state",
          "[0].user.login",
          "[0].labels[0].name",
          "[0].comments",
          "[0].created_at",
          "[0].html_url"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "create_issue",
      "description_for_ai": "Create a new issue in a repository with title, body, labels, and assignees.",
      "intent": [
        "create issue",
        "report bug",
        "feature request",
        "open ticket",
        "создать задачу github"
      ],
      "endpoint": "POST https://api.github.com/repos/{owner}/{repo}/issues",
      "input": {
        "owner": {
          "type": "string",
          "required": true
        },
        "repo": {
          "type": "string",
          "required": true
        },
        "title": {
          "type": "string",
          "required": true
        },
        "body": {
          "type": "string",
          "description": "Issue description in Markdown",
          "required": false
        },
        "labels": {
          "type": "array",
          "description": "['bug', 'enhancement']",
          "required": false
        },
        "assignees": {
          "type": "array",
          "description": "GitHub usernames to assign",
          "required": false
        },
        "milestone": {
          "type": "integer",
          "description": "Milestone number",
          "required": false
        }
      },
      "output": {
        "type": "issue",
        "fields": [
          "number",
          "title",
          "html_url",
          "state",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_file_contents",
      "description_for_ai": "Get content of a file from a repository. Returns base64 encoded content. Use to read source code, configs, docs.",
      "intent": [
        "read file github",
        "get source code",
        "file contents",
        "read repo file",
        "прочитать файл из репозитория"
      ],
      "endpoint": "GET https://api.github.com/repos/{owner}/{repo}/contents/{path}",
      "input": {
        "owner": {
          "type": "string",
          "required": true
        },
        "repo": {
          "type": "string",
          "required": true
        },
        "path": {
          "type": "string",
          "description": "File path e.g. src/main.py or README.md",
          "required": true
        },
        "ref": {
          "type": "string",
          "description": "Branch, tag, or commit SHA. Default: default branch.",
          "required": false
        }
      },
      "output": {
        "type": "file",
        "fields": [
          "name",
          "path",
          "sha",
          "size",
          "content (base64)",
          "encoding",
          "html_url",
          "download_url"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "create_or_update_file",
      "description_for_ai": "Create or update a file in a repository. Commits the change with a message. Requires SHA of existing file when updating.",
      "intent": [
        "create file github",
        "update file",
        "commit file",
        "write to repo",
        "push file",
        "записать файл в репозиторий"
      ],
      "endpoint": "PUT https://api.github.com/repos/{owner}/{repo}/contents/{path}",
      "input": {
        "owner": {
          "type": "string",
          "required": true
        },
        "repo": {
          "type": "string",
          "required": true
        },
        "path": {
          "type": "string",
          "required": true
        },
        "message": {
          "type": "string",
          "description": "Commit message",
          "required": true
        },
        "content": {
          "type": "string",
          "description": "Base64 encoded file content",
          "required": true
        },
        "sha": {
          "type": "string",
          "description": "SHA of existing file (required when updating)",
          "required": false
        },
        "branch": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "commit",
        "fields": [
          "content.path",
          "commit.sha",
          "commit.message",
          "commit.html_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_pull_requests",
      "description_for_ai": "List pull requests in a repository. See what code changes are pending review or merged.",
      "intent": [
        "pull requests",
        "PRs",
        "code review",
        "pending merges",
        "пулл реквесты"
      ],
      "endpoint": "GET https://api.github.com/repos/{owner}/{repo}/pulls",
      "input": {
        "owner": {
          "type": "string",
          "required": true
        },
        "repo": {
          "type": "string",
          "required": true
        },
        "state": {
          "type": "string",
          "description": "open, closed, all",
          "default": "open"
        },
        "head": {
          "type": "string",
          "description": "Filter by head branch: user:branch-name",
          "required": false
        },
        "base": {
          "type": "string",
          "description": "Filter by base branch e.g. main",
          "required": false
        },
        "sort": {
          "type": "string",
          "description": "created, updated, popularity, long-running",
          "default": "created"
        },
        "per_page": {
          "type": "integer",
          "default": 30
        }
      },
      "output": {
        "type": "list<pr>",
        "fields": [
          "[0].number",
          "[0].title",
          "[0].state",
          "[0].user.login",
          "[0].head.ref",
          "[0].base.ref",
          "[0].html_url",
          "[0].created_at"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "list_commits",
      "description_for_ai": "Get commit history for a repository or specific file. Returns author, message, date, SHA.",
      "intent": [
        "git commits",
        "commit history",
        "code changes",
        "who changed what",
        "история коммитов"
      ],
      "endpoint": "GET https://api.github.com/repos/{owner}/{repo}/commits",
      "input": {
        "owner": {
          "type": "string",
          "required": true
        },
        "repo": {
          "type": "string",
          "required": true
        },
        "sha": {
          "type": "string",
          "description": "Branch name or commit SHA to start from",
          "required": false
        },
        "path": {
          "type": "string",
          "description": "Filter by file path",
          "required": false
        },
        "author": {
          "type": "string",
          "description": "GitHub username or email",
          "required": false
        },
        "since": {
          "type": "string",
          "description": "ISO 8601 date filter",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 30
        }
      },
      "output": {
        "type": "list<commit>",
        "fields": [
          "[0].sha",
          "[0].commit.message",
          "[0].commit.author.name",
          "[0].commit.author.date",
          "[0].html_url"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "create_release",
      "description_for_ai": "Create a GitHub release with tag, title, release notes. Attach release assets (binaries, packages).",
      "intent": [
        "create release",
        "publish release",
        "github release",
        "tag release",
        "выпустить релиз"
      ],
      "endpoint": "POST https://api.github.com/repos/{owner}/{repo}/releases",
      "input": {
        "owner": {
          "type": "string",
          "required": true
        },
        "repo": {
          "type": "string",
          "required": true
        },
        "tag_name": {
          "type": "string",
          "description": "Tag for the release e.g. v1.0.0",
          "required": true
        },
        "name": {
          "type": "string",
          "description": "Release title",
          "required": false
        },
        "body": {
          "type": "string",
          "description": "Release notes in Markdown",
          "required": false
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "prerelease": {
          "type": "boolean",
          "default": false
        },
        "target_commitish": {
          "type": "string",
          "description": "Branch or commit SHA for the tag",
          "default": "main"
        }
      },
      "output": {
        "type": "release",
        "fields": [
          "id",
          "tag_name",
          "name",
          "html_url",
          "published_at",
          "upload_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_user",
      "description_for_ai": "Get GitHub user profile: bio, company, location, public repos count, followers.",
      "intent": [
        "github user",
        "user profile",
        "who is on github",
        "developer info",
        "профиль github"
      ],
      "endpoint": "GET https://api.github.com/users/{username}",
      "input": {
        "username": {
          "type": "string",
          "description": "GitHub username",
          "required": true
        }
      },
      "output": {
        "type": "user",
        "fields": [
          "login",
          "name",
          "bio",
          "company",
          "location",
          "public_repos",
          "followers",
          "following",
          "html_url",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "search_tip": "Use qualifiers in search: 'language:python stars:>500 topic:llm' finds popular Python LLM repos.",
    "base64_tip": "File content for create_file must be Base64 encoded. In JS: btoa(content). In Python: base64.b64encode(content.encode()).decode()",
    "rate_limit": "Without auth: 60 req/hour. With token: 5000 req/hour. Always use token in production.",
    "pagination": "Results paginated. Use ?page=2&per_page=100 to get more results."
  },
  "limits": {
    "anonymous_requests_per_hour": 60,
    "authenticated_requests_per_hour": 5000,
    "commercial_use": true,
    "attribution_required": false
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}