{
  "apia": "1.0",
  "service": {
    "id": "google-gemini-flash",
    "name": "Gemini 2.5 Flash API",
    "description_for_ai": "Googles fastest and cheapest frontier model. Excellent quality at $0.30/$2.50 per 1M tokens. 1M token context. Free tier: 1500 req/day. Best for: high-volume tasks, real-time applications, cost-sensitive production.",
    "url": "https://ai.google.dev",
    "api_base": "https://generativelanguage.googleapis.com/v1beta",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://ai.google.dev/gemini-api/docs/models"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "https://aistudio.google.com/app/apikey — free key instantly",
    "cost": "Free: 1500 req/day. Paid: $0.30/$2.50 per 1M tokens"
  },
  "capabilities": [
    {
      "id": "generate_content",
      "description_for_ai": "Fast, cheap AI text generation with Gemini Flash. Best for high-volume tasks, summarization, classification.",
      "intent": [
        "fast AI",
        "cheap AI generation",
        "Gemini Flash",
        "text generation fast",
        "быстрый AI Gemini"
      ],
      "endpoint": "POST https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent",
      "input": {
        "contents": {
          "type": "array",
          "description": "[{role: 'user', parts: [{text: 'prompt'}]}]",
          "required": true
        },
        "systemInstruction": {
          "type": "object",
          "required": false
        },
        "generationConfig": {
          "type": "object",
          "description": "{temperature, maxOutputTokens, responseMimeType}",
          "required": false
        }
      },
      "output": {
        "type": "response",
        "fields": [
          "candidates[0].content.parts[0].text",
          "usageMetadata.totalTokenCount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "analyze_image",
      "description_for_ai": "Analyze images quickly and cheaply with Gemini Flash vision.",
      "intent": [
        "image analysis fast",
        "Gemini Flash vision",
        "classify image",
        "анализ фото Gemini Flash"
      ],
      "endpoint": "POST https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent",
      "input": {
        "contents": {
          "type": "array",
          "description": "[{parts: [{inline_data: {mime_type: 'image/jpeg', data: 'BASE64'}}, {text: 'question'}]}]",
          "required": true
        }
      },
      "output": {
        "type": "response",
        "fields": [
          "candidates[0].content.parts[0].text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "json_mode",
      "description_for_ai": "Force Gemini Flash to return strictly valid JSON. Use for structured extraction and classification.",
      "intent": [
        "JSON output AI",
        "structured extraction",
        "JSON mode Gemini",
        "извлечение данных JSON"
      ],
      "endpoint": "POST https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent",
      "input": {
        "contents": {
          "type": "array",
          "required": true
        },
        "generationConfig": {
          "type": "object",
          "description": "{responseMimeType: 'application/json', responseSchema: {type: 'object', properties: {...}}}",
          "required": true
        }
      },
      "output": {
        "type": "json",
        "fields": [
          "candidates[0].content.parts[0].text (valid JSON string)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "stream_content",
      "description_for_ai": "Stream Gemini Flash responses token by token. Use for real-time chat interfaces.",
      "intent": [
        "stream AI response",
        "real-time AI",
        "streaming Gemini",
        "стриминг AI"
      ],
      "endpoint": "POST https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:streamGenerateContent",
      "input": {
        "contents": {
          "type": "array",
          "required": true
        }
      },
      "output": {
        "type": "stream<response>",
        "fields": [
          "chunks[].candidates[0].content.parts[0].text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "batch_process",
      "description_for_ai": "Process multiple prompts efficiently with Gemini Flash. Lower cost per token than Pro.",
      "intent": [
        "batch AI",
        "bulk processing",
        "process many texts",
        "пакетная обработка AI"
      ],
      "endpoint": "POST https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent",
      "input": {
        "contents": {
          "type": "array",
          "required": true
        },
        "generationConfig": {
          "type": "object",
          "description": "{temperature: 0, maxOutputTokens: 200}",
          "required": false
        }
      },
      "output": {
        "type": "response",
        "fields": [
          "candidates[0].content.parts[0].text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "free_tier": "1500 req/day free — most generous free tier among frontier models in 2026.",
    "best_value": "Best price-to-quality ratio in 2026. OpenAI-comparable quality at lower cost.",
    "thinking": "Add thinkingConfig: {thinkingBudget: 1024} for chain-of-thought on complex tasks."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}