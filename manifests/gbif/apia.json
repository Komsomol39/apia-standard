{"apia":"1.0","service":{"id":"gbif","name":"GBIF Biodiversity API","description_for_ai":"Global Biodiversity Information Facility. 2.4B+ species occurrence records. All species on Earth with location, taxonomy, images. Completely free. Use for nature apps, biodiversity research, species identification.","url":"https://gbif.org","api_base":"https://api.gbif.org/v1","category":"biodiversity","geo":["GLOBAL"],"language":"en","docs":"https://www.gbif.org/developer/summary"},"auth":{"type":"none","anonymous_access":true,"cost":"Free forever"},"capabilities":[{"id":"search_occurrences","description_for_ai":"Search species occurrence records by name, location, or taxon. Returns where species has been observed.","intent":["species occurrences","where is this animal","animal sightings","plant location","species distribution","wildlife data"],"endpoint":"GET https://api.gbif.org/v1/occurrence/search","input":{"scientificName":{"type":"string","description":"Scientific name e.g. Panthera leo, Quercus robur","required":false},"country":{"type":"string","description":"ISO 2-letter country code","required":false},"decimalLatitude":{"type":"string","description":"lat range e.g. 50,60","required":false},"decimalLongitude":{"type":"string","description":"lng range","required":false},"year":{"type":"string","description":"Year or range e.g. 2020,2026","required":false},"limit":{"type":"integer","default":20}},"output":{"type":"occurrences","fields":["results[0].scientificName","results[0].decimalLatitude","results[0].decimalLongitude","results[0].country","results[0].year","results[0].media[0].identifier"]},"realtime":false,"requires_auth":false},{"id":"search_species","description_for_ai":"Search species by name. Returns taxonomic info: kingdom, phylum, class, order, family, genus.","intent":["species info","animal taxonomy","plant species","what is this species","species classification"],"endpoint":"GET https://api.gbif.org/v1/species/search","input":{"q":{"type":"string","description":"Common or scientific name","required":true},"rank":{"type":"string","description":"SPECIES, GENUS, FAMILY, ORDER","required":false},"status":{"type":"string","description":"ACCEPTED, SYNONYM","required":false}},"output":{"type":"list<species>","fields":["canonicalName","vernacularName","kingdom","phylum","class","order","family","genus","taxonomicStatus"]},"realtime":false,"requires_auth":false}],"meta":{"apia_version":"1.0","manifest_author":"APIA community","last_verified":"2026-06-14"}}