{
  "apia": "1.0",
  "service": {
    "id": "gbif",
    "name": "GBIF Biodiversity API",
    "description_for_ai": "Global Biodiversity Information Facility. 2.4B+ species occurrence records. All species on Earth with location, taxonomy, images. Completely free. Use for nature apps, biodiversity research, species identification.",
    "url": "https://gbif.org",
    "api_base": "https://api.gbif.org/v1",
    "category": "science",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.gbif.org/developer/summary"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free forever"
  },
  "capabilities": [
    {
      "id": "search_occurrences",
      "description_for_ai": "Search species occurrence records by name, location, or taxon. Returns where species has been observed.",
      "intent": [
        "species occurrences",
        "where is this animal",
        "animal sightings",
        "plant location",
        "species distribution",
        "wildlife data"
      ],
      "endpoint": "GET https://api.gbif.org/v1/occurrence/search",
      "input": {
        "scientificName": {
          "type": "string",
          "description": "Scientific name e.g. Panthera leo, Quercus robur",
          "required": false
        },
        "country": {
          "type": "string",
          "description": "ISO 2-letter country code",
          "required": false
        },
        "decimalLatitude": {
          "type": "string",
          "description": "lat range e.g. 50,60",
          "required": false
        },
        "decimalLongitude": {
          "type": "string",
          "description": "lng range",
          "required": false
        },
        "year": {
          "type": "string",
          "description": "Year or range e.g. 2020,2026",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 20,
          "description": "Maximum number of results to return"
        }
      },
      "output": {
        "type": "occurrences",
        "fields": [
          "results[0].scientificName",
          "results[0].decimalLatitude",
          "results[0].decimalLongitude",
          "results[0].country",
          "results[0].year",
          "results[0].media[0].identifier"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "search_species",
      "description_for_ai": "Search species by name. Returns taxonomic info: kingdom, phylum, class, order, family, genus.",
      "intent": [
        "species info",
        "animal taxonomy",
        "plant species",
        "what is this species",
        "species classification"
      ],
      "endpoint": "GET https://api.gbif.org/v1/species/search",
      "input": {
        "q": {
          "type": "string",
          "description": "Common or scientific name",
          "required": true
        },
        "rank": {
          "type": "string",
          "description": "SPECIES, GENUS, FAMILY, ORDER",
          "required": false
        },
        "status": {
          "type": "string",
          "description": "ACCEPTED, SYNONYM",
          "required": false
        }
      },
      "output": {
        "type": "list<species>",
        "fields": [
          "canonicalName",
          "vernacularName",
          "kingdom",
          "phylum",
          "class",
          "order",
          "family",
          "genus",
          "taxonomicStatus"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "search_occurrences",
      "description_for_ai": "Search global biodiversity occurrence records from GBIF.",
      "intent": [
        "biodiversity occurrences",
        "species sightings",
        "GBIF search",
        "наблюдения видов"
      ],
      "endpoint": "GET https://api.gbif.org/v1/occurrence/search",
      "input": {
        "scientificName": {
          "type": "string",
          "required": false
        },
        "country": {
          "type": "string",
          "description": "ISO 3166-1 alpha-2",
          "required": false
        },
        "year": {
          "type": "integer",
          "required": false
        },
        "taxonKey": {
          "type": "integer",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<occurrence>",
        "fields": [
          "results[0].scientificName",
          "results[0].decimalLatitude",
          "results[0].decimalLongitude",
          "results[0].year",
          "results[0].country"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_dataset",
      "description_for_ai": "Get details about a specific GBIF dataset.",
      "intent": [
        "GBIF dataset",
        "biodiversity dataset",
        "dataset details GBIF"
      ],
      "endpoint": "GET https://api.gbif.org/v1/dataset/{key}",
      "input": {
        "key": {
          "type": "string",
          "description": "GBIF dataset UUID",
          "required": true
        }
      },
      "output": {
        "type": "dataset",
        "fields": [
          "key",
          "title",
          "description",
          "publishingOrganizationKey",
          "type",
          "recordCount"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "download_occurrences",
      "description_for_ai": "Request a download of occurrence data for bulk analysis.",
      "intent": [
        "download GBIF data",
        "bulk species data",
        "GBIF export"
      ],
      "endpoint": "POST https://api.gbif.org/v1/occurrence/download/request",
      "input": {
        "predicate": {
          "type": "object",
          "description": "{type: 'equals', key: 'TAXON_KEY', value: '2435098'}",
          "required": true
        }
      },
      "output": {
        "type": "download",
        "fields": [
          "key (download key to check status)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}