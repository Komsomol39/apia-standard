{
  "apia": "1.0",
  "service": {
    "id": "vercel",
    "name": "Vercel API",
    "description_for_ai": "Frontend cloud platform. Deploy Next.js, React, Vue, static sites. Edge functions, serverless, preview deployments. Used by Airbnb, GitHub, Stripe. Use for deploying web apps, managing deployments, environment variables.",
    "url": "https://vercel.com",
    "api_base": "https://api.vercel.com",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://vercel.com/docs/rest-api"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer {token}",
    "how_to_get": "Account Settings → Tokens",
    "cost": "Free hobby tier. Pro: $20/user/month"
  },
  "capabilities": [
    {
      "id": "list_deployments",
      "description_for_ai": "List Vercel deployments with status, URLs, and build info.",
      "intent": [
        "Vercel deployments",
        "list builds",
        "deployment history",
        "деплои Vercel"
      ],
      "endpoint": "GET https://api.vercel.com/v6/deployments",
      "input": {
        "app": {
          "type": "string",
          "description": "Filter by project name",
          "required": false
        },
        "state": {
          "type": "string",
          "description": "BUILDING, ERROR, INITIALIZING, QUEUED, READY, CANCELED",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 20
        },
        "teamId": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<deployment>",
        "fields": [
          "deployments[0].uid",
          "deployments[0].url",
          "deployments[0].state",
          "deployments[0].name",
          "deployments[0].createdAt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_deployment",
      "description_for_ai": "Get deployment details: URL, state, build logs.",
      "intent": [
        "deployment status Vercel",
        "build status",
        "check deploy",
        "статус деплоя Vercel"
      ],
      "endpoint": "GET https://api.vercel.com/v13/deployments/{idOrUrl}",
      "input": {
        "idOrUrl": {
          "type": "string",
          "description": "Deployment ID or URL",
          "required": true
        }
      },
      "output": {
        "type": "deployment",
        "fields": [
          "id",
          "url",
          "state",
          "name",
          "createdAt",
          "target (production|preview)",
          "meta.githubCommitMessage"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_deployment",
      "description_for_ai": "Create a new Vercel deployment from a git repository or file bundle.",
      "intent": [
        "deploy to Vercel",
        "create deployment",
        "publish to Vercel",
        "деплой на Vercel"
      ],
      "endpoint": "POST https://api.vercel.com/v13/deployments",
      "input": {
        "name": {
          "type": "string",
          "description": "Project name",
          "required": true
        },
        "gitSource": {
          "type": "object",
          "description": "{type: 'github', repoId: 'org/repo', ref: 'main'}",
          "required": false
        },
        "files": {
          "type": "array",
          "description": "For file-based: [{file: 'path', data: 'base64', encoding: 'base64'}]",
          "required": false
        },
        "target": {
          "type": "string",
          "description": "production or staging",
          "required": false
        }
      },
      "output": {
        "type": "deployment",
        "fields": [
          "id",
          "url",
          "readyState",
          "alias[0]"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_projects",
      "description_for_ai": "List all Vercel projects with their deployment URLs.",
      "intent": [
        "Vercel projects",
        "list projects",
        "my Vercel apps",
        "проекты Vercel"
      ],
      "endpoint": "GET https://api.vercel.com/v9/projects",
      "input": {
        "limit": {
          "type": "integer",
          "default": 20
        },
        "teamId": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<project>",
        "fields": [
          "projects[0].id",
          "projects[0].name",
          "projects[0].latestDeployments[0].url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_env_vars",
      "description_for_ai": "Get environment variables for a Vercel project.",
      "intent": [
        "Vercel env vars",
        "environment variables",
        "project config Vercel",
        "переменные Vercel"
      ],
      "endpoint": "GET https://api.vercel.com/v9/projects/{idOrName}/env",
      "input": {
        "idOrName": {
          "type": "string",
          "required": true
        },
        "teamId": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<env>",
        "fields": [
          "envs[0].key",
          "envs[0].type",
          "envs[0].target",
          "envs[0].createdAt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "cancel_deployment",
      "description_for_ai": "Cancel an in-progress Vercel deployment.",
      "intent": [
        "cancel deploy Vercel",
        "stop build",
        "отменить деплой Vercel"
      ],
      "endpoint": "PATCH https://api.vercel.com/v12/deployments/{id}/cancel",
      "input": {
        "id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "deployment",
        "fields": [
          "uid",
          "state (CANCELED)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "token": "Create deployment token: vercel.com/account/tokens. Or use VERCEL_TOKEN environment variable.",
    "project_id": "Get project ID from project settings or list_deployments response projectId field.",
    "env_vars": "Manage via PATCH /v10/projects/{projectId} with env array. Target: production, preview, development.",
    "domains": "Add/remove custom domains via /v10/projects/{projectId}/domains endpoint."
  }
}