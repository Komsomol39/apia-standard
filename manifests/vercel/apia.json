{
  "apia": "1.0",
  "service": {
    "id": "vercel",
    "name": "Vercel API",
    "description_for_ai": "Frontend cloud platform. Deploy Next.js, React, Vue, static sites. Edge functions, serverless, preview deployments. Used by Airbnb, GitHub, Stripe. Use for deploying web apps, managing deployments, environment variables.",
    "url": "https://vercel.com",
    "api_base": "https://api.vercel.com",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://vercel.com/docs/rest-api"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer {token}",
    "how_to_get": "Account Settings → Tokens",
    "cost": "Free hobby tier. Pro: $20/user/month"
  },
  "capabilities": [
    {
      "id": "list_deployments",
      "description_for_ai": "List deployments with status, URL, branch, and deployment time.",
      "intent": [
        "vercel deployments",
        "list deploys",
        "deployment history",
        "деплои vercel"
      ],
      "endpoint": "GET https://api.vercel.com/v6/deployments",
      "input": {
        "teamId": {
          "type": "string",
          "description": "Team ID for team projects",
          "required": false
        },
        "projectId": {
          "type": "string",
          "description": "Filter by project ID",
          "required": false
        },
        "state": {
          "type": "string",
          "description": "QUEUED, BUILDING, ERROR, INITIALIZING, READY, CANCELED",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<deployment>",
        "fields": [
          "deployments[0].uid",
          "deployments[0].name",
          "deployments[0].url",
          "deployments[0].state",
          "deployments[0].created",
          "deployments[0].meta.githubCommitMessage"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_deployment",
      "description_for_ai": "Get details of a specific deployment including build logs URL and error info.",
      "intent": [
        "vercel deployment details",
        "deploy status",
        "check deploy",
        "статус деплоя vercel"
      ],
      "endpoint": "GET https://api.vercel.com/v13/deployments/{idOrUrl}",
      "input": {
        "idOrUrl": {
          "type": "string",
          "description": "Deployment ID (dpl_...) or deployment URL",
          "required": true
        },
        "teamId": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "deployment",
        "fields": [
          "id",
          "url",
          "state",
          "errorCode",
          "errorMessage",
          "buildingAt",
          "ready",
          "creator.username"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_projects",
      "description_for_ai": "List all Vercel projects with their production deployment URLs.",
      "intent": [
        "vercel projects",
        "list projects",
        "my deployments",
        "проекты vercel"
      ],
      "endpoint": "GET https://api.vercel.com/v9/projects",
      "input": {
        "teamId": {
          "type": "string",
          "required": false
        },
        "search": {
          "type": "string",
          "description": "Filter by project name",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<project>",
        "fields": [
          "projects[0].id",
          "projects[0].name",
          "projects[0].latestDeployments[0].url",
          "projects[0].framework",
          "projects[0].updatedAt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "cancel_deployment",
      "description_for_ai": "Cancel a running deployment.",
      "intent": [
        "cancel vercel deploy",
        "stop deployment",
        "cancel build vercel",
        "отменить деплой vercel"
      ],
      "endpoint": "PATCH https://api.vercel.com/v12/deployments/{id}/cancel",
      "input": {
        "id": {
          "type": "string",
          "description": "Deployment ID (dpl_...)",
          "required": true
        },
        "teamId": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "deployment",
        "fields": [
          "id",
          "state",
          "canceledAt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "token": "Create deployment token: vercel.com/account/tokens. Or use VERCEL_TOKEN environment variable.",
    "project_id": "Get project ID from project settings or list_deployments response projectId field.",
    "env_vars": "Manage via PATCH /v10/projects/{projectId} with env array. Target: production, preview, development.",
    "domains": "Add/remove custom domains via /v10/projects/{projectId}/domains endpoint."
  }
}