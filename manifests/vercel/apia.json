{
  "apia": "1.0",
  "service": {
    "id": "vercel",
    "name": "Vercel API",
    "description_for_ai": "Frontend cloud platform. Deploy Next.js, React, Vue, static sites. Edge functions, serverless, preview deployments. Used by Airbnb, GitHub, Stripe. Use for deploying web apps, managing deployments, environment variables.",
    "url": "https://vercel.com",
    "api_base": "https://api.vercel.com",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://vercel.com/docs/rest-api"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer {token}",
    "how_to_get": "Account Settings → Tokens",
    "cost": "Free hobby tier. Pro: $20/user/month"
  },
  "capabilities": [
    {
      "id": "list_deployments",
      "description_for_ai": "Get recent Vercel deployments with build status, URL, and git commit info. Use for CI/CD monitoring and deployment tracking.",
      "intent": [
        "deployment status",
        "list deployments",
        "build status",
        "vercel deployments",
        "deploy history"
      ],
      "endpoint": "GET https://api.vercel.com/v6/deployments",
      "input": {
        "limit": {
          "type": "integer",
          "description": "Max deployments to return, default 20",
          "default": 20
        },
        "projectId": {
          "type": "string",
          "description": "Filter by specific project ID (optional)",
          "required": false
        },
        "state": {
          "type": "string",
          "description": "Filter by state: BUILDING, ERROR, INITIALIZING, QUEUED, READY, CANCELED",
          "required": false
        },
        "teamId": {
          "type": "string",
          "description": "Team ID for team deployments",
          "required": false
        },
        "target": {
          "type": "string",
          "description": "Filter by environment: production or preview",
          "required": false
        }
      },
      "output": {
        "type": "list<deployment>",
        "fields": [
          "deployments[0].uid",
          "deployments[0].url",
          "deployments[0].state",
          "deployments[0].createdAt",
          "deployments[0].meta.githubCommitMessage",
          "deployments[0].meta.githubCommitRef",
          "deployments[0].name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_deployment",
      "description_for_ai": "Deploy a project to Vercel from a git repository. Returns deployment object with URL. Deployment builds asynchronously.",
      "intent": [
        "deploy to vercel",
        "new deployment",
        "publish site"
      ],
      "endpoint": "POST https://api.vercel.com/v13/deployments",
      "input": {
        "name": {
          "type": "string",
          "description": "Project name on Vercel",
          "required": true
        },
        "gitSource": {
          "type": "object",
          "description": "{type: 'github', repoId: '123456', ref: 'main'} for GitHub deploy. Also supports 'gitlab' and 'bitbucket'.",
          "required": false
        },
        "files": {
          "type": "array",
          "description": "Files to deploy directly: [{file: 'path/to/file.js', data: 'content', encoding: 'utf-8'}]",
          "required": false
        },
        "projectSettings": {
          "type": "object",
          "description": "{framework: 'nextjs'|'vite'|'create-react-app', buildCommand: 'npm run build', outputDirectory: 'dist'}",
          "required": false
        },
        "env": {
          "type": "array",
          "description": "[{key: 'API_URL', value: 'https://api.example.com', type: 'plain'|'secret'}] environment variables",
          "required": false
        },
        "target": {
          "type": "string",
          "description": "Deployment environment: production or preview",
          "required": false
        }
      },
      "output": {
        "type": "deployment",
        "fields": [
          "id",
          "url",
          "readyState",
          "createdAt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "token": "Create deployment token: vercel.com/account/tokens. Or use VERCEL_TOKEN environment variable.",
    "project_id": "Get project ID from project settings or list_deployments response projectId field.",
    "env_vars": "Manage via PATCH /v10/projects/{projectId} with env array. Target: production, preview, development.",
    "domains": "Add/remove custom domains via /v10/projects/{projectId}/domains endpoint."
  }
}