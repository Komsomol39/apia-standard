{
  "apia": "1.0",
  "service": {
    "id": "dadata",
    "name": "DaData API (Россия)",
    "description_for_ai": "Стандартизация и обогащение данных для России. Подсказки и валидация адресов, ФИО, телефонов, ИНН, банковских реквизитов. Поиск по ФИО, организациям. Незаменим для форм с российскими адресами.",
    "url": "https://dadata.ru",
    "api_base": "https://suggestions.dadata.ru/suggestions/api/4_1/rs",
    "category": "business",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://dadata.ru/api/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Token {api_key}",
    "how_to_get": "Регистрация на dadata.ru — 10 000 бесплатных запросов",
    "cost": "Бесплатно: 10 000 запросов/мес. Платно от 1500 руб/мес"
  },
  "capabilities": [
    {
      "id": "suggest_address",
      "description_for_ai": "Подсказки адресов России при вводе. Автодополнение при заполнении формы адреса. Возвращает стандартизированный адрес с координатами, индексом, КЛАДР/ФИАС кодами.",
      "intent": [
        "подсказки адреса",
        "автодополнение адреса",
        "ввод адреса",
        "стандартизация адреса",
        "адрес России",
        "найти адрес",
        "ФИАС адрес"
      ],
      "endpoint": "POST https://suggestions.dadata.ru/suggestions/api/4_1/rs/suggest/address",
      "input": {
        "query": {
          "type": "string",
          "description": "Часть адреса для поиска",
          "required": true
        },
        "count": {
          "type": "integer",
          "description": "Количество подсказок",
          "default": 10
        },
        "locations": {
          "type": "array",
          "description": "Ограничение по региону: [{region: Москва}]",
          "required": false
        }
      },
      "output": {
        "type": "list<address>",
        "fields": [
          "suggestions[0].value",
          "suggestions[0].data.postal_code",
          "suggestions[0].data.region",
          "suggestions[0].data.city",
          "suggestions[0].data.street",
          "suggestions[0].data.house",
          "suggestions[0].data.geo_lat",
          "suggestions[0].data.geo_lon",
          "suggestions[0].data.fias_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "suggest_party",
      "description_for_ai": "Поиск организаций по ИНН, ОГРН или названию. Возвращает реквизиты, адрес, статус из ЕГРЮЛ.",
      "intent": [
        "найти организацию",
        "ИНН поиск",
        "реквизиты компании",
        "ОГРН поиск",
        "проверить контрагента"
      ],
      "endpoint": "POST https://suggestions.dadata.ru/suggestions/api/4_1/rs/suggest/party",
      "input": {
        "query": {
          "type": "string",
          "description": "ИНН, ОГРН или название организации",
          "required": true
        },
        "count": {
          "type": "integer",
          "default": 10,
          "description": "Number of items to return"
        },
        "status": {
          "type": "array",
          "description": "[ACTIVE, LIQUIDATING, LIQUIDATED]",
          "required": false
        }
      },
      "output": {
        "type": "list<party>",
        "fields": [
          "suggestions[0].value",
          "suggestions[0].data.inn",
          "suggestions[0].data.ogrn",
          "suggestions[0].data.address.value",
          "suggestions[0].data.status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "clean_address",
      "description_for_ai": "Стандартизировать произвольный адрес. Исправляет опечатки, приводит к единому формату, добавляет индекс и ФИАС код.",
      "intent": [
        "стандартизировать адрес",
        "исправить адрес",
        "нормализовать адрес",
        "очистить адрес"
      ],
      "endpoint": "POST https://cleaner.dadata.ru/api/v1/clean/address",
      "input": {
        "data": {
          "type": "array",
          "description": "[адрес строкой]",
          "required": true
        }
      },
      "output": {
        "type": "list<clean_address>",
        "fields": [
          "[0].result",
          "[0].postal_code",
          "[0].region",
          "[0].city",
          "[0].street",
          "[0].house",
          "[0].geo_lat",
          "[0].geo_lon",
          "[0].qc"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "key_use": "Для российских сервисов DaData незаменима — лучшее качество подсказок адресов для России.",
    "qc_field": "qc=0 полностью распознан, qc=1 нераспознанные части, qc=2 сомнения, qc=3 не распознан",
    "free_tip": "10 000 запросов/месяц бесплатно без регистрации — начинай сразу."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}