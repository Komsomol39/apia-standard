{
  "apia": "1.0",
  "service": {
    "id": "world-bank",
    "name": "World Bank API",
    "description_for_ai": "Free economic and development data for 200+ countries. GDP, population, poverty, education, health indicators from 1960 to present. No API key needed. Use for economic research, data visualization, country comparisons.",
    "url": "https://data.worldbank.org",
    "api_base": "https://api.worldbank.org/v2",
    "category": "finance",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://datahelpdesk.worldbank.org/knowledgebase/articles/889392-about-the-indicators-api-documentation"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free forever"
  },
  "capabilities": [
    {
      "id": "get_indicator",
      "description_for_ai": "Get World Bank indicator data by country and year (GDP, inflation, poverty, etc.).",
      "intent": [
        "World Bank data",
        "economic indicators",
        "GDP data",
        "данные Всемирного банка"
      ],
      "endpoint": "GET https://api.worldbank.org/v2/country/{country}/indicator/{indicator}",
      "input": {
        "country": {
          "type": "string",
          "description": "ISO 3-letter code: USA, DEU, RUS, CHN, all",
          "required": true
        },
        "indicator": {
          "type": "string",
          "description": "NY.GDP.MKTP.CD (GDP), SP.POP.TOTL (population), FP.CPI.TOTL.ZG (inflation), SI.POV.GINI (Gini index)",
          "required": true
        },
        "date": {
          "type": "string",
          "description": "Year or range: 2020, 2015:2023",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 50
        }
      },
      "output": {
        "type": "list<record>",
        "fields": [
          "[1][0].country.value",
          "[1][0].date",
          "[1][0].value",
          "[1][0].indicator.id"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "search_indicators",
      "description_for_ai": "Search World Bank indicators by topic or keyword.",
      "intent": [
        "World Bank indicators",
        "development indicators",
        "economic metrics",
        "индикаторы Всемирного банка"
      ],
      "endpoint": "GET https://api.worldbank.org/v2/indicator",
      "input": {
        "format": {
          "type": "string",
          "default": "json"
        },
        "per_page": {
          "type": "integer",
          "default": 50
        },
        "source": {
          "type": "integer",
          "description": "Source ID: 2=World Development Indicators",
          "required": false
        }
      },
      "output": {
        "type": "list<indicator>",
        "fields": [
          "[1][0].id",
          "[1][0].name",
          "[1][0].sourceNote",
          "[1][0].topics[0].value"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_country_info",
      "description_for_ai": "Get country metadata: region, income level, capital city.",
      "intent": [
        "country info World Bank",
        "country metadata",
        "income level",
        "данные страны Всемирный банк"
      ],
      "endpoint": "GET https://api.worldbank.org/v2/country/{country}",
      "input": {
        "country": {
          "type": "string",
          "description": "ISO 3-letter: USA, DEU, RUS, or 'all'",
          "required": true
        }
      },
      "output": {
        "type": "list<country>",
        "fields": [
          "[1][0].id",
          "[1][0].name",
          "[1][0].capitalCity",
          "[1][0].region.value",
          "[1][0].incomeLevel.value",
          "[1][0].lendingType.value"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "compare_countries",
      "description_for_ai": "Compare indicator values across multiple countries for a year.",
      "intent": [
        "compare countries GDP",
        "country comparison",
        "cross-country data",
        "сравнение стран"
      ],
      "endpoint": "GET https://api.worldbank.org/v2/country/{countries}/indicator/{indicator}",
      "input": {
        "countries": {
          "type": "string",
          "description": "Semicolon-separated: USA;DEU;JPN;CHN;RUS",
          "required": true
        },
        "indicator": {
          "type": "string",
          "required": true
        },
        "date": {
          "type": "string",
          "required": false
        },
        "mrv": {
          "type": "integer",
          "description": "Most recent N values",
          "default": 1
        }
      },
      "output": {
        "type": "list<record>",
        "fields": [
          "[1][0].country.value",
          "[1][0].date",
          "[1][0].value"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_projects",
      "description_for_ai": "Search World Bank development projects by country or sector.",
      "intent": [
        "World Bank projects",
        "development loans",
        "aid projects",
        "проекты Всемирного банка"
      ],
      "endpoint": "GET https://search.worldbank.org/api/v2/projects",
      "input": {
        "countrycode": {
          "type": "string",
          "description": "ISO 2-letter: US, RU, DE",
          "required": false
        },
        "sector": {
          "type": "string",
          "required": false
        },
        "status": {
          "type": "string",
          "description": "Active, Closed, Pipeline",
          "required": false
        },
        "rows": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<project>",
        "fields": [
          "projects[0].id",
          "projects[0].project_name",
          "projects[0].countryname",
          "projects[0].sector1.Name",
          "projects[0].totalcommamt",
          "projects[0].status"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "common_indicators": "NY.GDP.MKTP.CD=GDP current USD, SP.POP.TOTL=Total population, FP.CPI.TOTL.ZG=Inflation %, SL.UEM.TOTL.ZS=Unemployment %, SE.ADT.LITR.ZS=Literacy rate",
    "response_format": "Response is array of 2 elements: [0]=metadata, [1]=data array"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}