{
  "apia": "1.0",
  "service": {
    "id": "world-bank",
    "name": "World Bank API",
    "description_for_ai": "Free economic and development data for 200+ countries. GDP, population, poverty, education, health indicators from 1960 to present. No API key needed. Use for economic research, data visualization, country comparisons.",
    "url": "https://data.worldbank.org",
    "api_base": "https://api.worldbank.org/v2",
    "category": "finance",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://datahelpdesk.worldbank.org/knowledgebase/articles/889392-about-the-indicators-api-documentation"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free forever"
  },
  "capabilities": [
    {
      "id": "get_indicator",
      "description_for_ai": "Get economic indicator data for countries and years. GDP, inflation, unemployment, exports, population, education, health.",
      "intent": [
        "GDP data",
        "economic data",
        "country statistics",
        "development indicators",
        "population data",
        "unemployment rate",
        "world bank data"
      ],
      "endpoint": "GET https://api.worldbank.org/v2/country/{country}/indicator/{indicator}",
      "input": {
        "country": {
          "type": "string",
          "description": "ISO 2-letter country code or all for all countries. e.g. RU, US, DE, CN",
          "required": true
        },
        "indicator": {
          "type": "string",
          "description": "NY.GDP.MKTP.CD=GDP, SP.POP.TOTL=Population, FP.CPI.TOTL.ZG=Inflation, SL.UEM.TOTL.ZS=Unemployment",
          "required": true
        },
        "format": {
          "type": "string",
          "default": "json",
          "description": "Response format: json, xml, or csv"
        },
        "date": {
          "type": "string",
          "description": "Year range e.g. 2010:2023",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 50,
          "description": "Results per page. Check API docs for maximum allowed."
        }
      },
      "output": {
        "type": "list<data_point>",
        "fields": [
          "[1][0].country.value",
          "[1][0].date",
          "[1][0].value"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "search_indicators",
      "description_for_ai": "Search available World Bank indicators by keyword.",
      "intent": [
        "find indicator",
        "economic metric",
        "World Bank indicators list"
      ],
      "endpoint": "GET https://api.worldbank.org/v2/indicator",
      "input": {
        "format": {
          "type": "string",
          "default": "json",
          "description": "Response format: json, xml, or csv"
        },
        "per_page": {
          "type": "integer",
          "default": 20,
          "description": "Results per page. Check API docs for maximum allowed."
        },
        "source": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<indicator>",
        "fields": [
          "[1][0].id",
          "[1][0].name",
          "[1][0].sourceNote"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_indicator_data",
      "description_for_ai": "Get World Bank indicator data for any country/countries.",
      "intent": [
        "World Bank data",
        "economic data",
        "development indicators",
        "данные Всемирного Банка"
      ],
      "endpoint": "GET https://api.worldbank.org/v2/country/{country}/indicator/{indicator}",
      "input": {
        "country": {
          "type": "string",
          "description": "ISO 2-letter code or 'all': US, RU, CN, all",
          "required": true
        },
        "indicator": {
          "type": "string",
          "description": "NY.GDP.MKTP.CD (GDP), SP.POP.TOTL (population), SL.UEM.TOTL.ZS (unemployment), SI.POV.GINI (Gini)",
          "required": true
        },
        "format": {
          "type": "string",
          "default": "json"
        },
        "mrv": {
          "type": "integer",
          "description": "Most recent N values",
          "required": false
        },
        "date": {
          "type": "string",
          "description": "Year or range: 2020 or 2010:2020",
          "required": false
        }
      },
      "output": {
        "type": "list<record>",
        "fields": [
          "[1][0].country.value",
          "[1][0].date",
          "[1][0].value",
          "[1][0].indicator.id"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "list_indicators",
      "description_for_ai": "List World Bank indicators by topic or search by keyword.",
      "intent": [
        "World Bank indicators",
        "economic indicators list",
        "development metrics",
        "показатели Всемирного Банка"
      ],
      "endpoint": "GET https://api.worldbank.org/v2/indicator",
      "input": {
        "topic": {
          "type": "integer",
          "description": "Topic ID: 1=Agriculture, 2=Aid, 3=Economy, 5=Education, 8=Health",
          "required": false
        },
        "format": {
          "type": "string",
          "default": "json"
        },
        "per_page": {
          "type": "integer",
          "default": 50
        }
      },
      "output": {
        "type": "list<indicator>",
        "fields": [
          "[1][0].id",
          "[1][0].name",
          "[1][0].sourceNote",
          "[1][0].topics[0].value"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_country_info",
      "description_for_ai": "Get World Bank country metadata: region, income level, capital, coordinates.",
      "intent": [
        "country info World Bank",
        "country metadata",
        "income level country",
        "данные страны Всемирный Банк"
      ],
      "endpoint": "GET https://api.worldbank.org/v2/country/{country}",
      "input": {
        "country": {
          "type": "string",
          "description": "ISO 2-letter code: US, RU, CN, DE, IN",
          "required": true
        },
        "format": {
          "type": "string",
          "default": "json"
        }
      },
      "output": {
        "type": "country",
        "fields": [
          "[1][0].name",
          "[1][0].capitalCity",
          "[1][0].region.value",
          "[1][0].incomeLevel.value",
          "[1][0].lendingType.value"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "common_indicators": "NY.GDP.MKTP.CD=GDP current USD, SP.POP.TOTL=Total population, FP.CPI.TOTL.ZG=Inflation %, SL.UEM.TOTL.ZS=Unemployment %, SE.ADT.LITR.ZS=Literacy rate",
    "response_format": "Response is array of 2 elements: [0]=metadata, [1]=data array"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}