{
  "apia": "1.0",
  "service": {
    "id": "egrul-fns",
    "name": "ЕГРЮЛ / ЕГРИП (ФНС России)",
    "description_for_ai": "Государственный реестр юридических лиц и индивидуальных предпринимателей России. Используй для проверки компании по ИНН или ОГРН: статус, дата регистрации, адрес, руководители, виды деятельности. Данные официальные — от ФНС России.",
    "url": "https://egrul.nalog.ru",
    "api_base": "https://api-fns.ru/api",
    "category": "business",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://api-fns.ru/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Зарегистрироваться на https://api-fns.ru/",
    "cost": "бесплатно до 100 запросов/сутки"
  },
  "capabilities": [
    {
      "id": "search_company",
      "description_for_ai": "Search Russian companies in EGRUL (Единый государственный реестр юридических лиц) by name, INN, or OGRN.",
      "intent": [
        "поиск компании",
        "ЕГРЮЛ поиск",
        "найти ИНН компании",
        "проверить компанию"
      ],
      "endpoint": "https://egrul.nalog.ru/search-result/{query}",
      "input": {
        "query": {
          "type": "string",
          "description": "Company name, INN (10 digits), or OGRN (13 digits)",
          "required": true
        },
        "region": {
          "type": "string",
          "description": "Region code (01-99)",
          "required": false
        }
      },
      "output": {
        "type": "list<company>",
        "fields": [
          "rows[0].n (name)",
          "rows[0].i (INN)",
          "rows[0].o (OGRN)",
          "rows[0].a (address)",
          "rows[0].e (status)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_company_details",
      "description_for_ai": "Get full EGRUL extract for a company: directors, founders, capital, activity codes.",
      "intent": [
        "выписка ЕГРЮЛ",
        "данные компании",
        "учредители компании",
        "директор компании ИНН"
      ],
      "endpoint": "https://egrul.nalog.ru/",
      "input": {
        "inn": {
          "type": "string",
          "description": "Company INN (10 digits for LLC, 12 for IP)",
          "required": false
        },
        "ogrn": {
          "type": "string",
          "description": "OGRN (13 digits)",
          "required": false
        }
      },
      "output": {
        "type": "company",
        "fields": [
          "ЮЛ.НаимЮЛПолн",
          "ЮЛ.ИННЮЛ",
          "ЮЛ.ОгрнДата",
          "РуководительЮЛ.ФИОПолн",
          "СведУчредит",
          "КодОКВЭД"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "search_entrepreneur",
      "description_for_ai": "Search individual entrepreneurs (ИП) in EGRIP by name or INN.",
      "intent": [
        "поиск ИП",
        "ЕГРИП",
        "ИП по ИНН",
        "найти предпринимателя"
      ],
      "endpoint": "https://egrul.nalog.ru/search-result/{query}",
      "input": {
        "query": {
          "type": "string",
          "description": "Name or INN of individual entrepreneur",
          "required": true
        },
        "type": {
          "type": "string",
          "description": "ip for entrepreneurs",
          "default": "ip"
        }
      },
      "output": {
        "type": "list<entrepreneur>",
        "fields": [
          "rows[0].n (name)",
          "rows[0].i (INN)",
          "rows[0].o (OGRNIP)",
          "rows[0].a (address)",
          "rows[0].e (status)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "check_company_status",
      "description_for_ai": "Check if a Russian company is active, liquidated, or in bankruptcy. Quick INN-based verification.",
      "intent": [
        "статус компании",
        "проверить организацию",
        "ликвидирована компания",
        "действующее ли ООО"
      ],
      "endpoint": "https://api-fns.ru/api/egr",
      "input": {
        "req": {
          "type": "string",
          "description": "INN or OGRN to check",
          "required": true
        },
        "key": {
          "type": "string",
          "description": "API key from api-fns.ru",
          "required": true
        }
      },
      "output": {
        "type": "company_status",
        "fields": [
          "items[0].ЮЛ.НаимЮЛПолн",
          "items[0].ЮЛ.СтатусЮЛ"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "inn_tip": "ИНН юрлица — 10 цифр, ИНН ИП — 12 цифр. ОГРН юрлица — 13 цифр, ОГРНИП — 15 цифр.",
    "status_tip": "Проверяй поле СтатусЮЛ — если 'Недействующее', компания ликвидирована.",
    "alternative": "Также можно использовать официальный сервис ФНС напрямую: https://egrul.nalog.ru — но там нет API, только веб-форма."
  },
  "limits": {
    "free_requests_per_day": 100,
    "commercial_use": true,
    "attribution_required": false,
    "data_source": "Официальные данные ФНС России (ЕГРЮЛ/ЕГРИП)"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}