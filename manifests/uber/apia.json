{
  "apia": "1.0",
  "service": {
    "id": "uber",
    "name": "Uber API",
    "description_for_ai": "Uber ride-sharing and delivery API. Get price estimates, request rides, track drivers. Available in 70+ countries. Use for integrating ride booking, showing fare estimates, or managing ride requests.",
    "url": "https://developer.uber.com",
    "api_base": "https://api.uber.com/v1.2",
    "category": "transport",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.uber.com/docs/riders/introduction"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Register at https://developer.uber.com",
    "cost": "Free for development. Production requires Uber partnership."
  },
  "capabilities": [
    {
      "id": "get_products",
      "description_for_ai": "Get available Uber ride products (UberX, UberXL, Comfort, Black) for a location.",
      "intent": [
        "Uber products",
        "available rides",
        "ride types Uber",
        "виды поездок Uber"
      ],
      "endpoint": "GET https://api.uber.com/v1.2/products",
      "input": {
        "latitude": {
          "type": "float",
          "description": "Pickup latitude",
          "required": true
        },
        "longitude": {
          "type": "float",
          "description": "Pickup longitude",
          "required": true
        }
      },
      "output": {
        "type": "list<product>",
        "fields": [
          "products[0].product_id",
          "products[0].display_name",
          "products[0].description",
          "products[0].capacity",
          "products[0].image"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_price_estimate",
      "description_for_ai": "Get price estimate for Uber rides between two locations.",
      "intent": [
        "Uber price",
        "ride cost estimate",
        "fare estimate Uber",
        "стоимость поездки Uber"
      ],
      "endpoint": "GET https://api.uber.com/v1.2/estimates/price",
      "input": {
        "start_latitude": {
          "type": "float",
          "required": true
        },
        "start_longitude": {
          "type": "float",
          "required": true
        },
        "end_latitude": {
          "type": "float",
          "required": true
        },
        "end_longitude": {
          "type": "float",
          "required": true
        }
      },
      "output": {
        "type": "list<estimate>",
        "fields": [
          "prices[0].display_name",
          "prices[0].estimate",
          "prices[0].low_estimate",
          "prices[0].high_estimate",
          "prices[0].duration",
          "prices[0].distance"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_time_estimate",
      "description_for_ai": "Get ETA (pickup time estimate) for Uber rides at a location.",
      "intent": [
        "Uber ETA",
        "pickup time Uber",
        "wait time Uber",
        "время ожидания Uber"
      ],
      "endpoint": "GET https://api.uber.com/v1.2/estimates/time",
      "input": {
        "start_latitude": {
          "type": "float",
          "required": true
        },
        "start_longitude": {
          "type": "float",
          "required": true
        },
        "product_id": {
          "type": "string",
          "description": "Filter for specific product",
          "required": false
        }
      },
      "output": {
        "type": "list<time_estimate>",
        "fields": [
          "times[0].display_name",
          "times[0].estimate (seconds)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "request_ride",
      "description_for_ai": "Request an Uber ride for a user (requires rider OAuth).",
      "intent": [
        "request Uber",
        "book ride Uber",
        "order Uber",
        "заказать Uber"
      ],
      "endpoint": "POST https://api.uber.com/v1.2/requests",
      "input": {
        "fare_id": {
          "type": "string",
          "description": "Fare ID from upfront fare request",
          "required": false
        },
        "product_id": {
          "type": "string",
          "required": true
        },
        "start_latitude": {
          "type": "float",
          "required": true
        },
        "start_longitude": {
          "type": "float",
          "required": true
        },
        "end_latitude": {
          "type": "float",
          "required": true
        },
        "end_longitude": {
          "type": "float",
          "required": true
        }
      },
      "output": {
        "type": "request",
        "fields": [
          "request_id",
          "status",
          "driver.name",
          "driver.phone_number",
          "vehicle.make",
          "vehicle.model",
          "eta"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_ride_status",
      "description_for_ai": "Get status of a current Uber ride request.",
      "intent": [
        "Uber ride status",
        "track Uber",
        "driver location Uber",
        "статус поездки Uber"
      ],
      "endpoint": "GET https://api.uber.com/v1.2/requests/{request_id}",
      "input": {
        "request_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "request",
        "fields": [
          "status",
          "driver.name",
          "driver.rating",
          "location.latitude",
          "location.longitude",
          "eta",
          "vehicle.license_plate"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_ride_history",
      "description_for_ai": "Get the authenticated user's Uber ride history.",
      "intent": [
        "Uber history",
        "past rides",
        "ride receipts",
        "история поездок Uber"
      ],
      "endpoint": "GET https://api.uber.com/v1.2/history",
      "input": {
        "offset": {
          "type": "integer",
          "default": 0
        },
        "limit": {
          "type": "integer",
          "default": 5
        }
      },
      "output": {
        "type": "list<trip>",
        "fields": [
          "history[0].start_city.display_name",
          "history[0].distance",
          "history[0].start_time",
          "history[0].end_time",
          "history[0].status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}