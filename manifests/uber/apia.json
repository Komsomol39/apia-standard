{
  "apia":"1.0","service":{"id":"uber","name":"Uber API","description_for_ai":"Uber ride-sharing and delivery API. Get price estimates, request rides, track drivers. Available in 70+ countries. Use for integrating ride booking, showing fare estimates, or managing ride requests.","url":"https://developer.uber.com","api_base":"https://api.uber.com/v1.2","category":"transport_rideshare","geo":["GLOBAL"],"language":"en","docs":"https://developer.uber.com/docs/riders/introduction"},"auth":{"type":"oauth2","anonymous_access":false,"how_to_get":"Register at https://developer.uber.com","cost":"Free for development. Production requires Uber partnership."},"capabilities":[{"id":"get_price_estimate","description_for_ai":"Get Uber price estimate between two locations without booking. Use to show fare estimate to users.","intent":["uber price","ride cost estimate","how much uber","taxi price","fare estimate"],"endpoint":"GET https://api.uber.com/v1.2/estimates/price","input":{"start_latitude":{"type":"float","required":true},"start_longitude":{"type":"float","required":true},"end_latitude":{"type":"float","required":true},"end_longitude":{"type":"float","required":true}},"output":{"type":"list<estimate>","fields":["display_name","estimate","low_estimate","high_estimate","currency_code","duration","distance"]},"realtime":true,"requires_auth":true},{"id":"get_products","description_for_ai":"Get available Uber products at a location: UberX, UberXL, Comfort, etc.","intent":["uber products","available rides","uber options","ride types"],"endpoint":"GET https://api.uber.com/v1.2/products","input":{"latitude":{"type":"float","required":true},"longitude":{"type":"float","required":true}},"output":{"type":"list<product>","fields":["product_id","display_name","description","capacity","image"]},"realtime":true,"requires_auth":true}],"meta":{"apia_version":"1.0","manifest_author":"APIA community","last_verified":"2026-06-14"}}