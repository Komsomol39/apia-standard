{
  "apia": "1.0",
  "service": {
    "id": "uber",
    "name": "Uber API",
    "description_for_ai": "Uber ride-sharing and delivery API. Get price estimates, request rides, track drivers. Available in 70+ countries. Use for integrating ride booking, showing fare estimates, or managing ride requests.",
    "url": "https://developer.uber.com",
    "api_base": "https://api.uber.com/v1.2",
    "category": "transport",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.uber.com/docs/riders/introduction"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Register at https://developer.uber.com",
    "cost": "Free for development. Production requires Uber partnership."
  },
  "capabilities": [
    {
      "id": "get_price_estimate",
      "description_for_ai": "Get Uber fare estimate between two GPS coordinates without booking. Returns available ride types with price range and duration.",
      "intent": [
        "uber price",
        "ride cost estimate",
        "how much uber",
        "taxi price",
        "fare estimate"
      ],
      "endpoint": "GET https://api.uber.com/v1.2/estimates/price",
      "input": {
        "start_latitude": {
          "type": "float",
          "description": "Pickup latitude (-90 to 90)",
          "required": true
        },
        "start_longitude": {
          "type": "float",
          "description": "Pickup longitude (-180 to 180)",
          "required": true
        },
        "end_latitude": {
          "type": "float",
          "description": "Dropoff latitude",
          "required": true
        },
        "end_longitude": {
          "type": "float",
          "description": "Dropoff longitude",
          "required": true
        },
        "seat_count": {
          "type": "integer",
          "description": "Number of seats required (for UberXL, etc.)",
          "default": 2
        }
      },
      "output": {
        "type": "list<estimate>",
        "fields": [
          "prices[0].product_id",
          "prices[0].display_name",
          "prices[0].estimate (e.g. '$12-16')",
          "prices[0].low_estimate",
          "prices[0].high_estimate",
          "prices[0].currency_code",
          "prices[0].duration (seconds)",
          "prices[0].distance (miles)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_products",
      "description_for_ai": "Get available Uber ride types at a location: UberX, UberXL, Comfort, Black, etc. with capacity and description.",
      "intent": [
        "uber products",
        "available rides",
        "uber options",
        "ride types"
      ],
      "endpoint": "GET https://api.uber.com/v1.2/products",
      "input": {
        "latitude": {
          "type": "float",
          "description": "Location latitude",
          "required": true
        },
        "longitude": {
          "type": "float",
          "description": "Location longitude",
          "required": true
        }
      },
      "output": {
        "type": "list<product>",
        "fields": [
          "products[0].product_id",
          "products[0].display_name",
          "products[0].description",
          "products[0].capacity",
          "products[0].image"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}