{
  "apia": "1.0",
  "service": {
    "id": "uber",
    "name": "Uber API",
    "description_for_ai": "Uber ride-sharing and delivery API. Get price estimates, request rides, track drivers. Available in 70+ countries. Use for integrating ride booking, showing fare estimates, or managing ride requests.",
    "url": "https://developer.uber.com",
    "api_base": "https://api.uber.com/v1.2",
    "category": "transport",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.uber.com/docs/riders/introduction"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Register at https://developer.uber.com",
    "cost": "Free for development. Production requires Uber partnership."
  },
  "capabilities": [
    {
      "id": "get_price_estimates",
      "description_for_ai": "Get ride price estimates for Uber products between two locations.",
      "intent": [
        "uber price",
        "ride estimate",
        "how much uber",
        "стоимость uber",
        "цена uber"
      ],
      "endpoint": "GET https://api.uber.com/v1.2/estimates/price",
      "input": {
        "start_latitude": {
          "type": "float",
          "required": true
        },
        "start_longitude": {
          "type": "float",
          "required": true
        },
        "end_latitude": {
          "type": "float",
          "required": true
        },
        "end_longitude": {
          "type": "float",
          "required": true
        },
        "seat_count": {
          "type": "integer",
          "description": "Number of seats for uberPOOL",
          "default": 2
        }
      },
      "output": {
        "type": "list<estimate>",
        "fields": [
          "prices[0].display_name",
          "prices[0].estimate",
          "prices[0].minimum",
          "prices[0].duration",
          "prices[0].distance"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_time_estimates",
      "description_for_ai": "Get ETA (time until pickup) for Uber products at a location.",
      "intent": [
        "uber ETA",
        "uber arrival time",
        "pickup time uber",
        "время ожидания uber"
      ],
      "endpoint": "GET https://api.uber.com/v1.2/estimates/time",
      "input": {
        "start_latitude": {
          "type": "float",
          "required": true
        },
        "start_longitude": {
          "type": "float",
          "required": true
        },
        "product_id": {
          "type": "string",
          "description": "Specific product UUID. Omit for all products.",
          "required": false
        }
      },
      "output": {
        "type": "list<estimate>",
        "fields": [
          "times[0].display_name",
          "times[0].estimate (seconds)",
          "times[0].product_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_products",
      "description_for_ai": "Get available Uber products at a location (UberX, Comfort, Black, etc.).",
      "intent": [
        "uber products",
        "available rides uber",
        "uber types",
        "типы uber"
      ],
      "endpoint": "GET https://api.uber.com/v1.2/products",
      "input": {
        "latitude": {
          "type": "float",
          "required": true
        },
        "longitude": {
          "type": "float",
          "required": true
        }
      },
      "output": {
        "type": "list<product>",
        "fields": [
          "products[0].product_id",
          "products[0].display_name",
          "products[0].description",
          "products[0].capacity",
          "products[0].image"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_ride_history",
      "description_for_ai": "Get authenticated user's Uber ride history.",
      "intent": [
        "uber history",
        "past rides",
        "ride receipts",
        "история uber"
      ],
      "endpoint": "GET https://api.uber.com/v1.2/history",
      "input": {
        "offset": {
          "type": "integer",
          "default": 0
        },
        "limit": {
          "type": "integer",
          "description": "Max 50",
          "default": 5
        }
      },
      "output": {
        "type": "list<trip>",
        "fields": [
          "history[0].status",
          "history[0].start_city.display_name",
          "history[0].distance",
          "history[0].start_time",
          "history[0].end_time"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}