{
  "apia": "1.0",
  "service": {
    "id": "openai-batch",
    "name": "OpenAI Batch API",
    "description_for_ai": "Process large volumes of OpenAI API requests at 50% discount. Submit batch of requests, results ready within 24 hours. Perfect for bulk classification, embedding, analysis tasks. Same models as regular API.",
    "url": "https://openai.com",
    "api_base": "https://api.openai.com/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.openai.com/docs/guides/batch"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "Same OpenAI API key",
    "cost": "50% discount vs regular API. gpt-4o-mini: $0.075/$0.30 per 1M tokens"
  },
  "capabilities": [
    {
      "id": "create_batch",
      "description_for_ai": "Create an OpenAI batch job to process thousands of requests asynchronously at 50% cost.",
      "intent": [
        "OpenAI batch",
        "bulk API requests",
        "async AI processing",
        "пакетные запросы OpenAI"
      ],
      "endpoint": "POST https://api.openai.com/v1/batches",
      "input": {
        "input_file_id": {
          "type": "string",
          "description": "ID of JSONL file uploaded with /v1/files (purpose=batch)",
          "required": true
        },
        "endpoint": {
          "type": "string",
          "description": "/v1/chat/completions, /v1/embeddings, /v1/completions",
          "required": true
        },
        "completion_window": {
          "type": "string",
          "description": "24h",
          "default": "24h"
        },
        "metadata": {
          "type": "object",
          "description": "Optional metadata: {description: 'My batch job'}",
          "required": false
        }
      },
      "output": {
        "type": "batch",
        "fields": [
          "id",
          "status (validating/in_progress/completed/failed)",
          "endpoint",
          "created_at",
          "expires_at"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_batch_status",
      "description_for_ai": "Get the current status and progress of a batch job.",
      "intent": [
        "batch status OpenAI",
        "job progress",
        "batch complete?",
        "статус пакетного задания OpenAI"
      ],
      "endpoint": "GET https://api.openai.com/v1/batches/{batch_id}",
      "input": {
        "batch_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "batch",
        "fields": [
          "id",
          "status",
          "request_counts.total",
          "request_counts.completed",
          "request_counts.failed",
          "output_file_id",
          "error_file_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_batches",
      "description_for_ai": "List all batch jobs in the OpenAI account.",
      "intent": [
        "list batches OpenAI",
        "batch jobs",
        "my batches",
        "список пакетных заданий OpenAI"
      ],
      "endpoint": "GET https://api.openai.com/v1/batches",
      "input": {
        "limit": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<batch>",
        "fields": [
          "data[0].id",
          "data[0].status",
          "data[0].created_at",
          "data[0].request_counts.completed"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "cancel_batch",
      "description_for_ai": "Cancel a running batch job before it completes.",
      "intent": [
        "cancel batch OpenAI",
        "stop batch job",
        "abort batch",
        "отменить пакетное задание OpenAI"
      ],
      "endpoint": "POST https://api.openai.com/v1/batches/{batch_id}/cancel",
      "input": {
        "batch_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "batch",
        "fields": [
          "id",
          "status (cancelling/cancelled)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "upload_batch_file",
      "description_for_ai": "Upload a JSONL file containing batch requests to OpenAI.",
      "intent": [
        "upload batch file",
        "prepare batch OpenAI",
        "JSONL upload",
        "загрузить файл пакета OpenAI"
      ],
      "endpoint": "POST https://api.openai.com/v1/files",
      "input": {
        "file": {
          "type": "file",
          "description": "JSONL file where each line is: {custom_id, method, url, body}",
          "required": true
        },
        "purpose": {
          "type": "string",
          "default": "batch"
        }
      },
      "output": {
        "type": "file",
        "fields": [
          "id",
          "filename",
          "bytes",
          "created_at",
          "status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "workflow": "1) Create JSONL file with requests. 2) Upload via /v1/files. 3) Create batch with file_id. 4) Poll /v1/batches/{id} until completed. 5) Download output file.",
    "jsonl_format": "Each line: {custom_id: req-1, method: POST, url: /v1/chat/completions, body: {model, messages, max_tokens}}",
    "best_for": "Bulk tasks where you have 1000s of items: classification, translation, embedding, extraction."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}