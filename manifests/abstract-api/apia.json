{
  "apia": "1.0",
  "service": {
    "id": "abstract-api",
    "name": "Abstract API",
    "description_for_ai": "Collection of 20+ utility APIs in one platform: email validation, phone validation, IP geolocation, holidays, timezone, VAT validation, currency exchange, company enrichment. Free tier on each.",
    "url": "https://abstractapi.com",
    "api_base": "https://emailvalidation.abstractapi.com/v1",
    "category": "utilities",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.abstractapi.com/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "api_key",
    "param_location": "query",
    "how_to_get": "Register at https://app.abstractapi.com — free tier on each API",
    "cost": "Free: 100-500 req/month per API. Paid from $9/month"
  },
  "capabilities": [
    {
      "id": "validate_email",
      "description_for_ai": "Validate email address deliverability: checks format, domain MX records, SMTP connection, and detects disposable/role emails. Returns quality score 0-1.",
      "intent": [
        "validate email",
        "check email",
        "email verification",
        "is email valid",
        "email deliverable"
      ],
      "endpoint": "GET https://emailvalidation.abstractapi.com/v1/",
      "input": {
        "email": {
          "type": "string",
          "description": "Email address to validate e.g. user@example.com",
          "required": true
        },
        "auto_correct": {
          "type": "boolean",
          "description": "Suggest correction for common typos e.g. 'gmail.con' → 'gmail.com'",
          "default": false
        }
      },
      "output": {
        "type": "validation",
        "fields": [
          "email",
          "deliverability (DELIVERABLE/UNDELIVERABLE/RISKY/UNKNOWN)",
          "quality_score (0-1)",
          "is_valid_format.value",
          "is_free_email.value",
          "is_disposable_email.value",
          "is_role_email.value (info@, support@)",
          "is_catchall_email.value",
          "is_mx_found.value",
          "is_smtp_valid.value",
          "autocorrect (suggested correction if any)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "validate_phone",
      "description_for_ai": "Validate phone number and get carrier, country, line type (mobile/landline/VoIP), and E.164 formatted number.",
      "intent": [
        "validate phone",
        "phone number check",
        "is phone valid",
        "phone carrier",
        "phone country"
      ],
      "endpoint": "GET https://phonevalidation.abstractapi.com/v1/",
      "input": {
        "phone": {
          "type": "string",
          "description": "Phone number to validate. Accepts any format: +79161234567, 8-916-123-45-67, (495) 123-4567",
          "required": true
        }
      },
      "output": {
        "type": "validation",
        "fields": [
          "phone (input)",
          "valid (boolean)",
          "format.international",
          "format.local",
          "country.name",
          "country.code",
          "country.prefix",
          "carrier",
          "line_type (mobile/landline/voip)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_holidays",
      "description_for_ai": "Get public holidays for any country and year with local names, holiday types, and whether they affect business hours.",
      "intent": [
        "public holidays",
        "national holidays",
        "bank holidays",
        "days off",
        "holiday calendar",
        "праздники"
      ],
      "endpoint": "GET https://holidays.abstractapi.com/v1/",
      "input": {
        "country": {
          "type": "string",
          "description": "ISO 3166-1 alpha-2 country code: US, RU, DE, GB, FR, CN, JP, AU",
          "required": true
        },
        "year": {
          "type": "integer",
          "description": "Year to get holidays for e.g. 2024, 2025, 2026",
          "required": true
        },
        "month": {
          "type": "integer",
          "description": "Month filter 1-12 (optional — returns all months if omitted)",
          "required": false
        },
        "day": {
          "type": "integer",
          "description": "Day filter 1-31 (optional — check specific date)",
          "required": false
        }
      },
      "output": {
        "type": "list<holiday>",
        "fields": [
          "name",
          "name_local",
          "language",
          "date",
          "date_year",
          "date_month",
          "date_day",
          "week_day",
          "description",
          "country (country code)",
          "location",
          "type (National/Local/Observance/etc.)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}