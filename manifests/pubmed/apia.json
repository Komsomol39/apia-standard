{
  "apia": "1.0",
  "service": {
    "id": "pubmed",
    "name": "PubMed / NCBI Entrez API",
    "description_for_ai": "Free access to 35M+ biomedical research articles. Search by keyword, author, journal, MeSH terms. Get abstracts, full text links, citations. No API key needed for basic access. Essential for medical and scientific research.",
    "url": "https://pubmed.ncbi.nlm.nih.gov",
    "api_base": "https://eutils.ncbi.nlm.nih.gov/entrez/eutils",
    "category": "science",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.ncbi.nlm.nih.gov/books/NBK25499/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_limits": "3 req/sec",
    "param_name": "api_key",
    "param_location": "query",
    "how_to_get": "Register at https://www.ncbi.nlm.nih.gov/account/ — free",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "search",
      "description_for_ai": "Search PubMed biomedical literature database. 35M+ articles on medicine, biology, genetics.",
      "intent": [
        "search medical papers",
        "pubmed search",
        "medical research",
        "поиск медицинских статей PubMed"
      ],
      "endpoint": "GET https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esearch.fcgi",
      "input": {
        "db": {
          "type": "string",
          "default": "pubmed"
        },
        "term": {
          "type": "string",
          "description": "Search query. Examples: cancer[Title], LeCun[Author], brain tumor[MeSH Terms], 2024[PDAT]",
          "required": true
        },
        "retmax": {
          "type": "integer",
          "description": "Max results 1-10000",
          "default": 20
        },
        "retstart": {
          "type": "integer",
          "description": "Offset for pagination",
          "default": 0
        },
        "sort": {
          "type": "string",
          "description": "relevance or pub_date",
          "default": "relevance"
        },
        "retmode": {
          "type": "string",
          "default": "json"
        }
      },
      "output": {
        "type": "search_result",
        "fields": [
          "esearchresult.count",
          "esearchresult.idlist (PubMed IDs)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "fetch_articles",
      "description_for_ai": "Fetch full article details for PubMed IDs: title, abstract, authors, journal, DOI.",
      "intent": [
        "fetch pubmed articles",
        "article details",
        "paper info pubmed",
        "детали статьи PubMed"
      ],
      "endpoint": "GET https://eutils.ncbi.nlm.nih.gov/entrez/eutils/efetch.fcgi",
      "input": {
        "db": {
          "type": "string",
          "default": "pubmed"
        },
        "id": {
          "type": "string",
          "description": "Comma-separated PubMed IDs: 37376029,37376030",
          "required": true
        },
        "rettype": {
          "type": "string",
          "description": "abstract (plain text) or xml",
          "default": "abstract"
        },
        "retmode": {
          "type": "string",
          "default": "text"
        }
      },
      "output": {
        "type": "list<article>",
        "fields": [
          "Title",
          "Abstract",
          "Authors",
          "Journal",
          "PMID",
          "DOI"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_summary",
      "description_for_ai": "Get article summaries as JSON for multiple PubMed IDs. Faster than efetch for metadata.",
      "intent": [
        "article summary pubmed",
        "paper metadata",
        "bulk article info",
        "метаданные статей PubMed"
      ],
      "endpoint": "GET https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esummary.fcgi",
      "input": {
        "db": {
          "type": "string",
          "default": "pubmed"
        },
        "id": {
          "type": "string",
          "description": "Comma-separated PubMed IDs",
          "required": true
        },
        "retmode": {
          "type": "string",
          "default": "json"
        }
      },
      "output": {
        "type": "list<summary>",
        "fields": [
          "result.{PMID}.title",
          "result.{PMID}.authors[0].name",
          "result.{PMID}.pubdate",
          "result.{PMID}.source"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_cited_by",
      "description_for_ai": "Find articles that cite a specific PubMed article (using E-link).",
      "intent": [
        "citations pubmed",
        "citing papers",
        "who cites this paper",
        "цитирования PubMed"
      ],
      "endpoint": "GET https://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi",
      "input": {
        "dbfrom": {
          "type": "string",
          "default": "pubmed"
        },
        "db": {
          "type": "string",
          "default": "pubmed"
        },
        "id": {
          "type": "string",
          "description": "Source PubMed ID",
          "required": true
        },
        "linkname": {
          "type": "string",
          "description": "pubmed_pubmed_citedin (cited by) or pubmed_pubmed (related)",
          "default": "pubmed_pubmed_citedin"
        },
        "retmode": {
          "type": "string",
          "default": "json"
        }
      },
      "output": {
        "type": "links",
        "fields": [
          "linksets[0].linksetdbs[0].links (PubMed IDs of citing papers)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "search_clinical_trials",
      "description_for_ai": "Search PubMed for clinical trials on a condition or drug.",
      "intent": [
        "clinical trials",
        "medical trials pubmed",
        "drug research",
        "клинические исследования PubMed"
      ],
      "endpoint": "GET https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esearch.fcgi",
      "input": {
        "db": {
          "type": "string",
          "default": "pubmed"
        },
        "term": {
          "type": "string",
          "description": "e.g. 'COVID-19 vaccine[Title] AND Clinical Trial[Publication Type]' or 'metformin diabetes[Title/Abstract] AND Randomized Controlled Trial[pt]'",
          "required": true
        },
        "retmax": {
          "type": "integer",
          "default": 20
        },
        "retmode": {
          "type": "string",
          "default": "json"
        }
      },
      "output": {
        "type": "search_result",
        "fields": [
          "esearchresult.count",
          "esearchresult.idlist"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_full_text_link",
      "description_for_ai": "Get links to full-text versions and open access PDFs for PubMed articles.",
      "intent": [
        "full text pubmed",
        "open access paper",
        "free PDF research",
        "полный текст статьи PubMed"
      ],
      "endpoint": "GET https://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi",
      "input": {
        "dbfrom": {
          "type": "string",
          "default": "pubmed"
        },
        "id": {
          "type": "string",
          "required": true
        },
        "cmd": {
          "type": "string",
          "default": "prlinks"
        },
        "retmode": {
          "type": "string",
          "default": "json"
        }
      },
      "output": {
        "type": "links",
        "fields": [
          "linksets[0].idurllist[0].objurls[0].url.value (full text URL)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "flow": "1) esearch to get IDs by keyword. 2) efetch to get abstracts for those IDs.",
    "rate_limit": "Without API key: 3 req/sec. With key: 10 req/sec.",
    "mesh_terms": "Use MeSH controlled vocabulary for precise medical searches e.g. Neoplasms[MeSH]"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}