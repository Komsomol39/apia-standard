{
  "apia": "1.0",
  "service": {
    "id": "pubmed",
    "name": "PubMed / NCBI Entrez API",
    "description_for_ai": "Free access to 35M+ biomedical research articles. Search by keyword, author, journal, MeSH terms. Get abstracts, full text links, citations. No API key needed for basic access. Essential for medical and scientific research.",
    "url": "https://pubmed.ncbi.nlm.nih.gov",
    "api_base": "https://eutils.ncbi.nlm.nih.gov/entrez/eutils",
    "category": "science",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.ncbi.nlm.nih.gov/books/NBK25499/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_limits": "3 req/sec",
    "param_name": "api_key",
    "param_location": "query",
    "how_to_get": "Register at https://www.ncbi.nlm.nih.gov/account/ — free",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "search",
      "description_for_ai": "Search PubMed for biomedical literature by keyword, author, journal, date, or MeSH term.",
      "intent": [
        "pubmed search",
        "research papers",
        "medical literature",
        "scientific articles",
        "поиск pubmed"
      ],
      "endpoint": "GET https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esearch.fcgi",
      "input": {
        "db": {
          "type": "string",
          "default": "pubmed"
        },
        "term": {
          "type": "string",
          "description": "Query. Operators: AND, OR, NOT. Fields: [Author], [Journal], [MeSH Terms], [ti] for title. Example: 'diabetes AND insulin[MeSH Terms] AND 2024[dp]'",
          "required": true
        },
        "retmax": {
          "type": "integer",
          "description": "Max results",
          "default": 20
        },
        "retstart": {
          "type": "integer",
          "description": "Offset for pagination",
          "default": 0
        },
        "sort": {
          "type": "string",
          "description": "relevance or pub+date",
          "default": "relevance"
        },
        "datetype": {
          "type": "string",
          "description": "pdat (publication date)",
          "required": false
        },
        "mindate": {
          "type": "string",
          "description": "YYYY/MM/DD",
          "required": false
        },
        "maxdate": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "search",
        "fields": [
          "esearchresult.idlist (array of PMIDs)",
          "esearchresult.count",
          "esearchresult.translationset"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "fetch_abstracts",
      "description_for_ai": "Fetch article abstracts and metadata by PubMed IDs.",
      "intent": [
        "pubmed abstract",
        "article abstract",
        "paper details pubmed",
        "аннотация статьи pubmed"
      ],
      "endpoint": "GET https://eutils.ncbi.nlm.nih.gov/entrez/eutils/efetch.fcgi",
      "input": {
        "db": {
          "type": "string",
          "default": "pubmed"
        },
        "id": {
          "type": "string",
          "description": "Comma-separated PMIDs",
          "required": true
        },
        "rettype": {
          "type": "string",
          "description": "abstract, medline, xml",
          "default": "abstract"
        },
        "retmode": {
          "type": "string",
          "description": "text or xml",
          "default": "text"
        }
      },
      "output": {
        "type": "articles",
        "fields": [
          "PMID",
          "Title",
          "Abstract",
          "Authors",
          "Journal",
          "PublicationDate"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_article_details",
      "description_for_ai": "Fetch full metadata for PubMed articles: title, authors, DOI, citations, MeSH terms.",
      "intent": [
        "pubmed article",
        "citation details",
        "DOI pubmed",
        "детали статьи pubmed"
      ],
      "endpoint": "GET https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esummary.fcgi",
      "input": {
        "db": {
          "type": "string",
          "default": "pubmed"
        },
        "id": {
          "type": "string",
          "description": "Comma-separated PMIDs",
          "required": true
        },
        "retmode": {
          "type": "string",
          "default": "json"
        }
      },
      "output": {
        "type": "summaries",
        "fields": [
          "result.{pmid}.title",
          "result.{pmid}.authors[0].name",
          "result.{pmid}.source (journal)",
          "result.{pmid}.pubdate",
          "result.{pmid}.doi"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_citations",
      "description_for_ai": "Get articles that cite or are cited by a given PubMed article (citation links).",
      "intent": [
        "citations pubmed",
        "cited by",
        "references pubmed",
        "цитирования статьи"
      ],
      "endpoint": "GET https://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi",
      "input": {
        "dbfrom": {
          "type": "string",
          "default": "pubmed"
        },
        "db": {
          "type": "string",
          "default": "pubmed"
        },
        "id": {
          "type": "string",
          "description": "Source PMID",
          "required": true
        },
        "linkname": {
          "type": "string",
          "description": "pubmed_pubmed_citedin (cited by) or pubmed_pubmed_refs (references)",
          "required": true
        }
      },
      "output": {
        "type": "links",
        "fields": [
          "linksets[0].linksetdbs[0].links (array of related PMIDs)"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "flow": "1) esearch to get IDs by keyword. 2) efetch to get abstracts for those IDs.",
    "rate_limit": "Without API key: 3 req/sec. With key: 10 req/sec.",
    "mesh_terms": "Use MeSH controlled vocabulary for precise medical searches e.g. Neoplasms[MeSH]"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}