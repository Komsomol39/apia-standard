{
  "apia": "1.0",
  "service": {
    "id": "yookassa",
    "name": "ЮКасса API (YooKassa)",
    "description_for_ai": "Главный платёжный шлюз России от Яндекса. Приём платежей картами, СБП, ЮMoney, SberPay, наличными. Рассрочка Тинькофф. Используй для приёма онлайн-платежей в России, возвратов, подписок.",
    "url": "https://yookassa.ru",
    "api_base": "https://api.yookassa.ru/v3",
    "category": "finance",
    "geo": [
      "RU",
      "BY",
      "KZ"
    ],
    "language": "ru",
    "docs": "https://yookassa.ru/developers/api"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "shopId как логин, секретный ключ как пароль",
    "how_to_get": "Личный кабинет ЮКассы → Интеграция → Ключи API",
    "cost": "Без абонентской платы. Комиссия 2.8-3.5% с оборота"
  },
  "capabilities": [
    {
      "id": "create_payment",
      "description_for_ai": "Create a YooKassa (ЮKassa) payment for Russian e-commerce. Returns payment URL.",
      "intent": [
        "YooKassa payment",
        "ЮKassa оплата",
        "принять платёж ЮKassa",
        "российская оплата"
      ],
      "endpoint": "POST https://api.yookassa.ru/v3/payments",
      "input": {
        "amount": {
          "type": "object",
          "description": "{value: '100.00', currency: 'RUB'}",
          "required": true
        },
        "confirmation": {
          "type": "object",
          "description": "{type: 'redirect', return_url: 'https://...'}",
          "required": true
        },
        "capture": {
          "type": "boolean",
          "description": "Auto-capture (true) or authorize first (false)",
          "default": true
        },
        "description": {
          "type": "string",
          "description": "Payment description (max 128 chars)",
          "required": false
        },
        "metadata": {
          "type": "object",
          "description": "Custom metadata {order_id: '123'}",
          "required": false
        }
      },
      "output": {
        "type": "payment",
        "fields": [
          "id",
          "status (pending)",
          "confirmation.confirmation_url (redirect to this)",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_payment",
      "description_for_ai": "Get payment status and details by ID.",
      "intent": [
        "payment status YooKassa",
        "статус платежа ЮKassa",
        "проверить оплату ЮKassa"
      ],
      "endpoint": "GET https://api.yookassa.ru/v3/payments/{paymentId}",
      "input": {
        "paymentId": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "payment",
        "fields": [
          "id",
          "status (pending/waiting_for_capture/succeeded/canceled)",
          "amount.value",
          "payment_method.type",
          "captured_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "capture_payment",
      "description_for_ai": "Capture a held (authorized) payment.",
      "intent": [
        "capture YooKassa",
        "подтвердить платёж ЮKassa",
        "списать средства ЮKassa"
      ],
      "endpoint": "POST https://api.yookassa.ru/v3/payments/{paymentId}/capture",
      "input": {
        "paymentId": {
          "type": "string",
          "required": true
        },
        "amount": {
          "type": "object",
          "description": "{value: '100.00', currency: 'RUB'} — partial capture possible",
          "required": false
        }
      },
      "output": {
        "type": "payment",
        "fields": [
          "id",
          "status (succeeded)",
          "amount.value",
          "captured_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_refund",
      "description_for_ai": "Refund a YooKassa payment fully or partially.",
      "intent": [
        "refund YooKassa",
        "возврат ЮKassa",
        "отменить платёж ЮKassa"
      ],
      "endpoint": "POST https://api.yookassa.ru/v3/refunds",
      "input": {
        "payment_id": {
          "type": "string",
          "required": true
        },
        "amount": {
          "type": "object",
          "description": "{value: '50.00', currency: 'RUB'}",
          "required": true
        },
        "description": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "refund",
        "fields": [
          "id",
          "status (pending/succeeded/canceled)",
          "amount.value",
          "payment_id",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_webhook",
      "description_for_ai": "Subscribe to payment events via webhook: payment.succeeded, payment.canceled, refund.succeeded.",
      "intent": [
        "YooKassa webhook",
        "payment notification ЮKassa",
        "оплата вебхук ЮKassa"
      ],
      "endpoint": "POST https://api.yookassa.ru/v3/webhooks",
      "input": {
        "event": {
          "type": "string",
          "description": "payment.canceled, payment.succeeded, payment.waiting_for_capture, refund.succeeded",
          "required": true
        },
        "url": {
          "type": "string",
          "description": "Your webhook endpoint URL (must be HTTPS)",
          "required": true
        }
      },
      "output": {
        "type": "webhook",
        "fields": [
          "id",
          "event",
          "url",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "idempotency": "Add Idempotence-Key header (UUID) to prevent duplicate payments on retry. Same key = same result.",
    "webhook": "Configure webhooks in YooKassa dashboard for payment.succeeded, payment.canceled, refund.succeeded events.",
    "test_cards": "Test card: 4111111111111111, expiry any future date, CVC 123. Test 3DS: 4000000000000002",
    "receipts": "Russian law requires fiscal receipts (ФФД). Add receipt object with items and customer email/phone."
  }
}