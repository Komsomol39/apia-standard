{
  "apia": "1.0",
  "service": {
    "id": "yookassa",
    "name": "ЮКасса API (YooKassa)",
    "description_for_ai": "Главный платёжный шлюз России от Яндекса. Приём платежей картами, СБП, ЮMoney, SberPay, наличными. Рассрочка Тинькофф. Используй для приёма онлайн-платежей в России, возвратов, подписок.",
    "url": "https://yookassa.ru",
    "api_base": "https://api.yookassa.ru/v3",
    "category": "finance",
    "geo": [
      "RU",
      "BY",
      "KZ"
    ],
    "language": "ru",
    "docs": "https://yookassa.ru/developers/api"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "shopId как логин, секретный ключ как пароль",
    "how_to_get": "Личный кабинет ЮКассы → Интеграция → Ключи API",
    "cost": "Без абонентской платы. Комиссия 2.8-3.5% с оборота"
  },
  "capabilities": [
    {
      "id": "create_payment",
      "description_for_ai": "Create a payment in ЮКасса. Returns confirmation URL to redirect customer. Supports all Russian payment methods.",
      "intent": [
        "принять оплату юкасса",
        "создать платёж юкасса",
        "yookassa payment",
        "оплата картой россия"
      ],
      "endpoint": "POST https://api.yookassa.ru/v3/payments",
      "input": {
        "amount": {
          "type": "object",
          "description": "{value: '100.00', currency: 'RUB'}",
          "required": true
        },
        "confirmation": {
          "type": "object",
          "description": "{type: 'redirect', return_url: 'https://yoursite.ru/success'}",
          "required": true
        },
        "capture": {
          "type": "boolean",
          "description": "true — автоматический захват. false — двухэтапная оплата.",
          "default": true
        },
        "description": {
          "type": "string",
          "description": "Описание платежа видимое покупателю",
          "required": false
        },
        "metadata": {
          "type": "object",
          "description": "Ваши данные для сопоставления: {order_id: '123'}",
          "required": false
        },
        "receipt": {
          "type": "object",
          "description": "Чек для ФФД: {customer: {email}, items: [{description, quantity, amount, vat_code: 1}]}",
          "required": false
        },
        "payment_method_data": {
          "type": "object",
          "description": "{type: 'bank_card'} или не указывать для выбора покупателем",
          "required": false
        }
      },
      "output": {
        "type": "payment",
        "fields": [
          "id",
          "status",
          "confirmation.confirmation_url",
          "amount.value",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_payment",
      "description_for_ai": "Получить информацию о платеже по ID. Используй для проверки статуса после редиректа.",
      "intent": [
        "статус платежа юкасса",
        "проверить оплату",
        "payment status yookassa",
        "получить платёж"
      ],
      "endpoint": "GET https://api.yookassa.ru/v3/payments/{paymentId}",
      "input": {
        "paymentId": {
          "type": "string",
          "description": "ID платежа (uuid формата)",
          "required": true
        }
      },
      "output": {
        "type": "payment",
        "fields": [
          "id",
          "status (pending|waiting_for_capture|succeeded|canceled)",
          "paid",
          "amount.value",
          "payment_method.type",
          "captured_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_refund",
      "description_for_ai": "Создать возврат платежа полностью или частично.",
      "intent": [
        "возврат юкасса",
        "вернуть деньги юкасса",
        "refund yookassa",
        "отменить платёж юкасса"
      ],
      "endpoint": "POST https://api.yookassa.ru/v3/refunds",
      "input": {
        "payment_id": {
          "type": "string",
          "description": "ID платежа для возврата",
          "required": true
        },
        "amount": {
          "type": "object",
          "description": "{value: '50.00', currency: 'RUB'} — сумма возврата. Omit для полного возврата.",
          "required": false
        },
        "description": {
          "type": "string",
          "description": "Причина возврата",
          "required": false
        },
        "receipt": {
          "type": "object",
          "description": "Чек возврата (если был чек при оплате)",
          "required": false
        }
      },
      "output": {
        "type": "refund",
        "fields": [
          "id",
          "status",
          "amount.value",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_payments",
      "description_for_ai": "Получить список платежей с фильтрацией по дате, статусу, методу оплаты.",
      "intent": [
        "список платежей юкасса",
        "история платежей",
        "payment list yookassa",
        "отчёт по платежам"
      ],
      "endpoint": "GET https://api.yookassa.ru/v3/payments",
      "input": {
        "status": {
          "type": "string",
          "description": "pending, waiting_for_capture, succeeded, canceled",
          "required": false
        },
        "created_at.gte": {
          "type": "string",
          "description": "ISO 8601 — платежи после этой даты",
          "required": false
        },
        "created_at.lte": {
          "type": "string",
          "description": "ISO 8601 — платежи до этой даты",
          "required": false
        },
        "limit": {
          "type": "integer",
          "description": "Количество результатов 1-100",
          "default": 10
        },
        "cursor": {
          "type": "string",
          "description": "Курсор для пагинации",
          "required": false
        }
      },
      "output": {
        "type": "list<payment>",
        "fields": [
          "items[0].id",
          "items[0].status",
          "items[0].amount.value",
          "items[0].created_at",
          "next_cursor"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "idempotency": "Add Idempotence-Key header (UUID) to prevent duplicate payments on retry. Same key = same result.",
    "webhook": "Configure webhooks in YooKassa dashboard for payment.succeeded, payment.canceled, refund.succeeded events.",
    "test_cards": "Test card: 4111111111111111, expiry any future date, CVC 123. Test 3DS: 4000000000000002",
    "receipts": "Russian law requires fiscal receipts (ФФД). Add receipt object with items and customer email/phone."
  }
}