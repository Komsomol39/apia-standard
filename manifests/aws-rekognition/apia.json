{
  "apia": "1.0",
  "service": {
    "id": "aws-rekognition",
    "name": "AWS Rekognition",
    "description_for_ai": "Amazon Rekognition — AWS AI service for image and video analysis. Detect objects, scenes, faces, text, celebrities, inappropriate content. Face recognition and comparison. 5000 free images/month for first 12 months. Used by NFL, Pinterest, Marinus Analytics.",
    "url": "https://aws.amazon.com/rekognition",
    "api_base": "https://rekognition.{region}.amazonaws.com",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.aws.amazon.com/rekognition/"
  },
  "auth": {
    "type": "aws_sig_v4",
    "anonymous_access": false,
    "how_to_get": "AWS account at https://aws.amazon.com",
    "cost": "Free: 5000 images/month (1 year). Then $1/1000 images"
  },
  "capabilities": [
    {
      "id": "detect_labels",
      "description_for_ai": "Detect objects, scenes, and concepts in images with confidence scores and bounding boxes.",
      "intent": [
        "detect objects AWS",
        "image labels rekognition",
        "what is in image",
        "object detection AWS",
        "распознавание объектов AWS"
      ],
      "endpoint": "POST https://rekognition.{region}.amazonaws.com/",
      "input": {
        "Image": {
          "type": "object",
          "description": "{S3Object: {Bucket, Name, Version}} or {Bytes: BASE64}",
          "required": true
        },
        "MaxLabels": {
          "type": "integer",
          "default": 10
        },
        "MinConfidence": {
          "type": "float",
          "description": "Minimum confidence threshold 0-100",
          "default": 55.0
        }
      },
      "output": {
        "type": "labels",
        "fields": [
          "Labels[0].Name",
          "Labels[0].Confidence",
          "Labels[0].Instances[0].BoundingBox",
          "Labels[0].Parents"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_text",
      "description_for_ai": "Extract text from images — signs, license plates, documents. Returns text with location.",
      "intent": [
        "OCR AWS",
        "extract text rekognition",
        "read sign",
        "license plate",
        "распознать текст AWS"
      ],
      "endpoint": "POST https://rekognition.{region}.amazonaws.com/",
      "input": {
        "Image": {
          "type": "object",
          "required": true
        },
        "Filters": {
          "type": "object",
          "description": "{WordFilter: {MinConfidence: 80}, RegionsOfInterest: [{BoundingBox: {...}}]}",
          "required": false
        }
      },
      "output": {
        "type": "text",
        "fields": [
          "TextDetections[0].DetectedText",
          "TextDetections[0].Type (LINE|WORD)",
          "TextDetections[0].Confidence",
          "TextDetections[0].Geometry.BoundingBox"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "compare_faces",
      "description_for_ai": "Compare two face images to determine if same person. Returns similarity score. Use for identity verification.",
      "intent": [
        "face comparison AWS",
        "same person check",
        "face verification",
        "identity check",
        "сравнение лиц AWS"
      ],
      "endpoint": "POST https://rekognition.{region}.amazonaws.com/",
      "input": {
        "SourceImage": {
          "type": "object",
          "description": "Reference face image",
          "required": true
        },
        "TargetImage": {
          "type": "object",
          "description": "Image to compare against",
          "required": true
        },
        "SimilarityThreshold": {
          "type": "float",
          "description": "Minimum similarity to return 0-100",
          "default": 80.0
        }
      },
      "output": {
        "type": "face_match",
        "fields": [
          "FaceMatches[0].Similarity",
          "FaceMatches[0].Face.Confidence",
          "FaceMatches[0].Face.BoundingBox",
          "UnmatchedFaces"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_faces",
      "description_for_ai": "Detect faces in an image with attributes: age range, emotions, gender, glasses, beard, smile, pose.",
      "intent": [
        "detect faces",
        "face analysis",
        "emotion detection",
        "face attributes",
        "определение лиц AWS"
      ],
      "endpoint": "POST https://rekognition.{region}.amazonaws.com/",
      "input": {
        "Image": {
          "type": "object",
          "required": true
        },
        "Attributes": {
          "type": "array",
          "description": "['ALL'] for all attributes, ['DEFAULT'] for basic. Includes age, gender, emotions, facial hair.",
          "default": [
            "DEFAULT"
          ]
        }
      },
      "output": {
        "type": "faces",
        "fields": [
          "FaceDetails[0].AgeRange",
          "FaceDetails[0].Gender.Value",
          "FaceDetails[0].Emotions[0].Type",
          "FaceDetails[0].Emotions[0].Confidence",
          "FaceDetails[0].Smile.Value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "image_format": "Pass S3 URI or base64. S3 is faster and avoids base64 overhead for large images.",
    "region": "Use same region as your S3 bucket to avoid cross-region latency and data transfer costs.",
    "face_collection": "For face recognition at scale: create a collection, index faces, then use SearchFacesByImage.",
    "pricing": "First 5000 images/month free (12 months). Then $1-4/1000 images depending on feature."
  }
}