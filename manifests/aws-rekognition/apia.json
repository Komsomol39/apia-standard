{
  "apia": "1.0",
  "service": {
    "id": "aws-rekognition",
    "name": "AWS Rekognition",
    "description_for_ai": "Amazon Rekognition — AWS AI service for image and video analysis. Detect objects, scenes, faces, text, celebrities, inappropriate content. Face recognition and comparison. 5000 free images/month for first 12 months. Used by NFL, Pinterest, Marinus Analytics.",
    "url": "https://aws.amazon.com/rekognition",
    "api_base": "https://rekognition.{region}.amazonaws.com",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.aws.amazon.com/rekognition/"
  },
  "auth": {
    "type": "aws_sig_v4",
    "anonymous_access": false,
    "how_to_get": "AWS account at https://aws.amazon.com",
    "cost": "Free: 5000 images/month (1 year). Then $1/1000 images"
  },
  "capabilities": [
    {
      "id": "detect_labels",
      "description_for_ai": "Detect objects, scenes, and activities in images using AWS Rekognition.",
      "intent": [
        "detect objects image",
        "image labels",
        "what is in image",
        "что на изображении AWS"
      ],
      "endpoint": "POST https://rekognition.{region}.amazonaws.com/",
      "input": {
        "Image": {
          "type": "object",
          "description": "{Bytes: 'base64'} or {S3Object: {Bucket, Name}}",
          "required": true
        },
        "MaxLabels": {
          "type": "integer",
          "default": 10
        },
        "MinConfidence": {
          "type": "float",
          "description": "Minimum confidence 0-100",
          "default": 55
        }
      },
      "output": {
        "type": "labels",
        "fields": [
          "Labels[0].Name",
          "Labels[0].Confidence",
          "Labels[0].Parents[0].Name",
          "Labels[0].Instances (bounding boxes)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_faces",
      "description_for_ai": "Detect faces and analyze emotions, age range, facial features in images.",
      "intent": [
        "face detection",
        "detect emotions",
        "facial analysis",
        "распознавание лиц AWS"
      ],
      "endpoint": "POST https://rekognition.{region}.amazonaws.com/",
      "input": {
        "Image": {
          "type": "object",
          "description": "{Bytes: 'base64'} or {S3Object: {Bucket, Name}}",
          "required": true
        },
        "Attributes": {
          "type": "array",
          "description": "['ALL'] for full analysis or ['DEFAULT'] for basic",
          "default": [
            "DEFAULT"
          ]
        }
      },
      "output": {
        "type": "faces",
        "fields": [
          "FaceDetails[0].BoundingBox",
          "FaceDetails[0].AgeRange.Low",
          "FaceDetails[0].Emotions[0].Type",
          "FaceDetails[0].Emotions[0].Confidence",
          "FaceDetails[0].Gender.Value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_text",
      "description_for_ai": "Extract text from images and photos using Rekognition OCR.",
      "intent": [
        "OCR image",
        "read text from photo",
        "image text extraction",
        "распознавание текста на фото AWS"
      ],
      "endpoint": "POST https://rekognition.{region}.amazonaws.com/",
      "input": {
        "Image": {
          "type": "object",
          "required": true
        }
      },
      "output": {
        "type": "text",
        "fields": [
          "TextDetections[0].DetectedText",
          "TextDetections[0].Confidence",
          "TextDetections[0].Type (LINE|WORD)",
          "TextDetections[0].Geometry.BoundingBox"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "compare_faces",
      "description_for_ai": "Compare faces in two images to check if they're the same person.",
      "intent": [
        "face comparison",
        "face matching",
        "same person check",
        "сравнение лиц AWS"
      ],
      "endpoint": "POST https://rekognition.{region}.amazonaws.com/",
      "input": {
        "SourceImage": {
          "type": "object",
          "description": "Image with the reference face",
          "required": true
        },
        "TargetImage": {
          "type": "object",
          "description": "Image to compare against",
          "required": true
        },
        "SimilarityThreshold": {
          "type": "float",
          "description": "Minimum similarity 0-100",
          "default": 80
        }
      },
      "output": {
        "type": "comparison",
        "fields": [
          "FaceMatches[0].Similarity",
          "FaceMatches[0].Face.BoundingBox",
          "UnmatchedFaces"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_moderation",
      "description_for_ai": "Detect unsafe or inappropriate content in images for content moderation.",
      "intent": [
        "image moderation",
        "NSFW detection",
        "unsafe content",
        "модерация изображений AWS"
      ],
      "endpoint": "POST https://rekognition.{region}.amazonaws.com/",
      "input": {
        "Image": {
          "type": "object",
          "required": true
        },
        "MinConfidence": {
          "type": "float",
          "default": 50
        }
      },
      "output": {
        "type": "moderation",
        "fields": [
          "ModerationLabels[0].Name",
          "ModerationLabels[0].Confidence",
          "ModerationLabels[0].ParentName"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "image_format": "Pass S3 URI or base64. S3 is faster and avoids base64 overhead for large images.",
    "region": "Use same region as your S3 bucket to avoid cross-region latency and data transfer costs.",
    "face_collection": "For face recognition at scale: create a collection, index faces, then use SearchFacesByImage.",
    "pricing": "First 5000 images/month free (12 months). Then $1-4/1000 images depending on feature."
  }
}