{
  "apia": "1.0",
  "service": {
    "id": "aws-rekognition",
    "name": "AWS Rekognition",
    "description_for_ai": "Amazon Rekognition — AWS AI service for image and video analysis. Detect objects, scenes, faces, text, celebrities, inappropriate content. Face recognition and comparison. 5000 free images/month for first 12 months. Used by NFL, Pinterest, Marinus Analytics.",
    "url": "https://aws.amazon.com/rekognition",
    "api_base": "https://rekognition.{region}.amazonaws.com",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.aws.amazon.com/rekognition/"
  },
  "auth": {
    "type": "aws_sig_v4",
    "anonymous_access": false,
    "how_to_get": "AWS account at https://aws.amazon.com",
    "cost": "Free: 5000 images/month (1 year). Then $1/1000 images"
  },
  "capabilities": [
    {
      "id": "detect_labels",
      "description_for_ai": "Detect objects, scenes, and activities in images with AWS Rekognition.",
      "intent": [
        "detect labels Rekognition",
        "image recognition AWS",
        "object detection",
        "распознавание объектов AWS"
      ],
      "endpoint": "POST https://rekognition.{region}.amazonaws.com/",
      "input": {
        "Image": {
          "type": "object",
          "description": "{S3Object: {Bucket: 'bucket', Name: 'image.jpg'}} or {Bytes: 'base64'}",
          "required": true
        },
        "MaxLabels": {
          "type": "integer",
          "default": 10
        },
        "MinConfidence": {
          "type": "float",
          "default": 55.0
        }
      },
      "output": {
        "type": "labels",
        "fields": [
          "Labels[0].Name",
          "Labels[0].Confidence",
          "Labels[0].Categories[0].Name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_faces",
      "description_for_ai": "Detect and analyze faces in images: age range, emotions, gender, glasses, mask.",
      "intent": [
        "face detection Rekognition",
        "face analysis AWS",
        "emotions AWS",
        "обнаружение лиц AWS"
      ],
      "endpoint": "POST https://rekognition.{region}.amazonaws.com/",
      "input": {
        "Image": {
          "type": "object",
          "required": true
        },
        "Attributes": {
          "type": "array",
          "description": "['DEFAULT', 'ALL', 'AGE_RANGE', 'EMOTIONS']",
          "default": [
            "DEFAULT"
          ]
        }
      },
      "output": {
        "type": "faces",
        "fields": [
          "FaceDetails[0].AgeRange.Low",
          "FaceDetails[0].Gender.Value",
          "FaceDetails[0].Emotions[0].Type",
          "FaceDetails[0].Smile.Value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_text",
      "description_for_ai": "Detect and extract text from images (OCR) with AWS Rekognition.",
      "intent": [
        "OCR Rekognition",
        "image text AWS",
        "text detection",
        "распознавание текста AWS"
      ],
      "endpoint": "POST https://rekognition.{region}.amazonaws.com/",
      "input": {
        "Image": {
          "type": "object",
          "required": true
        }
      },
      "output": {
        "type": "text",
        "fields": [
          "TextDetections[0].DetectedText",
          "TextDetections[0].Type (LINE/WORD)",
          "TextDetections[0].Confidence"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "compare_faces",
      "description_for_ai": "Compare a face in a source image with faces in a target image.",
      "intent": [
        "face comparison Rekognition",
        "face matching",
        "person verification",
        "сравнение лиц AWS"
      ],
      "endpoint": "POST https://rekognition.{region}.amazonaws.com/",
      "input": {
        "SourceImage": {
          "type": "object",
          "required": true
        },
        "TargetImage": {
          "type": "object",
          "required": true
        },
        "SimilarityThreshold": {
          "type": "float",
          "description": "Minimum similarity 0-100",
          "default": 80.0
        }
      },
      "output": {
        "type": "comparison",
        "fields": [
          "FaceMatches[0].Similarity",
          "FaceMatches[0].Face.BoundingBox",
          "UnmatchedFaces"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_moderation",
      "description_for_ai": "Detect inappropriate, explicit, or violent content in images.",
      "intent": [
        "content moderation AWS",
        "explicit content detection",
        "safe image check",
        "модерация изображений AWS"
      ],
      "endpoint": "POST https://rekognition.{region}.amazonaws.com/",
      "input": {
        "Image": {
          "type": "object",
          "required": true
        },
        "MinConfidence": {
          "type": "float",
          "default": 50.0
        },
        "HumanLoopConfig": {
          "type": "object",
          "required": false
        }
      },
      "output": {
        "type": "moderation",
        "fields": [
          "ModerationLabels[0].Name",
          "ModerationLabels[0].Confidence",
          "ModerationLabels[0].ParentName"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "image_format": "Pass S3 URI or base64. S3 is faster and avoids base64 overhead for large images.",
    "region": "Use same region as your S3 bucket to avoid cross-region latency and data transfer costs.",
    "face_collection": "For face recognition at scale: create a collection, index faces, then use SearchFacesByImage.",
    "pricing": "First 5000 images/month free (12 months). Then $1-4/1000 images depending on feature."
  }
}