{
  "apia": "1.0",
  "service": {
    "id": "aws-rekognition",
    "name": "AWS Rekognition",
    "description_for_ai": "Amazon Rekognition — AWS AI service for image and video analysis. Detect objects, scenes, faces, text, celebrities, inappropriate content. Face recognition and comparison. 5000 free images/month for first 12 months. Used by NFL, Pinterest, Marinus Analytics.",
    "url": "https://aws.amazon.com/rekognition",
    "api_base": "https://rekognition.{region}.amazonaws.com",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.aws.amazon.com/rekognition/"
  },
  "auth": {
    "type": "aws_sig_v4",
    "anonymous_access": false,
    "how_to_get": "AWS account at https://aws.amazon.com",
    "cost": "Free: 5000 images/month (1 year). Then $1/1000 images"
  },
  "capabilities": [
    {
      "id": "detect_labels",
      "description_for_ai": "Detect objects, scenes, and concepts in images. Returns labels with confidence scores.",
      "intent": [
        "detect objects",
        "image labels",
        "what is in image",
        "image recognition",
        "object detection"
      ],
      "endpoint": "POST https://rekognition.{region}.amazonaws.com/",
      "input": {
        "Image": {
          "type": "object",
          "description": "{S3Object: {Bucket, Name}} or {Bytes: base64}",
          "required": true
        },
        "MaxLabels": {
          "type": "integer",
          "default": 10
        },
        "MinConfidence": {
          "type": "float",
          "default": 55.0
        }
      },
      "output": {
        "type": "labels",
        "fields": [
          "Labels[0].Name",
          "Labels[0].Confidence",
          "Labels[0].Instances[0].BoundingBox"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_text",
      "description_for_ai": "Extract text from images. Works well for signs, documents, license plates.",
      "intent": [
        "extract text",
        "OCR image",
        "read text",
        "sign text",
        "license plate"
      ],
      "endpoint": "POST https://rekognition.{region}.amazonaws.com/",
      "input": {
        "Image": {
          "type": "object",
          "required": true,
          "description": "Image URL or base64-encoded image data"
        }
      },
      "output": {
        "type": "text",
        "fields": [
          "TextDetections[0].DetectedText",
          "TextDetections[0].Confidence",
          "TextDetections[0].Type"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "compare_faces",
      "description_for_ai": "Compare two face images and determine if they are the same person. Use for face verification.",
      "intent": [
        "face match",
        "same person",
        "face comparison",
        "face verification",
        "identity check"
      ],
      "endpoint": "POST https://rekognition.{region}.amazonaws.com/",
      "input": {
        "SourceImage": {
          "type": "object",
          "required": true
        },
        "TargetImage": {
          "type": "object",
          "required": true
        },
        "SimilarityThreshold": {
          "type": "float",
          "default": 80.0
        }
      },
      "output": {
        "type": "face_match",
        "fields": [
          "FaceMatches[0].Similarity",
          "FaceMatches[0].Face.Confidence",
          "UnmatchedFaces"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "image_format": "Pass S3 URI or base64. S3 is faster and avoids base64 overhead for large images.",
    "region": "Use same region as your S3 bucket to avoid cross-region latency and data transfer costs.",
    "face_collection": "For face recognition at scale: create a collection, index faces, then use SearchFacesByImage.",
    "pricing": "First 5000 images/month free (12 months). Then $1-4/1000 images depending on feature."
  }
}