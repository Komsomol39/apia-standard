{
  "apia": "1.0",
  "service": {
    "id": "openai-whisper",
    "name": "OpenAI Whisper API",
    "description_for_ai": "OpenAI Whisper API — state-of-the-art speech recognition in 50+ languages. Near-human accuracy even with accents, background noise, and technical terms. Transcribe or translate audio files up to 25MB. $0.006/minute. Supports SRT/VTT subtitle output. Best STT accuracy available via API.",
    "url": "https://openai.com",
    "api_base": "https://api.openai.com/v1",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.openai.com/docs/guides/speech-to-text"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "OpenAI API key at https://platform.openai.com",
    "cost": "$0.006/minute audio"
  },
  "capabilities": [
    {
      "id": "transcribe",
      "description_for_ai": "Transcribe audio to text with Whisper. 99 languages, 97%+ accuracy. $0.006 per minute.",
      "intent": [
        "transcribe audio",
        "speech to text",
        "audio to text",
        "Whisper API",
        "транскрипция аудио Whisper"
      ],
      "endpoint": "POST https://api.openai.com/v1/audio/transcriptions",
      "input": {
        "file": {
          "type": "file",
          "description": "Audio file (mp3, mp4, mpeg, mpga, m4a, wav, webm). Max 25MB.",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "whisper-1"
        },
        "language": {
          "type": "string",
          "description": "ISO 639-1 code. Auto-detected if omitted.",
          "required": false
        },
        "prompt": {
          "type": "string",
          "description": "Hint for domain vocabulary e.g. 'This is a medical consultation about hypertension'",
          "required": false
        },
        "response_format": {
          "type": "string",
          "description": "json, text, srt, verbose_json, vtt",
          "default": "json"
        },
        "timestamp_granularities": {
          "type": "array",
          "description": "['word', 'segment'] — add timestamps to output",
          "required": false
        }
      },
      "output": {
        "type": "transcription",
        "fields": [
          "text",
          "segments[0].start",
          "segments[0].end",
          "words[0].word",
          "words[0].start"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "translate_to_english",
      "description_for_ai": "Transcribe and translate audio in any language to English in one step.",
      "intent": [
        "translate audio",
        "foreign audio to English",
        "audio translation",
        "перевод аудио на английский"
      ],
      "endpoint": "POST https://api.openai.com/v1/audio/translations",
      "input": {
        "file": {
          "type": "file",
          "description": "Audio in any language",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "whisper-1"
        },
        "prompt": {
          "type": "string",
          "required": false
        },
        "response_format": {
          "type": "string",
          "default": "json"
        }
      },
      "output": {
        "type": "translation",
        "fields": [
          "text (in English)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "transcribe_with_timestamps",
      "description_for_ai": "Get transcription with word-level or segment-level timestamps for subtitles, search, or alignment.",
      "intent": [
        "transcribe with timestamps",
        "word timestamps",
        "subtitle generation",
        "тайм-коды транскрипция"
      ],
      "endpoint": "POST https://api.openai.com/v1/audio/transcriptions",
      "input": {
        "file": {
          "type": "file",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "whisper-1"
        },
        "response_format": {
          "type": "string",
          "description": "verbose_json to get timestamps",
          "default": "verbose_json"
        },
        "timestamp_granularities": {
          "type": "array",
          "description": "['word'] for per-word, ['segment'] for per-sentence, or both",
          "default": [
            "segment"
          ]
        }
      },
      "output": {
        "type": "transcription",
        "fields": [
          "text",
          "segments[0].id",
          "segments[0].start",
          "segments[0].end",
          "segments[0].text",
          "words[0].word",
          "words[0].start",
          "words[0].end"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "export_srt",
      "description_for_ai": "Get transcription in SRT subtitle format, ready for video editing software.",
      "intent": [
        "SRT subtitles",
        "subtitle file",
        "generate subtitles",
        "файл субтитров SRT"
      ],
      "endpoint": "POST https://api.openai.com/v1/audio/transcriptions",
      "input": {
        "file": {
          "type": "file",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "whisper-1"
        },
        "response_format": {
          "type": "string",
          "description": "srt or vtt for subtitle formats",
          "required": true
        }
      },
      "output": {
        "type": "srt",
        "fields": [
          "SRT formatted text with timecodes"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "large_file_transcription",
      "description_for_ai": "Strategy for transcribing files >25MB: split into chunks, transcribe each with overlap for context.",
      "intent": [
        "large audio transcription",
        "long file transcription",
        "podcast transcription",
        "транскрипция длинного аудио"
      ],
      "endpoint": "POST https://api.openai.com/v1/audio/transcriptions",
      "input": {
        "file": {
          "type": "file",
          "description": "Split large files into <25MB chunks with ffmpeg: ffmpeg -i input.mp3 -segment_time 600 -f segment output%03d.mp3",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "whisper-1"
        },
        "prompt": {
          "type": "string",
          "description": "Last few words of previous chunk for continuity",
          "required": false
        }
      },
      "output": {
        "type": "transcription",
        "fields": [
          "text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}