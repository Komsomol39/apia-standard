{
  "apia": "1.0",
  "service": {
    "id": "openai-whisper",
    "name": "OpenAI Whisper API",
    "description_for_ai": "OpenAI Whisper API — state-of-the-art speech recognition in 50+ languages. Near-human accuracy even with accents, background noise, and technical terms. Transcribe or translate audio files up to 25MB. $0.006/minute. Supports SRT/VTT subtitle output. Best STT accuracy available via API.",
    "url": "https://openai.com",
    "api_base": "https://api.openai.com/v1",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.openai.com/docs/guides/speech-to-text"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "OpenAI API key at https://platform.openai.com",
    "cost": "$0.006/minute audio"
  },
  "capabilities": [
    {
      "id": "transcribe",
      "description_for_ai": "Transcribe audio to text using OpenAI Whisper. 97%+ accuracy across 100+ languages. $0.006/minute.",
      "intent": [
        "transcribe audio",
        "speech to text",
        "voice to text",
        "транскрибация аудио",
        "перевод голоса в текст"
      ],
      "endpoint": "POST https://api.openai.com/v1/audio/transcriptions",
      "input": {
        "file": {
          "type": "file",
          "description": "Audio file max 25MB. Formats: mp3, mp4, mpeg, mpga, m4a, wav, webm, ogg, flac",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "whisper-1"
        },
        "language": {
          "type": "string",
          "description": "ISO 639-1 code: en, ru, de, fr, zh, etc. Auto-detected if omitted. Providing it improves accuracy.",
          "required": false
        },
        "prompt": {
          "type": "string",
          "description": "Vocabulary hints for domain-specific terms. Spell out proper nouns, technical terms.",
          "required": false
        },
        "response_format": {
          "type": "string",
          "description": "json (text only), text, srt (subtitles), verbose_json (with timestamps), vtt",
          "default": "json"
        },
        "temperature": {
          "type": "float",
          "description": "0-1. Higher=more creative, may cause hallucination. Keep at 0 for best accuracy.",
          "default": 0
        }
      },
      "output": {
        "type": "transcription",
        "fields": [
          "text (json format)",
          "segments[0].start, segments[0].end, segments[0].text (verbose_json)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "translate",
      "description_for_ai": "Translate audio from any language to English text using Whisper. One step: audio → English.",
      "intent": [
        "translate audio",
        "audio translation",
        "speech translation",
        "перевод аудио на английский"
      ],
      "endpoint": "POST https://api.openai.com/v1/audio/translations",
      "input": {
        "file": {
          "type": "file",
          "description": "Audio file in any supported language, max 25MB",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "whisper-1"
        },
        "prompt": {
          "type": "string",
          "description": "Hint about content in English",
          "required": false
        },
        "response_format": {
          "type": "string",
          "description": "json, text, srt, verbose_json, vtt",
          "default": "json"
        },
        "temperature": {
          "type": "float",
          "default": 0
        }
      },
      "output": {
        "type": "translation",
        "fields": [
          "text (always in English)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "transcribe_long",
      "description_for_ai": "Split and transcribe audio files larger than 25MB by chunking them. Whisper limit is 25MB.",
      "intent": [
        "long audio transcription",
        "large file transcription",
        "transcribe long video",
        "транскрибация длинного аудио"
      ],
      "endpoint": "POST https://api.openai.com/v1/audio/transcriptions",
      "input": {
        "file": {
          "type": "file",
          "description": "Audio chunk under 25MB. Split large files at silence: ffmpeg -i input.mp3 -f segment -segment_time 600 -c copy chunk_%03d.mp3",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "whisper-1"
        },
        "response_format": {
          "type": "string",
          "default": "verbose_json"
        },
        "language": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "transcription",
        "fields": [
          "text",
          "segments[0].start",
          "segments[0].end"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "transcribe_realtime",
      "description_for_ai": "Real-time audio transcription using OpenAI Realtime API (WebSocket). Lower latency than file upload.",
      "intent": [
        "real-time transcription",
        "live transcription",
        "streaming speech to text",
        "транскрибация в реальном времени"
      ],
      "endpoint": "WSS wss://api.openai.com/v1/realtime",
      "input": {
        "model": {
          "type": "string",
          "default": "gpt-4o-realtime-preview"
        },
        "input_audio_transcription": {
          "type": "object",
          "description": "{model: whisper-1}",
          "required": true
        },
        "turn_detection": {
          "type": "object",
          "description": "{type: server_vad, threshold: 0.5, prefix_padding_ms: 300, silence_duration_ms: 500}",
          "required": false
        }
      },
      "output": {
        "type": "realtime_transcript",
        "fields": [
          "conversation.item.input_audio_transcription.completed event with transcript"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}