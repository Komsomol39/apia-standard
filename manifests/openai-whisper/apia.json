{
  "apia": "1.0",
  "service": {
    "id": "openai-whisper",
    "name": "OpenAI Whisper API",
    "description_for_ai": "OpenAI Whisper API — state-of-the-art speech recognition in 50+ languages. Near-human accuracy even with accents, background noise, and technical terms. Transcribe or translate audio files up to 25MB. $0.006/minute. Supports SRT/VTT subtitle output. Best STT accuracy available via API.",
    "url": "https://openai.com",
    "api_base": "https://api.openai.com/v1",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.openai.com/docs/guides/speech-to-text"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "OpenAI API key at https://platform.openai.com",
    "cost": "$0.006/minute audio"
  },
  "capabilities": [
    {
      "id": "transcribe",
      "description_for_ai": "Transcribe audio to text. Best-in-class accuracy for 100+ languages. $0.006/minute. Max 25MB.",
      "intent": [
        "transcribe audio",
        "speech to text",
        "audio to text",
        "whisper",
        "транскрибация whisper"
      ],
      "endpoint": "POST https://api.openai.com/v1/audio/transcriptions",
      "input": {
        "file": {
          "type": "file",
          "description": "Audio file (mp3, mp4, mpeg, mpga, m4a, wav, webm). Max 25MB.",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "whisper-1"
        },
        "language": {
          "type": "string",
          "description": "ISO 639-1 code. Providing language improves speed and accuracy.",
          "required": false
        },
        "prompt": {
          "type": "string",
          "description": "Guide transcription style or vocabulary. 'The following is a medical consultation.' or 'Names: John, Anthropic, GPT-4'",
          "required": false
        },
        "response_format": {
          "type": "string",
          "description": "json (default), text, srt (subtitles), vtt (subtitles), verbose_json (with timestamps)",
          "default": "json"
        },
        "temperature": {
          "type": "float",
          "description": "0 for deterministic. Increase if transcription seems stuck.",
          "default": 0
        },
        "timestamp_granularities": {
          "type": "array",
          "description": "['word', 'segment'] — requires verbose_json format",
          "required": false
        }
      },
      "output": {
        "type": "transcript",
        "fields": [
          "text",
          "words[0].word (verbose_json)",
          "words[0].start",
          "words[0].end",
          "segments[0].text"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "translate",
      "description_for_ai": "Transcribe AND translate audio to English in one call. Any language input → English output.",
      "intent": [
        "translate audio",
        "transcribe and translate",
        "audio translation",
        "перевод аудио whisper"
      ],
      "endpoint": "POST https://api.openai.com/v1/audio/translations",
      "input": {
        "file": {
          "type": "file",
          "description": "Audio file in any language",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "whisper-1"
        },
        "prompt": {
          "type": "string",
          "required": false
        },
        "response_format": {
          "type": "string",
          "default": "json"
        },
        "temperature": {
          "type": "float",
          "default": 0
        }
      },
      "output": {
        "type": "translation",
        "fields": [
          "text (English translation)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "transcribe_long",
      "description_for_ai": "Handle audio longer than 25MB by splitting into chunks. This is a pattern — split audio, transcribe each chunk, merge results.",
      "intent": [
        "long audio transcription",
        "transcribe podcast",
        "transcribe meeting recording",
        "длинная транскрибация"
      ],
      "endpoint": "POST https://api.openai.com/v1/audio/transcriptions",
      "input": {
        "file": {
          "type": "file",
          "description": "Split audio chunk under 25MB. Use ffmpeg: ffmpeg -i audio.mp3 -segment_time 300 -f segment chunk_%03d.mp3",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "whisper-1"
        },
        "language": {
          "type": "string",
          "required": false
        },
        "response_format": {
          "type": "string",
          "description": "verbose_json to get timestamps for accurate merging",
          "default": "verbose_json"
        }
      },
      "output": {
        "type": "transcript",
        "fields": [
          "text",
          "segments[0].start",
          "segments[0].end",
          "segments[0].text"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "transcribe_realtime",
      "description_for_ai": "Near-realtime transcription using GPT-4o audio preview model via chat completions API.",
      "intent": [
        "realtime whisper",
        "streaming transcription openai",
        "live audio openai",
        "реальное время транскрибация openai"
      ],
      "endpoint": "POST https://api.openai.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "gpt-4o-audio-preview"
        },
        "messages": {
          "type": "array",
          "description": "[{role: user, content: [{type: input_audio, input_audio: {data: BASE64_AUDIO, format: wav|mp3}}]}]",
          "required": true
        },
        "max_tokens": {
          "type": "integer",
          "default": 1024
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}