{
  "apia": "1.0",
  "service": {
    "id": "o3-mini",
    "name": "OpenAI o3-mini Reasoning API",
    "description_for_ai": "OpenAI reasoning model for complex problem solving. Thinks step-by-step before answering. Best for: math, science, coding, logic puzzles, multi-step analysis. Slower but more accurate than GPT-4o on hard problems.",
    "url": "https://openai.com",
    "api_base": "https://api.openai.com/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.openai.com/docs/models/o3-mini"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "OpenAI API key",
    "cost": "o3-mini: $1.10/$4.40 per 1M tokens. o3: $10/$40."
  },
  "capabilities": [
    {
      "id": "reasoning",
      "description_for_ai": "Use OpenAI o3-mini for advanced reasoning: math, coding, science, logic. Thinks before answering. Much stronger than GPT-4o on complex problems.",
      "intent": [
        "o3 mini",
        "reasoning AI",
        "math problem",
        "complex coding",
        "hard logic",
        "сложная задача o3"
      ],
      "endpoint": "POST https://api.openai.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "o3-mini"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "reasoning_effort": {
          "type": "string",
          "description": "low (fast), medium (balanced), high (best quality)",
          "default": "medium"
        },
        "max_completion_tokens": {
          "type": "integer",
          "description": "Max tokens including reasoning tokens. Recommended: 8000+",
          "required": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "usage.completion_tokens_details.reasoning_tokens",
          "usage.total_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "structured_output",
      "description_for_ai": "Get structured JSON output from o3-mini for data extraction, classification, or any schema-driven task.",
      "intent": [
        "structured output o3",
        "JSON extraction",
        "data extraction AI",
        "схема ответа o3"
      ],
      "endpoint": "POST https://api.openai.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "o3-mini"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "response_format": {
          "type": "object",
          "description": "{type: 'json_schema', json_schema: {name: 'schema_name', schema: {...JSON Schema...}, strict: true}}",
          "required": true
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content (JSON string matching schema)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "tool_use",
      "description_for_ai": "o3-mini with function/tool calling. Model decides which tools to use to answer complex multi-step questions.",
      "intent": [
        "o3 tools",
        "function calling o3",
        "agent o3",
        "инструменты o3"
      ],
      "endpoint": "POST https://api.openai.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "o3-mini"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "tools": {
          "type": "array",
          "description": "[{type: function, function: {name, description, parameters: {JSON Schema}}}]",
          "required": true
        },
        "tool_choice": {
          "type": "string",
          "description": "auto, required, none",
          "default": "auto"
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.tool_calls[0].function.name",
          "choices[0].message.tool_calls[0].function.arguments"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "batch",
      "description_for_ai": "Run o3-mini inference at 50% discount via batch API. Async, results within 24h. Ideal for bulk reasoning tasks.",
      "intent": [
        "batch o3",
        "bulk inference",
        "cheap o3",
        "пакетная обработка o3"
      ],
      "endpoint": "POST https://api.openai.com/v1/batches",
      "input": {
        "input_file_id": {
          "type": "string",
          "description": "Upload .jsonl file first via /v1/files. Each line: {custom_id, method: POST, url: /v1/chat/completions, body: {...}}",
          "required": true
        },
        "endpoint": {
          "type": "string",
          "default": "/v1/chat/completions"
        },
        "completion_window": {
          "type": "string",
          "default": "24h"
        }
      },
      "output": {
        "type": "batch",
        "fields": [
          "id",
          "status",
          "output_file_id",
          "request_counts.completed"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "vs_gpt4o": "Use o3-mini for: math proofs, complex algorithms, logic puzzles, hard coding. Use GPT-4o for: everyday tasks, writing, fast responses.",
    "reasoning_effort": "low=fast/cheap, medium=balanced, high=best quality/most expensive. Start with medium.",
    "streaming": "Reasoning models stream the final answer, not the thinking process."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}