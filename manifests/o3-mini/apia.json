{
  "apia": "1.0",
  "service": {
    "id": "o3-mini",
    "name": "OpenAI o3-mini Reasoning API",
    "description_for_ai": "OpenAI reasoning model for complex problem solving. Thinks step-by-step before answering. Best for: math, science, coding, logic puzzles, multi-step analysis. Slower but more accurate than GPT-4o on hard problems.",
    "url": "https://openai.com",
    "api_base": "https://api.openai.com/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.openai.com/docs/models/o3-mini"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "OpenAI API key",
    "cost": "o3-mini: $1.10/$4.40 per 1M tokens. o3: $10/$40."
  },
  "capabilities": [
    {
      "id": "reason",
      "description_for_ai": "Use OpenAI o3-mini for deep chain-of-thought reasoning. Best for math, science, and complex problems.",
      "intent": [
        "o3-mini reasoning",
        "advanced reasoning AI",
        "math problem AI",
        "рассуждение o3-mini"
      ],
      "endpoint": "POST https://api.openai.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "o3-mini"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "reasoning_effort": {
          "type": "string",
          "description": "low (fast/cheap), medium (balanced), high (best quality)",
          "default": "medium"
        },
        "max_completion_tokens": {
          "type": "integer",
          "description": "Controls maximum output including reasoning tokens",
          "required": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "usage.prompt_tokens",
          "usage.completion_tokens",
          "usage.completion_tokens_details.reasoning_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "solve_math",
      "description_for_ai": "Use o3-mini to solve complex math problems with step-by-step reasoning.",
      "intent": [
        "math solver AI",
        "solve equation",
        "calculus AI",
        "решение задач o3-mini"
      ],
      "endpoint": "POST https://api.openai.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "o3-mini"
        },
        "messages": {
          "type": "array",
          "description": "[{role: 'user', content: 'Solve: integrate x^2 sin(x) dx'}]",
          "required": true
        },
        "reasoning_effort": {
          "type": "string",
          "default": "high"
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "code_generation",
      "description_for_ai": "Generate complex algorithms and code with o3-mini's advanced reasoning.",
      "intent": [
        "code AI o3-mini",
        "algorithm generation",
        "complex code",
        "код o3-mini"
      ],
      "endpoint": "POST https://api.openai.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "o3-mini"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "reasoning_effort": {
          "type": "string",
          "default": "medium"
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "analyze_science",
      "description_for_ai": "Analyze scientific problems, research papers, or complex technical questions.",
      "intent": [
        "science analysis AI",
        "research analysis",
        "technical reasoning",
        "анализ научных задач o3-mini"
      ],
      "endpoint": "POST https://api.openai.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "o3-mini"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "reasoning_effort": {
          "type": "string",
          "description": "Use high for complex scientific questions",
          "default": "high"
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "structured_reasoning",
      "description_for_ai": "Get structured JSON output from o3-mini's reasoning.",
      "intent": [
        "structured output o3-mini",
        "JSON reasoning AI",
        "structured analysis",
        "структурированный вывод o3-mini"
      ],
      "endpoint": "POST https://api.openai.com/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "o3-mini"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "response_format": {
          "type": "object",
          "description": "{type: 'json_schema', json_schema: {name: 'result', strict: true, schema: {type: 'object', properties: {...}}}}",
          "required": false
        }
      },
      "output": {
        "type": "json",
        "fields": [
          "choices[0].message.content (valid JSON)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "vs_gpt4o": "Use o3-mini for: math proofs, complex algorithms, logic puzzles, hard coding. Use GPT-4o for: everyday tasks, writing, fast responses.",
    "reasoning_effort": "low=fast/cheap, medium=balanced, high=best quality/most expensive. Start with medium.",
    "streaming": "Reasoning models stream the final answer, not the thinking process."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}