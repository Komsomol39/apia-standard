{
  "apia": "1.0",
  "service": {
    "id": "idealista",
    "name": "Idealista API (Spain/Italy/Portugal)",
    "description_for_ai": "Idealista — крупнейший портал недвижимости в Испании, Италии и Португалии. 2M+ объявлений: аренда, покупка, коммерческая недвижимость. Официальный API для профессионалов рынка. Used by real estate agents and property portals across Southern Europe.",
    "url": "https://idealista.com",
    "api_base": "https://api.idealista.com/3.5",
    "category": "real_estate",
    "geo": [
      "ES",
      "IT",
      "PT"
    ],
    "language": "en",
    "docs": "https://developers.idealista.com/"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Apply at https://developers.idealista.com",
    "cost": "Professional license required"
  },
  "capabilities": [
    {
      "id": "search",
      "description_for_ai": "Leading property portal in Spain, Italy and Portugal. Buy and rent listings. Official API for real estate professionals. Use for property search in Southern Europe. Search properties in Spain, Italy or Portugal for sale or rent.",
      "intent": [
        "property Spain",
        "apartment Madrid",
        "buy house Italy",
        "rent Portugal",
        "pisos en venta",
        "alquiler"
      ],
      "endpoint": "POST https://api.idealista.com/3.5/{country}/search",
      "input": {
        "country": {
          "type": "string",
          "description": "ISO 3166-1 alpha-2 country code: US, RU, DE, GB, FR",
          "required": true
        },
        "operation": {
          "type": "string",
          "description": "sale or rent",
          "required": true
        },
        "propertyType": {
          "type": "string",
          "description": "homes, offices, premises, garages, bedrooms",
          "required": true
        },
        "center": {
          "type": "string",
          "description": "lat,lng",
          "required": false
        },
        "distance": {
          "type": "integer",
          "description": "meters",
          "required": false
        },
        "maxItems": {
          "type": "integer",
          "default": 40
        }
      },
      "output": {
        "type": "list<property>",
        "fields": [
          "propertyCode",
          "price",
          "rooms",
          "size",
          "floor",
          "address",
          "thumbnail",
          "description"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_property",
      "description_for_ai": "Get full property details by Idealista property code: photos, floor plan, description, price history, energy certificate, and contact info.",
      "intent": [
        "property details Spain",
        "apartment info",
        "house details Italy",
        "property info Portugal",
        "listing details"
      ],
      "endpoint": "GET https://api.idealista.com/3.5/{country}/detail",
      "input": {
        "country": {
          "type": "string",
          "description": "Country code: es, it, pt",
          "required": true
        },
        "propertyCode": {
          "type": "string",
          "description": "Property code from search results",
          "required": true
        }
      },
      "output": {
        "type": "property",
        "fields": [
          "price",
          "size",
          "rooms",
          "floor",
          "description",
          "photos",
          "address",
          "energyCertification",
          "contactInfo"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_properties",
      "description_for_ai": "Search real estate listings on Idealista (Spain, Italy, Portugal).",
      "intent": [
        "idealista search",
        "property Spain",
        "buy apartment Spain",
        "недвижимость испания"
      ],
      "endpoint": "GET https://api.idealista.com/3.5/es/search",
      "input": {
        "operation": {
          "type": "string",
          "description": "sale or rent",
          "required": true
        },
        "propertyType": {
          "type": "string",
          "description": "homes, offices, premises, garages, bedrooms, newDevelopments",
          "required": true
        },
        "center": {
          "type": "string",
          "description": "lat,lon e.g. 40.4167,-3.7037",
          "required": true
        },
        "distance": {
          "type": "integer",
          "description": "Radius in meters",
          "default": 1000
        },
        "maxPrice": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "list<property>",
        "fields": [
          "elementList[0].propertyCode",
          "elementList[0].price",
          "elementList[0].rooms",
          "elementList[0].size",
          "elementList[0].address",
          "elementList[0].thumbnail"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_property",
      "description_for_ai": "Get full details of a property listing on Idealista.",
      "intent": [
        "property details idealista",
        "listing info Spain",
        "real estate details"
      ],
      "endpoint": "GET https://api.idealista.com/3.5/es/detail/{propertyCode}",
      "input": {
        "propertyCode": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "property",
        "fields": [
          "propertyCode",
          "price",
          "rooms",
          "bathrooms",
          "size",
          "floor",
          "description",
          "images",
          "address"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_agencies",
      "description_for_ai": "Find real estate agencies on Idealista.",
      "intent": [
        "real estate agency Spain",
        "idealista agencies",
        "найти агентство недвижимости"
      ],
      "endpoint": "GET https://api.idealista.com/3.5/es/search",
      "input": {
        "propertyType": {
          "type": "string",
          "default": "agencies"
        },
        "center": {
          "type": "string",
          "required": true
        },
        "distance": {
          "type": "integer",
          "default": 5000
        }
      },
      "output": {
        "type": "list<agency>",
        "fields": [
          "agencyList[0].name",
          "agencyList[0].phone",
          "agencyList[0].address"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}