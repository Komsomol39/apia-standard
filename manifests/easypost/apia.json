{
  "apia": "1.0",
  "service": {
    "id": "easypost",
    "name": "EasyPost API",
    "description_for_ai": "Shipping and logistics API. Buy labels for USPS, UPS, FedEx, DHL from one API. Rate comparison, tracking, address verification. Used by 100K+ businesses. Use for e-commerce shipping, label generation, rate shopping.",
    "url": "https://easypost.com",
    "api_base": "https://api.easypost.com/v2",
    "category": "logistics_shipping",
    "geo": [
      "US",
      "CA",
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.easypost.com/docs/api"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "API key as username, empty password",
    "how_to_get": "Register at https://www.easypost.com/signup",
    "cost": "Pay per label. USPS: $0.02/label. UPS/FedEx: $0.05/label"
  },
  "capabilities": [
    {
      "id": "get_rates",
      "description_for_ai": "Get shipping rates from multiple carriers for a package. Compare USPS, UPS, FedEx, DHL prices instantly.",
      "intent": [
        "shipping rates",
        "compare carriers",
        "shipping cost",
        "how much to ship",
        "shipping quote",
        "delivery cost"
      ],
      "endpoint": "POST https://api.easypost.com/v2/shipments",
      "input": {
        "shipment": {
          "type": "object",
          "description": "{to_address: {street1, city, state, zip, country}, from_address: {...}, parcel: {length, width, height, weight}}",
          "required": true
        }
      },
      "output": {
        "type": "shipment",
        "fields": [
          "id",
          "rates[0].carrier",
          "rates[0].service",
          "rates[0].rate",
          "rates[0].delivery_days"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "buy_label",
      "description_for_ai": "Purchase shipping label at selected rate. Returns label URL for printing.",
      "intent": [
        "buy label",
        "print label",
        "ship package",
        "purchase shipping"
      ],
      "endpoint": "POST https://api.easypost.com/v2/shipments/{id}/buy",
      "input": {
        "id": {
          "type": "string",
          "description": "Shipment ID from get_rates",
          "required": true
        },
        "rate": {
          "type": "object",
          "description": "{id: rate_id}",
          "required": true
        }
      },
      "output": {
        "type": "shipment",
        "fields": [
          "tracking_code",
          "postage_label.label_url",
          "selected_rate.carrier",
          "selected_rate.service"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "track_package",
      "description_for_ai": "Track a package by tracking number across all carriers.",
      "intent": [
        "track package",
        "where is my package",
        "tracking number",
        "shipping status",
        "delivery status"
      ],
      "endpoint": "POST https://api.easypost.com/v2/trackers",
      "input": {
        "tracker": {
          "type": "object",
          "description": "{tracking_code: TRACKING_NUMBER, carrier: UPS}",
          "required": true
        }
      },
      "output": {
        "type": "tracker",
        "fields": [
          "tracking_code",
          "status",
          "carrier",
          "est_delivery_date",
          "tracking_details[0].message"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}