{
  "apia": "1.0",
  "service": {
    "id": "spoonacular",
    "name": "Spoonacular API",
    "description_for_ai": "Food and recipe API. 5000+ recipes, nutrition analysis, meal planning, grocery lists, ingredient substitutions, wine pairing. Search by diet (vegan, keto, gluten-free), ingredients, cuisine. 150 req/day free.",
    "url": "https://spoonacular.com",
    "api_base": "https://api.spoonacular.com",
    "category": "food",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://spoonacular.com/food-api/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "apiKey",
    "param_location": "query",
    "how_to_get": "Register at https://spoonacular.com/food-api/console",
    "cost": "Free: 150 points/day. Basic: $29/month"
  },
  "capabilities": [
    {
      "id": "search_recipes",
      "description_for_ai": "Search recipes by ingredients, diet, cuisine, and nutrients.",
      "intent": [
        "search recipes",
        "food API",
        "recipe search Spoonacular",
        "поиск рецептов"
      ],
      "endpoint": "GET https://api.spoonacular.com/recipes/complexSearch",
      "input": {
        "query": {
          "type": "string",
          "required": false
        },
        "includeIngredients": {
          "type": "string",
          "description": "Comma-separated: tomato,cheese",
          "required": false
        },
        "excludeIngredients": {
          "type": "string",
          "required": false
        },
        "diet": {
          "type": "string",
          "description": "vegetarian, vegan, gluten free, ketogenic, paleo",
          "required": false
        },
        "cuisine": {
          "type": "string",
          "description": "italian, mexican, asian, american, french",
          "required": false
        },
        "maxCalories": {
          "type": "integer",
          "required": false
        },
        "number": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<recipe>",
        "fields": [
          "results[0].id",
          "results[0].title",
          "results[0].image",
          "results[0].readyInMinutes",
          "results[0].servings"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_recipe_info",
      "description_for_ai": "Get full recipe details: ingredients, instructions, nutrition.",
      "intent": [
        "recipe details",
        "cooking instructions",
        "recipe info Spoonacular",
        "рецепт подробно"
      ],
      "endpoint": "GET https://api.spoonacular.com/recipes/{id}/information",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        },
        "includeNutrition": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "recipe",
        "fields": [
          "title",
          "readyInMinutes",
          "servings",
          "extendedIngredients[0].original",
          "instructions",
          "nutrition.nutrients[0].name",
          "nutrition.nutrients[0].amount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "analyze_nutrients",
      "description_for_ai": "Get nutritional information for a recipe or food item.",
      "intent": [
        "nutrition facts",
        "calories food",
        "macros recipe",
        "пищевая ценность"
      ],
      "endpoint": "GET https://api.spoonacular.com/recipes/{id}/nutritionWidget.json",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "nutrition",
        "fields": [
          "calories",
          "carbs",
          "fat",
          "protein",
          "nutrients[0].name",
          "nutrients[0].amount",
          "nutrients[0].unit"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "find_by_ingredients",
      "description_for_ai": "Find recipes you can make with ingredients you already have.",
      "intent": [
        "recipes by ingredients",
        "what to cook",
        "use ingredients",
        "рецепты из ингредиентов"
      ],
      "endpoint": "GET https://api.spoonacular.com/recipes/findByIngredients",
      "input": {
        "ingredients": {
          "type": "string",
          "description": "Comma-separated list: apples,flour,sugar",
          "required": true
        },
        "number": {
          "type": "integer",
          "default": 5
        },
        "ranking": {
          "type": "integer",
          "description": "1=maximize used ingredients, 2=minimize missing",
          "default": 1
        }
      },
      "output": {
        "type": "list<recipe>",
        "fields": [
          "[0].id",
          "[0].title",
          "[0].usedIngredientCount",
          "[0].missedIngredientCount",
          "[0].image"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_meal_plan",
      "description_for_ai": "Generate a daily or weekly meal plan based on diet and calorie goals.",
      "intent": [
        "meal plan",
        "diet plan",
        "weekly menu",
        "план питания"
      ],
      "endpoint": "GET https://api.spoonacular.com/mealplanner/generate",
      "input": {
        "timeFrame": {
          "type": "string",
          "description": "day or week",
          "default": "day"
        },
        "targetCalories": {
          "type": "integer",
          "description": "Daily calorie target",
          "required": false
        },
        "diet": {
          "type": "string",
          "required": false
        },
        "exclude": {
          "type": "string",
          "description": "Comma-separated ingredients to exclude",
          "required": false
        }
      },
      "output": {
        "type": "meal_plan",
        "fields": [
          "meals[0].id",
          "meals[0].title",
          "meals[0].readyInMinutes",
          "nutrients.calories",
          "nutrients.protein"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}