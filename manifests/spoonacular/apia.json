{
  "apia": "1.0",
  "service": {
    "id": "spoonacular",
    "name": "Spoonacular API",
    "description_for_ai": "Food and recipe API. 5000+ recipes, nutrition analysis, meal planning, grocery lists, ingredient substitutions, wine pairing. Search by diet (vegan, keto, gluten-free), ingredients, cuisine. 150 req/day free.",
    "url": "https://spoonacular.com",
    "api_base": "https://api.spoonacular.com",
    "category": "food",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://spoonacular.com/food-api/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "apiKey",
    "param_location": "query",
    "how_to_get": "Register at https://spoonacular.com/food-api/console",
    "cost": "Free: 150 points/day. Basic: $29/month"
  },
  "capabilities": [
    {
      "id": "search_recipes",
      "description_for_ai": "Search recipes by query, diet, cuisine, ingredients. Returns recipes with nutrition info.",
      "intent": [
        "find recipe",
        "diet recipe",
        "vegan recipe",
        "keto meal",
        "recipe search",
        "gluten free",
        "low calorie"
      ],
      "endpoint": "GET https://api.spoonacular.com/recipes/complexSearch",
      "input": {
        "query": {
          "type": "string",
          "required": false,
          "description": "Search query string"
        },
        "diet": {
          "type": "string",
          "description": "vegetarian, vegan, gluten free, ketogenic, paleo, primal",
          "required": false
        },
        "cuisine": {
          "type": "string",
          "description": "italian, mexican, chinese, indian, japanese, french",
          "required": false
        },
        "maxCalories": {
          "type": "integer",
          "required": false
        },
        "minProtein": {
          "type": "integer",
          "required": false
        },
        "intolerances": {
          "type": "string",
          "description": "dairy, egg, gluten, peanut, seafood, sesame",
          "required": false
        },
        "number": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<recipe>",
        "fields": [
          "id",
          "title",
          "image",
          "calories",
          "protein",
          "fat",
          "carbs"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "analyze_nutrition",
      "description_for_ai": "Get nutrition info for any food or recipe text. Returns calories, macros, vitamins.",
      "intent": [
        "nutrition facts",
        "calories in food",
        "macro breakdown",
        "analyze nutrition",
        "food nutrition"
      ],
      "endpoint": "POST https://api.spoonacular.com/recipes/analyze",
      "input": {
        "title": {
          "type": "string",
          "required": true,
          "description": "Title or name string"
        },
        "ingr": {
          "type": "array",
          "description": "List of ingredients",
          "required": true
        }
      },
      "output": {
        "type": "nutrition",
        "fields": [
          "calories",
          "fat",
          "protein",
          "carbs",
          "fiber",
          "vitamins"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "search_recipes",
      "description_for_ai": "Search recipes by ingredients, diet, cuisine, and nutrients.",
      "intent": [
        "search recipes spoonacular",
        "find recipe",
        "meal search",
        "поиск рецептов spoonacular"
      ],
      "endpoint": "GET https://api.spoonacular.com/recipes/complexSearch",
      "input": {
        "query": {
          "type": "string",
          "required": false
        },
        "diet": {
          "type": "string",
          "description": "vegetarian, vegan, gluten free, ketogenic, paleo",
          "required": false
        },
        "cuisine": {
          "type": "string",
          "description": "italian, mexican, asian, french, american",
          "required": false
        },
        "maxCalories": {
          "type": "integer",
          "required": false
        },
        "includeIngredients": {
          "type": "string",
          "description": "Comma-separated ingredients",
          "required": false
        },
        "number": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<recipe>",
        "fields": [
          "results[0].id",
          "results[0].title",
          "results[0].image",
          "results[0].readyInMinutes",
          "results[0].servings"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_recipe",
      "description_for_ai": "Get full recipe details: ingredients, instructions, nutrition.",
      "intent": [
        "recipe details spoonacular",
        "recipe ingredients",
        "cooking instructions",
        "рецепт spoonacular"
      ],
      "endpoint": "GET https://api.spoonacular.com/recipes/{id}/information",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        },
        "includeNutrition": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "recipe",
        "fields": [
          "id",
          "title",
          "readyInMinutes",
          "servings",
          "extendedIngredients[0].original",
          "analyzedInstructions[0].steps[0].step",
          "nutrition.nutrients[0].name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "analyze_nutrition",
      "description_for_ai": "Analyze nutrition content from a recipe URL or text.",
      "intent": [
        "nutrition analysis",
        "recipe nutrition",
        "calories recipe",
        "анализ питания spoonacular"
      ],
      "endpoint": "POST https://api.spoonacular.com/recipes/analyze",
      "input": {
        "title": {
          "type": "string",
          "required": true
        },
        "servings": {
          "type": "integer",
          "required": true
        },
        "ingredientList": {
          "type": "string",
          "description": "One ingredient per line",
          "required": true
        }
      },
      "output": {
        "type": "nutrition",
        "fields": [
          "calories",
          "carbs",
          "fat",
          "protein",
          "nutrients[0].name",
          "nutrients[0].amount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_recipes",
      "description_for_ai": "Search recipes with spoonacular by keyword, diet, cuisine, and ingredients.",
      "intent": [
        "recipe search spoonacular",
        "find recipe",
        "dinner ideas",
        "поиск рецептов spoonacular"
      ],
      "endpoint": "GET https://api.spoonacular.com/recipes/complexSearch",
      "input": {
        "query": {
          "type": "string",
          "required": false
        },
        "diet": {
          "type": "string",
          "description": "vegetarian, vegan, gluten free, ketogenic, paleo",
          "required": false
        },
        "cuisine": {
          "type": "string",
          "description": "italian, mexican, asian, american, french",
          "required": false
        },
        "includeIngredients": {
          "type": "string",
          "description": "Comma-separated ingredients to include",
          "required": false
        },
        "maxCalories": {
          "type": "integer",
          "required": false
        },
        "number": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<recipe>",
        "fields": [
          "results[0].id",
          "results[0].title",
          "results[0].image",
          "results[0].calories"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_recipe",
      "description_for_ai": "Get full recipe details: ingredients, instructions, nutrition.",
      "intent": [
        "recipe details spoonacular",
        "cooking instructions",
        "recipe info",
        "рецепт spoonacular"
      ],
      "endpoint": "GET https://api.spoonacular.com/recipes/{id}/information",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        },
        "includeNutrition": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "recipe",
        "fields": [
          "id",
          "title",
          "instructions",
          "extendedIngredients[0].original",
          "nutrition.nutrients[0].amount",
          "readyInMinutes",
          "servings"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "analyze_ingredients",
      "description_for_ai": "Analyze a list of ingredients for nutritional info.",
      "intent": [
        "ingredient nutrition",
        "calories ingredients",
        "nutrition analysis spoonacular",
        "питательность ингредиентов"
      ],
      "endpoint": "POST https://api.spoonacular.com/recipes/parseIngredients",
      "input": {
        "ingredientList": {
          "type": "string",
          "description": "Newline-separated: '1 cup rice\\n2 eggs\\n100g chicken'",
          "required": true
        },
        "servings": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<ingredient>",
        "fields": [
          "[0].name",
          "[0].amount",
          "[0].unit",
          "[0].nutrition.nutrients[0].name",
          "[0].nutrition.nutrients[0].amount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}