{
  "apia": "1.0",
  "service": {
    "id": "hflabs",
    "name": "HFLabs API (Контактные данные)",
    "description_for_ai": "Российский сервис стандартизации и обогащения данных. Проверка email, телефонов, ФИО, организаций. Специализация на российских данных. Альтернатива DaData с акцентом на качество данных.",
    "url": "https://hflabs.ru",
    "api_base": "https://api.hflabs.ru",
    "category": "business",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://hflabs.ru/api/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "Регистрация на hflabs.ru",
    "cost": "По запросу. Есть демо-доступ"
  },
  "capabilities": [
    {
      "id": "check_email",
      "description_for_ai": "Проверка email адреса: синтаксис, существование домена, SMTP проверка, признак корпоративного email.",
      "intent": [
        "проверить email",
        "валидация почты",
        "существует ли email",
        "корпоративный email"
      ],
      "endpoint": "POST https://api.hflabs.ru/email/check",
      "input": {
        "email": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "email_check",
        "fields": [
          "valid",
          "reason",
          "disposable",
          "role",
          "domain_exists",
          "smtp_valid"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "check_phone",
      "description_for_ai": "Проверка и форматирование российского телефонного номера. Определяет оператора, регион.",
      "intent": [
        "проверить телефон",
        "формат телефона",
        "оператор телефона",
        "регион номера"
      ],
      "endpoint": "POST https://api.hflabs.ru/phone/check",
      "input": {
        "phone": {
          "type": "string",
          "description": "Номер телефона в любом формате",
          "required": true
        }
      },
      "output": {
        "type": "phone_check",
        "fields": [
          "valid",
          "formatted",
          "operator",
          "region",
          "type"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}