{
  "apia": "1.0",
  "service": {
    "id": "booking-com",
    "name": "Booking.com Demand API",
    "description_for_ai": "Booking.com Demand API — access 28M+ accommodation listings worldwide. Hotels, apartments, hostels, villas with real-time prices and availability. 43+ languages, 150K+ destinations. Requires Booking.com partner agreement. Used by travel agencies and OTA platforms.",
    "url": "https://booking.com",
    "api_base": "https://demandapi.booking.com/3.1",
    "category": "transport",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.booking.com/demand/overview.html"
  },
  "auth": {
    "type": "oauth2_client_credentials",
    "anonymous_access": false,
    "how_to_get": "Apply at https://developers.booking.com — requires Booking.com partner account",
    "cost": "Revenue share model"
  },
  "capabilities": [
    {
      "id": "search_hotels",
      "description_for_ai": "Search hotels on Booking.com by destination, dates, and guests.",
      "intent": [
        "search hotels Booking",
        "Booking.com search",
        "find hotel",
        "поиск отелей Booking.com"
      ],
      "endpoint": "GET https://booking-com.p.rapidapi.com/v2/hotels/search",
      "input": {
        "dest_id": {
          "type": "string",
          "description": "Destination ID (get from search_destinations)",
          "required": true
        },
        "search_type": {
          "type": "string",
          "description": "city, landmark, district, airport",
          "required": true
        },
        "checkin_date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "checkout_date": {
          "type": "string",
          "required": true
        },
        "adults_number": {
          "type": "integer",
          "default": 1
        },
        "room_number": {
          "type": "integer",
          "default": 1
        },
        "filter_by_currency": {
          "type": "string",
          "default": "USD"
        }
      },
      "output": {
        "type": "list<hotel>",
        "fields": [
          "result[0].hotel_id",
          "result[0].hotel_name",
          "result[0].price_breakdown.all_inclusive_price",
          "result[0].review_score",
          "result[0].class (stars)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_hotel_details",
      "description_for_ai": "Get detailed information about a specific hotel on Booking.com.",
      "intent": [
        "hotel details Booking",
        "hotel info",
        "accommodation details",
        "детали отеля Booking.com"
      ],
      "endpoint": "GET https://booking-com.p.rapidapi.com/v1/hotels/data",
      "input": {
        "hotel_id": {
          "type": "integer",
          "required": true
        },
        "locale": {
          "type": "string",
          "default": "en-us"
        }
      },
      "output": {
        "type": "hotel",
        "fields": [
          "hotel_id",
          "hotel_name",
          "address",
          "city",
          "country_trans",
          "latitude",
          "longitude",
          "stars",
          "review_nr",
          "review_score"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_hotel_reviews",
      "description_for_ai": "Get guest reviews for a hotel on Booking.com.",
      "intent": [
        "hotel reviews Booking",
        "guest reviews",
        "ratings hotel",
        "отзывы Booking.com"
      ],
      "endpoint": "GET https://booking-com.p.rapidapi.com/v1/hotels/reviews",
      "input": {
        "hotel_id": {
          "type": "integer",
          "required": true
        },
        "page_number": {
          "type": "integer",
          "default": 0
        },
        "rows": {
          "type": "integer",
          "default": 25
        },
        "sort_type": {
          "type": "string",
          "description": "SORT_MOST_RELEVANT, SORT_RECENT, SORT_HIGHEST_SCORE, SORT_LOWEST_SCORE",
          "default": "SORT_MOST_RELEVANT"
        }
      },
      "output": {
        "type": "list<review>",
        "fields": [
          "result[0].author.name",
          "result[0].average_score",
          "result[0].pros",
          "result[0].cons",
          "result[0].date"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_destinations",
      "description_for_ai": "Search for destination IDs for hotels search on Booking.com.",
      "intent": [
        "Booking destination search",
        "city ID Booking",
        "destination lookup",
        "поиск направления Booking.com"
      ],
      "endpoint": "GET https://booking-com.p.rapidapi.com/v1/hotels/locations",
      "input": {
        "name": {
          "type": "string",
          "description": "City or destination name",
          "required": true
        },
        "locale": {
          "type": "string",
          "default": "en-us"
        }
      },
      "output": {
        "type": "list<destination>",
        "fields": [
          "[0].dest_id",
          "name",
          "[0].dest_type",
          "[0].country"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_hotel_photos",
      "description_for_ai": "Get photos for a Booking.com hotel.",
      "intent": [
        "hotel photos Booking",
        "accommodation images",
        "hotel pictures",
        "фото отеля Booking.com"
      ],
      "endpoint": "GET https://booking-com.p.rapidapi.com/v1/hotels/photos",
      "input": {
        "hotel_id": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "list<photo>",
        "fields": [
          "[0].url_1440",
          "[0].url_max",
          "[0].photo_id",
          "[0].tag_name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}