{
  "apia": "1.0",
  "service": {
    "id": "booking-com",
    "name": "Booking.com Demand API",
    "description_for_ai": "Hotel and accommodation search. 28M+ listings worldwide. Prices, availability, reviews, photos. Partner API requires approval. Use for travel apps, hotel booking, accommodation search.",
    "url": "https://booking.com",
    "api_base": "https://demandapi.booking.com/3.1",
    "category": "travel_hotels",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.booking.com/demand/overview.html"
  },
  "auth": {
    "type": "oauth2_client_credentials",
    "anonymous_access": false,
    "how_to_get": "Apply at https://developers.booking.com — requires Booking.com partner account",
    "cost": "Revenue share model"
  },
  "capabilities": [
    {
      "id": "search_hotels",
      "description_for_ai": "Hotel and accommodation search. 28M+ listings worldwide. Prices, availability, reviews, photos. Partner API requires approval. Use for travel apps, hotel booking, accommodation search. Search hotels by location and dates. Returns availability, prices, ratings, facilities.",
      "intent": [
        "find hotel",
        "book accommodation",
        "hotel search",
        "where to stay",
        "hotel prices",
        "hotel near me",
        "забронировать отель"
      ],
      "endpoint": "POST https://demandapi.booking.com/3.1/accommodations/search",
      "input": {
        "checkin": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "checkout": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "guests": {
          "type": "object",
          "description": "{number_of_adults: 2, number_of_rooms: 1}",
          "required": true,
          "note": "See description for full object structure"
        },
        "city_id": {
          "type": "integer",
          "description": "Booking.com city ID",
          "required": false
        },
        "latitude": {
          "type": "number",
          "required": false
        },
        "longitude": {
          "type": "number",
          "required": false
        },
        "radius": {
          "type": "integer",
          "description": "Search radius in km",
          "default": 10
        }
      },
      "output": {
        "type": "list<hotel>",
        "fields": [
          "accommodation_id",
          "name",
          "review_score",
          "review_score_word",
          "min_total_price",
          "currency_code",
          "url",
          "checkin",
          "checkout"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}