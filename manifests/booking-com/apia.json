{
  "apia": "1.0",
  "service": {
    "id": "booking-com",
    "name": "Booking.com Demand API",
    "description_for_ai": "Booking.com Demand API — access 28M+ accommodation listings worldwide. Hotels, apartments, hostels, villas with real-time prices and availability. 43+ languages, 150K+ destinations. Requires Booking.com partner agreement. Used by travel agencies and OTA platforms.",
    "url": "https://booking.com",
    "api_base": "https://demandapi.booking.com/3.1",
    "category": "transport",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.booking.com/demand/overview.html"
  },
  "auth": {
    "type": "oauth2_client_credentials",
    "anonymous_access": false,
    "how_to_get": "Apply at https://developers.booking.com — requires Booking.com partner account",
    "cost": "Revenue share model"
  },
  "capabilities": [
    {
      "id": "search_hotels",
      "description_for_ai": "Search hotels on Booking.com by destination and dates.",
      "intent": [
        "booking.com hotels",
        "hotel search booking",
        "find accommodation",
        "отели booking.com"
      ],
      "endpoint": "GET https://booking-com.p.rapidapi.com/v1/hotels/search",
      "input": {
        "dest_id": {
          "type": "string",
          "description": "Destination ID (get from search_location)",
          "required": true
        },
        "search_type": {
          "type": "string",
          "default": "CITY"
        },
        "checkin_date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "checkout_date": {
          "type": "string",
          "required": true
        },
        "adults_number": {
          "type": "integer",
          "default": 2
        },
        "order_by": {
          "type": "string",
          "description": "popularity, class_ascending, class_descending, price, review_score",
          "default": "popularity"
        },
        "room_number": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<hotel>",
        "fields": [
          "result[0].hotel_id",
          "result[0].hotel_name",
          "result[0].price_breakdown.gross_price",
          "result[0].review_score",
          "result[0].class (stars)",
          "result[0].city"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_hotel_details",
      "description_for_ai": "Get full Booking.com hotel details: amenities, photos, policies.",
      "intent": [
        "hotel details booking",
        "property info booking.com",
        "hotel amenities",
        "детали отеля booking.com"
      ],
      "endpoint": "GET https://booking-com.p.rapidapi.com/v1/hotels/data",
      "input": {
        "hotel_id": {
          "type": "integer",
          "required": true
        },
        "locale": {
          "type": "string",
          "default": "en-gb"
        }
      },
      "output": {
        "type": "hotel",
        "fields": [
          "hotel_name",
          "address",
          "hotel_include_breakfast",
          "checkin.from",
          "checkout.until",
          "facilities[0].name",
          "description.description"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_hotel_reviews",
      "description_for_ai": "Get guest reviews for a Booking.com hotel.",
      "intent": [
        "hotel reviews booking",
        "guest feedback",
        "ratings booking.com",
        "отзывы booking.com"
      ],
      "endpoint": "GET https://booking-com.p.rapidapi.com/v1/hotels/reviews",
      "input": {
        "hotel_id": {
          "type": "integer",
          "required": true
        },
        "locale": {
          "type": "string",
          "default": "en-gb"
        },
        "sort_type": {
          "type": "string",
          "description": "SORT_MOST_RELEVANT, SORT_RECENT",
          "default": "SORT_MOST_RELEVANT"
        }
      },
      "output": {
        "type": "list<review>",
        "fields": [
          "result[0].author.name",
          "result[0].average_score",
          "result[0].pros",
          "result[0].cons",
          "result[0].date"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_location",
      "description_for_ai": "Search for a Booking.com destination ID by city or area name.",
      "intent": [
        "booking destination id",
        "search city booking",
        "location ID booking",
        "ID направления booking"
      ],
      "endpoint": "GET https://booking-com.p.rapidapi.com/v1/hotels/locations",
      "input": {
        "name": {
          "type": "string",
          "description": "City or area name: Paris, London, New York",
          "required": true
        },
        "locale": {
          "type": "string",
          "default": "en-gb"
        }
      },
      "output": {
        "type": "list<location>",
        "fields": [
          "result[0].dest_id",
          "result[0].city_name",
          "result[0].dest_type",
          "result[0].label"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_room_availability",
      "description_for_ai": "Get room types and availability for a hotel.",
      "intent": [
        "room availability booking",
        "hotel rooms",
        "check availability booking",
        "наличие номеров booking.com"
      ],
      "endpoint": "GET https://booking-com.p.rapidapi.com/v1/hotels/room-list",
      "input": {
        "hotel_id": {
          "type": "integer",
          "required": true
        },
        "checkin_date": {
          "type": "string",
          "required": true
        },
        "checkout_date": {
          "type": "string",
          "required": true
        },
        "adults_number": {
          "type": "integer",
          "default": 2
        }
      },
      "output": {
        "type": "list<room>",
        "fields": [
          "block[0].name",
          "block[0].room_count_for_display",
          "block[0].product_price_breakdown.gross_amount.value",
          "block[0].room_description"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}