{
  "apia": "1.0",
  "service": {
    "id": "youtube",
    "name": "YouTube Data API v3",
    "description_for_ai": "Search YouTube videos, get video details, channel info, comments, trending videos. 10,000 units/day free. Use for video search, embedding, analytics, content discovery.",
    "url": "https://youtube.com",
    "api_base": "https://www.googleapis.com/youtube/v3",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.google.com/youtube/v3"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Enable YouTube Data API at https://console.cloud.google.com",
    "cost": "Free: 10,000 units/day. Search costs 100 units/call."
  },
  "capabilities": [
    {
      "id": "search_videos",
      "description_for_ai": "Search YouTube videos, channels, playlists. Returns title, views, thumbnail, channel.",
      "intent": [
        "youtube search",
        "find video",
        "search youtube",
        "поиск youtube"
      ],
      "endpoint": "GET https://www.googleapis.com/youtube/v3/search",
      "input": {
        "q": {
          "type": "string",
          "required": true
        },
        "type": {
          "type": "string",
          "description": "video, channel, playlist",
          "default": "video"
        },
        "maxResults": {
          "type": "integer",
          "default": 10
        },
        "order": {
          "type": "string",
          "description": "date, rating, relevance, title, videoCount, viewCount",
          "default": "relevance"
        },
        "publishedAfter": {
          "type": "string",
          "description": "ISO 8601 datetime filter",
          "required": false
        },
        "videoDuration": {
          "type": "string",
          "description": "any, long (>20min), medium (4-20min), short (<4min)",
          "required": false
        }
      },
      "output": {
        "type": "list<item>",
        "fields": [
          "items[0].id.videoId",
          "items[0].snippet.title",
          "items[0].snippet.channelTitle",
          "items[0].snippet.publishedAt",
          "items[0].snippet.thumbnails.default.url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_video_details",
      "description_for_ai": "Get video metadata: views, likes, duration, tags, category, description.",
      "intent": [
        "video details youtube",
        "views count",
        "video stats",
        "информация видео youtube"
      ],
      "endpoint": "GET https://www.googleapis.com/youtube/v3/videos",
      "input": {
        "id": {
          "type": "string",
          "description": "Comma-separated video IDs",
          "required": true
        },
        "part": {
          "type": "string",
          "description": "snippet,statistics,contentDetails,status",
          "default": "snippet,statistics,contentDetails"
        }
      },
      "output": {
        "type": "list<video>",
        "fields": [
          "items[0].snippet.title",
          "items[0].statistics.viewCount",
          "items[0].statistics.likeCount",
          "items[0].statistics.commentCount",
          "items[0].contentDetails.duration"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_channel",
      "description_for_ai": "Get YouTube channel info: subscriber count, video count, description.",
      "intent": [
        "youtube channel",
        "channel info",
        "subscribers count",
        "канал youtube"
      ],
      "endpoint": "GET https://www.googleapis.com/youtube/v3/channels",
      "input": {
        "id": {
          "type": "string",
          "description": "Channel ID",
          "required": false
        },
        "forUsername": {
          "type": "string",
          "description": "Channel username",
          "required": false
        },
        "part": {
          "type": "string",
          "default": "snippet,statistics"
        }
      },
      "output": {
        "type": "channel",
        "fields": [
          "items[0].snippet.title",
          "items[0].statistics.subscriberCount",
          "items[0].statistics.videoCount",
          "items[0].snippet.description"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_captions",
      "description_for_ai": "List available caption tracks for a video. Use to discover if subtitles are available.",
      "intent": [
        "youtube captions",
        "subtitles youtube",
        "video transcript",
        "субтитры youtube"
      ],
      "endpoint": "GET https://www.googleapis.com/youtube/v3/captions",
      "input": {
        "videoId": {
          "type": "string",
          "required": true
        },
        "part": {
          "type": "string",
          "default": "snippet"
        }
      },
      "output": {
        "type": "list<caption>",
        "fields": [
          "items[0].id",
          "items[0].snippet.language",
          "items[0].snippet.trackKind",
          "items[0].snippet.name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "quota": "Search = 100 units. Video details = 1 unit. Free quota = 10,000 units/day. Avoid heavy search loops.",
    "video_id": "YouTube URL youtube.com/watch?v=VIDEO_ID — the VIDEO_ID is what you pass to the API."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}