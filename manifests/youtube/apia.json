{
  "apia": "1.0",
  "service": {
    "id": "youtube",
    "name": "YouTube Data API v3",
    "description_for_ai": "Search YouTube videos, get video details, channel info, comments, trending videos. 10,000 units/day free. Use for video search, embedding, analytics, content discovery.",
    "url": "https://youtube.com",
    "api_base": "https://www.googleapis.com/youtube/v3",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.google.com/youtube/v3"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Enable YouTube Data API at https://console.cloud.google.com",
    "cost": "Free: 10,000 units/day. Search costs 100 units/call."
  },
  "capabilities": [
    {
      "id": "search_videos",
      "description_for_ai": "Search YouTube videos, channels, and playlists by keyword.",
      "intent": [
        "search YouTube",
        "find video",
        "YouTube search",
        "поиск YouTube"
      ],
      "endpoint": "GET https://www.googleapis.com/youtube/v3/search",
      "input": {
        "q": {
          "type": "string",
          "required": true
        },
        "part": {
          "type": "string",
          "default": "snippet"
        },
        "type": {
          "type": "string",
          "description": "video, channel, playlist",
          "default": "video"
        },
        "maxResults": {
          "type": "integer",
          "default": 10
        },
        "order": {
          "type": "string",
          "description": "relevance, date, rating, viewCount, title",
          "default": "relevance"
        },
        "publishedAfter": {
          "type": "string",
          "description": "ISO 8601 date filter",
          "required": false
        },
        "regionCode": {
          "type": "string",
          "description": "ISO country code: US, RU, DE",
          "required": false
        }
      },
      "output": {
        "type": "list<result>",
        "fields": [
          "items[0].id.videoId",
          "items[0].snippet.title",
          "items[0].snippet.description",
          "items[0].snippet.channelTitle",
          "items[0].snippet.publishedAt",
          "items[0].snippet.thumbnails.high.url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_video_details",
      "description_for_ai": "Get detailed video info: views, likes, duration, tags, captions.",
      "intent": [
        "video details YouTube",
        "video stats",
        "view count YouTube",
        "детали видео YouTube"
      ],
      "endpoint": "GET https://www.googleapis.com/youtube/v3/videos",
      "input": {
        "id": {
          "type": "string",
          "description": "Video ID(s), comma-separated",
          "required": true
        },
        "part": {
          "type": "string",
          "description": "snippet,statistics,contentDetails",
          "default": "snippet,statistics,contentDetails"
        }
      },
      "output": {
        "type": "list<video>",
        "fields": [
          "items[0].snippet.title",
          "items[0].snippet.channelTitle",
          "items[0].statistics.viewCount",
          "items[0].statistics.likeCount",
          "items[0].contentDetails.duration",
          "items[0].snippet.tags"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_channel",
      "description_for_ai": "Get YouTube channel details: subscribers, video count, description.",
      "intent": [
        "channel info YouTube",
        "subscriber count",
        "YouTube channel",
        "канал YouTube"
      ],
      "endpoint": "GET https://www.googleapis.com/youtube/v3/channels",
      "input": {
        "id": {
          "type": "string",
          "description": "Channel ID",
          "required": false
        },
        "forUsername": {
          "type": "string",
          "description": "Channel username/handle",
          "required": false
        },
        "part": {
          "type": "string",
          "default": "snippet,statistics"
        }
      },
      "output": {
        "type": "channel",
        "fields": [
          "items[0].snippet.title",
          "items[0].snippet.description",
          "items[0].statistics.subscriberCount",
          "items[0].statistics.videoCount",
          "items[0].statistics.viewCount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_playlist_videos",
      "description_for_ai": "Get all videos from a YouTube playlist.",
      "intent": [
        "playlist videos",
        "YouTube playlist",
        "channel videos",
        "видео плейлиста YouTube"
      ],
      "endpoint": "GET https://www.googleapis.com/youtube/v3/playlistItems",
      "input": {
        "playlistId": {
          "type": "string",
          "required": true
        },
        "part": {
          "type": "string",
          "default": "snippet"
        },
        "maxResults": {
          "type": "integer",
          "default": 50
        },
        "pageToken": {
          "type": "string",
          "description": "Pagination token",
          "required": false
        }
      },
      "output": {
        "type": "list<video>",
        "fields": [
          "items[0].snippet.title",
          "items[0].snippet.videoOwnerChannelTitle",
          "items[0].snippet.resourceId.videoId",
          "items[0].snippet.publishedAt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_captions",
      "description_for_ai": "Get available captions/subtitles for a YouTube video.",
      "intent": [
        "YouTube subtitles",
        "video captions",
        "transcript YouTube",
        "субтитры YouTube"
      ],
      "endpoint": "GET https://www.googleapis.com/youtube/v3/captions",
      "input": {
        "videoId": {
          "type": "string",
          "required": true
        },
        "part": {
          "type": "string",
          "default": "snippet"
        }
      },
      "output": {
        "type": "list<caption>",
        "fields": [
          "items[0].id",
          "items[0].snippet.language",
          "items[0].snippet.trackKind (standard/asr/forced)",
          "items[0].snippet.lastUpdated"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_comment_threads",
      "description_for_ai": "Get top-level comments for a YouTube video.",
      "intent": [
        "YouTube comments",
        "video comments",
        "comment section",
        "комментарии YouTube"
      ],
      "endpoint": "GET https://www.googleapis.com/youtube/v3/commentThreads",
      "input": {
        "videoId": {
          "type": "string",
          "required": true
        },
        "part": {
          "type": "string",
          "default": "snippet"
        },
        "maxResults": {
          "type": "integer",
          "default": 20
        },
        "order": {
          "type": "string",
          "description": "time or relevance",
          "default": "relevance"
        }
      },
      "output": {
        "type": "list<comment>",
        "fields": [
          "items[0].snippet.topLevelComment.snippet.textDisplay",
          "items[0].snippet.topLevelComment.snippet.authorDisplayName",
          "items[0].snippet.topLevelComment.snippet.likeCount",
          "items[0].snippet.totalReplyCount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "quota": "Search = 100 units. Video details = 1 unit. Free quota = 10,000 units/day. Avoid heavy search loops.",
    "video_id": "YouTube URL youtube.com/watch?v=VIDEO_ID — the VIDEO_ID is what you pass to the API."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}