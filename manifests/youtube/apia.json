{
  "apia": "1.0",
  "service": {
    "id": "youtube",
    "name": "YouTube Data API v3",
    "description_for_ai": "Search YouTube videos, get video details, channel info, comments, trending videos. 10,000 units/day free. Use for video search, embedding, analytics, content discovery.",
    "url": "https://youtube.com",
    "api_base": "https://www.googleapis.com/youtube/v3",
    "category": "media_video",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.google.com/youtube/v3"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Enable YouTube Data API at https://console.cloud.google.com",
    "cost": "Free: 10,000 units/day. Search costs 100 units/call."
  },
  "capabilities": [
    {
      "id": "search",
      "description_for_ai": "Search YouTube videos by keyword. Returns title, description, thumbnail, channel, publish date.",
      "intent": [
        "find youtube video",
        "search videos",
        "youtube search",
        "видео на ютубе",
        "найти видео"
      ],
      "endpoint": "GET https://www.googleapis.com/youtube/v3/search",
      "input": {
        "q": {
          "type": "string",
          "required": true
        },
        "part": {
          "type": "string",
          "default": "snippet"
        },
        "type": {
          "type": "string",
          "default": "video"
        },
        "maxResults": {
          "type": "integer",
          "default": 10,
          "max": 50
        },
        "order": {
          "type": "string",
          "description": "relevance, date, viewCount, rating",
          "default": "relevance"
        },
        "regionCode": {
          "type": "string",
          "description": "ISO 3166-1 country code",
          "required": false
        },
        "relevanceLanguage": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<video>",
        "fields": [
          "id.videoId",
          "snippet.title",
          "snippet.description",
          "snippet.thumbnails.default.url",
          "snippet.channelTitle",
          "snippet.publishedAt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_video",
      "description_for_ai": "Get detailed info about a YouTube video: view count, likes, duration, tags, full description.",
      "intent": [
        "video details",
        "view count",
        "youtube video info",
        "video statistics"
      ],
      "endpoint": "GET https://www.googleapis.com/youtube/v3/videos",
      "input": {
        "id": {
          "type": "string",
          "description": "YouTube video ID",
          "required": true
        },
        "part": {
          "type": "string",
          "default": "snippet,statistics,contentDetails"
        }
      },
      "output": {
        "type": "video",
        "fields": [
          "snippet.title",
          "snippet.description",
          "statistics.viewCount",
          "statistics.likeCount",
          "contentDetails.duration",
          "snippet.tags"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "quota": "Search = 100 units. Video details = 1 unit. Free quota = 10,000 units/day. Avoid heavy search loops.",
    "video_id": "YouTube URL youtube.com/watch?v=VIDEO_ID — the VIDEO_ID is what you pass to the API."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}