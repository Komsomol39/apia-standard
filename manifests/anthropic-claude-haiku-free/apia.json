        "free claude",
        "claude haiku free",
        "test claude",
        "бесплатный Claude Haiku"
      ],
      "endpoint": "POST https://api.anthropic.com/v1/messages",
      "input": {
        "model": {
          "type": "string",
          "default": "claude-haiku-4-5"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "max_tokens": {
          "type": "integer",
          "default": 1024
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "content[0].text",
          "usage.input_tokens"
