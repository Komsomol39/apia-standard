{
  "apia": "1.0",
  "service": {
    "id": "zendesk",
    "name": "Zendesk API",
    "description_for_ai": "Customer support platform. Manage tickets, users, organizations, knowledge base articles, chat. Used by Airbnb, Shopify, Slack for customer service. Use for support ticket management, customer service automation.",
    "url": "https://zendesk.com",
    "api_base": "https://{subdomain}.zendesk.com/api/v2",
    "category": "support",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.zendesk.com/api-reference/"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "Email/token as username:password base64 encoded",
    "how_to_get": "Admin Center → Apps → API",
    "cost": "Suite Team: $55/agent/month. 14-day trial"
  },
  "capabilities": [
    {
      "id": "list_tickets",
      "description_for_ai": "List support tickets with filters by status, priority, assignee, and requester.",
      "intent": [
        "zendesk tickets",
        "support tickets",
        "customer tickets",
        "тикеты zendesk"
      ],
      "endpoint": "GET https://{subdomain}.zendesk.com/api/v2/tickets",
      "input": {
        "status": {
          "type": "string",
          "description": "new, open, pending, hold, solved, closed",
          "required": false
        },
        "priority": {
          "type": "string",
          "description": "low, normal, high, urgent",
          "required": false
        },
        "sort_by": {
          "type": "string",
          "description": "created_at, updated_at, priority, status",
          "default": "created_at"
        },
        "sort_order": {
          "type": "string",
          "default": "desc"
        },
        "per_page": {
          "type": "integer",
          "default": 25
        }
      },
      "output": {
        "type": "list<ticket>",
        "fields": [
          "tickets[0].id",
          "tickets[0].subject",
          "tickets[0].status",
          "tickets[0].priority",
          "tickets[0].requester_id",
          "tickets[0].assignee_id",
          "tickets[0].created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_ticket",
      "description_for_ai": "Create a new Zendesk support ticket.",
      "intent": [
        "create zendesk ticket",
        "new ticket",
        "open support ticket",
        "создать тикет zendesk"
      ],
      "endpoint": "POST https://{subdomain}.zendesk.com/api/v2/tickets",
      "input": {
        "ticket": {
          "type": "object",
          "description": "{subject: 'Issue title', comment: {body: 'Description'}, requester: {email, name}, priority: 'normal', status: 'new', tags: ['bug', 'billing'], custom_fields: [{id: 123, value: 'value'}]}",
          "required": true
        }
      },
      "output": {
        "type": "ticket",
        "fields": [
          "ticket.id",
          "ticket.subject",
          "ticket.status",
          "ticket.url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_ticket",
      "description_for_ai": "Update a ticket: change status, priority, assignee, or add a comment.",
      "intent": [
        "update ticket zendesk",
        "close ticket",
        "reply to ticket zendesk",
        "обновить тикет zendesk"
      ],
      "endpoint": "PUT https://{subdomain}.zendesk.com/api/v2/tickets/{ticket_id}",
      "input": {
        "ticket_id": {
          "type": "integer",
          "required": true
        },
        "ticket": {
          "type": "object",
          "description": "{status: 'solved', priority: 'urgent', comment: {body: 'Reply text', public: true}, assignee_id: 123}",
          "required": true
        }
      },
      "output": {
        "type": "ticket",
        "fields": [
          "ticket.id",
          "ticket.status",
          "ticket.updated_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search",
      "description_for_ai": "Search across tickets, users, and organizations using Zendesk Search API.",
      "intent": [
        "zendesk search",
        "find ticket",
        "search support",
        "поиск zendesk"
      ],
      "endpoint": "GET https://{subdomain}.zendesk.com/api/v2/search",
      "input": {
        "query": {
          "type": "string",
          "description": "Search query: 'type:ticket status:open priority:urgent' or 'billing error created>2024-01-01'",
          "required": true
        },
        "sort_by": {
          "type": "string",
          "description": "created_at, updated_at, priority, status, ticket_type",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 25
        }
      },
      "output": {
        "type": "list<result>",
        "fields": [
          "results[0].id",
          "results[0].subject",
          "results[0].status",
          "count"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}