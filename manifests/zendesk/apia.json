{
  "apia": "1.0",
  "service": {
    "id": "zendesk",
    "name": "Zendesk API",
    "description_for_ai": "Customer support platform. Manage tickets, users, organizations, knowledge base articles, chat. Used by Airbnb, Shopify, Slack for customer service. Use for support ticket management, customer service automation.",
    "url": "https://zendesk.com",
    "api_base": "https://{subdomain}.zendesk.com/api/v2",
    "category": "support",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.zendesk.com/api-reference/"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "Email/token as username:password base64 encoded",
    "how_to_get": "Admin Center → Apps → API",
    "cost": "Suite Team: $55/agent/month. 14-day trial"
  },
  "capabilities": [
    {
      "id": "create_ticket",
      "description_for_ai": "Create a new customer support ticket with all metadata. Automatically creates customer contact if email doesn't exist.",
      "intent": [
        "create support ticket",
        "customer issue",
        "help desk ticket",
        "support request",
        "customer complaint"
      ],
      "endpoint": "POST https://{subdomain}.zendesk.com/api/v2/tickets",
      "input": {
        "subject": {
          "type": "string",
          "description": "Ticket subject/title — brief description of issue",
          "required": true
        },
        "description": {
          "type": "string",
          "description": "Detailed issue description (first comment body). HTML supported.",
          "required": true
        },
        "email": {
          "type": "string",
          "description": "Customer's email address — creates contact automatically if new",
          "required": true
        },
        "name": {
          "type": "string",
          "description": "Customer's full name",
          "required": false
        },
        "priority": {
          "type": "string",
          "description": "urgent, high, normal, or low",
          "default": "normal"
        },
        "status": {
          "type": "string",
          "description": "new, open, pending, hold, solved, or closed",
          "default": "new"
        },
        "type": {
          "type": "string",
          "description": "Ticket type: problem, incident, question, or task",
          "required": false
        },
        "tags": {
          "type": "array",
          "description": "Array of tag strings for categorization and routing",
          "required": false
        },
        "assignee_id": {
          "type": "integer",
          "description": "Agent ID to assign ticket to. Get IDs from GET /users?role=agent",
          "required": false
        },
        "group_id": {
          "type": "integer",
          "description": "Support group ID for team routing",
          "required": false
        },
        "custom_fields": {
          "type": "array",
          "description": "[{id: field_id, value: 'field_value'}] for custom ticket fields",
          "required": false
        }
      },
      "output": {
        "type": "ticket",
        "fields": [
          "ticket.id",
          "ticket.url",
          "ticket.status",
          "ticket.priority",
          "ticket.requester_id",
          "ticket.created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_tickets",
      "description_for_ai": "List support tickets with flexible filters. Use for queue management, SLA monitoring, and reporting dashboards.",
      "intent": [
        "open tickets",
        "support queue",
        "customer issues",
        "pending tickets",
        "help desk queue"
      ],
      "endpoint": "GET https://{subdomain}.zendesk.com/api/v2/tickets",
      "input": {
        "status": {
          "type": "string",
          "description": "Filter by status: new, open, pending, hold, solved, closed",
          "required": false
        },
        "assignee_id": {
          "type": "integer",
          "description": "Filter by assigned agent ID",
          "required": false
        },
        "group_id": {
          "type": "integer",
          "description": "Filter by support group ID",
          "required": false
        },
        "priority": {
          "type": "string",
          "description": "Filter by priority: urgent, high, normal, low",
          "required": false
        },
        "sort_by": {
          "type": "string",
          "description": "Field to sort by: created_at, updated_at, priority, status, id",
          "default": "created_at"
        },
        "sort_order": {
          "type": "string",
          "description": "Sort direction: asc or desc",
          "default": "desc"
        },
        "per_page": {
          "type": "integer",
          "description": "Results per page, max 100",
          "default": 25
        },
        "page": {
          "type": "integer",
          "description": "Page number",
          "default": 1
        }
      },
      "output": {
        "type": "list<ticket>",
        "fields": [
          "tickets[0].id",
          "tickets[0].subject",
          "tickets[0].status",
          "tickets[0].priority",
          "tickets[0].requester_id",
          "tickets[0].assignee_id",
          "tickets[0].created_at",
          "tickets[0].updated_at",
          "count"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}