{
  "apia": "1.0",
  "service": {
    "id": "zendesk",
    "name": "Zendesk API",
    "description_for_ai": "Customer support platform. Manage tickets, users, organizations, knowledge base articles, chat. Used by Airbnb, Shopify, Slack for customer service. Use for support ticket management, customer service automation.",
    "url": "https://zendesk.com",
    "api_base": "https://{subdomain}.zendesk.com/api/v2",
    "category": "support",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.zendesk.com/api-reference/"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "Email/token as username:password base64 encoded",
    "how_to_get": "Admin Center → Apps → API",
    "cost": "Suite Team: $55/agent/month. 14-day trial"
  },
  "capabilities": [
    {
      "id": "list_tickets",
      "description_for_ai": "List support tickets with status, priority, and assignee filters.",
      "intent": [
        "zendesk tickets",
        "support tickets",
        "customer issues",
        "тикеты zendesk"
      ],
      "endpoint": "GET https://{subdomain}.zendesk.com/api/v2/tickets",
      "input": {
        "status": {
          "type": "string",
          "description": "new, open, pending, hold, solved, closed",
          "required": false
        },
        "priority": {
          "type": "string",
          "description": "urgent, high, normal, low",
          "required": false
        },
        "page": {
          "type": "integer",
          "default": 1
        },
        "per_page": {
          "type": "integer",
          "default": 25
        }
      },
      "output": {
        "type": "list<ticket>",
        "fields": [
          "tickets[0].id",
          "tickets[0].subject",
          "tickets[0].status",
          "tickets[0].priority",
          "tickets[0].requester_id",
          "tickets[0].created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_ticket",
      "description_for_ai": "Create a support ticket in Zendesk.",
      "intent": [
        "create ticket zendesk",
        "open ticket",
        "support request",
        "создать тикет zendesk"
      ],
      "endpoint": "POST https://{subdomain}.zendesk.com/api/v2/tickets",
      "input": {
        "ticket": {
          "type": "object",
          "description": "{subject: 'Issue title', comment: {body: 'Details'}, priority: 'normal', requester: {email: 'user@example.com'}, tags: ['bug', 'urgent']}",
          "required": true
        }
      },
      "output": {
        "type": "ticket",
        "fields": [
          "ticket.id",
          "ticket.subject",
          "ticket.status",
          "ticket.created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_tickets",
      "description_for_ai": "Search Zendesk tickets using query syntax.",
      "intent": [
        "search zendesk",
        "find ticket",
        "поиск тикетов zendesk"
      ],
      "endpoint": "GET https://{subdomain}.zendesk.com/api/v2/search",
      "input": {
        "query": {
          "type": "string",
          "description": "type:ticket status:open priority:urgent subject:billing",
          "required": true
        },
        "sort_by": {
          "type": "string",
          "description": "created_at, updated_at, priority, status",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 25
        }
      },
      "output": {
        "type": "list<result>",
        "fields": [
          "results[0].id",
          "results[0].subject",
          "results[0].status",
          "count"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "add_comment",
      "description_for_ai": "Add a public or private comment to a Zendesk ticket.",
      "intent": [
        "reply ticket zendesk",
        "comment zendesk",
        "respond to ticket",
        "ответить на тикет zendesk"
      ],
      "endpoint": "PUT https://{subdomain}.zendesk.com/api/v2/tickets/{ticket_id}",
      "input": {
        "ticket_id": {
          "type": "integer",
          "required": true
        },
        "ticket": {
          "type": "object",
          "description": "{comment: {body: 'Response text', public: true}, status: 'pending'}",
          "required": true
        }
      },
      "output": {
        "type": "ticket",
        "fields": [
          "ticket.id",
          "ticket.status",
          "ticket.updated_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}