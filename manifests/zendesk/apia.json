{
  "apia": "1.0",
  "service": {
    "id": "zendesk",
    "name": "Zendesk API",
    "description_for_ai": "Customer support platform. Manage tickets, users, organizations, knowledge base articles, chat. Used by Airbnb, Shopify, Slack for customer service. Use for support ticket management, customer service automation.",
    "url": "https://zendesk.com",
    "api_base": "https://{subdomain}.zendesk.com/api/v2",
    "category": "support",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.zendesk.com/api-reference/"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "Email/token as username:password base64 encoded",
    "how_to_get": "Admin Center → Apps → API",
    "cost": "Suite Team: $55/agent/month. 14-day trial"
  },
  "capabilities": [
    {
      "id": "list_tickets",
      "description_for_ai": "List support tickets in Zendesk. Filter by status, assignee, priority.",
      "intent": [
        "Zendesk tickets",
        "support tickets",
        "customer issues",
        "заявки Zendesk"
      ],
      "endpoint": "GET https://{subdomain}.zendesk.com/api/v2/tickets",
      "input": {
        "status": {
          "type": "string",
          "description": "new, open, pending, hold, solved, closed",
          "required": false
        },
        "priority": {
          "type": "string",
          "description": "urgent, high, normal, low",
          "required": false
        },
        "assignee_id": {
          "type": "integer",
          "required": false
        },
        "sort_by": {
          "type": "string",
          "description": "created_at, updated_at, priority, status",
          "default": "created_at"
        },
        "per_page": {
          "type": "integer",
          "default": 25
        }
      },
      "output": {
        "type": "list<ticket>",
        "fields": [
          "tickets[0].id",
          "tickets[0].subject",
          "tickets[0].status",
          "tickets[0].priority",
          "tickets[0].requester_id",
          "tickets[0].created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_ticket",
      "description_for_ai": "Create a new support ticket in Zendesk.",
      "intent": [
        "create Zendesk ticket",
        "submit support request",
        "new ticket",
        "создать заявку Zendesk"
      ],
      "endpoint": "POST https://{subdomain}.zendesk.com/api/v2/tickets",
      "input": {
        "subject": {
          "type": "string",
          "required": true
        },
        "body": {
          "type": "string",
          "description": "Comment body",
          "required": true
        },
        "requester_email": {
          "type": "string",
          "required": false
        },
        "priority": {
          "type": "string",
          "description": "urgent, high, normal, low",
          "default": "normal"
        },
        "tags": {
          "type": "array",
          "required": false
        },
        "type": {
          "type": "string",
          "description": "problem, incident, question, task",
          "required": false
        }
      },
      "output": {
        "type": "ticket",
        "fields": [
          "ticket.id",
          "ticket.subject",
          "ticket.status",
          "ticket.url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_ticket",
      "description_for_ai": "Update ticket status, priority, assignee, or add a comment.",
      "intent": [
        "update ticket Zendesk",
        "resolve ticket",
        "assign ticket",
        "обновить заявку Zendesk"
      ],
      "endpoint": "PUT https://{subdomain}.zendesk.com/api/v2/tickets/{ticket_id}",
      "input": {
        "ticket_id": {
          "type": "integer",
          "required": true
        },
        "status": {
          "type": "string",
          "description": "open, pending, solved, closed",
          "required": false
        },
        "assignee_id": {
          "type": "integer",
          "required": false
        },
        "comment": {
          "type": "object",
          "description": "{body: 'Reply text', public: true}",
          "required": false
        },
        "priority": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "ticket",
        "fields": [
          "ticket.id",
          "ticket.status",
          "ticket.updated_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_tickets",
      "description_for_ai": "Search tickets by keyword, requester, tag, or date.",
      "intent": [
        "search Zendesk",
        "find ticket",
        "ticket search",
        "поиск заявок Zendesk"
      ],
      "endpoint": "GET https://{subdomain}.zendesk.com/api/v2/search",
      "input": {
        "query": {
          "type": "string",
          "description": "Zendesk search: 'type:ticket status:open priority:urgent' or keyword",
          "required": true
        },
        "per_page": {
          "type": "integer",
          "default": 25
        }
      },
      "output": {
        "type": "list<ticket>",
        "fields": [
          "results[0].id",
          "results[0].subject",
          "results[0].status",
          "results[0].requester.email"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_users",
      "description_for_ai": "List agents and end-users in Zendesk.",
      "intent": [
        "Zendesk users",
        "agents list",
        "customer list Zendesk",
        "пользователи Zendesk"
      ],
      "endpoint": "GET https://{subdomain}.zendesk.com/api/v2/users",
      "input": {
        "role": {
          "type": "string",
          "description": "end-user, agent, admin",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 25
        }
      },
      "output": {
        "type": "list<user>",
        "fields": [
          "users[0].id",
          "users[0].name",
          "users[0].email",
          "users[0].role",
          "users[0].created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "add_comment",
      "description_for_ai": "Add a public or private comment to an existing ticket.",
      "intent": [
        "reply ticket Zendesk",
        "add comment",
        "respond to customer",
        "ответить клиенту Zendesk"
      ],
      "endpoint": "PUT https://{subdomain}.zendesk.com/api/v2/tickets/{ticket_id}",
      "input": {
        "ticket_id": {
          "type": "integer",
          "required": true
        },
        "body": {
          "type": "string",
          "description": "Comment text",
          "required": true
        },
        "public": {
          "type": "boolean",
          "description": "True = customer sees it, False = internal note",
          "default": true
        },
        "author_id": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "ticket",
        "fields": [
          "ticket.id",
          "audit.id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}