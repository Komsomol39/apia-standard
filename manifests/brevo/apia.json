{
  "apia": "1.0",
  "service": {
    "id": "brevo",
    "name": "Brevo (Sendinblue) API",
    "description_for_ai": "All-in-one marketing platform. Email, SMS, WhatsApp, push notifications, CRM. 500K+ companies. Generous free tier: 300 emails/day. Use for transactional email, marketing campaigns, SMS, WhatsApp Business.",
    "url": "https://brevo.com",
    "api_base": "https://api.brevo.com/v3",
    "category": "marketing_email",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.brevo.com/reference/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "api-key: {api_key}",
    "how_to_get": "Account → Settings → API Keys",
    "cost": "Free: 300 emails/day. Starter: $25/month 20K emails"
  },
  "capabilities": [
    {
      "id": "send_email",
      "description_for_ai": "Send transactional or marketing email via Brevo. Supports templates, HTML content, attachments.",
      "intent": [
        "send email",
        "transactional email",
        "email notification",
        "email campaign",
        "brevo email"
      ],
      "endpoint": "POST https://api.brevo.com/v3/smtp/email",
      "input": {
        "sender": {
          "type": "object",
          "description": "{name, email}",
          "required": true
        },
        "to": {
          "type": "array",
          "description": "[{email, name}]",
          "required": true
        },
        "subject": {
          "type": "string",
          "required": true
        },
        "htmlContent": {
          "type": "string",
          "description": "HTML email body",
          "required": false
        },
        "textContent": {
          "type": "string",
          "required": false
        },
        "templateId": {
          "type": "integer",
          "description": "Brevo template ID",
          "required": false
        },
        "params": {
          "type": "object",
          "description": "Template variables",
          "required": false
        }
      },
      "output": {
        "type": "email",
        "fields": [
          "messageId"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_sms",
      "description_for_ai": "Send transactional SMS message via Brevo to any phone number worldwide. Supports 180+ countries.",
      "intent": [
        "send SMS Brevo",
        "SMS marketing",
        "text message",
        "bulk SMS"
      ],
      "endpoint": "POST https://api.brevo.com/v3/transactionalSMS/sms",
      "input": {
        "sender": {
          "type": "string",
          "description": "Sender name (max 11 chars)",
          "required": true
        },
        "recipient": {
          "type": "string",
          "description": "Phone in E.164 format",
          "required": true
        },
        "content": {
          "type": "string",
          "description": "SMS text max 160 chars",
          "required": true
        }
      },
      "output": {
        "type": "sms",
        "fields": [
          "messageId",
          "smsCount",
          "creditUsed"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "api_key": "Get API key: account.brevo.com → SMTP & API → API Keys → Create a new API key",
    "sender_name": "SMS sender name: max 11 alphanumeric chars (no spaces). Register with carriers for best deliverability.",
    "free_plan": "Free plan: 300 emails/day unlimited contacts. SMS is pay-per-message (~0.5-2 cents depending on country).",
    "templates": "Create email templates in Brevo UI, then reference by templateId in send_email for personalized campaigns."
  }
}