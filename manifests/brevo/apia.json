{
  "apia": "1.0",
  "service": {
    "id": "brevo",
    "name": "Brevo (Sendinblue) API",
    "description_for_ai": "All-in-one marketing platform. Email, SMS, WhatsApp, push notifications, CRM. 500K+ companies. Generous free tier: 300 emails/day. Use for transactional email, marketing campaigns, SMS, WhatsApp Business.",
    "url": "https://brevo.com",
    "api_base": "https://api.brevo.com/v3",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.brevo.com/reference/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "api-key: {api_key}",
    "how_to_get": "Account → Settings → API Keys",
    "cost": "Free: 300 emails/day. Starter: $25/month 20K emails"
  },
  "capabilities": [
    {
      "id": "send_transactional_email",
      "description_for_ai": "Send a transactional email via Brevo (formerly Sendinblue).",
      "intent": [
        "send email Brevo",
        "Sendinblue email",
        "transactional email",
        "отправить письмо Brevo"
      ],
      "endpoint": "POST https://api.brevo.com/v3/smtp/email",
      "input": {
        "sender": {
          "type": "object",
          "description": "{name: 'My App', email: 'noreply@example.com'}",
          "required": true
        },
        "to": {
          "type": "array",
          "description": "[{email: 'user@example.com', name: 'User'}]",
          "required": true
        },
        "subject": {
          "type": "string",
          "required": true
        },
        "htmlContent": {
          "type": "string",
          "description": "HTML email body",
          "required": false
        },
        "textContent": {
          "type": "string",
          "required": false
        },
        "templateId": {
          "type": "integer",
          "description": "Brevo template ID",
          "required": false
        },
        "params": {
          "type": "object",
          "description": "Template variables: {name: 'John', link: 'https://...'}",
          "required": false
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "messageId"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_contacts",
      "description_for_ai": "Get all contacts in Brevo with their attributes and lists.",
      "intent": [
        "Brevo contacts",
        "email contacts",
        "subscribers Brevo",
        "контакты Brevo"
      ],
      "endpoint": "GET https://api.brevo.com/v3/contacts",
      "input": {
        "limit": {
          "type": "integer",
          "default": 50
        },
        "offset": {
          "type": "integer",
          "default": 0
        },
        "sort": {
          "type": "string",
          "description": "asc or desc",
          "default": "desc"
        }
      },
      "output": {
        "type": "list<contact>",
        "fields": [
          "contacts[0].email",
          "contacts[0].attributes.FIRSTNAME",
          "contacts[0].listIds",
          "contacts[0].createdAt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_contact",
      "description_for_ai": "Create a new contact in Brevo CRM.",
      "intent": [
        "add contact Brevo",
        "create subscriber",
        "add email Brevo",
        "добавить контакт Brevo"
      ],
      "endpoint": "POST https://api.brevo.com/v3/contacts",
      "input": {
        "email": {
          "type": "string",
          "required": true
        },
        "attributes": {
          "type": "object",
          "description": "{FIRSTNAME: 'John', LASTNAME: 'Doe', SMS: '+1234567890'}",
          "required": false
        },
        "listIds": {
          "type": "array",
          "description": "List IDs to add contact to",
          "required": false
        }
      },
      "output": {
        "type": "contact",
        "fields": [
          "id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_sms",
      "description_for_ai": "Send transactional SMS via Brevo.",
      "intent": [
        "send SMS Brevo",
        "Brevo SMS",
        "transactional SMS",
        "SMS Brevo"
      ],
      "endpoint": "POST https://api.brevo.com/v3/transactionalSMS/sms",
      "input": {
        "sender": {
          "type": "string",
          "description": "Sender name (max 11 chars)",
          "required": true
        },
        "recipient": {
          "type": "string",
          "description": "Phone number with country code: +33612345678",
          "required": true
        },
        "content": {
          "type": "string",
          "description": "SMS text (max 160 chars)",
          "required": true
        },
        "type": {
          "type": "string",
          "description": "transactional or marketing",
          "default": "transactional"
        }
      },
      "output": {
        "type": "sms",
        "fields": [
          "messageId",
          "smsCount",
          "usedCredits",
          "remainingCredits"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_email_stats",
      "description_for_ai": "Get email campaign statistics: opens, clicks, bounces, spam.",
      "intent": [
        "Brevo stats",
        "email analytics",
        "campaign report",
        "статистика Brevo"
      ],
      "endpoint": "GET https://api.brevo.com/v3/emailCampaigns/{campaignId}/report",
      "input": {
        "campaignId": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "report",
        "fields": [
          "stats.globalStats.viewed",
          "stats.globalStats.clicks",
          "stats.globalStats.hardBounces",
          "stats.globalStats.softBounces",
          "stats.globalStats.unsubscriptions"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "api_key": "Get API key: account.brevo.com → SMTP & API → API Keys → Create a new API key",
    "sender_name": "SMS sender name: max 11 alphanumeric chars (no spaces). Register with carriers for best deliverability.",
    "free_plan": "Free plan: 300 emails/day unlimited contacts. SMS is pay-per-message (~0.5-2 cents depending on country).",
    "templates": "Create email templates in Brevo UI, then reference by templateId in send_email for personalized campaigns."
  }
}