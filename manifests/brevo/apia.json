{
  "apia": "1.0",
  "service": {
    "id": "brevo",
    "name": "Brevo (Sendinblue) API",
    "description_for_ai": "All-in-one marketing platform. Email, SMS, WhatsApp, push notifications, CRM. 500K+ companies. Generous free tier: 300 emails/day. Use for transactional email, marketing campaigns, SMS, WhatsApp Business.",
    "url": "https://brevo.com",
    "api_base": "https://api.brevo.com/v3",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.brevo.com/reference/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "api-key: {api_key}",
    "how_to_get": "Account → Settings → API Keys",
    "cost": "Free: 300 emails/day. Starter: $25/month 20K emails"
  },
  "capabilities": [
    {
      "id": "send_transactional_email",
      "description_for_ai": "Send a transactional email (order confirmation, password reset, notification) via Brevo SMTP API.",
      "intent": [
        "send email brevo",
        "transactional email",
        "smtp email",
        "отправить письмо brevo"
      ],
      "endpoint": "POST https://api.brevo.com/v3/smtp/email",
      "input": {
        "sender": {
          "type": "object",
          "description": "{name: 'My App', email: 'no-reply@myapp.com'}",
          "required": true
        },
        "to": {
          "type": "array",
          "description": "[{email: 'user@example.com', name: 'User'}]",
          "required": true
        },
        "subject": {
          "type": "string",
          "required": true
        },
        "htmlContent": {
          "type": "string",
          "description": "HTML email body",
          "required": false
        },
        "textContent": {
          "type": "string",
          "description": "Plain text fallback",
          "required": false
        },
        "templateId": {
          "type": "integer",
          "description": "Brevo template ID",
          "required": false
        },
        "params": {
          "type": "object",
          "description": "Template variables {FIRSTNAME: 'John'}",
          "required": false
        }
      },
      "output": {
        "type": "send_result",
        "fields": [
          "messageId"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_contact",
      "description_for_ai": "Create or update a contact in Brevo CRM. Subscribe to lists, set attributes.",
      "intent": [
        "add contact brevo",
        "subscribe email",
        "create subscriber",
        "добавить контакт brevo"
      ],
      "endpoint": "POST https://api.brevo.com/v3/contacts",
      "input": {
        "email": {
          "type": "string",
          "required": true
        },
        "attributes": {
          "type": "object",
          "description": "{FIRSTNAME: 'John', LASTNAME: 'Doe', SMS: '+79001234567'}",
          "required": false
        },
        "listIds": {
          "type": "array",
          "description": "List IDs to add contact to",
          "required": false
        },
        "updateEnabled": {
          "type": "boolean",
          "description": "Update if exists",
          "default": true
        }
      },
      "output": {
        "type": "contact",
        "fields": [
          "id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_sms",
      "description_for_ai": "Send SMS via Brevo. Supports international numbers.",
      "intent": [
        "sms brevo",
        "send SMS brevo",
        "text message brevo",
        "смс через brevo"
      ],
      "endpoint": "POST https://api.brevo.com/v3/transactionalSMS/sms",
      "input": {
        "sender": {
          "type": "string",
          "description": "Sender name max 11 chars alphanumeric",
          "required": true
        },
        "recipient": {
          "type": "string",
          "description": "Phone in E.164 format e.g. +79001234567",
          "required": true
        },
        "content": {
          "type": "string",
          "description": "SMS text max 160 chars per segment",
          "required": true
        }
      },
      "output": {
        "type": "sms_result",
        "fields": [
          "messageId",
          "smsCount",
          "usedCredits"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_email_stats",
      "description_for_ai": "Get email campaign statistics: delivered, opened, clicked, bounced, unsubscribed.",
      "intent": [
        "email stats brevo",
        "campaign analytics",
        "email performance",
        "статистика email brevo"
      ],
      "endpoint": "GET https://api.brevo.com/v3/smtp/statistics/events",
      "input": {
        "startDate": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        },
        "endDate": {
          "type": "string",
          "required": false
        },
        "event": {
          "type": "string",
          "description": "delivered, opened, clicked, bounced, unsubscribed, softBounced",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 50
        }
      },
      "output": {
        "type": "list<event>",
        "fields": [
          "events[0].email",
          "events[0].event",
          "events[0].date",
          "events[0].subject",
          "events[0].messageId"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "api_key": "Get API key: account.brevo.com → SMTP & API → API Keys → Create a new API key",
    "sender_name": "SMS sender name: max 11 alphanumeric chars (no spaces). Register with carriers for best deliverability.",
    "free_plan": "Free plan: 300 emails/day unlimited contacts. SMS is pay-per-message (~0.5-2 cents depending on country).",
    "templates": "Create email templates in Brevo UI, then reference by templateId in send_email for personalized campaigns."
  }
}