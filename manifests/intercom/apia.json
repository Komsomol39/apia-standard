{
  "apia": "1.0",
  "service": {
    "id": "intercom",
    "name": "Intercom API",
    "description_for_ai": "Customer messaging platform. Live chat, chatbots, email campaigns, help center. 25K+ companies use it. Manage contacts, conversations, send messages. Use for customer engagement, support automation, in-app messaging.",
    "url": "https://intercom.com",
    "api_base": "https://api.intercom.io",
    "category": "support",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.intercom.com/docs/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer {token}",
    "how_to_get": "Settings → Integrations → API Keys",
    "cost": "Starter: $74/month. 14-day trial"
  },
  "capabilities": [
    {
      "id": "search_contacts",
      "description_for_ai": "Search Intercom contacts (leads and users) by email, name, or custom attributes.",
      "intent": [
        "find contact intercom",
        "search user intercom",
        "customer lookup intercom",
        "поиск контакта intercom"
      ],
      "endpoint": "POST https://api.intercom.io/contacts/search",
      "input": {
        "query": {
          "type": "object",
          "description": "{field: 'email', operator: '=', value: 'user@example.com'} or {operator: 'AND', value: [{...}, {...}]}",
          "required": true
        },
        "pagination": {
          "type": "object",
          "description": "{per_page: 20}",
          "required": false
        }
      },
      "output": {
        "type": "list<contact>",
        "fields": [
          "data[0].id",
          "data[0].email",
          "data[0].name",
          "data[0].external_id",
          "data[0].created_at",
          "total_count"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_contact",
      "description_for_ai": "Create a new Intercom user or lead.",
      "intent": [
        "create contact intercom",
        "add user intercom",
        "new lead intercom",
        "добавить контакт intercom"
      ],
      "endpoint": "POST https://api.intercom.io/contacts",
      "input": {
        "role": {
          "type": "string",
          "description": "user or lead",
          "required": true
        },
        "email": {
          "type": "string",
          "required": false
        },
        "name": {
          "type": "string",
          "required": false
        },
        "external_id": {
          "type": "string",
          "description": "Your internal user ID",
          "required": false
        },
        "custom_attributes": {
          "type": "object",
          "description": "{plan: 'pro', company: 'Acme'}",
          "required": false
        }
      },
      "output": {
        "type": "contact",
        "fields": [
          "id",
          "email",
          "name",
          "role",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_message",
      "description_for_ai": "Send a message to a user via Intercom (email or in-app).",
      "intent": [
        "intercom message",
        "send in-app message",
        "customer message intercom",
        "написать пользователю intercom"
      ],
      "endpoint": "POST https://api.intercom.io/messages",
      "input": {
        "message_type": {
          "type": "string",
          "description": "email or inapp",
          "required": true
        },
        "subject": {
          "type": "string",
          "description": "Email subject",
          "required": false
        },
        "body": {
          "type": "string",
          "description": "Message content (HTML for email)",
          "required": true
        },
        "from": {
          "type": "object",
          "description": "{type: admin, id: 'admin_id'}",
          "required": true
        },
        "to": {
          "type": "object",
          "description": "{type: user, id: 'contact_id'}",
          "required": true
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "id",
          "message_type",
          "subject",
          "body",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_conversations",
      "description_for_ai": "List Intercom conversations with filters by status and assignee.",
      "intent": [
        "intercom conversations",
        "support chats",
        "customer conversations",
        "разговоры intercom"
      ],
      "endpoint": "GET https://api.intercom.io/conversations",
      "input": {
        "open": {
          "type": "boolean",
          "description": "true for open, false for closed",
          "required": false
        },
        "assigned": {
          "type": "boolean",
          "required": false
        },
        "display_as": {
          "type": "string",
          "description": "plaintext or html",
          "default": "plaintext"
        },
        "per_page": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<conversation>",
        "fields": [
          "conversations[0].id",
          "conversations[0].title",
          "conversations[0].state",
          "conversations[0].contact.contacts[0].id",
          "conversations[0].statistics"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_note",
      "description_for_ai": "Add an internal note to an Intercom conversation.",
      "intent": [
        "intercom note",
        "internal note",
        "add comment intercom",
        "заметка intercom"
      ],
      "endpoint": "POST https://api.intercom.io/conversations/{conversation_id}/reply",
      "input": {
        "conversation_id": {
          "type": "string",
          "required": true
        },
        "type": {
          "type": "string",
          "default": "admin"
        },
        "admin_id": {
          "type": "string",
          "required": true
        },
        "message_type": {
          "type": "string",
          "default": "note"
        },
        "body": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "note",
        "fields": [
          "type",
          "id",
          "body",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "auth": "Create Access Token at app.intercom.com/a/apps/{app_id}/developer-hub/access-tokens. Add to Authorization: Bearer header.",
    "contact_vs_user": "role='user' for logged-in users, role='lead' for anonymous visitors. Users have external_id.",
    "events": "Track events via POST /events: {event_name: 'purchase', user_id: '123', created_at: unix_ts, metadata: {}}",
    "rate_limits": "1000 req/min. Webhook events fire in real-time — prefer webhooks over polling."
  }
}