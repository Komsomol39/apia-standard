{
  "apia": "1.0",
  "service": {
    "id": "intercom",
    "name": "Intercom API",
    "description_for_ai": "Customer messaging platform. Live chat, chatbots, email campaigns, help center. 25K+ companies use it. Manage contacts, conversations, send messages. Use for customer engagement, support automation, in-app messaging.",
    "url": "https://intercom.com",
    "api_base": "https://api.intercom.io",
    "category": "support",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.intercom.com/docs/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer {token}",
    "how_to_get": "Settings → Integrations → API Keys",
    "cost": "Starter: $74/month. 14-day trial"
  },
  "capabilities": [
    {
      "id": "create_contact",
      "description_for_ai": "Create or update a lead/user contact in Intercom.",
      "intent": [
        "intercom contact",
        "add user intercom",
        "lead intercom",
        "контакт intercom"
      ],
      "endpoint": "POST https://api.intercom.io/contacts",
      "input": {
        "role": {
          "type": "string",
          "description": "user or lead",
          "required": true
        },
        "email": {
          "type": "string",
          "required": false
        },
        "name": {
          "type": "string",
          "required": false
        },
        "phone": {
          "type": "string",
          "required": false
        },
        "custom_attributes": {
          "type": "object",
          "description": "Custom contact fields",
          "required": false
        }
      },
      "output": {
        "type": "contact",
        "fields": [
          "id",
          "email",
          "name",
          "role",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_message",
      "description_for_ai": "Send an in-app or email message to a contact via Intercom.",
      "intent": [
        "intercom message",
        "send message intercom",
        "customer message",
        "сообщение intercom"
      ],
      "endpoint": "POST https://api.intercom.io/messages",
      "input": {
        "message_type": {
          "type": "string",
          "description": "inapp, email",
          "required": true
        },
        "subject": {
          "type": "string",
          "description": "Email subject (email only)",
          "required": false
        },
        "body": {
          "type": "string",
          "description": "Message body HTML",
          "required": true
        },
        "template": {
          "type": "string",
          "description": "plain or personal",
          "required": false
        },
        "from": {
          "type": "object",
          "description": "{type: admin, id: 'admin_id'}",
          "required": true
        },
        "to": {
          "type": "object",
          "description": "{type: user, id: 'contact_id'}",
          "required": true
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "id",
          "created_at",
          "body"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_contacts",
      "description_for_ai": "Search Intercom contacts by email, name, or custom attributes.",
      "intent": [
        "search intercom contacts",
        "find customer intercom",
        "поиск intercom"
      ],
      "endpoint": "POST https://api.intercom.io/contacts/search",
      "input": {
        "query": {
          "type": "object",
          "description": "{field: 'email', operator: '=', value: 'user@example.com'} or {operator: 'AND', value: [{...}, {...}]}",
          "required": true
        },
        "pagination": {
          "type": "object",
          "description": "{per_page: 25}",
          "required": false
        }
      },
      "output": {
        "type": "list<contact>",
        "fields": [
          "data[0].id",
          "data[0].email",
          "data[0].name",
          "data[0].created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_conversation",
      "description_for_ai": "Start a new conversation with a contact from an admin.",
      "intent": [
        "intercom conversation",
        "start chat intercom",
        "initiate conversation",
        "создать разговор intercom"
      ],
      "endpoint": "POST https://api.intercom.io/conversations",
      "input": {
        "from": {
          "type": "object",
          "description": "{type: admin, id: 'admin_id'}",
          "required": true
        },
        "to": {
          "type": "object",
          "description": "{type: user, id: 'contact_id'}",
          "required": true
        },
        "subject": {
          "type": "string",
          "required": false
        },
        "body": {
          "type": "string",
          "description": "Opening message",
          "required": true
        }
      },
      "output": {
        "type": "conversation",
        "fields": [
          "id",
          "created_at",
          "state",
          "type"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "auth": "Create Access Token at app.intercom.com/a/apps/{app_id}/developer-hub/access-tokens. Add to Authorization: Bearer header.",
    "contact_vs_user": "role='user' for logged-in users, role='lead' for anonymous visitors. Users have external_id.",
    "events": "Track events via POST /events: {event_name: 'purchase', user_id: '123', created_at: unix_ts, metadata: {}}",
    "rate_limits": "1000 req/min. Webhook events fire in real-time — prefer webhooks over polling."
  }
}