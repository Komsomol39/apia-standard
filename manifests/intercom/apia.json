{
  "apia": "1.0",
  "service": {
    "id": "intercom",
    "name": "Intercom API",
    "description_for_ai": "Customer messaging platform. Live chat, chatbots, email campaigns, help center. 25K+ companies use it. Manage contacts, conversations, send messages. Use for customer engagement, support automation, in-app messaging.",
    "url": "https://intercom.com",
    "api_base": "https://api.intercom.io",
    "category": "support",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.intercom.com/docs/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer {token}",
    "how_to_get": "Settings → Integrations → API Keys",
    "cost": "Starter: $74/month. 14-day trial"
  },
  "capabilities": [
    {
      "id": "list_conversations",
      "description_for_ai": "List customer conversations in Intercom.",
      "intent": [
        "Intercom conversations",
        "customer chats",
        "support conversations",
        "разговоры Intercom"
      ],
      "endpoint": "GET https://api.intercom.io/conversations",
      "input": {
        "open": {
          "type": "boolean",
          "description": "Filter open/closed",
          "required": false
        },
        "assigned_to": {
          "type": "string",
          "description": "Admin ID",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<conversation>",
        "fields": [
          "conversations[0].id",
          "conversations[0].title",
          "conversations[0].state",
          "conversations[0].read",
          "conversations[0].created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_message",
      "description_for_ai": "Send a message to a user via Intercom.",
      "intent": [
        "send Intercom message",
        "message user Intercom",
        "outbound message",
        "отправить сообщение Intercom"
      ],
      "endpoint": "POST https://api.intercom.io/messages",
      "input": {
        "message_type": {
          "type": "string",
          "description": "inapp or email",
          "required": true
        },
        "subject": {
          "type": "string",
          "description": "Email subject",
          "required": false
        },
        "body": {
          "type": "string",
          "required": true
        },
        "from": {
          "type": "object",
          "description": "{type: 'admin', id: 'admin_id'}",
          "required": true
        },
        "to": {
          "type": "object",
          "description": "{type: 'user', id: 'user_id'} or {type: 'contact', id: 'contact_id'}",
          "required": true
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "id",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_contact",
      "description_for_ai": "Create or update a user/lead contact in Intercom.",
      "intent": [
        "create contact Intercom",
        "new user Intercom",
        "add lead Intercom",
        "контакт Intercom"
      ],
      "endpoint": "POST https://api.intercom.io/contacts",
      "input": {
        "role": {
          "type": "string",
          "description": "user or lead",
          "required": true
        },
        "email": {
          "type": "string",
          "required": false
        },
        "name": {
          "type": "string",
          "required": false
        },
        "external_id": {
          "type": "string",
          "description": "Your internal user ID",
          "required": false
        },
        "custom_attributes": {
          "type": "object",
          "required": false
        }
      },
      "output": {
        "type": "contact",
        "fields": [
          "id",
          "external_id",
          "email",
          "name",
          "role",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_contacts",
      "description_for_ai": "List contacts (users/leads) in Intercom.",
      "intent": [
        "Intercom contacts",
        "users list Intercom",
        "leads Intercom",
        "контакты Intercom"
      ],
      "endpoint": "GET https://api.intercom.io/contacts",
      "input": {
        "per_page": {
          "type": "integer",
          "default": 50
        }
      },
      "output": {
        "type": "list<contact>",
        "fields": [
          "data[0].id",
          "data[0].email",
          "data[0].name",
          "data[0].role",
          "data[0].last_seen_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "reply_conversation",
      "description_for_ai": "Reply to an Intercom conversation as admin.",
      "intent": [
        "reply Intercom",
        "respond conversation",
        "admin reply",
        "ответить в Intercom"
      ],
      "endpoint": "POST https://api.intercom.io/conversations/{id}/reply",
      "input": {
        "id": {
          "type": "string",
          "required": true
        },
        "type": {
          "type": "string",
          "default": "admin"
        },
        "admin_id": {
          "type": "string",
          "required": true
        },
        "message_type": {
          "type": "string",
          "description": "comment or note",
          "default": "comment"
        },
        "body": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "conversation",
        "fields": [
          "id",
          "state",
          "updated_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_note",
      "description_for_ai": "Create an internal note on a contact in Intercom.",
      "intent": [
        "note Intercom",
        "internal note",
        "contact note",
        "заметка в Intercom"
      ],
      "endpoint": "POST https://api.intercom.io/notes",
      "input": {
        "body": {
          "type": "string",
          "required": true
        },
        "contact_id": {
          "type": "string",
          "required": true
        },
        "admin_id": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "note",
        "fields": [
          "id",
          "body",
          "created_at",
          "contact.id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "auth": "Create Access Token at app.intercom.com/a/apps/{app_id}/developer-hub/access-tokens. Add to Authorization: Bearer header.",
    "contact_vs_user": "role='user' for logged-in users, role='lead' for anonymous visitors. Users have external_id.",
    "events": "Track events via POST /events: {event_name: 'purchase', user_id: '123', created_at: unix_ts, metadata: {}}",
    "rate_limits": "1000 req/min. Webhook events fire in real-time — prefer webhooks over polling."
  }
}