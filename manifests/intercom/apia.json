{"apia":"1.0","service":{"id":"intercom","name":"Intercom API","description_for_ai":"Customer messaging platform. Live chat, chatbots, email campaigns, help center. 25K+ companies use it. Manage contacts, conversations, send messages. Use for customer engagement, support automation, in-app messaging.","url":"https://intercom.com","api_base":"https://api.intercom.io","category":"customer_support","geo":["GLOBAL"],"language":"en","docs":"https://developers.intercom.com/docs/"},"auth":{"type":"bearer_token","anonymous_access":false,"header":"Authorization: Bearer {token}","how_to_get":"Settings → Integrations → API Keys","cost":"Starter: $74/month. 14-day trial"},"capabilities":[{"id":"create_contact","description_for_ai":"Create or update a contact in Intercom CRM. Set custom attributes for personalization.","intent":["add contact intercom","create user","identify user","track customer","contact management"],"endpoint":"POST https://api.intercom.io/contacts","input":{"role":{"type":"string","description":"user or lead","default":"lead"},"email":{"type":"string","required":false},"name":{"type":"string","required":false},"custom_attributes":{"type":"object","description":"Custom fields key-value","required":false},"external_id":{"type":"string","description":"Your internal user ID","required":false}},"output":{"type":"contact","fields":["id","email","name","role","created_at","custom_attributes"]},"realtime":true,"requires_auth":true},{"id":"send_message","description_for_ai":"Send in-app or email message to a user via Intercom.","intent":["send intercom message","message user","in-app notification","user communication","chat message"],"endpoint":"POST https://api.intercom.io/messages","input":{"message_type":{"type":"string","description":"inapp or email","default":"inapp"},"subject":{"type":"string","description":"Email subject (for email type)","required":false},"body":{"type":"string","description":"Message content","required":true},"from":{"type":"object","descrip