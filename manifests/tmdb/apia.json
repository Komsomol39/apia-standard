{
  "apia": "1.0",
  "service": {
    "id": "tmdb",
    "name": "The Movie Database (TMDB) API",
    "description_for_ai": "Free movie and TV database with 1M+ titles. Metadata, cast, ratings, trailers, posters. Used by major streaming apps. No cost. Use for movie/show info, search, recommendations, now playing.",
    "url": "https://themoviedb.org",
    "api_base": "https://api.themoviedb.org/3",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.themoviedb.org/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Bearer ...",
    "how_to_get": "Free key at https://www.themoviedb.org/settings/api",
    "cost": "Completely free"
  },
  "capabilities": [
    {
      "id": "search_movies",
      "description_for_ai": "Search movies by title with release year, language, and region filters.",
      "intent": [
        "find movie",
        "search film",
        "TMDB search",
        "поиск фильма"
      ],
      "endpoint": "GET https://api.themoviedb.org/3/search/movie",
      "input": {
        "query": {
          "type": "string",
          "required": true
        },
        "year": {
          "type": "integer",
          "required": false
        },
        "language": {
          "type": "string",
          "description": "ISO 639-1 code: en-US, ru-RU",
          "default": "en-US"
        },
        "include_adult": {
          "type": "boolean",
          "default": false
        },
        "page": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<movie>",
        "fields": [
          "results[0].id",
          "results[0].title",
          "results[0].overview",
          "results[0].release_date",
          "results[0].vote_average",
          "results[0].poster_path"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_movie",
      "description_for_ai": "Get full movie details: cast, crew, budget, genres, runtime, trailers.",
      "intent": [
        "movie details TMDB",
        "film info",
        "movie cast",
        "подробности фильма TMDB"
      ],
      "endpoint": "GET https://api.themoviedb.org/3/movie/{movie_id}",
      "input": {
        "movie_id": {
          "type": "integer",
          "required": true
        },
        "append_to_response": {
          "type": "string",
          "description": "Extra data: credits,videos,images,similar,recommendations",
          "required": false
        },
        "language": {
          "type": "string",
          "default": "en-US"
        }
      },
      "output": {
        "type": "movie",
        "fields": [
          "id",
          "title",
          "overview",
          "release_date",
          "vote_average",
          "budget",
          "revenue",
          "runtime",
          "genres",
          "credits.cast[0].name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_trending",
      "description_for_ai": "Get trending movies, TV shows, or people on TMDB.",
      "intent": [
        "trending movies",
        "popular films now",
        "trending TMDB",
        "популярные фильмы сейчас"
      ],
      "endpoint": "GET https://api.themoviedb.org/3/trending/{media_type}/{time_window}",
      "input": {
        "media_type": {
          "type": "string",
          "description": "movie, tv, person, all",
          "required": true
        },
        "time_window": {
          "type": "string",
          "description": "day or week",
          "required": true
        },
        "language": {
          "type": "string",
          "default": "en-US"
        }
      },
      "output": {
        "type": "list<item>",
        "fields": [
          "results[0].id",
          "results[0].title",
          "results[0].vote_average",
          "results[0].release_date",
          "results[0].poster_path"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_tv",
      "description_for_ai": "Search TV shows on TMDB.",
      "intent": [
        "search TV show",
        "find series",
        "TV search TMDB",
        "поиск сериала TMDB"
      ],
      "endpoint": "GET https://api.themoviedb.org/3/search/tv",
      "input": {
        "query": {
          "type": "string",
          "required": true
        },
        "language": {
          "type": "string",
          "default": "en-US"
        },
        "page": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<tv>",
        "fields": [
          "results[0].id",
          "results[0].name",
          "results[0].overview",
          "results[0].first_air_date",
          "results[0].vote_average",
          "results[0].poster_path"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_recommendations",
      "description_for_ai": "Get movie or TV show recommendations based on a specific title.",
      "intent": [
        "movie recommendations",
        "similar movies",
        "what to watch next",
        "похожие фильмы TMDB"
      ],
      "endpoint": "GET https://api.themoviedb.org/3/{media_type}/{id}/recommendations",
      "input": {
        "media_type": {
          "type": "string",
          "description": "movie or tv",
          "required": true
        },
        "id": {
          "type": "integer",
          "description": "Movie or TV show ID",
          "required": true
        },
        "language": {
          "type": "string",
          "default": "en-US"
        }
      },
      "output": {
        "type": "list<item>",
        "fields": [
          "results[0].id",
          "results[0].title",
          "results[0].vote_average",
          "results[0].overview"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "discover",
      "description_for_ai": "Discover movies/TV filtered by genre, release year, rating, and more.",
      "intent": [
        "discover movies",
        "filter movies",
        "movies by genre TMDB",
        "фильмы по жанру TMDB"
      ],
      "endpoint": "GET https://api.themoviedb.org/3/discover/{media_type}",
      "input": {
        "media_type": {
          "type": "string",
          "description": "movie or tv",
          "required": true
        },
        "with_genres": {
          "type": "string",
          "description": "Genre IDs comma-separated: 28 (Action), 35 (Comedy), 18 (Drama), 27 (Horror), 878 (Sci-Fi)",
          "required": false
        },
        "sort_by": {
          "type": "string",
          "description": "popularity.desc, vote_average.desc, release_date.desc",
          "default": "popularity.desc"
        },
        "vote_average.gte": {
          "type": "float",
          "required": false
        },
        "primary_release_year": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "list<movie>",
        "fields": [
          "results[0].id",
          "results[0].title",
          "results[0].vote_average",
          "results[0].release_date",
          "results[0].genre_ids"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "poster_url": "Poster images: https://image.tmdb.org/t/p/w500{poster_path}",
    "language": "Supports ru-RU for Russian. Pass language=ru-RU for Russian titles and descriptions.",
    "free": "100% free, just need API key."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}