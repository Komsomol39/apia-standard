{
  "apia": "1.0",
  "service": {
    "id": "tmdb",
    "name": "The Movie Database (TMDB) API",
    "description_for_ai": "Free movie and TV database with 1M+ titles. Metadata, cast, ratings, trailers, posters. Used by major streaming apps. No cost. Use for movie/show info, search, recommendations, now playing.",
    "url": "https://themoviedb.org",
    "api_base": "https://api.themoviedb.org/3",
    "category": "media_entertainment",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.themoviedb.org/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Bearer ...",
    "how_to_get": "Free key at https://www.themoviedb.org/settings/api",
    "cost": "Completely free"
  },
  "capabilities": [
    {
      "id": "search_movie",
      "description_for_ai": "Search for movies by title. Returns matching movies with ratings, release dates, overview, and poster images.",
      "intent": [
        "find movie",
        "movie info",
        "search film",
        "movie details",
        "фильм информация",
        "что за фильм"
      ],
      "endpoint": "GET https://api.themoviedb.org/3/search/movie",
      "input": {
        "query": {
          "type": "string",
          "description": "Movie title or keywords to search",
          "required": true
        },
        "language": {
          "type": "string",
          "description": "Language for results: en-US, ru-RU, de-DE, fr-FR, etc.",
          "default": "en-US"
        },
        "year": {
          "type": "integer",
          "description": "Filter by release year e.g. 2024",
          "required": false
        },
        "page": {
          "type": "integer",
          "description": "Page number, max 500 pages",
          "default": 1
        },
        "include_adult": {
          "type": "boolean",
          "description": "Include adult content results",
          "default": false
        },
        "region": {
          "type": "string",
          "description": "ISO 3166-1 country code to prioritize results for that region",
          "required": false
        }
      },
      "output": {
        "type": "list<movie>",
        "fields": [
          "results[0].id",
          "results[0].title",
          "results[0].overview",
          "results[0].release_date",
          "results[0].vote_average",
          "results[0].poster_path",
          "results[0].genre_ids",
          "total_results",
          "total_pages"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_movie",
      "description_for_ai": "Get comprehensive details for a movie by TMDB ID: cast, crew, trailers, budget, revenue, similar movies, keywords, and streaming providers.",
      "intent": [
        "movie details",
        "cast",
        "director",
        "trailer",
        "movie budget",
        "movie rating"
      ],
      "endpoint": "GET https://api.themoviedb.org/3/movie/{movie_id}",
      "input": {
        "movie_id": {
          "type": "integer",
          "description": "TMDB movie ID from search results or TMDB URL",
          "required": true
        },
        "append_to_response": {
          "type": "string",
          "description": "Comma-separated extras: videos,credits,similar,images,keywords,release_dates,watch/providers. E.g. 'videos,credits,similar'",
          "required": false
        },
        "language": {
          "type": "string",
          "description": "Response language e.g. en-US, ru-RU",
          "default": "en-US"
        }
      },
      "output": {
        "type": "movie",
        "fields": [
          "title",
          "overview",
          "release_date",
          "runtime",
          "vote_average",
          "vote_count",
          "budget",
          "revenue",
          "genres",
          "credits.cast[0].name",
          "videos.results[0].key",
          "similar.results[0].title"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "now_playing",
      "description_for_ai": "Get movies currently playing in theaters. Updated daily. Use for 'what's in cinema', movie recommendations, current releases.",
      "intent": [
        "movies in theaters",
        "now playing",
        "cinema today",
        "new movies",
        "что идёт в кино"
      ],
      "endpoint": "GET https://api.themoviedb.org/3/movie/now_playing",
      "input": {
        "language": {
          "type": "string",
          "description": "Response language",
          "default": "en-US"
        },
        "page": {
          "type": "integer",
          "default": 1
        },
        "region": {
          "type": "string",
          "description": "ISO 3166-1 country code to get local theater releases",
          "required": false
        }
      },
      "output": {
        "type": "list<movie>",
        "fields": [
          "results[0].title",
          "results[0].release_date",
          "results[0].vote_average",
          "results[0].overview",
          "results[0].poster_path",
          "dates.minimum",
          "dates.maximum"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "poster_url": "Poster images: https://image.tmdb.org/t/p/w500{poster_path}",
    "language": "Supports ru-RU for Russian. Pass language=ru-RU for Russian titles and descriptions.",
    "free": "100% free, just need API key."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}