{
  "apia": "1.0",
  "service": {
    "id": "openweathermap",
    "name": "OpenWeatherMap",
    "description_for_ai": "World's most popular weather API. Use for current weather, forecasts and historical data for any city or coordinates. Returns temperature, humidity, wind, pressure, precipitation, sunrise/sunset. Free tier: 1000 calls/day. Used by 5M+ developers worldwide.",
    "url": "https://openweathermap.org",
    "api_base": "https://api.openweathermap.org/data/2.5",
    "category": "weather",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://openweathermap.org/api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "appid",
    "param_location": "query",
    "how_to_get": "Register at https://openweathermap.org/api — free tier available instantly",
    "cost": "Free: 1000 calls/day. Paid plans from $40/month"
  },
  "capabilities": [
    {
      "id": "current_weather",
      "description_for_ai": "Get current weather conditions for any city or coordinates: temperature, humidity, wind speed, cloud cover, visibility, weather description and icon.",
      "intent": [
        "current weather",
        "what's the weather",
        "temperature now",
        "is it raining",
        "weather today",
        "погода сейчас"
      ],
      "endpoint": "GET https://api.openweathermap.org/data/2.5/weather",
      "input": {
        "q": {
          "type": "string",
          "description": "City name e.g. 'Moscow', 'London,GB', 'New York,US'. Use country code for disambiguation.",
          "required": false
        },
        "lat": {
          "type": "float",
          "description": "Latitude (-90 to 90). Use with lon for coordinate-based lookup.",
          "required": false
        },
        "lon": {
          "type": "float",
          "description": "Longitude (-180 to 180)",
          "required": false
        },
        "units": {
          "type": "string",
          "description": "metric (Celsius, m/s), imperial (Fahrenheit, mph), standard (Kelvin)",
          "default": "metric"
        },
        "lang": {
          "type": "string",
          "description": "Language for description: en, ru, de, fr, es, zh_cn, ja, etc.",
          "default": "en"
        }
      },
      "output": {
        "type": "weather",
        "fields": [
          "main.temp",
          "main.feels_like",
          "main.humidity",
          "main.pressure",
          "weather[0].description",
          "weather[0].icon",
          "wind.speed",
          "wind.deg",
          "clouds.all",
          "visibility",
          "name",
          "sys.country"
        ]
      },
      "realtime": true,
      "requires_auth": true,
      "rate_limit": "1000/day free"
    },
    {
      "id": "forecast_5day",
      "description_for_ai": "Get 5-day weather forecast in 3-hour intervals (40 data points). Returns temperature, precipitation probability, wind, and conditions.",
      "intent": [
        "weather forecast",
        "will it rain",
        "weekend weather",
        "weather tomorrow",
        "5 day forecast",
        "прогноз погоды"
      ],
      "endpoint": "GET https://api.openweathermap.org/data/2.5/forecast",
      "input": {
        "q": {
          "type": "string",
          "description": "City name e.g. 'Moscow' or 'Paris,FR'",
          "required": false
        },
        "lat": {
          "type": "float",
          "required": false,
          "description": "Latitude coordinate (decimal degrees, -90 to 90)"
        },
        "lon": {
          "type": "float",
          "required": false,
          "description": "Longitude coordinate (decimal degrees, -180 to 180)"
        },
        "units": {
          "type": "string",
          "description": "metric, imperial, or standard",
          "default": "metric"
        },
        "lang": {
          "type": "string",
          "default": "en",
          "description": "Language code e.g. en, ru, de, fr, es"
        },
        "cnt": {
          "type": "integer",
          "description": "Number of timestamps (max 40 = 5 days × 8 per day)",
          "required": false
        }
      },
      "output": {
        "type": "forecast",
        "fields": [
          "list[0].dt_txt",
          "list[0].main.temp",
          "list[0].main.humidity",
          "list[0].weather[0].description",
          "list[0].wind.speed",
          "list[0].pop (precipitation probability 0-1)",
          "city.name",
          "city.country"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "air_quality",
      "description_for_ai": "Air quality index (AQI) and pollutant data for any coordinates. Use for 'air quality in Beijing', 'is it safe to jog outside', 'pollution level'.",
      "intent": [
        "air quality",
        "AQI",
        "pollution",
        "smog",
        "safe to exercise outside"
      ],
      "endpoint": "GET https://api.openweathermap.org/data/2.5/air_pollution",
      "input": {
        "lat": {
          "type": "float",
          "required": true,
          "description": "Latitude coordinate (decimal degrees, -90 to 90)"
        },
        "lon": {
          "type": "float",
          "required": true,
          "description": "Longitude coordinate (decimal degrees, -180 to 180)"
        }
      },
      "output": {
        "type": "air_quality",
        "fields": [
          "list[0].main.aqi",
          "list[0].components.pm2_5",
          "list[0].components.pm10",
          "list[0].components.no2",
          "list[0].components.o3"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "geo_flow": "Always prefer lat/lon over city name for accuracy. City names can be ambiguous ('Springfield' exists in 34 US states).",
    "units_tip": "Use metric for most countries (Celsius). Use imperial only if user explicitly mentions Fahrenheit.",
    "aqi_scale": "AQI: 1=Good, 2=Fair, 3=Moderate, 4=Poor, 5=Very Poor.",
    "pop_field": "In forecast, 'pop' = probability of precipitation (0.0 to 1.0). Multiply by 100 for percentage."
  },
  "limits": {
    "free_calls_per_day": 1000,
    "commercial_use": true,
    "attribution_required": true,
    "attribution_text": "Powered by OpenWeatherMap"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}