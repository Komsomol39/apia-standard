{
  "apia": "1.0",
  "service": {
    "id": "openweathermap",
    "name": "OpenWeatherMap",
    "description_for_ai": "World's most popular weather API. Use for current weather, forecasts and historical data for any city or coordinates. Returns temperature, humidity, wind, pressure, precipitation, sunrise/sunset. Free tier: 1000 calls/day. Used by 5M+ developers worldwide.",
    "url": "https://openweathermap.org",
    "api_base": "https://api.openweathermap.org/data/2.5",
    "category": "environment",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://openweathermap.org/api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "appid",
    "param_location": "query",
    "how_to_get": "Register at https://openweathermap.org/api — free tier available instantly",
    "cost": "Free: 1000 calls/day. Paid plans from $40/month"
  },
  "capabilities": [
    {
      "id": "current_weather",
      "description_for_ai": "Get current weather conditions for a city or coordinates.",
      "intent": [
        "current weather",
        "weather now",
        "what is weather",
        "погода сейчас",
        "температура"
      ],
      "endpoint": "GET https://api.openweathermap.org/data/2.5/weather",
      "input": {
        "q": {
          "type": "string",
          "description": "City name: London, Moscow, New York,US",
          "required": false
        },
        "lat": {
          "type": "float",
          "description": "Latitude (use with lon instead of q)",
          "required": false
        },
        "lon": {
          "type": "float",
          "required": false
        },
        "units": {
          "type": "string",
          "description": "metric (°C), imperial (°F), standard (K)",
          "default": "metric"
        },
        "lang": {
          "type": "string",
          "description": "Language: en, ru, de, fr, es",
          "default": "en"
        }
      },
      "output": {
        "type": "weather",
        "fields": [
          "main.temp",
          "main.feels_like",
          "main.humidity",
          "weather[0].description",
          "wind.speed",
          "visibility",
          "name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "forecast_5day",
      "description_for_ai": "5-day weather forecast in 3-hour intervals.",
      "intent": [
        "weather forecast",
        "5 day forecast",
        "weather prediction",
        "прогноз погоды на 5 дней"
      ],
      "endpoint": "GET https://api.openweathermap.org/data/2.5/forecast",
      "input": {
        "q": {
          "type": "string",
          "required": false
        },
        "lat": {
          "type": "float",
          "required": false
        },
        "lon": {
          "type": "float",
          "required": false
        },
        "units": {
          "type": "string",
          "default": "metric"
        },
        "cnt": {
          "type": "integer",
          "description": "Number of 3h intervals (max 40)",
          "required": false
        },
        "lang": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "forecast",
        "fields": [
          "list[0].dt_txt",
          "list[0].main.temp",
          "list[0].weather[0].description",
          "list[0].pop (rain probability)",
          "list[0].wind.speed"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "air_quality",
      "description_for_ai": "Get air quality index (AQI) and pollutant levels for coordinates.",
      "intent": [
        "air quality",
        "AQI",
        "pollution level",
        "качество воздуха",
        "загрязнение воздуха"
      ],
      "endpoint": "GET https://api.openweathermap.org/data/2.5/air_pollution",
      "input": {
        "lat": {
          "type": "float",
          "required": true
        },
        "lon": {
          "type": "float",
          "required": true
        }
      },
      "output": {
        "type": "air_quality",
        "fields": [
          "list[0].main.aqi (1-5 scale)",
          "list[0].components.pm2_5",
          "list[0].components.pm10",
          "list[0].components.no2",
          "list[0].components.o3"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "geocoding",
      "description_for_ai": "Convert city name to coordinates or reverse geocode coordinates to location name.",
      "intent": [
        "city coordinates",
        "geocode city",
        "location coordinates",
        "координаты города"
      ],
      "endpoint": "GET https://api.openweathermap.org/geo/1.0/direct",
      "input": {
        "q": {
          "type": "string",
          "description": "City name, state code, country code: London,GB or Moscow,RU",
          "required": true
        },
        "limit": {
          "type": "integer",
          "description": "Max results 1-5",
          "default": 5
        }
      },
      "output": {
        "type": "list<location>",
        "fields": [
          "[0].name",
          "[0].lat",
          "[0].lon",
          "[0].country",
          "[0].state"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "historical_weather",
      "description_for_ai": "Get historical weather data for a specific date (paid plan required).",
      "intent": [
        "historical weather",
        "past weather",
        "weather history",
        "историческая погода"
      ],
      "endpoint": "GET https://api.openweathermap.org/data/3.0/onecall/timemachine",
      "input": {
        "lat": {
          "type": "float",
          "required": true
        },
        "lon": {
          "type": "float",
          "required": true
        },
        "dt": {
          "type": "integer",
          "description": "Unix timestamp for the historical date",
          "required": true
        },
        "units": {
          "type": "string",
          "default": "metric"
        }
      },
      "output": {
        "type": "historical",
        "fields": [
          "data[0].temp",
          "data[0].weather[0].description",
          "data[0].wind_speed",
          "data[0].humidity"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "onecall_forecast",
      "description_for_ai": "All-in-one forecast: current, hourly (48h), daily (8 days), and alerts. One API call.",
      "intent": [
        "full forecast",
        "onecall weather",
        "8 day forecast",
        "полный прогноз погоды"
      ],
      "endpoint": "GET https://api.openweathermap.org/data/3.0/onecall",
      "input": {
        "lat": {
          "type": "float",
          "required": true
        },
        "lon": {
          "type": "float",
          "required": true
        },
        "exclude": {
          "type": "string",
          "description": "current,minutely,hourly,daily,alerts — omit to exclude",
          "required": false
        },
        "units": {
          "type": "string",
          "default": "metric"
        },
        "lang": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "forecast",
        "fields": [
          "current.temp",
          "current.weather[0].description",
          "hourly[0].temp",
          "daily[0].temp.day",
          "daily[0].summary",
          "alerts[0].event"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "geo_flow": "Always prefer lat/lon over city name for accuracy. City names can be ambiguous ('Springfield' exists in 34 US states).",
    "units_tip": "Use metric for most countries (Celsius). Use imperial only if user explicitly mentions Fahrenheit.",
    "aqi_scale": "AQI: 1=Good, 2=Fair, 3=Moderate, 4=Poor, 5=Very Poor.",
    "pop_field": "In forecast, 'pop' = probability of precipitation (0.0 to 1.0). Multiply by 100 for percentage."
  },
  "limits": {
    "free_calls_per_day": 1000,
    "commercial_use": true,
    "attribution_required": true,
    "attribution_text": "Powered by OpenWeatherMap"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}