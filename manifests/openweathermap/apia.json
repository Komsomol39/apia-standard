{
  "apia": "1.0",
  "service": {
    "id": "openweathermap",
    "name": "OpenWeatherMap",
    "description_for_ai": "World's most popular weather API. Use for current weather, forecasts and historical data for any city or coordinates. Returns temperature, humidity, wind, pressure, precipitation, sunrise/sunset. Free tier: 1000 calls/day. Used by 5M+ developers worldwide.",
    "url": "https://openweathermap.org",
    "api_base": "https://api.openweathermap.org/data/2.5",
    "category": "environment",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://openweathermap.org/api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "appid",
    "param_location": "query",
    "how_to_get": "Register at https://openweathermap.org/api — free tier available instantly",
    "cost": "Free: 1000 calls/day. Paid plans from $40/month"
  },
  "capabilities": [
    {
      "id": "current_weather",
      "description_for_ai": "Get current weather conditions for any city or coordinates: temperature, humidity, wind, description.",
      "intent": [
        "current weather",
        "weather now",
        "temperature today",
        "погода сейчас",
        "какая погода"
      ],
      "endpoint": "GET https://api.openweathermap.org/data/2.5/weather",
      "input": {
        "q": {
          "type": "string",
          "description": "City name e.g. Moscow,ru or London,uk",
          "required": false
        },
        "lat": {
          "type": "float",
          "required": false
        },
        "lon": {
          "type": "float",
          "required": false
        },
        "units": {
          "type": "string",
          "description": "standard (Kelvin), metric (Celsius), imperial (Fahrenheit)",
          "default": "metric"
        },
        "lang": {
          "type": "string",
          "description": "Language: en, ru, de, fr, etc.",
          "default": "en"
        },
        "appid": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "weather",
        "fields": [
          "main.temp",
          "main.feels_like",
          "main.humidity",
          "weather[0].description",
          "wind.speed",
          "name",
          "dt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "forecast_5day",
      "description_for_ai": "Get 5-day weather forecast in 3-hour intervals for any city.",
      "intent": [
        "weather forecast",
        "5 day forecast",
        "weather next week",
        "прогноз погоды",
        "погода на неделю"
      ],
      "endpoint": "GET https://api.openweathermap.org/data/2.5/forecast",
      "input": {
        "q": {
          "type": "string",
          "required": false
        },
        "lat": {
          "type": "float",
          "required": false
        },
        "lon": {
          "type": "float",
          "required": false
        },
        "units": {
          "type": "string",
          "default": "metric"
        },
        "cnt": {
          "type": "integer",
          "description": "Number of 3-hour periods, max 40",
          "required": false
        },
        "appid": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "forecast",
        "fields": [
          "list[0].dt_txt",
          "list[0].main.temp",
          "list[0].weather[0].description",
          "list[0].pop (precipitation probability)",
          "city.name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "air_pollution",
      "description_for_ai": "Get current or forecast air quality index (AQI) and pollutant concentrations: CO, NO2, PM2.5, PM10, O3.",
      "intent": [
        "air quality",
        "air pollution",
        "AQI",
        "качество воздуха",
        "загрязнение воздуха"
      ],
      "endpoint": "GET https://api.openweathermap.org/data/2.5/air_pollution",
      "input": {
        "lat": {
          "type": "float",
          "required": true
        },
        "lon": {
          "type": "float",
          "required": true
        },
        "appid": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "air_quality",
        "fields": [
          "list[0].main.aqi (1=Good, 2=Fair, 3=Moderate, 4=Poor, 5=Very Poor)",
          "list[0].components.pm2_5",
          "list[0].components.pm10",
          "list[0].components.no2",
          "list[0].components.co"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "geocoding",
      "description_for_ai": "Convert city name to coordinates or reverse geocode coordinates to city name.",
      "intent": [
        "geocode weather",
        "city coordinates",
        "city to lat lon",
        "координаты города"
      ],
      "endpoint": "GET https://api.openweathermap.org/geo/1.0/direct",
      "input": {
        "q": {
          "type": "string",
          "description": "City name, state, country e.g. London,GB or Moscow,RU",
          "required": true
        },
        "limit": {
          "type": "integer",
          "description": "Max results 1-5",
          "default": 5
        },
        "appid": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<location>",
        "fields": [
          "[0].name",
          "[0].lat",
          "[0].lon",
          "[0].country",
          "[0].state"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "geo_flow": "Always prefer lat/lon over city name for accuracy. City names can be ambiguous ('Springfield' exists in 34 US states).",
    "units_tip": "Use metric for most countries (Celsius). Use imperial only if user explicitly mentions Fahrenheit.",
    "aqi_scale": "AQI: 1=Good, 2=Fair, 3=Moderate, 4=Poor, 5=Very Poor.",
    "pop_field": "In forecast, 'pop' = probability of precipitation (0.0 to 1.0). Multiply by 100 for percentage."
  },
  "limits": {
    "free_calls_per_day": 1000,
    "commercial_use": true,
    "attribution_required": true,
    "attribution_text": "Powered by OpenWeatherMap"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}