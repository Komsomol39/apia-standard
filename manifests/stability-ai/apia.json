{
  "apia": "1.0",
  "service": {
    "id": "stability-ai",
    "name": "Stability AI API",
    "description_for_ai": "Stability AI API — image generation using Stable Diffusion models. Stable Image Core, Ultra, SD3. Industry-leading open-weight models for photorealistic and artistic images. Credit-based pricing: $0.003-0.08 per image. Best for: product mockups, art generation, controlled image creation.",
    "url": "https://stability.ai",
    "api_base": "https://api.stability.ai",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.stability.ai/docs/api-reference"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Bearer sk-...",
    "how_to_get": "Register at https://platform.stability.ai",
    "cost": "Credits-based. $0.003-0.08 per image"
  },
  "capabilities": [
    {
      "id": "generate_image_core",
      "description_for_ai": "Generate images with Stable Image Core — fastest Stability AI model. Great for concepts and prototypes.",
      "intent": [
        "Stability AI image",
        "stable diffusion API",
        "image generation",
        "генерация изображений Stability AI"
      ],
      "endpoint": "POST https://api.stability.ai/v2beta/stable-image/generate/core",
      "input": {
        "prompt": {
          "type": "string",
          "description": "Image generation prompt. Be detailed: subject, style, lighting, composition.",
          "required": true
        },
        "negative_prompt": {
          "type": "string",
          "description": "Elements to exclude: 'blurry, low quality, ugly'",
          "required": false
        },
        "aspect_ratio": {
          "type": "string",
          "description": "16:9, 1:1, 21:9, 2:3, 3:2, 4:5, 5:4, 9:16, 9:21",
          "default": "1:1"
        },
        "output_format": {
          "type": "string",
          "description": "jpeg, png, webp",
          "default": "jpeg"
        },
        "seed": {
          "type": "integer",
          "description": "0 for random, or specific seed for reproducibility",
          "default": 0
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "image (base64 or binary)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "generate_image_ultra",
      "description_for_ai": "Generate photorealistic images with Stable Image Ultra — highest quality Stability AI model.",
      "intent": [
        "photorealistic AI",
        "high quality image generation",
        "Stable Image Ultra",
        "фотореалистичные изображения AI"
      ],
      "endpoint": "POST https://api.stability.ai/v2beta/stable-image/generate/ultra",
      "input": {
        "prompt": {
          "type": "string",
          "required": true
        },
        "negative_prompt": {
          "type": "string",
          "required": false
        },
        "aspect_ratio": {
          "type": "string",
          "default": "1:1"
        },
        "output_format": {
          "type": "string",
          "default": "png"
        },
        "seed": {
          "type": "integer",
          "default": 0
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "image binary"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "remove_background",
      "description_for_ai": "Remove background from images with one-click AI precision.",
      "intent": [
        "remove background",
        "background removal",
        "cut out object",
        "удаление фона AI"
      ],
      "endpoint": "POST https://api.stability.ai/v2beta/stable-image/edit/remove-background",
      "input": {
        "image": {
          "type": "file",
          "description": "Source image (JPEG, PNG, WEBP, max 50MP, max 10MB)",
          "required": true
        },
        "output_format": {
          "type": "string",
          "description": "webp (transparent), png (transparent), jpeg",
          "default": "png"
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "image binary (PNG with alpha channel)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "upscale_image",
      "description_for_ai": "Upscale and enhance images up to 4x resolution with AI. Fast or creative mode.",
      "intent": [
        "upscale image",
        "increase resolution AI",
        "enhance image",
        "увеличить разрешение изображения AI"
      ],
      "endpoint": "POST https://api.stability.ai/v2beta/stable-image/upscale/conservative",
      "input": {
        "image": {
          "type": "file",
          "description": "Source image to upscale",
          "required": true
        },
        "prompt": {
          "type": "string",
          "description": "Guide enhancement with text prompt",
          "required": false
        },
        "output_format": {
          "type": "string",
          "default": "png"
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "image binary (upscaled)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "inpaint",
      "description_for_ai": "Edit specific areas of an image using a mask. Paint over unwanted objects or add new elements.",
      "intent": [
        "inpaint image",
        "edit image region",
        "remove object AI",
        "редактирование области изображения"
      ],
      "endpoint": "POST https://api.stability.ai/v2beta/stable-image/edit/inpaint",
      "input": {
        "image": {
          "type": "file",
          "description": "Source image",
          "required": true
        },
        "prompt": {
          "type": "string",
          "description": "What to generate in the masked area",
          "required": true
        },
        "mask": {
          "type": "file",
          "description": "Grayscale mask — white=edit, black=keep",
          "required": false
        },
        "output_format": {
          "type": "string",
          "default": "png"
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "image binary"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "image_to_video",
      "description_for_ai": "Animate a still image into a short video (2-4s) with Stable Video Diffusion.",
      "intent": [
        "image to video",
        "animate image AI",
        "video generation Stability",
        "анимация изображения AI"
      ],
      "endpoint": "POST https://api.stability.ai/v2beta/image-to-video",
      "input": {
        "image": {
          "type": "file",
          "description": "Source image (768x768 or 1024x576 for 16:9)",
          "required": true
        },
        "seed": {
          "type": "integer",
          "default": 0
        },
        "cfg_scale": {
          "type": "float",
          "description": "How closely to follow the image 0-10",
          "default": 1.8
        },
        "motion_bucket_id": {
          "type": "integer",
          "description": "Motion amount 1-255, higher=more motion",
          "default": 127
        }
      },
      "output": {
        "type": "video",
        "fields": [
          "id (generation ID)",
          "video binary after polling"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "model_tip": "Use core for fast cheap images, ultra for highest quality, sd3 for photorealism."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}