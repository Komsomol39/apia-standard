{
  "apia": "1.0",
  "service": {
    "id": "stability-ai",
    "name": "Stability AI API",
    "description_for_ai": "Stability AI API — image generation using Stable Diffusion models. Stable Image Core, Ultra, SD3. Industry-leading open-weight models for photorealistic and artistic images. Credit-based pricing: $0.003-0.08 per image. Best for: product mockups, art generation, controlled image creation.",
    "url": "https://stability.ai",
    "api_base": "https://api.stability.ai",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.stability.ai/docs/api-reference"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Bearer sk-...",
    "how_to_get": "Register at https://platform.stability.ai",
    "cost": "Credits-based. $0.003-0.08 per image"
  },
  "capabilities": [
    {
      "id": "generate_image",
      "description_for_ai": "Generate images with Stable Image Core or SD3. Text-to-image with style presets.",
      "intent": [
        "stable diffusion",
        "image generation stability",
        "SD3 generate",
        "генерация stability AI"
      ],
      "endpoint": "POST https://api.stability.ai/v2beta/stable-image/generate/core",
      "input": {
        "prompt": {
          "type": "string",
          "description": "Image description",
          "required": true
        },
        "negative_prompt": {
          "type": "string",
          "description": "Things to avoid in image",
          "required": false
        },
        "style_preset": {
          "type": "string",
          "description": "3d-model, analog-film, anime, cinematic, comic-book, digital-art, enhance, fantasy-art, isometric, line-art, low-poly, modeling-compound, neon-punk, origami, photographic, pixel-art, tile-texture",
          "required": false
        },
        "output_format": {
          "type": "string",
          "description": "webp, jpeg, png",
          "default": "webp"
        },
        "aspect_ratio": {
          "type": "string",
          "description": "16:9, 1:1, 21:9, 2:3, 3:2, 4:5, 5:4, 9:16, 9:21",
          "default": "1:1"
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "image (base64)",
          "finish_reason",
          "seed"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "upscale_image",
      "description_for_ai": "Upscale image 4x with AI. Adds detail and sharpness. Conservative mode for photography, creative for artistic upscaling.",
      "intent": [
        "upscale image",
        "increase resolution",
        "4x upscale",
        "image enhancement",
        "увеличить разрешение stability"
      ],
      "endpoint": "POST https://api.stability.ai/v2beta/stable-image/upscale/conservative",
      "input": {
        "image": {
          "type": "file",
          "description": "Image to upscale (PNG/JPEG/WEBP)",
          "required": true
        },
        "prompt": {
          "type": "string",
          "description": "Description to guide upscaling detail generation",
          "required": true
        },
        "negative_prompt": {
          "type": "string",
          "required": false
        },
        "creativity": {
          "type": "float",
          "description": "0-1 creative vs conservative upscaling",
          "default": 0.3
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "image (base64)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "remove_background",
      "description_for_ai": "Automatically remove image background. Returns PNG with transparent background.",
      "intent": [
        "remove background",
        "transparent background",
        "cut out background",
        "background removal",
        "убрать фон stability"
      ],
      "endpoint": "POST https://api.stability.ai/v2beta/stable-image/edit/remove-background",
      "input": {
        "image": {
          "type": "file",
          "description": "Image with background to remove (PNG/JPEG/WEBP)",
          "required": true
        },
        "output_format": {
          "type": "string",
          "description": "png (preserves transparency) or webp",
          "default": "png"
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "image (base64 PNG with transparency)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "image_to_image",
      "description_for_ai": "Edit an existing image guided by a text prompt. Change style, add elements, modify content.",
      "intent": [
        "edit image stability",
        "image to image",
        "image editing AI",
        "редактировать изображение stability"
      ],
      "endpoint": "POST https://api.stability.ai/v2beta/stable-image/edit/inpaint",
      "input": {
        "image": {
          "type": "file",
          "description": "Original image",
          "required": true
        },
        "prompt": {
          "type": "string",
          "required": true
        },
        "mask": {
          "type": "file",
          "description": "Mask image (white=edit area, black=keep). If omitted, auto-generates mask.",
          "required": false
        },
        "negative_prompt": {
          "type": "string",
          "required": false
        },
        "output_format": {
          "type": "string",
          "default": "webp"
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "image (base64)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "model_tip": "Use core for fast cheap images, ultra for highest quality, sd3 for photorealism."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}