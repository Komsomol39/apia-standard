{
  "apia": "1.0",
  "service": {
    "id": "carbon-interface",
    "name": "Carbon Interface API",
    "description_for_ai": "Calculate carbon emissions for flights, driving, shipping, electricity. Returns CO2 equivalent in grams/kg. Use for carbon footprint calculators, sustainability apps, ESG reporting.",
    "url": "https://carboninterface.com",
    "api_base": "https://www.carboninterface.com/api/v1",
    "category": "environment",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.carboninterface.com"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "Register at https://www.carboninterface.com/users/sign_up — free tier",
    "cost": "Free: 100 estimates/month. Paid from $50/month"
  },
  "capabilities": [
    {
      "id": "flight_estimate",
      "description_for_ai": "Calculate CO2 equivalent emissions for a flight between airports. Returns carbon per passenger in kg and metric tons.",
      "intent": [
        "flight carbon",
        "carbon footprint flight",
        "CO2 emissions",
        "environmental impact flight",
        "carbon calculator",
        "углеродный след полёта"
      ],
      "endpoint": "POST https://www.carboninterface.com/api/v1/estimates",
      "input": {
        "type": {
          "type": "string",
          "description": "Estimate type — always 'flight' for this capability",
          "default": "flight"
        },
        "passengers": {
          "type": "integer",
          "description": "Number of passengers to calculate emissions for",
          "default": 1
        },
        "legs": {
          "type": "array",
          "description": "Flight route legs: [{departure_airport: 'SVO', destination_airport: 'JFK'}, ...]. Supports multi-leg trips.",
          "required": true
        },
        "cabin_class": {
          "type": "string",
          "description": "economy (default, ~2.5x), premium_economy (~3x), business (~5x), first (~7x) multiplier vs economy",
          "default": "economy"
        }
      },
      "output": {
        "type": "estimate",
        "fields": [
          "data.id",
          "data.type",
          "data.attributes.passengers",
          "data.attributes.legs",
          "data.attributes.distance_value",
          "data.attributes.distance_unit",
          "data.attributes.carbon_g",
          "data.attributes.carbon_lb",
          "data.attributes.carbon_kg",
          "data.attributes.carbon_mt"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "vehicle_estimate",
      "description_for_ai": "Calculate CO2 emissions for driving a specific vehicle model over a given distance.",
      "intent": [
        "driving carbon",
        "car emissions",
        "CO2 driving",
        "vehicle footprint"
      ],
      "endpoint": "POST https://www.carboninterface.com/api/v1/estimates",
      "input": {
        "type": {
          "type": "string",
          "description": "Estimate type — always 'vehicle'",
          "default": "vehicle"
        },
        "distance_unit": {
          "type": "string",
          "description": "km or mi",
          "required": true
        },
        "distance_value": {
          "type": "number",
          "description": "Distance driven e.g. 100 (km or miles)",
          "required": true
        },
        "vehicle_model_id": {
          "type": "string",
          "description": "Vehicle model ID from GET /vehicle_makes/{id}/vehicle_models. Get make IDs from /vehicle_makes.",
          "required": true
        }
      },
      "output": {
        "type": "estimate",
        "fields": [
          "data.attributes.carbon_g",
          "data.attributes.carbon_kg",
          "data.attributes.carbon_mt",
          "data.attributes.distance_value",
          "data.attributes.vehicle_make",
          "data.attributes.vehicle_model"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}