{
  "apia": "1.0",
  "service": {
    "id": "airtable",
    "name": "Airtable API",
    "description_for_ai": "Flexible database-spreadsheet hybrid. Tables, records, views, formulas, attachments. 300K+ companies use it. Use for data management, project tracking, CRM-lite, content calendars, inventory.",
    "url": "https://airtable.com",
    "api_base": "https://api.airtable.com/v0",
    "category": "productivity",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://airtable.com/developers/web/api/introduction"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer pat...",
    "how_to_get": "Create token at https://airtable.com/create/tokens",
    "cost": "Free: unlimited bases, 1000 records/base. Team: $20/month"
  },
  "capabilities": [
    {
      "id": "list_records",
      "description_for_ai": "List records from an Airtable table with filters, sort, and field selection.",
      "intent": [
        "airtable records",
        "get data airtable",
        "list rows",
        "данные airtable"
      ],
      "endpoint": "GET https://api.airtable.com/v0/{baseId}/{tableId}",
      "input": {
        "baseId": {
          "type": "string",
          "required": true
        },
        "tableId": {
          "type": "string",
          "description": "Table ID or name",
          "required": true
        },
        "filterByFormula": {
          "type": "string",
          "description": "Airtable formula: {Status}='Done', AND({Priority}='High',NOT({Done}))",
          "required": false
        },
        "sort": {
          "type": "array",
          "description": "[{field: 'Created', direction: 'desc'}]",
          "required": false
        },
        "fields": {
          "type": "array",
          "description": "Field names to return. Omit for all.",
          "required": false
        },
        "maxRecords": {
          "type": "integer",
          "required": false
        },
        "pageSize": {
          "type": "integer",
          "default": 100
        }
      },
      "output": {
        "type": "list<record>",
        "fields": [
          "records[0].id",
          "records[0].fields",
          "offset (for next page)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_record",
      "description_for_ai": "Create one or multiple records in an Airtable table.",
      "intent": [
        "create airtable record",
        "add row airtable",
        "new entry airtable",
        "добавить запись airtable"
      ],
      "endpoint": "POST https://api.airtable.com/v0/{baseId}/{tableId}",
      "input": {
        "baseId": {
          "type": "string",
          "required": true
        },
        "tableId": {
          "type": "string",
          "required": true
        },
        "records": {
          "type": "array",
          "description": "[{fields: {Name: 'Task', Status: 'Todo', Priority: 'High'}}]",
          "required": true
        },
        "typecast": {
          "type": "boolean",
          "description": "Auto-convert values to field types",
          "default": false
        }
      },
      "output": {
        "type": "list<record>",
        "fields": [
          "records[0].id",
          "records[0].fields",
          "records[0].createdTime"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_record",
      "description_for_ai": "Update specific fields of existing Airtable records by ID.",
      "intent": [
        "update airtable",
        "edit record airtable",
        "patch airtable",
        "обновить airtable"
      ],
      "endpoint": "PATCH https://api.airtable.com/v0/{baseId}/{tableId}",
      "input": {
        "baseId": {
          "type": "string",
          "required": true
        },
        "tableId": {
          "type": "string",
          "required": true
        },
        "records": {
          "type": "array",
          "description": "[{id: 'recXXXX', fields: {Status: 'Done'}}]",
          "required": true
        }
      },
      "output": {
        "type": "list<record>",
        "fields": [
          "records[0].id",
          "records[0].fields"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "delete_record",
      "description_for_ai": "Delete one or multiple Airtable records by ID.",
      "intent": [
        "delete airtable record",
        "remove row airtable",
        "удалить запись airtable"
      ],
      "endpoint": "DELETE https://api.airtable.com/v0/{baseId}/{tableId}",
      "input": {
        "baseId": {
          "type": "string",
          "required": true
        },
        "tableId": {
          "type": "string",
          "required": true
        },
        "records": {
          "type": "array",
          "description": "['recXXXX', 'recYYYY'] — up to 10 IDs",
          "required": true
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "records[0].id",
          "records[0].deleted"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "base_id": "Get base ID from Airtable URL: airtable.com/{BASE_ID}/..., looks like 'appXXXXXXXXXXXXXX'",
    "token": "Create token at airtable.com/create/tokens. Scope: data.records:read, data.records:write",
    "formula": "filterByFormula supports Airtable formula syntax: {Status}='Active', AND({Price}>100, {Stock}>0)",
    "pagination": "Use offset token from response for next page. Max 100 records per request."
  }
}