{
  "apia": "1.0",
  "service": {
    "id": "airtable",
    "name": "Airtable API",
    "description_for_ai": "Flexible database-spreadsheet hybrid. Tables, records, views, formulas, attachments. 300K+ companies use it. Use for data management, project tracking, CRM-lite, content calendars, inventory.",
    "url": "https://airtable.com",
    "api_base": "https://api.airtable.com/v0",
    "category": "productivity",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://airtable.com/developers/web/api/introduction"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer pat...",
    "how_to_get": "Create token at https://airtable.com/create/tokens",
    "cost": "Free: unlimited bases, 1000 records/base. Team: $20/month"
  },
  "capabilities": [
    {
      "id": "list_records",
      "description_for_ai": "Get records from an Airtable table. Filter, sort, and paginate.",
      "intent": [
        "Airtable records",
        "get data Airtable",
        "list rows Airtable",
        "данные Airtable"
      ],
      "endpoint": "GET https://api.airtable.com/v0/{baseId}/{tableIdOrName}",
      "input": {
        "baseId": {
          "type": "string",
          "description": "Base ID (starts with 'app')",
          "required": true
        },
        "tableIdOrName": {
          "type": "string",
          "required": true
        },
        "filterByFormula": {
          "type": "string",
          "description": "Airtable formula e.g. {Status}='Active', SEARCH('keyword', {Name})",
          "required": false
        },
        "sort": {
          "type": "array",
          "description": "[{field: 'Name', direction: 'asc'}]",
          "required": false
        },
        "fields": {
          "type": "array",
          "description": "Return only these field names",
          "required": false
        },
        "maxRecords": {
          "type": "integer",
          "default": 100
        }
      },
      "output": {
        "type": "list<record>",
        "fields": [
          "records[0].id",
          "records[0].fields.{fieldname}",
          "records[0].createdTime"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_records",
      "description_for_ai": "Create one or multiple records in an Airtable table.",
      "intent": [
        "create Airtable record",
        "add row Airtable",
        "insert Airtable",
        "добавить запись Airtable"
      ],
      "endpoint": "POST https://api.airtable.com/v0/{baseId}/{tableIdOrName}",
      "input": {
        "baseId": {
          "type": "string",
          "required": true
        },
        "tableIdOrName": {
          "type": "string",
          "required": true
        },
        "records": {
          "type": "array",
          "description": "[{fields: {Name: 'Value', Status: 'Active', Date: '2024-01-15'}}]",
          "required": true
        }
      },
      "output": {
        "type": "list<record>",
        "fields": [
          "records[0].id",
          "records[0].fields"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_records",
      "description_for_ai": "Update specific fields of existing Airtable records.",
      "intent": [
        "update Airtable",
        "edit record Airtable",
        "modify row",
        "обновить Airtable"
      ],
      "endpoint": "PATCH https://api.airtable.com/v0/{baseId}/{tableIdOrName}",
      "input": {
        "baseId": {
          "type": "string",
          "required": true
        },
        "tableIdOrName": {
          "type": "string",
          "required": true
        },
        "records": {
          "type": "array",
          "description": "[{id: 'rec...', fields: {Status: 'Done'}}]",
          "required": true
        }
      },
      "output": {
        "type": "list<record>",
        "fields": [
          "records[0].id",
          "records[0].fields"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "delete_records",
      "description_for_ai": "Delete records from Airtable by record ID.",
      "intent": [
        "delete Airtable record",
        "remove row Airtable",
        "удалить запись Airtable"
      ],
      "endpoint": "DELETE https://api.airtable.com/v0/{baseId}/{tableIdOrName}",
      "input": {
        "baseId": {
          "type": "string",
          "required": true
        },
        "tableIdOrName": {
          "type": "string",
          "required": true
        },
        "records": {
          "type": "array",
          "description": "Record IDs: ['rec1', 'rec2'] (max 10 at once)",
          "required": true
        }
      },
      "output": {
        "type": "delete",
        "fields": [
          "records[0].id",
          "records[0].deleted"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_bases",
      "description_for_ai": "List all Airtable bases (databases) the user has access to.",
      "intent": [
        "Airtable bases",
        "list databases Airtable",
        "my Airtable",
        "базы Airtable"
      ],
      "endpoint": "GET https://api.airtable.com/v0/meta/bases",
      "input": {
        "offset": {
          "type": "string",
          "description": "Pagination offset",
          "required": false
        }
      },
      "output": {
        "type": "list<base>",
        "fields": [
          "bases[0].id",
          "bases[0].name",
          "bases[0].permissionLevel"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_base_schema",
      "description_for_ai": "Get the schema (tables and fields) for an Airtable base.",
      "intent": [
        "Airtable schema",
        "table structure",
        "field types Airtable",
        "схема Airtable"
      ],
      "endpoint": "GET https://api.airtable.com/v0/meta/bases/{baseId}/tables",
      "input": {
        "baseId": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "schema",
        "fields": [
          "tables[0].id",
          "tables[0].name",
          "tables[0].fields[0].name",
          "tables[0].fields[0].type"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "base_id": "Get base ID from Airtable URL: airtable.com/{BASE_ID}/..., looks like 'appXXXXXXXXXXXXXX'",
    "token": "Create token at airtable.com/create/tokens. Scope: data.records:read, data.records:write",
    "formula": "filterByFormula supports Airtable formula syntax: {Status}='Active', AND({Price}>100, {Stock}>0)",
    "pagination": "Use offset token from response for next page. Max 100 records per request."
  }
}