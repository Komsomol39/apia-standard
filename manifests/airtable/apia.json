{
  "apia": "1.0",
  "service": {
    "id": "airtable",
    "name": "Airtable API",
    "description_for_ai": "Flexible database-spreadsheet hybrid. Tables, records, views, formulas, attachments. 300K+ companies use it. Use for data management, project tracking, CRM-lite, content calendars, inventory.",
    "url": "https://airtable.com",
    "api_base": "https://api.airtable.com/v0",
    "category": "productivity",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://airtable.com/developers/web/api/introduction"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer pat...",
    "how_to_get": "Create token at https://airtable.com/create/tokens",
    "cost": "Free: unlimited bases, 1000 records/base. Team: $20/month"
  },
  "capabilities": [
    {
      "id": "list_records",
      "description_for_ai": "List records from an Airtable table with filters, sorts, and field selection.",
      "intent": [
        "airtable records",
        "get table data",
        "list rows airtable",
        "данные airtable"
      ],
      "endpoint": "GET https://api.airtable.com/v0/{baseId}/{tableName}",
      "input": {
        "baseId": {
          "type": "string",
          "required": true
        },
        "tableName": {
          "type": "string",
          "required": true
        },
        "filterByFormula": {
          "type": "string",
          "description": "Airtable formula e.g. AND({Status}='Done', {Priority}='High')",
          "required": false
        },
        "sort": {
          "type": "array",
          "description": "[{field: 'Name', direction: 'asc'}]",
          "required": false
        },
        "fields": {
          "type": "array",
          "description": "Field names to return",
          "required": false
        },
        "maxRecords": {
          "type": "integer",
          "required": false
        },
        "view": {
          "type": "string",
          "description": "View name to use",
          "required": false
        }
      },
      "output": {
        "type": "list<record>",
        "fields": [
          "records[0].id",
          "records[0].fields",
          "records[0].createdTime",
          "offset"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_records",
      "description_for_ai": "Create one or more records in an Airtable table (up to 10 per request).",
      "intent": [
        "create airtable record",
        "add row airtable",
        "insert record",
        "добавить запись airtable"
      ],
      "endpoint": "POST https://api.airtable.com/v0/{baseId}/{tableName}",
      "input": {
        "baseId": {
          "type": "string",
          "required": true
        },
        "tableName": {
          "type": "string",
          "required": true
        },
        "records": {
          "type": "array",
          "description": "[{fields: {Name: 'John', Status: 'Active', Score: 95}}]",
          "required": true
        }
      },
      "output": {
        "type": "list<record>",
        "fields": [
          "records[0].id",
          "records[0].fields",
          "records[0].createdTime"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_records",
      "description_for_ai": "Update fields of existing records by ID. Use PATCH to update only specified fields.",
      "intent": [
        "update airtable record",
        "edit row airtable",
        "change field airtable",
        "обновить запись airtable"
      ],
      "endpoint": "PATCH https://api.airtable.com/v0/{baseId}/{tableName}",
      "input": {
        "baseId": {
          "type": "string",
          "required": true
        },
        "tableName": {
          "type": "string",
          "required": true
        },
        "records": {
          "type": "array",
          "description": "[{id: 'recXXXXXXXX', fields: {Status: 'Done'}}]",
          "required": true
        }
      },
      "output": {
        "type": "list<record>",
        "fields": [
          "records[0].id",
          "records[0].fields"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "delete_records",
      "description_for_ai": "Delete records from an Airtable table by ID (up to 10 per request).",
      "intent": [
        "delete airtable record",
        "remove row airtable",
        "удалить запись airtable"
      ],
      "endpoint": "DELETE https://api.airtable.com/v0/{baseId}/{tableName}",
      "input": {
        "baseId": {
          "type": "string",
          "required": true
        },
        "tableName": {
          "type": "string",
          "required": true
        },
        "records": {
          "type": "array",
          "description": "['recXXX', 'recYYY'] — record IDs to delete",
          "required": true
        }
      },
      "output": {
        "type": "list<deleted>",
        "fields": [
          "records[0].id",
          "records[0].deleted"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "base_id": "Get base ID from Airtable URL: airtable.com/{BASE_ID}/..., looks like 'appXXXXXXXXXXXXXX'",
    "token": "Create token at airtable.com/create/tokens. Scope: data.records:read, data.records:write",
    "formula": "filterByFormula supports Airtable formula syntax: {Status}='Active', AND({Price}>100, {Stock}>0)",
    "pagination": "Use offset token from response for next page. Max 100 records per request."
  }
}