{
  "apia": "1.0",
  "service": {
    "id": "polygon-io",
    "name": "Polygon.io API",
    "description_for_ai": "Real-time and historical US stock market data. Stocks, options, forex, crypto. Tick-level data, aggregates, news, financials. Free: 5 req/min. Used by hedge funds and retail traders.",
    "url": "https://polygon.io",
    "api_base": "https://api.polygon.io",
    "category": "finance",
    "geo": [
      "US",
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://polygon.io/docs/stocks/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "apiKey",
    "param_location": "query",
    "how_to_get": "Register at https://polygon.io",
    "cost": "Free: 5 req/min, end-of-day data. Starter: $29/month real-time"
  },
  "capabilities": [
    {
      "id": "get_quote",
      "description_for_ai": "Get real-time stock snapshot: price, bid/ask, volume, VWAP, open/close.",
      "intent": [
        "polygon stock price",
        "real-time quote",
        "stock ticker polygon",
        "биржевая котировка polygon"
      ],
      "endpoint": "GET https://api.polygon.io/v2/snapshot/locale/us/markets/stocks/tickers/{stocksTicker}",
      "input": {
        "stocksTicker": {
          "type": "string",
          "description": "Stock ticker: AAPL, MSFT, TSLA",
          "required": true
        }
      },
      "output": {
        "type": "snapshot",
        "fields": [
          "ticker.day.c (close)",
          "ticker.day.o (open)",
          "ticker.day.v (volume)",
          "ticker.lastTrade.p (price)",
          "ticker.lastQuote.P (ask)",
          "ticker.prevDay.c"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_aggregates",
      "description_for_ai": "Get OHLCV bar data for any timeframe: minute, hour, day, week, month. Use for charting.",
      "intent": [
        "stock chart data",
        "OHLCV bars",
        "candlestick data",
        "price history polygon",
        "свечи polygon"
      ],
      "endpoint": "GET https://api.polygon.io/v2/aggs/ticker/{stocksTicker}/range/{multiplier}/{timespan}/{from}/{to}",
      "input": {
        "stocksTicker": {
          "type": "string",
          "required": true
        },
        "multiplier": {
          "type": "integer",
          "description": "Timespan multiplier e.g. 1 (for 1-day bars)",
          "required": true
        },
        "timespan": {
          "type": "string",
          "description": "minute, hour, day, week, month, quarter, year",
          "required": true
        },
        "from": {
          "type": "string",
          "description": "Start date YYYY-MM-DD",
          "required": true
        },
        "to": {
          "type": "string",
          "description": "End date YYYY-MM-DD",
          "required": true
        },
        "adjusted": {
          "type": "boolean",
          "description": "Adjust for splits and dividends",
          "default": true
        },
        "limit": {
          "type": "integer",
          "default": 120
        }
      },
      "output": {
        "type": "bars",
        "fields": [
          "results[0].t (timestamp ms)",
          "results[0].o (open)",
          "results[0].h (high)",
          "results[0].l (low)",
          "results[0].c (close)",
          "results[0].v (volume)",
          "results[0].vw (VWAP)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "search_tickers",
      "description_for_ai": "Search for stock tickers by company name. Find ticker symbols.",
      "intent": [
        "find ticker",
        "search stock",
        "company ticker",
        "найти акцию polygon"
      ],
      "endpoint": "GET https://api.polygon.io/v3/reference/tickers",
      "input": {
        "search": {
          "type": "string",
          "description": "Company name or ticker prefix",
          "required": false
        },
        "ticker": {
          "type": "string",
          "description": "Exact ticker symbol",
          "required": false
        },
        "market": {
          "type": "string",
          "description": "stocks, crypto, fx, otc",
          "required": false
        },
        "active": {
          "type": "boolean",
          "description": "Filter to only active tickers",
          "default": true
        },
        "limit": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<ticker>",
        "fields": [
          "results[0].ticker",
          "results[0].name",
          "results[0].market",
          "results[0].primary_exchange",
          "results[0].currency_name"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_ticker_details",
      "description_for_ai": "Get company details for a ticker: description, employees, revenue, SIC, address, website.",
      "intent": [
        "company info polygon",
        "stock details",
        "company description",
        "описание компании polygon"
      ],
      "endpoint": "GET https://api.polygon.io/v3/reference/tickers/{ticker}",
      "input": {
        "ticker": {
          "type": "string",
          "description": "Stock ticker symbol",
          "required": true
        },
        "date": {
          "type": "string",
          "description": "Historical details as of date YYYY-MM-DD",
          "required": false
        }
      },
      "output": {
        "type": "ticker_details",
        "fields": [
          "results.name",
          "results.description",
          "results.total_employees",
          "results.homepage_url",
          "results.address.address1",
          "results.sic_description",
          "results.market_cap"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}