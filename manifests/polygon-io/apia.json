{
  "apia": "1.0",
  "service": {
    "id": "polygon-io",
    "name": "Polygon.io API",
    "description_for_ai": "Real-time and historical US stock market data. Stocks, options, forex, crypto. Tick-level data, aggregates, news, financials. Free: 5 req/min. Used by hedge funds and retail traders.",
    "url": "https://polygon.io",
    "api_base": "https://api.polygon.io",
    "category": "finance",
    "geo": [
      "US",
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://polygon.io/docs/stocks/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "apiKey",
    "param_location": "query",
    "how_to_get": "Register at https://polygon.io",
    "cost": "Free: 5 req/min, end-of-day data. Starter: $29/month real-time"
  },
  "capabilities": [
    {
      "id": "get_ticker_details",
      "description_for_ai": "Get stock details: name, sector, description, market cap, employees, website.",
      "intent": [
        "stock info",
        "company details",
        "ticker info",
        "информация об акции"
      ],
      "endpoint": "GET https://api.polygon.io/v3/reference/tickers/{stocksTicker}",
      "input": {
        "stocksTicker": {
          "type": "string",
          "description": "Stock symbol: AAPL, TSLA, MSFT",
          "required": true
        }
      },
      "output": {
        "type": "ticker",
        "fields": [
          "results.ticker",
          "results.name",
          "results.description",
          "results.market_cap",
          "results.total_employees",
          "results.homepage_url",
          "results.sic_description"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_previous_close",
      "description_for_ai": "Get the previous day's open, high, low, close, volume for a stock.",
      "intent": [
        "stock price",
        "yesterday close",
        "OHLCV stock",
        "цена акции"
      ],
      "endpoint": "GET https://api.polygon.io/v2/aggs/ticker/{stocksTicker}/prev",
      "input": {
        "stocksTicker": {
          "type": "string",
          "required": true
        },
        "adjusted": {
          "type": "boolean",
          "description": "Adjust for splits",
          "default": true
        }
      },
      "output": {
        "type": "ohlcv",
        "fields": [
          "results[0].c (close)",
          "results[0].h (high)",
          "results[0].l (low)",
          "results[0].o (open)",
          "results[0].v (volume)",
          "results[0].vw (VWAP)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_aggregates",
      "description_for_ai": "Get historical price bars (OHLCV) for a stock. Aggregate by minute, hour, day, week, month.",
      "intent": [
        "stock history",
        "price chart",
        "historical data stock",
        "история цен акции"
      ],
      "endpoint": "GET https://api.polygon.io/v2/aggs/ticker/{stocksTicker}/range/{multiplier}/{timespan}/{from}/{to}",
      "input": {
        "stocksTicker": {
          "type": "string",
          "required": true
        },
        "multiplier": {
          "type": "integer",
          "description": "Size of timespan e.g. 1",
          "required": true
        },
        "timespan": {
          "type": "string",
          "description": "minute, hour, day, week, month, quarter, year",
          "required": true
        },
        "from": {
          "type": "string",
          "description": "Start date YYYY-MM-DD",
          "required": true
        },
        "to": {
          "type": "string",
          "description": "End date YYYY-MM-DD",
          "required": true
        },
        "adjusted": {
          "type": "boolean",
          "default": true
        },
        "limit": {
          "type": "integer",
          "default": 120
        }
      },
      "output": {
        "type": "list<bar>",
        "fields": [
          "results[0].t (timestamp)",
          "results[0].o",
          "results[0].h",
          "results[0].l",
          "results[0].c",
          "results[0].v"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_last_quote",
      "description_for_ai": "Get real-time bid/ask quote for a stock.",
      "intent": [
        "stock quote",
        "bid ask price",
        "real time stock",
        "котировка акции"
      ],
      "endpoint": "GET https://api.polygon.io/v2/last/nbbo/{stocksTicker}",
      "input": {
        "stocksTicker": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "quote",
        "fields": [
          "results.P (ask price)",
          "results.p (bid price)",
          "results.S (ask size)",
          "results.s (bid size)",
          "results.t (timestamp)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_tickers",
      "description_for_ai": "Search stocks, ETFs, and other securities by keyword.",
      "intent": [
        "search stock",
        "find ticker",
        "stock symbol lookup",
        "поиск акции"
      ],
      "endpoint": "GET https://api.polygon.io/v3/reference/tickers",
      "input": {
        "search": {
          "type": "string",
          "description": "Company name or symbol",
          "required": false
        },
        "type": {
          "type": "string",
          "description": "CS (stock), ETF, FUND, IND (index), FX, CRYPTO",
          "required": false
        },
        "market": {
          "type": "string",
          "description": "stocks, options, forex, crypto, otc",
          "required": false
        },
        "active": {
          "type": "boolean",
          "default": true
        },
        "limit": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<ticker>",
        "fields": [
          "results[0].ticker",
          "results[0].name",
          "results[0].type",
          "results[0].market",
          "results[0].primary_exchange"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_news",
      "description_for_ai": "Get financial news for a stock or general market news.",
      "intent": [
        "stock news",
        "company news",
        "market news",
        "новости акции"
      ],
      "endpoint": "GET https://api.polygon.io/v2/reference/news",
      "input": {
        "ticker": {
          "type": "string",
          "description": "Filter by ticker symbol",
          "required": false
        },
        "published_utc.gte": {
          "type": "string",
          "description": "Articles published after date: 2024-01-01",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<article>",
        "fields": [
          "results[0].title",
          "results[0].article_url",
          "results[0].publisher.name",
          "results[0].published_utc",
          "results[0].tickers",
          "results[0].description"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}