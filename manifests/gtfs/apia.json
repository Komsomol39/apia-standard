{
  "apia": "1.0",
  "service": {
    "id": "gtfs",
    "name": "GTFS / Transitland API",
    "description_for_ai": "Global public transit data standard and aggregator. GTFS feeds from 1000+ cities worldwide — bus, metro, tram, ferry schedules. Transitland aggregates feeds from all cities. Use for public transit routing, schedule display.",
    "url": "https://www.transit.land",
    "api_base": "https://transit.land/api/v2",
    "category": "transport",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.transit.land/documentation"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "Register at https://www.transit.land/documentation/rest-api",
    "cost": "Free tier available"
  },
  "capabilities": [
    {
      "id": "get_routes",
      "description_for_ai": "Get public transit routes (bus, metro, tram, rail) for an agency or geographic bounding box.",
      "intent": [
        "bus routes",
        "metro lines",
        "public transit",
        "bus schedule",
        "transit routes",
        "расписание автобуса"
      ],
      "endpoint": "GET https://transit.land/api/v2/rest/routes",
      "input": {
        "agency_key": {
          "type": "string",
          "description": "Transit agency key from Transitland e.g. 'f-dp3wjp-metro' for LA Metro. Search agencies at transit.land/agencies",
          "required": false
        },
        "bbox": {
          "type": "string",
          "description": "Geographic bounding box: min_lon,min_lat,max_lon,max_lat e.g. '-87.7,41.8,-87.6,41.9' for Chicago area",
          "required": false
        },
        "limit": {
          "type": "integer",
          "description": "Max routes per page",
          "default": 20
        },
        "after": {
          "type": "integer",
          "description": "Pagination cursor (ID) for next page",
          "required": false
        }
      },
      "output": {
        "type": "list<route>",
        "fields": [
          "routes[0].id",
          "routes[0].short_name",
          "routes[0].long_name",
          "routes[0].route_type (0=tram,1=metro,2=rail,3=bus)",
          "routes[0].agency.name",
          "routes[0].agency.onestop_id"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_stops",
      "description_for_ai": "Get transit stops (bus stops, metro stations, etc.) near a location or within a bounding box.",
      "intent": [
        "bus stop",
        "transit stop",
        "metro station",
        "nearest stop"
      ],
      "endpoint": "GET https://transit.land/api/v2/rest/stops",
      "input": {
        "lon": {
          "type": "float",
          "description": "Center longitude for proximity search",
          "required": false
        },
        "lat": {
          "type": "float",
          "description": "Center latitude for proximity search",
          "required": false
        },
        "radius": {
          "type": "integer",
          "description": "Search radius in meters from lon,lat point",
          "default": 500
        },
        "bbox": {
          "type": "string",
          "description": "Alternative to lon/lat/radius: min_lon,min_lat,max_lon,max_lat bounding box",
          "required": false
        },
        "limit": {
          "type": "integer",
          "description": "Max stops to return",
          "default": 20
        }
      },
      "output": {
        "type": "list<stop>",
        "fields": [
          "stops[0].id",
          "stops[0].stop_name",
          "stops[0].geometry.coordinates",
          "stops[0].served_by_routes[0].short_name",
          "stops[0].departures_url"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_stops",
      "description_for_ai": "Get public transit stops from a GTFS feed.",
      "intent": [
        "transit stops",
        "bus stops GTFS",
        "transit data",
        "остановки GTFS"
      ],
      "endpoint": "GET {gtfs_feed_url}/stops.txt",
      "input": {
        "feed_url": {
          "type": "string",
          "description": "GTFS feed URL (city transit agency)",
          "required": true
        }
      },
      "output": {
        "type": "list<stop>",
        "fields": [
          "stop_id",
          "stop_name",
          "stop_lat",
          "stop_lon",
          "stop_code",
          "wheelchair_boarding"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_routes",
      "description_for_ai": "Get transit routes (bus/metro/tram lines) from a GTFS feed.",
      "intent": [
        "transit routes",
        "bus routes",
        "metro lines GTFS",
        "маршруты GTFS"
      ],
      "endpoint": "GET {gtfs_feed_url}/routes.txt",
      "input": {
        "feed_url": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<route>",
        "fields": [
          "route_id",
          "route_short_name",
          "route_long_name",
          "route_type (0=tram, 1=subway, 2=rail, 3=bus)"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_realtime_positions",
      "description_for_ai": "Get real-time vehicle positions from GTFS-RT feed.",
      "intent": [
        "live transit",
        "bus position",
        "real-time GTFS",
        "реалтайм транспорт"
      ],
      "endpoint": "GET {gtfs_rt_url}/VehiclePositions",
      "input": {
        "feed_url": {
          "type": "string",
          "description": "GTFS-RT vehicle positions URL",
          "required": true
        }
      },
      "output": {
        "type": "list<vehicle>",
        "fields": [
          "entity[0].vehicle.vehicle.id",
          "entity[0].vehicle.position.latitude",
          "entity[0].vehicle.position.longitude",
          "entity[0].vehicle.trip.route_id"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}