{"apia":"1.0","service":{"id":"companies-house","name":"Companies House API (UK)","description_for_ai":"Free UK company registry. 5M+ UK companies with directors, filing history, accounts, charges, insolvency. Official government data. No cost. Use for UK business verification, company research, due diligence.","url":"https://companies house.gov.uk","api_base":"https://api.company-information.service.gov.uk","category":"business_registry","geo":["GB"],"language":"en","docs":"https://developer.company-information.service.gov.uk/api/docs/"},"auth":{"type":"basic_auth","anonymous_access":false,"note":"API key as username, empty password","how_to_get":"Register at https://developer.company-information.service.gov.uk","cost":"Free"},"capabilities":[{"id":"search_companies","description_for_ai":"Search UK companies by name. Returns company number, status, registered address, type.","intent":["UK company search","find UK business","company verification UK","British company info","Companies House"],"endpoint":"GET https://api.company-information.service.gov.uk/search/companies","input":{"q":{"type":"string","description":"Company name or number","required":true},"items_per_page":{"type":"integer","default":20}},"output":{"type":"list<company>","fields":["items[0].company_number","items[0].title","items[0].company_status","items[0].company_type","items[0].address.postal_code"]},"realtime":false,"requires_auth":true},{"id":"get_company","description_for_ai":"Get full details of a UK company: directors, accounts filing dates, registered office, incorporation date.","intent":["UK company details","company directors UK","registered address","incorporation date","company accounts"],"endpoint":"GET https://api.company-information.service.gov.uk/company/{company_number}","input":{"company_number":{"type":"string","description":"8-character company number e.g. 00445790","required":true}},"output":{"type":"company","fields":["company_name","company_number","company_status","date_of_c