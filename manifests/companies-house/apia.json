{
  "apia": "1.0",
  "service": {
    "id": "companies-house",
    "name": "Companies House API (UK)",
    "description_for_ai": "Free UK company registry. 5M+ UK companies with directors, filing history, accounts, charges, insolvency. Official government data. No cost. Use for UK business verification, company research, due diligence.",
    "url": "https://companies house.gov.uk",
    "api_base": "https://api.company-information.service.gov.uk",
    "category": "business",
    "geo": [
      "GB"
    ],
    "language": "en",
    "docs": "https://developer.company-information.service.gov.uk/api/docs/"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "API key as username, empty password",
    "how_to_get": "Register at https://developer.company-information.service.gov.uk",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "search_companies",
      "description_for_ai": "Search UK companies by name. Returns company number, status, registered address, type.",
      "intent": [
        "UK company search",
        "find UK business",
        "company verification UK",
        "British company info",
        "Companies House"
      ],
      "endpoint": "GET https://api.company-information.service.gov.uk/search/companies",
      "input": {
        "q": {
          "type": "string",
          "description": "Company name or number",
          "required": true
        },
        "items_per_page": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<company>",
        "fields": [
          "items[0].company_number",
          "items[0].title",
          "items[0].company_status",
          "items[0].company_type",
          "items[0].address.postal_code"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_company",
      "description_for_ai": "Get full details of a UK company: directors, accounts filing dates, registered office, incorporation date.",
      "intent": [
        "UK company details",
        "company directors UK",
        "registered address",
        "incorporation date",
        "company accounts"
      ],
      "endpoint": "GET https://api.company-information.service.gov.uk/company/{company_number}",
      "input": {
        "company_number": {
          "type": "string",
          "description": "8-character company number e.g. 00445790",
          "required": true
        }
      },
      "output": {
        "type": "company",
        "fields": [
          "company_name",
          "company_number",
          "company_status",
          "date_of_creation",
          "registered_office_address",
          "accounts.next_due",
          "confirmation_statement.next_due"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_company",
      "description_for_ai": "Get full UK company details: registered address, officers, accounts filing.",
      "intent": [
        "UK company details",
        "companies house info",
        "company registration UK",
        "данные компании Великобритания"
      ],
      "endpoint": "GET https://api.company-information.service.gov.uk/company/{company_number}",
      "input": {
        "company_number": {
          "type": "string",
          "description": "8-digit UK company number e.g. 00445790",
          "required": true
        }
      },
      "output": {
        "type": "company",
        "fields": [
          "company_name",
          "company_number",
          "registered_office_address.address_line_1",
          "date_of_creation",
          "company_status",
          "sic_codes"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_officers",
      "description_for_ai": "Get list of company officers (directors, secretaries) from Companies House.",
      "intent": [
        "company directors UK",
        "officers companies house",
        "directors list UK",
        "директора компании UK"
      ],
      "endpoint": "GET https://api.company-information.service.gov.uk/company/{company_number}/officers",
      "input": {
        "company_number": {
          "type": "string",
          "required": true
        },
        "register_type": {
          "type": "string",
          "description": "directors, secretaries, llp-members",
          "required": false
        }
      },
      "output": {
        "type": "list<officer>",
        "fields": [
          "items[0].name",
          "items[0].officer_role",
          "items[0].appointed_on",
          "items[0].nationality"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_filings",
      "description_for_ai": "Get filing history of a UK company: annual returns, accounts, changes.",
      "intent": [
        "UK company filings",
        "companies house filings",
        "annual accounts UK"
      ],
      "endpoint": "GET https://api.company-information.service.gov.uk/company/{company_number}/filing-history",
      "input": {
        "company_number": {
          "type": "string",
          "required": true
        },
        "category": {
          "type": "string",
          "description": "accounts, annual-return, officers, mortgage, persons-with-significant-control",
          "required": false
        }
      },
      "output": {
        "type": "list<filing>",
        "fields": [
          "items[0].type",
          "items[0].date",
          "items[0].description",
          "items[0].links.document_metadata"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}