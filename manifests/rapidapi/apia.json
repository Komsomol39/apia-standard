{
  "apia": "1.0",
  "service": {
    "id": "rapidapi",
    "name": "RapidAPI Hub",
    "description_for_ai": "API marketplace with 40,000+ APIs. One API key, one SDK to access: weather, sports, finance, social media, entertainment, translation, and thousands of niche APIs. Simplifies multi-API integration. Use when you need an API for a specific niche not covered elsewhere.",
    "url": "https://rapidapi.com",
    "api_base": "https://api.rapidapi.com",
    "category": "utilities",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.rapidapi.com/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "X-RapidAPI-Key: {key}",
    "how_to_get": "Register at https://rapidapi.com — free tier on most APIs",
    "cost": "Free tier on most APIs. Premium APIs vary."
  },
  "capabilities": [
    {
      "id": "list_apis",
      "description_for_ai": "Search and list APIs available in the RapidAPI marketplace.",
      "intent": [
        "search APIs",
        "find API",
        "RapidAPI marketplace",
        "поиск API RapidAPI"
      ],
      "endpoint": "GET https://api.rapidapi.com/api/v1/search",
      "input": {
        "query": {
          "type": "string",
          "required": true
        },
        "category": {
          "type": "string",
          "required": false
        },
        "pricing": {
          "type": "string",
          "description": "free, paid",
          "required": false
        }
      },
      "output": {
        "type": "list<api>",
        "fields": [
          "apis[0].id",
          "apis[0].name",
          "apis[0].description",
          "apis[0].version",
          "apis[0].pricing.type"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "test_endpoint",
      "description_for_ai": "Test any RapidAPI endpoint with your subscription key.",
      "intent": [
        "test RapidAPI endpoint",
        "call RapidAPI",
        "API request RapidAPI",
        "запрос через RapidAPI"
      ],
      "endpoint": "GET https://{api_host}/",
      "input": {
        "X-RapidAPI-Key": {
          "type": "string",
          "description": "Your RapidAPI subscription key",
          "required": true
        },
        "X-RapidAPI-Host": {
          "type": "string",
          "description": "API host from RapidAPI URL",
          "required": true
        }
      },
      "output": {
        "type": "response",
        "fields": [
          "API-specific response"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_api_details",
      "description_for_ai": "Get details about a specific RapidAPI API: docs, pricing, endpoints.",
      "intent": [
        "API details RapidAPI",
        "API documentation",
        "endpoint list",
        "детали API RapidAPI"
      ],
      "endpoint": "GET https://api.rapidapi.com/api/v1/apis/{apiId}",
      "input": {
        "apiId": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "api",
        "fields": [
          "name",
          "description",
          "pricing[0].plan",
          "pricing[0].requests",
          "endpoints[0].name",
          "endpoints[0].method",
          "endpoints[0].url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_my_usage",
      "description_for_ai": "Get your RapidAPI subscription usage statistics.",
      "intent": [
        "RapidAPI usage",
        "API requests count",
        "my API stats",
        "статистика использования RapidAPI"
      ],
      "endpoint": "GET https://api.rapidapi.com/api/v1/user/usage",
      "input": {
        "period": {
          "type": "string",
          "description": "day, week, month",
          "default": "month"
        }
      },
      "output": {
        "type": "usage",
        "fields": [
          "requests",
          "errors",
          "quotaUsed",
          "quotaLimit"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_categories",
      "description_for_ai": "Get all API categories in the RapidAPI marketplace.",
      "intent": [
        "RapidAPI categories",
        "API types",
        "marketplace categories",
        "категории RapidAPI"
      ],
      "endpoint": "GET https://api.rapidapi.com/api/v1/categories",
      "input": {},
      "output": {
        "type": "list<category>",
        "fields": [
          "[0].id",
          "[0].name",
          "[0].apisCount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "discovery": "Search RapidAPI.com for specific API names. Each API has its own host and endpoint structure.",
    "free_tiers": "Most APIs on RapidAPI have generous free tiers. Check each API page for limits."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}