{
  "apia": "1.0",
  "service": {
    "id": "rapidapi",
    "name": "RapidAPI Hub",
    "description_for_ai": "API marketplace with 40,000+ APIs. One API key, one SDK to access: weather, sports, finance, social media, entertainment, translation, and thousands of niche APIs. Simplifies multi-API integration. Use when you need an API for a specific niche not covered elsewhere.",
    "url": "https://rapidapi.com",
    "api_base": "https://api.rapidapi.com",
    "category": "utilities",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.rapidapi.com/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "X-RapidAPI-Key: {key}",
    "how_to_get": "Register at https://rapidapi.com — free tier on most APIs",
    "cost": "Free tier on most APIs. Premium APIs vary."
  },
  "capabilities": [
    {
      "id": "search_apis",
      "description_for_ai": "Search RapidAPI marketplace for APIs by keyword and category.",
      "intent": [
        "search APIs RapidAPI",
        "find API",
        "API marketplace",
        "поиск API RapidAPI"
      ],
      "endpoint": "GET https://marketplace-search.p.rapidapi.com/apis/search",
      "input": {
        "q": {
          "type": "string",
          "description": "Search query",
          "required": true
        },
        "page": {
          "type": "integer",
          "default": 0
        },
        "size": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<api>",
        "fields": [
          "apis[0].apiId",
          "apis[0].name",
          "apis[0].description",
          "apis[0].thumbnail",
          "apis[0].pricing.type"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_api_details",
      "description_for_ai": "Get full details about an API on RapidAPI marketplace.",
      "intent": [
        "API details RapidAPI",
        "API documentation",
        "API info",
        "информация API RapidAPI"
      ],
      "endpoint": "GET https://marketplace-search.p.rapidapi.com/apis/{apiId}",
      "input": {
        "apiId": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "api",
        "fields": [
          "name",
          "description",
          "pricing[0].price",
          "rating.count",
          "rating.avgScore",
          "subscribers",
          "endpoints[0].name",
          "endpoints[0].method"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "test_api_endpoint",
      "description_for_ai": "Make a test request to any API available on RapidAPI.",
      "intent": [
        "test API RapidAPI",
        "call API",
        "API request",
        "тест API RapidAPI"
      ],
      "endpoint": "GET|POST https://{api_host}/{endpoint}",
      "input": {
        "api_host": {
          "type": "string",
          "description": "API host from RapidAPI (e.g., joke-api5.p.rapidapi.com)",
          "required": true
        },
        "endpoint": {
          "type": "string",
          "required": true
        },
        "params": {
          "type": "object",
          "description": "Query parameters",
          "required": false
        }
      },
      "output": {
        "type": "api_response",
        "fields": [
          "Response varies by API"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_my_subscriptions",
      "description_for_ai": "Get all APIs the user is subscribed to on RapidAPI.",
      "intent": [
        "my subscriptions RapidAPI",
        "subscribed APIs",
        "my APIs",
        "мои подписки RapidAPI"
      ],
      "endpoint": "GET https://api.rapidapi.com/api/subscriptions",
      "input": {},
      "output": {
        "type": "list<subscription>",
        "fields": [
          "[0].api.name",
          "[0].plan.name",
          "[0].billing.status",
          "[0].requestsLeft"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_usage_stats",
      "description_for_ai": "Get API usage statistics for your RapidAPI account.",
      "intent": [
        "API usage stats",
        "request count RapidAPI",
        "billing stats",
        "статистика RapidAPI"
      ],
      "endpoint": "GET https://api.rapidapi.com/api/usage",
      "input": {
        "period": {
          "type": "string",
          "description": "day, week, month",
          "default": "month"
        }
      },
      "output": {
        "type": "usage",
        "fields": [
          "totalRequests",
          "successfulRequests",
          "failedRequests",
          "byApi[0].name",
          "byApi[0].requests"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "discovery": "Search RapidAPI.com for specific API names. Each API has its own host and endpoint structure.",
    "free_tiers": "Most APIs on RapidAPI have generous free tiers. Check each API page for limits."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}