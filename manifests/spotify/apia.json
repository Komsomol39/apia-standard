{
  "apia": "1.0",
  "service": {
    "id": "spotify",
    "name": "Spotify Web API",
    "description_for_ai": "World's largest music streaming platform API. Search songs, artists, albums, playlists. Get audio features (tempo, energy, danceability). Control playback. Free to use for reading data. Use for music recommendations, song info, playlist creation, 'what song is this', 'find music by mood'.",
    "url": "https://spotify.com",
    "api_base": "https://api.spotify.com/v1",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.spotify.com/documentation/web-api"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "note": "Client Credentials flow for reading public data (no user login needed). Authorization Code flow for user-specific actions.",
    "token_url": "https://accounts.spotify.com/api/token",
    "how_to_get": "Register app at https://developer.spotify.com/dashboard — free",
    "cost": "Free for reading data. Premium account needed for playback control."
  },
  "capabilities": [
    {
      "id": "search",
      "description_for_ai": "Search Spotify for tracks, albums, artists, playlists, podcasts, or episodes.",
      "intent": [
        "search spotify",
        "find song",
        "search music",
        "find artist spotify",
        "найти музыку spotify"
      ],
      "endpoint": "GET https://api.spotify.com/v1/search",
      "input": {
        "q": {
          "type": "string",
          "description": "Search query. Use field filters: track:shape artist:radiohead, album:pablo honey",
          "required": true
        },
        "type": {
          "type": "string",
          "description": "Comma-separated: track, album, artist, playlist, show, episode",
          "required": true
        },
        "market": {
          "type": "string",
          "description": "ISO 3166-1 country code for availability filtering",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 20
        },
        "offset": {
          "type": "integer",
          "default": 0
        }
      },
      "output": {
        "type": "search_results",
        "fields": [
          "tracks.items[0].id",
          "tracks.items[0].name",
          "tracks.items[0].artists[0].name",
          "tracks.items[0].album.name",
          "tracks.items[0].preview_url",
          "tracks.items[0].uri"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_track",
      "description_for_ai": "Get full track details: duration, popularity, preview URL, audio features.",
      "intent": [
        "track info",
        "song details",
        "track data",
        "информация о треке"
      ],
      "endpoint": "GET https://api.spotify.com/v1/tracks/{id}",
      "input": {
        "id": {
          "type": "string",
          "description": "Spotify track ID",
          "required": true
        },
        "market": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "track",
        "fields": [
          "id",
          "name",
          "duration_ms",
          "popularity",
          "preview_url",
          "album.name",
          "artists[0].name",
          "uri"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_recommendations",
      "description_for_ai": "Get song recommendations based on seed tracks, artists, or genres. Fine-tune with audio feature targets.",
      "intent": [
        "song recommendations",
        "music recommendation",
        "similar songs",
        "discover music",
        "рекомендации spotify"
      ],
      "endpoint": "GET https://api.spotify.com/v1/recommendations",
      "input": {
        "seed_tracks": {
          "type": "string",
          "description": "Comma-separated track IDs (up to 5 seeds total)",
          "required": false
        },
        "seed_artists": {
          "type": "string",
          "description": "Comma-separated artist IDs",
          "required": false
        },
        "seed_genres": {
          "type": "string",
          "description": "Comma-separated genres: pop, rock, jazz, classical, hip-hop",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 20
        },
        "target_energy": {
          "type": "float",
          "description": "0.0-1.0 target energy level",
          "required": false
        },
        "target_valence": {
          "type": "float",
          "description": "0.0-1.0 musical positivity",
          "required": false
        },
        "target_tempo": {
          "type": "float",
          "description": "Target BPM",
          "required": false
        }
      },
      "output": {
        "type": "list<track>",
        "fields": [
          "tracks[0].id",
          "tracks[0].name",
          "tracks[0].artists[0].name",
          "tracks[0].uri"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_playlist",
      "description_for_ai": "Create a new Spotify playlist for a user. Can be public or private.",
      "intent": [
        "create playlist",
        "new playlist spotify",
        "make playlist",
        "создать плейлист"
      ],
      "endpoint": "POST https://api.spotify.com/v1/users/{user_id}/playlists",
      "input": {
        "user_id": {
          "type": "string",
          "description": "Spotify user ID",
          "required": true
        },
        "name": {
          "type": "string",
          "required": true
        },
        "description": {
          "type": "string",
          "required": false
        },
        "public": {
          "type": "boolean",
          "default": true
        },
        "collaborative": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "playlist",
        "fields": [
          "id",
          "name",
          "external_urls.spotify",
          "uri"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "add_tracks_to_playlist",
      "description_for_ai": "Add tracks to a Spotify playlist by track URIs.",
      "intent": [
        "add to playlist",
        "playlist tracks",
        "add songs playlist",
        "добавить в плейлист"
      ],
      "endpoint": "POST https://api.spotify.com/v1/playlists/{playlist_id}/tracks",
      "input": {
        "playlist_id": {
          "type": "string",
          "required": true
        },
        "uris": {
          "type": "array",
          "description": "['spotify:track:id1', 'spotify:track:id2'] — up to 100 tracks",
          "required": true
        },
        "position": {
          "type": "integer",
          "description": "Position to insert (0=beginning). Omit to append.",
          "required": false
        }
      },
      "output": {
        "type": "snapshot",
        "fields": [
          "snapshot_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_current_playback",
      "description_for_ai": "Get what the user is currently playing: track, device, progress, shuffle/repeat state.",
      "intent": [
        "now playing spotify",
        "current track",
        "what is playing",
        "spotify playback",
        "что играет spotify"
      ],
      "endpoint": "GET https://api.spotify.com/v1/me/player",
      "input": {
        "market": {
          "type": "string",
          "required": false
        },
        "additional_types": {
          "type": "string",
          "description": "track,episode",
          "required": false
        }
      },
      "output": {
        "type": "playback",
        "fields": [
          "is_playing",
          "item.name",
          "item.artists[0].name",
          "progress_ms",
          "item.duration_ms",
          "device.name",
          "shuffle_state",
          "repeat_state"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "control_playback",
      "description_for_ai": "Control playback: play, pause, skip to next/previous, set volume, shuffle, repeat.",
      "intent": [
        "play pause spotify",
        "skip track",
        "control playback",
        "pause music",
        "управление воспроизведением spotify"
      ],
      "endpoint": "PUT https://api.spotify.com/v1/me/player/play",
      "input": {
        "device_id": {
          "type": "string",
          "description": "Device ID to target",
          "required": false
        },
        "context_uri": {
          "type": "string",
          "description": "Spotify URI of album/playlist to play",
          "required": false
        },
        "uris": {
          "type": "array",
          "description": "Track URIs to play",
          "required": false
        },
        "offset": {
          "type": "object",
          "description": "{position: 0} or {uri: 'spotify:track:...'} to start from",
          "required": false
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "204 No Content on success"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_user_top",
      "description_for_ai": "Get user's top tracks or artists based on listening history. Filter by time range.",
      "intent": [
        "top tracks",
        "favorite songs",
        "most listened",
        "top artists spotify",
        "любимая музыка spotify"
      ],
      "endpoint": "GET https://api.spotify.com/v1/me/top/{type}",
      "input": {
        "type": {
          "type": "string",
          "description": "tracks or artists",
          "required": true
        },
        "time_range": {
          "type": "string",
          "description": "short_term (4 weeks), medium_term (6 months), long_term (all time)",
          "default": "medium_term"
        },
        "limit": {
          "type": "integer",
          "default": 20
        },
        "offset": {
          "type": "integer",
          "default": 0
        }
      },
      "output": {
        "type": "list<item>",
        "fields": [
          "items[0].name",
          "items[0].id",
          "items[0].popularity",
          "items[0].uri"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "auth_flow": "For public data search use Client Credentials (simpler — just client_id + client_secret, no user login). For user playlists use Authorization Code flow.",
    "mood_mapping": "Map moods to audio features: Happy=high valence(0.8+), Energetic=high energy(0.8+), Calm=low energy(0.2-), Sad=low valence(0.2-), Dance=high danceability(0.8+).",
    "preview_url": "preview_url gives 30-second MP3 preview — free to play without premium.",
    "market_tip": "Always set market=RU for Russian users to filter out unavailable tracks."
  },
  "limits": {
    "rate_limit": "Rate limited by Spotify — avoid hammering. Use caching.",
    "commercial_use": true,
    "attribution_required": true,
    "attribution_text": "Powered by Spotify"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}