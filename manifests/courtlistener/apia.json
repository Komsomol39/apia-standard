{
  "apia": "1.0",
  "service": {
    "id": "courtlistener",
    "name": "CourtListener API",
    "description_for_ai": "CourtListener — free US court case database from Free Law Project. 5M+ court opinions from Supreme Court, Circuit Courts, and District Courts. Federal and state case law. Oral arguments, dockets, and judge profiles. Essential for US legal research. No authentication needed for basic access.",
    "url": "https://courtlistener.com",
    "api_base": "https://www.courtlistener.com/api/rest/v3",
    "category": "legal",
    "geo": [
      "US"
    ],
    "language": "en",
    "docs": "https://www.courtlistener.com/help/api/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_limits": "5000 req/day",
    "header": "Authorization: Token {token}",
    "how_to_get": "Register at https://www.courtlistener.com",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "search_cases",
      "description_for_ai": "Search US court cases and opinions in CourtListener database.",
      "intent": [
        "search court cases",
        "legal case search",
        "CourtListener search",
        "поиск судебных дел"
      ],
      "endpoint": "GET https://www.courtlistener.com/api/rest/v3/search/",
      "input": {
        "q": {
          "type": "string",
          "description": "Full-text search query",
          "required": true
        },
        "type": {
          "type": "string",
          "description": "o (opinions), r (recap, PACER), p (people)",
          "default": "o"
        },
        "court": {
          "type": "string",
          "description": "Court ID: scotus, ca1, ca9, dcd, nysd",
          "required": false
        },
        "filed_after": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        }
      },
      "output": {
        "type": "list<case>",
        "fields": [
          "results[0].id",
          "results[0].caseName",
          "results[0].court",
          "results[0].dateFiled",
          "results[0].snippet"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_opinion",
      "description_for_ai": "Get full text of a court opinion from CourtListener.",
      "intent": [
        "court opinion text",
        "case full text",
        "legal ruling",
        "текст решения суда"
      ],
      "endpoint": "GET https://www.courtlistener.com/api/rest/v3/opinions/{id}/",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "opinion",
        "fields": [
          "id",
          "case_name",
          "date_filed",
          "html (opinion HTML)",
          "plain_text",
          "author_str",
          "joined_by_str"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_docket",
      "description_for_ai": "Get docket entries (PACER case events) for a federal case.",
      "intent": [
        "case docket",
        "PACER entries",
        "federal case docket",
        "судебный реестр"
      ],
      "endpoint": "GET https://www.courtlistener.com/api/rest/v3/dockets/{id}/",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "docket",
        "fields": [
          "case_name",
          "court_id",
          "date_filed",
          "date_terminated",
          "docket_number",
          "docket_entries[0].date_filed",
          "docket_entries[0].description"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_judge_info",
      "description_for_ai": "Get information about a federal judge from CourtListener.",
      "intent": [
        "judge info",
        "federal judge",
        "court judge",
        "информация о судье"
      ],
      "endpoint": "GET https://www.courtlistener.com/api/rest/v3/people/{id}/",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "judge",
        "fields": [
          "name_full",
          "date_dob",
          "political_affiliation",
          "positions[0].court.full_name",
          "positions[0].date_start",
          "education[0].school.name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_citations",
      "description_for_ai": "Get cases that cite a specific opinion (forward citations).",
      "intent": [
        "case citations",
        "citing cases",
        "how cited",
        "ссылки на судебное дело"
      ],
      "endpoint": "GET https://www.courtlistener.com/api/rest/v3/search/?q=cites:{opinion_id}",
      "input": {
        "opinion_id": {
          "type": "integer",
          "required": true
        },
        "count": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<case>",
        "fields": [
          "results[0].caseName",
          "results[0].dateFiled",
          "results[0].court"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}