{
  "apia": "1.0",
  "service": {
    "id": "courtlistener",
    "name": "CourtListener API",
    "description_for_ai": "CourtListener — free US court case database from Free Law Project. 5M+ court opinions from Supreme Court, Circuit Courts, and District Courts. Federal and state case law. Oral arguments, dockets, and judge profiles. Essential for US legal research. No authentication needed for basic access.",
    "url": "https://courtlistener.com",
    "api_base": "https://www.courtlistener.com/api/rest/v3",
    "category": "legal",
    "geo": [
      "US"
    ],
    "language": "en",
    "docs": "https://www.courtlistener.com/help/api/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_limits": "5000 req/day",
    "header": "Authorization: Token {token}",
    "how_to_get": "Register at https://www.courtlistener.com",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "search_opinions",
      "description_for_ai": "Search US court opinions (case law) by keyword, court, and date.",
      "intent": [
        "case law search",
        "court opinions",
        "legal precedent",
        "решения судов США"
      ],
      "endpoint": "GET https://www.courtlistener.com/api/rest/v3/search/",
      "input": {
        "q": {
          "type": "string",
          "description": "Search query",
          "required": true
        },
        "type": {
          "type": "string",
          "description": "o (opinions), r (RECAP), oa (oral arguments), p (people)",
          "default": "o"
        },
        "court": {
          "type": "string",
          "description": "scotus, ca1, ca2, ... (circuit), cafc, nysd, etc.",
          "required": false
        },
        "filed_after": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        },
        "order_by": {
          "type": "string",
          "description": "score desc, dateFiled desc",
          "default": "score desc"
        }
      },
      "output": {
        "type": "list<opinion>",
        "fields": [
          "results[0].caseName",
          "results[0].court_citation_string",
          "results[0].dateFiled",
          "results[0].download_url",
          "results[0].snippet"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_opinion",
      "description_for_ai": "Get full text and metadata of a court opinion by ID.",
      "intent": [
        "opinion text",
        "case text",
        "court decision",
        "текст судебного решения"
      ],
      "endpoint": "GET https://www.courtlistener.com/api/rest/v3/opinions/{id}/",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "opinion",
        "fields": [
          "case_name",
          "date_filed",
          "court.full_name",
          "plain_text",
          "html_with_citations",
          "citations"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_dockets",
      "description_for_ai": "Search court dockets (case filings) in PACER/RECAP.",
      "intent": [
        "court docket",
        "case filing",
        "PACER docket",
        "материалы дела"
      ],
      "endpoint": "GET https://www.courtlistener.com/api/rest/v3/dockets/",
      "input": {
        "q": {
          "type": "string",
          "required": false
        },
        "court": {
          "type": "string",
          "required": false
        },
        "case_name": {
          "type": "string",
          "required": false
        },
        "docket_number": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<docket>",
        "fields": [
          "results[0].id",
          "results[0].case_name",
          "results[0].court_id",
          "results[0].date_filed",
          "results[0].docket_number"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_citations",
      "description_for_ai": "Get all opinions that cite a given court opinion.",
      "intent": [
        "case citations",
        "citing cases",
        "legal precedent network",
        "цитирование дела"
      ],
      "endpoint": "GET https://www.courtlistener.com/api/rest/v3/search/",
      "input": {
        "q": {
          "type": "string",
          "description": "cites: followed by opinion ID",
          "required": true
        }
      },
      "output": {
        "type": "list<opinion>",
        "fields": [
          "results[0].caseName",
          "results[0].dateFiled",
          "results[0].court_citation_string"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_judge",
      "description_for_ai": "Get information about a federal judge from CourtListener.",
      "intent": [
        "judge info",
        "federal judge",
        "judge biography",
        "информация о судье"
      ],
      "endpoint": "GET https://www.courtlistener.com/api/rest/v3/people/",
      "input": {
        "name_last": {
          "type": "string",
          "required": false
        },
        "name_first": {
          "type": "string",
          "required": false
        },
        "court": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<judge>",
        "fields": [
          "results[0].name_full",
          "results[0].date_dob",
          "results[0].political_affiliation_5",
          "results[0].fjc_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}