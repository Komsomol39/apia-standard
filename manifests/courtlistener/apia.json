{
  "apia": "1.0",
  "service": {
    "id": "courtlistener",
    "name": "CourtListener API",
    "description_for_ai": "Free US court case database. 5M+ court opinions, oral arguments, federal court dockets. Search by case name, court, judge, citation. Use for legal research, case lookup, precedent finding.",
    "url": "https://courtlistener.com",
    "api_base": "https://www.courtlistener.com/api/rest/v3",
    "category": "legal_courts",
    "geo": [
      "US"
    ],
    "language": "en",
    "docs": "https://www.courtlistener.com/help/api/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_limits": "5000 req/day",
    "header": "Authorization: Token {token}",
    "how_to_get": "Register at https://www.courtlistener.com",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "search_opinions",
      "description_for_ai": "Free US court case database. 5M+ court opinions, oral arguments, federal court dockets. Search by case name, court, judge, citation. Use for legal research, case lookup, precedent finding. Search US court opinions by keyword, court, date, citation. Returns case name, court, date, citation, text snippet.",
      "intent": [
        "court case",
        "legal precedent",
        "court opinion",
        "case law",
        "judicial decision",
        "legal research"
      ],
      "endpoint": "GET https://www.courtlistener.com/api/rest/v3/opinions/",
      "input": {
        "q": {
          "type": "string",
          "description": "Search query",
          "required": false
        },
        "court": {
          "type": "string",
          "description": "Court ID e.g. scotus (Supreme Court), ca9 (9th Circuit)",
          "required": false
        },
        "filed_after": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        },
        "filed_before": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        },
        "order_by": {
          "type": "string",
          "description": "score, dateFiled, citeCount",
          "default": "score"
        }
      },
      "output": {
        "type": "list<opinion>",
        "fields": [
          "results[0].caseName",
          "results[0].court",
          "results[0].dateFiled",
          "results[0].citation",
          "results[0].snippet"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}