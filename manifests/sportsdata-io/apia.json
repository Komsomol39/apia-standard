{
  "apia": "1.0",
  "service": {
    "id": "sportsdata-io",
    "name": "SportsData.io API",
    "description_for_ai": "Comprehensive sports data API. NFL, NBA, MLB, NHL, Soccer, Golf, Tennis, NASCAR real-time scores, stats, odds. Used by major sports apps. Use for live scores, player stats, team standings.",
    "url": "https://sportsdata.io",
    "api_base": "https://api.sportsdata.io",
    "category": "sports",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://sportsdata.io/developers/api-documentation/nfl"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Ocp-Apim-Subscription-Key: ...",
    "how_to_get": "Register at https://sportsdata.io/developers",
    "cost": "Free trial. Paid from $9/month per sport"
  },
  "capabilities": [
    {
      "id": "get_scores",
      "description_for_ai": "Get live and final game scores for NFL, NBA, MLB, NHL, soccer.",
      "intent": [
        "sports scores",
        "live scores",
        "game results",
        "счёт матча SportsData"
      ],
      "endpoint": "GET https://api.sportsdata.io/v3/{sport}/scores/json/ScoresByDate/{date}",
      "input": {
        "sport": {
          "type": "string",
          "description": "nfl, nba, mlb, nhl, soccer",
          "required": true
        },
        "date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        }
      },
      "output": {
        "type": "list<game>",
        "fields": [
          "[0].GameKey",
          "[0].HomeTeam",
          "[0].AwayTeam",
          "[0].HomeScore",
          "[0].AwayScore",
          "[0].Status",
          "[0].DateTime"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_player_stats",
      "description_for_ai": "Get player statistics for a season or game.",
      "intent": [
        "player stats",
        "athlete performance",
        "sports stats",
        "статистика игрока"
      ],
      "endpoint": "GET https://api.sportsdata.io/v3/{sport}/stats/json/PlayerSeasonStats/{season}",
      "input": {
        "sport": {
          "type": "string",
          "required": true
        },
        "season": {
          "type": "string",
          "description": "2024, 2024REG, 2024POST",
          "required": true
        }
      },
      "output": {
        "type": "list<player_stats>",
        "fields": [
          "[0].Name",
          "[0].Team",
          "[0].Position",
          "[0].Games",
          "[0].Points",
          "[0].Assists",
          "[0].Rebounds"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_standings",
      "description_for_ai": "Get current league standings/rankings.",
      "intent": [
        "standings",
        "league table",
        "rankings sports",
        "турнирная таблица"
      ],
      "endpoint": "GET https://api.sportsdata.io/v3/{sport}/scores/json/Standings/{season}",
      "input": {
        "sport": {
          "type": "string",
          "required": true
        },
        "season": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<team>",
        "fields": [
          "[0].Team",
          "[0].Name",
          "[0].Wins",
          "[0].Losses",
          "[0].Percentage",
          "[0].Conference"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_schedule",
      "description_for_ai": "Get the full game schedule for a team or season.",
      "intent": [
        "sports schedule",
        "game schedule",
        "fixtures",
        "расписание матчей"
      ],
      "endpoint": "GET https://api.sportsdata.io/v3/{sport}/scores/json/Games/{season}",
      "input": {
        "sport": {
          "type": "string",
          "required": true
        },
        "season": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<game>",
        "fields": [
          "[0].GameKey",
          "[0].Date",
          "[0].HomeTeam",
          "[0].AwayTeam",
          "[0].Status",
          "[0].StadiumID"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_team_roster",
      "description_for_ai": "Get current team roster with player details.",
      "intent": [
        "team roster",
        "squad list",
        "players on team",
        "состав команды"
      ],
      "endpoint": "GET https://api.sportsdata.io/v3/{sport}/scores/json/Players/{team}",
      "input": {
        "sport": {
          "type": "string",
          "required": true
        },
        "team": {
          "type": "string",
          "description": "Team abbreviation: LAL, NYK, BOS",
          "required": true
        }
      },
      "output": {
        "type": "list<player>",
        "fields": [
          "[0].PlayerID",
          "[0].Name",
          "[0].Position",
          "[0].Jersey",
          "[0].Height",
          "[0].Weight",
          "[0].BirthDate"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}