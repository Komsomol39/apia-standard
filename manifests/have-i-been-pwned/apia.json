{
  "apia": "1.0",
  "service": {
    "id": "have-i-been-pwned",
    "name": "Have I Been Pwned API",
    "description_for_ai": "Check if email or password has been compromised in data breaches. 12B+ compromised accounts in database. Free to check emails. Use for security awareness, account protection checks.",
    "url": "https://haveibeenpwned.com",
    "api_base": "https://haveibeenpwned.com/api/v3",
    "category": "security",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://haveibeenpwned.com/API/v3"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "hibp-api-key: ...",
    "how_to_get": "Purchase key at https://haveibeenpwned.com/API/Key",
    "cost": "$3.95/month"
  },
  "capabilities": [
    {
      "id": "check_email_breach",
      "description_for_ai": "Check if an email address has appeared in known data breaches.",
      "intent": [
        "check email breach",
        "has email been hacked",
        "HIBP check",
        "проверить утечку email"
      ],
      "endpoint": "GET https://haveibeenpwned.com/api/v3/breachedaccount/{account}",
      "input": {
        "account": {
          "type": "string",
          "description": "Email address to check",
          "required": true
        },
        "truncateResponse": {
          "type": "boolean",
          "description": "Return only breach names (no details)",
          "default": true
        },
        "includeUnverified": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "list<breach>",
        "fields": [
          "[0].Name",
          "[0].Domain (if truncateResponse=false)",
          "[0].BreachDate (if truncateResponse=false)",
          "[0].PwnCount (if truncateResponse=false)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_breach_details",
      "description_for_ai": "Get detailed information about a specific data breach.",
      "intent": [
        "breach details HIBP",
        "data breach info",
        "hack details",
        "детали утечки данных"
      ],
      "endpoint": "GET https://haveibeenpwned.com/api/v3/breach/{name}",
      "input": {
        "name": {
          "type": "string",
          "description": "Breach name e.g. Adobe, LinkedIn, Dropbox",
          "required": true
        }
      },
      "output": {
        "type": "breach",
        "fields": [
          "Name",
          "Domain",
          "BreachDate",
          "PwnCount",
          "Description",
          "DataClasses",
          "IsVerified",
          "IsFabricated"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_all_breaches",
      "description_for_ai": "Get list of all known data breaches in the HIBP database.",
      "intent": [
        "all breaches",
        "known data breaches",
        "breach database",
        "список утечек данных"
      ],
      "endpoint": "GET https://haveibeenpwned.com/api/v3/breaches",
      "input": {
        "domain": {
          "type": "string",
          "description": "Filter by domain e.g. adobe.com",
          "required": false
        }
      },
      "output": {
        "type": "list<breach>",
        "fields": [
          "[0].Name",
          "[0].Domain",
          "[0].BreachDate",
          "[0].PwnCount",
          "[0].DataClasses"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "check_password",
      "description_for_ai": "Check if a password has appeared in data breaches using k-anonymity (safe — only first 5 chars of SHA1 sent).",
      "intent": [
        "check password breach",
        "is password leaked",
        "password check HIBP",
        "проверить пароль на утечку"
      ],
      "endpoint": "GET https://api.pwnedpasswords.com/range/{hashPrefix}",
      "input": {
        "hashPrefix": {
          "type": "string",
          "description": "First 5 characters of SHA1 hash of the password (k-anonymity model — original password never sent)",
          "required": true
        }
      },
      "output": {
        "type": "list<hash_suffix>",
        "fields": [
          "HASH_SUFFIX:COUNT (count=how many times seen in breaches)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "check_pastebin_leaks",
      "description_for_ai": "Check if an email appears in paste (Pastebin, GitHub) leaks.",
      "intent": [
        "pastebin leak",
        "email in pastebin",
        "paste leak HIBP",
        "утечка в pastebin"
      ],
      "endpoint": "GET https://haveibeenpwned.com/api/v3/pasteaccount/{account}",
      "input": {
        "account": {
          "type": "string",
          "description": "Email address to check",
          "required": true
        }
      },
      "output": {
        "type": "list<paste>",
        "fields": [
          "[0].Source",
          "[0].Id",
          "[0].Title",
          "[0].Date",
          "[0].EmailCount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "password_privacy": "Never send full password to API. Hash with SHA-1, take first 5 chars, send those. Check if full hash is in response.",
    "free": "Password check endpoint is completely free and uses k-anonymity for privacy."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}