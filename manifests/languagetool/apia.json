{
  "apia": "1.0",
  "service": {
    "id": "languagetool",
    "name": "LanguageTool API",
    "description_for_ai": "Free grammar and spell checker. Supports 25+ languages including Russian, German, French, Spanish. Detects grammar errors, punctuation mistakes, style issues. Free: 20 req/min 20KB text.",
    "url": "https://languagetool.org",
    "api_base": "https://api.languagetool.org/v2",
    "category": "nlp",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://languagetool.org/http-api/"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "anonymous_limits": "20 req/min, 20KB text",
    "cost": "Free. Premium: $4.99/month"
  },
  "capabilities": [
    {
      "id": "check_text",
      "description_for_ai": "Grammar and spell check text with LanguageTool. 30+ languages.",
      "intent": [
        "grammar check",
        "spell check",
        "text correction",
        "проверка грамматики LanguageTool"
      ],
      "endpoint": "POST https://api.languagetoolplus.com/v2/check",
      "input": {
        "text": {
          "type": "string",
          "description": "Text to check",
          "required": true
        },
        "language": {
          "type": "string",
          "description": "en-US, en-GB, de-DE, fr, es, ru, it, nl, pt-BR (auto for autodetect)",
          "required": true
        },
        "enabledRules": {
          "type": "string",
          "description": "Comma-separated rule IDs to enable",
          "required": false
        },
        "disabledRules": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "check",
        "fields": [
          "matches[0].message",
          "matches[0].shortMessage",
          "matches[0].offset",
          "matches[0].length",
          "matches[0].replacements[0].value",
          "matches[0].rule.id",
          "matches[0].rule.category.name"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "check_with_context",
      "description_for_ai": "Check text with piecemeal context (data array) for CMS or structured content.",
      "intent": [
        "grammar check structured",
        "check HTML content",
        "editor grammar check",
        "проверка структурированного текста"
      ],
      "endpoint": "POST https://api.languagetoolplus.com/v2/check",
      "input": {
        "data": {
          "type": "string",
          "description": "JSON: {annotation:[{text:'Normal text '},{markup:'<b>','interpretAs':' '},{text:'marked up'}]}",
          "required": true
        },
        "language": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "check",
        "fields": [
          "matches[0].message",
          "matches[0].offset",
          "matches[0].replacements[0].value"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_languages",
      "description_for_ai": "Get all supported languages in LanguageTool.",
      "intent": [
        "LanguageTool languages",
        "supported languages",
        "grammar check languages",
        "языки LanguageTool"
      ],
      "endpoint": "GET https://api.languagetoolplus.com/v2/languages",
      "input": {},
      "output": {
        "type": "list<language>",
        "fields": [
          "[0].name",
          "[0].code",
          "[0].longCode"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "check_markdown",
      "description_for_ai": "Check grammar in Markdown text, ignoring Markdown syntax.",
      "intent": [
        "markdown grammar check",
        "check markdown",
        "markdown spell check",
        "проверка Markdown"
      ],
      "endpoint": "POST https://api.languagetoolplus.com/v2/check",
      "input": {
        "text": {
          "type": "string",
          "required": true
        },
        "language": {
          "type": "string",
          "required": true
        },
        "textFormat": {
          "type": "string",
          "default": "plain"
        }
      },
      "output": {
        "type": "check",
        "fields": [
          "matches[0].message",
          "matches[0].replacements[0].value",
          "language.detectedLanguage.name"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_rule_categories",
      "description_for_ai": "Get all rule categories available in LanguageTool.",
      "intent": [
        "grammar rules",
        "rule categories",
        "error types",
        "правила проверки"
      ],
      "endpoint": "GET https://languagetool.org/api/v2/rule/en/categories",
      "input": {},
      "output": {
        "type": "list<category>",
        "fields": [
          "[0].id",
          "[0].name"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "language_codes": "English: en-US or en-GB. Russian: ru-RU. German: de-DE. French: fr. Spanish: es.",
    "free": "Free tier is very generous — 20 req/min with 20KB text per request is enough for most use cases.",
    "self_host": "LanguageTool is open source and can be self-hosted for unlimited use."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}