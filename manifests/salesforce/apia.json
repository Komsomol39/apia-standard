{
  "apia": "1.0",
  "service": {
    "id": "salesforce",
    "name": "Salesforce REST API",
    "description_for_ai": "Enterprise CRM platform. Leads, opportunities, accounts, contacts, cases. Workflow automation, reporting. Most widely used CRM in enterprise. Use for sales pipeline, customer data, service management.",
    "url": "https://salesforce.com",
    "api_base": "https://{instance}.salesforce.com/services/data/v59.0",
    "category": "business",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.salesforce.com/docs/atlas.en-us.api_rest.meta/api_rest/"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Developer org at https://developer.salesforce.com/signup — free",
    "cost": "Free developer org. Enterprise from $150/user/month"
  },
  "capabilities": [
    {
      "id": "soql_query",
      "description_for_ai": "Query Salesforce data using SOQL (Salesforce Object Query Language). Like SQL for Salesforce objects.",
      "intent": [
        "salesforce query",
        "soql",
        "query crm data",
        "salesforce data",
        "запрос salesforce"
      ],
      "endpoint": "GET https://{instance}.salesforce.com/services/data/v59.0/query",
      "input": {
        "q": {
          "type": "string",
          "description": "SOQL query: 'SELECT Id, Name, Email FROM Contact WHERE Account.Name = \\'Acme\\' LIMIT 10', 'SELECT Id, Amount, StageName FROM Opportunity WHERE CloseDate = THIS_MONTH ORDER BY Amount DESC'",
          "required": true
        }
      },
      "output": {
        "type": "query_result",
        "fields": [
          "totalSize",
          "done",
          "records[0].Id",
          "records[0] (all queried fields)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_record",
      "description_for_ai": "Create a new Salesforce record (Contact, Lead, Account, Opportunity, Case, or any custom object).",
      "intent": [
        "create salesforce record",
        "new lead salesforce",
        "create contact salesforce",
        "new opportunity",
        "создать запись salesforce"
      ],
      "endpoint": "POST https://{instance}.salesforce.com/services/data/v59.0/sobjects/{object}",
      "input": {
        "object": {
          "type": "string",
          "description": "Object type: Contact, Lead, Account, Opportunity, Case, Task",
          "required": true
        },
        "fields": {
          "type": "object",
          "description": "Object fields: {FirstName, LastName, Email, Phone, Company (for Lead), AccountId (for Contact)}",
          "required": true
        }
      },
      "output": {
        "type": "record",
        "fields": [
          "id",
          "success",
          "errors"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_record",
      "description_for_ai": "Update fields of an existing Salesforce record by ID.",
      "intent": [
        "update salesforce",
        "edit record",
        "change stage",
        "update opportunity",
        "обновить запись salesforce"
      ],
      "endpoint": "PATCH https://{instance}.salesforce.com/services/data/v59.0/sobjects/{object}/{id}",
      "input": {
        "object": {
          "type": "string",
          "required": true
        },
        "id": {
          "type": "string",
          "description": "Salesforce record ID (15 or 18 chars)",
          "required": true
        },
        "fields": {
          "type": "object",
          "description": "Fields to update",
          "required": true
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "204 No Content on success"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_record",
      "description_for_ai": "Get a single Salesforce record with all or specific fields.",
      "intent": [
        "get salesforce record",
        "contact details salesforce",
        "record by id",
        "данные записи salesforce"
      ],
      "endpoint": "GET https://{instance}.salesforce.com/services/data/v59.0/sobjects/{object}/{id}",
      "input": {
        "object": {
          "type": "string",
          "required": true
        },
        "id": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "Comma-separated field names. Omit for all.",
          "required": false
        }
      },
      "output": {
        "type": "record",
        "fields": [
          "Id",
          "Name",
          "all requested fields"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search",
      "description_for_ai": "Full-text search across Salesforce using SOSL (Salesforce Object Search Language). Searches across multiple objects at once.",
      "intent": [
        "search salesforce",
        "find in crm",
        "salesforce search",
        "full text search",
        "поиск salesforce"
      ],
      "endpoint": "GET https://{instance}.salesforce.com/services/data/v59.0/search",
      "input": {
        "q": {
          "type": "string",
          "description": "SOSL query: 'FIND {John Smith} IN ALL FIELDS RETURNING Contact(Id, Name, Email), Lead(Id, Name)'",
          "required": true
        }
      },
      "output": {
        "type": "search_result",
        "fields": [
          "searchRecords[0].Id",
          "searchRecords[0].Name",
          "searchRecords[0].attributes.type"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_metadata",
      "description_for_ai": "Get schema/metadata for a Salesforce object — all available fields, types, relationships. Use to discover field names before querying.",
      "intent": [
        "salesforce schema",
        "object metadata",
        "field names salesforce",
        "describe object",
        "схема salesforce"
      ],
      "endpoint": "GET https://{instance}.salesforce.com/services/data/v59.0/sobjects/{object}/describe",
      "input": {
        "object": {
          "type": "string",
          "description": "Object name: Contact, Lead, Account, Opportunity, or any custom object",
          "required": true
        }
      },
      "output": {
        "type": "metadata",
        "fields": [
          "name",
          "label",
          "fields[0].name",
          "fields[0].label",
          "fields[0].type",
          "fields[0].referenceTo"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}