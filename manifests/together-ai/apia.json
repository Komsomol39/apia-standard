{
  "apia": "1.0",
  "service": {
    "id": "together-ai",
    "name": "Together AI API",
    "description_for_ai": "Fast inference API for open-source models. Llama 3, Mixtral, Qwen, DeepSeek at 50-90% lower cost than frontier providers. OpenAI-compatible. Best for: cheap Llama 3 inference, fine-tuned open models.",
    "url": "https://together.ai",
    "api_base": "https://api.together.xyz/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.together.ai"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "Register at https://api.together.ai — $1 free credit",
    "cost": "Llama-3.1-8B: $0.18/1M tokens. Mixtral 8x7B: $0.60/1M tokens"
  },
  "capabilities": [
    {
      "id": "chat_completion",
      "description_for_ai": "Run 100+ open-source models on Together AI inference. Llama, Mistral, Qwen, DeepSeek. Cheaper than OpenAI.",
      "intent": [
        "together AI",
        "open source LLM",
        "cheap inference",
        "Together AI API"
      ],
      "endpoint": "POST https://api.together.xyz/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "description": "meta-llama/Llama-3.2-90B-Vision-Instruct-Turbo, mistralai/Mixtral-8x7B-Instruct-v0.1, Qwen/Qwen2.5-72B-Instruct-Turbo, deepseek-ai/DeepSeek-R1",
          "required": true
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "temperature": {
          "type": "float",
          "default": 0.7
        },
        "max_tokens": {
          "type": "integer",
          "required": false
        },
        "stream": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "usage.prompt_tokens",
          "usage.completion_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "embeddings",
      "description_for_ai": "Generate text embeddings on Together AI with open source models.",
      "intent": [
        "Together AI embeddings",
        "open source embeddings",
        "embeddings cheap",
        "эмбеддинги Together AI"
      ],
      "endpoint": "POST https://api.together.xyz/v1/embeddings",
      "input": {
        "model": {
          "type": "string",
          "description": "BAAI/bge-base-en-v1.5, togethercomputer/m2-bert-80M-8k-retrieval",
          "required": true
        },
        "input": {
          "type": "string or array",
          "required": true
        }
      },
      "output": {
        "type": "embeddings",
        "fields": [
          "data[0].embedding",
          "usage.total_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "image_generation",
      "description_for_ai": "Generate images with open source models on Together AI: FLUX, SDXL.",
      "intent": [
        "image generation Together AI",
        "FLUX API",
        "open source image AI",
        "генерация изображений Together AI"
      ],
      "endpoint": "POST https://api.together.xyz/v1/images/generations",
      "input": {
        "model": {
          "type": "string",
          "description": "black-forest-labs/FLUX.1-schnell-Free, black-forest-labs/FLUX.1.1-pro",
          "required": true
        },
        "prompt": {
          "type": "string",
          "required": true
        },
        "n": {
          "type": "integer",
          "default": 1
        },
        "width": {
          "type": "integer",
          "default": 1024
        },
        "height": {
          "type": "integer",
          "default": 1024
        },
        "steps": {
          "type": "integer",
          "required": false
        },
        "seed": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "data[0].url",
          "data[0].b64_json"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_models",
      "description_for_ai": "List all available models on Together AI.",
      "intent": [
        "Together AI models",
        "available models",
        "open source models list",
        "список моделей Together AI"
      ],
      "endpoint": "GET https://api.together.xyz/v1/models",
      "input": {},
      "output": {
        "type": "list<model>",
        "fields": [
          "[0].id",
          "[0].display_name",
          "[0].type",
          "[0].context_length",
          "[0].pricing.input"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "fine_tune",
      "description_for_ai": "Fine-tune an open source model on your own data using Together AI.",
      "intent": [
        "fine tune LLM",
        "custom model",
        "train model",
        "обучение модели Together AI"
      ],
      "endpoint": "POST https://api.together.xyz/v1/fine-tunes",
      "input": {
        "training_file": {
          "type": "string",
          "description": "File ID of training data (JSONL format)",
          "required": true
        },
        "model": {
          "type": "string",
          "description": "Base model to fine-tune",
          "required": true
        },
        "n_epochs": {
          "type": "integer",
          "description": "Training epochs",
          "default": 3
        },
        "batch_size": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "fine_tune",
        "fields": [
          "id",
          "status",
          "model_output_name",
          "created_at"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "openai_compat": "100% OpenAI SDK compatible — change base_url and model name only.",
    "pricing": "10-50x cheaper than OpenAI for equivalent open-source models."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}