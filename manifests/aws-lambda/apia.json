{
  "apia": "1.0",
  "service": {
    "id": "aws-lambda",
    "name": "AWS Lambda API",
    "description_for_ai": "Serverless compute. Run code without servers. Pay per 100ms execution. 1M free invocations/month forever. Supports Node.js, Python, Java, Go, Ruby. Use for event-driven functions, APIs, automation, processing.",
    "url": "https://aws.amazon.com/lambda",
    "api_base": "https://lambda.{region}.amazonaws.com",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.aws.amazon.com/lambda/latest/dg/API_Reference.html"
  },
  "auth": {
    "type": "aws_sig_v4",
    "anonymous_access": false,
    "how_to_get": "AWS account at https://aws.amazon.com",
    "cost": "Free forever: 1M requests/month, 400K GB-seconds/month"
  },
  "capabilities": [
    {
      "id": "invoke_function",
      "description_for_ai": "Invoke an AWS Lambda function synchronously or asynchronously.",
      "intent": [
        "invoke Lambda",
        "run Lambda function",
        "call AWS function",
        "вызвать Lambda"
      ],
      "endpoint": "POST https://lambda.{region}.amazonaws.com/2015-03-31/functions/{FunctionName}/invocations",
      "input": {
        "FunctionName": {
          "type": "string",
          "description": "Function name, ARN, or partial ARN",
          "required": true
        },
        "Payload": {
          "type": "object",
          "description": "JSON input to the function",
          "required": false
        },
        "InvocationType": {
          "type": "string",
          "description": "RequestResponse (sync), Event (async), DryRun",
          "default": "RequestResponse"
        },
        "LogType": {
          "type": "string",
          "description": "None or Tail (returns last 4KB of logs)",
          "default": "None"
        }
      },
      "output": {
        "type": "response",
        "fields": [
          "StatusCode (200 for sync, 202 for async)",
          "Payload (function response)",
          "LogResult (base64 logs if Tail)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_functions",
      "description_for_ai": "List all Lambda functions in an AWS account.",
      "intent": [
        "list Lambda functions",
        "AWS functions",
        "my Lambda functions",
        "функции Lambda"
      ],
      "endpoint": "GET https://lambda.{region}.amazonaws.com/2015-03-31/functions/",
      "input": {
        "FunctionVersion": {
          "type": "string",
          "description": "ALL to include versions",
          "required": false
        },
        "MaxItems": {
          "type": "integer",
          "default": 50
        }
      },
      "output": {
        "type": "list<function>",
        "fields": [
          "Functions[0].FunctionName",
          "Functions[0].Runtime",
          "Functions[0].LastModified",
          "Functions[0].Description"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_function_code",
      "description_for_ai": "Deploy new code to a Lambda function from a ZIP or S3.",
      "intent": [
        "deploy Lambda",
        "update Lambda code",
        "Lambda deployment",
        "обновить код Lambda"
      ],
      "endpoint": "PUT https://lambda.{region}.amazonaws.com/2015-03-31/functions/{FunctionName}/code",
      "input": {
        "FunctionName": {
          "type": "string",
          "required": true
        },
        "ZipFile": {
          "type": "binary",
          "description": "Base64-encoded ZIP file",
          "required": false
        },
        "S3Bucket": {
          "type": "string",
          "description": "S3 bucket with code",
          "required": false
        },
        "S3Key": {
          "type": "string",
          "description": "S3 object key",
          "required": false
        }
      },
      "output": {
        "type": "function",
        "fields": [
          "FunctionName",
          "LastModified",
          "CodeSize",
          "Version"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_function_logs",
      "description_for_ai": "Get CloudWatch logs for a Lambda function.",
      "intent": [
        "Lambda logs",
        "CloudWatch Lambda",
        "function errors",
        "логи Lambda"
      ],
      "endpoint": "GET https://logs.{region}.amazonaws.com/log-groups?logGroupNamePrefix=/aws/lambda/{FunctionName}",
      "input": {
        "FunctionName": {
          "type": "string",
          "required": true
        },
        "startTime": {
          "type": "integer",
          "description": "Millisecond timestamp",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 50
        }
      },
      "output": {
        "type": "list<log>",
        "fields": [
          "events[0].message",
          "events[0].timestamp"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_event_source",
      "description_for_ai": "Map a Lambda function to trigger from SQS, DynamoDB Streams, or Kinesis.",
      "intent": [
        "Lambda trigger",
        "event source Lambda",
        "SQS to Lambda",
        "триггер Lambda"
      ],
      "endpoint": "POST https://lambda.{region}.amazonaws.com/2015-03-31/event-source-mappings/",
      "input": {
        "EventSourceArn": {
          "type": "string",
          "description": "ARN of SQS queue, DynamoDB stream, or Kinesis stream",
          "required": true
        },
        "FunctionName": {
          "type": "string",
          "required": true
        },
        "BatchSize": {
          "type": "integer",
          "default": 10
        },
        "Enabled": {
          "type": "boolean",
          "default": true
        }
      },
      "output": {
        "type": "mapping",
        "fields": [
          "UUID",
          "EventSourceArn",
          "FunctionArn",
          "State"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "sdk": "Use AWS SDK (boto3/aws-sdk) for easier auth. Raw HTTP requires SigV4 signing.",
    "free_forever": "1M invocations/month free forever — not just trial. Best serverless free tier.",
    "cold_start": "First invocation after idle period has ~100ms cold start. Provisioned concurrency eliminates this."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}