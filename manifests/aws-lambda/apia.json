{
  "apia": "1.0",
  "service": {
    "id": "aws-lambda",
    "name": "AWS Lambda API",
    "description_for_ai": "Serverless compute. Run code without servers. Pay per 100ms execution. 1M free invocations/month forever. Supports Node.js, Python, Java, Go, Ruby. Use for event-driven functions, APIs, automation, processing.",
    "url": "https://aws.amazon.com/lambda",
    "api_base": "https://lambda.{region}.amazonaws.com",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.aws.amazon.com/lambda/latest/dg/API_Reference.html"
  },
  "auth": {
    "type": "aws_sig_v4",
    "anonymous_access": false,
    "how_to_get": "AWS account at https://aws.amazon.com",
    "cost": "Free forever: 1M requests/month, 400K GB-seconds/month"
  },
  "capabilities": [
    {
      "id": "invoke_function",
      "description_for_ai": "Invoke an AWS Lambda function synchronously or asynchronously.",
      "intent": [
        "invoke Lambda",
        "call function AWS",
        "run serverless function",
        "вызов Lambda функции"
      ],
      "endpoint": "POST https://lambda.{region}.amazonaws.com/2015-03-31/functions/{FunctionName}/invocations",
      "input": {
        "FunctionName": {
          "type": "string",
          "description": "Function name, ARN, or partial ARN",
          "required": true
        },
        "Payload": {
          "type": "object",
          "description": "JSON payload passed to the function",
          "required": false
        },
        "InvocationType": {
          "type": "string",
          "description": "RequestResponse (sync), Event (async), DryRun",
          "default": "RequestResponse"
        },
        "LogType": {
          "type": "string",
          "description": "Tail to get logs in response",
          "required": false
        }
      },
      "output": {
        "type": "invocation",
        "fields": [
          "StatusCode",
          "Payload (function return value)",
          "LogResult (base64 logs if requested)",
          "FunctionError"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_functions",
      "description_for_ai": "List all Lambda functions in an account/region.",
      "intent": [
        "list Lambda functions",
        "AWS functions",
        "serverless functions list",
        "список Lambda функций"
      ],
      "endpoint": "GET https://lambda.{region}.amazonaws.com/2015-03-31/functions",
      "input": {
        "MaxItems": {
          "type": "integer",
          "default": 50
        },
        "Marker": {
          "type": "string",
          "description": "Pagination token",
          "required": false
        }
      },
      "output": {
        "type": "list<function>",
        "fields": [
          "Functions[0].FunctionName",
          "Functions[0].Runtime",
          "Functions[0].Handler",
          "Functions[0].LastModified",
          "Functions[0].MemorySize"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_function",
      "description_for_ai": "Create a new Lambda function from a ZIP file or container image.",
      "intent": [
        "create Lambda function",
        "deploy serverless",
        "new function AWS",
        "создать Lambda функцию"
      ],
      "endpoint": "POST https://lambda.{region}.amazonaws.com/2015-03-31/functions",
      "input": {
        "FunctionName": {
          "type": "string",
          "required": true
        },
        "Runtime": {
          "type": "string",
          "description": "python3.12, nodejs20.x, java21, go1.x, dotnet8",
          "required": true
        },
        "Role": {
          "type": "string",
          "description": "IAM role ARN",
          "required": true
        },
        "Handler": {
          "type": "string",
          "description": "Function handler e.g. index.handler",
          "required": true
        },
        "Code": {
          "type": "object",
          "description": "{ZipFile: 'base64'} or {S3Bucket, S3Key} or {ImageUri}",
          "required": true
        },
        "MemorySize": {
          "type": "integer",
          "description": "128-10240 MB",
          "default": 128
        },
        "Timeout": {
          "type": "integer",
          "description": "Seconds 1-900",
          "default": 3
        }
      },
      "output": {
        "type": "function",
        "fields": [
          "FunctionArn",
          "FunctionName",
          "State",
          "Runtime"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_function_code",
      "description_for_ai": "Update Lambda function code by uploading new ZIP or pointing to S3.",
      "intent": [
        "update Lambda code",
        "deploy new version",
        "redeploy Lambda",
        "обновить код Lambda"
      ],
      "endpoint": "PUT https://lambda.{region}.amazonaws.com/2015-03-31/functions/{FunctionName}/code",
      "input": {
        "FunctionName": {
          "type": "string",
          "required": true
        },
        "ZipFile": {
          "type": "string",
          "description": "Base64-encoded ZIP file",
          "required": false
        },
        "S3Bucket": {
          "type": "string",
          "required": false
        },
        "S3Key": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "function",
        "fields": [
          "FunctionArn",
          "CodeSize",
          "LastModified",
          "Version"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_function_logs",
      "description_for_ai": "Get recent execution logs for a Lambda function from CloudWatch.",
      "intent": [
        "Lambda logs",
        "function errors",
        "execution log Lambda",
        "логи Lambda функции"
      ],
      "endpoint": "GET https://logs.{region}.amazonaws.com/?Action=FilterLogEvents",
      "input": {
        "logGroupName": {
          "type": "string",
          "description": "/aws/lambda/{FunctionName}",
          "required": true
        },
        "startTime": {
          "type": "integer",
          "description": "Unix timestamp ms",
          "required": false
        },
        "filterPattern": {
          "type": "string",
          "description": "Filter: ERROR, REPORT, or custom pattern",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 50
        }
      },
      "output": {
        "type": "logs",
        "fields": [
          "events[0].message",
          "events[0].timestamp"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "sdk": "Use AWS SDK (boto3/aws-sdk) for easier auth. Raw HTTP requires SigV4 signing.",
    "free_forever": "1M invocations/month free forever — not just trial. Best serverless free tier.",
    "cold_start": "First invocation after idle period has ~100ms cold start. Provisioned concurrency eliminates this."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}