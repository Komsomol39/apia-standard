{
  "apia": "1.0",
  "service": {
    "id": "football-data",
    "name": "Football-Data.org API",
    "description_for_ai": "Free football (soccer) data API. Live scores, standings, fixtures, team and player data for top European leagues and international competitions. Free tier: 10 req/min. No credit card needed.",
    "url": "https://football-data.org",
    "api_base": "https://api.football-data.org/v4",
    "category": "sports_football",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.football-data.org/general/v4/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "X-Auth-Token: ...",
    "how_to_get": "Free key at https://www.football-data.org/client/register",
    "cost": "Free: 10 req/min. Paid from $9/month for all competitions"
  },
  "capabilities": [
    {
      "id": "get_matches",
      "description_for_ai": "Get football match results and upcoming fixtures. Filter by competition, team, date range.",
      "intent": [
        "football scores",
        "soccer results",
        "match fixtures",
        "Premier League scores",
        "Champions League",
        "football today",
        "результаты футбол"
      ],
      "endpoint": "GET https://api.football-data.org/v4/matches",
      "input": {
        "competitions": {
          "type": "string",
          "description": "Competition codes: PL=Premier League, BL1=Bundesliga, SA=Serie A, PD=La Liga, CL=Champions League",
          "required": false
        },
        "dateFrom": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        },
        "dateTo": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        },
        "status": {
          "type": "string",
          "description": "SCHEDULED, LIVE, IN_PLAY, PAUSED, FINISHED",
          "required": false
        }
      },
      "output": {
        "type": "list<match>",
        "fields": [
          "homeTeam.name",
          "awayTeam.name",
          "score.fullTime.home",
          "score.fullTime.away",
          "status",
          "utcDate",
          "competition.name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_standings",
      "description_for_ai": "Get current league standings table with points, goals, wins, losses.",
      "intent": [
        "league table",
        "standings",
        "who is first",
        "points table",
        "Premier League table",
        "таблица чемпионат"
      ],
      "endpoint": "GET https://api.football-data.org/v4/competitions/{code}/standings",
      "input": {
        "code": {
          "type": "string",
          "description": "Competition code: PL, BL1, SA, PD, FL1, DED, CL",
          "required": true
        },
        "season": {
          "type": "integer",
          "description": "Year e.g. 2025",
          "required": false
        }
      },
      "output": {
        "type": "standings",
        "fields": [
          "standings[0].table[].team.name",
          "standings[0].table[].points",
          "standings[0].table[].playedGames",
          "standings[0].table[].won",
          "standings[0].table[].draw",
          "standings[0].table[].lost",
          "standings[0].table[].goalsFor"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "free_competitions": "Free tier: PL, BL1, FL1, PD, SA, CL, WC. Other competitions need paid tier.",
    "live_scores": "LIVE and IN_PLAY status filters give current live matches."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}