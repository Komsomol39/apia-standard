{
  "apia": "1.0",
  "service": {
    "id": "apollo-io",
    "name": "Apollo.io API",
    "description_for_ai": "Apollo.io — B2B sales intelligence platform with 265M+ contacts and 70M+ companies. Verified emails, direct dials, LinkedIn URLs, technographic data, buying intent signals. Used by 10,000+ sales teams. Sequences, email tracking, and CRM sync included. Best for outbound sales at scale.",
    "url": "https://apollo.io",
    "api_base": "https://api.apollo.io/v1",
    "category": "sales_intelligence",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://apolloio.github.io/apollo-api-docs/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "x-api-key: {api_key}",
    "how_to_get": "Settings → API keys",
    "cost": "Free: 50 credits/month. Basic: $59/month"
  },
  "capabilities": [
    {
      "id": "people_search",
      "description_for_ai": "Search 265M+ B2B contacts with advanced filters: job title, seniority, company size, industry, location. Returns verified emails and phone numbers.",
      "intent": [
        "find contacts",
        "B2B leads",
        "sales prospects",
        "decision makers",
        "CXO contacts",
        "VP contacts"
      ],
      "endpoint": "POST https://api.apollo.io/v1/mixed_people/search",
      "input": {
        "person_titles": {
          "type": "array",
          "description": "Job titles to target: ['CEO', 'CTO', 'VP Engineering', 'Director of Marketing']",
          "required": false
        },
        "person_seniority_levels": {
          "type": "array",
          "description": "Seniority: ['c_suite', 'vp', 'director', 'manager', 'individual_contributor']",
          "required": false
        },
        "organization_locations": {
          "type": "array",
          "description": "Company locations: ['United States', 'California', 'New York City']",
          "required": false
        },
        "person_locations": {
          "type": "array",
          "description": "Person locations: ['San Francisco, California', 'London, England']",
          "required": false
        },
        "organization_industry_tag_ids": {
          "type": "array",
          "description": "Industry IDs — get from /industries endpoint. E.g. 'technology', 'financial_services'",
          "required": false
        },
        "organization_num_employees_ranges": {
          "type": "array",
          "description": "Company size ranges: ['1,10', '11,50', '51,200', '201,1000', '1001,10000', '10001,99999']",
          "required": false
        },
        "q_organization_keyword_tags": {
          "type": "array",
          "description": "Company keyword tags: ['SaaS', 'artificial intelligence', 'fintech']",
          "required": false
        },
        "page": {
          "type": "integer",
          "description": "Page number (1-indexed)",
          "default": 1
        },
        "per_page": {
          "type": "integer",
          "description": "Results per page, max 100",
          "default": 25
        }
      },
      "output": {
        "type": "list<person>",
        "fields": [
          "people[0].name",
          "people[0].title",
          "people[0].email",
          "people[0].email_status",
          "people[0].phone_numbers[0].raw_number",
          "people[0].organization.name",
          "people[0].organization.website_url",
          "people[0].linkedin_url",
          "pagination.total_entries"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "enrich_person",
      "description_for_ai": "Enrich a person profile from Apollo database: get verified email, direct phone, LinkedIn URL, job title, and company from name and company/domain.",
      "intent": [
        "professional contact",
        "get phone",
        "get phone number",
        "contact data",
        "find email",
        "lead enrichment",
        "enrich contact",
        "find email from name"
      ],
      "endpoint": "POST https://api.apollo.io/v1/people/match",
      "input": {
        "name": {
          "type": "string",
          "required": false,
          "description": "Name identifier"
        },
        "organization_name": {
          "type": "string",
          "required": false
        },
        "domain": {
          "type": "string",
          "required": false
        },
        "linkedin_url": {
          "type": "string",
          "required": false
        },
        "email": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "person",
        "fields": [
          "person.name",
          "person.email",
          "person.phone_numbers",
          "person.title",
          "person.organization.name",
          "person.linkedin_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}