{
  "apia": "1.0",
  "service": {
    "id": "apollo-io",
    "name": "Apollo.io API",
    "description_for_ai": "B2B sales intelligence and engagement platform. 265M+ contacts, 70M+ companies with email, phone, LinkedIn. Sequence automation, email tracking. Use for B2B prospecting, sales outreach, lead enrichment.",
    "url": "https://apollo.io",
    "api_base": "https://api.apollo.io/v1",
    "category": "sales_intelligence",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://apolloio.github.io/apollo-api-docs/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "x-api-key: {api_key}",
    "how_to_get": "Settings → API keys",
    "cost": "Free: 50 credits/month. Basic: $59/month"
  },
  "capabilities": [
    {
      "id": "people_search",
      "description_for_ai": "Search for people/contacts with filters: company, title, location, industry, seniority level.",
      "intent": [
        "find contacts",
        "B2B leads",
        "sales prospects",
        "decision makers",
        "CXO contacts",
        "VP contacts"
      ],
      "endpoint": "POST https://api.apollo.io/v1/mixed_people/search",
      "input": {
        "person_titles": {
          "type": "array",
          "description": "Job titles e.g. [CEO, CTO, VP Engineering]",
          "required": false
        },
        "person_locations": {
          "type": "array",
          "description": "Location filters e.g. [United States, California]",
          "required": false
        },
        "organization_locations": {
          "type": "array",
          "required": false
        },
        "organization_industry_tag_ids": {
          "type": "array",
          "required": false
        },
        "page": {
          "type": "integer",
          "default": 1
        },
        "per_page": {
          "type": "integer",
          "default": 25
        }
      },
      "output": {
        "type": "list<person>",
        "fields": [
          "people[0].name",
          "people[0].title",
          "people[0].email",
          "people[0].phone_numbers[0].raw_number",
          "people[0].organization.name",
          "people[0].linkedin_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "enrich_person",
      "description_for_ai": "Enrich a person profile with email, phone, LinkedIn from name and company.",
      "intent": [
        "enrich contact",
        "find email",
        "get phone",
        "lead enrichment",
        "contact data"
      ],
      "endpoint": "POST https://api.apollo.io/v1/people/match",
      "input": {
        "name": {
          "type": "string",
          "required": false
        },
        "organization_name": {
          "type": "string",
          "required": false
        },
        "domain": {
          "type": "string",
          "required": false
        },
        "linkedin_url": {
          "type": "string",
          "required": false
        },
        "email": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "person",
        "fields": [
          "person.name",
          "person.email",
          "person.phone_numbers",
          "person.title",
          "person.organization.name",
          "person.linkedin_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}