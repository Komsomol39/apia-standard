{
  "apia": "1.0",
  "service": {
    "id": "apollo-io",
    "name": "Apollo.io API",
    "description_for_ai": "Apollo.io — B2B sales intelligence platform with 265M+ contacts and 70M+ companies. Verified emails, direct dials, LinkedIn URLs, technographic data, buying intent signals. Used by 10,000+ sales teams. Sequences, email tracking, and CRM sync included. Best for outbound sales at scale.",
    "url": "https://apollo.io",
    "api_base": "https://api.apollo.io/v1",
    "category": "business",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://apolloio.github.io/apollo-api-docs/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "x-api-key: {api_key}",
    "how_to_get": "Settings → API keys",
    "cost": "Free: 50 credits/month. Basic: $59/month"
  },
  "capabilities": [
    {
      "id": "search_people",
      "description_for_ai": "Search Apollo's database of 275M+ people by title, company, location, and industry.",
      "intent": [
        "find leads",
        "prospect search",
        "people search Apollo",
        "поиск контактов Apollo"
      ],
      "endpoint": "POST https://api.apollo.io/api/v1/mixed_people/search",
      "input": {
        "person_titles": {
          "type": "array",
          "description": "Job titles: ['CEO', 'CTO', 'VP Sales']",
          "required": false
        },
        "organization_domains": {
          "type": "array",
          "description": "Company domains: ['google.com', 'apple.com']",
          "required": false
        },
        "person_locations": {
          "type": "array",
          "description": "Locations: ['San Francisco, CA', 'New York, NY']",
          "required": false
        },
        "q_keywords": {
          "type": "string",
          "description": "Keyword search",
          "required": false
        },
        "page": {
          "type": "integer",
          "default": 1
        },
        "per_page": {
          "type": "integer",
          "default": 25
        }
      },
      "output": {
        "type": "list<person>",
        "fields": [
          "people[0].id",
          "people[0].name",
          "people[0].title",
          "people[0].email",
          "people[0].organization.name",
          "people[0].linkedin_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "enrich_person",
      "description_for_ai": "Enrich a person's data with email, phone, LinkedIn, company, and more.",
      "intent": [
        "enrich contact",
        "find email",
        "contact data enrichment",
        "обогащение данных Apollo"
      ],
      "endpoint": "POST https://api.apollo.io/api/v1/people/match",
      "input": {
        "first_name": {
          "type": "string",
          "required": false
        },
        "last_name": {
          "type": "string",
          "required": false
        },
        "email": {
          "type": "string",
          "required": false
        },
        "organization_name": {
          "type": "string",
          "required": false
        },
        "domain": {
          "type": "string",
          "description": "Company domain for better matching",
          "required": false
        },
        "linkedin_url": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "person",
        "fields": [
          "person.name",
          "person.email",
          "person.phone_numbers[0].raw_number",
          "person.title",
          "person.organization.name",
          "person.linkedin_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_organizations",
      "description_for_ai": "Search companies in Apollo by industry, size, revenue, and tech stack.",
      "intent": [
        "company search",
        "find companies",
        "B2B prospecting",
        "поиск компаний Apollo"
      ],
      "endpoint": "POST https://api.apollo.io/api/v1/mixed_companies/search",
      "input": {
        "q_organization_keyword_tags": {
          "type": "array",
          "description": "Industry tags",
          "required": false
        },
        "organization_num_employees_ranges": {
          "type": "array",
          "description": "Size ranges: ['1,10', '11,50', '51,200']",
          "required": false
        },
        "organization_locations": {
          "type": "array",
          "required": false
        },
        "currently_using_any_of_technology_uids": {
          "type": "array",
          "description": "Tech stack filter",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 25
        }
      },
      "output": {
        "type": "list<org>",
        "fields": [
          "organizations[0].id",
          "organizations[0].name",
          "organizations[0].website_url",
          "organizations[0].num_employees",
          "organizations[0].industry"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_contact",
      "description_for_ai": "Add a contact to Apollo CRM.",
      "intent": [
        "add contact Apollo",
        "create lead",
        "save contact",
        "добавить контакт Apollo"
      ],
      "endpoint": "POST https://api.apollo.io/api/v1/contacts",
      "input": {
        "first_name": {
          "type": "string",
          "required": true
        },
        "last_name": {
          "type": "string",
          "required": true
        },
        "email": {
          "type": "string",
          "required": false
        },
        "organization_name": {
          "type": "string",
          "required": false
        },
        "title": {
          "type": "string",
          "required": false
        },
        "phone_numbers": {
          "type": "array",
          "description": "[{raw_number: '+1...', dnc_status: 'not_marked'}]",
          "required": false
        }
      },
      "output": {
        "type": "contact",
        "fields": [
          "contact.id",
          "contact.name",
          "contact.email"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_sequence",
      "description_for_ai": "Add contacts to an email sequence for automated outreach.",
      "intent": [
        "email sequence",
        "sales outreach",
        "automated emails Apollo",
        "автоматическая рассылка Apollo"
      ],
      "endpoint": "POST https://api.apollo.io/api/v1/emailer_campaigns/{emailer_campaign_id}/add_contact_ids",
      "input": {
        "emailer_campaign_id": {
          "type": "string",
          "required": true
        },
        "contact_ids": {
          "type": "array",
          "description": "Array of contact IDs to add",
          "required": true
        },
        "send_email_from_email_account_id": {
          "type": "string",
          "description": "Email account ID to send from",
          "required": true
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "contacts[0].id",
          "contacts[0].emailer_campaign_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}