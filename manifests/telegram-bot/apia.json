{
  "apia": "1.0",
  "service": {
    "id": "telegram-bot",
    "name": "Telegram Bot API",
    "description_for_ai": "Create bots that send messages, handle commands, and interact with Telegram users. 950M+ users. Free, fast, no rate limits for personal bots. The simplest way to build a conversational interface. Use to send notifications, create interactive bots, receive commands from users via Telegram.",
    "url": "https://telegram.org",
    "api_base": "https://api.telegram.org/bot{token}",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://core.telegram.org/bots/api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_location": "path",
    "how_to_get": "Message @BotFather on Telegram → /newbot → get token instantly. Free forever.",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "send_message",
      "description_for_ai": "Send a text message to a Telegram user or group chat. Supports Markdown/HTML formatting, reply keyboards, inline keyboards.",
      "intent": [
        "send telegram message",
        "telegram notify",
        "message user telegram",
        "telegram bot send",
        "отправить сообщение telegram"
      ],
      "endpoint": "POST https://api.telegram.org/bot{token}/sendMessage",
      "input": {
        "chat_id": {
          "type": "string",
          "description": "Telegram chat ID or @username",
          "required": true
        },
        "text": {
          "type": "string",
          "description": "Message text, max 4096 chars",
          "required": true
        },
        "parse_mode": {
          "type": "string",
          "description": "HTML or MarkdownV2 for formatting",
          "required": false
        },
        "reply_markup": {
          "type": "object",
          "description": "InlineKeyboardMarkup or ReplyKeyboardMarkup for buttons",
          "required": false
        },
        "reply_to_message_id": {
          "type": "integer",
          "description": "Reply to specific message",
          "required": false
        },
        "disable_notification": {
          "type": "boolean",
          "description": "Send silently (no notification sound)",
          "default": false
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "ok",
          "result.message_id",
          "result.chat.id",
          "result.text",
          "result.date"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_photo",
      "description_for_ai": "Send a photo to Telegram chat. Can use URL, file_id (for previously sent file), or upload bytes.",
      "intent": [
        "send photo telegram",
        "telegram image",
        "send picture",
        "photo bot",
        "отправить фото telegram"
      ],
      "endpoint": "POST https://api.telegram.org/bot{token}/sendPhoto",
      "input": {
        "chat_id": {
          "type": "string",
          "required": true
        },
        "photo": {
          "type": "string",
          "description": "File URL, file_id, or multipart upload",
          "required": true
        },
        "caption": {
          "type": "string",
          "description": "Photo caption, max 1024 chars",
          "required": false
        },
        "parse_mode": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "result.message_id",
          "result.photo[-1].file_id",
          "result.caption"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_document",
      "description_for_ai": "Send a file (PDF, DOCX, CSV, ZIP) to Telegram chat. Max 50MB.",
      "intent": [
        "send file telegram",
        "telegram document",
        "send pdf telegram",
        "attach file",
        "отправить файл telegram"
      ],
      "endpoint": "POST https://api.telegram.org/bot{token}/sendDocument",
      "input": {
        "chat_id": {
          "type": "string",
          "required": true
        },
        "document": {
          "type": "string",
          "description": "File URL, file_id, or multipart upload",
          "required": true
        },
        "caption": {
          "type": "string",
          "required": false
        },
        "parse_mode": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "result.message_id",
          "result.document.file_id",
          "result.document.file_name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_updates",
      "description_for_ai": "Get pending updates (messages, callbacks, inline queries) via long polling. Use for simple bots without webhooks. Call repeatedly to receive messages.",
      "intent": [
        "receive messages telegram",
        "get telegram messages",
        "polling bot",
        "check messages",
        "получить сообщения telegram"
      ],
      "endpoint": "GET https://api.telegram.org/bot{token}/getUpdates",
      "input": {
        "offset": {
          "type": "integer",
          "description": "Identifier of the first update to return. Pass last update_id + 1 to confirm previous updates.",
          "required": false
        },
        "limit": {
          "type": "integer",
          "description": "Max updates to return 1-100",
          "default": 100
        },
        "timeout": {
          "type": "integer",
          "description": "Long polling timeout in seconds. 0 = short poll",
          "default": 30
        },
        "allowed_updates": {
          "type": "array",
          "description": "['message', 'callback_query', 'inline_query'] — filter update types",
          "required": false
        }
      },
      "output": {
        "type": "updates",
        "fields": [
          "result[0].update_id",
          "result[0].message.text",
          "result[0].message.from.id",
          "result[0].callback_query.data"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "set_webhook",
      "description_for_ai": "Set a webhook URL — Telegram will POST updates to your server. Preferred over getUpdates for production. Must be HTTPS.",
      "intent": [
        "telegram webhook",
        "set webhook",
        "receive updates server",
        "production bot setup",
        "настроить webhook telegram"
      ],
      "endpoint": "POST https://api.telegram.org/bot{token}/setWebhook",
      "input": {
        "url": {
          "type": "string",
          "description": "HTTPS URL to receive updates. Empty string to remove webhook.",
          "required": true
        },
        "secret_token": {
          "type": "string",
          "description": "Secret token sent in X-Telegram-Bot-Api-Secret-Token header to verify requests",
          "required": false
        },
        "allowed_updates": {
          "type": "array",
          "description": "Update types to receive",
          "required": false
        },
        "max_connections": {
          "type": "integer",
          "description": "Max simultaneous HTTPS connections 1-100",
          "default": 40
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "ok",
          "result",
          "description"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "answer_callback_query",
      "description_for_ai": "Respond to a button click (callback query) from an inline keyboard. Required to clear the loading state after button press.",
      "intent": [
        "telegram button click",
        "callback query",
        "inline button response",
        "answer button",
        "ответить на кнопку telegram"
      ],
      "endpoint": "POST https://api.telegram.org/bot{token}/answerCallbackQuery",
      "input": {
        "callback_query_id": {
          "type": "string",
          "description": "ID from the callback_query update",
          "required": true
        },
        "text": {
          "type": "string",
          "description": "Notification text to show (0-200 chars). Omit for silent acknowledge.",
          "required": false
        },
        "show_alert": {
          "type": "boolean",
          "description": "Show as alert dialog instead of notification",
          "default": false
        },
        "url": {
          "type": "string",
          "description": "URL to open on client side",
          "required": false
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "ok",
          "result"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "edit_message_text",
      "description_for_ai": "Edit text of a previously sent message. Use to update bot messages without spamming — e.g. update progress, show results inline.",
      "intent": [
        "edit telegram message",
        "update message",
        "change message text",
        "edit bot message",
        "редактировать сообщение telegram"
      ],
      "endpoint": "POST https://api.telegram.org/bot{token}/editMessageText",
      "input": {
        "chat_id": {
          "type": "string",
          "required": false
        },
        "message_id": {
          "type": "integer",
          "description": "ID of the message to edit",
          "required": false
        },
        "inline_message_id": {
          "type": "string",
          "description": "For inline bot messages",
          "required": false
        },
        "text": {
          "type": "string",
          "required": true
        },
        "parse_mode": {
          "type": "string",
          "required": false
        },
        "reply_markup": {
          "type": "object",
          "description": "New inline keyboard",
          "required": false
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "result.message_id",
          "result.text",
          "result.edit_date"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_invoice",
      "description_for_ai": "Send a payment invoice via Telegram Payments. User can pay directly in the Telegram app. Requires payment provider token (Stripe, YooMoney etc.)",
      "intent": [
        "telegram payment",
        "telegram invoice",
        "pay in telegram",
        "telegram shop",
        "оплата через telegram"
      ],
      "endpoint": "POST https://api.telegram.org/bot{token}/sendInvoice",
      "input": {
        "chat_id": {
          "type": "string",
          "required": true
        },
        "title": {
          "type": "string",
          "description": "Product name 1-32 chars",
          "required": true
        },
        "description": {
          "type": "string",
          "description": "Product description 1-255 chars",
          "required": true
        },
        "payload": {
          "type": "string",
          "description": "Internal payload for your system",
          "required": true
        },
        "provider_token": {
          "type": "string",
          "description": "Payment provider token from @BotFather",
          "required": true
        },
        "currency": {
          "type": "string",
          "description": "3-letter ISO 4217 currency code",
          "required": true
        },
        "prices": {
          "type": "array",
          "description": "[{label: 'Product', amount: 1000}] — amount in smallest units",
          "required": true
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "result.message_id",
          "result.invoice.title",
          "result.invoice.total_amount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "botfather": "To create a bot: open Telegram → search @BotFather → send /newbot → choose name → get token. Takes 30 seconds.",
    "chat_id_tip": "To get your own chat_id: send any message to your bot, then call getUpdates — your ID is in message.from.id.",
    "markdown_v2": "MarkdownV2 requires escaping special chars with backslash: . ! - = + | { } # ( ) [ ]. Use HTML mode instead for simplicity.",
    "webhook_vs_polling": "For production use webhook (set once, Telegram pushes updates). For development use getUpdates polling.",
    "russia_note": "Telegram is very popular in Russia and CIS — great alternative to SMS for Russian-speaking users."
  },
  "limits": {
    "messages_per_second": 30,
    "messages_per_minute_per_group": 20,
    "commercial_use": true,
    "attribution_required": false,
    "cost": "Completely free"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}