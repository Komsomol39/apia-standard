{
  "apia": "1.0",
  "service": {
    "id": "mixpanel",
    "name": "Mixpanel API",
    "description_for_ai": "Product analytics platform. Track user events, funnels, retention, cohorts. Understand user behavior in mobile and web apps. Used by Yelp, DocuSign, Expedia. Use for product analytics, funnel analysis, user retention tracking.",
    "url": "https://mixpanel.com",
    "api_base": "https://api.mixpanel.com",
    "category": "product_analytics",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.mixpanel.com/reference/overview"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "Project token for tracking, secret for data export",
    "how_to_get": "Project Settings → Access Keys",
    "cost": "Free: 100M events/month. Growth: $24/month"
  },
  "capabilities": [
    {
      "id": "track_event",
      "description_for_ai": "Track a user event in Mixpanel. Records what users do in your app.",
      "intent": [
        "track event",
        "analytics event",
        "user action",
        "product tracking",
        "event tracking"
      ],
      "endpoint": "POST https://api.mixpanel.com/track",
      "input": {
        "event": {
          "type": "string",
          "description": "Event name e.g. Purchase Completed, Button Clicked",
          "required": true
        },
        "properties": {
          "type": "object",
          "description": "{distinct_id: user123, token: PROJECT_TOKEN, ...custom properties}",
          "required": true
        }
      },
      "output": {
        "type": "success",
        "fields": [
          "status",
          "error"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "export_events",
      "description_for_ai": "Export raw event data for date range. Returns one JSON event per line.",
      "intent": [
        "export analytics",
        "raw events",
        "data export",
        "analytics data"
      ],
      "endpoint": "GET https://data.mixpanel.com/api/2.0/export",
      "input": {
        "from_date": {
          "type": "string",
          "description": "Start date filter: YYYY-MM-DD",
          "required": true
        },
        "to_date": {
          "type": "string",
          "description": "End date filter: YYYY-MM-DD",
          "required": true
        },
        "event": {
          "type": "string",
          "description": "Event name filter",
          "required": false
        }
      },
      "output": {
        "type": "jsonl",
        "fields": [
          "event",
          "properties.distinct_id",
          "properties.time",
          "properties.mp_country_code"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}