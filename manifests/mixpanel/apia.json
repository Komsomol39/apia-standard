{
  "apia": "1.0",
  "service": {
    "id": "mixpanel",
    "name": "Mixpanel API",
    "description_for_ai": "Product analytics platform. Track user events, funnels, retention, cohorts. Understand user behavior in mobile and web apps. Used by Yelp, DocuSign, Expedia. Use for product analytics, funnel analysis, user retention tracking.",
    "url": "https://mixpanel.com",
    "api_base": "https://api.mixpanel.com",
    "category": "analytics",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.mixpanel.com/reference/overview"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "Project token for tracking, secret for data export",
    "how_to_get": "Project Settings → Access Keys",
    "cost": "Free: 100M events/month. Growth: $24/month"
  },
  "capabilities": [
    {
      "id": "track_event",
      "description_for_ai": "Track a user event in Mixpanel. Must send from server or with distinct_id.",
      "intent": [
        "track event Mixpanel",
        "analytics event",
        "user action tracking",
        "аналитика Mixpanel"
      ],
      "endpoint": "POST https://api.mixpanel.com/track",
      "input": {
        "event": {
          "type": "string",
          "required": true
        },
        "properties": {
          "type": "object",
          "description": "{distinct_id: 'user123', token: 'project_token', $os: 'iOS', plan: 'pro', value: 99.99}",
          "required": true
        }
      },
      "output": {
        "type": "status",
        "fields": [
          "1 (success)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "identify_user",
      "description_for_ai": "Create or update a Mixpanel user profile.",
      "intent": [
        "user profile Mixpanel",
        "identify user",
        "set user properties",
        "профиль пользователя Mixpanel"
      ],
      "endpoint": "POST https://api.mixpanel.com/engage#profile-set",
      "input": {
        "records": {
          "type": "array",
          "description": "[{$token: 'project_token', $distinct_id: 'user123', $set: {$name: 'John', $email: 'john@example.com', plan: 'pro'}}]",
          "required": true
        }
      },
      "output": {
        "type": "status",
        "fields": [
          "1 (success)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "query_events",
      "description_for_ai": "Query event data with JQL (JavaScript Query Language) for custom analytics.",
      "intent": [
        "Mixpanel query",
        "analytics query",
        "event data",
        "запрос Mixpanel"
      ],
      "endpoint": "POST https://mixpanel.com/api/2.0/jql",
      "input": {
        "script": {
          "type": "string",
          "description": "JQL script: function main() { return Events({from_date: '2024-01-01', to_date: '2024-01-31', event_selectors: [{event: 'Sign Up'}]}).groupBy([mixpanel.numeric_bucket('$time', mixpanel.daily)], mixpanel.reducer.count()); }",
          "required": true
        }
      },
      "output": {
        "type": "list<result>",
        "fields": [
          "[0].key",
          "[0].value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_funnels",
      "description_for_ai": "Get funnel analysis from Mixpanel — conversion rates between steps.",
      "intent": [
        "funnel Mixpanel",
        "conversion funnel",
        "user journey",
        "воронка Mixpanel"
      ],
      "endpoint": "GET https://mixpanel.com/api/2.0/funnels",
      "input": {
        "funnel_id": {
          "type": "integer",
          "required": true
        },
        "from_date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "to_date": {
          "type": "string",
          "required": true
        },
        "interval": {
          "type": "integer",
          "description": "Days per interval",
          "default": 30
        }
      },
      "output": {
        "type": "funnel",
        "fields": [
          "data.steps[0].event",
          "data.steps[0].count",
          "data.steps[0].conversion_ratio",
          "data.analysis.completion"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_retention",
      "description_for_ai": "Get user retention cohort analysis.",
      "intent": [
        "retention Mixpanel",
        "user retention",
        "cohort analysis",
        "удержание пользователей Mixpanel"
      ],
      "endpoint": "GET https://mixpanel.com/api/2.0/retention",
      "input": {
        "from_date": {
          "type": "string",
          "required": true
        },
        "to_date": {
          "type": "string",
          "required": true
        },
        "born_event": {
          "type": "string",
          "description": "Event defining cohort entry",
          "required": true
        },
        "event": {
          "type": "string",
          "description": "Return event to track retention",
          "required": true
        }
      },
      "output": {
        "type": "retention",
        "fields": [
          "counts[0].first",
          "counts[0].counts (day 1-30 retains)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "export_events",
      "description_for_ai": "Export raw event data from Mixpanel for a date range.",
      "intent": [
        "export events Mixpanel",
        "raw data export",
        "data dump Mixpanel",
        "экспорт данных Mixpanel"
      ],
      "endpoint": "GET https://data.mixpanel.com/api/2.0/export",
      "input": {
        "from_date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "to_date": {
          "type": "string",
          "required": true
        },
        "event": {
          "type": "array",
          "description": "Filter by event names",
          "required": false
        }
      },
      "output": {
        "type": "stream<event>",
        "fields": [
          "Newline-delimited JSON: {event, properties, distinct_id, time}"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}