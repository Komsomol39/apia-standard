{
  "apia": "1.0",
  "service": {
    "id": "mixpanel",
    "name": "Mixpanel API",
    "description_for_ai": "Product analytics platform. Track user events, funnels, retention, cohorts. Understand user behavior in mobile and web apps. Used by Yelp, DocuSign, Expedia. Use for product analytics, funnel analysis, user retention tracking.",
    "url": "https://mixpanel.com",
    "api_base": "https://api.mixpanel.com",
    "category": "analytics",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.mixpanel.com/reference/overview"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "Project token for tracking, secret for data export",
    "how_to_get": "Project Settings → Access Keys",
    "cost": "Free: 100M events/month. Growth: $24/month"
  },
  "capabilities": [
    {
      "id": "track_event",
      "description_for_ai": "Track a user event in Mixpanel for analytics and funnel analysis.",
      "intent": [
        "track event",
        "analytics event",
        "mixpanel track",
        "трекинг события mixpanel"
      ],
      "endpoint": "POST https://api.mixpanel.com/track",
      "input": {
        "data": {
          "type": "string",
          "description": "Base64-encoded JSON: [{event: 'Button Click', properties: {token: 'TOKEN', distinct_id: 'user123', time: 1609459200, page: '/home', $browser: 'Chrome'}}]",
          "required": true
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "1 (success) or 0 (failure)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "query_jql",
      "description_for_ai": "Run JQL (JavaScript Query Language) queries on Mixpanel data for custom reports.",
      "intent": [
        "mixpanel query",
        "event analytics",
        "funnel analysis mixpanel",
        "аналитика mixpanel"
      ],
      "endpoint": "POST https://mixpanel.com/api/2.0/jql",
      "input": {
        "script": {
          "type": "string",
          "description": "JQL script e.g. function main() { return Events({from_date: '2024-01-01', to_date: '2024-01-31', event_selectors: [{event: 'Purchase'}]}).groupBy(['properties.plan'], mixpanel.reducer.count()); }",
          "required": true
        }
      },
      "output": {
        "type": "list<result>",
        "fields": [
          "results (array of {key, value})"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "set_user_profile",
      "description_for_ai": "Create or update a Mixpanel user profile with properties.",
      "intent": [
        "set user mixpanel",
        "user profile analytics",
        "identify user",
        "профиль пользователя mixpanel"
      ],
      "endpoint": "POST https://api.mixpanel.com/engage",
      "input": {
        "data": {
          "type": "string",
          "description": "Base64-encoded JSON: [{$token: 'TOKEN', $distinct_id: 'user123', $set: {$name: 'John Doe', $email: 'john@example.com', plan: 'pro', created_at: '2024-01-15'}}]",
          "required": true
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "1 (success) or 0 (failure)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_event_stats",
      "description_for_ai": "Get aggregated event statistics over a time range using Mixpanel Insights API.",
      "intent": [
        "event stats mixpanel",
        "event count",
        "daily events",
        "статистика событий mixpanel"
      ],
      "endpoint": "GET https://mixpanel.com/api/2.0/events",
      "input": {
        "event": {
          "type": "array",
          "description": "Event names e.g. ['Purchase', 'Sign Up']",
          "required": true
        },
        "type": {
          "type": "string",
          "description": "general or unique",
          "default": "general"
        },
        "unit": {
          "type": "string",
          "description": "minute, hour, day, week, month",
          "default": "day"
        },
        "interval": {
          "type": "integer",
          "description": "Number of units back from now",
          "default": 30
        },
        "from_date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        }
      },
      "output": {
        "type": "stats",
        "fields": [
          "data.series (dates)",
          "data.values.EventName (date→count map)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "create_annotation",
      "description_for_ai": "Create an annotation on a Mixpanel chart to mark important events (deploys, campaigns).",
      "intent": [
        "annotation mixpanel",
        "mark event analytics",
        "milestone mixpanel",
        "аннотация mixpanel"
      ],
      "endpoint": "POST https://mixpanel.com/api/2.0/annotations/create",
      "input": {
        "project_id": {
          "type": "integer",
          "required": true
        },
        "description": {
          "type": "string",
          "required": true
        },
        "date": {
          "type": "string",
          "description": "YYYY-MM-DDTHH:MM:SS",
          "required": true
        }
      },
      "output": {
        "type": "annotation",
        "fields": [
          "annotation.id",
          "annotation.description",
          "annotation.date"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}