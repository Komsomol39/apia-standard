{
  "apia": "1.0",
  "service": {
    "id": "tripadvisor",
    "name": "TripAdvisor Content API",
    "description_for_ai": "Travel reviews and recommendations. Hotels, restaurants, attractions ratings and reviews from 1B+ reviews. Location search, photos, traveler reviews. Use for travel planning, destination info, review aggregation.",
    "url": "https://tripadvisor.com",
    "api_base": "https://api.content.tripadvisor.com/api/v1",
    "category": "transport",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://tripadvisor-content-api.readme.io/reference/overview"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Register at https://tripadvisor-content-api.readme.io",
    "cost": "Free: 5000 req/month. Paid: custom"
  },
  "capabilities": [
    {
      "id": "search_locations",
      "description_for_ai": "Search TripAdvisor for hotels, restaurants, and attractions.",
      "intent": [
        "search TripAdvisor",
        "hotels TripAdvisor",
        "restaurants TripAdvisor",
        "поиск TripAdvisor"
      ],
      "endpoint": "GET https://api.content.tripadvisor.com/api/v1/location/search",
      "input": {
        "searchQuery": {
          "type": "string",
          "required": true
        },
        "category": {
          "type": "string",
          "description": "hotels, restaurants, attractions, geos",
          "required": false
        },
        "language": {
          "type": "string",
          "default": "en"
        }
      },
      "output": {
        "type": "list<location>",
        "fields": [
          "data[0].location_id",
          "data[0].name",
          "data[0].address_obj.address_string",
          "data[0].category.name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_location_details",
      "description_for_ai": "Get full TripAdvisor location details: rating, reviews count, address, hours.",
      "intent": [
        "location details TripAdvisor",
        "hotel details",
        "restaurant info TripAdvisor",
        "детали TripAdvisor"
      ],
      "endpoint": "GET https://api.content.tripadvisor.com/api/v1/location/{locationId}/details",
      "input": {
        "locationId": {
          "type": "string",
          "required": true
        },
        "language": {
          "type": "string",
          "default": "en"
        },
        "currency": {
          "type": "string",
          "default": "USD"
        }
      },
      "output": {
        "type": "location",
        "fields": [
          "name",
          "rating",
          "num_reviews",
          "ranking",
          "price_level",
          "address_obj.address_string",
          "hours.weekday_text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_reviews",
      "description_for_ai": "Get reviews for a TripAdvisor location.",
      "intent": [
        "TripAdvisor reviews",
        "hotel reviews",
        "restaurant reviews",
        "отзывы TripAdvisor"
      ],
      "endpoint": "GET https://api.content.tripadvisor.com/api/v1/location/{locationId}/reviews",
      "input": {
        "locationId": {
          "type": "string",
          "required": true
        },
        "language": {
          "type": "string",
          "default": "en"
        }
      },
      "output": {
        "type": "list<review>",
        "fields": [
          "data[0].id",
          "data[0].rating",
          "data[0].title",
          "data[0].text",
          "data[0].user.username",
          "data[0].published_date"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_photos",
      "description_for_ai": "Get photos for a TripAdvisor location.",
      "intent": [
        "TripAdvisor photos",
        "hotel photos",
        "location images",
        "фото TripAdvisor"
      ],
      "endpoint": "GET https://api.content.tripadvisor.com/api/v1/location/{locationId}/photos",
      "input": {
        "locationId": {
          "type": "string",
          "required": true
        },
        "language": {
          "type": "string",
          "default": "en"
        }
      },
      "output": {
        "type": "list<photo>",
        "fields": [
          "data[0].id",
          "data[0].images.original.url",
          "data[0].images.large.url",
          "data[0].caption"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "nearby_search",
      "description_for_ai": "Find hotels, restaurants, and attractions near GPS coordinates.",
      "intent": [
        "nearby TripAdvisor",
        "places near me",
        "local attractions",
        "рядом TripAdvisor"
      ],
      "endpoint": "GET https://api.content.tripadvisor.com/api/v1/location/nearby_search",
      "input": {
        "latLong": {
          "type": "string",
          "description": "lat,long e.g. 48.8566,2.3522",
          "required": true
        },
        "category": {
          "type": "string",
          "description": "hotels, restaurants, attractions",
          "required": false
        },
        "radius": {
          "type": "integer",
          "default": 5
        },
        "radiusUnit": {
          "type": "string",
          "description": "km or mi",
          "default": "km"
        }
      },
      "output": {
        "type": "list<location>",
        "fields": [
          "data[0].location_id",
          "data[0].name",
          "data[0].address_obj.address_string",
          "data[0].distance_string"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "location_id": "Get location IDs via search_locations first, then use location_id for reviews/photos.",
    "language": "Pass language param for localized names and reviews: en, ru, de, fr, es, it, ja, zh",
    "rate_limits": "Free tier: 5000 requests/month. Headers: X-RateLimit-Limit, X-RateLimit-Remaining.",
    "categories": "Search categories: hotels, restaurants, attractions, geos (cities/regions/countries)"
  }
}