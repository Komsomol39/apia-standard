{
  "apia": "1.0",
  "service": {
    "id": "tripadvisor",
    "name": "TripAdvisor Content API",
    "description_for_ai": "Travel reviews and recommendations. Hotels, restaurants, attractions ratings and reviews from 1B+ reviews. Location search, photos, traveler reviews. Use for travel planning, destination info, review aggregation.",
    "url": "https://tripadvisor.com",
    "api_base": "https://api.content.tripadvisor.com/api/v1",
    "category": "transport",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://tripadvisor-content-api.readme.io/reference/overview"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Register at https://tripadvisor-content-api.readme.io",
    "cost": "Free: 5000 req/month. Paid: custom"
  },
  "capabilities": [
    {
      "id": "search_locations",
      "description_for_ai": "Search TripAdvisor locations: hotels, restaurants, attractions by keyword and location.",
      "intent": [
        "find hotel review",
        "restaurant reviews",
        "tourist attractions",
        "things to do",
        "tripadvisor search",
        "travel recommendations"
      ],
      "endpoint": "GET https://api.content.tripadvisor.com/api/v1/location/search",
      "input": {
        "searchQuery": {
          "type": "string",
          "required": true
        },
        "category": {
          "type": "string",
          "description": "hotels, restaurants, attractions, geos",
          "required": false
        },
        "latLong": {
          "type": "string",
          "description": "lat,lng",
          "required": false
        },
        "language": {
          "type": "string",
          "default": "en",
          "description": "Language code: en, ru, de, fr, es, zh, ja, ko, pt"
        }
      },
      "output": {
        "type": "list<location>",
        "fields": [
          "location_id",
          "name",
          "address_obj.address_string",
          "distance",
          "rating",
          "num_reviews",
          "photo.images.medium.url",
          "web_url"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_location_reviews",
      "description_for_ai": "Get user reviews for a specific TripAdvisor location with rating, text, date, and reviewer info.",
      "intent": [
        "hotel reviews",
        "restaurant reviews",
        "attraction reviews",
        "what do people say"
      ],
      "endpoint": "GET https://api.content.tripadvisor.com/api/v1/location/{locationId}/reviews",
      "input": {
        "locationId": {
          "type": "string",
          "required": true
        },
        "language": {
          "type": "string",
          "default": "en",
          "description": "Language code: en, ru, de, fr, es, zh, ja, ko, pt"
        },
        "limit": {
          "type": "integer",
          "default": 5,
          "description": "Maximum number of results to return"
        }
      },
      "output": {
        "type": "list<review>",
        "fields": [
          "id",
          "rating",
          "title",
          "text",
          "travel_date",
          "user.username",
          "published_date"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "location_id": "Get location IDs via search_locations first, then use location_id for reviews/photos.",
    "language": "Pass language param for localized names and reviews: en, ru, de, fr, es, it, ja, zh",
    "rate_limits": "Free tier: 5000 requests/month. Headers: X-RateLimit-Limit, X-RateLimit-Remaining.",
    "categories": "Search categories: hotels, restaurants, attractions, geos (cities/regions/countries)"
  }
}