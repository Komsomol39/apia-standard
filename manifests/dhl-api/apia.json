{
  "apia": "1.0",
  "service": {
    "id": "dhl-api",
    "name": "DHL Express API",
    "description_for_ai": "DHL international express shipping. Rates, labels, tracking for 220+ countries. Official DHL API. Use for international business shipping, cross-border e-commerce.",
    "url": "https://developer.dhl.com",
    "api_base": "https://express.api.dhl.com/mydhlapi",
    "category": "logistics_shipping",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.dhl.com/api-reference/dhl-express-mydhl-api"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "how_to_get": "Register at https://developer.dhl.com",
    "cost": "Per shipment pricing"
  },
  "capabilities": [
    {
      "id": "get_rates",
      "description_for_ai": "Get DHL Express shipping rates between two cities. Returns available products with price, delivery date, and transit time.",
      "intent": [
        "DHL rates",
        "international shipping",
        "express delivery",
        "DHL price",
        "overseas shipping"
      ],
      "endpoint": "GET https://express.api.dhl.com/mydhlapi/rates",
      "input": {
        "accountNumber": {
          "type": "string",
          "description": "Your DHL account number",
          "required": true
        },
        "originCountryCode": {
          "type": "string",
          "description": "Origin ISO 2-letter country code e.g. RU, DE, US",
          "required": true
        },
        "originCityName": {
          "type": "string",
          "description": "Origin city name e.g. Moscow, Berlin",
          "required": true
        },
        "destinationCountryCode": {
          "type": "string",
          "description": "Destination country code",
          "required": true
        },
        "destinationCityName": {
          "type": "string",
          "required": true
        },
        "weight": {
          "type": "number",
          "description": "Shipment weight in kg",
          "required": true
        },
        "length": {
          "type": "number",
          "description": "Package length in cm",
          "required": true
        },
        "width": {
          "type": "number",
          "description": "Package width in cm",
          "required": true
        },
        "height": {
          "type": "number",
          "description": "Package height in cm",
          "required": true
        },
        "plannedShippingDateAndTime": {
          "type": "string",
          "description": "Pickup date ISO 8601 e.g. 2024-01-15T10:00:00GMT+03:00",
          "required": true
        },
        "isCustomsDeclarable": {
          "type": "boolean",
          "description": "true for international shipments",
          "default": true
        }
      },
      "output": {
        "type": "rates",
        "fields": [
          "products[0].productName",
          "products[0].totalPrice[0].price",
          "products[0].deliveryCapabilities.estimatedDeliveryDateAndTime"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "track_shipment",
      "description_for_ai": "Track a DHL Express shipment by waybill number. Returns current status, location, and full event history.",
      "intent": [
        "track DHL",
        "DHL tracking",
        "where is my DHL package",
        "DHL status"
      ],
      "endpoint": "GET https://express.api.dhl.com/mydhlapi/shipments/{shipmentTrackingNumber}/tracking",
      "input": {
        "shipmentTrackingNumber": {
          "type": "string",
          "description": "DHL waybill/tracking number (10 digits)",
          "required": true
        },
        "trackingView": {
          "type": "string",
          "description": "all-checkpoints for full history or last-checkpoint for latest only",
          "default": "all-checkpoints"
        },
        "levelOfDetail": {
          "type": "string",
          "description": "shipment for basic or all-checkpoints for detailed",
          "default": "all-checkpoints"
        }
      },
      "output": {
        "type": "tracking",
        "fields": [
          "shipments[0].status",
          "shipments[0].events[0].description",
          "shipments[0].events[0].timestamp",
          "shipments[0].estimatedDeliveryDate"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "sandbox": "Test with sandbox API: https://express.api.dhl.com/mydhlapi/test — use test credentials from developer.dhl.com",
    "account": "Production requires a DHL business account number. Apply at dhl.com or through local DHL office.",
    "incoterms": "For customs: add incoterms (DAP most common for ecommerce), description of goods, and declared value."
  }
}