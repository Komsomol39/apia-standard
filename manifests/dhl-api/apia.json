{
  "apia": "1.0",
  "service": {
    "id": "dhl-api",
    "name": "DHL Express API",
    "description_for_ai": "DHL international express shipping. Rates, labels, tracking for 220+ countries. Official DHL API. Use for international business shipping, cross-border e-commerce.",
    "url": "https://developer.dhl.com",
    "api_base": "https://express.api.dhl.com/mydhlapi",
    "category": "logistics",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.dhl.com/api-reference/dhl-express-mydhl-api"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "how_to_get": "Register at https://developer.dhl.com",
    "cost": "Per shipment pricing"
  },
  "capabilities": [
    {
      "id": "track_shipment",
      "description_for_ai": "Track DHL shipment status and location history by tracking number.",
      "intent": [
        "track DHL",
        "DHL tracking",
        "shipment status",
        "отследить DHL",
        "трекинг DHL"
      ],
      "endpoint": "GET https://api-eu.dhl.com/track/shipments",
      "input": {
        "trackingNumber": {
          "type": "string",
          "description": "DHL tracking number(s), comma-separated up to 10",
          "required": true
        },
        "service": {
          "type": "string",
          "description": "DHL Express: express, DHL eCommerce: eCommerce, DHL Parcel: parcel-de",
          "required": false
        },
        "language": {
          "type": "string",
          "description": "en, de, fr, es, ru etc.",
          "default": "en"
        }
      },
      "output": {
        "type": "tracking",
        "fields": [
          "shipments[0].status.status",
          "shipments[0].status.description",
          "shipments[0].status.location.address.addressLocality",
          "shipments[0].events[0].timestamp",
          "shipments[0].estimatedTimeOfDelivery"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_rates",
      "description_for_ai": "Get shipping rates and estimated delivery times from DHL Express.",
      "intent": [
        "DHL rates",
        "shipping cost DHL",
        "DHL quote",
        "стоимость доставки DHL"
      ],
      "endpoint": "GET https://api-eu.dhl.com/rates/v1/rates",
      "input": {
        "originCountryCode": {
          "type": "string",
          "description": "ISO 3166-1 alpha-2 e.g. DE, RU, US",
          "required": true
        },
        "originPostalCode": {
          "type": "string",
          "required": false
        },
        "destinationCountryCode": {
          "type": "string",
          "required": true
        },
        "destinationPostalCode": {
          "type": "string",
          "required": false
        },
        "weight": {
          "type": "float",
          "description": "Weight in kg",
          "required": true
        },
        "length": {
          "type": "float",
          "description": "cm",
          "required": false
        },
        "width": {
          "type": "float",
          "required": false
        },
        "height": {
          "type": "float",
          "required": false
        }
      },
      "output": {
        "type": "rates",
        "fields": [
          "products[0].productName",
          "products[0].totalPrice[0].price",
          "products[0].totalPrice[0].currency",
          "products[0].pickupCapabilities.nextBusinessDay"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_shipment",
      "description_for_ai": "Create a DHL Express shipment and get shipping label.",
      "intent": [
        "create DHL shipment",
        "DHL label",
        "book DHL",
        "создать отправление DHL"
      ],
      "endpoint": "POST https://api-eu.dhl.com/ship/v1/shipments",
      "input": {
        "plannedShippingDateAndTime": {
          "type": "string",
          "description": "ISO 8601 pickup date/time",
          "required": true
        },
        "pickup": {
          "type": "object",
          "description": "{isRequested: true}",
          "required": true
        },
        "productCode": {
          "type": "string",
          "description": "DHL product code e.g. N (domestic), P (express worldwide)",
          "required": true
        },
        "accounts": {
          "type": "array",
          "description": "[{typeCode: shipper, number: 'DHL_ACCOUNT'}]",
          "required": true
        },
        "shipper": {
          "type": "object",
          "description": "{name1, addressLine1, cityName, countryCode, postalCode, phone, email}",
          "required": true
        },
        "consignee": {
          "type": "object",
          "description": "Same fields as shipper",
          "required": true
        },
        "packages": {
          "type": "array",
          "description": "[{weight: 1.5, dimensions: {length: 30, width: 20, height: 10}}]",
          "required": true
        }
      },
      "output": {
        "type": "shipment",
        "fields": [
          "shipmentTrackingNumber",
          "documents[0].content (base64 PDF label)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "find_service_points",
      "description_for_ai": "Find DHL service points (parcel shops, lockers, drop-off points) near a location.",
      "intent": [
        "DHL service point",
        "DHL drop off",
        "parcel locker DHL",
        "пункт выдачи DHL"
      ],
      "endpoint": "GET https://api.dhl.com/location-finder/v1/find-by-geo",
      "input": {
        "latitude": {
          "type": "float",
          "required": true
        },
        "longitude": {
          "type": "float",
          "required": true
        },
        "radius": {
          "type": "integer",
          "description": "Search radius in meters, max 3000",
          "default": 1000
        },
        "limit": {
          "type": "integer",
          "default": 15
        },
        "serviceType": {
          "type": "string",
          "description": "parcel-drop-off, express-drop-off, parcel-pickup",
          "required": false
        }
      },
      "output": {
        "type": "list<location>",
        "fields": [
          "locations[0].place.address.streetAddress",
          "locations[0].place.address.postalCode",
          "locations[0].openingHours",
          "locations[0].location.ids[0].value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "sandbox": "Test with sandbox API: https://express.api.dhl.com/mydhlapi/test — use test credentials from developer.dhl.com",
    "account": "Production requires a DHL business account number. Apply at dhl.com or through local DHL office.",
    "incoterms": "For customs: add incoterms (DAP most common for ecommerce), description of goods, and declared value."
  }
}