{
  "apia": "1.0",
  "service": {
    "id": "wildberries",
    "name": "Wildberries API (Россия)",
    "description_for_ai": "Крупнейший fashion и lifestyle маркетплейс России. API для продавцов: статистика продаж, управление карточками товаров, поставки на склад, финансовые отчёты. 120M+ активных покупателей в месяц.",
    "url": "https://seller.wildberries.ru",
    "api_base": "https://statistics-api.wildberries.ru",
    "category": "ecommerce",
    "geo": [
      "RU",
      "BY",
      "KZ"
    ],
    "language": "ru",
    "docs": "https://openapi.wildberries.ru/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: {api_key}",
    "how_to_get": "Личный кабинет WB → Настройки → Доступ к API",
    "cost": "Бесплатно для продавцов"
  },
  "capabilities": [
    {
      "id": "search_products",
      "description_for_ai": "Search Wildberries marketplace products by keyword, category, and filters.",
      "intent": [
        "wildberries search",
        "поиск wb",
        "товары wildberries",
        "найти товар wildberries"
      ],
      "endpoint": "GET https://search.wb.ru/exactmatch/ru/common/v4/search",
      "input": {
        "query": {
          "type": "string",
          "description": "Search query in Russian or English",
          "required": true
        },
        "page": {
          "type": "integer",
          "default": 1
        },
        "sort": {
          "type": "string",
          "description": "popular, priceup, pricedown, rate, newly",
          "default": "popular"
        },
        "priceU": {
          "type": "string",
          "description": "Price filter: 0;100000 (min;max in kopecks*100)",
          "required": false
        }
      },
      "output": {
        "type": "list<product>",
        "fields": [
          "data.products[0].id",
          "data.products[0].name",
          "data.products[0].brand",
          "data.products[0].salePriceU (kopecks)",
          "data.products[0].rating",
          "data.products[0].reviewRating"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_product_card",
      "description_for_ai": "Get full product card from Wildberries: description, photos, sizes, specifications.",
      "intent": [
        "wb card",
        "wb товар",
        "wildberries product",
        "карточка wildberries"
      ],
      "endpoint": "GET https://card.wb.ru/cards/v2/detail",
      "input": {
        "nm": {
          "type": "integer",
          "description": "Product article (артикул WB)",
          "required": true
        }
      },
      "output": {
        "type": "product",
        "fields": [
          "data.products[0].id",
          "data.products[0].imt_name",
          "data.products[0].colors",
          "data.products[0].sizes",
          "data.products[0].pics"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_seller_orders",
      "description_for_ai": "Get marketplace orders for WB Seller API (seller portal).",
      "intent": [
        "wildberries orders",
        "wb orders",
        "заказы wildberries",
        "заказы wb"
      ],
      "endpoint": "GET https://statistics-api.wildberries.ru/api/v1/supplier/orders",
      "input": {
        "dateFrom": {
          "type": "string",
          "description": "ISO 8601 date e.g. 2024-01-01T00:00:00",
          "required": true
        },
        "flag": {
          "type": "integer",
          "description": "0=all, 1=only changed since dateFrom",
          "default": 0
        }
      },
      "output": {
        "type": "list<order>",
        "fields": [
          "[0].srid",
          "[0].article",
          "[0].totalPrice",
          "[0].discountPercent",
          "[0].warehouseName",
          "[0].regionName",
          "[0].date"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_stocks",
      "description_for_ai": "Get current stock levels for seller products on WB warehouses.",
      "intent": [
        "wildberries stock",
        "wb остатки",
        "остатки wildberries",
        "wb склад"
      ],
      "endpoint": "GET https://statistics-api.wildberries.ru/api/v1/supplier/stocks",
      "input": {
        "dateFrom": {
          "type": "string",
          "description": "ISO 8601 date",
          "required": true
        }
      },
      "output": {
        "type": "list<stock>",
        "fields": [
          "[0].nmId",
          "[0].supplierArticle",
          "[0].warehouseName",
          "[0].quantity",
          "[0].Price",
          "[0].subject"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_sales",
      "description_for_ai": "Get sales report from Wildberries seller statistics.",
      "intent": [
        "wildberries sales",
        "wb продажи",
        "отчёт о продажах wb"
      ],
      "endpoint": "GET https://statistics-api.wildberries.ru/api/v1/supplier/sales",
      "input": {
        "dateFrom": {
          "type": "string",
          "description": "ISO 8601 date",
          "required": true
        },
        "flag": {
          "type": "integer",
          "description": "0=all, 1=only new since dateFrom",
          "default": 0
        }
      },
      "output": {
        "type": "list<sale>",
        "fields": [
          "[0].srid",
          "[0].article",
          "[0].totalPrice",
          "[0].subject",
          "[0].date"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "api_key": "Generate API key in seller dashboard: Профиль → Настройки → Доступ к новому API",
    "multiple_keys": "WB uses separate keys for different API sections: Statistics, Promotions, Marketplace, etc.",
    "date_filter": "dateFrom is required. Always specify date range to avoid timeout on large datasets.",
    "analytics": "More detailed analytics via POST /api/v1/analytics/data: turnover, days_on_stock, ordered_units"
  }
}