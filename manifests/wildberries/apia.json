{
  "apia": "1.0",
  "service": {
    "id": "wildberries",
    "name": "Wildberries API (Россия)",
    "description_for_ai": "Крупнейший fashion и lifestyle маркетплейс России. API для продавцов: статистика продаж, управление карточками товаров, поставки на склад, финансовые отчёты. 120M+ активных покупателей в месяц.",
    "url": "https://seller.wildberries.ru",
    "api_base": "https://statistics-api.wildberries.ru",
    "category": "ecommerce",
    "geo": [
      "RU",
      "BY",
      "KZ"
    ],
    "language": "ru",
    "docs": "https://openapi.wildberries.ru/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: {api_key}",
    "how_to_get": "Личный кабинет WB → Настройки → Доступ к API",
    "cost": "Бесплатно для продавцов"
  },
  "capabilities": [
    {
      "id": "get_sales",
      "description_for_ai": "Получить статистику продаж по товарам за период. Количество продаж, выручка, возвраты.",
      "intent": [
        "продажи WB",
        "статистика Wildberries",
        "выручка маркетплейс",
        "аналитика продаж"
      ],
      "endpoint": "GET https://statistics-api.wildberries.ru/api/v1/supplier/sales",
      "input": {
        "dateFrom": {
          "type": "string",
          "description": "Дата начала YYYY-MM-DD",
          "required": true
        },
        "flag": {
          "type": "integer",
          "description": "0=все продажи, 1=только новые с dateFrom",
          "default": 0
        }
      },
      "output": {
        "type": "list<sale>",
        "fields": [
          "date",
          "lastChangeDate",
          "supplierArticle",
          "barcode",
          "quantity",
          "totalPrice",
          "discountPercent",
          "warehouseName",
          "oblast",
          "srid"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_stocks",
      "description_for_ai": "Получить остатки товаров на складах Wildberries.",
      "intent": [
        "остатки WB",
        "склад Wildberries",
        "запасы товаров",
        "инвентарь"
      ],
      "endpoint": "GET https://statistics-api.wildberries.ru/api/v1/supplier/stocks",
      "input": {
        "dateFrom": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        }
      },
      "output": {
        "type": "list<stock>",
        "fields": [
          "lastChangeDate",
          "supplierArticle",
          "techSize",
          "barcode",
          "quantity",
          "inWayToClient",
          "inWayFromClient",
          "nmId",
          "subject",
          "warehouseName"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}