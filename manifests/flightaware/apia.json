{
  "apia": "1.0",
  "service": {
    "id": "flightaware",
    "name": "FlightAware AeroAPI",
    "description_for_ai": "Real-time flight tracking and aviation data. Track any flight by number or tail number. Departure/arrival times, gate info, delay status, flight history. Used by airports, airlines, travel apps.",
    "url": "https://flightaware.com",
    "api_base": "https://aeroapi.flightaware.com/aeroapi",
    "category": "transport",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://flightaware.com/commercial/aeroapi/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "x-apikey: ...",
    "how_to_get": "Register at https://flightaware.com/commercial/aeroapi",
    "cost": "Free: 500 queries/month. Paid from $29.99/month"
  },
  "capabilities": [
    {
      "id": "get_flight",
      "description_for_ai": "Get real-time status of a specific flight by flight number. Returns departure/arrival times, gate, delay status, aircraft type.",
      "intent": [
        "flight arrival time",
        "flight ETA",
        "track flight",
        "flight tracker",
        "flight status",
        "рейс статус",
        "flight delay",
        "is flight delayed",
        "is plane landed",
        "где самолёт"
      ],
      "endpoint": "GET https://aeroapi.flightaware.com/aeroapi/flights/{flight_id}",
      "input": {
        "flight_id": {
          "type": "string",
          "description": "Flight number e.g. AA100, SU100, BA001",
          "required": true
        }
      },
      "output": {
        "type": "flight",
        "fields": [
          "ident",
          "origin.code",
          "destination.code",
          "scheduled_out",
          "estimated_out",
          "actual_out",
          "status",
          "aircraft_type",
          "gate_origin",
          "gate_destination",
          "delay"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_flights",
      "description_for_ai": "Search for flights departing from or arriving at an airport. Returns scheduled and live flight data with status.",
      "intent": [
        "arrivals at airport",
        "flight schedule",
        "flights between cities",
        "airport schedule",
        "schedule",
        "departures from airport",
        "рейсы аэропорта"
      ],
      "endpoint": "GET https://aeroapi.flightaware.com/aeroapi/airports/{airport_id}/flights",
      "input": {
        "airport_id": {
          "type": "string",
          "description": "ICAO airport code e.g. KSFO, EGLL, UUEE (Moscow Sheremetyevo)",
          "required": true
        },
        "type": {
          "type": "string",
          "description": "departures or arrivals",
          "default": "departures"
        }
      },
      "output": {
        "type": "list<flight>",
        "fields": [
          "ident",
          "origin.code",
          "destination.code",
          "scheduled_out",
          "status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_flight",
      "description_for_ai": "Get current or historical flight status and tracking data.",
      "intent": [
        "flight status",
        "track flight",
        "отследить рейс",
        "FlightAware track"
      ],
      "endpoint": "GET https://aeroapi.flightaware.com/aeroapi/flights/{ident}",
      "input": {
        "ident": {
          "type": "string",
          "description": "Flight number e.g. UAL1, BA294",
          "required": true
        }
      },
      "output": {
        "type": "flight",
        "fields": [
          "flights[0].ident",
          "flights[0].status",
          "flights[0].origin.city",
          "flights[0].destination.city",
          "flights[0].departure_delay",
          "flights[0].estimated_in"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "airport_flights",
      "description_for_ai": "Get arrivals or departures at an airport.",
      "intent": [
        "airport arrivals",
        "airport departures",
        "flights at airport",
        "рейсы аэропорт"
      ],
      "endpoint": "GET https://aeroapi.flightaware.com/aeroapi/airports/{airport_code}/flights/arrivals",
      "input": {
        "airport_code": {
          "type": "string",
          "description": "ICAO or IATA code e.g. KJFK or JFK",
          "required": true
        },
        "type": {
          "type": "string",
          "description": "arrivals or departures",
          "required": true
        }
      },
      "output": {
        "type": "list<flight>",
        "fields": [
          "arrivals[0].ident",
          "arrivals[0].status",
          "arrivals[0].origin.city",
          "arrivals[0].estimated_in"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "track_aircraft",
      "description_for_ai": "Get live position and flight track for an aircraft by tail number.",
      "intent": [
        "track aircraft",
        "plane position",
        "live flight track",
        "местоположение самолёта"
      ],
      "endpoint": "GET https://aeroapi.flightaware.com/aeroapi/flights/{ident}/track",
      "input": {
        "ident": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "track",
        "fields": [
          "positions[0].fa_flight_id",
          "positions[0].timestamp",
          "positions[0].latitude",
          "positions[0].longitude",
          "positions[0].altitude",
          "positions[0].groundspeed"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}