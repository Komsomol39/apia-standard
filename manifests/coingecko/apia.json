{
  "apia": "1.0",
  "service": {
    "id": "coingecko",
    "name": "CoinGecko API",
    "description_for_ai": "Comprehensive crypto market data. 10,000+ coins, prices in 50+ currencies, market cap rankings, trading volume, historical data, DeFi metrics. Free tier without API key. More complete than Coinbase for altcoins.",
    "url": "https://coingecko.com",
    "api_base": "https://api.coingecko.com/api/v3",
    "category": "finance_crypto",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.coingecko.com/api/documentation"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_limits": "30 req/min",
    "param_name": "x_cg_demo_api_key",
    "param_location": "query",
    "how_to_get": "Free key at https://www.coingecko.com/en/api",
    "cost": "Free demo. Pro: $129/month"
  },
  "capabilities": [
    {
      "id": "get_price",
      "description_for_ai": "Get current price of any cryptocurrency in any currency. Supports 10,000+ coins and 50+ currencies.",
      "intent": [
        "crypto price",
        "bitcoin price",
        "altcoin price",
        "token price",
        "coin value",
        "курс криптовалюты"
      ],
      "endpoint": "GET https://api.coingecko.com/api/v3/simple/price",
      "input": {
        "ids": {
          "type": "string",
          "description": "Coin IDs comma-separated: bitcoin, ethereum, solana, toncoin, dogecoin",
          "required": true
        },
        "vs_currencies": {
          "type": "string",
          "description": "Currency codes: usd, eur, rub, btc, eth",
          "default": "usd"
        },
        "include_24hr_change": {
          "type": "boolean",
          "default": false
        },
        "include_market_cap": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "prices",
        "fields": [
          "bitcoin.usd",
          "bitcoin.usd_24h_change",
          "ethereum.usd",
          "solana.usd"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_market_chart",
      "description_for_ai": "Get historical price data for a cryptocurrency over time. Returns price, market cap, volume arrays.",
      "intent": [
        "crypto history",
        "price chart",
        "historical crypto",
        "price over time",
        "coin chart"
      ],
      "endpoint": "GET https://api.coingecko.com/api/v3/coins/{id}/market_chart",
      "input": {
        "id": {
          "type": "string",
          "description": "Coin ID e.g. bitcoin, ethereum, solana",
          "required": true
        },
        "vs_currency": {
          "type": "string",
          "default": "usd"
        },
        "days": {
          "type": "string",
          "description": "Number of days: 1, 7, 14, 30, 90, 180, 365, max",
          "required": true
        },
        "interval": {
          "type": "string",
          "description": "daily for days>90",
          "required": false
        }
      },
      "output": {
        "type": "chart",
        "fields": [
          "prices (array of [timestamp, price])",
          "market_caps",
          "total_volumes"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_trending",
      "description_for_ai": "Get trending coins in last 24h by searches on CoinGecko.",
      "intent": [
        "trending crypto",
        "hot coins",
        "most searched crypto",
        "trending tokens"
      ],
      "endpoint": "GET https://api.coingecko.com/api/v3/search/trending",
      "input": {},
      "output": {
        "type": "trending",
        "fields": [
          "coins[0].item.name",
          "coins[0].item.symbol",
          "coins[0].item.market_cap_rank"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "coin_ids": "Use /coins/list to get all coin IDs. Common ones: bitcoin, ethereum, solana, cardano, dogecoin, toncoin, the-open-network",
    "free": "Most endpoints free without key. Add key for higher rate limits."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}