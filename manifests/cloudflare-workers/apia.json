{
  "apia": "1.0",
  "service": {
    "id": "cloudflare-workers",
    "name": "Cloudflare Workers API",
    "description_for_ai": "Serverless edge computing platform. Deploy JavaScript/Rust/Python at 300+ locations worldwide. 0ms cold start. 100K requests/day free. Use for edge APIs, proxies, middleware, serverless functions.",
    "url": "https://workers.cloudflare.com",
    "api_base": "https://api.cloudflare.com/client/v4",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.cloudflare.com/workers/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Bearer {api_token}",
    "how_to_get": "https://dash.cloudflare.com/profile/api-tokens",
    "cost": "Free: 100K req/day. Paid: $5/month 10M requests"
  },
  "capabilities": [
    {
      "id": "deploy_worker",
      "description_for_ai": "Deploy or update a Worker script to Cloudflare edge (300+ locations worldwide). Instant global deployment.",
      "intent": [
        "deploy worker cloudflare",
        "edge function cloudflare",
        "upload worker",
        "задеплоить cloudflare worker"
      ],
      "endpoint": "PUT https://api.cloudflare.com/client/v4/accounts/{account_id}/workers/scripts/{script_name}",
      "input": {
        "account_id": {
          "type": "string",
          "required": true
        },
        "script_name": {
          "type": "string",
          "description": "Worker name (letters, numbers, hyphens)",
          "required": true
        },
        "script": {
          "type": "string",
          "description": "Worker JavaScript/TypeScript code as string",
          "required": true
        },
        "bindings": {
          "type": "array",
          "description": "[{type: 'kv_namespace', name: 'MY_KV', namespace_id: '...'}, {type: 'secret_text', name: 'API_KEY'}]",
          "required": false
        }
      },
      "output": {
        "type": "worker",
        "fields": [
          "id",
          "created_on",
          "modified_on",
          "script"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_worker",
      "description_for_ai": "Get source code of an existing Worker script.",
      "intent": [
        "get worker code",
        "read worker",
        "worker source",
        "код worker cloudflare"
      ],
      "endpoint": "GET https://api.cloudflare.com/client/v4/accounts/{account_id}/workers/scripts/{script_name}",
      "input": {
        "account_id": {
          "type": "string",
          "required": true
        },
        "script_name": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "script",
        "fields": [
          "JavaScript source code as text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "kv_put",
      "description_for_ai": "Write a key-value pair to Cloudflare KV Storage. Available globally at edge.",
      "intent": [
        "KV store cloudflare",
        "store data edge",
        "cloudflare KV write",
        "запись KV cloudflare"
      ],
      "endpoint": "PUT https://api.cloudflare.com/client/v4/accounts/{account_id}/storage/kv/namespaces/{namespace_id}/values/{key}",
      "input": {
        "account_id": {
          "type": "string",
          "required": true
        },
        "namespace_id": {
          "type": "string",
          "required": true
        },
        "key": {
          "type": "string",
          "required": true
        },
        "value": {
          "type": "string",
          "description": "Value to store (max 25MB)",
          "required": true
        },
        "expiration_ttl": {
          "type": "integer",
          "description": "TTL in seconds. After expiry, key is deleted.",
          "required": false
        },
        "metadata": {
          "type": "object",
          "description": "JSON metadata to attach to key",
          "required": false
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "success",
          "result"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "r2_upload",
      "description_for_ai": "Upload object to Cloudflare R2 (S3-compatible object storage with zero egress fees).",
      "intent": [
        "R2 upload",
        "cloudflare storage",
        "R2 object store",
        "хранилище cloudflare R2"
      ],
      "endpoint": "PUT https://{account_id}.r2.cloudflarestorage.com/{bucket}/{key}",
      "input": {
        "account_id": {
          "type": "string",
          "required": true
        },
        "bucket": {
          "type": "string",
          "required": true
        },
        "key": {
          "type": "string",
          "description": "Object key/path",
          "required": true
        },
        "body": {
          "type": "binary",
          "description": "File content",
          "required": true
        },
        "ContentType": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "upload",
        "fields": [
          "ETag"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}