{
  "apia": "1.0",
  "service": {
    "id": "cloudflare-workers",
    "name": "Cloudflare Workers API",
    "description_for_ai": "Serverless edge computing platform. Deploy JavaScript/Rust/Python at 300+ locations worldwide. 0ms cold start. 100K requests/day free. Use for edge APIs, proxies, middleware, serverless functions.",
    "url": "https://workers.cloudflare.com",
    "api_base": "https://api.cloudflare.com/client/v4",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.cloudflare.com/workers/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Bearer {api_token}",
    "how_to_get": "https://dash.cloudflare.com/profile/api-tokens",
    "cost": "Free: 100K req/day. Paid: $5/month 10M requests"
  },
  "capabilities": [
    {
      "id": "deploy_worker",
      "description_for_ai": "Deploy or update a Cloudflare Worker script. Workers run globally at the edge in 300+ cities.",
      "intent": [
        "deploy Cloudflare Worker",
        "update Worker",
        "deploy edge function",
        "деплой Cloudflare Worker"
      ],
      "endpoint": "PUT https://api.cloudflare.com/client/v4/accounts/{account_id}/workers/scripts/{script_name}",
      "input": {
        "account_id": {
          "type": "string",
          "required": true
        },
        "script_name": {
          "type": "string",
          "required": true
        },
        "script": {
          "type": "string",
          "description": "Worker JavaScript/TypeScript code",
          "required": true
        },
        "bindings": {
          "type": "array",
          "description": "[{type: 'kv_namespace', name: 'MY_KV', namespace_id: 'xxx'}]",
          "required": false
        }
      },
      "output": {
        "type": "worker",
        "fields": [
          "id",
          "etag",
          "created_on",
          "modified_on"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_workers",
      "description_for_ai": "List all Cloudflare Workers in an account.",
      "intent": [
        "list Workers",
        "Cloudflare scripts",
        "my Workers",
        "список Workers Cloudflare"
      ],
      "endpoint": "GET https://api.cloudflare.com/client/v4/accounts/{account_id}/workers/scripts",
      "input": {
        "account_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<worker>",
        "fields": [
          "result[0].id",
          "result[0].created_on",
          "result[0].modified_on",
          "result[0].usage_model"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "kv_put",
      "description_for_ai": "Store a key-value pair in Cloudflare KV storage. Global edge storage with low latency reads.",
      "intent": [
        "KV store Cloudflare",
        "edge storage",
        "store value KV",
        "хранилище KV Cloudflare"
      ],
      "endpoint": "PUT https://api.cloudflare.com/client/v4/accounts/{account_id}/storage/kv/namespaces/{namespace_id}/values/{key}",
      "input": {
        "account_id": {
          "type": "string",
          "required": true
        },
        "namespace_id": {
          "type": "string",
          "required": true
        },
        "key": {
          "type": "string",
          "required": true
        },
        "value": {
          "type": "string",
          "required": true
        },
        "expiration_ttl": {
          "type": "integer",
          "description": "TTL in seconds",
          "required": false
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "success"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "kv_get",
      "description_for_ai": "Get a value from Cloudflare KV storage by key.",
      "intent": [
        "KV get Cloudflare",
        "read from KV",
        "get stored value",
        "прочитать KV Cloudflare"
      ],
      "endpoint": "GET https://api.cloudflare.com/client/v4/accounts/{account_id}/storage/kv/namespaces/{namespace_id}/values/{key}",
      "input": {
        "account_id": {
          "type": "string",
          "required": true
        },
        "namespace_id": {
          "type": "string",
          "required": true
        },
        "key": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "value",
        "fields": [
          "value (string)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "add_route",
      "description_for_ai": "Add a route pattern to trigger a Worker for specific URL paths.",
      "intent": [
        "Worker route",
        "URL pattern Worker",
        "route Worker",
        "роут Cloudflare Worker"
      ],
      "endpoint": "POST https://api.cloudflare.com/client/v4/zones/{zone_id}/workers/routes",
      "input": {
        "zone_id": {
          "type": "string",
          "required": true
        },
        "pattern": {
          "type": "string",
          "description": "URL pattern e.g. example.com/api/* or *.example.com/*",
          "required": true
        },
        "script": {
          "type": "string",
          "description": "Worker script name",
          "required": true
        }
      },
      "output": {
        "type": "route",
        "fields": [
          "result.id",
          "result.pattern",
          "result.script"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_worker_metrics",
      "description_for_ai": "Get usage metrics for a Cloudflare Worker: requests, errors, CPU time.",
      "intent": [
        "Worker metrics",
        "Cloudflare analytics",
        "Worker usage",
        "метрики Worker Cloudflare"
      ],
      "endpoint": "GET https://api.cloudflare.com/client/v4/accounts/{account_id}/workers/scripts/{script_name}/analytics/requests",
      "input": {
        "account_id": {
          "type": "string",
          "required": true
        },
        "script_name": {
          "type": "string",
          "required": true
        },
        "since": {
          "type": "string",
          "description": "ISO 8601 date",
          "required": false
        },
        "until": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "metrics",
        "fields": [
          "totals.requests.all",
          "totals.errors.all",
          "totals.subrequests.all"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}