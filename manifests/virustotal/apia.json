{
  "apia": "1.0",
  "service": {
    "id": "virustotal",
    "name": "VirusTotal API",
    "description_for_ai": "Scan files, URLs, IPs and domains for malware using 70+ antivirus engines. Free: 4 lookups/min. Use for security checking, malware detection, URL safety verification, threat intelligence.",
    "url": "https://virustotal.com",
    "api_base": "https://www.virustotal.com/api/v3",
    "category": "security",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.virustotal.com/reference/overview"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "x-apikey: ...",
    "how_to_get": "Free API key at https://www.virustotal.com/gui/join-us",
    "cost": "Free: 4 req/min, 500 req/day. Premium for higher limits"
  },
  "capabilities": [
    {
      "id": "scan_url",
      "description_for_ai": "Scan a URL for malware and phishing with 70+ antivirus engines.",
      "intent": [
        "scan URL",
        "check URL malware",
        "is URL safe",
        "проверить URL VirusTotal"
      ],
      "endpoint": "POST https://www.virustotal.com/api/v3/urls",
      "input": {
        "url": {
          "type": "string",
          "description": "URL to scan",
          "required": true
        }
      },
      "output": {
        "type": "analysis",
        "fields": [
          "data.id (analysis ID for polling)",
          "data.type"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_url_report",
      "description_for_ai": "Get VirusTotal report for a URL (scan results from 70+ engines).",
      "intent": [
        "URL report VirusTotal",
        "malware check URL",
        "URL safety report",
        "отчёт URL VirusTotal"
      ],
      "endpoint": "GET https://www.virustotal.com/api/v3/urls/{url_id}",
      "input": {
        "url_id": {
          "type": "string",
          "description": "Base64 URL-encoded URL or ID from scan_url",
          "required": true
        }
      },
      "output": {
        "type": "report",
        "fields": [
          "data.attributes.last_analysis_stats.malicious",
          "data.attributes.last_analysis_stats.harmless",
          "data.attributes.last_analysis_results"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "scan_file",
      "description_for_ai": "Upload and scan a file for malware with 70+ antivirus engines.",
      "intent": [
        "scan file",
        "check file malware",
        "file virus scan",
        "проверить файл VirusTotal"
      ],
      "endpoint": "POST https://www.virustotal.com/api/v3/files",
      "input": {
        "file": {
          "type": "file",
          "description": "File to scan, max 32MB (use large file upload for >32MB)",
          "required": true
        }
      },
      "output": {
        "type": "analysis",
        "fields": [
          "data.id (analysis ID for polling)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_file_report",
      "description_for_ai": "Get VirusTotal scan report for a file by hash (MD5, SHA1, SHA256).",
      "intent": [
        "file hash check",
        "malware hash lookup",
        "hash reputation",
        "проверить хэш файла VirusTotal"
      ],
      "endpoint": "GET https://www.virustotal.com/api/v3/files/{hash}",
      "input": {
        "hash": {
          "type": "string",
          "description": "MD5, SHA1, or SHA256 hash of the file",
          "required": true
        }
      },
      "output": {
        "type": "report",
        "fields": [
          "data.attributes.last_analysis_stats.malicious",
          "data.attributes.last_analysis_stats.harmless",
          "data.attributes.names[0]",
          "data.attributes.type_description"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_ip_report",
      "description_for_ai": "Get reputation report for an IP address.",
      "intent": [
        "IP reputation",
        "check IP address",
        "malicious IP",
        "репутация IP VirusTotal"
      ],
      "endpoint": "GET https://www.virustotal.com/api/v3/ip_addresses/{ip}",
      "input": {
        "ip": {
          "type": "string",
          "description": "IPv4 address to check",
          "required": true
        }
      },
      "output": {
        "type": "report",
        "fields": [
          "data.attributes.last_analysis_stats.malicious",
          "data.attributes.country",
          "data.attributes.as_owner",
          "data.attributes.reputation"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "async": "URL scanning is async: 1) POST to scan → get id. 2) GET /analyses/{id} until status=completed.",
    "rate_limit": "Free: 4 req/min. Exceed this and you get 429. Add sleep between requests."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}