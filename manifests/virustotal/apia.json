{
  "apia": "1.0",
  "service": {
    "id": "virustotal",
    "name": "VirusTotal API",
    "description_for_ai": "Scan files, URLs, IPs and domains for malware using 70+ antivirus engines. Free: 4 lookups/min. Use for security checking, malware detection, URL safety verification, threat intelligence.",
    "url": "https://virustotal.com",
    "api_base": "https://www.virustotal.com/api/v3",
    "category": "security",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.virustotal.com/reference/overview"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "x-apikey: ...",
    "how_to_get": "Free API key at https://www.virustotal.com/gui/join-us",
    "cost": "Free: 4 req/min, 500 req/day. Premium for higher limits"
  },
  "capabilities": [
    {
      "id": "scan_url",
      "description_for_ai": "Submit a URL to VirusTotal for malware and phishing scanning.",
      "intent": [
        "scan URL VirusTotal",
        "check URL malware",
        "phishing check",
        "проверить URL VirusTotal"
      ],
      "endpoint": "POST https://www.virustotal.com/api/v3/urls",
      "input": {
        "url": {
          "type": "string",
          "description": "URL to scan",
          "required": true
        }
      },
      "output": {
        "type": "analysis",
        "fields": [
          "data.id (analysis ID for results)",
          "data.type"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_url_report",
      "description_for_ai": "Get VirusTotal scan results for a URL. Returns verdicts from 90+ security engines.",
      "intent": [
        "URL report VirusTotal",
        "malware results",
        "security check URL",
        "отчёт URL VirusTotal"
      ],
      "endpoint": "GET https://www.virustotal.com/api/v3/urls/{id}",
      "input": {
        "id": {
          "type": "string",
          "description": "URL ID (base64url of URL) or analysis ID",
          "required": true
        }
      },
      "output": {
        "type": "report",
        "fields": [
          "data.attributes.last_analysis_stats.malicious",
          "data.attributes.last_analysis_stats.suspicious",
          "data.attributes.last_analysis_stats.harmless",
          "data.attributes.reputation"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "scan_file_hash",
      "description_for_ai": "Get VirusTotal report for a file by its MD5, SHA1, or SHA256 hash.",
      "intent": [
        "file hash VirusTotal",
        "check file hash",
        "malware hash lookup",
        "проверить хэш файла VirusTotal"
      ],
      "endpoint": "GET https://www.virustotal.com/api/v3/files/{id}",
      "input": {
        "id": {
          "type": "string",
          "description": "MD5, SHA1, or SHA256 hash",
          "required": true
        }
      },
      "output": {
        "type": "report",
        "fields": [
          "data.attributes.meaningful_name",
          "data.attributes.last_analysis_stats.malicious",
          "data.attributes.type_description",
          "data.attributes.names"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "scan_ip",
      "description_for_ai": "Get VirusTotal report for an IP address — reputation, malware hosting, etc.",
      "intent": [
        "IP reputation VirusTotal",
        "check IP malware",
        "IP security check",
        "проверить IP VirusTotal"
      ],
      "endpoint": "GET https://www.virustotal.com/api/v3/ip_addresses/{ip}",
      "input": {
        "ip": {
          "type": "string",
          "description": "IPv4 or IPv6 address",
          "required": true
        }
      },
      "output": {
        "type": "report",
        "fields": [
          "data.attributes.country",
          "data.attributes.last_analysis_stats.malicious",
          "data.attributes.reputation",
          "data.attributes.as_owner"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_domain_report",
      "description_for_ai": "Get VirusTotal security report for a domain.",
      "intent": [
        "domain reputation",
        "domain malware check",
        "domain VirusTotal",
        "репутация домена VirusTotal"
      ],
      "endpoint": "GET https://www.virustotal.com/api/v3/domains/{domain}",
      "input": {
        "domain": {
          "type": "string",
          "description": "Domain name: example.com",
          "required": true
        }
      },
      "output": {
        "type": "report",
        "fields": [
          "data.attributes.reputation",
          "data.attributes.last_analysis_stats.malicious",
          "data.attributes.categories",
          "data.attributes.registrar"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "async": "URL scanning is async: 1) POST to scan → get id. 2) GET /analyses/{id} until status=completed.",
    "rate_limit": "Free: 4 req/min. Exceed this and you get 429. Add sleep between requests."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}