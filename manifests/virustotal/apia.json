{
  "apia": "1.0",
  "service": {
    "id": "virustotal",
    "name": "VirusTotal API",
    "description_for_ai": "Scan files, URLs, IPs and domains for malware using 70+ antivirus engines. Free: 4 lookups/min. Use for security checking, malware detection, URL safety verification, threat intelligence.",
    "url": "https://virustotal.com",
    "api_base": "https://www.virustotal.com/api/v3",
    "category": "security",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.virustotal.com/reference/overview"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "x-apikey: ...",
    "how_to_get": "Free API key at https://www.virustotal.com/gui/join-us",
    "cost": "Free: 4 req/min, 500 req/day. Premium for higher limits"
  },
  "capabilities": [
    {
      "id": "scan_url",
      "description_for_ai": "Scan a URL for malware, phishing, and suspicious content using 70+ antivirus engines.",
      "intent": [
        "check URL malware",
        "virustotal scan",
        "phishing check",
        "is URL safe",
        "проверить URL virustotal"
      ],
      "endpoint": "POST https://www.virustotal.com/api/v3/urls",
      "input": {
        "url": {
          "type": "string",
          "description": "URL to scan",
          "required": true
        }
      },
      "output": {
        "type": "scan",
        "fields": [
          "data.id (scan ID to check results)",
          "data.type"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_url_report",
      "description_for_ai": "Get analysis results for a scanned URL. Check malicious/suspicious verdicts from 70+ vendors.",
      "intent": [
        "url scan results",
        "malware verdict",
        "virustotal report",
        "результат проверки virustotal"
      ],
      "endpoint": "GET https://www.virustotal.com/api/v3/analyses/{id}",
      "input": {
        "id": {
          "type": "string",
          "description": "Analysis ID from scan_url response (base64url of url)",
          "required": true
        }
      },
      "output": {
        "type": "analysis",
        "fields": [
          "data.attributes.status",
          "data.attributes.stats.malicious",
          "data.attributes.stats.suspicious",
          "data.attributes.stats.undetected",
          "data.attributes.results.{engine}.result"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "scan_file_hash",
      "description_for_ai": "Check if a file hash (MD5/SHA1/SHA256) is known malware.",
      "intent": [
        "file hash check",
        "malware hash",
        "virustotal hash",
        "хэш файла virustotal"
      ],
      "endpoint": "GET https://www.virustotal.com/api/v3/files/{hash}",
      "input": {
        "hash": {
          "type": "string",
          "description": "MD5, SHA-1, or SHA-256 hash of the file",
          "required": true
        }
      },
      "output": {
        "type": "file",
        "fields": [
          "data.attributes.meaningful_name",
          "data.attributes.type_description",
          "data.attributes.last_analysis_stats.malicious",
          "data.attributes.last_analysis_stats.undetected",
          "data.attributes.names"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search",
      "description_for_ai": "Search VirusTotal for IPs, domains, URLs, files using intelligence queries.",
      "intent": [
        "virustotal search",
        "threat intelligence",
        "IP reputation",
        "репутация IP virustotal"
      ],
      "endpoint": "GET https://www.virustotal.com/api/v3/search",
      "input": {
        "query": {
          "type": "string",
          "description": "entity: IP (1.2.3.4), domain (evil.com), hash, or VTI query: entity:ip country:RU malicious-votes:>=10",
          "required": true
        },
        "limit": {
          "type": "integer",
          "default": 20
        },
        "cursor": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "results",
        "fields": [
          "data[0].id",
          "data[0].type",
          "data[0].attributes.last_analysis_stats"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "async": "URL scanning is async: 1) POST to scan → get id. 2) GET /analyses/{id} until status=completed.",
    "rate_limit": "Free: 4 req/min. Exceed this and you get 429. Add sleep between requests."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}