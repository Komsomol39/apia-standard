{
  "apia": "1.0",
  "service": {
    "id": "coingecko-defi",
    "name": "CoinGecko DeFi & NFT API",
    "description_for_ai": "DeFi protocols data, NFT collections, exchanges, derivatives. Total DeFi market cap, protocol TVL, NFT floor prices, trading volumes. Extension of CoinGecko for Web3/DeFi analytics.",
    "url": "https://coingecko.com",
    "api_base": "https://api.coingecko.com/api/v3",
    "category": "finance",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.coingecko.com/api/documentation"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "cost": "Free tier available"
  },
  "capabilities": [
    {
      "id": "get_defi_stats",
      "description_for_ai": "Get global DeFi market stats: total market cap, total volume, DeFi dominance.",
      "intent": [
        "DeFi stats",
        "DeFi market cap",
        "decentralized finance",
        "TVL",
        "DeFi volume"
      ],
      "endpoint": "GET https://api.coingecko.com/api/v3/global/decentralized_finance_defi",
      "input": {},
      "output": {
        "type": "defi_stats",
        "fields": [
          "data.defi_market_cap",
          "data.eth_market_cap",
          "data.defi_dominance",
          "data.top_coin_name",
          "data.top_coin_defi_dominance"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_nft_list",
      "description_for_ai": "Get list of NFT collections with floor price, market cap, volume.",
      "intent": [
        "NFT collections",
        "NFT floor price",
        "NFT market",
        "digital art",
        "blockchain collectibles"
      ],
      "endpoint": "GET https://api.coingecko.com/api/v3/nfts/list",
      "input": {
        "order": {
          "type": "string",
          "description": "h24_volume_native_asc, floor_price_native_desc",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 100,
          "description": "Results per page. Check API docs for maximum allowed."
        }
      },
      "output": {
        "type": "list<nft>",
        "fields": [
          "id",
          "name",
          "symbol",
          "asset_platform_id",
          "contract_address"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_defi_protocols",
      "description_for_ai": "Get DeFi protocol list with TVL (total value locked) from CoinGecko.",
      "intent": [
        "DeFi protocols",
        "TVL defi",
        "top defi protocols",
        "протоколы DeFi"
      ],
      "endpoint": "GET https://api.coingecko.com/api/v3/defi",
      "input": {},
      "output": {
        "type": "defi",
        "fields": [
          "defi_market_cap",
          "eth_market_cap",
          "defi_to_eth_ratio",
          "top_coin_name",
          "top_coin_defi_dominance"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_protocol_tvl",
      "description_for_ai": "Get historical TVL of a DeFi protocol.",
      "intent": [
        "protocol TVL",
        "DeFi TVL history",
        "TVL chart",
        "исторический TVL"
      ],
      "endpoint": "GET https://api.llama.fi/protocol/{protocol}",
      "input": {
        "protocol": {
          "type": "string",
          "description": "Protocol slug e.g. uniswap, aave, makerdao",
          "required": true
        }
      },
      "output": {
        "type": "protocol",
        "fields": [
          "name",
          "tvl (array of {date, totalLiquidityUSD})",
          "mcap",
          "currentChainTvls"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "list_defi_coins",
      "description_for_ai": "List top DeFi coins by market cap.",
      "intent": [
        "top DeFi coins",
        "DeFi token list",
        "DeFi market",
        "монеты DeFi"
      ],
      "endpoint": "GET https://api.coingecko.com/api/v3/coins/markets",
      "input": {
        "vs_currency": {
          "type": "string",
          "default": "usd"
        },
        "category": {
          "type": "string",
          "default": "decentralized-finance-defi"
        },
        "order": {
          "type": "string",
          "default": "market_cap_desc"
        },
        "per_page": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<coin>",
        "fields": [
          "[0].id",
          "[0].name",
          "[0].symbol",
          "[0].current_price",
          "[0].market_cap",
          "[0].price_change_percentage_24h"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "free": "Most DeFi endpoints free on demo tier. Pro tier needed for on-chain data and higher limits.",
    "ids": "Use /coins/list to get exact coin IDs. DeFi: uniswap, aave, compound, curve-dao-token, maker",
    "tvl": "TVL (Total Value Locked) data from DeFiLlama API (defillama.com/docs) is more comprehensive."
  }
}