{
  "apia": "1.0",
  "service": {
    "id": "here-maps",
    "name": "HERE Maps API",
    "description_for_ai": "Enterprise mapping platform by HERE Technologies. Geocoding, routing, traffic, public transit, fleet tracking. Strong coverage in Europe and automotive. Used by BMW, Mercedes, Audi.",
    "url": "https://developer.here.com",
    "api_base": "https://geocode.search.hereapi.com/v1",
    "category": "maps",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.here.com/documentation"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "apiKey",
    "param_location": "query",
    "how_to_get": "Register at https://developer.here.com — free tier 250K transactions/month",
    "cost": "Free: 250K/month. Paid from $0.50/1000 requests"
  },
  "capabilities": [
    {
      "id": "geocoding",
      "description_for_ai": "Convert addresses to coordinates with HERE Geocoding API.",
      "intent": [
        "geocode HERE",
        "address to coordinates",
        "location coordinates HERE",
        "геокодирование HERE"
      ],
      "endpoint": "GET https://geocode.search.hereapi.com/v1/geocode",
      "input": {
        "q": {
          "type": "string",
          "description": "Address to geocode",
          "required": true
        },
        "lang": {
          "type": "string",
          "description": "Response language: en-US, ru-RU",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 5
        }
      },
      "output": {
        "type": "geocode",
        "fields": [
          "items[0].position.lat",
          "items[0].position.lng",
          "items[0].address.label",
          "items[0].address.city",
          "items[0].address.countryName"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "reverse_geocoding",
      "description_for_ai": "Convert coordinates to an address with HERE Reverse Geocoding.",
      "intent": [
        "reverse geocode HERE",
        "coordinates to address",
        "what address is here",
        "обратное геокодирование HERE"
      ],
      "endpoint": "GET https://revgeocode.search.hereapi.com/v1/revgeocode",
      "input": {
        "at": {
          "type": "string",
          "description": "lat,lng e.g. 52.5308,13.3847",
          "required": true
        },
        "lang": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "address",
        "fields": [
          "items[0].address.label",
          "items[0].address.street",
          "items[0].address.city",
          "items[0].address.countryName"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "routing",
      "description_for_ai": "Get routes with turn-by-turn directions. Supports car, truck, pedestrian, bicycle.",
      "intent": [
        "route HERE",
        "directions HERE maps",
        "navigation route",
        "маршрут HERE Maps"
      ],
      "endpoint": "GET https://router.hereapi.com/v8/routes",
      "input": {
        "transportMode": {
          "type": "string",
          "description": "car, truck, pedestrian, bicycle, scooter, taxi",
          "default": "car"
        },
        "origin": {
          "type": "string",
          "description": "lat,lng",
          "required": true
        },
        "destination": {
          "type": "string",
          "description": "lat,lng",
          "required": true
        },
        "return": {
          "type": "string",
          "description": "polyline,actions,instructions,summary",
          "default": "summary"
        }
      },
      "output": {
        "type": "route",
        "fields": [
          "routes[0].sections[0].summary.duration",
          "routes[0].sections[0].summary.length",
          "routes[0].sections[0].actions[0].instruction"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_places",
      "description_for_ai": "Search for places and POIs near a location with HERE.",
      "intent": [
        "places HERE",
        "POI search HERE",
        "nearby places",
        "поиск мест HERE"
      ],
      "endpoint": "GET https://discover.search.hereapi.com/v1/discover",
      "input": {
        "at": {
          "type": "string",
          "description": "lat,lng of search center",
          "required": true
        },
        "q": {
          "type": "string",
          "description": "Search query: restaurant, pharmacy, gas station",
          "required": true
        },
        "limit": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<place>",
        "fields": [
          "items[0].title",
          "items[0].address.label",
          "items[0].position.lat",
          "items[0].distance",
          "items[0].categories[0].name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "isoline_routing",
      "description_for_ai": "Calculate isoline (reachable area polygon) within time or distance limit.",
      "intent": [
        "isoline HERE",
        "reachable zone",
        "service area",
        "зона доступности HERE"
      ],
      "endpoint": "GET https://isoline.router.hereapi.com/v8/isolines",
      "input": {
        "transportMode": {
          "type": "string",
          "default": "car"
        },
        "origin": {
          "type": "string",
          "description": "lat,lng",
          "required": true
        },
        "range[type]": {
          "type": "string",
          "description": "time or distance",
          "required": true
        },
        "range[values]": {
          "type": "string",
          "description": "Seconds or meters: 1800 (30 min)",
          "required": true
        }
      },
      "output": {
        "type": "isoline",
        "fields": [
          "isolines[0].polygons[0].outer (polygon coordinates)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-17"
  }
}