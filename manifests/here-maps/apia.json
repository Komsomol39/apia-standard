{
  "apia": "1.0",
  "service": {
    "id": "here-maps",
    "name": "HERE Maps API",
    "description_for_ai": "Enterprise mapping platform by HERE Technologies. Geocoding, routing, traffic, public transit, fleet tracking. Strong coverage in Europe and automotive. Used by BMW, Mercedes, Audi.",
    "url": "https://here.com",
    "api_base": "https://geocoder.ls.hereapi.com",
    "category": "maps",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.here.com/documentation"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "apiKey",
    "param_location": "query",
    "how_to_get": "Register at https://developer.here.com — free tier 250K transactions/month",
    "cost": "Free: 250K/month. Paid from $0.50/1000 requests"
  },
  "capabilities": [
    {
      "id": "geocode",
      "description_for_ai": "Convert address to coordinates using HERE Maps. Accurate for 200+ countries.",
      "intent": [
        "geocode here",
        "address coordinates here",
        "here maps geocoding",
        "координаты адреса here"
      ],
      "endpoint": "GET https://geocode.search.hereapi.com/v1/geocode",
      "input": {
        "q": {
          "type": "string",
          "description": "Free-text address",
          "required": true
        },
        "lang": {
          "type": "string",
          "description": "Language code: en-US, ru-RU, de-DE",
          "required": false
        },
        "in": {
          "type": "string",
          "description": "Geographic filter: countryCode:RUS to restrict to Russia",
          "required": false
        }
      },
      "output": {
        "type": "geocode",
        "fields": [
          "items[0].position.lat",
          "items[0].position.lng",
          "items[0].address.label",
          "items[0].id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "reverse_geocode",
      "description_for_ai": "Convert coordinates to address using HERE Maps.",
      "intent": [
        "reverse geocode here",
        "coordinates to address here",
        "what address at location"
      ],
      "endpoint": "GET https://revgeocode.search.hereapi.com/v1/revgeocode",
      "input": {
        "at": {
          "type": "string",
          "description": "lat,lng e.g. 55.7558,37.6173",
          "required": true
        },
        "lang": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "address",
        "fields": [
          "items[0].address.label",
          "items[0].address.street",
          "items[0].address.city",
          "items[0].address.countryCode"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "routing",
      "description_for_ai": "Calculate route between points with traffic-aware travel times. Supports car, truck, pedestrian, bicycle.",
      "intent": [
        "here routing",
        "directions here",
        "route here maps",
        "маршрут here"
      ],
      "endpoint": "GET https://router.hereapi.com/v8/routes",
      "input": {
        "origin": {
          "type": "string",
          "description": "lat,lng of start",
          "required": true
        },
        "destination": {
          "type": "string",
          "description": "lat,lng of end",
          "required": true
        },
        "transportMode": {
          "type": "string",
          "description": "car, truck, pedestrian, bicycle, scooter",
          "default": "car"
        },
        "return": {
          "type": "string",
          "description": "summary,actions,instructions,polyline",
          "required": false
        },
        "departureTime": {
          "type": "string",
          "description": "ISO 8601 for traffic-aware routing",
          "required": false
        }
      },
      "output": {
        "type": "route",
        "fields": [
          "routes[0].sections[0].summary.duration",
          "routes[0].sections[0].summary.length",
          "routes[0].sections[0].actions"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "places_search",
      "description_for_ai": "Discover places (restaurants, POIs, services) near a location with HERE Places.",
      "intent": [
        "find places here",
        "nearby search here",
        "POI here maps",
        "места here"
      ],
      "endpoint": "GET https://discover.search.hereapi.com/v1/discover",
      "input": {
        "at": {
          "type": "string",
          "description": "lat,lng center point",
          "required": true
        },
        "q": {
          "type": "string",
          "description": "Search term: restaurant, hospital, ATM",
          "required": true
        },
        "limit": {
          "type": "integer",
          "default": 20
        },
        "lang": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<place>",
        "fields": [
          "items[0].title",
          "items[0].address.label",
          "items[0].distance",
          "items[0].categories[0].name",
          "items[0].position"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "traffic_flow",
      "description_for_ai": "Get real-time traffic flow data for a bounding box or corridor.",
      "intent": [
        "traffic HERE",
        "road congestion",
        "traffic data",
        "пробки HERE Maps"
      ],
      "endpoint": "GET https://data.traffic.hereapi.com/v7/flow",
      "input": {
        "in": {
          "type": "string",
          "description": "bbox:west,south,east,north or corridor",
          "required": true
        },
        "locationReferencing": {
          "type": "string",
          "description": "olr or shape",
          "default": "olr"
        }
      },
      "output": {
        "type": "traffic",
        "fields": [
          "results[0].location.description",
          "results[0].currentFlow.speed",
          "results[0].currentFlow.jamFactor"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}