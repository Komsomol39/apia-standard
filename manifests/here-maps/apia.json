{
  "apia":"1.0","service":{"id":"here-maps","name":"HERE Maps API","description_for_ai":"Enterprise mapping platform by HERE Technologies. Geocoding, routing, traffic, public transit, fleet tracking. Strong coverage in Europe and automotive. Used by BMW, Mercedes, Audi.","url":"https://here.com","api_base":"https://geocoder.ls.hereapi.com","category":"maps_geocoding","geo":["GLOBAL"],"language":"en","docs":"https://developer.here.com/documentation"},"auth":{"type":"apikey","anonymous_access":false,"param_name":"apiKey","param_location":"query","how_to_get":"Register at https://developer.here.com — free tier 250K transactions/month","cost":"Free: 250K/month. Paid from $0.50/1000 requests"},"capabilities":[{"id":"geocode","description_for_ai":"Geocode addresses to coordinates. Strong accuracy in Germany, Europe, automotive use cases.","intent":["geocode","address to coordinates","here maps geocoding"],"endpoint":"GET https://geocode.search.hereapi.com/v1/geocode","input":{"q":{"type":"string","description":"Address to geocode","required":true},"lang":{"type":"string","default":"en-US"}},"output":{"type":"geocode","fields":["items[0].position.lat","items[0].position.lng","items[0].address.label"]},"realtime":false,"requires_auth":true},{"id":"routing","description_for_ai":"Calculate route with real-time traffic. Returns duration, distance, and turn-by-turn instructions.","intent":["routing","directions with traffic","HERE navigation"],"endpoint":"GET https://router.hereapi.com/v8/routes","input":{"transportMode":{"type":"string","description":"car, pedestrian, bicycle, truck","required":true},"origin":{"type":"string","description":"lat,lng","required":true},"destination":{"type":"string","description":"lat,lng","required":true},"return":{"type":"string","default":"summary,polyline,actions"}},"output":{"type":"route","fields":["routes[0].sections[0].summary.duration","routes[0].sections[0].summary.length"]},"realtime":true,"requires_auth":true}],"meta":{"apia_version":"1.0","manifest_author":"APIA community","last_verified":"2026-06-14"}}