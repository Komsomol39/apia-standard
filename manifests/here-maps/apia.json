{
  "apia": "1.0",
  "service": {
    "id": "here-maps",
    "name": "HERE Maps API",
    "description_for_ai": "Enterprise mapping platform by HERE Technologies. Geocoding, routing, traffic, public transit, fleet tracking. Strong coverage in Europe and automotive. Used by BMW, Mercedes, Audi.",
    "url": "https://here.com",
    "api_base": "https://geocoder.ls.hereapi.com",
    "category": "maps",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.here.com/documentation"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "apiKey",
    "param_location": "query",
    "how_to_get": "Register at https://developer.here.com — free tier 250K transactions/month",
    "cost": "Free: 250K/month. Paid from $0.50/1000 requests"
  },
  "capabilities": [
    {
      "id": "geocode",
      "description_for_ai": "Geocode an address to coordinates. Strong accuracy in Germany, Europe, and automotive use cases. Returns lat/lng, formatted address, and bounding box.",
      "intent": [
        "geocode address",
        "address to coordinates",
        "here maps geocoding",
        "find location coordinates",
        "convert address to GPS"
      ],
      "endpoint": "GET https://geocode.search.hereapi.com/v1/geocode",
      "input": {
        "q": {
          "type": "string",
          "description": "Address to geocode: '1600 Amphitheatre Parkway, Mountain View, CA', 'Тверская улица 1, Москва'",
          "required": true
        },
        "lang": {
          "type": "string",
          "description": "Response language BCP-47 code: en-US, de-DE, ru-RU, fr-FR",
          "default": "en-US"
        },
        "limit": {
          "type": "integer",
          "description": "Max results to return",
          "default": 1
        },
        "in": {
          "type": "string",
          "description": "Geographic filter: 'countryCode:DEU' or 'circle:52.5,13.4;r=5000' (5km around Berlin)",
          "required": false
        }
      },
      "output": {
        "type": "geocode",
        "fields": [
          "items[0].position.lat",
          "items[0].position.lng",
          "items[0].address.label",
          "items[0].address.city",
          "items[0].address.state",
          "items[0].address.countryName",
          "items[0].mapView"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "routing",
      "description_for_ai": "Calculate route with real-time traffic. Returns turn-by-turn instructions, duration, distance, and route polyline.",
      "intent": [
        "routing",
        "directions with traffic",
        "HERE navigation",
        "drive directions",
        "route between cities",
        "navigation"
      ],
      "endpoint": "GET https://router.hereapi.com/v8/routes",
      "input": {
        "transportMode": {
          "type": "string",
          "description": "car, pedestrian, bicycle, truck, scooter",
          "required": true
        },
        "origin": {
          "type": "string",
          "description": "Start point as lat,lng: '55.75,37.62'",
          "required": true
        },
        "destination": {
          "type": "string",
          "description": "End point as lat,lng: '59.93,30.32'",
          "required": true
        },
        "return": {
          "type": "string",
          "description": "Comma-separated data to return: summary,polyline,actions,instructions,travelSummary",
          "default": "summary,actions"
        },
        "departureTime": {
          "type": "string",
          "description": "ISO 8601 departure time for traffic-aware routing: '2024-01-15T09:00:00+03:00'",
          "required": false
        }
      },
      "output": {
        "type": "route",
        "fields": [
          "routes[0].sections[0].summary.duration (seconds)",
          "routes[0].sections[0].summary.length (meters)",
          "routes[0].sections[0].actions[0].instruction",
          "routes[0].sections[0].polyline"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}