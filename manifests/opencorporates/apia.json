{
  "apia": "1.0",
  "service": {
    "id": "opencorporates",
    "name": "OpenCorporates API",
    "description_for_ai": "Largest open database of company information. 200M+ companies from 140+ jurisdictions worldwide. Company registration, officers, filings. Use for global business verification, KYC, due diligence.",
    "url": "https://opencorporates.com",
    "api_base": "https://api.opencorporates.com/v0.4",
    "category": "business",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://api.opencorporates.com/documentation/API-Reference"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_limits": "10 req/min",
    "param_name": "api_token",
    "param_location": "query",
    "how_to_get": "Register at https://opencorporates.com/users/sign_in",
    "cost": "Free basic. Enterprise from $400/month"
  },
  "capabilities": [
    {
      "id": "search_companies",
      "description_for_ai": "Search companies globally in the OpenCorporates database (140M+ companies).",
      "intent": [
        "company search",
        "business lookup",
        "company registry",
        "поиск компаний OpenCorporates"
      ],
      "endpoint": "GET https://api.opencorporates.com/v0.4/companies/search",
      "input": {
        "q": {
          "type": "string",
          "description": "Company name",
          "required": true
        },
        "jurisdiction_code": {
          "type": "string",
          "description": "us, gb, de, ru, fr, au (country code)",
          "required": false
        },
        "inactive": {
          "type": "boolean",
          "description": "Include inactive companies",
          "default": false
        },
        "per_page": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<company>",
        "fields": [
          "companies[0].company.name",
          "companies[0].company.company_number",
          "companies[0].company.jurisdiction_code",
          "companies[0].company.incorporation_date",
          "companies[0].company.current_status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_company",
      "description_for_ai": "Get full company details from OpenCorporates by jurisdiction and number.",
      "intent": [
        "company details",
        "business info",
        "registered company",
        "детали компании OpenCorporates"
      ],
      "endpoint": "GET https://api.opencorporates.com/v0.4/companies/{jurisdiction_code}/{company_number}",
      "input": {
        "jurisdiction_code": {
          "type": "string",
          "description": "us_de, gb, de, ru",
          "required": true
        },
        "company_number": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "company",
        "fields": [
          "company.name",
          "company.company_number",
          "company.incorporation_date",
          "company.company_type",
          "company.registered_address_in_full",
          "company.officers"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_officers",
      "description_for_ai": "Search company officers (directors, executives) by name.",
      "intent": [
        "company officer search",
        "director search",
        "executive lookup",
        "поиск директоров OpenCorporates"
      ],
      "endpoint": "GET https://api.opencorporates.com/v0.4/officers/search",
      "input": {
        "q": {
          "type": "string",
          "description": "Officer name",
          "required": true
        },
        "jurisdiction_code": {
          "type": "string",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<officer>",
        "fields": [
          "officers[0].officer.name",
          "officers[0].officer.position",
          "officers[0].officer.company.name",
          "officers[0].officer.company.jurisdiction_code",
          "officers[0].officer.start_date"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_company_filings",
      "description_for_ai": "Get regulatory filings and events for a company.",
      "intent": [
        "company filings",
        "regulatory filings",
        "corporate events",
        "документы компании OpenCorporates"
      ],
      "endpoint": "GET https://api.opencorporates.com/v0.4/companies/{jurisdiction_code}/{company_number}/filings",
      "input": {
        "jurisdiction_code": {
          "type": "string",
          "required": true
        },
        "company_number": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<filing>",
        "fields": [
          "filings[0].filing.filing_date",
          "filings[0].filing.title",
          "filings[0].filing.description",
          "filings[0].filing.filing_type"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "network_analysis",
      "description_for_ai": "Find corporate network connections for a company (ownership, directors).",
      "intent": [
        "corporate network",
        "company connections",
        "ownership graph",
        "корпоративная сеть OpenCorporates"
      ],
      "endpoint": "GET https://api.opencorporates.com/v0.4/corporate_groupings/{company_name}",
      "input": {
        "company_name": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "network",
        "fields": [
          "corporate_grouping.name",
          "corporate_grouping.wikipedia_id",
          "corporate_grouping.memberships_count"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}