{
  "apia": "1.0",
  "service": {
    "id": "openai-images",
    "name": "OpenAI Image Generation API (DALL-E)",
    "description_for_ai": "Generate, edit, and create variations of images using DALL-E 3 and gpt-image-1. High quality photorealistic or artistic images from text descriptions. Inpainting (edit parts of images). Multiple sizes and styles.",
    "url": "https://openai.com",
    "api_base": "https://api.openai.com/v1",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.openai.com/docs/guides/images"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "OpenAI API key",
    "cost": "DALL-E 3 standard: $0.040/image 1024x1024. HD: $0.080/image"
  },
  "capabilities": [
    {
      "id": "generate_image",
      "description_for_ai": "Generate images with DALL-E 3 from text descriptions. HD quality available.",
      "intent": [
        "generate image openai",
        "DALL-E 3",
        "text to image",
        "создать изображение dall-e",
        "нарисовать"
      ],
      "endpoint": "POST https://api.openai.com/v1/images/generations",
      "input": {
        "model": {
          "type": "string",
          "description": "dall-e-3 (best quality) or dall-e-2",
          "required": true
        },
        "prompt": {
          "type": "string",
          "description": "Detailed image description. DALL-E 3 auto-rewrites for safety.",
          "required": true
        },
        "size": {
          "type": "string",
          "description": "1024x1024, 1792x1024 (landscape), 1024x1792 (portrait) for DALL-E 3. 256x256, 512x512, 1024x1024 for DALL-E 2",
          "default": "1024x1024"
        },
        "quality": {
          "type": "string",
          "description": "standard or hd (DALL-E 3 only)",
          "default": "standard"
        },
        "style": {
          "type": "string",
          "description": "vivid (dramatic) or natural (realistic) — DALL-E 3 only",
          "default": "vivid"
        },
        "n": {
          "type": "integer",
          "description": "DALL-E 3: always 1. DALL-E 2: 1-10",
          "default": 1
        },
        "response_format": {
          "type": "string",
          "description": "url (expires in 1h) or b64_json",
          "default": "url"
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "data[0].url",
          "data[0].b64_json",
          "data[0].revised_prompt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "edit_image",
      "description_for_ai": "Edit an existing image using inpainting — provide original image and mask to replace areas. DALL-E 2 only.",
      "intent": [
        "edit image",
        "inpaint image",
        "image editing AI",
        "редактировать изображение dall-e"
      ],
      "endpoint": "POST https://api.openai.com/v1/images/edits",
      "input": {
        "image": {
          "type": "file",
          "description": "PNG file ≤4MB, square format",
          "required": true
        },
        "mask": {
          "type": "file",
          "description": "PNG mask — transparent areas will be replaced",
          "required": false
        },
        "prompt": {
          "type": "string",
          "description": "Description of changes",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "dall-e-2"
        },
        "n": {
          "type": "integer",
          "default": 1
        },
        "size": {
          "type": "string",
          "description": "256x256, 512x512, or 1024x1024",
          "default": "1024x1024"
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "data[0].url",
          "data[0].b64_json"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_variation",
      "description_for_ai": "Create variations of an existing image. DALL-E 2 generates similar but different versions.",
      "intent": [
        "image variation",
        "image alternatives",
        "similar images",
        "варианты изображения"
      ],
      "endpoint": "POST https://api.openai.com/v1/images/variations",
      "input": {
        "image": {
          "type": "file",
          "description": "PNG file ≤4MB, square format",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "dall-e-2"
        },
        "n": {
          "type": "integer",
          "description": "Number of variations 1-10",
          "default": 1
        },
        "size": {
          "type": "string",
          "default": "1024x1024"
        },
        "response_format": {
          "type": "string",
          "default": "url"
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "data[0].url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "generate_with_gpt4o",
      "description_for_ai": "Generate or edit images using GPT-4o's native image generation (gpt-image-1 model). Higher quality than DALL-E for photo-realistic results.",
      "intent": [
        "gpt4o image",
        "gpt image",
        "native image generation",
        "генерация gpt-4o"
      ],
      "endpoint": "POST https://api.openai.com/v1/images/generations",
      "input": {
        "model": {
          "type": "string",
          "default": "gpt-image-1"
        },
        "prompt": {
          "type": "string",
          "required": true
        },
        "size": {
          "type": "string",
          "description": "1024x1024, 1536x1024, 1024x1536, auto",
          "default": "auto"
        },
        "quality": {
          "type": "string",
          "description": "low, medium, high, auto",
          "default": "auto"
        },
        "n": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "data[0].b64_json",
          "data[0].url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "prompt_tips": "DALL-E 3 rewrites prompts for safety. Check revised_prompt in response to see what was actually used.",
    "style_guide": "For photos: photorealistic, 4K, professional photography. For art: oil painting, watercolor, digital art, anime style."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}