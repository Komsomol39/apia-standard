{
  "apia": "1.0",
  "service": {
    "id": "openai-images",
    "name": "OpenAI Image Generation API (DALL-E)",
    "description_for_ai": "Generate, edit, and create variations of images using DALL-E 3 and gpt-image-1. High quality photorealistic or artistic images from text descriptions. Inpainting (edit parts of images). Multiple sizes and styles.",
    "url": "https://openai.com",
    "api_base": "https://api.openai.com/v1",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.openai.com/docs/guides/images"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "OpenAI API key",
    "cost": "DALL-E 3 standard: $0.040/image 1024x1024. HD: $0.080/image"
  },
  "capabilities": [
    {
      "id": "generate_image_dalle3",
      "description_for_ai": "Generate high-quality images with DALL-E 3. Photorealistic or artistic, $0.04-$0.12/image.",
      "intent": [
        "generate image DALL-E",
        "AI art",
        "text to image OpenAI",
        "DALL-E 3",
        "создать изображение DALL-E"
      ],
      "endpoint": "POST https://api.openai.com/v1/images/generations",
      "input": {
        "model": {
          "type": "string",
          "default": "dall-e-3"
        },
        "prompt": {
          "type": "string",
          "description": "Detailed image prompt. DALL-E 3 enhances prompts automatically.",
          "required": true
        },
        "size": {
          "type": "string",
          "description": "1024x1024, 1792x1024 (wide), 1024x1792 (tall)",
          "default": "1024x1024"
        },
        "quality": {
          "type": "string",
          "description": "standard or hd (2x price, more detail)",
          "default": "standard"
        },
        "style": {
          "type": "string",
          "description": "vivid (dramatic) or natural (realistic photos)",
          "default": "vivid"
        },
        "response_format": {
          "type": "string",
          "description": "url (link expires in 1h) or b64_json",
          "default": "url"
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "data[0].url",
          "data[0].revised_prompt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "generate_image_dalle2",
      "description_for_ai": "Generate images with DALL-E 2. Supports multiple images per call and multiple sizes.",
      "intent": [
        "DALL-E 2",
        "multiple images",
        "batch image generation",
        "генерация изображений DALL-E 2"
      ],
      "endpoint": "POST https://api.openai.com/v1/images/generations",
      "input": {
        "model": {
          "type": "string",
          "default": "dall-e-2"
        },
        "prompt": {
          "type": "string",
          "required": true
        },
        "n": {
          "type": "integer",
          "description": "Number of images 1-10",
          "default": 1
        },
        "size": {
          "type": "string",
          "description": "256x256, 512x512, 1024x1024",
          "default": "1024x1024"
        },
        "response_format": {
          "type": "string",
          "default": "url"
        }
      },
      "output": {
        "type": "list<image>",
        "fields": [
          "data[0].url",
          "data[0].b64_json"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "edit_image",
      "description_for_ai": "Edit an image by describing changes. Requires original image and mask (transparent area = edit zone).",
      "intent": [
        "edit image AI",
        "image inpainting",
        "modify image",
        "редактирование изображения AI"
      ],
      "endpoint": "POST https://api.openai.com/v1/images/edits",
      "input": {
        "image": {
          "type": "file",
          "description": "Original image (PNG, max 4MB, square)",
          "required": true
        },
        "mask": {
          "type": "file",
          "description": "Mask PNG — transparent pixels are edited (optional)",
          "required": false
        },
        "prompt": {
          "type": "string",
          "description": "Description of desired edit",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "dall-e-2"
        },
        "n": {
          "type": "integer",
          "default": 1
        },
        "size": {
          "type": "string",
          "default": "1024x1024"
        }
      },
      "output": {
        "type": "list<image>",
        "fields": [
          "data[0].url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_variation",
      "description_for_ai": "Create variations of an existing image with DALL-E 2.",
      "intent": [
        "image variation",
        "similar images",
        "remix image",
        "вариации изображения"
      ],
      "endpoint": "POST https://api.openai.com/v1/images/variations",
      "input": {
        "image": {
          "type": "file",
          "description": "Source image (PNG, max 4MB, square)",
          "required": true
        },
        "n": {
          "type": "integer",
          "description": "Number of variations 1-10",
          "default": 1
        },
        "size": {
          "type": "string",
          "default": "1024x1024"
        },
        "response_format": {
          "type": "string",
          "default": "url"
        }
      },
      "output": {
        "type": "list<image>",
        "fields": [
          "data[0].url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "generate_image_gpt4o",
      "description_for_ai": "Generate and edit images using GPT-Image-1 (GPT-4o native image generation). Follows complex instructions better than DALL-E.",
      "intent": [
        "GPT image",
        "GPT-4o image",
        "best image AI OpenAI",
        "изображение GPT-4o"
      ],
      "endpoint": "POST https://api.openai.com/v1/images/generations",
      "input": {
        "model": {
          "type": "string",
          "default": "gpt-image-1"
        },
        "prompt": {
          "type": "string",
          "required": true
        },
        "size": {
          "type": "string",
          "description": "1024x1024, 1536x1024, 1024x1536, auto",
          "default": "auto"
        },
        "quality": {
          "type": "string",
          "description": "low, medium, high, auto",
          "default": "auto"
        },
        "background": {
          "type": "string",
          "description": "transparent, opaque, auto",
          "default": "auto"
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "data[0].b64_json",
          "data[0].url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "describe_image_cost",
      "description_for_ai": "Reference for DALL-E pricing. 1024x1024 standard=$0.040, HD=$0.080; 1792x1024=$0.080/$0.120.",
      "intent": [
        "DALL-E price",
        "image generation cost",
        "OpenAI image pricing",
        "стоимость генерации изображений"
      ],
      "endpoint": "GET https://api.openai.com/v1/models",
      "input": {},
      "output": {
        "type": "reference",
        "fields": [
          "dall-e-3: $0.04-$0.12/image",
          "dall-e-2: $0.016-$0.020/image",
          "gpt-image-1: $0.011-$0.19/image"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "prompt_tips": "DALL-E 3 rewrites prompts for safety. Check revised_prompt in response to see what was actually used.",
    "style_guide": "For photos: photorealistic, 4K, professional photography. For art: oil painting, watercolor, digital art, anime style."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}