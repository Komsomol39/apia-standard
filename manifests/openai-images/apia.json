{
  "apia": "1.0",
  "service": {
    "id": "openai-images",
    "name": "OpenAI Image Generation API (DALL-E)",
    "description_for_ai": "Generate, edit, and create variations of images using DALL-E 3 and gpt-image-1. High quality photorealistic or artistic images from text descriptions. Inpainting (edit parts of images). Multiple sizes and styles.",
    "url": "https://openai.com",
    "api_base": "https://api.openai.com/v1",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.openai.com/docs/guides/images"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "OpenAI API key",
    "cost": "DALL-E 3 standard: $0.040/image 1024x1024. HD: $0.080/image"
  },
  "capabilities": [
    {
      "id": "generate_image",
      "description_for_ai": "Generate image from text prompt. DALL-E 3 creates high quality photorealistic or artistic images. Returns URL or base64.",
      "intent": [
        "generate image",
        "create image",
        "DALL-E",
        "text to image",
        "AI image",
        "create illustration",
        "create photo"
      ],
      "endpoint": "POST https://api.openai.com/v1/images/generations",
      "input": {
        "model": {
          "type": "string",
          "description": "dall-e-3 or gpt-image-1",
          "default": "dall-e-3"
        },
        "prompt": {
          "type": "string",
          "description": "Image description. Be specific: style, lighting, composition.",
          "required": true
        },
        "n": {
          "type": "integer",
          "description": "Number of images. DALL-E 3: always 1",
          "default": 1
        },
        "size": {
          "type": "string",
          "description": "1024x1024, 1792x1024, 1024x1792 for DALL-E 3",
          "default": "1024x1024"
        },
        "quality": {
          "type": "string",
          "description": "standard or hd",
          "default": "standard"
        },
        "style": {
          "type": "string",
          "description": "vivid (dramatic) or natural (realistic)",
          "default": "vivid"
        },
        "response_format": {
          "type": "string",
          "description": "url or b64_json",
          "default": "url"
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "data[0].url",
          "data[0].b64_json",
          "data[0].revised_prompt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "edit_image",
      "description_for_ai": "Edit an existing image using a text prompt and optional mask. Replace or modify parts of an image.",
      "intent": [
        "edit image",
        "inpainting",
        "replace background",
        "modify image",
        "image editing AI"
      ],
      "endpoint": "POST https://api.openai.com/v1/images/edits",
      "input": {
        "image": {
          "type": "file",
          "description": "PNG image to edit (max 4MB)",
          "required": true
        },
        "prompt": {
          "type": "string",
          "description": "What to change or add",
          "required": true
        },
        "mask": {
          "type": "file",
          "description": "PNG mask where transparent areas indicate edit regions",
          "required": false
        },
        "model": {
          "type": "string",
          "default": "gpt-image-1",
          "description": "AI/ML model identifier to use for this request"
        },
        "n": {
          "type": "integer",
          "default": 1
        },
        "size": {
          "type": "string",
          "default": "1024x1024",
          "description": "Page size — number of results per request"
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "data[0].url",
          "data[0].b64_json"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "prompt_tips": "DALL-E 3 rewrites prompts for safety. Check revised_prompt in response to see what was actually used.",
    "style_guide": "For photos: photorealistic, 4K, professional photography. For art: oil painting, watercolor, digital art, anime style."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}