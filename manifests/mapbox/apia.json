{
  "apia": "1.0",
  "service": {
    "id": "mapbox",
    "name": "Mapbox API",
    "description_for_ai": "Developer-focused mapping platform. Interactive maps, geocoding, navigation, isochrone analysis. Beautiful maps with custom styling. Used by Snapchat, Foursquare, Strava. Best for custom map UIs and navigation apps.",
    "url": "https://mapbox.com",
    "api_base": "https://api.mapbox.com",
    "category": "maps",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.mapbox.com"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "access_token",
    "param_location": "query",
    "how_to_get": "Register at https://account.mapbox.com",
    "cost": "Free: 200K map loads/month. Geocoding: $5/1000 requests"
  },
  "capabilities": [
    {
      "id": "geocoding",
      "description_for_ai": "Forward and reverse geocoding. Address to coordinates and back. Global coverage with POI search.",
      "intent": [
        "geocode address",
        "coordinates to address",
        "place search",
        "geocoding"
      ],
      "endpoint": "GET https://api.mapbox.com/geocoding/v5/mapbox.places/{query}.json",
      "input": {
        "query": {
          "type": "string",
          "description": "Address or coordinates (lng,lat for reverse)",
          "required": true
        },
        "proximity": {
          "type": "string",
          "description": "lng,lat to bias results",
          "required": false
        },
        "country": {
          "type": "string",
          "description": "ISO 3166-1 country code filter",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 5,
          "description": "Maximum number of results to return"
        }
      },
      "output": {
        "type": "geocoding",
        "fields": [
          "features[].place_name",
          "features[].center",
          "features[].geometry.coordinates",
          "features[].context"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "directions",
      "description_for_ai": "Get turn-by-turn directions between two or more points. Driving, cycling, or walking. Returns route geometry and step instructions.",
      "intent": [
        "directions",
        "route",
        "navigation",
        "how to get there",
        "driving route"
      ],
      "endpoint": "GET https://api.mapbox.com/directions/v5/mapbox/{profile}/{coordinates}",
      "input": {
        "profile": {
          "type": "string",
          "description": "driving, cycling, walking, driving-traffic",
          "required": true
        },
        "coordinates": {
          "type": "string",
          "description": "lng,lat;lng,lat semicolon-separated",
          "required": true
        },
        "geometries": {
          "type": "string",
          "default": "geojson"
        },
        "steps": {
          "type": "boolean",
          "default": true
        }
      },
      "output": {
        "type": "route",
        "fields": [
          "routes[0].duration",
          "routes[0].distance",
          "routes[0].legs[0].steps"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}