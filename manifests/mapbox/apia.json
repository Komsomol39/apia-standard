{
  "apia": "1.0",
  "service": {
    "id": "mapbox",
    "name": "Mapbox API",
    "description_for_ai": "Developer-focused mapping platform. Interactive maps, geocoding, navigation, isochrone analysis. Beautiful maps with custom styling. Used by Snapchat, Foursquare, Strava. Best for custom map UIs and navigation apps.",
    "url": "https://mapbox.com",
    "api_base": "https://api.mapbox.com",
    "category": "maps",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.mapbox.com"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "access_token",
    "param_location": "query",
    "how_to_get": "Register at https://account.mapbox.com",
    "cost": "Free: 200K map loads/month. Geocoding: $5/1000 requests"
  },
  "capabilities": [
    {
      "id": "geocoding",
      "description_for_ai": "Forward and reverse geocoding with Mapbox. Convert addresses to coordinates and back.",
      "intent": [
        "geocode Mapbox",
        "address to coordinates",
        "location lookup",
        "геокодирование Mapbox"
      ],
      "endpoint": "GET https://api.mapbox.com/geocoding/v5/mapbox.places/{search_text}.json",
      "input": {
        "search_text": {
          "type": "string",
          "description": "Address or place name to geocode",
          "required": true
        },
        "proximity": {
          "type": "string",
          "description": "Bias results to lng,lat e.g. -74.0,40.7",
          "required": false
        },
        "country": {
          "type": "string",
          "description": "ISO 3166-1 country code filter",
          "required": false
        },
        "language": {
          "type": "string",
          "description": "IETF language tag: en, ru, de",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 5
        },
        "types": {
          "type": "string",
          "description": "country, region, place, address, poi",
          "required": false
        }
      },
      "output": {
        "type": "geocode",
        "fields": [
          "features[0].center [lng, lat]",
          "features[0].place_name",
          "features[0].id",
          "features[0].context"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "directions",
      "description_for_ai": "Get turn-by-turn directions between coordinates. Driving, cycling, walking.",
      "intent": [
        "directions Mapbox",
        "route Mapbox",
        "driving route",
        "маршрут Mapbox"
      ],
      "endpoint": "GET https://api.mapbox.com/directions/v5/mapbox/{profile}/{coordinates}",
      "input": {
        "profile": {
          "type": "string",
          "description": "mapbox/driving, mapbox/driving-traffic, mapbox/walking, mapbox/cycling",
          "required": true
        },
        "coordinates": {
          "type": "string",
          "description": "lng,lat;lng,lat;... semicolon-separated waypoints",
          "required": true
        },
        "steps": {
          "type": "boolean",
          "description": "Include turn-by-turn instructions",
          "default": false
        },
        "alternatives": {
          "type": "boolean",
          "description": "Return alternative routes",
          "default": false
        },
        "geometries": {
          "type": "string",
          "description": "geojson or polyline",
          "default": "geojson"
        }
      },
      "output": {
        "type": "route",
        "fields": [
          "routes[0].distance (meters)",
          "routes[0].duration (seconds)",
          "routes[0].legs[0].steps[0].maneuver.instruction",
          "routes[0].geometry"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "isochrone",
      "description_for_ai": "Get areas reachable within a time limit from a location. Good for service area analysis.",
      "intent": [
        "isochrone Mapbox",
        "reachable area",
        "drive time zone",
        "зона доступности"
      ],
      "endpoint": "GET https://api.mapbox.com/isochrone/v1/mapbox/{profile}/{coordinates}",
      "input": {
        "profile": {
          "type": "string",
          "description": "mapbox/driving, mapbox/walking, mapbox/cycling",
          "required": true
        },
        "coordinates": {
          "type": "string",
          "description": "lng,lat of center",
          "required": true
        },
        "contours_minutes": {
          "type": "string",
          "description": "Comma-separated times e.g. 5,10,15",
          "required": true
        },
        "polygons": {
          "type": "boolean",
          "description": "Return as polygon (true) or lines (false)",
          "default": true
        }
      },
      "output": {
        "type": "geojson",
        "fields": [
          "features[0].geometry.coordinates",
          "features[0].properties.contour (minutes)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "matrix",
      "description_for_ai": "Calculate travel durations or distances between multiple origins and destinations.",
      "intent": [
        "distance matrix Mapbox",
        "travel time matrix",
        "routing matrix",
        "матрица расстояний Mapbox"
      ],
      "endpoint": "GET https://api.mapbox.com/directions-matrix/v1/mapbox/{profile}/{coordinates}",
      "input": {
        "profile": {
          "type": "string",
          "required": true
        },
        "coordinates": {
          "type": "string",
          "description": "lng,lat;... all waypoints",
          "required": true
        },
        "sources": {
          "type": "string",
          "description": "Indices of source points: 0;1 or all",
          "default": "all"
        },
        "destinations": {
          "type": "string",
          "description": "Indices of destination points",
          "default": "all"
        },
        "annotations": {
          "type": "string",
          "description": "duration, distance, or duration,distance",
          "default": "duration"
        }
      },
      "output": {
        "type": "matrix",
        "fields": [
          "durations[0][0] (seconds)",
          "distances[0][0] (meters)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_places",
      "description_for_ai": "Search for places and points of interest with Mapbox Places API.",
      "intent": [
        "search places Mapbox",
        "find POI",
        "nearby places",
        "поиск мест Mapbox"
      ],
      "endpoint": "GET https://api.mapbox.com/geocoding/v5/mapbox.places/{query}.json",
      "input": {
        "query": {
          "type": "string",
          "required": true
        },
        "types": {
          "type": "string",
          "description": "poi, address, neighborhood, place, locality",
          "required": false
        },
        "proximity": {
          "type": "string",
          "description": "lng,lat",
          "required": false
        },
        "bbox": {
          "type": "string",
          "description": "min_lng,min_lat,max_lng,max_lat",
          "required": false
        }
      },
      "output": {
        "type": "list<place>",
        "fields": [
          "features[0].place_name",
          "features[0].center",
          "features[0].properties.category"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "static_map_image",
      "description_for_ai": "Generate a static map image with custom markers and overlays.",
      "intent": [
        "static map",
        "map image",
        "map screenshot",
        "изображение карты Mapbox"
      ],
      "endpoint": "GET https://api.mapbox.com/styles/v1/{username}/{style_id}/static/{overlay}/{lon},{lat},{zoom}/{width}x{height}",
      "input": {
        "style_id": {
          "type": "string",
          "description": "streets-v12, satellite-v9, light-v11, dark-v11, outdoors-v12",
          "required": true
        },
        "lon": {
          "type": "float",
          "description": "Center longitude",
          "required": true
        },
        "lat": {
          "type": "float",
          "required": true
        },
        "zoom": {
          "type": "float",
          "description": "0-22",
          "required": true
        },
        "width": {
          "type": "integer",
          "description": "1-1280 pixels",
          "default": 600
        },
        "height": {
          "type": "integer",
          "default": 400
        },
        "overlay": {
          "type": "string",
          "description": "pin-s+f44(lon,lat) for marker",
          "required": false
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "PNG image binary"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}