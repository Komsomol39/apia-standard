{
  "apia": "1.0",
  "service": {
    "id": "unsplash",
    "name": "Unsplash API",
    "description_for_ai": "Free high-quality stock photos API. 5M+ professional photos. Search by keyword, get random photo, download. Free tier: 50 requests/hour. Perfect for adding visual content to apps.",
    "url": "https://unsplash.com",
    "api_base": "https://api.unsplash.com",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://unsplash.com/documentation"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Client-ID YOUR_ACCESS_KEY",
    "how_to_get": "Register at https://unsplash.com/developers — free",
    "cost": "Free: 50 req/hour. Production: unlimited with approval"
  },
  "capabilities": [
    {
      "id": "search_photos",
      "description_for_ai": "Search free high-quality stock photos on Unsplash. Returns photos with download URLs and photographer credits.",
      "intent": [
        "stock photos",
        "free images",
        "unsplash search",
        "бесплатные фото unsplash"
      ],
      "endpoint": "GET https://api.unsplash.com/search/photos",
      "input": {
        "query": {
          "type": "string",
          "required": true
        },
        "per_page": {
          "type": "integer",
          "default": 10
        },
        "page": {
          "type": "integer",
          "default": 1
        },
        "orientation": {
          "type": "string",
          "description": "landscape, portrait, squarish",
          "required": false
        },
        "color": {
          "type": "string",
          "description": "black_and_white, black, white, yellow, orange, red, purple, magenta, green, teal, blue",
          "required": false
        },
        "order_by": {
          "type": "string",
          "description": "relevant or latest",
          "default": "relevant"
        }
      },
      "output": {
        "type": "list<photo>",
        "fields": [
          "results[0].id",
          "results[0].urls.regular",
          "results[0].urls.thumb",
          "results[0].description",
          "results[0].user.name",
          "results[0].links.download"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_photo",
      "description_for_ai": "Get a specific photo with full metadata: dimensions, EXIF, location, tags, download link.",
      "intent": [
        "photo details unsplash",
        "get image unsplash",
        "photo info",
        "детали фото unsplash"
      ],
      "endpoint": "GET https://api.unsplash.com/photos/{id}",
      "input": {
        "id": {
          "type": "string",
          "description": "Photo ID from search results",
          "required": true
        }
      },
      "output": {
        "type": "photo",
        "fields": [
          "id",
          "urls.full",
          "urls.regular",
          "user.name",
          "width",
          "height",
          "exif.model",
          "location.name",
          "downloads"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "download_photo",
      "description_for_ai": "Trigger a download event and get the full-resolution download URL. Required by Unsplash guidelines when downloading a photo.",
      "intent": [
        "download unsplash photo",
        "free stock image download",
        "скачать фото unsplash"
      ],
      "endpoint": "GET https://api.unsplash.com/photos/{id}/download",
      "input": {
        "id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "download",
        "fields": [
          "url (direct download link to full-resolution image)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_random_photo",
      "description_for_ai": "Get one or multiple random photos. Optionally filter by query, orientation, or collection.",
      "intent": [
        "random photo unsplash",
        "random image",
        "random stock photo",
        "случайное фото unsplash"
      ],
      "endpoint": "GET https://api.unsplash.com/photos/random",
      "input": {
        "query": {
          "type": "string",
          "description": "Filter random photos by topic",
          "required": false
        },
        "count": {
          "type": "integer",
          "description": "Number of photos 1-30",
          "default": 1
        },
        "orientation": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "photo or list<photo>",
        "fields": [
          "urls.regular",
          "user.name",
          "description",
          "links.download"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "attribution": "Must credit photographer: Photo by {user.name} on Unsplash. Link to photo URL.",
    "sizes": "urls.thumb (small), urls.regular (1080px), urls.full (max), urls.raw (original)."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}