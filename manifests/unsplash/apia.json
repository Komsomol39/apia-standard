{
  "apia": "1.0",
  "service": {
    "id": "unsplash",
    "name": "Unsplash API",
    "description_for_ai": "Free high-quality stock photos API. 5M+ professional photos. Search by keyword, get random photo, download. Free tier: 50 requests/hour. Perfect for adding visual content to apps.",
    "url": "https://unsplash.com",
    "api_base": "https://api.unsplash.com",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://unsplash.com/documentation"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Client-ID YOUR_ACCESS_KEY",
    "how_to_get": "Register at https://unsplash.com/developers — free",
    "cost": "Free: 50 req/hour. Production: unlimited with approval"
  },
  "capabilities": [
    {
      "id": "search_photos",
      "description_for_ai": "Search free high-resolution photos on Unsplash.",
      "intent": [
        "search Unsplash",
        "free photos",
        "stock photos Unsplash",
        "поиск фото Unsplash"
      ],
      "endpoint": "GET https://api.unsplash.com/search/photos",
      "input": {
        "query": {
          "type": "string",
          "required": true
        },
        "per_page": {
          "type": "integer",
          "default": 10
        },
        "page": {
          "type": "integer",
          "default": 1
        },
        "orientation": {
          "type": "string",
          "description": "landscape, portrait, squarish",
          "required": false
        },
        "color": {
          "type": "string",
          "description": "black_and_white, black, white, yellow, orange, red, purple, magenta, green, teal, blue",
          "required": false
        }
      },
      "output": {
        "type": "list<photo>",
        "fields": [
          "results[0].id",
          "results[0].description",
          "results[0].urls.raw",
          "results[0].urls.full",
          "results[0].urls.regular",
          "results[0].user.name",
          "results[0].links.download"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_photo",
      "description_for_ai": "Get details and download URL for a specific Unsplash photo.",
      "intent": [
        "photo details Unsplash",
        "download Unsplash",
        "photo URL Unsplash",
        "фото Unsplash по ID"
      ],
      "endpoint": "GET https://api.unsplash.com/photos/{id}",
      "input": {
        "id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "photo",
        "fields": [
          "id",
          "description",
          "urls.raw",
          "urls.full",
          "width",
          "height",
          "user.name",
          "links.download_location"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "random_photo",
      "description_for_ai": "Get a random photo, optionally filtered by query or collection.",
      "intent": [
        "random photo Unsplash",
        "random image",
        "surprise photo",
        "случайное фото Unsplash"
      ],
      "endpoint": "GET https://api.unsplash.com/photos/random",
      "input": {
        "query": {
          "type": "string",
          "description": "Filter by topic keyword",
          "required": false
        },
        "orientation": {
          "type": "string",
          "required": false
        },
        "count": {
          "type": "integer",
          "description": "Number of photos 1-30",
          "default": 1
        }
      },
      "output": {
        "type": "photo or list<photo>",
        "fields": [
          "id",
          "urls.regular",
          "description",
          "user.name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_user_photos",
      "description_for_ai": "Get all photos by a specific Unsplash photographer.",
      "intent": [
        "photographer photos",
        "user photos Unsplash",
        "creator content Unsplash",
        "фото фотографа Unsplash"
      ],
      "endpoint": "GET https://api.unsplash.com/users/{username}/photos",
      "input": {
        "username": {
          "type": "string",
          "required": true
        },
        "per_page": {
          "type": "integer",
          "default": 10
        },
        "page": {
          "type": "integer",
          "default": 1
        },
        "order_by": {
          "type": "string",
          "description": "latest, oldest, popular, views, downloads",
          "default": "latest"
        }
      },
      "output": {
        "type": "list<photo>",
        "fields": [
          "[0].id",
          "[0].urls.regular",
          "[0].description",
          "[0].likes",
          "[0].downloads"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_topics",
      "description_for_ai": "List editorial topics/collections on Unsplash.",
      "intent": [
        "Unsplash topics",
        "photo categories",
        "collections Unsplash",
        "темы Unsplash"
      ],
      "endpoint": "GET https://api.unsplash.com/topics",
      "input": {
        "per_page": {
          "type": "integer",
          "default": 10
        },
        "order_by": {
          "type": "string",
          "description": "featured, latest, oldest, position",
          "default": "featured"
        }
      },
      "output": {
        "type": "list<topic>",
        "fields": [
          "[0].id",
          "[0].slug",
          "[0].title",
          "[0].total_photos",
          "[0].cover_photo.urls.regular"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "attribution": "Must credit photographer: Photo by {user.name} on Unsplash. Link to photo URL.",
    "sizes": "urls.thumb (small), urls.regular (1080px), urls.full (max), urls.raw (original)."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}