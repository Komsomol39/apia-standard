{
  "apia": "1.0",
  "service": {
    "id": "foursquare",
    "name": "Foursquare Places API",
    "description_for_ai": "Global POI database with 100M+ places. Business categories, hours, ratings, photos. Powers apps like Apple Maps, Snapchat, Uber. Use for finding nearby places, business info, check-ins.",
    "url": "https://foursquare.com",
    "api_base": "https://api.foursquare.com/v3",
    "category": "maps",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.foursquare.com/reference/place-search"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: YOUR_API_KEY",
    "how_to_get": "Register at https://location.foursquare.com/developer",
    "cost": "Free: 1000 API calls/day. Paid from $0.005/call"
  },
  "capabilities": [
    {
      "id": "place_search",
      "description_for_ai": "Global POI database with 100M+ places. Business categories, hours, ratings, photos. Powers apps like Apple Maps, Snapchat, Uber. Use for finding nearby places, business info, check-ins. Search for places near coordinates by category or keyword. Returns name, address, hours, distance, rating.",
      "intent": [
        "places nearby",
        "find restaurant",
        "coffee shop near me",
        "foursquare search",
        "POI search"
      ],
      "endpoint": "GET https://api.foursquare.com/v3/places/search",
      "input": {
        "query": {
          "type": "string",
          "description": "Search term e.g. coffee, pizza, bank",
          "required": false
        },
        "ll": {
          "type": "string",
          "description": "Latitude,Longitude e.g. 55.75,37.62",
          "required": false
        },
        "radius": {
          "type": "integer",
          "description": "Search radius in meters (unless otherwise specified)",
          "default": 500
        },
        "categories": {
          "type": "string",
          "description": "Category IDs comma-separated",
          "required": false
        },
        "open_now": {
          "type": "boolean",
          "description": "Filter to currently open places",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 10,
          "max": 50,
          "description": "Maximum number of results to return"
        }
      },
      "output": {
        "type": "list<place>",
        "fields": [
          "fsq_id",
          "name",
          "location.address",
          "geocodes.main",
          "categories",
          "hours.open_now",
          "rating",
          "distance"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}