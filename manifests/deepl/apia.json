{
  "apia": "1.0",
  "service": {
    "id": "deepl",
    "name": "DeepL Translate API",
    "description_for_ai": "Highest quality machine translation API. Supports 30+ languages with neural machine translation. Better than Google Translate for European languages. Free tier: 500,000 characters/month. Use when user needs to translate text between languages.",
    "url": "https://deepl.com",
    "api_base": "https://api-free.deepl.com/v2",
    "category": "nlp",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.deepl.com/docs-api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: DeepL-Auth-Key YOUR_KEY",
    "how_to_get": "Register at https://www.deepl.com/pro-api — free tier available",
    "cost": "Free: 500K chars/month. Pro: $5.49/month for 1M chars"
  },
  "capabilities": [
    {
      "id": "translate_text",
      "description_for_ai": "Translate text with DeepL — the most accurate translation AI available. 33 languages.",
      "intent": [
        "translate DeepL",
        "DeepL translation",
        "high quality translation",
        "перевод DeepL"
      ],
      "endpoint": "POST https://api-free.deepl.com/v2/translate",
      "input": {
        "text": {
          "type": "array",
          "description": "Text(s) to translate. Array for batch.",
          "required": true
        },
        "target_lang": {
          "type": "string",
          "description": "Target language: EN-US, EN-GB, DE, FR, ES, IT, JA, KO, PT-BR, PT-PT, RU, ZH, NL, PL, CS, SK, DA, FI, SV, RO, HU, BG, EL, LT, LV, ET, SL",
          "required": true
        },
        "source_lang": {
          "type": "string",
          "description": "Source language (auto-detected if omitted)",
          "required": false
        },
        "formality": {
          "type": "string",
          "description": "default, more (formal), less (informal), prefer_more, prefer_less",
          "required": false
        },
        "split_sentences": {
          "type": "string",
          "description": "0 (no split), 1 (split on newlines), nonewlines",
          "default": "1"
        }
      },
      "output": {
        "type": "translation",
        "fields": [
          "translations[0].text",
          "translations[0].detected_source_language"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "translate_document",
      "description_for_ai": "Translate entire documents (PDF, Word, PowerPoint) with DeepL while preserving formatting.",
      "intent": [
        "translate document DeepL",
        "document translation",
        "translate PDF DeepL",
        "перевод документа DeepL"
      ],
      "endpoint": "POST https://api-free.deepl.com/v2/document",
      "input": {
        "file": {
          "type": "file",
          "description": "Document file: .docx, .pptx, .xlsx, .pdf, .htm, .html, .txt, .xlf, .xliff, .srt",
          "required": true
        },
        "target_lang": {
          "type": "string",
          "required": true
        },
        "source_lang": {
          "type": "string",
          "required": false
        },
        "filename": {
          "type": "string",
          "description": "Original filename for format detection",
          "required": false
        }
      },
      "output": {
        "type": "document",
        "fields": [
          "document_id",
          "document_key (save for downloading)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_usage",
      "description_for_ai": "Get DeepL API quota usage: characters translated vs limit.",
      "intent": [
        "DeepL usage",
        "translation quota",
        "characters remaining",
        "квота DeepL"
      ],
      "endpoint": "GET https://api-free.deepl.com/v2/usage",
      "input": {},
      "output": {
        "type": "usage",
        "fields": [
          "character_count",
          "character_limit"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_languages",
      "description_for_ai": "Get all available source and target languages for DeepL.",
      "intent": [
        "DeepL languages",
        "supported languages",
        "translation languages",
        "языки DeepL"
      ],
      "endpoint": "GET https://api-free.deepl.com/v2/languages",
      "input": {
        "type": {
          "type": "string",
          "description": "source or target",
          "required": true
        }
      },
      "output": {
        "type": "list<language>",
        "fields": [
          "[0].language (code)",
          "[0].name",
          "[0].supports_formality"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "improve_writing",
      "description_for_ai": "Rephrase and improve text style with DeepL Write (English and German).",
      "intent": [
        "DeepL Write",
        "improve text",
        "rephrase text",
        "улучшить текст DeepL"
      ],
      "endpoint": "POST https://api-free.deepl.com/v2/write/result",
      "input": {
        "text": {
          "type": "array",
          "description": "Text(s) to improve",
          "required": true
        },
        "target_lang": {
          "type": "string",
          "description": "EN (English), DE (German)",
          "required": true
        },
        "style": {
          "type": "string",
          "description": "default, confident, diplomatic, enthusiastic, fluent, academic",
          "required": false
        }
      },
      "output": {
        "type": "improvement",
        "fields": [
          "improvements[0].text",
          "improvements[0].detected_source_language"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "lang_codes": "English: EN-US or EN-GB. Russian: RU. German: DE. French: FR. Chinese: ZH. Japanese: JA. Korean: KO.",
    "auto_detect": "Omit source_lang to let DeepL auto-detect — works well for most cases.",
    "formality_tip": "Formality parameter only works for some languages (DE, FR, IT, ES, NL, PL, PT, RU). Use 'more' for business texts.",
    "batch_tip": "Send multiple texts in one request as an array — much more efficient than multiple single requests."
  },
  "limits": {
    "free_chars_per_month": 500000,
    "commercial_use": true,
    "attribution_required": false
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}