{
  "apia": "1.0",
  "service": {
    "id": "deepl",
    "name": "DeepL Translate API",
    "description_for_ai": "Highest quality machine translation API. Supports 30+ languages with neural machine translation. Better than Google Translate for European languages. Free tier: 500,000 characters/month. Use when user needs to translate text between languages.",
    "url": "https://deepl.com",
    "api_base": "https://api-free.deepl.com/v2",
    "category": "nlp",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.deepl.com/docs-api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: DeepL-Auth-Key YOUR_KEY",
    "how_to_get": "Register at https://www.deepl.com/pro-api — free tier available",
    "cost": "Free: 500K chars/month. Pro: $5.49/month for 1M chars"
  },
  "capabilities": [
    {
      "id": "translate_text",
      "description_for_ai": "Translate text with DeepL — highest quality machine translation, especially for European languages. Preserves formatting.",
      "intent": [
        "translate",
        "translation",
        "deepl translate",
        "перевести текст",
        "перевод"
      ],
      "endpoint": "POST https://api-free.deepl.com/v2/translate",
      "input": {
        "text": {
          "type": "array",
          "description": "Array of strings to translate (batch up to 50)",
          "required": true
        },
        "target_lang": {
          "type": "string",
          "description": "Target language: EN-US, EN-GB, DE, FR, ES, IT, RU, ZH, JA, PT-BR, PT-PT, NL, PL, CS, RO, HU, BG, DA, FI, EL, SK, SL, SV, LT, LV, ET",
          "required": true
        },
        "source_lang": {
          "type": "string",
          "description": "Source language (auto-detected if omitted)",
          "required": false
        },
        "formality": {
          "type": "string",
          "description": "default, more (formal), less (informal), prefer_more, prefer_less",
          "required": false
        },
        "preserve_formatting": {
          "type": "boolean",
          "default": false
        },
        "split_sentences": {
          "type": "string",
          "description": "0 (none), 1 (punctuation), nonewlines",
          "default": "1"
        }
      },
      "output": {
        "type": "translation",
        "fields": [
          "translations[0].text",
          "translations[0].detected_source_language"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "translate_document",
      "description_for_ai": "Translate entire documents (PDF, DOCX, PPTX, XLSX, HTML, TXT) with DeepL while preserving layout.",
      "intent": [
        "translate document",
        "translate PDF",
        "translate DOCX",
        "перевести документ",
        "перевести файл"
      ],
      "endpoint": "POST https://api-free.deepl.com/v2/document",
      "input": {
        "file": {
          "type": "file",
          "description": "Document to translate. Supported: .txt, .html, .docx, .pptx, .xlsx, .pdf",
          "required": true
        },
        "target_lang": {
          "type": "string",
          "required": true
        },
        "source_lang": {
          "type": "string",
          "required": false
        },
        "formality": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "document",
        "fields": [
          "document_id",
          "document_key (needed to check status and download)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_usage",
      "description_for_ai": "Check DeepL API usage: characters translated and character limit for current billing period.",
      "intent": [
        "deepl usage",
        "translation quota",
        "API limit deepl",
        "лимит deepl"
      ],
      "endpoint": "GET https://api-free.deepl.com/v2/usage",
      "input": {},
      "output": {
        "type": "usage",
        "fields": [
          "character_count",
          "character_limit"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_languages",
      "description_for_ai": "Get list of all supported source and target languages.",
      "intent": [
        "deepl languages",
        "supported languages",
        "translation languages",
        "языки deepl"
      ],
      "endpoint": "GET https://api-free.deepl.com/v2/languages",
      "input": {
        "type": {
          "type": "string",
          "description": "source or target",
          "required": false
        }
      },
      "output": {
        "type": "list<language>",
        "fields": [
          "[0].language",
          "[0].name",
          "[0].supports_formality"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "lang_codes": "English: EN-US or EN-GB. Russian: RU. German: DE. French: FR. Chinese: ZH. Japanese: JA. Korean: KO.",
    "auto_detect": "Omit source_lang to let DeepL auto-detect — works well for most cases.",
    "formality_tip": "Formality parameter only works for some languages (DE, FR, IT, ES, NL, PL, PT, RU). Use 'more' for business texts.",
    "batch_tip": "Send multiple texts in one request as an array — much more efficient than multiple single requests."
  },
  "limits": {
    "free_chars_per_month": 500000,
    "commercial_use": true,
    "attribution_required": false
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}