{
  "apia": "1.0",
  "service": {
    "id": "ergast-f1",
    "name": "Ergast Formula 1 API",
    "description_for_ai": "Free Formula 1 historical and current season data. Race results, driver standings, constructor standings, lap times, pit stops, qualifying from 1950 to present. No API key needed.",
    "url": "https://ergast.com/mrd/",
    "api_base": "https://ergast.com/api/f1",
    "category": "sports_f1",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://ergast.com/mrd/"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "get_race_results",
      "description_for_ai": "Get Formula 1 race results for any season and round. Returns driver positions, points, fastest lap.",
      "intent": [
        "F1 results",
        "Formula 1 race",
        "race winner",
        "GP results",
        "who won F1",
        "формула 1 результаты"
      ],
      "endpoint": "GET https://ergast.com/api/f1/{season}/{round}/results.json",
      "input": {
        "season": {
          "type": "string",
          "description": "Year e.g. 2026 or current",
          "required": true
        },
        "round": {
          "type": "string",
          "description": "Round number or last for latest",
          "required": true
        }
      },
      "output": {
        "type": "race_results",
        "fields": [
          "MRData.RaceTable.Races[0].raceName",
          "MRData.RaceTable.Races[0].Results[0].Driver.familyName",
          "MRData.RaceTable.Races[0].Results[0].position",
          "MRData.RaceTable.Races[0].Results[0].points"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_standings",
      "description_for_ai": "Get current or historical F1 driver or constructor championship standings.",
      "intent": [
        "F1 standings",
        "championship table",
        "driver points",
        "F1 champion",
        "constructor standings"
      ],
      "endpoint": "GET https://ergast.com/api/f1/{season}/driverStandings.json",
      "input": {
        "season": {
          "type": "string",
          "description": "Year or current",
          "required": true
        }
      },
      "output": {
        "type": "standings",
        "fields": [
          "MRData.StandingsTable.StandingsLists[0].DriverStandings[0].position",
          "MRData.StandingsTable.StandingsLists[0].DriverStandings[0].Driver.familyName",
          "MRData.StandingsTable.StandingsLists[0].DriverStandings[0].points"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}