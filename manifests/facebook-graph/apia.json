{
  "apia": "1.0",
  "service": {
    "id": "facebook-graph",
    "name": "Facebook Graph API",
    "description_for_ai": "Facebook and Instagram platform API. Pages, posts, ads, user data, events, groups. 3B+ users. Manage Facebook Pages, run ads, get insights. Requires app review for most endpoints.",
    "url": "https://facebook.com",
    "api_base": "https://graph.facebook.com/v20.0",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.facebook.com/docs/graph-api"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Create app at https://developers.facebook.com/apps",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "get_page_info",
      "description_for_ai": "Get Facebook Page details: name, fans, category, description.",
      "intent": [
        "facebook page",
        "fb page info",
        "page details facebook",
        "страница facebook"
      ],
      "endpoint": "GET https://graph.facebook.com/v19.0/{page_id}",
      "input": {
        "page_id": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "id,name,fan_count,category,description,link,phone,email,website",
          "required": false
        },
        "access_token": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "page",
        "fields": [
          "id",
          "name",
          "fan_count",
          "category",
          "description"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_post",
      "description_for_ai": "Create a post on a Facebook Page with text, link, or photo.",
      "intent": [
        "post facebook",
        "facebook post",
        "publish facebook",
        "пост facebook"
      ],
      "endpoint": "POST https://graph.facebook.com/v19.0/{page_id}/feed",
      "input": {
        "page_id": {
          "type": "string",
          "required": true
        },
        "message": {
          "type": "string",
          "description": "Post text",
          "required": false
        },
        "link": {
          "type": "string",
          "description": "URL to share",
          "required": false
        },
        "published": {
          "type": "boolean",
          "default": true
        },
        "access_token": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "post",
        "fields": [
          "id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_page_insights",
      "description_for_ai": "Get Facebook Page analytics: reach, impressions, page views, engagement.",
      "intent": [
        "facebook analytics",
        "page insights",
        "facebook stats",
        "аналитика facebook"
      ],
      "endpoint": "GET https://graph.facebook.com/v19.0/{page_id}/insights",
      "input": {
        "page_id": {
          "type": "string",
          "required": true
        },
        "metric": {
          "type": "string",
          "description": "page_impressions,page_reach,page_views_total,page_fans,page_engaged_users",
          "required": true
        },
        "period": {
          "type": "string",
          "description": "day, week, days_28, month",
          "required": true
        },
        "access_token": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "insights",
        "fields": [
          "data[0].name",
          "data[0].values[0].value",
          "data[0].period"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "search_pages",
      "description_for_ai": "Search for Facebook Pages by name or keyword.",
      "intent": [
        "search facebook page",
        "find facebook page",
        "поиск страницы facebook"
      ],
      "endpoint": "GET https://graph.facebook.com/v19.0/search",
      "input": {
        "q": {
          "type": "string",
          "required": true
        },
        "type": {
          "type": "string",
          "default": "page"
        },
        "fields": {
          "type": "string",
          "description": "id,name,fan_count,category",
          "required": false
        },
        "access_token": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<page>",
        "fields": [
          "data[0].id",
          "data[0].name",
          "data[0].fan_count",
          "data[0].category"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "access_token": "Page posts require a Page Access Token (not User token). Get via: GET /{user_id}/accounts to list pages and their tokens.",
    "permissions": "For reading: pages_read_engagement. For publishing: pages_manage_posts. Request via App Review for production.",
    "rate_limits": "Facebook uses app-level and user-level rate limits. Watch X-App-Usage and X-Ad-Account-Usage headers."
  }
}