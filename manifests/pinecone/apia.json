{
  "apia": "1.0",
  "service": {
    "id": "pinecone",
    "name": "Pinecone API",
    "description_for_ai": "Leading vector database for AI applications. Store and search embeddings for semantic search, RAG, recommendations. Serverless — no infrastructure. Use after generating embeddings with OpenAI/Cohere/HuggingFace.",
    "url": "https://pinecone.io",
    "api_base": "https://api.pinecone.io",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.pinecone.io"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Api-Key: ...",
    "how_to_get": "Register at https://app.pinecone.io — free tier available",
    "cost": "Free: 2GB storage. Serverless from $0.033/GB/month"
  },
  "capabilities": [
    {
      "id": "upsert_vectors",
      "description_for_ai": "Store vectors in Pinecone index. Use for RAG — store embedded documents with metadata.",
      "intent": [
        "store embeddings Pinecone",
        "upsert vectors",
        "RAG storage",
        "векторное хранилище Pinecone"
      ],
      "endpoint": "POST https://{index-host}/vectors/upsert",
      "input": {
        "vectors": {
          "type": "array",
          "description": "[{id: 'doc1', values: [0.1, 0.2, ...], metadata: {text: 'source text', url: 'source url'}}]",
          "required": true
        },
        "namespace": {
          "type": "string",
          "description": "Logical partition for vectors",
          "required": false
        }
      },
      "output": {
        "type": "upsert",
        "fields": [
          "upsertedCount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "query_vectors",
      "description_for_ai": "Find most similar vectors (semantic search) by query vector. Returns top K matches.",
      "intent": [
        "vector search",
        "semantic search Pinecone",
        "RAG retrieval",
        "семантический поиск Pinecone"
      ],
      "endpoint": "POST https://{index-host}/query",
      "input": {
        "vector": {
          "type": "array",
          "description": "Query embedding vector (float array)",
          "required": true
        },
        "topK": {
          "type": "integer",
          "description": "Number of results to return",
          "default": 10
        },
        "filter": {
          "type": "object",
          "description": "Metadata filter: {source: {$eq: 'docs'}}",
          "required": false
        },
        "includeMetadata": {
          "type": "boolean",
          "default": true
        },
        "namespace": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "matches",
        "fields": [
          "matches[0].id",
          "matches[0].score",
          "matches[0].metadata.text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "delete_vectors",
      "description_for_ai": "Delete specific vectors or all vectors in a namespace.",
      "intent": [
        "delete vectors Pinecone",
        "remove embeddings",
        "clear namespace",
        "удалить векторы Pinecone"
      ],
      "endpoint": "POST https://{index-host}/vectors/delete",
      "input": {
        "ids": {
          "type": "array",
          "description": "Vector IDs to delete",
          "required": false
        },
        "deleteAll": {
          "type": "boolean",
          "description": "Delete all vectors in namespace",
          "required": false
        },
        "namespace": {
          "type": "string",
          "required": false
        },
        "filter": {
          "type": "object",
          "description": "Delete by metadata filter",
          "required": false
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "{}"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_indexes",
      "description_for_ai": "List all Pinecone indexes in your project.",
      "intent": [
        "Pinecone indexes",
        "list indexes",
        "my Pinecone",
        "список индексов Pinecone"
      ],
      "endpoint": "GET https://api.pinecone.io/indexes",
      "input": {},
      "output": {
        "type": "list<index>",
        "fields": [
          "indexes[0].name",
          "indexes[0].dimension",
          "indexes[0].metric",
          "indexes[0].status.ready",
          "indexes[0].host"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_index",
      "description_for_ai": "Create a new Pinecone vector index with specified dimensions and similarity metric.",
      "intent": [
        "create Pinecone index",
        "new vector index",
        "setup Pinecone",
        "создать индекс Pinecone"
      ],
      "endpoint": "POST https://api.pinecone.io/indexes",
      "input": {
        "name": {
          "type": "string",
          "required": true
        },
        "dimension": {
          "type": "integer",
          "description": "Vector size: 1536 for OpenAI, 768 for Cohere, 384 for MiniLM",
          "required": true
        },
        "metric": {
          "type": "string",
          "description": "cosine, euclidean, or dotproduct",
          "default": "cosine"
        },
        "spec": {
          "type": "object",
          "description": "{serverless: {cloud: 'aws', region: 'us-east-1'}}",
          "required": true
        }
      },
      "output": {
        "type": "index",
        "fields": [
          "name",
          "dimension",
          "metric",
          "status.ready",
          "host"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "rag_flow": "1) Generate embedding with OpenAI/Cohere. 2) Query Pinecone for top-K similar. 3) Pass retrieved docs to LLM as context.",
    "dimensions": "Match dimensions to your embedding model: OpenAI text-embedding-3-small=1536, Cohere embed-v3=1024."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}