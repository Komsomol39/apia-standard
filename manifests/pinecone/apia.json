{
  "apia": "1.0",
  "service": {
    "id": "pinecone",
    "name": "Pinecone API",
    "description_for_ai": "Leading vector database for AI applications. Store and search embeddings for semantic search, RAG, recommendations. Serverless — no infrastructure. Use after generating embeddings with OpenAI/Cohere/HuggingFace.",
    "url": "https://pinecone.io",
    "api_base": "https://api.pinecone.io",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.pinecone.io"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Api-Key: ...",
    "how_to_get": "Register at https://app.pinecone.io — free tier available",
    "cost": "Free: 2GB storage. Serverless from $0.033/GB/month"
  },
  "capabilities": [
    {
      "id": "upsert_vectors",
      "description_for_ai": "Insert or update vectors in a Pinecone index. Use for building semantic search, RAG, or recommendation systems.",
      "intent": [
        "pinecone upsert",
        "store embeddings",
        "vector store",
        "сохранить векторы pinecone"
      ],
      "endpoint": "POST https://{index-host}/vectors/upsert",
      "input": {
        "vectors": {
          "type": "array",
          "description": "[{id: 'unique_id', values: [0.1, 0.2, ...], metadata: {text: 'source text', category: 'article'}}]",
          "required": true
        },
        "namespace": {
          "type": "string",
          "description": "Separate namespaces for multi-tenant isolation",
          "required": false
        }
      },
      "output": {
        "type": "upsert_result",
        "fields": [
          "upsertedCount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "query_vectors",
      "description_for_ai": "Find most similar vectors to a query vector. Core operation for semantic search and RAG retrieval.",
      "intent": [
        "pinecone search",
        "semantic search",
        "find similar",
        "найти похожие",
        "RAG retrieval"
      ],
      "endpoint": "POST https://{index-host}/query",
      "input": {
        "vector": {
          "type": "array",
          "description": "Query embedding vector",
          "required": false
        },
        "id": {
          "type": "string",
          "description": "Query by existing vector ID instead of providing values",
          "required": false
        },
        "topK": {
          "type": "integer",
          "description": "Number of most similar results",
          "required": true
        },
        "filter": {
          "type": "object",
          "description": "Metadata filter: {category: {$eq: 'article'}, score: {$gte: 0.9}}",
          "required": false
        },
        "includeMetadata": {
          "type": "boolean",
          "default": true
        },
        "namespace": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "matches",
        "fields": [
          "matches[0].id",
          "matches[0].score",
          "matches[0].metadata.text",
          "matches[0].metadata"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "delete_vectors",
      "description_for_ai": "Delete vectors by IDs, by metadata filter, or delete all in namespace.",
      "intent": [
        "delete vectors pinecone",
        "remove embeddings",
        "clear namespace",
        "удалить векторы pinecone"
      ],
      "endpoint": "POST https://{index-host}/vectors/delete",
      "input": {
        "ids": {
          "type": "array",
          "description": "List of vector IDs to delete",
          "required": false
        },
        "deleteAll": {
          "type": "boolean",
          "description": "Delete all vectors in namespace",
          "default": false
        },
        "filter": {
          "type": "object",
          "description": "Delete by metadata filter",
          "required": false
        },
        "namespace": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "{}"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "describe_index_stats",
      "description_for_ai": "Get index statistics: vector count, dimension, and per-namespace breakdown.",
      "intent": [
        "pinecone stats",
        "index info",
        "vector count pinecone",
        "статистика pinecone"
      ],
      "endpoint": "POST https://{index-host}/describe_index_stats",
      "input": {
        "filter": {
          "type": "object",
          "description": "Optional metadata filter for stats",
          "required": false
        }
      },
      "output": {
        "type": "stats",
        "fields": [
          "dimension",
          "totalVectorCount",
          "namespaces (dict of namespace→count)",
          "indexFullness"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_indexes",
      "description_for_ai": "List all Pinecone indexes in the project.",
      "intent": [
        "pinecone indexes",
        "vector databases",
        "list indexes",
        "список индексов pinecone"
      ],
      "endpoint": "GET https://api.pinecone.io/indexes",
      "input": {},
      "output": {
        "type": "list<index>",
        "fields": [
          "indexes[0].name",
          "indexes[0].dimension",
          "indexes[0].metric",
          "indexes[0].status.state",
          "indexes[0].host"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "rag_flow": "1) Generate embedding with OpenAI/Cohere. 2) Query Pinecone for top-K similar. 3) Pass retrieved docs to LLM as context.",
    "dimensions": "Match dimensions to your embedding model: OpenAI text-embedding-3-small=1536, Cohere embed-v3=1024."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}