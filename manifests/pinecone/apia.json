{
  "apia": "1.0",
  "service": {
    "id": "pinecone",
    "name": "Pinecone API",
    "description_for_ai": "Leading vector database for AI applications. Store and search embeddings for semantic search, RAG, recommendations. Serverless — no infrastructure. Use after generating embeddings with OpenAI/Cohere/HuggingFace.",
    "url": "https://pinecone.io",
    "api_base": "https://api.pinecone.io",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.pinecone.io"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Api-Key: ...",
    "how_to_get": "Register at https://app.pinecone.io — free tier available",
    "cost": "Free: 2GB storage. Serverless from $0.033/GB/month"
  },
  "capabilities": [
    {
      "id": "upsert_vectors",
      "description_for_ai": "Insert or update vectors in a Pinecone index. Each vector has an ID, embedding values, and optional metadata for filtering.",
      "intent": [
        "store vectors",
        "upsert pinecone",
        "save embeddings",
        "index vectors",
        "сохранить векторы pinecone"
      ],
      "endpoint": "POST https://{index_host}/vectors/upsert",
      "input": {
        "vectors": {
          "type": "array",
          "description": "[{id: 'doc-1', values: [0.1, 0.2, ...], metadata: {text: 'chunk text', source: 'file.pdf'}}]",
          "required": true
        },
        "namespace": {
          "type": "string",
          "description": "Logical partition within index. Default namespace if omitted.",
          "required": false
        }
      },
      "output": {
        "type": "upsert",
        "fields": [
          "upsertedCount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "query_vectors",
      "description_for_ai": "Search for similar vectors using semantic similarity. Returns top K nearest neighbors with scores. Core RAG operation.",
      "intent": [
        "vector search",
        "semantic search pinecone",
        "similar documents",
        "RAG search",
        "поиск похожих векторов pinecone"
      ],
      "endpoint": "POST https://{index_host}/query",
      "input": {
        "vector": {
          "type": "array",
          "description": "Query embedding vector (float array)",
          "required": true
        },
        "topK": {
          "type": "integer",
          "description": "Number of results to return",
          "default": 10
        },
        "filter": {
          "type": "object",
          "description": "Metadata filter: {source: {$eq: 'file.pdf'}, score: {$gte: 0.8}}",
          "required": false
        },
        "includeMetadata": {
          "type": "boolean",
          "description": "Include metadata in results",
          "default": true
        },
        "includeValues": {
          "type": "boolean",
          "description": "Include vector values in results",
          "default": false
        },
        "namespace": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "matches",
        "fields": [
          "matches[0].id",
          "matches[0].score",
          "matches[0].metadata"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "delete_vectors",
      "description_for_ai": "Delete vectors by IDs or filter expression from an index.",
      "intent": [
        "delete vectors",
        "remove embeddings",
        "clear index",
        "удалить векторы pinecone"
      ],
      "endpoint": "POST https://{index_host}/vectors/delete",
      "input": {
        "ids": {
          "type": "array",
          "description": "List of vector IDs to delete",
          "required": false
        },
        "deleteAll": {
          "type": "boolean",
          "description": "Delete all vectors in namespace",
          "default": false
        },
        "filter": {
          "type": "object",
          "description": "Delete by metadata filter",
          "required": false
        },
        "namespace": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "{}"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "describe_index_stats",
      "description_for_ai": "Get index statistics: total vector count, dimension, namespace breakdown.",
      "intent": [
        "pinecone stats",
        "index info",
        "vector count",
        "статистика pinecone"
      ],
      "endpoint": "GET https://{index_host}/describe_index_stats",
      "input": {
        "filter": {
          "type": "object",
          "description": "Optional metadata filter for scoped stats",
          "required": false
        }
      },
      "output": {
        "type": "stats",
        "fields": [
          "totalVectorCount",
          "dimension",
          "indexFullness",
          "namespaces"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "rag_flow": "1) Generate embedding with OpenAI/Cohere. 2) Query Pinecone for top-K similar. 3) Pass retrieved docs to LLM as context.",
    "dimensions": "Match dimensions to your embedding model: OpenAI text-embedding-3-small=1536, Cohere embed-v3=1024."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}