{
  "apia": "1.0",
  "service": {
    "id": "wolfram-alpha",
    "name": "Wolfram Alpha API",
    "description_for_ai": "Computational knowledge engine. Answers math, science, geography, history, statistics questions with step-by-step solutions. Solves equations, computes integrals, converts units, plots functions. Use for math homework, scientific calculations, factual queries.",
    "url": "https://wolframalpha.com",
    "api_base": "https://api.wolframalpha.com",
    "category": "science",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://products.wolframalpha.com/api/documentation/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "appid",
    "param_location": "query",
    "how_to_get": "Get key at https://developer.wolframalpha.com/access",
    "cost": "Free: 2000 calls/month. Paid from $20/month"
  },
  "capabilities": [
    {
      "id": "query",
      "description_for_ai": "Answer any factual or computational query with step-by-step results. Math equations, unit conversions, science facts, statistics, geographic data.",
      "intent": [
        "compute integral",
        "вычислить",
        "unit converter",
        "solve equation",
        "решить задачу",
        "compute formula",
        "calculate",
        "конвертировать единицы",
        "unit conversion",
        "scientific query",
        "решить уравнение",
        "scientific facts",
        "mathematical answer",
        "solve math",
        "math homework",
        "math calculation"
      ],
      "endpoint": "GET https://api.wolframalpha.com/v2/query",
      "input": {
        "input": {
          "type": "string",
          "description": "Natural language query e.g. integrate x^2 dx, distance from Moscow to Beijing, derivative of sin(x)",
          "required": true
        },
        "format": {
          "type": "string",
          "default": "plaintext",
          "description": "Response format: json, xml, or csv"
        },
        "output": {
          "type": "string",
          "default": "json"
        },
        "units": {
          "type": "string",
          "description": "metric or imperial",
          "default": "metric"
        }
      },
      "output": {
        "type": "query_result",
        "fields": [
          "queryresult.pods[0].subpods[0].plaintext",
          "queryresult.pods[1].subpods[0].plaintext"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "simple_query",
      "description_for_ai": "Get a simple one-line answer to a factual question. Faster and cheaper than full query.",
      "intent": [
        "quick answer",
        "fast fact",
        "one-line result",
        "simple math",
        "simple calculation",
        "fast answer",
        "quick calculation"
      ],
      "endpoint": "GET https://api.wolframalpha.com/v1/result",
      "input": {
        "i": {
          "type": "string",
          "description": "Simple query e.g. speed of light, capital of France, 2+2",
          "required": true
        }
      },
      "output": {
        "type": "string",
        "fields": [
          "plain text answer"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "short_answer",
      "description_for_ai": "Get a short factual answer from Wolfram Alpha (fastest endpoint).",
      "intent": [
        "wolfram alpha answer",
        "quick calculation",
        "factual query",
        "ответ wolfram alpha"
      ],
      "endpoint": "GET https://api.wolframalpha.com/v1/result",
      "input": {
        "i": {
          "type": "string",
          "description": "Natural language query: 'population of France', 'sqrt(144)', 'distance from NYC to London'",
          "required": true
        }
      },
      "output": {
        "type": "text",
        "fields": [
          "Plain text answer string"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "full_results",
      "description_for_ai": "Get full structured Wolfram Alpha results with multiple pods (charts, formulas, related info).",
      "intent": [
        "wolfram full results",
        "computational knowledge",
        "detailed answer wolfram",
        "подробный ответ wolfram alpha"
      ],
      "endpoint": "GET https://api.wolframalpha.com/v2/query",
      "input": {
        "input": {
          "type": "string",
          "required": true
        },
        "format": {
          "type": "string",
          "description": "plaintext, image, MathML, Sound",
          "default": "plaintext"
        },
        "podstate": {
          "type": "string",
          "description": "Show additional pod states: 'Step-by-step solution'",
          "required": false
        },
        "units": {
          "type": "string",
          "description": "metric or nonmetric",
          "default": "metric"
        }
      },
      "output": {
        "type": "pods",
        "fields": [
          "queryresult.pods[0].title",
          "queryresult.pods[0].subpods[0].plaintext"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "spoken_result",
      "description_for_ai": "Get a spoken-language answer from Wolfram Alpha, suitable for voice assistants.",
      "intent": [
        "wolfram spoken",
        "voice answer",
        "verbal result",
        "голосовой ответ wolfram"
      ],
      "endpoint": "GET https://api.wolframalpha.com/v1/spoken",
      "input": {
        "i": {
          "type": "string",
          "required": true
        },
        "units": {
          "type": "string",
          "default": "metric"
        }
      },
      "output": {
        "type": "text",
        "fields": [
          "Natural language spoken sentence"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}