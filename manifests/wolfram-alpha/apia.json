{
  "apia": "1.0",
  "service": {
    "id": "wolfram-alpha",
    "name": "Wolfram Alpha API",
    "description_for_ai": "Computational knowledge engine. Answers math, science, geography, history, statistics questions with step-by-step solutions. Solves equations, computes integrals, converts units, plots functions. Use for math homework, scientific calculations, factual queries.",
    "url": "https://wolframalpha.com",
    "api_base": "https://api.wolframalpha.com",
    "category": "science",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://products.wolframalpha.com/api/documentation/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "appid",
    "param_location": "query",
    "how_to_get": "Get key at https://developer.wolframalpha.com/access",
    "cost": "Free: 2000 calls/month. Paid from $20/month"
  },
  "capabilities": [
    {
      "id": "short_answer",
      "description_for_ai": "Get a concise short answer to a factual question using Wolfram Alpha.",
      "intent": [
        "Wolfram Alpha answer",
        "factual question",
        "quick calculation",
        "ответ Wolfram Alpha"
      ],
      "endpoint": "GET https://api.wolframalpha.com/v1/result",
      "input": {
        "i": {
          "type": "string",
          "description": "Query: 'distance from Earth to Moon in km', 'derivative of sin(x)', 'GDP of Germany 2023'",
          "required": true
        },
        "units": {
          "type": "string",
          "description": "metric or nonmetric",
          "default": "metric"
        }
      },
      "output": {
        "type": "string",
        "fields": [
          "Plain text answer"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "full_results",
      "description_for_ai": "Get full Wolfram Alpha results with multiple pods (computations, graphs, definitions).",
      "intent": [
        "Wolfram Alpha full",
        "computation Wolfram",
        "math solve Wolfram",
        "полный ответ Wolfram Alpha"
      ],
      "endpoint": "GET https://api.wolframalpha.com/v2/query",
      "input": {
        "input": {
          "type": "string",
          "required": true
        },
        "format": {
          "type": "string",
          "description": "image,plaintext,mathml",
          "default": "plaintext"
        },
        "podstate": {
          "type": "string",
          "required": false
        },
        "units": {
          "type": "string",
          "default": "metric"
        }
      },
      "output": {
        "type": "pods",
        "fields": [
          "queryresult.pods[0].title",
          "queryresult.pods[0].subpods[0].plaintext",
          "queryresult.pods[1].subpods[0].plaintext"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "simple_image",
      "description_for_ai": "Get a simple result image from Wolfram Alpha.",
      "intent": [
        "Wolfram image",
        "result image",
        "visual answer Wolfram",
        "изображение Wolfram Alpha"
      ],
      "endpoint": "GET https://api.wolframalpha.com/v1/simple",
      "input": {
        "i": {
          "type": "string",
          "required": true
        },
        "width": {
          "type": "integer",
          "default": 500
        },
        "fontsize": {
          "type": "integer",
          "default": 22
        },
        "background": {
          "type": "string",
          "default": "white"
        }
      },
      "output": {
        "type": "image/gif",
        "fields": [
          "PNG/GIF image bytes"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "spoken_answer",
      "description_for_ai": "Get a spoken/natural language answer for voice assistants.",
      "intent": [
        "spoken answer Wolfram",
        "voice answer",
        "natural language result",
        "речевой ответ Wolfram"
      ],
      "endpoint": "GET https://api.wolframalpha.com/v1/spoken",
      "input": {
        "i": {
          "type": "string",
          "required": true
        },
        "units": {
          "type": "string",
          "default": "metric"
        }
      },
      "output": {
        "type": "string",
        "fields": [
          "Natural language sentence e.g. 'The answer is 42'"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "llm_api",
      "description_for_ai": "Get LLM-optimized Wolfram Alpha results for use in AI pipelines.",
      "intent": [
        "Wolfram LLM API",
        "AI computation",
        "structured Wolfram result",
        "Wolfram для AI"
      ],
      "endpoint": "GET https://www.wolframalpha.com/api/v1/llm-api",
      "input": {
        "input": {
          "type": "string",
          "required": true
        },
        "maxchars": {
          "type": "integer",
          "default": 6800
        }
      },
      "output": {
        "type": "text",
        "fields": [
          "Markdown-formatted result with computation steps, formulas, tables"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}