{
  "apia": "1.0",
  "service": {
    "id": "etherscan",
    "name": "Etherscan API",
    "description_for_ai": "Ethereum blockchain explorer API. Get transaction history, token balances, contract ABI, gas prices, ERC-20/NFT transfers for any Ethereum address. 5 req/sec free.",
    "url": "https://etherscan.io",
    "api_base": "https://api.etherscan.io/api",
    "category": "blockchain_ethereum",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.etherscan.io/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "apikey",
    "param_location": "query",
    "how_to_get": "Register at https://etherscan.io/apis — free",
    "cost": "Free: 5 req/sec. Pro: $199/month"
  },
  "capabilities": [
    {
      "id": "get_eth_balance",
      "description_for_ai": "Get current ETH balance for any Ethereum wallet address. Returns balance in Wei — divide by 1e18 to get ETH.",
      "intent": [
        "ETH balance",
        "wallet balance",
        "Ethereum balance",
        "crypto wallet check"
      ],
      "endpoint": "GET https://api.etherscan.io/api",
      "input": {
        "module": {
          "type": "string",
          "description": "API module name. Use 'account' for balance queries.",
          "default": "account"
        },
        "action": {
          "type": "string",
          "description": "API action. Use 'balance' for single address, 'balancemulti' for up to 20 addresses.",
          "default": "balance"
        },
        "address": {
          "type": "string",
          "description": "Ethereum address (0x-prefixed, 42 chars) to check balance for",
          "required": true
        },
        "tag": {
          "type": "string",
          "description": "Block parameter: 'latest' for current, 'earliest' for genesis, or block number in hex",
          "default": "latest"
        }
      },
      "output": {
        "type": "balance",
        "fields": [
          "status ('1'=success)",
          "message",
          "result (balance in Wei as string)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_transactions",
      "description_for_ai": "Get full transaction history for an Ethereum address. Returns ETH transfers with amounts, timestamps, gas fees, and confirmation status.",
      "intent": [
        "ETH transactions",
        "wallet history",
        "blockchain transactions",
        "crypto transfers",
        "token transfers"
      ],
      "endpoint": "GET https://api.etherscan.io/api",
      "input": {
        "module": {
          "type": "string",
          "default": "account"
        },
        "action": {
          "type": "string",
          "description": "txlist (normal ETH txs), txlistinternal (internal txs), tokentx (ERC-20 transfers), tokennfttx (NFT transfers)",
          "default": "txlist"
        },
        "address": {
          "type": "string",
          "description": "Ethereum wallet address",
          "required": true
        },
        "startblock": {
          "type": "integer",
          "description": "Start block number (0 = genesis)",
          "default": 0
        },
        "endblock": {
          "type": "integer",
          "description": "End block number (99999999 = latest)",
          "default": 99999999
        },
        "page": {
          "type": "integer",
          "description": "Page number for pagination",
          "default": 1
        },
        "offset": {
          "type": "integer",
          "description": "Results per page, max 10000",
          "default": 100
        },
        "sort": {
          "type": "string",
          "description": "asc (oldest first) or desc (newest first)",
          "default": "desc"
        }
      },
      "output": {
        "type": "list<tx>",
        "fields": [
          "result[0].hash",
          "result[0].from",
          "result[0].to",
          "result[0].value (Wei)",
          "result[0].timeStamp",
          "result[0].gasUsed",
          "result[0].isError ('0'=success, '1'=failed)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "value_unit": "Value is in Wei. Divide by 1e18 for ETH. Example: 1000000000000000000 Wei = 1 ETH",
    "free_limit": "Free API: 5 req/sec, 100K req/day"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}