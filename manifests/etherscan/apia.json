{
  "apia": "1.0",
  "service": {
    "id": "etherscan",
    "name": "Etherscan API",
    "description_for_ai": "Ethereum blockchain explorer API. Get transaction history, token balances, contract ABI, gas prices, ERC-20/NFT transfers for any Ethereum address. 5 req/sec free.",
    "url": "https://etherscan.io",
    "api_base": "https://api.etherscan.io/api",
    "category": "finance",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.etherscan.io/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "apikey",
    "param_location": "query",
    "how_to_get": "Register at https://etherscan.io/apis — free",
    "cost": "Free: 5 req/sec. Pro: $199/month"
  },
  "capabilities": [
    {
      "id": "get_balance",
      "description_for_ai": "Get ETH balance of any Ethereum address.",
      "intent": [
        "eth balance",
        "ethereum balance",
        "wallet balance",
        "баланс ethereum"
      ],
      "endpoint": "GET https://api.etherscan.io/api",
      "input": {
        "module": {
          "type": "string",
          "default": "account"
        },
        "action": {
          "type": "string",
          "default": "balance"
        },
        "address": {
          "type": "string",
          "description": "Ethereum address 0x...",
          "required": true
        },
        "tag": {
          "type": "string",
          "default": "latest"
        },
        "apikey": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "balance",
        "fields": [
          "result (in Wei, divide by 1e18 for ETH)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_transactions",
      "description_for_ai": "Get list of normal ETH transactions for an address.",
      "intent": [
        "ethereum transactions",
        "eth tx history",
        "wallet transactions",
        "транзакции ethereum"
      ],
      "endpoint": "GET https://api.etherscan.io/api",
      "input": {
        "module": {
          "type": "string",
          "default": "account"
        },
        "action": {
          "type": "string",
          "default": "txlist"
        },
        "address": {
          "type": "string",
          "required": true
        },
        "startblock": {
          "type": "integer",
          "default": 0
        },
        "endblock": {
          "type": "integer",
          "default": 99999999
        },
        "sort": {
          "type": "string",
          "default": "desc"
        },
        "apikey": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<tx>",
        "fields": [
          "result[0].hash",
          "result[0].from",
          "result[0].to",
          "result[0].value",
          "result[0].timeStamp"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_token_transfers",
      "description_for_ai": "Get ERC-20 token transfer events for an address or contract.",
      "intent": [
        "token transfers",
        "ERC20 transfers",
        "token history",
        "переводы токенов"
      ],
      "endpoint": "GET https://api.etherscan.io/api",
      "input": {
        "module": {
          "type": "string",
          "default": "account"
        },
        "action": {
          "type": "string",
          "default": "tokentx"
        },
        "address": {
          "type": "string",
          "required": false
        },
        "contractaddress": {
          "type": "string",
          "description": "ERC-20 contract address",
          "required": false
        },
        "sort": {
          "type": "string",
          "default": "desc"
        },
        "apikey": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<transfer>",
        "fields": [
          "result[0].tokenName",
          "result[0].tokenSymbol",
          "result[0].value",
          "result[0].from",
          "result[0].to"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_gas_price",
      "description_for_ai": "Get current Ethereum gas price in Wei and safe/fast estimates.",
      "intent": [
        "gas price",
        "ethereum gas",
        "transaction fee ETH",
        "цена газа ethereum"
      ],
      "endpoint": "GET https://api.etherscan.io/api",
      "input": {
        "module": {
          "type": "string",
          "default": "gastracker"
        },
        "action": {
          "type": "string",
          "default": "gasoracle"
        },
        "apikey": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "gas",
        "fields": [
          "result.SafeGasPrice",
          "result.ProposeGasPrice",
          "result.FastGasPrice",
          "result.suggestBaseFee"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_token_transfers",
      "description_for_ai": "Get ERC-20 token transfer events for an address.",
      "intent": [
        "token transfers",
        "ERC20 history",
        "token transactions",
        "переводы токенов Etherscan"
      ],
      "endpoint": "GET https://api.etherscan.io/api?module=account&action=tokentx",
      "input": {
        "address": {
          "type": "string",
          "required": true
        },
        "contractaddress": {
          "type": "string",
          "description": "Filter by token contract",
          "required": false
        },
        "startblock": {
          "type": "integer",
          "default": 0
        },
        "endblock": {
          "type": "integer",
          "default": 99999999
        },
        "sort": {
          "type": "string",
          "default": "desc"
        }
      },
      "output": {
        "type": "list<transfer>",
        "fields": [
          "result[0].hash",
          "result[0].tokenName",
          "result[0].tokenSymbol",
          "result[0].value",
          "result[0].from",
          "result[0].to"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_token_transfers",
      "description_for_ai": "Get ERC-20 token transfer events for a wallet or contract address.",
      "intent": [
        "token transfers Etherscan",
        "ERC-20 history",
        "token transactions",
        "трансферы токенов Etherscan"
      ],
      "endpoint": "GET https://api.etherscan.io/api?module=account&action=tokentx",
      "input": {
        "address": {
          "type": "string",
          "description": "Ethereum wallet address",
          "required": true
        },
        "contractaddress": {
          "type": "string",
          "description": "Filter by token contract",
          "required": false
        },
        "startblock": {
          "type": "integer",
          "required": false
        },
        "endblock": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "list<transfer>",
        "fields": [
          "result[0].hash",
          "result[0].from",
          "result[0].to",
          "result[0].value",
          "result[0].tokenName",
          "result[0].tokenSymbol"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "value_unit": "Value is in Wei. Divide by 1e18 for ETH. Example: 1000000000000000000 Wei = 1 ETH",
    "free_limit": "Free API: 5 req/sec, 100K req/day"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}