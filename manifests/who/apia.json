{
  "apia": "1.0",
  "service": {
    "id": "who",
    "name": "WHO GHO API (World Health Organization)",
    "description_for_ai": "Free WHO Global Health Observatory data. Health statistics for 194 countries: disease rates, mortality, life expectancy, immunization coverage, health spending. No API key needed.",
    "url": "https://www.who.int/data/gho",
    "api_base": "https://ghoapi.azureedge.net/api",
    "category": "healthcare_public",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.who.int/data/gho/info/gho-odata-api"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "get_indicator",
      "description_for_ai": "Get WHO health indicator data for countries and years. E.g. life expectancy, mortality rates, disease prevalence, vaccination coverage.",
      "intent": [
        "mortality data",
        "disease rates",
        "WHO statistics",
        "vaccination coverage",
        "world health data",
        "global health",
        "mortality rate",
        "world health",
        "life expectancy",
        "health metrics"
      ],
      "endpoint": "GET https://ghoapi.azureedge.net/api/{indicator_code}",
      "input": {
        "indicator_code": {
          "type": "string",
          "description": "WHO indicator code e.g. WHOSIS_000001=Life expectancy, MDG_0000000001=Under-5 mortality",
          "required": true
        },
        "$filter": {
          "type": "string",
          "description": "OData filter e.g. SpatialDim eq USD for USA",
          "required": false
        },
        "$top": {
          "type": "integer",
          "default": 100
        }
      },
      "output": {
        "type": "list<observation>",
        "fields": [
          "SpatialDim",
          "TimeDim",
          "NumericValue",
          "Low",
          "High"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "list_indicators",
      "description_for_ai": "List all available WHO health indicators with codes and names.",
      "intent": [
        "health metrics list",
        "WHO indicators",
        "available statistics",
        "available health data"
      ],
      "endpoint": "GET https://ghoapi.azureedge.net/api/Indicator",
      "input": {
        "$filter": {
          "type": "string",
          "required": false
        },
        "$top": {
          "type": "integer",
          "default": 100
        }
      },
      "output": {
        "type": "list<indicator>",
        "fields": [
          "IndicatorCode",
          "IndicatorName",
          "Language"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "country_codes": "Use ISO3 codes: USA, RUS, DEU, CHN, GBR etc. in SpatialDim filter.",
    "common_indicators": "WHOSIS_000001=Life expectancy at birth, MDG_0000000001=Under-5 mortality, WHS9_86=HIV prevalence"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}