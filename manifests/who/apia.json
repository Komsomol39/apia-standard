{
  "apia": "1.0",
  "service": {
    "id": "who",
    "name": "WHO GHO API (World Health Organization)",
    "description_for_ai": "Free WHO Global Health Observatory data. Health statistics for 194 countries: disease rates, mortality, life expectancy, immunization coverage, health spending. No API key needed.",
    "url": "https://www.who.int/data/gho",
    "api_base": "https://ghoapi.azureedge.net/api",
    "category": "healthcare",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.who.int/data/gho/info/gho-odata-api"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "get_indicator_data",
      "description_for_ai": "Get WHO global health indicator data by country and year (mortality, disease rates, etc.).",
      "intent": [
        "WHO health data",
        "global health statistics",
        "disease data WHO",
        "данные ВОЗ"
      ],
      "endpoint": "GET https://ghoapi.azureedge.net/api/{indicatorCode}",
      "input": {
        "indicatorCode": {
          "type": "string",
          "description": "Indicator code: WHOSIS_000001 (life expectancy), MDG_0000000026 (infant mortality), SDGHEALTHWORKERS (health workers)",
          "required": true
        },
        "$filter": {
          "type": "string",
          "description": "OData filter: SpatialDim eq 'RUS' and TimeDim eq 2020",
          "required": false
        },
        "$top": {
          "type": "integer",
          "default": 100
        }
      },
      "output": {
        "type": "list<record>",
        "fields": [
          "value[0].SpatialDim (country)",
          "value[0].TimeDim (year)",
          "value[0].NumericValue",
          "value[0].Low",
          "value[0].High"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "list_indicators",
      "description_for_ai": "List all WHO Global Health Observatory indicators.",
      "intent": [
        "WHO indicators",
        "health metrics list",
        "GHO indicators",
        "показатели ВОЗ"
      ],
      "endpoint": "GET https://ghoapi.azureedge.net/api/Indicator",
      "input": {
        "$filter": {
          "type": "string",
          "description": "Filter: contains(IndicatorName, 'mortality')",
          "required": false
        },
        "$top": {
          "type": "integer",
          "default": 50
        }
      },
      "output": {
        "type": "list<indicator>",
        "fields": [
          "value[0].IndicatorCode",
          "value[0].IndicatorName",
          "value[0].Language"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_country_data",
      "description_for_ai": "Get all health statistics for a specific country.",
      "intent": [
        "country health WHO",
        "health data country",
        "statistics country WHO",
        "здоровье страны ВОЗ"
      ],
      "endpoint": "GET https://ghoapi.azureedge.net/api/{indicatorCode}",
      "input": {
        "indicatorCode": {
          "type": "string",
          "required": true
        },
        "$filter": {
          "type": "string",
          "description": "SpatialDim eq 'DEU'",
          "required": true
        },
        "$orderby": {
          "type": "string",
          "description": "TimeDim desc",
          "required": false
        }
      },
      "output": {
        "type": "list<record>",
        "fields": [
          "value[0].NumericValue",
          "value[0].TimeDim",
          "value[0].Dim1 (sex/age group)"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "list_countries",
      "description_for_ai": "Get the list of countries and regions in the WHO GHO database.",
      "intent": [
        "WHO countries",
        "country list WHO",
        "regions WHO",
        "страны ВОЗ"
      ],
      "endpoint": "GET https://ghoapi.azureedge.net/api/DIMENSION/COUNTRY/DimensionValues",
      "input": {},
      "output": {
        "type": "list<country>",
        "fields": [
          "value[0].Code",
          "value[0].Title",
          "value[0].ParentTitle (region)"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_disease_outbreak",
      "description_for_ai": "Get WHO disease outbreak news and alerts.",
      "intent": [
        "disease outbreak WHO",
        "epidemic alert",
        "health emergency",
        "вспышка болезни ВОЗ"
      ],
      "endpoint": "GET https://www.who.int/api/news/diseaseoutbreaknews",
      "input": {
        "sf_cultureInfo": {
          "type": "string",
          "description": "Language: en, ru, fr, es, ar, zh",
          "default": "en"
        },
        "$top": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<outbreak>",
        "fields": [
          "value[0].Title",
          "value[0].PublicationDateAndTime",
          "value[0].ItemDefaultUrl",
          "value[0].Summary"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "country_codes": "Use ISO3 codes: USA, RUS, DEU, CHN, GBR etc. in SpatialDim filter.",
    "common_indicators": "WHOSIS_000001=Life expectancy at birth, MDG_0000000001=Under-5 mortality, WHS9_86=HIV prevalence"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}