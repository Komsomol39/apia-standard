{
  "apia": "1.0",
  "service": {
    "id": "avito",
    "name": "Авито API (Россия)",
    "description_for_ai": "Крупнейший классифайд России. API для бизнеса: управление объявлениями (недвижимость, авто, товары, услуги, работа), чаты с покупателями, статистика, авторизация через Авито. 60M+ уникальных пользователей в месяц.",
    "url": "https://avito.ru",
    "api_base": "https://api.avito.ru",
    "category": "ecommerce",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://developers.avito.ru/"
  },
  "auth": {
    "type": "oauth2_client_credentials",
    "anonymous_access": false,
    "token_url": "https://api.avito.ru/token",
    "how_to_get": "Зарегистрировать приложение на https://developers.avito.ru",
    "cost": "Бесплатно для базового доступа"
  },
  "capabilities": [
    {
      "id": "get_items",
      "description_for_ai": "Get your own active/inactive listings on Авито with status, price, views, and category.",
      "intent": [
        "объявления Авито",
        "мои объявления",
        "управление объявлениями",
        "публикации Авито"
      ],
      "endpoint": "GET https://api.avito.ru/core/v1/items",
      "input": {
        "status": {
          "type": "string",
          "description": "active, removed, blocked",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 25,
          "description": "Results per page. Check API docs for maximum allowed."
        },
        "page": {
          "type": "integer",
          "default": 1,
          "description": "Page number for pagination (1-indexed)"
        }
      },
      "output": {
        "type": "list<item>",
        "fields": [
          "id",
          "title",
          "status",
          "price",
          "category.id",
          "address"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_items",
      "description_for_ai": "Search public listings on Авито by keyword, category, and location. Returns ads with price, photos, and seller info.",
      "intent": [
        "классифайд",
        "найти на Авито",
        "аренда квартиры",
        "товары Авито",
        "classifieds Russia",
        "поиск объявлений",
        "купить авто",
        "купить на Авито",
        "недвижимость Авито",
        "объявления Авито",
        "авто Авито"
      ],
      "endpoint": "GET https://api.avito.ru/v1/ads",
      "input": {
        "query": {
          "type": "string",
          "required": false,
          "description": "Search query string"
        },
        "categoryId": {
          "type": "integer",
          "description": "9=Недвижимость, 4=Авто, 1=Электроника",
          "required": false
        },
        "locationId": {
          "type": "integer",
          "description": "637640=Москва, 638587=СПб",
          "required": false
        },
        "priceMin": {
          "type": "integer",
          "required": false
        },
        "priceMax": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "list<ad>",
        "fields": [
          "id",
          "title",
          "price.value",
          "location.name",
          "category.name",
          "images[0]"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "auth": "OAuth2 client credentials: POST /token with client_id and client_secret from developer.avito.ru",
    "scope": "Request scopes: items:info (view ads), job:read (employment), user:read (profile)",
    "rate_limits": "API rate limits vary by plan. Free tier: 100 req/min. Check X-RateLimit headers.",
    "categories": "Category IDs: 9=Real Estate, 4=Auto, 1=Electronics, 2=Fashion, 7=Services, 8=Jobs"
  }
}