{
  "apia": "1.0",
  "service": {
    "id": "avito",
    "name": "Авито API (Россия)",
    "description_for_ai": "Крупнейший классифайд России. API для бизнеса: управление объявлениями (недвижимость, авто, товары, услуги, работа), чаты с покупателями, статистика, авторизация через Авито. 60M+ уникальных пользователей в месяц.",
    "url": "https://avito.ru",
    "api_base": "https://api.avito.ru",
    "category": "ecommerce",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://developers.avito.ru/"
  },
  "auth": {
    "type": "oauth2_client_credentials",
    "anonymous_access": false,
    "token_url": "https://api.avito.ru/token",
    "how_to_get": "Зарегистрировать приложение на https://developers.avito.ru",
    "cost": "Бесплатно для базового доступа"
  },
  "capabilities": [
    {
      "id": "search_items",
      "description_for_ai": "Поиск объявлений на Авито по ключевым словам, категории, городу и цене.",
      "intent": [
        "объявления авито",
        "купить авито",
        "авито поиск",
        "поиск авито",
        "авто авито"
      ],
      "endpoint": "GET https://api.avito.ru/v1/ads",
      "input": {
        "query": {
          "type": "string",
          "required": false
        },
        "categoryId": {
          "type": "integer",
          "description": "ID категории. 9=Недвижимость, 4=Авто, 1=Электроника, 2=Одежда, 7=Услуги",
          "required": false
        },
        "locationId": {
          "type": "integer",
          "description": "637640=Москва, 638587=Санкт-Петербург. Получить список: /locations",
          "required": false
        },
        "priceMin": {
          "type": "integer",
          "required": false
        },
        "priceMax": {
          "type": "integer",
          "required": false
        },
        "page": {
          "type": "integer",
          "default": 1
        },
        "count": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<ad>",
        "fields": [
          "ads[0].id",
          "ads[0].title",
          "ads[0].price.value",
          "ads[0].location.name",
          "ads[0].category.name",
          "ads[0].images[0].url",
          "ads[0].url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_item",
      "description_for_ai": "Получить полное объявление Авито по ID с описанием, ценой, фото и контактами.",
      "intent": [
        "объявление авито",
        "детали авито",
        "avito item",
        "товар авито"
      ],
      "endpoint": "GET https://api.avito.ru/core/v1/items/{itemId}",
      "input": {
        "itemId": {
          "type": "integer",
          "description": "ID объявления",
          "required": true
        }
      },
      "output": {
        "type": "item",
        "fields": [
          "id",
          "title",
          "description",
          "price.value",
          "location.name",
          "category.name",
          "images",
          "stats.uniqViews",
          "url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_my_items",
      "description_for_ai": "Получить список своих объявлений с их статусами и статистикой просмотров.",
      "intent": [
        "мои объявления авито",
        "my ads avito",
        "статус объявления авито",
        "управление объявлениями"
      ],
      "endpoint": "GET https://api.avito.ru/core/v1/items",
      "input": {
        "status": {
          "type": "string",
          "description": "active, removed, blocked, old",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 25
        },
        "page": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<item>",
        "fields": [
          "resources[0].id",
          "resources[0].title",
          "resources[0].status",
          "resources[0].price",
          "resources[0].stats.views"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_messages",
      "description_for_ai": "Получить список чатов и сообщений от покупателей по объявлениям.",
      "intent": [
        "чаты авито",
        "сообщения авито",
        "avito messages",
        "покупатели авито"
      ],
      "endpoint": "GET https://api.avito.ru/messenger/v3/accounts/{userId}/chats",
      "input": {
        "userId": {
          "type": "string",
          "description": "Ваш Avito user ID",
          "required": true
        },
        "item_ids": {
          "type": "array",
          "description": "Фильтр по ID объявлений",
          "required": false
        },
        "unread_only": {
          "type": "boolean",
          "description": "Только непрочитанные",
          "default": false
        }
      },
      "output": {
        "type": "list<chat>",
        "fields": [
          "chats[0].id",
          "chats[0].context.value.item.title",
          "chats[0].last_message.content.text",
          "chats[0].users[0].name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "auth": "OAuth2 client credentials: POST /token with client_id and client_secret from developer.avito.ru",
    "scope": "Request scopes: items:info (view ads), job:read (employment), user:read (profile)",
    "rate_limits": "API rate limits vary by plan. Free tier: 100 req/min. Check X-RateLimit headers.",
    "categories": "Category IDs: 9=Real Estate, 4=Auto, 1=Electronics, 2=Fashion, 7=Services, 8=Jobs"
  }
}