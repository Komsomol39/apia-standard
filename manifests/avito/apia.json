{
  "apia": "1.0",
  "service": {
    "id": "avito",
    "name": "Авито API (Россия)",
    "description_for_ai": "Крупнейший классифайд России. API для бизнеса: управление объявлениями (недвижимость, авто, товары, услуги, работа), чаты с покупателями, статистика, авторизация через Авито. 60M+ уникальных пользователей в месяц.",
    "url": "https://avito.ru",
    "api_base": "https://api.avito.ru",
    "category": "ecommerce",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://developers.avito.ru/"
  },
  "auth": {
    "type": "oauth2_client_credentials",
    "anonymous_access": false,
    "token_url": "https://api.avito.ru/token",
    "how_to_get": "Зарегистрировать приложение на https://developers.avito.ru",
    "cost": "Бесплатно для базового доступа"
  },
  "capabilities": [
    {
      "id": "search_items",
      "description_for_ai": "Search Avito marketplace listings: jobs, real estate, vehicles, goods. Russia's largest classifieds.",
      "intent": [
        "avito search",
        "найти объявление avito",
        "avito объявления",
        "поиск avito"
      ],
      "endpoint": "GET https://api.avito.ru/core/v1/items",
      "input": {
        "query": {
          "type": "string",
          "description": "Search query",
          "required": false
        },
        "category_id": {
          "type": "integer",
          "description": "Category ID from /core/v1/categories",
          "required": false
        },
        "location_id": {
          "type": "integer",
          "description": "Location ID: 637640=Moscow, 638587=SPb",
          "required": false
        },
        "price_from": {
          "type": "integer",
          "required": false
        },
        "price_to": {
          "type": "integer",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 25
        },
        "page": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<item>",
        "fields": [
          "result.items[0].id",
          "result.items[0].title",
          "result.items[0].price_string",
          "result.items[0].url",
          "result.items[0].location"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_item",
      "description_for_ai": "Get full details of an Avito listing by ID.",
      "intent": [
        "avito item",
        "объявление avito",
        "avito listing",
        "детали avito"
      ],
      "endpoint": "GET https://api.avito.ru/core/v1/items/{itemId}",
      "input": {
        "itemId": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "item",
        "fields": [
          "item.id",
          "item.title",
          "item.description",
          "item.price_string",
          "item.url",
          "item.category.name",
          "item.location.name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_user_items",
      "description_for_ai": "Get listings posted by a specific user.",
      "intent": [
        "объявления пользователя avito",
        "user listings avito",
        "my avito items",
        "мои объявления avito"
      ],
      "endpoint": "GET https://api.avito.ru/core/v1/accounts/{user_id}/items",
      "input": {
        "user_id": {
          "type": "integer",
          "required": true
        },
        "status": {
          "type": "string",
          "description": "active, closed",
          "default": "active"
        },
        "per_page": {
          "type": "integer",
          "default": 25
        }
      },
      "output": {
        "type": "list<item>",
        "fields": [
          "result.items[0].id",
          "result.items[0].title",
          "result.items[0].status",
          "result.items[0].price_string"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_message",
      "description_for_ai": "Send a message to a seller on Avito.",
      "intent": [
        "avito message",
        "написать продавцу avito",
        "сообщение avito"
      ],
      "endpoint": "POST https://api.avito.ru/messenger/v1/accounts/{user_id}/chats/{chat_id}/messages",
      "input": {
        "user_id": {
          "type": "integer",
          "required": true
        },
        "chat_id": {
          "type": "string",
          "required": true
        },
        "message": {
          "type": "object",
          "description": "{type: text, payload: {text: 'Message text'}}",
          "required": true
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "id",
          "created",
          "type"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "auth": "OAuth2 client credentials: POST /token with client_id and client_secret from developer.avito.ru",
    "scope": "Request scopes: items:info (view ads), job:read (employment), user:read (profile)",
    "rate_limits": "API rate limits vary by plan. Free tier: 100 req/min. Check X-RateLimit headers.",
    "categories": "Category IDs: 9=Real Estate, 4=Auto, 1=Electronics, 2=Fashion, 7=Services, 8=Jobs"
  }
}