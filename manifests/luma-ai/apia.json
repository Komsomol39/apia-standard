{
  "apia": "1.0",
  "service": {
    "id": "luma-ai",
    "name": "Luma AI Dream Machine API",
    "description_for_ai": "AI video generation from text or image. Dream Machine model creates cinematic quality videos. 5 second clips. Use for creative video content, marketing, social media videos.",
    "url": "https://lumalabs.ai",
    "api_base": "https://api.lumalabs.ai/dream-machine/v1",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.lumalabs.ai/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer {api_key}",
    "how_to_get": "Get API key at https://lumalabs.ai/dream-machine/api",
    "cost": "$0.006/second of video"
  },
  "capabilities": [
    {
      "id": "create_generation",
      "description_for_ai": "Generate video from text prompt or image. Returns generation ID to poll for result.",
      "intent": [
        "AI video",
        "text to video",
        "dream machine",
        "video generation",
        "cinematic video"
      ],
      "endpoint": "POST https://api.lumalabs.ai/dream-machine/v1/generations",
      "input": {
        "prompt": {
          "type": "string",
          "description": "Video description",
          "required": false
        },
        "keyframes": {
          "type": "object",
          "description": "{frame0: {type: image, url: image_url}} for image-to-video",
          "required": false
        },
        "loop": {
          "type": "boolean",
          "description": "Seamlessly looping video",
          "default": false
        },
        "aspect_ratio": {
          "type": "string",
          "description": "16:9, 9:16, 4:3, 3:4, 21:9, 9:21",
          "default": "16:9"
        }
      },
      "output": {
        "type": "generation",
        "fields": [
          "id",
          "state",
          "created_at"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_generation",
      "description_for_ai": "Check generation status and get download URL when video is ready. Poll every 3-5 seconds until state=completed.",
      "intent": [
        "check video",
        "generation status",
        "download video"
      ],
      "endpoint": "GET https://api.lumalabs.ai/dream-machine/v1/generations/{id}",
      "input": {
        "id": {
          "type": "string",
          "required": true,
          "description": "Unique identifier"
        }
      },
      "output": {
        "type": "generation",
        "fields": [
          "id",
          "state",
          "assets.video",
          "failure_reason"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "generate_video",
      "description_for_ai": "Generate a video from text prompt or image with Luma AI Dream Machine.",
      "intent": [
        "Luma AI video",
        "AI video generation",
        "Dream Machine",
        "генерация видео Luma"
      ],
      "endpoint": "POST https://api.lumalabs.ai/dream-machine/v1/generations",
      "input": {
        "prompt": {
          "type": "string",
          "required": true
        },
        "model": {
          "type": "string",
          "description": "dream-machine (text), photon-flash (image to video)",
          "default": "dream-machine"
        },
        "loop": {
          "type": "boolean",
          "default": false
        },
        "aspect_ratio": {
          "type": "string",
          "description": "16:9, 9:16, 1:1, 4:3, 3:4, 21:9, 9:21",
          "default": "16:9"
        }
      },
      "output": {
        "type": "generation",
        "fields": [
          "id",
          "state (queued, dreaming, completed)",
          "assets.video (URL when done)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "image_to_video",
      "description_for_ai": "Animate a still image into video with Luma AI.",
      "intent": [
        "animate image Luma",
        "image to video Luma",
        "photo animation AI",
        "анимация фото Luma"
      ],
      "endpoint": "POST https://api.lumalabs.ai/dream-machine/v1/generations/image",
      "input": {
        "prompt": {
          "type": "string",
          "required": false
        },
        "keyframes": {
          "type": "object",
          "description": "{frame0: {type: 'image', url: 'https://...'}, frame1: {type: 'image', url: 'https://...'}}",
          "required": true
        }
      },
      "output": {
        "type": "generation",
        "fields": [
          "id",
          "state",
          "assets.video"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_generation",
      "description_for_ai": "Check status of a Luma AI video generation.",
      "intent": [
        "generation status Luma",
        "video status AI",
        "check video Luma",
        "статус генерации Luma"
      ],
      "endpoint": "GET https://api.lumalabs.ai/dream-machine/v1/generations/{id}",
      "input": {
        "id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "generation",
        "fields": [
          "id",
          "state",
          "failure_reason",
          "assets.video"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "async_flow": "Video generation is async: 1) POST to create generation → get id. 2) Poll GET /generations/{id} every 3-5s until state=completed. 3) Download assets.video URL.",
    "generation_time": "Typical generation: 2-5 minutes for 5-second clip. Use exponential backoff for polling.",
    "aspect_ratios": "16:9 landscape, 9:16 portrait (Reels/TikTok), 1:1 square, 4:3 classic, 3:4 portrait",
    "credits": "Each generation costs credits. Monitor via GET /credits endpoint."
  }
}