{
  "apia": "1.0",
  "service": {
    "id": "yelp",
    "name": "Yelp Fusion API",
    "description_for_ai": "Business reviews and local search API. 265M+ reviews, 8M+ businesses. Search restaurants, services, shops with ratings and hours. Best for US/Canada business discovery. Use for finding local businesses with reviews.",
    "url": "https://yelp.com",
    "api_base": "https://api.yelp.com/v3",
    "category": "local_business",
    "geo": [
      "US",
      "CA",
      "GB",
      "AU",
      "FR",
      "DE"
    ],
    "language": "en",
    "docs": "https://docs.developer.yelp.com/docs/fusion-intro"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "Register at https://www.yelp.com/developers",
    "cost": "Free: 500 calls/day"
  },
  "capabilities": [
    {
      "id": "search_businesses",
      "description_for_ai": "Business reviews and local search API. 265M+ reviews, 8M+ businesses. Search restaurants, services, shops with ratings and hours. Best for US/Canada business discovery. Use for finding local businesses with reviews. Search businesses by keyword and location. Returns name, rating, price, hours, address, phone.",
      "intent": [
        "find restaurant",
        "local business",
        "yelp search",
        "best coffee shop",
        "reviews nearby"
      ],
      "endpoint": "GET https://api.yelp.com/v3/businesses/search",
      "input": {
        "term": {
          "type": "string",
          "description": "Search term e.g. pizza, coffee, plumber",
          "required": false
        },
        "location": {
          "type": "string",
          "description": "Address or city e.g. San Francisco CA",
          "required": false
        },
        "latitude": {
          "type": "float",
          "required": false,
          "description": "Latitude in decimal degrees (-90 to 90)"
        },
        "longitude": {
          "type": "float",
          "required": false,
          "description": "Longitude in decimal degrees (-180 to 180)"
        },
        "radius": {
          "type": "integer",
          "description": "Meters, max 40000",
          "default": 1000
        },
        "open_now": {
          "type": "boolean",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 20,
          "max": 50,
          "description": "Maximum number of results to return"
        },
        "sort_by": {
          "type": "string",
          "description": "best_match, rating, review_count, distance",
          "default": "best_match"
        }
      },
      "output": {
        "type": "list<business>",
        "fields": [
          "id",
          "name",
          "rating",
          "review_count",
          "price",
          "location.display_address",
          "display_phone",
          "hours",
          "categories"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}