{
  "apia": "1.0",
  "service": {
    "id": "jokeapi",
    "name": "JokeAPI",
    "description_for_ai": "Free joke and humor API with 4000+ jokes. Supports 7 languages including Russian. Content categories: Programming, Miscellaneous, Dark, Pun, Spooky, Christmas. Content filters for safe mode. No API key needed — completely free.",
    "url": "https://jokeapi.dev",
    "api_base": "https://v2.jokeapi.dev",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://jokeapi.dev/#docs"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "get_joke",
      "description_for_ai": "Get a random joke from JokeAPI. Supports various categories and safe mode.",
      "intent": [
        "get joke",
        "random joke",
        "funny joke",
        "анекдот JokeAPI"
      ],
      "endpoint": "GET https://v2.jokeapi.dev/joke/{categories}",
      "input": {
        "categories": {
          "type": "string",
          "description": "Any, Programming, Misc, Dark, Pun, Spooky, Christmas (comma-separated)",
          "default": "Any"
        },
        "lang": {
          "type": "string",
          "description": "en, cs, de, es, fr, pt",
          "default": "en"
        },
        "blacklistFlags": {
          "type": "string",
          "description": "nsfw, religious, political, racist, sexist, explicit (comma-separated)",
          "required": false
        },
        "type": {
          "type": "string",
          "description": "single or twopart",
          "required": false
        }
      },
      "output": {
        "type": "joke",
        "fields": [
          "type",
          "joke (single type)",
          "setup + delivery (twopart)",
          "category",
          "flags"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_multiple_jokes",
      "description_for_ai": "Get multiple jokes at once from JokeAPI (up to 10).",
      "intent": [
        "multiple jokes",
        "joke batch",
        "jokes list",
        "несколько анекдотов"
      ],
      "endpoint": "GET https://v2.jokeapi.dev/joke/{categories}",
      "input": {
        "categories": {
          "type": "string",
          "default": "Any"
        },
        "amount": {
          "type": "integer",
          "description": "Number of jokes 1-10",
          "default": 3
        },
        "blacklistFlags": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<joke>",
        "fields": [
          "jokes[0].category",
          "jokes[0].type",
          "jokes[0].joke",
          "jokes[0].setup",
          "jokes[0].delivery"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "search_jokes",
      "description_for_ai": "Search jokes containing a specific keyword.",
      "intent": [
        "search jokes",
        "find joke about",
        "keyword joke",
        "поиск анекдота"
      ],
      "endpoint": "GET https://v2.jokeapi.dev/joke/Any",
      "input": {
        "contains": {
          "type": "string",
          "description": "Keyword that must appear in the joke",
          "required": true
        },
        "lang": {
          "type": "string",
          "default": "en"
        }
      },
      "output": {
        "type": "joke",
        "fields": [
          "category",
          "type",
          "joke or setup/delivery"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_joke_info",
      "description_for_ai": "Get JokeAPI statistics and available categories/flags.",
      "intent": [
        "JokeAPI info",
        "joke categories",
        "API stats",
        "информация JokeAPI"
      ],
      "endpoint": "GET https://v2.jokeapi.dev/info",
      "input": {},
      "output": {
        "type": "info",
        "fields": [
          "version",
          "jokes.totalCount",
          "formats",
          "categories",
          "flags",
          "lang"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_joke_by_id",
      "description_for_ai": "Get a specific joke by its numeric ID.",
      "intent": [
        "joke by ID",
        "specific joke",
        "joke number",
        "анекдот по ID"
      ],
      "endpoint": "GET https://v2.jokeapi.dev/joke/Any",
      "input": {
        "idRange": {
          "type": "string",
          "description": "Single ID (42) or range (1-50)",
          "required": true
        }
      },
      "output": {
        "type": "joke",
        "fields": [
          "id",
          "category",
          "type",
          "joke or setup/delivery"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}