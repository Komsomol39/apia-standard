{
  "apia": "1.0",
  "service": {
    "id": "jokeapi",
    "name": "JokeAPI",
    "description_for_ai": "Free joke and humor API with 4000+ jokes. Supports 7 languages including Russian. Content categories: Programming, Miscellaneous, Dark, Pun, Spooky, Christmas. Content filters for safe mode. No API key needed — completely free.",
    "url": "https://jokeapi.dev",
    "api_base": "https://v2.jokeapi.dev",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://jokeapi.dev/#docs"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "get_joke",
      "description_for_ai": "Get a random joke from JokeAPI. Supports many categories and languages.",
      "intent": [
        "get joke",
        "random joke",
        "joke API",
        "анекдот jokeapi"
      ],
      "endpoint": "GET https://v2.jokeapi.dev/joke/{category}",
      "input": {
        "category": {
          "type": "string",
          "description": "Any, Misc, Programming, Dark, Pun, Spooky, Christmas",
          "default": "Any"
        },
        "lang": {
          "type": "string",
          "description": "en, de, cs, es, fr, pt",
          "default": "en"
        },
        "type": {
          "type": "string",
          "description": "single or twopart",
          "required": false
        },
        "blacklistFlags": {
          "type": "string",
          "description": "nsfw,racist,sexist,explicit (comma-separated to exclude)",
          "required": false
        }
      },
      "output": {
        "type": "joke",
        "fields": [
          "type",
          "joke (single type)",
          "setup + delivery (twopart type)",
          "category",
          "lang"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_multiple_jokes",
      "description_for_ai": "Get multiple jokes at once (up to 10).",
      "intent": [
        "multiple jokes",
        "batch jokes",
        "joke list",
        "несколько анекдотов"
      ],
      "endpoint": "GET https://v2.jokeapi.dev/joke/{category}",
      "input": {
        "category": {
          "type": "string",
          "default": "Programming"
        },
        "amount": {
          "type": "integer",
          "description": "Number of jokes 1-10",
          "default": 3
        },
        "lang": {
          "type": "string",
          "default": "en"
        }
      },
      "output": {
        "type": "list<joke>",
        "fields": [
          "jokes[0].type",
          "jokes[0].joke or jokes[0].setup"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "search_jokes",
      "description_for_ai": "Search jokes by keyword.",
      "intent": [
        "search jokes",
        "find joke keyword",
        "joke search",
        "поиск анекдотов"
      ],
      "endpoint": "GET https://v2.jokeapi.dev/joke/{category}",
      "input": {
        "category": {
          "type": "string",
          "default": "Any"
        },
        "contains": {
          "type": "string",
          "description": "Keyword to search for in jokes",
          "required": true
        }
      },
      "output": {
        "type": "list<joke>",
        "fields": [
          "jokes[0].joke",
          "jokes[0].category",
          "total"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_categories",
      "description_for_ai": "Get list of available joke categories and flags.",
      "intent": [
        "joke categories",
        "available categories jokeapi",
        "joke types",
        "категории анекдотов"
      ],
      "endpoint": "GET https://v2.jokeapi.dev/categories",
      "input": {},
      "output": {
        "type": "categories",
        "fields": [
          "categories (array)",
          "categoryAliases",
          "flags (array)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_info",
      "description_for_ai": "Get JokeAPI info: total jokes, categories, languages, flags.",
      "intent": [
        "jokeapi info",
        "joke database info",
        "API stats jokeapi"
      ],
      "endpoint": "GET https://v2.jokeapi.dev/info",
      "input": {},
      "output": {
        "type": "info",
        "fields": [
          "totalCount",
          "categories",
          "availableLanguages",
          "availableFlags"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}