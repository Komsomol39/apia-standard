{
  "apia": "1.0",
  "service": {
    "id": "google-gemini",
    "name": "Google Gemini API",
    "description_for_ai": "Google Gemini AI models. Most generous free tier of any frontier AI API. Gemini 2.5 Flash is fast and cheap, Gemini 3.1 Pro is the flagship. Supports text, vision, audio, video, and code. 1M+ token context window. Use when cost matters or for multimodal tasks involving video/audio.",
    "url": "https://ai.google.dev",
    "api_base": "https://generativelanguage.googleapis.com/v1beta",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://ai.google.dev/api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Get key instantly at https://aistudio.google.com/app/apikey — free",
    "cost": "Free tier: 1500 req/day for Gemini 2.5 Flash. Paid: $0.30/$2.50 per 1M tokens for 2.5 Flash"
  },
  "capabilities": [
    {
      "id": "generate_content",
      "description_for_ai": "Generate text with Gemini 1.5 Pro/Flash. Supports text, images, audio, video, and documents in one request.",
      "intent": [
        "ask Gemini",
        "AI text generation",
        "Gemini API",
        "Google AI",
        "спросить Gemini"
      ],
      "endpoint": "POST https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent",
      "input": {
        "model": {
          "type": "string",
          "description": "gemini-1.5-pro (best), gemini-1.5-flash (fast/cheap), gemini-2.0-flash (latest)",
          "required": true
        },
        "contents": {
          "type": "array",
          "description": "[{role: 'user', parts: [{text: 'prompt'}]}] — or include {inline_data: {mime_type, data}} for images",
          "required": true
        },
        "systemInstruction": {
          "type": "object",
          "description": "{parts: [{text: 'System prompt'}]}",
          "required": false
        },
        "generationConfig": {
          "type": "object",
          "description": "{temperature, maxOutputTokens, responseMimeType: 'application/json'}",
          "required": false
        },
        "tools": {
          "type": "array",
          "description": "Function declarations for tool calling",
          "required": false
        }
      },
      "output": {
        "type": "response",
        "fields": [
          "candidates[0].content.parts[0].text",
          "usageMetadata.promptTokenCount",
          "usageMetadata.candidatesTokenCount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "vision_analysis",
      "description_for_ai": "Analyze images, PDFs, videos with Gemini. Describe content, extract text, answer questions. Supports URLs and base64.",
      "intent": [
        "analyze image Gemini",
        "image understanding",
        "PDF analysis Google",
        "video understanding",
        "анализ изображения Gemini"
      ],
      "endpoint": "POST https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent",
      "input": {
        "contents": {
          "type": "array",
          "description": "[{parts: [{inline_data: {mime_type: 'image/jpeg', data: 'BASE64'}}, {text: 'Describe this'}]}] or use file_data with URI",
          "required": true
        }
      },
      "output": {
        "type": "response",
        "fields": [
          "candidates[0].content.parts[0].text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "embeddings",
      "description_for_ai": "Generate text embeddings for semantic search and RAG with text-embedding-004.",
      "intent": [
        "Gemini embeddings",
        "text embeddings Google",
        "semantic search",
        "RAG",
        "векторные эмбеддинги Google"
      ],
      "endpoint": "POST https://generativelanguage.googleapis.com/v1beta/models/text-embedding-004:embedContent",
      "input": {
        "content": {
          "type": "object",
          "description": "{parts: [{text: 'Text to embed'}]}",
          "required": true
        },
        "taskType": {
          "type": "string",
          "description": "RETRIEVAL_DOCUMENT, RETRIEVAL_QUERY, SEMANTIC_SIMILARITY, CLASSIFICATION",
          "required": false
        }
      },
      "output": {
        "type": "embedding",
        "fields": [
          "embedding.values (float array)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "count_tokens",
      "description_for_ai": "Count tokens for a request before sending to estimate cost.",
      "intent": [
        "count tokens Gemini",
        "token count",
        "estimate cost",
        "подсчёт токенов"
      ],
      "endpoint": "POST https://generativelanguage.googleapis.com/v1beta/models/{model}:countTokens",
      "input": {
        "model": {
          "type": "string",
          "required": true
        },
        "contents": {
          "type": "array",
          "required": true
        }
      },
      "output": {
        "type": "token_count",
        "fields": [
          "totalTokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_models",
      "description_for_ai": "List all available Gemini models with their capabilities and limits.",
      "intent": [
        "Gemini models",
        "available models",
        "список моделей Gemini"
      ],
      "endpoint": "GET https://generativelanguage.googleapis.com/v1beta/models",
      "input": {
        "pageSize": {
          "type": "integer",
          "default": 50
        }
      },
      "output": {
        "type": "list<model>",
        "fields": [
          "models[0].name",
          "models[0].displayName",
          "models[0].inputTokenLimit",
          "models[0].outputTokenLimit"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "function_calling",
      "description_for_ai": "Use Gemini with function calling (tool use). Model decides when to call defined tools. Ideal for agents.",
      "intent": [
        "Gemini function calling",
        "tool use Gemini",
        "AI agent Gemini",
        "вызов функций Gemini"
      ],
      "endpoint": "POST https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro:generateContent",
      "input": {
        "contents": {
          "type": "array",
          "required": true
        },
        "tools": {
          "type": "array",
          "description": "[{function_declarations: [{name, description, parameters: {type: 'object', properties: {...}, required: [...]}}]}]",
          "required": true
        },
        "tool_config": {
          "type": "object",
          "description": "{function_calling_config: {mode: 'AUTO'|'ANY'|'NONE'}}",
          "required": false
        }
      },
      "output": {
        "type": "response",
        "fields": [
          "candidates[0].content.parts[0].function_call.name",
          "candidates[0].content.parts[0].function_call.args"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "free_tier": "gemini-2.5-flash: 1500 requests/day FREE. Best free frontier model in 2026.",
    "json_mode": "Set generationConfig.responseMimeType='application/json' for structured JSON output.",
    "multimodal": "Pass images, audio, video inline. gemini-2.5-pro handles 1M token context with full video/audio understanding.",
    "context": "1M token context = entire codebases, long books, hours of audio. No chunking needed.",
    "thinking": "gemini-2.5-flash-thinking-exp supports extended reasoning for hard problems."
  },
  "limits": {
    "free_requests_per_day": 1500,
    "commercial_use": true,
    "attribution_required": false
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}