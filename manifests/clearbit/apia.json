{
  "apia": "1.0",
  "service": {
    "id": "clearbit",
    "name": "Clearbit API (HubSpot)",
    "description_for_ai": "Business intelligence API. Enrich company and person data from email or domain. Get company size, industry, funding, tech stack, social profiles. Used by Stripe, Zendesk, Intercom. Use for lead enrichment, B2B data.",
    "url": "https://clearbit.com",
    "api_base": "https://company.clearbit.com/v2",
    "category": "business",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://dashboard.clearbit.com/docs"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "API key as username, empty password",
    "how_to_get": "Register at https://clearbit.com",
    "cost": "Free: 50 lookups/month. Paid from $99/month"
  },
  "capabilities": [
    {
      "id": "enrich_person",
      "description_for_ai": "Enrich a person's profile from their email address. Returns name, title, company, bio, social.",
      "intent": [
        "enrich email",
        "find person info",
        "email lookup Clearbit",
        "обогащение email Clearbit"
      ],
      "endpoint": "GET https://person.clearbit.com/v2/combined/find",
      "input": {
        "email": {
          "type": "string",
          "description": "Email address to look up",
          "required": true
        }
      },
      "output": {
        "type": "person",
        "fields": [
          "person.name.fullName",
          "person.title",
          "person.employment.name",
          "person.linkedin.handle",
          "person.twitter.handle",
          "company.name",
          "company.domain"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "enrich_company",
      "description_for_ai": "Enrich company data from domain: size, industry, funding, tech stack.",
      "intent": [
        "company enrichment",
        "company info Clearbit",
        "domain lookup",
        "информация о компании Clearbit"
      ],
      "endpoint": "GET https://company.clearbit.com/v2/companies/find",
      "input": {
        "domain": {
          "type": "string",
          "description": "Company domain: e.g. stripe.com",
          "required": true
        }
      },
      "output": {
        "type": "company",
        "fields": [
          "name",
          "domain",
          "category.industry",
          "metrics.employees",
          "metrics.estimatedAnnualRevenue",
          "tech",
          "location",
          "description"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "reveal_visitor",
      "description_for_ai": "Identify anonymous website visitors and their company from their IP address.",
      "intent": [
        "identify visitor",
        "IP to company",
        "website visitor identification",
        "идентификация посетителя Clearbit"
      ],
      "endpoint": "GET https://reveal.clearbit.com/v1/companies/find",
      "input": {
        "ip": {
          "type": "string",
          "description": "Visitor's IP address",
          "required": true
        }
      },
      "output": {
        "type": "company",
        "fields": [
          "company.name",
          "company.domain",
          "company.category.industry",
          "company.metrics.employees"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "email_lookup",
      "description_for_ai": "Find email addresses for a person at a company.",
      "intent": [
        "find email address",
        "email finder",
        "contact email Clearbit",
        "найти email Clearbit"
      ],
      "endpoint": "GET https://prospector.clearbit.com/v2/people/find",
      "input": {
        "domain": {
          "type": "string",
          "required": true
        },
        "role": {
          "type": "string",
          "description": "Role category: sales, marketing, engineering",
          "required": false
        },
        "seniority": {
          "type": "string",
          "description": "executive, director, manager",
          "required": false
        }
      },
      "output": {
        "type": "list<person>",
        "fields": [
          "results[0].name.fullName",
          "results[0].email",
          "results[0].title"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "autocomplete_company",
      "description_for_ai": "Autocomplete company names for search inputs.",
      "intent": [
        "company autocomplete",
        "company name search",
        "автодополнение компании Clearbit"
      ],
      "endpoint": "GET https://autocomplete.clearbit.com/v1/companies/suggest",
      "input": {
        "query": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<company>",
        "fields": [
          "[0].name",
          "[0].domain",
          "[0].logo"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}