{
  "apia": "1.0",
  "service": {
    "id": "pipedrive",
    "name": "Pipedrive CRM API",
    "description_for_ai": "Sales-focused CRM. Deals, contacts, organizations, activities, pipelines. Visual sales pipeline. Popular with SMBs. Free trial 14 days. Use for sales pipeline management, deal tracking, contact management.",
    "url": "https://pipedrive.com",
    "api_base": "https://api.pipedrive.com/v1",
    "category": "business",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.pipedrive.com/docs/api/v1"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "api_token",
    "param_location": "query",
    "how_to_get": "Settings → Personal preferences → API",
    "cost": "Essential: $14/user/month. 14-day free trial."
  },
  "capabilities": [
    {
      "id": "search_deals",
      "description_for_ai": "Search Pipedrive CRM deals by title, value, status, stage, and owner.",
      "intent": [
        "pipedrive deals",
        "CRM deals",
        "sales pipeline search",
        "сделки pipedrive"
      ],
      "endpoint": "GET https://{company}.pipedrive.com/api/v1/deals",
      "input": {
        "status": {
          "type": "string",
          "description": "open, won, lost, deleted, all_not_deleted",
          "default": "open"
        },
        "filter_id": {
          "type": "integer",
          "description": "Saved filter ID",
          "required": false
        },
        "stage_id": {
          "type": "integer",
          "description": "Filter by pipeline stage",
          "required": false
        },
        "user_id": {
          "type": "integer",
          "description": "Filter by owner",
          "required": false
        },
        "start": {
          "type": "integer",
          "default": 0
        },
        "limit": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<deal>",
        "fields": [
          "data[0].id",
          "data[0].title",
          "data[0].value",
          "data[0].currency",
          "data[0].status",
          "data[0].stage_id",
          "data[0].person_name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_deal",
      "description_for_ai": "Create a new deal in Pipedrive with value, stage, expected close date, and linked contact.",
      "intent": [
        "create deal pipedrive",
        "new opportunity",
        "add deal CRM",
        "создать сделку pipedrive"
      ],
      "endpoint": "POST https://{company}.pipedrive.com/api/v1/deals",
      "input": {
        "title": {
          "type": "string",
          "required": true
        },
        "value": {
          "type": "number",
          "required": false
        },
        "currency": {
          "type": "string",
          "default": "USD"
        },
        "status": {
          "type": "string",
          "description": "open, won, lost",
          "default": "open"
        },
        "stage_id": {
          "type": "integer",
          "description": "Pipeline stage ID",
          "required": false
        },
        "person_id": {
          "type": "integer",
          "description": "Contact ID to link",
          "required": false
        },
        "org_id": {
          "type": "integer",
          "description": "Organization ID",
          "required": false
        },
        "expected_close_date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        }
      },
      "output": {
        "type": "deal",
        "fields": [
          "data.id",
          "data.title",
          "data.value",
          "data.status",
          "data.stage_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_person",
      "description_for_ai": "Create a new contact person in Pipedrive.",
      "intent": [
        "create contact pipedrive",
        "new person CRM",
        "add contact",
        "добавить контакт pipedrive"
      ],
      "endpoint": "POST https://{company}.pipedrive.com/api/v1/persons",
      "input": {
        "name": {
          "type": "string",
          "required": true
        },
        "email": {
          "type": "array",
          "description": "[{value: 'email@example.com', primary: true}]",
          "required": false
        },
        "phone": {
          "type": "array",
          "description": "[{value: '+1234567890', primary: true}]",
          "required": false
        },
        "org_id": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "person",
        "fields": [
          "data.id",
          "data.name",
          "data.email[0].value",
          "data.phone[0].value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "add_note",
      "description_for_ai": "Add a note to a deal, person, or organization in Pipedrive.",
      "intent": [
        "note pipedrive",
        "add note CRM",
        "deal note",
        "заметка pipedrive"
      ],
      "endpoint": "POST https://{company}.pipedrive.com/api/v1/notes",
      "input": {
        "content": {
          "type": "string",
          "description": "Note text (HTML supported)",
          "required": true
        },
        "deal_id": {
          "type": "integer",
          "required": false
        },
        "person_id": {
          "type": "integer",
          "required": false
        },
        "org_id": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "note",
        "fields": [
          "data.id",
          "data.content",
          "data.add_time"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "api_token": "Get token: Settings → Personal Preferences → API. Append to every request as ?api_token=...",
    "pagination": "Use start and limit params. Response includes additional_data.pagination.more_items_in_collection",
    "custom_fields": "Custom fields have hash keys like 'abc123def456'. List all via GET /dealFields, /personFields etc.",
    "webhooks": "Set up webhooks in Tools → Webhooks for real-time deal/contact/activity updates."
  }
}