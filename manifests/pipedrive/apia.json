{
  "apia": "1.0",
  "service": {
    "id": "pipedrive",
    "name": "Pipedrive CRM API",
    "description_for_ai": "Sales-focused CRM. Deals, contacts, organizations, activities, pipelines. Visual sales pipeline. Popular with SMBs. Free trial 14 days. Use for sales pipeline management, deal tracking, contact management.",
    "url": "https://pipedrive.com",
    "api_base": "https://api.pipedrive.com/v1",
    "category": "crm",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.pipedrive.com/docs/api/v1"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "api_token",
    "param_location": "query",
    "how_to_get": "Settings → Personal preferences → API",
    "cost": "Essential: $14/user/month. 14-day free trial."
  },
  "capabilities": [
    {
      "id": "get_deals",
      "description_for_ai": "Get sales deals from pipeline with value, stage, owner, close date.",
      "intent": [
        "sales deals",
        "pipeline deals",
        "open opportunities",
        "deal list",
        "sales pipeline"
      ],
      "endpoint": "GET https://api.pipedrive.com/v1/deals",
      "input": {
        "status": {
          "type": "string",
          "description": "open, won, lost, all",
          "default": "open"
        },
        "stage_id": {
          "type": "integer",
          "required": false
        },
        "user_id": {
          "type": "integer",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 100
        }
      },
      "output": {
        "type": "list<deal>",
        "fields": [
          "id",
          "title",
          "value",
          "currency",
          "status",
          "stage_id",
          "person_id",
          "org_id",
          "close_time",
          "won_time"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_deal",
      "description_for_ai": "Create new sales deal in Pipedrive pipeline.",
      "intent": [
        "new deal",
        "add opportunity",
        "create sale",
        "pipeline entry"
      ],
      "endpoint": "POST https://api.pipedrive.com/v1/deals",
      "input": {
        "title": {
          "type": "string",
          "required": true
        },
        "value": {
          "type": "number",
          "required": false
        },
        "currency": {
          "type": "string",
          "default": "USD"
        },
        "person_id": {
          "type": "integer",
          "required": false
        },
        "org_id": {
          "type": "integer",
          "required": false
        },
        "stage_id": {
          "type": "integer",
          "required": false
        },
        "close_time": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        }
      },
      "output": {
        "type": "deal",
        "fields": [
          "data.id",
          "data.title",
          "data.value",
          "data.status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}