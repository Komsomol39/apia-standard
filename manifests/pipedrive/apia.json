{
  "apia": "1.0",
  "service": {
    "id": "pipedrive",
    "name": "Pipedrive CRM API",
    "description_for_ai": "Sales-focused CRM. Deals, contacts, organizations, activities, pipelines. Visual sales pipeline. Popular with SMBs. Free trial 14 days. Use for sales pipeline management, deal tracking, contact management.",
    "url": "https://pipedrive.com",
    "api_base": "https://api.pipedrive.com/v1",
    "category": "business",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.pipedrive.com/docs/api/v1"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "api_token",
    "param_location": "query",
    "how_to_get": "Settings → Personal preferences → API",
    "cost": "Essential: $14/user/month. 14-day free trial."
  },
  "capabilities": [
    {
      "id": "search_deals",
      "description_for_ai": "Search Pipedrive deals by keyword, owner, stage, or status.",
      "intent": [
        "Pipedrive deals",
        "sales pipeline",
        "search deals",
        "сделки Pipedrive"
      ],
      "endpoint": "GET https://api.pipedrive.com/v1/deals/search",
      "input": {
        "term": {
          "type": "string",
          "description": "Search term",
          "required": true
        },
        "status": {
          "type": "string",
          "description": "open, won, lost, deleted, all_not_deleted",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 25
        }
      },
      "output": {
        "type": "list<deal>",
        "fields": [
          "data.items[0].item.id",
          "data.items[0].item.title",
          "data.items[0].item.value",
          "data.items[0].item.status",
          "data.items[0].item.owner_name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_deal",
      "description_for_ai": "Create a new deal in Pipedrive CRM pipeline.",
      "intent": [
        "create deal Pipedrive",
        "new sale",
        "add opportunity",
        "новая сделка Pipedrive"
      ],
      "endpoint": "POST https://api.pipedrive.com/v1/deals",
      "input": {
        "title": {
          "type": "string",
          "required": true
        },
        "value": {
          "type": "number",
          "description": "Deal value in default currency",
          "required": false
        },
        "currency": {
          "type": "string",
          "description": "Currency code: USD, EUR, GBP",
          "required": false
        },
        "person_id": {
          "type": "integer",
          "description": "Associated contact",
          "required": false
        },
        "org_id": {
          "type": "integer",
          "description": "Associated organization",
          "required": false
        },
        "stage_id": {
          "type": "integer",
          "description": "Pipeline stage ID",
          "required": false
        },
        "expected_close_date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        }
      },
      "output": {
        "type": "deal",
        "fields": [
          "data.id",
          "data.title",
          "data.status",
          "data.stage_id",
          "data.add_time"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "add_activity",
      "description_for_ai": "Log an activity (call, email, meeting, task) to a deal or contact.",
      "intent": [
        "log activity Pipedrive",
        "add call note",
        "schedule meeting CRM",
        "активность Pipedrive"
      ],
      "endpoint": "POST https://api.pipedrive.com/v1/activities",
      "input": {
        "subject": {
          "type": "string",
          "required": true
        },
        "type": {
          "type": "string",
          "description": "call, meeting, task, deadline, email, lunch",
          "required": true
        },
        "deal_id": {
          "type": "integer",
          "required": false
        },
        "person_id": {
          "type": "integer",
          "required": false
        },
        "due_date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        },
        "due_time": {
          "type": "string",
          "description": "HH:MM",
          "required": false
        },
        "note": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "activity",
        "fields": [
          "data.id",
          "data.subject",
          "data.type",
          "data.due_date"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_pipeline_stages",
      "description_for_ai": "Get all pipeline stages with their order and conversion rates.",
      "intent": [
        "pipeline stages",
        "sales stages Pipedrive",
        "CRM pipeline",
        "этапы продаж Pipedrive"
      ],
      "endpoint": "GET https://api.pipedrive.com/v1/stages",
      "input": {
        "pipeline_id": {
          "type": "integer",
          "description": "Filter by pipeline",
          "required": false
        }
      },
      "output": {
        "type": "list<stage>",
        "fields": [
          "data[0].id",
          "data[0].name",
          "data[0].pipeline_id",
          "data[0].deal_probability"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_person",
      "description_for_ai": "Create a new contact person in Pipedrive.",
      "intent": [
        "add contact Pipedrive",
        "new person CRM",
        "create contact Pipedrive",
        "новый контакт Pipedrive"
      ],
      "endpoint": "POST https://api.pipedrive.com/v1/persons",
      "input": {
        "name": {
          "type": "string",
          "required": true
        },
        "email": {
          "type": "array",
          "description": "[{value: 'email@example.com', primary: true}]",
          "required": false
        },
        "phone": {
          "type": "array",
          "description": "[{value: '+1...', primary: true}]",
          "required": false
        },
        "org_id": {
          "type": "integer",
          "description": "Organization ID",
          "required": false
        }
      },
      "output": {
        "type": "person",
        "fields": [
          "data.id",
          "data.name",
          "data.email[0].value",
          "data.org_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_deal_details",
      "description_for_ai": "Get full details of a deal including activities, notes, and contacts.",
      "intent": [
        "deal details Pipedrive",
        "sale information",
        "детали сделки Pipedrive"
      ],
      "endpoint": "GET https://api.pipedrive.com/v1/deals/{id}",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "deal",
        "fields": [
          "data.id",
          "data.title",
          "data.value",
          "data.status",
          "data.person_name",
          "data.org_name",
          "data.stage_id",
          "data.expected_close_date"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "api_token": "Get token: Settings → Personal Preferences → API. Append to every request as ?api_token=...",
    "pagination": "Use start and limit params. Response includes additional_data.pagination.more_items_in_collection",
    "custom_fields": "Custom fields have hash keys like 'abc123def456'. List all via GET /dealFields, /personFields etc.",
    "webhooks": "Set up webhooks in Tools → Webhooks for real-time deal/contact/activity updates."
  }
}