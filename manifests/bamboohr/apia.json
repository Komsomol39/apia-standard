{
  "apia": "1.0",
  "service": {
    "id": "bamboohr",
    "name": "BambooHR API",
    "description_for_ai": "HR software for small and medium businesses. Employee records, time off, performance reviews, onboarding, org chart. Used by 30K+ companies. Use for HR data integration, time off management, employee directory.",
    "url": "https://bamboohr.com",
    "api_base": "https://api.bamboohr.com/api/gateway.php/{company}/v1",
    "category": "hr",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://documentation.bamboohr.com/reference"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "API key as username, anything as password",
    "how_to_get": "Account → API Keys",
    "cost": "Essentials: $8/employee/month"
  },
  "capabilities": [
    {
      "id": "get_employee",
      "description_for_ai": "Get employee profile from BambooHR by ID or list all employees.",
      "intent": [
        "employee info BambooHR",
        "HR profile",
        "employee data",
        "данные сотрудника BambooHR"
      ],
      "endpoint": "GET https://api.bamboohr.com/api/gateway.php/{companyDomain}/v1/employees/{id}",
      "input": {
        "companyDomain": {
          "type": "string",
          "description": "Your BambooHR company domain subdomain",
          "required": true
        },
        "id": {
          "type": "string",
          "description": "Employee ID or 'directory' for full list",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "firstName,lastName,workEmail,department,jobTitle,hireDate,employmentHistoryStatus",
          "required": false
        }
      },
      "output": {
        "type": "employee",
        "fields": [
          "id",
          "firstName",
          "lastName",
          "workEmail",
          "department",
          "jobTitle",
          "hireDate"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_employee",
      "description_for_ai": "Update employee information in BambooHR.",
      "intent": [
        "update employee",
        "change employee data",
        "обновить данные сотрудника BambooHR"
      ],
      "endpoint": "POST https://api.bamboohr.com/api/gateway.php/{companyDomain}/v1/employees/{id}",
      "input": {
        "companyDomain": {
          "type": "string",
          "required": true
        },
        "id": {
          "type": "integer",
          "required": true
        },
        "fields": {
          "type": "object",
          "description": "{department: 'Engineering', jobTitle: 'Senior Engineer', workEmail: 'new@company.com'}",
          "required": true
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "200 OK on success"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_time_off",
      "description_for_ai": "Get employee time-off requests and balances.",
      "intent": [
        "time off BambooHR",
        "vacation requests",
        "PTO balance",
        "отпуск BambooHR"
      ],
      "endpoint": "GET https://api.bamboohr.com/api/gateway.php/{companyDomain}/v1/time_off/requests",
      "input": {
        "companyDomain": {
          "type": "string",
          "required": true
        },
        "start": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "end": {
          "type": "string",
          "required": true
        },
        "status": {
          "type": "string",
          "description": "approved, denied, superceded, requested, canceled",
          "required": false
        }
      },
      "output": {
        "type": "list<time_off>",
        "fields": [
          "[0].id",
          "[0].employee.id",
          "[0].employee.displayName",
          "[0].type.name",
          "[0].start",
          "[0].end",
          "[0].status.status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_whos_out",
      "description_for_ai": "Get a list of employees who are out of office in a date range.",
      "intent": [
        "who is out BambooHR",
        "time off calendar",
        "absent employees",
        "кто отсутствует BambooHR"
      ],
      "endpoint": "GET https://api.bamboohr.com/api/gateway.php/{companyDomain}/v1/time_off/whos_out",
      "input": {
        "companyDomain": {
          "type": "string",
          "required": true
        },
        "start": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "end": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<absence>",
        "fields": [
          "[0].id",
          "[0].type",
          "[0].employee.id",
          "[0].employee.displayName",
          "[0].start",
          "[0].end"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "add_employee",
      "description_for_ai": "Create a new employee record in BambooHR.",
      "intent": [
        "add employee BambooHR",
        "new hire",
        "onboard employee",
        "добавить сотрудника BambooHR"
      ],
      "endpoint": "POST https://api.bamboohr.com/api/gateway.php/{companyDomain}/v1/employees",
      "input": {
        "companyDomain": {
          "type": "string",
          "required": true
        },
        "firstName": {
          "type": "string",
          "required": true
        },
        "lastName": {
          "type": "string",
          "required": true
        },
        "hireDate": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "department": {
          "type": "string",
          "required": false
        },
        "jobTitle": {
          "type": "string",
          "required": false
        },
        "workEmail": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "employee",
        "fields": [
          "id (new employee ID)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "company_domain": "Replace {company} in base URL with your BambooHR subdomain e.g. mycompany",
    "auth": "API key as username in basic auth, any string as password (e.g. 'x'). Get key: Account → API Keys",
    "fields": "Use GET /v1/meta/fields to discover all available field IDs for your account."
  }
}