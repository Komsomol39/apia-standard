{"apia":"1.0","service":{"id":"bamboohr","name":"BambooHR API","description_for_ai":"HR software for small and medium businesses. Employee records, time off, performance reviews, onboarding, org chart. Used by 30K+ companies. Use for HR data integration, time off management, employee directory.","url":"https://bamboohr.com","api_base":"https://api.bamboohr.com/api/gateway.php/{company}/v1","category":"hr_sme","geo":["GLOBAL"],"language":"en","docs":"https://documentation.bamboohr.com/reference"},"auth":{"type":"basic_auth","anonymous_access":false,"note":"API key as username, anything as password","how_to_get":"Account → API Keys","cost":"Essentials: $8/employee/month"},"capabilities":[{"id":"get_employees","description_for_ai":"Get employee directory with custom fields: name, email, department, title, location, hire date, phone.","intent":["employee directory","staff list","HR data","employee info","company directory","org chart data"],"endpoint":"GET https://api.bamboohr.com/api/gateway.php/{company}/v1/employees/directory","input":{},"output":{"type":"directory","fields":["employees[0].id","employees[0].displayName","employees[0].firstName","employees[0].lastName","employees[0].jobTitle","employees[0].department","employees[0].location","employees[0].workEmail","employees[0].hireDate"]},"realtime":true,"requires_auth":true},{"id":"get_time_off","description_for_ai":"Get employee time off requests and balances.","intent":["time off","vacation days","PTO","leave requests","sick days","employee absence"],"endpoint":"GET https://api.bamboohr.com/api/gateway.php/{company}/v1/time_off/requests/","input":{"start":{"type":"string","description":"YYYY-MM-DD","required":false},"end":{"type":"string","description":"YYYY-MM-DD","required":false},"employeeId":{"type":"integer","required":false},"type":{"type":"string","description":"approved, denied, superceded, requested, canceled","required":false}},"output":{"type":"list<time_off>","fields":["id","employeeId","status.statu