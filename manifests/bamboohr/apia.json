{
  "apia": "1.0",
  "service": {
    "id": "bamboohr",
    "name": "BambooHR API",
    "description_for_ai": "HR software for small and medium businesses. Employee records, time off, performance reviews, onboarding, org chart. Used by 30K+ companies. Use for HR data integration, time off management, employee directory.",
    "url": "https://bamboohr.com",
    "api_base": "https://api.bamboohr.com/api/gateway.php/{company}/v1",
    "category": "hr",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://documentation.bamboohr.com/reference"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "API key as username, anything as password",
    "how_to_get": "Account → API Keys",
    "cost": "Essentials: $8/employee/month"
  },
  "capabilities": [
    {
      "id": "get_employee",
      "description_for_ai": "Get employee profile with personal info, job details, salary, and custom fields.",
      "intent": [
        "employee info bamboohr",
        "HR employee data",
        "employee profile",
        "данные сотрудника bamboohr"
      ],
      "endpoint": "GET https://api.bamboohr.com/api/gateway.php/{company}/v1/employees/{id}",
      "input": {
        "company": {
          "type": "string",
          "required": true
        },
        "id": {
          "type": "string",
          "description": "Employee ID or 'directory' for all",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "Comma-separated: firstName,lastName,workEmail,department,jobTitle,salary,startDate,status",
          "required": false
        }
      },
      "output": {
        "type": "employee",
        "fields": [
          "id",
          "firstName",
          "lastName",
          "workEmail",
          "department",
          "jobTitle",
          "status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_employees",
      "description_for_ai": "List all active employees with basic info. Use for directory or reporting.",
      "intent": [
        "list employees",
        "employee directory",
        "all staff bamboohr",
        "список сотрудников"
      ],
      "endpoint": "GET https://api.bamboohr.com/api/gateway.php/{company}/v1/employees/directory",
      "input": {
        "company": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<employee>",
        "fields": [
          "employees[0].id",
          "employees[0].displayName",
          "employees[0].workEmail",
          "employees[0].department",
          "employees[0].jobTitle"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_time_off",
      "description_for_ai": "Get employee time-off requests and balances.",
      "intent": [
        "time off bamboohr",
        "vacation requests",
        "leave management",
        "отпуск bamboohr"
      ],
      "endpoint": "GET https://api.bamboohr.com/api/gateway.php/{company}/v1/time_off/requests",
      "input": {
        "company": {
          "type": "string",
          "required": true
        },
        "employeeId": {
          "type": "integer",
          "required": false
        },
        "start": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        },
        "end": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        },
        "status": {
          "type": "string",
          "description": "approved, denied, superceded, requested, canceled",
          "required": false
        }
      },
      "output": {
        "type": "list<request>",
        "fields": [
          "[0].id",
          "[0].employeeId",
          "[0].status.status",
          "[0].start.date",
          "[0].end.date",
          "[0].type.name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_employee",
      "description_for_ai": "Update employee fields: department, job title, manager, status.",
      "intent": [
        "update employee bamboohr",
        "change department HR",
        "edit employee info",
        "обновить сотрудника bamboohr"
      ],
      "endpoint": "POST https://api.bamboohr.com/api/gateway.php/{company}/v1/employees/{id}",
      "input": {
        "company": {
          "type": "string",
          "required": true
        },
        "id": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "object",
          "description": "{department: 'Engineering', jobTitle: 'Senior Developer', supervisorId: '123'}",
          "required": true
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "200 OK on success"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "company_domain": "Replace {company} in base URL with your BambooHR subdomain e.g. mycompany",
    "auth": "API key as username in basic auth, any string as password (e.g. 'x'). Get key: Account → API Keys",
    "fields": "Use GET /v1/meta/fields to discover all available field IDs for your account."
  }
}