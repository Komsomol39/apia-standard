{
  "apia": "1.0",
  "service": {
    "id": "shippo",
    "name": "Shippo API",
    "description_for_ai": "Shippo — multi-carrier shipping API connecting to 85+ carriers worldwide including USPS, UPS, FedEx, DHL, Canada Post, Australia Post, and regional carriers. Generate labels, compare rates, track packages. Free 30 labels/month. Used by 100K+ Shopify and WooCommerce merchants.",
    "url": "https://goshippo.com",
    "api_base": "https://api.goshippo.com",
    "category": "logistics",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://goshippo.com/docs/reference"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: ShippoToken shippo_test_...",
    "how_to_get": "Register at https://app.goshippo.com",
    "cost": "Free: 30 shipments/month. Basic: $19/month"
  },
  "capabilities": [
    {
      "id": "create_shipment",
      "description_for_ai": "Create a shipment with Shippo and get rates from multiple carriers.",
      "intent": [
        "shipping rates",
        "Shippo shipment",
        "compare shipping",
        "стоимость доставки Shippo"
      ],
      "endpoint": "POST https://api.goshippo.com/shipments/",
      "input": {
        "address_from": {
          "type": "object",
          "description": "{name, company, street1, city, state, zip, country, phone, email}",
          "required": true
        },
        "address_to": {
          "type": "object",
          "description": "Same format",
          "required": true
        },
        "parcels": {
          "type": "array",
          "description": "[{length, width, height, distance_unit: 'in', weight, mass_unit: 'lb'}]",
          "required": true
        },
        "async": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "shipment",
        "fields": [
          "object_id",
          "rates[0].provider",
          "rates[0].servicelevel.name",
          "rates[0].amount",
          "rates[0].currency",
          "rates[0].estimated_days"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_label",
      "description_for_ai": "Purchase a shipping label for a specific rate.",
      "intent": [
        "buy shipping label",
        "print label Shippo",
        "purchase postage",
        "купить ярлык доставки Shippo"
      ],
      "endpoint": "POST https://api.goshippo.com/transactions/",
      "input": {
        "rate": {
          "type": "string",
          "description": "Rate object ID from create_shipment",
          "required": true
        },
        "label_file_type": {
          "type": "string",
          "description": "PDF, PDF_4X6, PNG, ZPLII",
          "default": "PDF"
        },
        "async": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "transaction",
        "fields": [
          "object_id",
          "status (SUCCESS/ERROR)",
          "label_url",
          "tracking_number",
          "tracking_url_provider"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "track_shipment",
      "description_for_ai": "Track a shipment by tracking number and carrier.",
      "intent": [
        "track package Shippo",
        "shipment tracking",
        "delivery status",
        "отслеживание посылки Shippo"
      ],
      "endpoint": "GET https://api.goshippo.com/tracks/{carrier}/{tracking_number}",
      "input": {
        "carrier": {
          "type": "string",
          "description": "usps, fedex, ups, dhl_express, canada_post",
          "required": true
        },
        "tracking_number": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "tracking",
        "fields": [
          "tracking_status.status",
          "tracking_status.status_details",
          "tracking_status.location.city",
          "tracking_history[0].status",
          "tracking_history[0].status_date",
          "eta"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "validate_address",
      "description_for_ai": "Validate and standardize a shipping address with Shippo.",
      "intent": [
        "validate address",
        "address verification",
        "check address Shippo",
        "проверка адреса Shippo"
      ],
      "endpoint": "POST https://api.goshippo.com/addresses/",
      "input": {
        "name": {
          "type": "string",
          "required": true
        },
        "street1": {
          "type": "string",
          "required": true
        },
        "city": {
          "type": "string",
          "required": true
        },
        "state": {
          "type": "string",
          "required": false
        },
        "zip": {
          "type": "string",
          "required": true
        },
        "country": {
          "type": "string",
          "required": true
        },
        "validate": {
          "type": "boolean",
          "default": true
        }
      },
      "output": {
        "type": "address",
        "fields": [
          "object_id",
          "validation_results.is_valid",
          "validation_results.messages[0].text",
          "street1",
          "city",
          "state",
          "zip"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_parcels",
      "description_for_ai": "Get parcel templates (standard box sizes) for easy shipment creation.",
      "intent": [
        "parcel templates",
        "box sizes Shippo",
        "package types",
        "шаблоны посылок Shippo"
      ],
      "endpoint": "GET https://api.goshippo.com/parcel-templates/",
      "input": {
        "carrier": {
          "type": "string",
          "description": "Filter by carrier: usps, fedex, ups",
          "required": false
        }
      },
      "output": {
        "type": "list<template>",
        "fields": [
          "results[0].name",
          "results[0].carrier",
          "results[0].length",
          "results[0].width",
          "results[0].height",
          "results[0].distance_unit"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}