{
  "apia": "1.0",
  "service": {
    "id": "hh-kz",
    "name": "HeadHunter Казахстан (hh.kz)",
    "description_for_ai": "Крупнейшая биржа труда Казахстана. Используй для поиска вакансий в Казахстане по ключевым словам, городу или координатам. API идентично hh.ru, отличается только базовым URL и валютой (тенге). Зарплаты в тенге (₸).",
    "url": "https://hh.kz",
    "api_base": "https://api.hh.kz/v1",
    "category": "employment",
    "geo": [
      "KZ"
    ],
    "language": "ru",
    "docs": "https://github.com/hhru/api",
    "note": "API полностью совместимо с hh.ru — те же endpoints, те же параметры, другой base URL и валюта"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": true,
    "anonymous_capabilities": [
      "search_vacancies",
      "get_vacancy",
      "get_areas"
    ],
    "oauth_url": "https://hh.kz/oauth/authorize",
    "token_url": "https://hh.kz/oauth/token"
  },
  "capabilities": [
    {
      "id": "search_vacancies",
      "description_for_ai": "Поиск вакансий в Казахстане по ключевому слову, городу или координатам. Зарплаты в тенге (₸). Используй для запросов 'работа в Алматы', 'вакансии в Астане', 'найди работу в Казахстане'.",
      "intent": [
        "работа в Казахстане",
        "вакансии в Алматы",
        "работа в Астане",
        "найти работу в КЗ",
        "вакансии в Казахстане",
        "работа в Шымкенте"
      ],
      "endpoint": "GET https://api.hh.kz/vacancies",
      "input": {
        "text": {
          "type": "string",
          "description": "Поисковый запрос",
          "required": false
        },
        "area": {
          "type": "integer",
          "description": "ID города. Алматы=160, Астана=159, Шымкент=210. Получить через get_areas",
          "required": false
        },
        "lat": {
          "type": "float",
          "description": "Широта для геопоиска",
          "required": false
        },
        "lng": {
          "type": "float",
          "description": "Долгота для геопоиска",
          "required": false
        },
        "salary": {
          "type": "integer",
          "description": "Минимальная зарплата в тенге (₸)",
          "required": false
        },
        "currency": {
          "type": "string",
          "description": "Валюта зарплаты",
          "default": "KZT"
        },
        "experience": {
          "type": "string",
          "description": "noExperience, between1And3, between3And6, moreThan6",
          "required": false
        },
        "schedule": {
          "type": "string",
          "description": "fullDay, remote, flexible, shift",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 20,
          "max": 100,
          "description": "Results per page. Check API docs for maximum allowed."
        },
        "page": {
          "type": "integer",
          "default": 0,
          "description": "Page number for pagination (1-indexed)"
        }
      },
      "output": {
        "type": "list<vacancy>",
        "fields": [
          "id",
          "name",
          "area.name",
          "salary.from",
          "salary.to",
          "salary.currency",
          "employer.name",
          "url",
          "published_at"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_vacancy",
      "description_for_ai": "Get full vacancy details from hh.kz Kazakhstan: title, company, salary in KZT, requirements, and employer info.",
      "intent": [
        "вакансия Казахстан",
        "работа Алматы",
        "работа Астана",
        "job Kazakhstan",
        "зарплата KZT"
      ],
      "endpoint": "GET https://api.hh.kz/vacancies/{vacancy_id}",
      "input": {
        "id": {
          "type": "string",
          "description": "Vacancy ID from search results",
          "required": true
        },
        "locale": {
          "type": "string",
          "description": "Response language: RU or EN",
          "default": "RU"
        }
      },
      "output": {
        "type": "vacancy",
        "fields": [
          "name",
          "description",
          "key_skills",
          "employer.name",
          "salary",
          "address.raw",
          "contacts"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_areas",
      "description_for_ai": "Список городов Казахстана с ID для фильтрации вакансий.",
      "intent": [
        "города Казахстана",
        "ID Алматы",
        "регионы КЗ"
      ],
      "endpoint": "GET https://api.hh.kz/areas",
      "input": {},
      "output": {
        "type": "list<area>",
        "fields": [
          "id",
          "name",
          "areas"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "base_url": "Use api.hh.kz for Kazakhstan-localized results. API identical to hh.ru.",
    "areas": "Kazakhstan area ID: 40. Almaty: 160. Astana/Nur-Sultan: 159. Get full list from /areas.",
    "currency": "Salaries in KZT (Kazakhstani tenge). Filter by: salary_currency=KZT."
  },
  "limits": {
    "requests_per_day": 1000,
    "commercial_use": false,
    "attribution_required": true
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}