{
  "apia": "1.0",
  "service": {
    "id": "sendgrid",
    "name": "SendGrid API (Twilio)",
    "description_for_ai": "Email delivery API trusted by 80,000+ companies. Send transactional and marketing emails. 100 emails/day free. High deliverability, analytics, templates. Use for sending emails programmatically.",
    "url": "https://sendgrid.com",
    "api_base": "https://api.sendgrid.com/v3",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.sendgrid.com/api-reference"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer SG...",
    "how_to_get": "Register at https://signup.sendgrid.com — 100 emails/day free",
    "cost": "Free: 100/day. Essentials: $19.95/month 50K emails"
  },
  "capabilities": [
    {
      "id": "send_email",
      "description_for_ai": "Send transactional email via SendGrid. Supports HTML, templates, and attachments.",
      "intent": [
        "send email SendGrid",
        "transactional email",
        "email API SendGrid",
        "отправить письмо SendGrid"
      ],
      "endpoint": "POST https://api.sendgrid.com/v3/mail/send",
      "input": {
        "from": {
          "type": "object",
          "description": "{email: 'sender@example.com', name: 'Sender Name'}",
          "required": true
        },
        "to": {
          "type": "array",
          "description": "Array in personalizations: [{to: [{email, name}], subject: '...'}]",
          "required": true
        },
        "subject": {
          "type": "string",
          "required": false
        },
        "content": {
          "type": "array",
          "description": "[{type: 'text/plain', value: '...'}, {type: 'text/html', value: '<p>...</p>'}]",
          "required": false
        },
        "template_id": {
          "type": "string",
          "description": "Dynamic template ID from SendGrid",
          "required": false
        },
        "dynamic_template_data": {
          "type": "object",
          "description": "Template variables: {first_name: 'John', order_id: '12345'}",
          "required": false
        }
      },
      "output": {
        "type": "status",
        "fields": [
          "202 Accepted on success",
          "X-Message-Id header"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_stats",
      "description_for_ai": "Get email delivery statistics: requests, deliveries, opens, clicks, bounces.",
      "intent": [
        "SendGrid stats",
        "email analytics",
        "delivery stats",
        "статистика SendGrid"
      ],
      "endpoint": "GET https://api.sendgrid.com/v3/stats",
      "input": {
        "start_date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "end_date": {
          "type": "string",
          "required": false
        },
        "aggregated_by": {
          "type": "string",
          "description": "day, week, month",
          "default": "day"
        }
      },
      "output": {
        "type": "list<stats>",
        "fields": [
          "[0].date",
          "[0].stats[0].metrics.requests",
          "[0].stats[0].metrics.delivered",
          "[0].stats[0].metrics.opens",
          "[0].stats[0].metrics.clicks",
          "[0].stats[0].metrics.bounces"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "manage_contacts",
      "description_for_ai": "Add or update email contacts in SendGrid marketing lists.",
      "intent": [
        "SendGrid contacts",
        "email list SendGrid",
        "add subscriber SendGrid",
        "контакты SendGrid"
      ],
      "endpoint": "PUT https://api.sendgrid.com/v3/marketing/contacts",
      "input": {
        "contacts": {
          "type": "array",
          "description": "[{email: 'user@example.com', first_name: 'John', last_name: 'Doe', custom_fields: {}}]",
          "required": true
        },
        "list_ids": {
          "type": "array",
          "description": "List IDs to add contacts to",
          "required": false
        }
      },
      "output": {
        "type": "job",
        "fields": [
          "job_id",
          "created_count",
          "updated_count",
          "errored_count"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_template",
      "description_for_ai": "Create a transactional email template in SendGrid.",
      "intent": [
        "email template SendGrid",
        "create template",
        "email design",
        "шаблон письма SendGrid"
      ],
      "endpoint": "POST https://api.sendgrid.com/v3/templates",
      "input": {
        "name": {
          "type": "string",
          "required": true
        },
        "generation": {
          "type": "string",
          "description": "dynamic (use Handlebars) or legacy",
          "default": "dynamic"
        }
      },
      "output": {
        "type": "template",
        "fields": [
          "id",
          "name",
          "generation"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "validate_email",
      "description_for_ai": "Validate an email address for syntax and deliverability.",
      "intent": [
        "validate email SendGrid",
        "email check",
        "deliverability check",
        "проверка email SendGrid"
      ],
      "endpoint": "POST https://api.sendgrid.com/v3/validations/email",
      "input": {
        "email": {
          "type": "string",
          "required": true
        },
        "source": {
          "type": "string",
          "description": "Source label for tracking",
          "required": false
        }
      },
      "output": {
        "type": "validation",
        "fields": [
          "result.email",
          "result.verdict",
          "result.score",
          "result.suggestion"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_bounces",
      "description_for_ai": "Get list of bounced email addresses to clean your list.",
      "intent": [
        "bounce list SendGrid",
        "email bounces",
        "invalid emails",
        "отказы доставки SendGrid"
      ],
      "endpoint": "GET https://api.sendgrid.com/v3/suppression/bounces",
      "input": {
        "start_time": {
          "type": "integer",
          "description": "Unix timestamp",
          "required": false
        },
        "end_time": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "list<bounce>",
        "fields": [
          "[0].email",
          "[0].status",
          "[0].reason",
          "[0].created"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "sender_auth": "Verify sender email or domain first: app.sendgrid.com/settings/sender_auth. Unverified senders get blocked.",
    "templates": "Use Dynamic Templates in SendGrid for personalized emails with Handlebars variables.",
    "suppression": "Bounces/unsubscribes are auto-managed. Check suppression list before re-adding: GET /v3/suppression/bounces",
    "webhooks": "Enable Event Webhook for delivery tracking: open, click, bounce, spam_report events.",
    "from_address": "Must use verified sender email or domain. Verify at https://app.sendgrid.com/settings/sender_auth",
    "html": "Send both text/plain and text/html versions for better deliverability."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}