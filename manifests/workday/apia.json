{
  "apia": "1.0",
  "service": {
    "id": "workday",
    "name": "Workday API",
    "description_for_ai": "Enterprise HR platform. Employee records, payroll, recruiting, time tracking, benefits, learning. Used by 10K+ organizations. Use for HR automation, employee data integration, talent management.",
    "url": "https://workday.com",
    "api_base": "https://{tenant}.workday.com/api",
    "category": "hr",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.workday.com/"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Workday tenant Admin → OAuth Clients",
    "cost": "Enterprise licensing required"
  },
  "capabilities": [
    {
      "id": "get_workers",
      "description_for_ai": "Get employee/worker data from Workday.",
      "intent": [
        "Workday employees",
        "HR data Workday",
        "worker list",
        "сотрудники Workday"
      ],
      "endpoint": "GET https://{tenant}.workday.com/ccx/service/{tenant}/Human_Resources/v40.0/workers",
      "input": {
        "Count": {
          "type": "integer",
          "default": 100
        },
        "Page": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<worker>",
        "fields": [
          "Worker[0].Worker_Reference.ID",
          "Worker[0].Worker_Data.Personal_Data.Name_Data.Preferred_Name_Data.Name_Detail_Data.First_Name",
          "Worker[0].Worker_Data.Employment_Data.Worker_Status_Data.Active"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_job_postings",
      "description_for_ai": "Get active job postings from Workday Recruiting.",
      "intent": [
        "Workday jobs",
        "job postings",
        "open positions Workday",
        "вакансии Workday"
      ],
      "endpoint": "GET https://{tenant}.workday.com/wday/authgwy/{tenant}/login?redirect_uri=.",
      "input": {
        "tenant": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<job>",
        "fields": [
          "[0].title",
          "[0].location",
          "[0].jobReqId",
          "[0].posted_date"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_organizations",
      "description_for_ai": "Get organizational structure from Workday.",
      "intent": [
        "Workday org chart",
        "departments Workday",
        "organization structure",
        "структура организации Workday"
      ],
      "endpoint": "GET https://{tenant}.workday.com/ccx/service/{tenant}/Human_Resources/v40.0/organizations",
      "input": {
        "Organization_Type": {
          "type": "string",
          "description": "Company, Cost_Center, Department",
          "required": false
        }
      },
      "output": {
        "type": "list<org>",
        "fields": [
          "Organization[0].Organization_Reference.ID",
          "Organization[0].Organization_Data.Organization_Code",
          "Organization[0].Organization_Data.Organization_Name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_absence_data",
      "description_for_ai": "Get employee absence/time-off data from Workday.",
      "intent": [
        "employee absence Workday",
        "time off Workday",
        "vacation data HR",
        "отпуска сотрудников Workday"
      ],
      "endpoint": "GET https://{tenant}.workday.com/ccx/service/{tenant}/Absence_Management/v40.0/absences",
      "input": {
        "Worker_Reference": {
          "type": "string",
          "description": "Worker reference ID",
          "required": false
        },
        "Start_Date": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        }
      },
      "output": {
        "type": "list<absence>",
        "fields": [
          "Absence[0].Absence_Type",
          "Absence[0].Start_Date",
          "Absence[0].End_Date",
          "Absence[0].Days"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_compensation",
      "description_for_ai": "Get compensation data for workers from Workday.",
      "intent": [
        "Workday compensation",
        "salary data HR",
        "pay data Workday",
        "данные о зарплате Workday"
      ],
      "endpoint": "GET https://{tenant}.workday.com/ccx/service/{tenant}/Compensation/v40.0/workers",
      "input": {
        "Worker_Reference": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<comp>",
        "fields": [
          "Worker[0].Compensation_Data.Primary_Compensation_Basis",
          "Worker[0].Compensation_Data.Grade_Profile_Summary_Data.Grade"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}