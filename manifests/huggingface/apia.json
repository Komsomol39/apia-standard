{
  "apia": "1.0",
  "service": {
    "id": "huggingface",
    "name": "Hugging Face Inference API",
    "description_for_ai": "Run 300,000+ open-source ML models via API. Text generation, classification, translation, image generation, audio. Free tier available. Access to Llama, Mistral, SDXL, Whisper and thousands of specialized models.",
    "url": "https://huggingface.co",
    "api_base": "https://api-inference.huggingface.co",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://huggingface.co/docs/api-inference"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Bearer hf_...",
    "how_to_get": "Free token at https://huggingface.co/settings/tokens",
    "cost": "Free tier available. PRO: $9/month for priority"
  },
  "capabilities": [
    {
      "id": "inference_api",
      "description_for_ai": "Run 200,000+ ML models via API. Text generation, image classification, NLP, audio — all from one API.",
      "intent": [
        "HuggingFace models",
        "run ML model",
        "AI model API",
        "запустить модель HuggingFace"
      ],
      "endpoint": "POST https://api-inference.huggingface.co/models/{model}",
      "input": {
        "model": {
          "type": "string",
          "description": "Model name e.g. meta-llama/Llama-3.1-8B-Instruct, mistralai/Mistral-7B, gpt2, bert-base-uncased",
          "required": true
        },
        "inputs": {
          "type": "string or object",
          "description": "Input depends on task: string for text-gen/classification, {source_sentence, sentences} for embeddings, etc.",
          "required": true
        },
        "parameters": {
          "type": "object",
          "description": "{max_new_tokens: 200, temperature: 0.7, return_full_text: false}",
          "required": false
        }
      },
      "output": {
        "type": "varies",
        "fields": [
          "[0].generated_text (text-gen)",
          "[0].label, [0].score (classification)",
          "[0] (embedding float array)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_models",
      "description_for_ai": "Search and filter 200,000+ models on HuggingFace Hub by task, library, language, dataset.",
      "intent": [
        "find HuggingFace model",
        "search models",
        "ML model search",
        "найти модель HuggingFace"
      ],
      "endpoint": "GET https://huggingface.co/api/models",
      "input": {
        "search": {
          "type": "string",
          "description": "Search query",
          "required": false
        },
        "task": {
          "type": "string",
          "description": "text-generation, text-classification, token-classification, translation, summarization, image-classification, text-to-image, automatic-speech-recognition",
          "required": false
        },
        "language": {
          "type": "string",
          "description": "ISO code: en, ru, zh, de",
          "required": false
        },
        "library": {
          "type": "string",
          "description": "transformers, diffusers, peft, gguf",
          "required": false
        },
        "sort": {
          "type": "string",
          "description": "downloads, likes, trending",
          "default": "downloads"
        },
        "limit": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<model>",
        "fields": [
          "[0].id",
          "[0].task",
          "[0].downloads",
          "[0].likes",
          "[0].tags"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "text_to_image",
      "description_for_ai": "Generate images from text using Stable Diffusion, FLUX, or other image models on HuggingFace.",
      "intent": [
        "generate image HuggingFace",
        "Stable Diffusion API",
        "text to image",
        "генерация изображений HuggingFace"
      ],
      "endpoint": "POST https://api-inference.huggingface.co/models/{model}",
      "input": {
        "model": {
          "type": "string",
          "description": "black-forest-labs/FLUX.1-schnell, stabilityai/stable-diffusion-xl-base-1.0, runwayml/stable-diffusion-v1-5",
          "required": true
        },
        "inputs": {
          "type": "string",
          "description": "Image generation prompt",
          "required": true
        },
        "parameters": {
          "type": "object",
          "description": "{negative_prompt, num_inference_steps: 20, width: 512, height: 512}",
          "required": false
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "image binary (PNG)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "sentence_similarity",
      "description_for_ai": "Calculate semantic similarity between sentences using embedding models.",
      "intent": [
        "text similarity",
        "sentence similarity",
        "semantic match",
        "схожесть текстов HuggingFace"
      ],
      "endpoint": "POST https://api-inference.huggingface.co/models/sentence-transformers/all-MiniLM-L6-v2",
      "input": {
        "inputs": {
          "type": "object",
          "description": "{source_sentence: 'main text', sentences: ['compare to this', 'and this']}",
          "required": true
        }
      },
      "output": {
        "type": "similarities",
        "fields": [
          "[0] (float 0-1 similarity score per sentence)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_model_info",
      "description_for_ai": "Get model details: task, downloads, license, tags, files available.",
      "intent": [
        "model info",
        "model details HuggingFace",
        "model card",
        "информация о модели HuggingFace"
      ],
      "endpoint": "GET https://huggingface.co/api/models/{model}",
      "input": {
        "model": {
          "type": "string",
          "description": "Model ID e.g. meta-llama/Llama-3.1-8B-Instruct",
          "required": true
        }
      },
      "output": {
        "type": "model",
        "fields": [
          "id",
          "task",
          "downloads",
          "likes",
          "tags",
          "license",
          "siblings (files)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "list_datasets",
      "description_for_ai": "Search and browse datasets on HuggingFace Hub.",
      "intent": [
        "find dataset",
        "HuggingFace dataset",
        "ML dataset",
        "наборы данных HuggingFace"
      ],
      "endpoint": "GET https://huggingface.co/api/datasets",
      "input": {
        "search": {
          "type": "string",
          "required": false
        },
        "task": {
          "type": "string",
          "required": false
        },
        "language": {
          "type": "string",
          "required": false
        },
        "sort": {
          "type": "string",
          "default": "downloads"
        },
        "limit": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<dataset>",
        "fields": [
          "[0].id",
          "[0].downloads",
          "[0].likes",
          "[0].tags"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "cold_start": "Free tier models sleep — first request may take 20-30s. Use wait_for_model=true.",
    "model_search": "Search models at huggingface.co/models — filter by task (text-generation, image-classification etc.)"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}