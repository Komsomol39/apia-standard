{
  "apia": "1.0",
  "service": {
    "id": "mailchimp",
    "name": "Mailchimp API",
    "description_for_ai": "Email marketing platform API. Manage subscriber lists, send campaigns, automate email sequences, track open rates. 500 contacts and 1000 emails/month free. Best for marketing emails and newsletters.",
    "url": "https://mailchimp.com",
    "api_base": "https://{dc}.api.mailchimp.com/3.0",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://mailchimp.com/developer/marketing/api/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "Get API key at https://mailchimp.com/account/api — free account available",
    "cost": "Free: 500 contacts, 1K emails/month. Essentials from $13/month"
  },
  "capabilities": [
    {
      "id": "add_subscriber",
      "description_for_ai": "Add or update an email subscriber in a Mailchimp audience list.",
      "intent": [
        "add subscriber mailchimp",
        "email list mailchimp",
        "subscribe email",
        "подписчик mailchimp"
      ],
      "endpoint": "POST https://{dc}.api.mailchimp.com/3.0/lists/{list_id}/members",
      "input": {
        "list_id": {
          "type": "string",
          "description": "Audience/List ID from Mailchimp dashboard",
          "required": true
        },
        "email_address": {
          "type": "string",
          "required": true
        },
        "status": {
          "type": "string",
          "description": "subscribed, unsubscribed, cleaned, pending, transactional",
          "required": true
        },
        "merge_fields": {
          "type": "object",
          "description": "{FNAME: 'John', LNAME: 'Doe', PHONE: '+1234567890'}",
          "required": false
        },
        "tags": {
          "type": "array",
          "description": "Tags to apply to subscriber",
          "required": false
        },
        "language": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "member",
        "fields": [
          "id",
          "email_address",
          "status",
          "merge_fields",
          "timestamp_signup"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_campaign",
      "description_for_ai": "Send a Mailchimp email campaign to a list.",
      "intent": [
        "send campaign mailchimp",
        "email blast",
        "newsletter mailchimp",
        "рассылка mailchimp"
      ],
      "endpoint": "POST https://{dc}.api.mailchimp.com/3.0/campaigns/{campaign_id}/actions/send",
      "input": {
        "campaign_id": {
          "type": "string",
          "description": "Campaign ID — create first via POST /3.0/campaigns",
          "required": true
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "204 No Content on success"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_campaign",
      "description_for_ai": "Create a new email campaign with subject, from name, and audience.",
      "intent": [
        "create campaign mailchimp",
        "new email campaign",
        "design newsletter",
        "создать кампанию mailchimp"
      ],
      "endpoint": "POST https://{dc}.api.mailchimp.com/3.0/campaigns",
      "input": {
        "type": {
          "type": "string",
          "description": "regular, plaintext, absplit, rss, variate",
          "required": true
        },
        "recipients": {
          "type": "object",
          "description": "{list_id: 'audience_id', segment_opts: {saved_segment_id: 123}}",
          "required": true
        },
        "settings": {
          "type": "object",
          "description": "{subject_line: 'Newsletter', title: 'May 2024', from_name: 'Company', reply_to: 'hello@company.com'}",
          "required": true
        }
      },
      "output": {
        "type": "campaign",
        "fields": [
          "id",
          "type",
          "status",
          "create_time"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_reports",
      "description_for_ai": "Get campaign performance report: opens, clicks, bounces, unsubscribes.",
      "intent": [
        "mailchimp report",
        "campaign stats",
        "email analytics",
        "аналитика mailchimp"
      ],
      "endpoint": "GET https://{dc}.api.mailchimp.com/3.0/reports/{campaign_id}",
      "input": {
        "campaign_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "report",
        "fields": [
          "emails_sent",
          "opens.open_rate",
          "clicks.click_rate",
          "bounces.hard_bounces",
          "unsubscribed",
          "forwards.forwards_count"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "dc": "Replace {dc} in base URL with your datacenter code from API key suffix e.g. key us21 → dc=us21",
    "list_id": "Get list IDs from GET /lists endpoint. Each 'audience' has a unique list_id.",
    "double_optin": "status='pending' sends confirmation email (double opt-in). 'subscribed' adds directly (use for known users).",
    "tags": "Use tags array to segment subscribers: ['newsletter', 'vip', 'trial']"
  }
}