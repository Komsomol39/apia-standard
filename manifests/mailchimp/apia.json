{
  "apia": "1.0",
  "service": {
    "id": "mailchimp",
    "name": "Mailchimp API",
    "description_for_ai": "Email marketing platform API. Manage subscriber lists, send campaigns, automate email sequences, track open rates. 500 contacts and 1000 emails/month free. Best for marketing emails and newsletters.",
    "url": "https://mailchimp.com",
    "api_base": "https://{dc}.api.mailchimp.com/3.0",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://mailchimp.com/developer/marketing/api/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "Get API key at https://mailchimp.com/account/api — free account available",
    "cost": "Free: 500 contacts, 1K emails/month. Essentials from $13/month"
  },
  "capabilities": [
    {
      "id": "get_lists",
      "description_for_ai": "Get all Mailchimp email audiences (lists) with subscriber counts.",
      "intent": [
        "Mailchimp lists",
        "email audiences",
        "subscriber lists",
        "списки Mailchimp"
      ],
      "endpoint": "GET https://{dc}.api.mailchimp.com/3.0/lists",
      "input": {
        "count": {
          "type": "integer",
          "default": 10
        },
        "offset": {
          "type": "integer",
          "default": 0
        }
      },
      "output": {
        "type": "list<audience>",
        "fields": [
          "lists[0].id",
          "lists[0].name",
          "lists[0].stats.member_count",
          "lists[0].stats.open_rate",
          "lists[0].stats.click_rate"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "add_subscriber",
      "description_for_ai": "Add or update a subscriber in a Mailchimp list.",
      "intent": [
        "add subscriber Mailchimp",
        "subscribe email",
        "add to list",
        "добавить подписчика Mailchimp"
      ],
      "endpoint": "PUT https://{dc}.api.mailchimp.com/3.0/lists/{list_id}/members/{subscriber_hash}",
      "input": {
        "list_id": {
          "type": "string",
          "required": true
        },
        "email_address": {
          "type": "string",
          "required": true
        },
        "status": {
          "type": "string",
          "description": "subscribed, unsubscribed, cleaned, pending",
          "default": "subscribed"
        },
        "merge_fields": {
          "type": "object",
          "description": "{FNAME: 'John', LNAME: 'Doe', PHONE: '+1234567890'}",
          "required": false
        },
        "tags": {
          "type": "array",
          "description": "String tags to apply",
          "required": false
        }
      },
      "output": {
        "type": "member",
        "fields": [
          "id",
          "email_address",
          "status",
          "merge_fields"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_campaign",
      "description_for_ai": "Create an email campaign in Mailchimp.",
      "intent": [
        "create campaign Mailchimp",
        "email campaign",
        "newsletter Mailchimp",
        "рассылка Mailchimp"
      ],
      "endpoint": "POST https://{dc}.api.mailchimp.com/3.0/campaigns",
      "input": {
        "type": {
          "type": "string",
          "description": "regular, plaintext, absplit, rss, variate",
          "default": "regular"
        },
        "settings": {
          "type": "object",
          "description": "{subject_line, preview_text, title, from_name, reply_to, list_id}",
          "required": true
        }
      },
      "output": {
        "type": "campaign",
        "fields": [
          "id",
          "type",
          "status",
          "emails_sent",
          "web_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_campaign",
      "description_for_ai": "Send a ready Mailchimp campaign to its audience.",
      "intent": [
        "send campaign Mailchimp",
        "send email Mailchimp",
        "blast email",
        "отправить рассылку Mailchimp"
      ],
      "endpoint": "POST https://{dc}.api.mailchimp.com/3.0/campaigns/{campaign_id}/actions/send",
      "input": {
        "campaign_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "status",
        "fields": [
          "204 No Content on success"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_campaign_report",
      "description_for_ai": "Get email campaign statistics: opens, clicks, bounces, unsubscribes.",
      "intent": [
        "campaign stats Mailchimp",
        "email analytics",
        "open rate",
        "статистика рассылки Mailchimp"
      ],
      "endpoint": "GET https://{dc}.api.mailchimp.com/3.0/reports/{campaign_id}",
      "input": {
        "campaign_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "report",
        "fields": [
          "emails_sent",
          "opens.open_rate",
          "clicks.click_rate",
          "bounces.hard_bounces",
          "unsubscribes"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_members",
      "description_for_ai": "Search for subscribers in Mailchimp by email or name.",
      "intent": [
        "search subscriber Mailchimp",
        "find member",
        "subscriber lookup",
        "найти подписчика Mailchimp"
      ],
      "endpoint": "GET https://{dc}.api.mailchimp.com/3.0/search-members",
      "input": {
        "query": {
          "type": "string",
          "description": "Email or name to search",
          "required": true
        },
        "list_id": {
          "type": "string",
          "description": "Filter to specific list",
          "required": false
        }
      },
      "output": {
        "type": "list<member>",
        "fields": [
          "exact_matches.members[0].email_address",
          "full_search.members[0].status",
          "full_search.members[0].merge_fields"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "dc": "Replace {dc} in base URL with your datacenter code from API key suffix e.g. key us21 → dc=us21",
    "list_id": "Get list IDs from GET /lists endpoint. Each 'audience' has a unique list_id.",
    "double_optin": "status='pending' sends confirmation email (double opt-in). 'subscribed' adds directly (use for known users).",
    "tags": "Use tags array to segment subscribers: ['newsletter', 'vip', 'trial']"
  }
}