{
  "apia": "1.0",
  "service": {
    "id": "mailchimp",
    "name": "Mailchimp API",
    "description_for_ai": "Email marketing platform API. Manage subscriber lists, send campaigns, automate email sequences, track open rates. 500 contacts and 1000 emails/month free. Best for marketing emails and newsletters.",
    "url": "https://mailchimp.com",
    "api_base": "https://{dc}.api.mailchimp.com/3.0",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://mailchimp.com/developer/marketing/api/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "Get API key at https://mailchimp.com/account/api — free account available",
    "cost": "Free: 500 contacts, 1K emails/month. Essentials from $13/month"
  },
  "capabilities": [
    {
      "id": "add_subscriber",
      "description_for_ai": "Add or update a subscriber in a Mailchimp audience list.",
      "intent": [
        "mailchimp subscribe",
        "add to mailchimp",
        "email list mailchimp",
        "подписать на рассылку mailchimp"
      ],
      "endpoint": "PUT https://{dc}.api.mailchimp.com/3.0/lists/{list_id}/members/{subscriber_hash}",
      "input": {
        "list_id": {
          "type": "string",
          "description": "Audience list ID",
          "required": true
        },
        "subscriber_hash": {
          "type": "string",
          "description": "MD5 hash of lowercase email address",
          "required": true
        },
        "email_address": {
          "type": "string",
          "required": true
        },
        "status": {
          "type": "string",
          "description": "subscribed, unsubscribed, pending, cleaned",
          "default": "subscribed"
        },
        "merge_fields": {
          "type": "object",
          "description": "{FNAME: 'John', LNAME: 'Doe'}",
          "required": false
        },
        "tags": {
          "type": "array",
          "required": false
        }
      },
      "output": {
        "type": "member",
        "fields": [
          "id",
          "email_address",
          "status",
          "unique_email_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_campaign",
      "description_for_ai": "Create and send an email campaign to an audience.",
      "intent": [
        "send campaign mailchimp",
        "email campaign",
        "newsletter mailchimp",
        "рассылка mailchimp"
      ],
      "endpoint": "POST https://{dc}.api.mailchimp.com/3.0/campaigns/{campaign_id}/actions/send",
      "input": {
        "campaign_id": {
          "type": "string",
          "description": "Campaign ID (create first via /3.0/campaigns)",
          "required": true
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "204 No Content on success"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_campaign_report",
      "description_for_ai": "Get email campaign performance: opens, clicks, bounces, unsubscribes.",
      "intent": [
        "mailchimp report",
        "campaign stats",
        "email performance mailchimp",
        "статистика рассылки mailchimp"
      ],
      "endpoint": "GET https://{dc}.api.mailchimp.com/3.0/reports/{campaign_id}",
      "input": {
        "campaign_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "report",
        "fields": [
          "emails_sent",
          "opens.open_rate",
          "clicks.click_rate",
          "bounces.hard_bounces",
          "unsubscribed",
          "abuse_reports"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "list_audiences",
      "description_for_ai": "Get all Mailchimp audience lists with subscriber counts.",
      "intent": [
        "mailchimp lists",
        "audiences mailchimp",
        "email lists",
        "списки mailchimp"
      ],
      "endpoint": "GET https://{dc}.api.mailchimp.com/3.0/lists",
      "input": {
        "count": {
          "type": "integer",
          "default": 10
        },
        "offset": {
          "type": "integer",
          "default": 0
        }
      },
      "output": {
        "type": "list<audience>",
        "fields": [
          "lists[0].id",
          "lists[0].name",
          "lists[0].stats.member_count",
          "lists[0].stats.open_rate"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "dc": "Replace {dc} in base URL with your datacenter code from API key suffix e.g. key us21 → dc=us21",
    "list_id": "Get list IDs from GET /lists endpoint. Each 'audience' has a unique list_id.",
    "double_optin": "status='pending' sends confirmation email (double opt-in). 'subscribed' adds directly (use for known users).",
    "tags": "Use tags array to segment subscribers: ['newsletter', 'vip', 'trial']"
  }
}