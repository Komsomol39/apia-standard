{
  "apia": "1.0",
  "service": {
    "id": "pagerduty",
    "name": "PagerDuty API",
    "description_for_ai": "Incident management and on-call scheduling platform. Create incidents, manage on-call rotations, send alerts. Used by 25K+ companies. Use for DevOps incident alerting, on-call management, incident response.",
    "url": "https://pagerduty.com",
    "api_base": "https://api.pagerduty.com",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.pagerduty.com/api-reference/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Token token={api_key}",
    "how_to_get": "Account Settings → API Access",
    "cost": "Free: 14-day trial. Professional: $21/user/month"
  },
  "capabilities": [
    {
      "id": "list_incidents",
      "description_for_ai": "List PagerDuty incidents filtered by status, urgency, and service.",
      "intent": [
        "pagerduty incidents",
        "on-call incidents",
        "alerts pagerduty",
        "инциденты pagerduty"
      ],
      "endpoint": "GET https://api.pagerduty.com/incidents",
      "input": {
        "statuses[]": {
          "type": "array",
          "description": "triggered, acknowledged, resolved",
          "required": false
        },
        "urgencies[]": {
          "type": "array",
          "description": "high, low",
          "required": false
        },
        "service_ids[]": {
          "type": "array",
          "description": "Filter by service IDs",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 25
        },
        "offset": {
          "type": "integer",
          "default": 0
        },
        "date_range": {
          "type": "string",
          "description": "all or custom range with since/until params",
          "required": false
        }
      },
      "output": {
        "type": "list<incident>",
        "fields": [
          "incidents[0].id",
          "incidents[0].title",
          "incidents[0].status",
          "incidents[0].urgency",
          "incidents[0].service.name",
          "incidents[0].created_at",
          "incidents[0].html_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_incident",
      "description_for_ai": "Create a PagerDuty incident to alert on-call team.",
      "intent": [
        "create incident pagerduty",
        "trigger alert",
        "page on-call",
        "создать инцидент pagerduty"
      ],
      "endpoint": "POST https://api.pagerduty.com/incidents",
      "input": {
        "incident": {
          "type": "object",
          "description": "{type: 'incident', title: 'Database down', service: {id: 'SERVICE_ID', type: 'service_reference'}, urgency: 'high', body: {type: 'incident_body', details: 'Error details'}, escalation_policy: {id: 'EP_ID'}}",
          "required": true
        },
        "from": {
          "type": "string",
          "description": "Email of PD user creating the incident (required in header)",
          "required": true
        }
      },
      "output": {
        "type": "incident",
        "fields": [
          "incident.id",
          "incident.incident_number",
          "incident.status",
          "incident.html_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "acknowledge_incident",
      "description_for_ai": "Acknowledge a PagerDuty incident to stop escalations.",
      "intent": [
        "acknowledge pagerduty",
        "ack incident",
        "accept alert",
        "принять инцидент pagerduty"
      ],
      "endpoint": "PUT https://api.pagerduty.com/incidents/{id}",
      "input": {
        "id": {
          "type": "string",
          "required": true
        },
        "from": {
          "type": "string",
          "description": "Email of acknowledging user",
          "required": true
        },
        "incident": {
          "type": "object",
          "description": "{type: 'incident', status: 'acknowledged'}",
          "required": true
        }
      },
      "output": {
        "type": "incident",
        "fields": [
          "incident.id",
          "incident.status",
          "incident.acknowledgements[0].acknowledger.email"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_on_call",
      "description_for_ai": "Get who is currently on call for each PagerDuty schedule.",
      "intent": [
        "who is on call",
        "on-call schedule",
        "pagerduty on call",
        "кто дежурит pagerduty"
      ],
      "endpoint": "GET https://api.pagerduty.com/oncalls",
      "input": {
        "schedule_ids[]": {
          "type": "array",
          "description": "Filter by schedule IDs",
          "required": false
        },
        "since": {
          "type": "string",
          "description": "ISO 8601 start",
          "required": false
        },
        "until": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<oncall>",
        "fields": [
          "oncalls[0].user.summary",
          "oncalls[0].user.email",
          "oncalls[0].schedule.summary",
          "oncalls[0].escalation_level",
          "oncalls[0].start",
          "oncalls[0].end"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}