{
  "apia": "1.0",
  "service": {
    "id": "pagerduty",
    "name": "PagerDuty API",
    "description_for_ai": "Incident management and on-call scheduling platform. Create incidents, manage on-call rotations, send alerts. Used by 25K+ companies. Use for DevOps incident alerting, on-call management, incident response.",
    "url": "https://pagerduty.com",
    "api_base": "https://api.pagerduty.com",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.pagerduty.com/api-reference/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Token token={api_key}",
    "how_to_get": "Account Settings → API Access",
    "cost": "Free: 14-day trial. Professional: $21/user/month"
  },
  "capabilities": [
    {
      "id": "list_incidents",
      "description_for_ai": "List PagerDuty incidents. Filter by status, service, or urgency.",
      "intent": [
        "PagerDuty incidents",
        "on-call alerts",
        "incident list",
        "инциденты PagerDuty"
      ],
      "endpoint": "GET https://api.pagerduty.com/incidents",
      "input": {
        "statuses[]": {
          "type": "array",
          "description": "triggered, acknowledged, resolved",
          "required": false
        },
        "service_ids[]": {
          "type": "array",
          "description": "Filter by service ID",
          "required": false
        },
        "urgencies[]": {
          "type": "array",
          "description": "high or low",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 25
        }
      },
      "output": {
        "type": "list<incident>",
        "fields": [
          "incidents[0].id",
          "incidents[0].title",
          "incidents[0].status",
          "incidents[0].urgency",
          "incidents[0].service.summary",
          "incidents[0].created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_incident",
      "description_for_ai": "Create a new PagerDuty incident to alert on-call responders.",
      "intent": [
        "create incident PagerDuty",
        "trigger alert",
        "page on-call",
        "создать инцидент PagerDuty"
      ],
      "endpoint": "POST https://api.pagerduty.com/incidents",
      "input": {
        "title": {
          "type": "string",
          "required": true
        },
        "service_id": {
          "type": "string",
          "required": true
        },
        "urgency": {
          "type": "string",
          "description": "high or low",
          "default": "high"
        },
        "body": {
          "type": "object",
          "description": "{type: 'incident_body', details: 'Incident description'}",
          "required": false
        },
        "escalation_policy_id": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "incident",
        "fields": [
          "incident.id",
          "incident.title",
          "incident.status",
          "incident.html_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "acknowledge_incident",
      "description_for_ai": "Acknowledge a PagerDuty incident to indicate you are working on it.",
      "intent": [
        "acknowledge PagerDuty",
        "ack incident",
        "working on incident",
        "взять инцидент PagerDuty"
      ],
      "endpoint": "PUT https://api.pagerduty.com/incidents/{id}",
      "input": {
        "id": {
          "type": "string",
          "required": true
        },
        "status": {
          "type": "string",
          "default": "acknowledged"
        }
      },
      "output": {
        "type": "incident",
        "fields": [
          "incident.id",
          "incident.status",
          "incident.acknowledgements"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "resolve_incident",
      "description_for_ai": "Resolve a PagerDuty incident.",
      "intent": [
        "resolve PagerDuty",
        "close incident",
        "resolve alert",
        "закрыть инцидент PagerDuty"
      ],
      "endpoint": "PUT https://api.pagerduty.com/incidents/{id}",
      "input": {
        "id": {
          "type": "string",
          "required": true
        },
        "status": {
          "type": "string",
          "default": "resolved"
        }
      },
      "output": {
        "type": "incident",
        "fields": [
          "incident.id",
          "incident.status",
          "incident.resolved_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_on_call",
      "description_for_ai": "Get who is currently on-call for each schedule.",
      "intent": [
        "who is on-call",
        "on-call schedule",
        "duty schedule",
        "дежурный PagerDuty"
      ],
      "endpoint": "GET https://api.pagerduty.com/oncalls",
      "input": {
        "schedule_ids[]": {
          "type": "array",
          "required": false
        },
        "escalation_policy_ids[]": {
          "type": "array",
          "required": false
        }
      },
      "output": {
        "type": "list<oncall>",
        "fields": [
          "oncalls[0].user.summary",
          "oncalls[0].schedule.summary",
          "oncalls[0].start",
          "oncalls[0].end"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_services",
      "description_for_ai": "List PagerDuty services to get service IDs for incidents.",
      "intent": [
        "PagerDuty services",
        "list services",
        "service IDs",
        "сервисы PagerDuty"
      ],
      "endpoint": "GET https://api.pagerduty.com/services",
      "input": {
        "query": {
          "type": "string",
          "description": "Search by service name",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 25
        }
      },
      "output": {
        "type": "list<service>",
        "fields": [
          "services[0].id",
          "services[0].name",
          "services[0].status",
          "services[0].escalation_policy.summary"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}