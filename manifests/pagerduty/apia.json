{
  "apia": "1.0",
  "service": {
    "id": "pagerduty",
    "name": "PagerDuty API",
    "description_for_ai": "Incident management and on-call scheduling platform. Create incidents, manage on-call rotations, send alerts. Used by 25K+ companies. Use for DevOps incident alerting, on-call management, incident response.",
    "url": "https://pagerduty.com",
    "api_base": "https://api.pagerduty.com",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.pagerduty.com/api-reference/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Token token={api_key}",
    "how_to_get": "Account Settings → API Access",
    "cost": "Free: 14-day trial. Professional: $21/user/month"
  },
  "capabilities": [
    {
      "id": "list_incidents",
      "description_for_ai": "List PagerDuty incidents with urgency, status, and service filters.",
      "intent": [
        "pagerduty incidents",
        "on-call incidents",
        "alerts pagerduty",
        "инциденты pagerduty"
      ],
      "endpoint": "GET https://api.pagerduty.com/incidents",
      "input": {
        "statuses[]": {
          "type": "array",
          "description": "triggered, acknowledged, resolved",
          "required": false
        },
        "urgencies[]": {
          "type": "array",
          "description": "high, low",
          "required": false
        },
        "service_ids[]": {
          "type": "array",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 25
        },
        "offset": {
          "type": "integer",
          "default": 0
        }
      },
      "output": {
        "type": "list<incident>",
        "fields": [
          "incidents[0].id",
          "incidents[0].title",
          "incidents[0].status",
          "incidents[0].urgency",
          "incidents[0].service.summary",
          "incidents[0].created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_incident",
      "description_for_ai": "Manually create a PagerDuty incident to alert on-call responders.",
      "intent": [
        "create pagerduty incident",
        "trigger alert",
        "page on-call",
        "создать инцидент pagerduty"
      ],
      "endpoint": "POST https://api.pagerduty.com/incidents",
      "input": {
        "incident": {
          "type": "object",
          "description": "{type: 'incident', title: 'Database down', service: {id: 'SERVICE_ID', type: 'service_reference'}, urgency: 'high', body: {type: 'incident_body', details: 'Details here'}}",
          "required": true
        }
      },
      "output": {
        "type": "incident",
        "fields": [
          "incident.id",
          "incident.status",
          "incident.urgency",
          "incident.html_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "acknowledge_incident",
      "description_for_ai": "Acknowledge a PagerDuty incident to stop notifications while you investigate.",
      "intent": [
        "acknowledge pagerduty",
        "accept incident",
        "ACK alert",
        "принять инцидент pagerduty"
      ],
      "endpoint": "PUT https://api.pagerduty.com/incidents",
      "input": {
        "incidents": {
          "type": "array",
          "description": "[{id: 'INCIDENT_ID', type: 'incident_reference', status: 'acknowledged'}]",
          "required": true
        }
      },
      "output": {
        "type": "incidents",
        "fields": [
          "incidents[0].id",
          "incidents[0].status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_on_call",
      "description_for_ai": "Get who is currently on-call for a schedule or service.",
      "intent": [
        "who is on call",
        "pagerduty on-call",
        "on-call schedule",
        "кто дежурит pagerduty"
      ],
      "endpoint": "GET https://api.pagerduty.com/oncalls",
      "input": {
        "schedule_ids[]": {
          "type": "array",
          "description": "Filter by schedule IDs",
          "required": false
        },
        "user_ids[]": {
          "type": "array",
          "description": "Filter by user IDs",
          "required": false
        },
        "earliest": {
          "type": "boolean",
          "description": "Only return earliest on-call per schedule",
          "default": true
        }
      },
      "output": {
        "type": "list<oncall>",
        "fields": [
          "oncalls[0].user.summary",
          "oncalls[0].schedule.summary",
          "oncalls[0].start",
          "oncalls[0].end"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}