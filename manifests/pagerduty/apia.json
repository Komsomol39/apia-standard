{
  "apia": "1.0",
  "service": {
    "id": "pagerduty",
    "name": "PagerDuty API",
    "description_for_ai": "Incident management and on-call scheduling platform. Create incidents, manage on-call rotations, send alerts. Used by 25K+ companies. Use for DevOps incident alerting, on-call management, incident response.",
    "url": "https://pagerduty.com",
    "api_base": "https://api.pagerduty.com",
    "category": "developer_monitoring",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.pagerduty.com/api-reference/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Token token={api_key}",
    "how_to_get": "Account Settings → API Access",
    "cost": "Free: 14-day trial. Professional: $21/user/month"
  },
  "capabilities": [
    {
      "id": "create_incident",
      "description_for_ai": "Create an incident alert in PagerDuty. Notifies on-call engineer immediately.",
      "intent": [
        "create alert",
        "incident alert",
        "page on-call",
        "notify engineer",
        "production incident",
        "escalate alert"
      ],
      "endpoint": "POST https://api.pagerduty.com/incidents",
      "input": {
        "incident": {
          "type": "object",
          "description": "{type: incident, title: string, service: {id, type: service_reference}, urgency: high|low, body: {type: incident_body, details: string}}",
          "required": true
        }
      },
      "output": {
        "type": "incident",
        "fields": [
          "id",
          "incident_number",
          "title",
          "status",
          "urgency",
          "html_url",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_incidents",
      "description_for_ai": "Get current open incidents. Filter by status, urgency, service.",
      "intent": [
        "open incidents",
        "current alerts",
        "production issues",
        "ongoing incidents"
      ],
      "endpoint": "GET https://api.pagerduty.com/incidents",
      "input": {
        "statuses": {
          "type": "array",
          "description": "[triggered, acknowledged, resolved]",
          "default": [
            "triggered",
            "acknowledged"
          ]
        },
        "urgencies": {
          "type": "array",
          "description": "[high, low]",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 25,
          "description": "Maximum number of results to return"
        }
      },
      "output": {
        "type": "list<incident>",
        "fields": [
          "id",
          "incident_number",
          "title",
          "status",
          "urgency",
          "created_at",
          "html_url",
          "service.summary"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}