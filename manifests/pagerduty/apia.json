{
  "apia": "1.0",
  "service": {
    "id": "pagerduty",
    "name": "PagerDuty API",
    "description_for_ai": "Incident management and on-call scheduling platform. Create incidents, manage on-call rotations, send alerts. Used by 25K+ companies. Use for DevOps incident alerting, on-call management, incident response.",
    "url": "https://pagerduty.com",
    "api_base": "https://api.pagerduty.com",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.pagerduty.com/api-reference/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Token token={api_key}",
    "how_to_get": "Account Settings → API Access",
    "cost": "Free: 14-day trial. Professional: $21/user/month"
  },
  "capabilities": [
    {
      "id": "create_incident",
      "description_for_ai": "Create a PagerDuty incident that immediately notifies the on-call engineer. Use for production issues requiring human intervention.",
      "intent": [
        "create alert",
        "incident alert",
        "page on-call",
        "notify engineer",
        "production incident",
        "escalate alert"
      ],
      "endpoint": "POST https://api.pagerduty.com/incidents",
      "input": {
        "incident": {
          "type": "object",
          "description": "{type: 'incident', title: 'Database connection pool exhausted', urgency: 'high', service: {id: 'SERVICE_ID', type: 'service_reference'}, body: {type: 'incident_body', details: 'Detailed description of the incident, steps taken, impact'}, escalation_policy: {id: 'POLICY_ID', type: 'escalation_policy_reference'}}",
          "required": true
        }
      },
      "output": {
        "type": "incident",
        "fields": [
          "incident.id",
          "incident.incident_number",
          "incident.title",
          "incident.status",
          "incident.urgency",
          "incident.html_url",
          "incident.created_at",
          "incident.service.summary"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_incidents",
      "description_for_ai": "Get current open incidents. Filter by status, urgency, or service. Use for incident dashboards and status monitoring.",
      "intent": [
        "open incidents",
        "current alerts",
        "production issues",
        "ongoing incidents"
      ],
      "endpoint": "GET https://api.pagerduty.com/incidents",
      "input": {
        "statuses": {
          "type": "array",
          "description": "Status filter: ['triggered'] (new), ['acknowledged'] (being worked on), ['resolved'], or combine: ['triggered','acknowledged']",
          "default": [
            "triggered",
            "acknowledged"
          ]
        },
        "urgencies": {
          "type": "array",
          "description": "Urgency filter: ['high'] or ['low'] or both",
          "required": false
        },
        "service_ids": {
          "type": "array",
          "description": "Filter by service IDs",
          "required": false
        },
        "team_ids": {
          "type": "array",
          "description": "Filter by team IDs",
          "required": false
        },
        "since": {
          "type": "string",
          "description": "ISO 8601 — return incidents created after this time",
          "required": false
        },
        "limit": {
          "type": "integer",
          "description": "Max incidents to return, max 100",
          "default": 25
        }
      },
      "output": {
        "type": "list<incident>",
        "fields": [
          "incidents[0].id",
          "incidents[0].incident_number",
          "incidents[0].title",
          "incidents[0].status",
          "incidents[0].urgency",
          "incidents[0].created_at",
          "incidents[0].html_url",
          "incidents[0].service.summary",
          "incidents[0].assignments[0].assignee.summary"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}