{
  "apia": "1.0",
  "service": {
    "id": "auth0",
    "name": "Auth0 Management API",
    "description_for_ai": "Identity platform for authentication and authorization. User management, social login, MFA, SSO, machine-to-machine auth. 7500 MAU free. Industry standard for auth in web/mobile apps.",
    "url": "https://auth0.com",
    "api_base": "https://{tenant}.auth0.com/api/v2",
    "category": "security",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://auth0.com/docs/api/management/v2"
  },
  "auth": {
    "type": "oauth2_client_credentials",
    "anonymous_access": false,
    "how_to_get": "Create account at https://auth0.com — 7500 MAU free",
    "cost": "Free: 7500 MAU. Growth: $23/month"
  },
  "capabilities": [
    {
      "id": "get_users",
      "description_for_ai": "Search and list Auth0 users with filters.",
      "intent": [
        "auth0 users",
        "list users",
        "user management",
        "пользователи auth0"
      ],
      "endpoint": "GET https://{tenant}.auth0.com/api/v2/users",
      "input": {
        "q": {
          "type": "string",
          "description": "Lucene query: email:john@* OR user_metadata.plan:pro",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 50
        },
        "page": {
          "type": "integer",
          "default": 0
        },
        "sort": {
          "type": "string",
          "description": "field:order e.g. created_at:-1",
          "required": false
        },
        "include_totals": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "list<user>",
        "fields": [
          "[0].user_id",
          "[0].email",
          "[0].name",
          "[0].created_at",
          "[0].last_login",
          "[0].login_count"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_user",
      "description_for_ai": "Create a new Auth0 user with email, password, and metadata.",
      "intent": [
        "create user auth0",
        "register user",
        "new auth0 account",
        "создать пользователя auth0"
      ],
      "endpoint": "POST https://{tenant}.auth0.com/api/v2/users",
      "input": {
        "connection": {
          "type": "string",
          "description": "Connection name e.g. Username-Password-Authentication",
          "required": true
        },
        "email": {
          "type": "string",
          "required": true
        },
        "password": {
          "type": "string",
          "required": false
        },
        "name": {
          "type": "string",
          "required": false
        },
        "app_metadata": {
          "type": "object",
          "description": "App-specific data: {plan: 'pro', role: 'admin'}",
          "required": false
        },
        "user_metadata": {
          "type": "object",
          "description": "User preferences: {theme: 'dark', language: 'en'}",
          "required": false
        },
        "email_verified": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "user",
        "fields": [
          "user_id",
          "email",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_user",
      "description_for_ai": "Update Auth0 user metadata, roles, or blocked status.",
      "intent": [
        "update user auth0",
        "block user",
        "change role auth0",
        "обновить пользователя auth0"
      ],
      "endpoint": "PATCH https://{tenant}.auth0.com/api/v2/users/{id}",
      "input": {
        "id": {
          "type": "string",
          "description": "Auth0 user ID (auth0|xxxxx)",
          "required": true
        },
        "name": {
          "type": "string",
          "required": false
        },
        "app_metadata": {
          "type": "object",
          "required": false
        },
        "user_metadata": {
          "type": "object",
          "required": false
        },
        "blocked": {
          "type": "boolean",
          "description": "Block user from logging in",
          "required": false
        },
        "email_verified": {
          "type": "boolean",
          "required": false
        }
      },
      "output": {
        "type": "user",
        "fields": [
          "user_id",
          "email",
          "updated_at",
          "blocked"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_token",
      "description_for_ai": "Get a Management API access token using client credentials flow.",
      "intent": [
        "auth0 access token",
        "management API token",
        "client credentials",
        "токен auth0"
      ],
      "endpoint": "POST https://{tenant}.auth0.com/oauth/token",
      "input": {
        "grant_type": {
          "type": "string",
          "default": "client_credentials"
        },
        "client_id": {
          "type": "string",
          "required": true
        },
        "client_secret": {
          "type": "string",
          "required": true
        },
        "audience": {
          "type": "string",
          "description": "https://{tenant}.auth0.com/api/v2/",
          "required": true
        }
      },
      "output": {
        "type": "token",
        "fields": [
          "access_token",
          "expires_in",
          "token_type"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "tenant": "Replace {tenant} with your Auth0 tenant domain e.g. myapp.auth0.com or myapp.eu.auth0.com",
    "m2m_token": "Get Management API token: Machine-to-Machine app → authorize with https://{tenant}/api/v2/ audience.",
    "token_expiry": "Management API tokens expire in 24 hours. Cache and refresh automatically.",
    "connections": "Username-Password-Authentication is default DB connection. Social logins have their own connection names."
  }
}