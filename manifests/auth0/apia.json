{
  "apia": "1.0",
  "service": {
    "id": "auth0",
    "name": "Auth0 Management API",
    "description_for_ai": "Identity platform for authentication and authorization. User management, social login, MFA, SSO, machine-to-machine auth. 7500 MAU free. Industry standard for auth in web/mobile apps.",
    "url": "https://auth0.com",
    "api_base": "https://{tenant}.auth0.com/api/v2",
    "category": "security",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://auth0.com/docs/api/management/v2"
  },
  "auth": {
    "type": "oauth2_client_credentials",
    "anonymous_access": false,
    "how_to_get": "Create account at https://auth0.com — 7500 MAU free",
    "cost": "Free: 7500 MAU. Growth: $23/month"
  },
  "capabilities": [
    {
      "id": "get_users",
      "description_for_ai": "List or search users in Auth0 by email, name, or query.",
      "intent": [
        "auth0 users",
        "list users auth0",
        "find user auth0",
        "пользователи auth0"
      ],
      "endpoint": "GET https://{domain}.auth0.com/api/v2/users",
      "input": {
        "q": {
          "type": "string",
          "description": "Lucene query: email:user@example.com, name:*john*, logins_count:[100 TO *]",
          "required": false
        },
        "search_engine": {
          "type": "string",
          "default": "v3"
        },
        "page": {
          "type": "integer",
          "default": 0
        },
        "per_page": {
          "type": "integer",
          "default": 50
        },
        "include_totals": {
          "type": "boolean",
          "default": true
        },
        "fields": {
          "type": "string",
          "description": "Comma-separated: user_id,email,name,app_metadata",
          "required": false
        }
      },
      "output": {
        "type": "list<user>",
        "fields": [
          "users[0].user_id",
          "users[0].email",
          "users[0].name",
          "users[0].last_login",
          "users[0].logins_count",
          "total"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_user",
      "description_for_ai": "Create a new user in Auth0 with email, password, and metadata.",
      "intent": [
        "create user auth0",
        "register user",
        "add user auth0",
        "создать пользователя auth0"
      ],
      "endpoint": "POST https://{domain}.auth0.com/api/v2/users",
      "input": {
        "connection": {
          "type": "string",
          "description": "Connection name e.g. Username-Password-Authentication",
          "required": true
        },
        "email": {
          "type": "string",
          "required": true
        },
        "password": {
          "type": "string",
          "description": "Must meet connection's password policy",
          "required": true
        },
        "name": {
          "type": "string",
          "required": false
        },
        "app_metadata": {
          "type": "object",
          "description": "Role/permission data: {role: 'admin', tenant: 'acme'}",
          "required": false
        },
        "user_metadata": {
          "type": "object",
          "description": "Non-sensitive user preferences",
          "required": false
        },
        "email_verified": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "user",
        "fields": [
          "user_id",
          "email",
          "created_at",
          "identities[0].connection"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_user",
      "description_for_ai": "Update user profile, metadata, or block/unblock a user.",
      "intent": [
        "update user auth0",
        "block user",
        "update role auth0",
        "обновить пользователя auth0"
      ],
      "endpoint": "PATCH https://{domain}.auth0.com/api/v2/users/{user_id}",
      "input": {
        "user_id": {
          "type": "string",
          "required": true
        },
        "name": {
          "type": "string",
          "required": false
        },
        "app_metadata": {
          "type": "object",
          "required": false
        },
        "user_metadata": {
          "type": "object",
          "required": false
        },
        "blocked": {
          "type": "boolean",
          "description": "Block/unblock user login",
          "required": false
        },
        "email_verified": {
          "type": "boolean",
          "required": false
        }
      },
      "output": {
        "type": "user",
        "fields": [
          "user_id",
          "email",
          "blocked",
          "updated_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_token",
      "description_for_ai": "Get Management API access token using client credentials. Required before calling other Auth0 API endpoints.",
      "intent": [
        "auth0 token",
        "management api token",
        "auth0 access token",
        "токен auth0"
      ],
      "endpoint": "POST https://{domain}.auth0.com/oauth/token",
      "input": {
        "client_id": {
          "type": "string",
          "required": true
        },
        "client_secret": {
          "type": "string",
          "required": true
        },
        "audience": {
          "type": "string",
          "description": "https://{domain}.auth0.com/api/v2/",
          "required": true
        },
        "grant_type": {
          "type": "string",
          "default": "client_credentials"
        }
      },
      "output": {
        "type": "token",
        "fields": [
          "access_token",
          "token_type",
          "expires_in"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "assign_roles",
      "description_for_ai": "Assign or remove roles from an Auth0 user for RBAC (role-based access control).",
      "intent": [
        "assign role auth0",
        "user permissions",
        "RBAC auth0",
        "роли пользователя auth0"
      ],
      "endpoint": "POST https://{domain}.auth0.com/api/v2/users/{user_id}/roles",
      "input": {
        "user_id": {
          "type": "string",
          "required": true
        },
        "roles": {
          "type": "array",
          "description": "Array of role IDs to assign",
          "required": true
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "204 No Content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "tenant": "Replace {tenant} with your Auth0 tenant domain e.g. myapp.auth0.com or myapp.eu.auth0.com",
    "m2m_token": "Get Management API token: Machine-to-Machine app → authorize with https://{tenant}/api/v2/ audience.",
    "token_expiry": "Management API tokens expire in 24 hours. Cache and refresh automatically.",
    "connections": "Username-Password-Authentication is default DB connection. Social logins have their own connection names."
  }
}