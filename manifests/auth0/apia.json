{
  "apia": "1.0",
  "service": {
    "id": "auth0",
    "name": "Auth0 Management API",
    "description_for_ai": "Identity platform for authentication and authorization. User management, social login, MFA, SSO, machine-to-machine auth. 7500 MAU free. Industry standard for auth in web/mobile apps.",
    "url": "https://auth0.com",
    "api_base": "https://{tenant}.auth0.com/api/v2",
    "category": "security",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://auth0.com/docs/api/management/v2"
  },
  "auth": {
    "type": "oauth2_client_credentials",
    "anonymous_access": false,
    "how_to_get": "Create account at https://auth0.com — 7500 MAU free",
    "cost": "Free: 7500 MAU. Growth: $23/month"
  },
  "capabilities": [
    {
      "id": "get_users",
      "description_for_ai": "Get users from Auth0 tenant with profile, login stats, and custom metadata. Filter by email, connection, or custom query.",
      "intent": [
        "get users",
        "user list",
        "auth users",
        "registered users",
        "user management"
      ],
      "endpoint": "GET https://{tenant}.auth0.com/api/v2/users",
      "input": {
        "page": {
          "type": "integer",
          "description": "Page number (0-indexed)",
          "default": 0
        },
        "per_page": {
          "type": "integer",
          "description": "Results per page, max 100",
          "default": 50
        },
        "q": {
          "type": "string",
          "description": "Lucene query syntax: 'email:user@example.com', 'logins_count:[5 TO *]', 'app_metadata.role:admin'",
          "required": false
        },
        "fields": {
          "type": "string",
          "description": "Comma-separated fields to return: user_id,email,name,last_login,logins_count,app_metadata,user_metadata",
          "required": false
        },
        "sort": {
          "type": "string",
          "description": "Sort by field:order e.g. 'last_login:-1' (newest first), 'email:1' (A-Z)",
          "required": false
        }
      },
      "output": {
        "type": "list<user>",
        "fields": [
          "user_id",
          "email",
          "name",
          "picture",
          "last_login",
          "logins_count",
          "created_at",
          "user_metadata (custom user data)",
          "app_metadata (roles, permissions)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_user",
      "description_for_ai": "Create a new user in Auth0 database connection. Set email, password, and custom metadata.",
      "intent": [
        "create user",
        "register user",
        "add user",
        "new account"
      ],
      "endpoint": "POST https://{tenant}.auth0.com/api/v2/users",
      "input": {
        "connection": {
          "type": "string",
          "description": "Database connection name: 'Username-Password-Authentication' (default), or custom connection name",
          "required": true
        },
        "email": {
          "type": "string",
          "description": "User's email address (must be unique)",
          "required": true
        },
        "password": {
          "type": "string",
          "description": "Password — must meet connection's password policy (min length, complexity)",
          "required": true
        },
        "email_verified": {
          "type": "boolean",
          "description": "Skip email verification if true",
          "default": false
        },
        "name": {
          "type": "string",
          "description": "User's display name",
          "required": false
        },
        "user_metadata": {
          "type": "object",
          "description": "Custom data editable by user: {preferences: {theme: 'dark'}, onboarding: {step: 1}}",
          "required": false
        },
        "app_metadata": {
          "type": "object",
          "description": "App-managed data (not user-editable): {roles: ['admin'], plan: 'pro', tenant_id: 'abc123'}",
          "required": false
        }
      },
      "output": {
        "type": "user",
        "fields": [
          "user_id (format: 'auth0|123456')",
          "email",
          "name",
          "created_at",
          "identities"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "tenant": "Replace {tenant} with your Auth0 tenant domain e.g. myapp.auth0.com or myapp.eu.auth0.com",
    "m2m_token": "Get Management API token: Machine-to-Machine app → authorize with https://{tenant}/api/v2/ audience.",
    "token_expiry": "Management API tokens expire in 24 hours. Cache and refresh automatically.",
    "connections": "Username-Password-Authentication is default DB connection. Social logins have their own connection names."
  }
}