{
  "apia": "1.0",
  "service": {
    "id": "auth0",
    "name": "Auth0 Management API",
    "description_for_ai": "Identity platform for authentication and authorization. User management, social login, MFA, SSO, machine-to-machine auth. 7500 MAU free. Industry standard for auth in web/mobile apps.",
    "url": "https://auth0.com",
    "api_base": "https://{tenant}.auth0.com/api/v2",
    "category": "security",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://auth0.com/docs/api/management/v2"
  },
  "auth": {
    "type": "oauth2_client_credentials",
    "anonymous_access": false,
    "how_to_get": "Create account at https://auth0.com — 7500 MAU free",
    "cost": "Free: 7500 MAU. Growth: $23/month"
  },
  "capabilities": [
    {
      "id": "get_users",
      "description_for_ai": "List users from Auth0 with filtering, sorting, and search.",
      "intent": [
        "Auth0 users",
        "list users",
        "user management Auth0",
        "пользователи Auth0"
      ],
      "endpoint": "GET https://{domain}/api/v2/users",
      "input": {
        "q": {
          "type": "string",
          "description": "Lucene query: email:*@gmail.com or name:John",
          "required": false
        },
        "sort": {
          "type": "string",
          "description": "Field:order e.g. created_at:1 (asc) or created_at:-1 (desc)",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 50
        }
      },
      "output": {
        "type": "list<user>",
        "fields": [
          "[0].user_id",
          "[0].email",
          "[0].name",
          "[0].created_at",
          "[0].last_login",
          "[0].app_metadata"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_user",
      "description_for_ai": "Create a new user in Auth0.",
      "intent": [
        "create user Auth0",
        "register user",
        "add user Auth0",
        "создать пользователя Auth0"
      ],
      "endpoint": "POST https://{domain}/api/v2/users",
      "input": {
        "connection": {
          "type": "string",
          "description": "Connection name: Username-Password-Authentication, email, sms",
          "required": true
        },
        "email": {
          "type": "string",
          "required": false
        },
        "password": {
          "type": "string",
          "required": false
        },
        "given_name": {
          "type": "string",
          "required": false
        },
        "family_name": {
          "type": "string",
          "required": false
        },
        "app_metadata": {
          "type": "object",
          "description": "Application-specific metadata",
          "required": false
        },
        "user_metadata": {
          "type": "object",
          "required": false
        }
      },
      "output": {
        "type": "user",
        "fields": [
          "user_id",
          "email",
          "created_at",
          "app_metadata"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_user",
      "description_for_ai": "Update user attributes: name, email, password, metadata, blocked status.",
      "intent": [
        "update user Auth0",
        "block user",
        "change password Auth0",
        "обновить пользователя Auth0"
      ],
      "endpoint": "PATCH https://{domain}/api/v2/users/{id}",
      "input": {
        "id": {
          "type": "string",
          "description": "User ID: auth0|xxx",
          "required": true
        },
        "blocked": {
          "type": "boolean",
          "description": "Block/unblock user",
          "required": false
        },
        "email": {
          "type": "string",
          "required": false
        },
        "name": {
          "type": "string",
          "required": false
        },
        "app_metadata": {
          "type": "object",
          "required": false
        }
      },
      "output": {
        "type": "user",
        "fields": [
          "user_id",
          "email",
          "blocked",
          "updated_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_tokens",
      "description_for_ai": "Exchange credentials for Auth0 access tokens (client credentials flow).",
      "intent": [
        "Auth0 token",
        "access token",
        "OAuth token",
        "токен Auth0"
      ],
      "endpoint": "POST https://{domain}/oauth/token",
      "input": {
        "client_id": {
          "type": "string",
          "required": true
        },
        "client_secret": {
          "type": "string",
          "required": true
        },
        "audience": {
          "type": "string",
          "description": "API identifier",
          "required": true
        },
        "grant_type": {
          "type": "string",
          "description": "client_credentials or authorization_code or refresh_token",
          "required": true
        },
        "code": {
          "type": "string",
          "description": "Auth code for authorization_code flow",
          "required": false
        }
      },
      "output": {
        "type": "token",
        "fields": [
          "access_token",
          "token_type",
          "expires_in",
          "scope"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_roles",
      "description_for_ai": "Get all roles defined in Auth0 for RBAC.",
      "intent": [
        "Auth0 roles",
        "RBAC",
        "user roles",
        "роли Auth0"
      ],
      "endpoint": "GET https://{domain}/api/v2/roles",
      "input": {
        "name_filter": {
          "type": "string",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 50
        }
      },
      "output": {
        "type": "list<role>",
        "fields": [
          "[0].id",
          "[0].name",
          "[0].description"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "assign_roles",
      "description_for_ai": "Assign RBAC roles to a user.",
      "intent": [
        "assign role Auth0",
        "user permissions",
        "role assignment",
        "назначить роль Auth0"
      ],
      "endpoint": "POST https://{domain}/api/v2/users/{id}/roles",
      "input": {
        "id": {
          "type": "string",
          "description": "User ID",
          "required": true
        },
        "roles": {
          "type": "array",
          "description": "Role IDs to assign",
          "required": true
        }
      },
      "output": {
        "type": "status",
        "fields": [
          "204 No Content on success"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "tenant": "Replace {tenant} with your Auth0 tenant domain e.g. myapp.auth0.com or myapp.eu.auth0.com",
    "m2m_token": "Get Management API token: Machine-to-Machine app → authorize with https://{tenant}/api/v2/ audience.",
    "token_expiry": "Management API tokens expire in 24 hours. Cache and refresh automatically.",
    "connections": "Username-Password-Authentication is default DB connection. Social logins have their own connection names."
  }
}