{
  "apia": "1.0",
  "service": {
    "id": "auth0",
    "name": "Auth0 Management API",
    "description_for_ai": "Identity platform for authentication and authorization. User management, social login, MFA, SSO, machine-to-machine auth. 7500 MAU free. Industry standard for auth in web/mobile apps.",
    "url": "https://auth0.com",
    "api_base": "https://{tenant}.auth0.com/api/v2",
    "category": "security_identity",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://auth0.com/docs/api/management/v2"
  },
  "auth": {
    "type": "oauth2_client_credentials",
    "anonymous_access": false,
    "how_to_get": "Create account at https://auth0.com — 7500 MAU free",
    "cost": "Free: 7500 MAU. Growth: $23/month"
  },
  "capabilities": [
    {
      "id": "get_users",
      "description_for_ai": "Get users from Auth0 tenant with profile info, login history, metadata.",
      "intent": [
        "get users",
        "user list",
        "auth users",
        "registered users",
        "user management"
      ],
      "endpoint": "GET https://{tenant}.auth0.com/api/v2/users",
      "input": {
        "page": {
          "type": "integer",
          "default": 0
        },
        "per_page": {
          "type": "integer",
          "default": 50,
          "max": 100
        },
        "q": {
          "type": "string",
          "description": "Lucene query e.g. email:user@example.com",
          "required": false
        },
        "fields": {
          "type": "string",
          "description": "Comma-separated fields to return",
          "required": false
        }
      },
      "output": {
        "type": "list<user>",
        "fields": [
          "user_id",
          "email",
          "name",
          "picture",
          "last_login",
          "logins_count",
          "user_metadata",
          "app_metadata"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_user",
      "description_for_ai": "Create new user in Auth0. Set password, email, metadata.",
      "intent": [
        "create user",
        "register user",
        "add user",
        "new account"
      ],
      "endpoint": "POST https://{tenant}.auth0.com/api/v2/users",
      "input": {
        "connection": {
          "type": "string",
          "description": "Connection name e.g. Username-Password-Authentication",
          "required": true
        },
        "email": {
          "type": "string",
          "required": true
        },
        "password": {
          "type": "string",
          "required": true
        },
        "user_metadata": {
          "type": "object",
          "required": false
        }
      },
      "output": {
        "type": "user",
        "fields": [
          "user_id",
          "email",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "tenant": "Replace {tenant} with your Auth0 tenant domain e.g. myapp.auth0.com or myapp.eu.auth0.com",
    "m2m_token": "Get Management API token: Machine-to-Machine app → authorize with https://{tenant}/api/v2/ audience.",
    "token_expiry": "Management API tokens expire in 24 hours. Cache and refresh automatically.",
    "connections": "Username-Password-Authentication is default DB connection. Social logins have their own connection names."
  }
}