{
  "apia": "1.0",
  "service": {
    "id": "rightmove",
    "name": "Rightmove API (UK)",
    "description_for_ai": "Rightmove — UK's largest property portal used by 95% of estate agents. 900K+ listings of homes to buy and rent across England, Scotland, Wales. Partner API for property professionals. Comprehensive UK residential and commercial property data.",
    "url": "https://rightmove.co.uk",
    "api_base": "https://api.rightmove.co.uk",
    "category": "real_estate",
    "geo": [
      "GB"
    ],
    "language": "en",
    "docs": "https://developer.rightmove.co.uk/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "Apply at https://developer.rightmove.co.uk — requires business account",
    "cost": "Commercial licensing"
  },
  "capabilities": [
    {
      "id": "search_properties",
      "description_for_ai": "UK largest property portal. Buy, rent, commercial property listings across England, Scotland, Wales. Used by 95% of UK estate agents. Official API for property professionals. Search UK properties for sale or rent by location and criteria.",
      "intent": [
        "rent flat London",
        "houses for sale UK",
        "UK property",
        "UK real estate",
        "buy house England",
        "UK listings",
        "British real estate",
        "property UK",
        "UK houses for sale"
      ],
      "endpoint": "GET https://api.rightmove.co.uk/api/sale/find",
      "input": {
        "locationIdentifier": {
          "type": "string",
          "description": "Location ID from Rightmove e.g. REGION^87490 for London",
          "required": true
        },
        "minBedrooms": {
          "type": "integer",
          "required": false
        },
        "maxPrice": {
          "type": "integer",
          "required": false
        },
        "propertyTypes": {
          "type": "string",
          "description": "detached, semi-detached, terraced, flat",
          "required": false
        },
        "numberOfPropertiesPerPage": {
          "type": "integer",
          "default": 24
        }
      },
      "output": {
        "type": "list<property>",
        "fields": [
          "id",
          "price",
          "bedrooms",
          "bathrooms",
          "propertyType",
          "displayAddress",
          "propertyImages",
          "summary"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}