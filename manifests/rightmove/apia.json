{
  "apia": "1.0",
  "service": {
    "id": "rightmove",
    "name": "Rightmove API (UK)",
    "description_for_ai": "Rightmove — UK's largest property portal used by 95% of estate agents. 900K+ listings of homes to buy and rent across England, Scotland, Wales. Partner API for property professionals. Comprehensive UK residential and commercial property data.",
    "url": "https://rightmove.co.uk",
    "api_base": "https://api.rightmove.co.uk",
    "category": "real_estate",
    "geo": [
      "GB"
    ],
    "language": "en",
    "docs": "https://developer.rightmove.co.uk/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "Apply at https://developer.rightmove.co.uk — requires business account",
    "cost": "Commercial licensing"
  },
  "capabilities": [
    {
      "id": "search_properties",
      "description_for_ai": "Search UK properties for sale or rent on Rightmove.",
      "intent": [
        "UK property search",
        "Rightmove listings",
        "buy house UK",
        "поиск недвижимости Rightmove"
      ],
      "endpoint": "GET https://api.rightmove.co.uk/api/sale/find",
      "input": {
        "locationIdentifier": {
          "type": "string",
          "description": "Location: REGION^61325 (London), USERDEFINEDAREA^{json}",
          "required": true
        },
        "minBedrooms": {
          "type": "integer",
          "required": false
        },
        "maxPrice": {
          "type": "integer",
          "required": false
        },
        "propertyTypes": {
          "type": "string",
          "description": "detached, semi-detached, terraced, flat, bungalow",
          "required": false
        },
        "numberOfPropertiesPerPage": {
          "type": "integer",
          "default": 24
        }
      },
      "output": {
        "type": "list<property>",
        "fields": [
          "properties[0].id",
          "properties[0].price.amount",
          "properties[0].displayAddress",
          "properties[0].bedrooms",
          "properties[0].bathrooms",
          "properties[0].propertySubType"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_property_details",
      "description_for_ai": "Get full property listing details from Rightmove.",
      "intent": [
        "property details Rightmove",
        "house details UK",
        "listing info",
        "детали объекта Rightmove"
      ],
      "endpoint": "GET https://api.rightmove.co.uk/api/properties/{property_id}",
      "input": {
        "property_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "property",
        "fields": [
          "id",
          "price.amount",
          "displayAddress",
          "description",
          "bedrooms",
          "bathrooms",
          "images[0].url",
          "floorplans[0].url",
          "nearestStations[0].name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_to_rent",
      "description_for_ai": "Search rental properties on Rightmove.",
      "intent": [
        "rent property UK",
        "Rightmove rent",
        "UK rental",
        "аренда Rightmove"
      ],
      "endpoint": "GET https://api.rightmove.co.uk/api/rent/find",
      "input": {
        "locationIdentifier": {
          "type": "string",
          "required": true
        },
        "minBedrooms": {
          "type": "integer",
          "required": false
        },
        "maxPrice": {
          "type": "integer",
          "description": "Max monthly rent in GBP",
          "required": false
        },
        "letFurnishType": {
          "type": "string",
          "description": "furnished, unfurnished, partFurnished",
          "required": false
        }
      },
      "output": {
        "type": "list<rental>",
        "fields": [
          "properties[0].id",
          "properties[0].price.amount",
          "properties[0].price.frequency",
          "properties[0].displayAddress",
          "properties[0].bedrooms"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_price_trends",
      "description_for_ai": "Get UK house price trend data by area.",
      "intent": [
        "UK house prices",
        "price trends Rightmove",
        "property market data",
        "тренды цен Rightmove"
      ],
      "endpoint": "GET https://api.rightmove.co.uk/api/statistics/trends",
      "input": {
        "locationIdentifier": {
          "type": "string",
          "required": true
        },
        "propertyType": {
          "type": "string",
          "description": "detached, semi-detached, terraced, flat",
          "required": false
        }
      },
      "output": {
        "type": "trends",
        "fields": [
          "currentAveragePrice",
          "priceChange12Month",
          "priceChange5Year",
          "totalAvailableProperties"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "find_agents",
      "description_for_ai": "Find estate agents in a UK area.",
      "intent": [
        "estate agents UK",
        "property agents",
        "find agent Rightmove",
        "агенты Rightmove"
      ],
      "endpoint": "GET https://api.rightmove.co.uk/api/agents/find",
      "input": {
        "locationIdentifier": {
          "type": "string",
          "required": true
        },
        "agentType": {
          "type": "string",
          "description": "sale, lettings",
          "default": "sale"
        }
      },
      "output": {
        "type": "list<agent>",
        "fields": [
          "agents[0].id",
          "agents[0].name",
          "agents[0].address",
          "agents[0].totalLiveProperties",
          "agents[0].logoUrl"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}