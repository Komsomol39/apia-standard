{
  "apia": "1.0",
  "service": {
    "id": "openaq",
    "name": "OpenAQ API",
    "description_for_ai": "Free, open air quality data from 10,000+ monitoring stations worldwide. PM2.5, PM10, NO2, O3, CO, SO2 measurements in real-time and historical. No API key needed for basic access. Use for environmental monitoring, health apps, air quality dashboards.",
    "url": "https://openaq.org",
    "api_base": "https://api.openaq.org/v3",
    "category": "environment",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.openaq.org"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_limits": "10 req/min",
    "header": "X-API-Key: ...",
    "how_to_get": "Free key at https://explore.openaq.org/register",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "get_measurements",
      "description_for_ai": "Get real-time and historical air quality measurements from 10,000+ monitoring stations worldwide. Filter by location, pollutant, and date range.",
      "intent": [
        "air quality",
        "pollution level",
        "PM2.5",
        "air quality index",
        "is air clean",
        "качество воздуха",
        "загрязнение воздуха"
      ],
      "endpoint": "GET https://api.openaq.org/v3/measurements",
      "input": {
        "coordinates": {
          "type": "string",
          "description": "Center point for proximity search: lat,lng e.g. 55.75,37.62 (Moscow)",
          "required": false
        },
        "radius": {
          "type": "integer",
          "description": "Search radius in meters from coordinates",
          "default": 10000
        },
        "parameter": {
          "type": "string",
          "description": "Pollutant: pm25, pm10, no2, o3, co, so2, bc (black carbon), um100 (ultrafine particles)",
          "required": false
        },
        "location_id": {
          "type": "integer",
          "description": "Specific station location ID from get_locations",
          "required": false
        },
        "limit": {
          "type": "integer",
          "description": "Results per page, max 1000",
          "default": 100
        },
        "page": {
          "type": "integer",
          "description": "Page number",
          "default": 1
        },
        "date_from": {
          "type": "string",
          "description": "ISO 8601 start datetime e.g. 2024-01-01T00:00:00Z",
          "required": false
        },
        "date_to": {
          "type": "string",
          "description": "ISO 8601 end datetime",
          "required": false
        }
      },
      "output": {
        "type": "list<measurement>",
        "fields": [
          "results[0].parameter",
          "results[0].value",
          "results[0].unit",
          "results[0].location.name",
          "results[0].location.coordinates.latitude",
          "results[0].location.coordinates.longitude",
          "results[0].date.utc",
          "meta.found"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_locations",
      "description_for_ai": "Get air quality monitoring station locations. Find stations near coordinates or filter by country.",
      "intent": [
        "monitoring stations",
        "air sensors",
        "pollution monitors"
      ],
      "endpoint": "GET https://api.openaq.org/v3/locations",
      "input": {
        "coordinates": {
          "type": "string",
          "description": "lat,lng to find nearby stations",
          "required": false
        },
        "radius": {
          "type": "integer",
          "description": "Search radius in meters",
          "default": 10000
        },
        "country_id": {
          "type": "string",
          "description": "ISO 2-letter country code to filter by: US, DE, IN, CN, RU",
          "required": false
        },
        "parameter": {
          "type": "string",
          "description": "Filter stations that measure a specific parameter: pm25, pm10, no2",
          "required": false
        },
        "limit": {
          "type": "integer",
          "description": "Max results per page, max 1000",
          "default": 100
        }
      },
      "output": {
        "type": "list<location>",
        "fields": [
          "results[0].id",
          "results[0].name",
          "results[0].city",
          "results[0].country.name",
          "results[0].coordinates.latitude",
          "results[0].coordinates.longitude",
          "results[0].parameters[0].parameter",
          "results[0].lastUpdated"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "aqi_mapping": "PM2.5: 0-12=Good, 12-35.4=Moderate, 35.5-55.4=Unhealthy for Sensitive, 55.5-150.4=Unhealthy, 150.5+=Very Unhealthy",
    "free": "Basic access free, no key. Get key for higher rate limits."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}