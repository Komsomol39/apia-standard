{
  "apia": "1.0",
  "service": {
    "id": "elevenlabs",
    "name": "ElevenLabs API",
    "description_for_ai": "Best-in-class text-to-speech and voice cloning. 1000+ voices, 29 languages, ultra-realistic output. Clone any voice from audio sample. Use for audiobooks, podcasts, voice assistants, accessibility features.",
    "url": "https://elevenlabs.io",
    "api_base": "https://api.elevenlabs.io/v1",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://elevenlabs.io/docs/api-reference"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "xi-api-key: ...",
    "how_to_get": "Register at https://elevenlabs.io — 10K chars/month free",
    "cost": "Free: 10K chars/month. Starter: $5/month 30K chars"
  },
  "capabilities": [
    {
      "id": "text_to_speech",
      "description_for_ai": "Convert text to natural speech with ElevenLabs. Best quality TTS available, with 1000+ voices in 32 languages.",
      "intent": [
        "text to speech elevenlabs",
        "TTS elevenlabs",
        "voice synthesis",
        "озвучить текст elevenlabs",
        "синтез речи"
      ],
      "endpoint": "POST https://api.elevenlabs.io/v1/text-to-speech/{voice_id}",
      "input": {
        "voice_id": {
          "type": "string",
          "description": "Voice ID from /voices list. Common: 21m00Tcm4TlvDq8ikWAM (Rachel, neutral), EXAVITQu4vr4xnSDxMaL (Bella, calm)",
          "required": true
        },
        "text": {
          "type": "string",
          "description": "Text to convert, max 2500 chars per request",
          "required": true
        },
        "model_id": {
          "type": "string",
          "description": "eleven_turbo_v2 (fast, cheap), eleven_multilingual_v2 (best quality, 32 languages)",
          "default": "eleven_turbo_v2"
        },
        "voice_settings": {
          "type": "object",
          "description": "{stability: 0.5, similarity_boost: 0.75, style: 0.5, use_speaker_boost: true}. Stability 0=expressive, 1=monotone.",
          "required": false
        },
        "output_format": {
          "type": "string",
          "description": "mp3_44100_128 (default), pcm_16000, ulaw_8000 (phone)",
          "default": "mp3_44100_128"
        }
      },
      "output": {
        "type": "audio",
        "fields": [
          "binary audio stream (MP3/PCM)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_voices",
      "description_for_ai": "List all available ElevenLabs voices including premade and cloned voices.",
      "intent": [
        "elevenlabs voices",
        "list voices TTS",
        "available voices",
        "список голосов elevenlabs"
      ],
      "endpoint": "GET https://api.elevenlabs.io/v1/voices",
      "input": {},
      "output": {
        "type": "list<voice>",
        "fields": [
          "voices[0].voice_id",
          "voices[0].name",
          "voices[0].category",
          "voices[0].description",
          "voices[0].preview_url",
          "voices[0].labels.language"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "clone_voice",
      "description_for_ai": "Create a cloned voice from audio samples. 3-5 minutes of clean speech recommended.",
      "intent": [
        "clone voice elevenlabs",
        "voice cloning",
        "custom voice",
        "клонировать голос elevenlabs"
      ],
      "endpoint": "POST https://api.elevenlabs.io/v1/voices/add",
      "input": {
        "name": {
          "type": "string",
          "description": "Name for the cloned voice",
          "required": true
        },
        "files": {
          "type": "file[]",
          "description": "1-25 audio files (MP3/WAV/M4A), each 50MB max. 3-5 min total for good quality.",
          "required": true
        },
        "description": {
          "type": "string",
          "required": false
        },
        "labels": {
          "type": "string",
          "description": "JSON string: {language: 'ru', accent: 'russian'}",
          "required": false
        }
      },
      "output": {
        "type": "voice",
        "fields": [
          "voice_id",
          "name"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "speech_to_speech",
      "description_for_ai": "Transform voice style while keeping content — change speaker, accent, or style of existing audio.",
      "intent": [
        "voice conversion",
        "speech to speech",
        "voice transformation",
        "преобразование голоса elevenlabs"
      ],
      "endpoint": "POST https://api.elevenlabs.io/v1/speech-to-speech/{voice_id}",
      "input": {
        "voice_id": {
          "type": "string",
          "description": "Target voice ID",
          "required": true
        },
        "audio": {
          "type": "file",
          "description": "Source audio to transform",
          "required": true
        },
        "model_id": {
          "type": "string",
          "default": "eleven_english_sts_v2"
        },
        "voice_settings": {
          "type": "object",
          "required": false
        }
      },
      "output": {
        "type": "audio",
        "fields": [
          "binary audio stream"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "voice_tip": "Rachel (21m00Tcm4TlvDq8ikWAM) and Adam (pNInz6obpgDQGcFmaJgB) are popular defaults. Get full list with get_voices.",
    "language": "eleven_multilingual_v2 supports 29 languages including Russian. Detect language automatically from text.",
    "streaming": "Use /stream endpoint for real-time audio streaming in voice apps."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}