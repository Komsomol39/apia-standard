{
  "apia": "1.0",
  "service": {
    "id": "elevenlabs",
    "name": "ElevenLabs API",
    "description_for_ai": "Best-in-class text-to-speech and voice cloning. 1000+ voices, 29 languages, ultra-realistic output. Clone any voice from audio sample. Use for audiobooks, podcasts, voice assistants, accessibility features.",
    "url": "https://elevenlabs.io",
    "api_base": "https://api.elevenlabs.io/v1",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://elevenlabs.io/docs/api-reference"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "xi-api-key: ...",
    "how_to_get": "Register at https://elevenlabs.io — 10K chars/month free",
    "cost": "Free: 10K chars/month. Starter: $5/month 30K chars"
  },
  "capabilities": [
    {
      "id": "text_to_speech",
      "description_for_ai": "Convert text to ultra-realistic speech. 1000+ voices, 29 languages. Best quality TTS available.",
      "intent": [
        "text to speech",
        "TTS ElevenLabs",
        "voice generation",
        "realistic voice",
        "синтез речи ElevenLabs"
      ],
      "endpoint": "POST https://api.elevenlabs.io/v1/text-to-speech/{voice_id}",
      "input": {
        "voice_id": {
          "type": "string",
          "description": "Voice ID — get from /voices. Popular: 21m00Tcm4TlvDq8ikWAM (Rachel), EXAVITQu4vr4xnSDxMaL (Bella)",
          "required": true
        },
        "text": {
          "type": "string",
          "description": "Text to convert, max 5000 chars per request",
          "required": true
        },
        "model_id": {
          "type": "string",
          "description": "eleven_multilingual_v2 (best), eleven_turbo_v2_5 (fast, cheap), eleven_monolingual_v1",
          "default": "eleven_multilingual_v2"
        },
        "voice_settings": {
          "type": "object",
          "description": "{stability: 0.5, similarity_boost: 0.75, style: 0.0, use_speaker_boost: true}",
          "required": false
        },
        "output_format": {
          "type": "string",
          "description": "mp3_44100_128, mp3_22050_32, pcm_24000, ulaw_8000",
          "default": "mp3_44100_128"
        }
      },
      "output": {
        "type": "audio",
        "fields": [
          "audio binary stream"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "voice_clone",
      "description_for_ai": "Clone a voice from audio samples. 1-5 minutes of clean audio creates a professional voice clone.",
      "intent": [
        "voice clone",
        "clone voice",
        "custom voice",
        "клонирование голоса ElevenLabs"
      ],
      "endpoint": "POST https://api.elevenlabs.io/v1/voices/add",
      "input": {
        "name": {
          "type": "string",
          "description": "Name for the cloned voice",
          "required": true
        },
        "files": {
          "type": "array",
          "description": "Audio files for cloning (mp3/wav/m4a, 1-25 files, min 1 min total)",
          "required": true
        },
        "description": {
          "type": "string",
          "required": false
        },
        "labels": {
          "type": "object",
          "description": "{accent: 'American', age: 'young', gender: 'female'}",
          "required": false
        }
      },
      "output": {
        "type": "voice",
        "fields": [
          "voice_id",
          "name",
          "category"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "list_voices",
      "description_for_ai": "List all available voices including pre-made and cloned voices.",
      "intent": [
        "list voices",
        "available voices ElevenLabs",
        "voice catalog",
        "список голосов ElevenLabs"
      ],
      "endpoint": "GET https://api.elevenlabs.io/v1/voices",
      "input": {
        "show_legacy": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "list<voice>",
        "fields": [
          "voices[0].voice_id",
          "voices[0].name",
          "voices[0].category",
          "voices[0].labels.accent",
          "voices[0].labels.gender"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "speech_to_speech",
      "description_for_ai": "Transform voice from one style to another while preserving content. Change accent, age, gender.",
      "intent": [
        "voice conversion",
        "speech to speech",
        "voice transform",
        "изменение голоса ElevenLabs"
      ],
      "endpoint": "POST https://api.elevenlabs.io/v1/speech-to-speech/{voice_id}",
      "input": {
        "voice_id": {
          "type": "string",
          "required": true
        },
        "audio": {
          "type": "file",
          "description": "Source audio file",
          "required": true
        },
        "model_id": {
          "type": "string",
          "default": "eleven_english_sts_v2"
        }
      },
      "output": {
        "type": "audio",
        "fields": [
          "audio binary stream"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "generate_sound_effects",
      "description_for_ai": "Generate sound effects from text description.",
      "intent": [
        "sound effects",
        "SFX generation",
        "audio effects AI",
        "звуковые эффекты AI"
      ],
      "endpoint": "POST https://api.elevenlabs.io/v1/sound-generation",
      "input": {
        "text": {
          "type": "string",
          "description": "Description of sound: 'thunder strike', 'coffee shop ambiance', 'robot beeping'",
          "required": true
        },
        "duration_seconds": {
          "type": "float",
          "description": "Duration 0.5-22 seconds",
          "required": false
        },
        "prompt_influence": {
          "type": "float",
          "description": "0.0-1.0 how closely to follow prompt",
          "default": 0.3
        }
      },
      "output": {
        "type": "audio",
        "fields": [
          "audio binary (mp3)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_usage",
      "description_for_ai": "Get character usage and subscription quota for the current period.",
      "intent": [
        "ElevenLabs usage",
        "quota check",
        "characters remaining",
        "остаток квоты ElevenLabs"
      ],
      "endpoint": "GET https://api.elevenlabs.io/v1/user/subscription",
      "input": {},
      "output": {
        "type": "subscription",
        "fields": [
          "character_count",
          "character_limit",
          "tier",
          "next_character_count_reset_unix"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "voice_tip": "Rachel (21m00Tcm4TlvDq8ikWAM) and Adam (pNInz6obpgDQGcFmaJgB) are popular defaults. Get full list with get_voices.",
    "language": "eleven_multilingual_v2 supports 29 languages including Russian. Detect language automatically from text.",
    "streaming": "Use /stream endpoint for real-time audio streaming in voice apps."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}