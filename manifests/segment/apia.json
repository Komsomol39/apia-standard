{
  "apia": "1.0",
  "service": {
    "id": "segment",
    "name": "Segment API (Twilio)",
    "description_for_ai": "Customer Data Platform. Collect user events once, send to 450+ destinations (analytics, CRM, email, ads). Single tracking code for all tools. Used by IBM, Intuit, FOX. Use for unified analytics, customer data routing.",
    "url": "https://segment.com",
    "api_base": "https://api.segment.io/v1",
    "category": "business",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://segment.com/docs/connections/sources/catalog/libraries/server/http-api/"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "Write Key as username, empty password",
    "how_to_get": "Workspace → Sources → Your Source → Settings → API Keys",
    "cost": "Free: 1000 MTU/month. Team: $120/month"
  },
  "capabilities": [
    {
      "id": "track",
      "description_for_ai": "Track user events in Segment. Data is forwarded to all connected destinations (Mixpanel, BigQuery, etc.).",
      "intent": [
        "track event Segment",
        "analytics event",
        "user event tracking",
        "аналитика Segment"
      ],
      "endpoint": "POST https://api.segment.io/v1/track",
      "input": {
        "userId": {
          "type": "string",
          "description": "User identifier",
          "required": false
        },
        "anonymousId": {
          "type": "string",
          "description": "Anonymous ID if user not identified",
          "required": false
        },
        "event": {
          "type": "string",
          "description": "Event name: 'Order Completed', 'Video Watched'",
          "required": true
        },
        "properties": {
          "type": "object",
          "description": "{revenue: 29.99, product_id: 'sku123', category: 'Electronics'}",
          "required": false
        },
        "context": {
          "type": "object",
          "description": "{campaign: {source: 'google', medium: 'cpc'}}",
          "required": false
        }
      },
      "output": {
        "type": "status",
        "fields": [
          "success: true"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "identify",
      "description_for_ai": "Identify a user and set their traits in Segment.",
      "intent": [
        "identify user Segment",
        "user traits",
        "customer data",
        "идентификация Segment"
      ],
      "endpoint": "POST https://api.segment.io/v1/identify",
      "input": {
        "userId": {
          "type": "string",
          "required": true
        },
        "traits": {
          "type": "object",
          "description": "{email, name, company, plan, created_at}",
          "required": true
        },
        "anonymousId": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "status",
        "fields": [
          "success: true"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "page",
      "description_for_ai": "Record a page view in Segment with page name and URL.",
      "intent": [
        "page view Segment",
        "track page",
        "page analytics",
        "просмотр страницы Segment"
      ],
      "endpoint": "POST https://api.segment.io/v1/page",
      "input": {
        "userId": {
          "type": "string",
          "required": false
        },
        "anonymousId": {
          "type": "string",
          "required": false
        },
        "name": {
          "type": "string",
          "description": "Page name: 'Home', 'Pricing', 'Checkout'",
          "required": false
        },
        "properties": {
          "type": "object",
          "description": "{url, referrer, title, path}",
          "required": false
        }
      },
      "output": {
        "type": "status",
        "fields": [
          "success: true"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "group",
      "description_for_ai": "Associate a user with a group/company/account in Segment.",
      "intent": [
        "group user Segment",
        "company association",
        "account grouping",
        "группировка Segment"
      ],
      "endpoint": "POST https://api.segment.io/v1/group",
      "input": {
        "userId": {
          "type": "string",
          "required": true
        },
        "groupId": {
          "type": "string",
          "description": "Company or account ID",
          "required": true
        },
        "traits": {
          "type": "object",
          "description": "{name: 'Acme Inc', plan: 'enterprise', employees: 500}",
          "required": false
        }
      },
      "output": {
        "type": "status",
        "fields": [
          "success: true"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "alias",
      "description_for_ai": "Merge anonymous user ID with authenticated user ID in Segment.",
      "intent": [
        "alias user Segment",
        "merge user IDs",
        "link anonymous to user",
        "объединение ID Segment"
      ],
      "endpoint": "POST https://api.segment.io/v1/alias",
      "input": {
        "previousId": {
          "type": "string",
          "description": "Anonymous ID from before login",
          "required": true
        },
        "userId": {
          "type": "string",
          "description": "Authenticated user ID",
          "required": true
        }
      },
      "output": {
        "type": "status",
        "fields": [
          "success: true"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_sources",
      "description_for_ai": "List all Segment sources in your workspace via Config API.",
      "intent": [
        "Segment sources",
        "data sources list",
        "Segment workspace",
        "источники данных Segment"
      ],
      "endpoint": "GET https://platform.segmentapis.com/v1beta/workspaces/{workspace}/sources",
      "input": {
        "workspace": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<source>",
        "fields": [
          "sources[0].name",
          "sources[0].catalog_name",
          "sources[0].enabled",
          "sources[0].write_key"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}