{
  "apia": "1.0",
  "service": {
    "id": "segment",
    "name": "Segment API (Twilio)",
    "description_for_ai": "Customer Data Platform. Collect user events once, send to 450+ destinations (analytics, CRM, email, ads). Single tracking code for all tools. Used by IBM, Intuit, FOX. Use for unified analytics, customer data routing.",
    "url": "https://segment.com",
    "api_base": "https://api.segment.io/v1",
    "category": "business",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://segment.com/docs/connections/sources/catalog/libraries/server/http-api/"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "Write Key as username, empty password",
    "how_to_get": "Workspace → Sources → Your Source → Settings → API Keys",
    "cost": "Free: 1000 MTU/month. Team: $120/month"
  },
  "capabilities": [
    {
      "id": "track",
      "description_for_ai": "Track a user action/event. Segment forwards to 300+ destinations (analytics, CRM, email, etc.).",
      "intent": [
        "segment track",
        "analytics event segment",
        "CDP event",
        "событие segment"
      ],
      "endpoint": "POST https://api.segment.io/v1/track",
      "input": {
        "userId": {
          "type": "string",
          "description": "User ID for logged-in users",
          "required": false
        },
        "anonymousId": {
          "type": "string",
          "description": "Anonymous ID for non-logged in users",
          "required": false
        },
        "event": {
          "type": "string",
          "description": "Event name: 'Signed Up', 'Order Completed', 'Product Viewed'",
          "required": true
        },
        "properties": {
          "type": "object",
          "description": "Event properties: {revenue: 99.99, currency: 'USD', product: 'Pro Plan'}",
          "required": false
        },
        "timestamp": {
          "type": "string",
          "description": "ISO 8601 timestamp",
          "required": false
        },
        "context": {
          "type": "object",
          "description": "{ip, userAgent, campaign: {source, medium, name}}",
          "required": false
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "200 OK on success"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "identify",
      "description_for_ai": "Associate a user ID with traits (properties). Syncs user data to all connected tools.",
      "intent": [
        "segment identify",
        "user traits",
        "profile segment",
        "профиль segment"
      ],
      "endpoint": "POST https://api.segment.io/v1/identify",
      "input": {
        "userId": {
          "type": "string",
          "required": true
        },
        "traits": {
          "type": "object",
          "description": "User attributes: {email, name, plan, company, createdAt, phone}",
          "required": false
        },
        "anonymousId": {
          "type": "string",
          "description": "Alias previously anonymous activity to this user",
          "required": false
        },
        "timestamp": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "200 OK"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "page",
      "description_for_ai": "Track a page view with URL, referrer, and properties.",
      "intent": [
        "track pageview segment",
        "page event segment",
        "website analytics segment",
        "просмотр страницы segment"
      ],
      "endpoint": "POST https://api.segment.io/v1/page",
      "input": {
        "userId": {
          "type": "string",
          "required": false
        },
        "anonymousId": {
          "type": "string",
          "required": false
        },
        "name": {
          "type": "string",
          "description": "Page name e.g. 'Home', 'Product', 'Checkout'",
          "required": false
        },
        "properties": {
          "type": "object",
          "description": "{url, path, referrer, search, title}",
          "required": false
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "200 OK"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "group",
      "description_for_ai": "Associate a user with an account/company for B2B analytics.",
      "intent": [
        "group segment",
        "B2B analytics",
        "company tracking segment",
        "компания segment"
      ],
      "endpoint": "POST https://api.segment.io/v1/group",
      "input": {
        "userId": {
          "type": "string",
          "required": true
        },
        "groupId": {
          "type": "string",
          "description": "Company/organization ID",
          "required": true
        },
        "traits": {
          "type": "object",
          "description": "Company traits: {name, plan, employees, industry, website}",
          "required": false
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "200 OK"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "track_event",
      "description_for_ai": "Track an analytics event with Segment. Routes to all connected destinations (Mixpanel, GA, etc).",
      "intent": [
        "segment track",
        "analytics event segment",
        "send event segment",
        "трекинг segment"
      ],
      "endpoint": "POST https://api.segment.io/v1/track",
      "input": {
        "userId": {
          "type": "string",
          "required": false
        },
        "anonymousId": {
          "type": "string",
          "required": false
        },
        "event": {
          "type": "string",
          "description": "Event name",
          "required": true
        },
        "properties": {
          "type": "object",
          "description": "Custom event properties",
          "required": false
        },
        "timestamp": {
          "type": "string",
          "description": "ISO 8601. Omit for now.",
          "required": false
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "success"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}