{
  "apia": "1.0",
  "service": {
    "id": "open-food-facts",
    "name": "Open Food Facts API",
    "description_for_ai": "Free open database of food products worldwide. 3M+ products with ingredients, nutrition, additives, allergens, Nutri-Score, Eco-Score. Search by barcode or name. No API key needed.",
    "url": "https://world.openfoodfacts.org",
    "api_base": "https://world.openfoodfacts.org",
    "category": "food",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://wiki.openfoodfacts.org/API"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free forever — open data"
  },
  "capabilities": [
    {
      "id": "get_by_barcode",
      "description_for_ai": "Get full product info by barcode: name, brand, ingredients, nutrition per 100g, Nutri-Score, allergens, additives.",
      "intent": [
        "scan barcode",
        "product info",
        "food label",
        "ingredients list",
        "barcode lookup",
        "Nutri-Score",
        "allergens"
      ],
      "endpoint": "GET https://world.openfoodfacts.org/api/v2/product/{barcode}.json",
      "input": {
        "barcode": {
          "type": "string",
          "description": "EAN-13 or UPC barcode number",
          "required": true
        }
      },
      "output": {
        "type": "product",
        "fields": [
          "product.product_name",
          "product.brands",
          "product.ingredients_text",
          "product.nutriscore_grade",
          "product.ecoscore_grade",
          "product.nutriments.energy-kcal_100g",
          "product.allergens",
          "product.additives_tags"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "search_products",
      "description_for_ai": "Search food products by name. Returns matching products with nutrition and labels.",
      "intent": [
        "search food product",
        "find food",
        "product search",
        "food brand"
      ],
      "endpoint": "GET https://world.openfoodfacts.org/cgi/search.pl",
      "input": {
        "search_terms": {
          "type": "string",
          "required": true
        },
        "search_simple": {
          "type": "integer",
          "default": 1
        },
        "action": {
          "type": "string",
          "default": "process"
        },
        "json": {
          "type": "integer",
          "default": 1
        },
        "page_size": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<product>",
        "fields": [
          "products[0].product_name",
          "products[0].brands",
          "products[0].nutriscore_grade",
          "products[0].nutriments"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_product",
      "description_for_ai": "Get nutritional info for a food product by barcode.",
      "intent": [
        "product nutrition barcode",
        "food scan barcode",
        "open food facts product",
        "состав продукта штрихкод"
      ],
      "endpoint": "GET https://world.openfoodfacts.org/api/v2/product/{barcode}",
      "input": {
        "barcode": {
          "type": "string",
          "description": "EAN-13 or UPC barcode",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "product_name,brands,nutriscore_grade,nutriments,ingredients_text",
          "required": false
        }
      },
      "output": {
        "type": "product",
        "fields": [
          "product.product_name",
          "product.brands",
          "product.nutriscore_grade",
          "product.nutriments.energy-kcal_100g",
          "product.ingredients_text"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "search_products",
      "description_for_ai": "Search food products in Open Food Facts database.",
      "intent": [
        "search food products",
        "find food open food facts",
        "product search nutrition"
      ],
      "endpoint": "GET https://world.openfoodfacts.org/cgi/search.pl",
      "input": {
        "search_terms": {
          "type": "string",
          "required": true
        },
        "json": {
          "type": "integer",
          "default": 1
        },
        "page_size": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<product>",
        "fields": [
          "products[0].product_name",
          "products[0].brands",
          "products[0].nutriscore_grade",
          "products[0].code"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_allergens",
      "description_for_ai": "Check allergens in a food product.",
      "intent": [
        "allergens product",
        "food allergens",
        "contains nuts",
        "аллергены продукт"
      ],
      "endpoint": "GET https://world.openfoodfacts.org/api/v2/product/{barcode}",
      "input": {
        "barcode": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "string",
          "default": "allergens,allergens_tags,traces_tags"
        }
      },
      "output": {
        "type": "allergens",
        "fields": [
          "product.allergens",
          "product.allergens_tags",
          "product.traces_tags"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "nutriscore": "Nutri-Score: A=best, B=good, C=ok, D=poor, E=worst. Use for quick health comparison.",
    "barcode_formats": "Accepts EAN-8, EAN-13 (European), UPC-A, UPC-E (US)."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}