{
  "apia": "1.0",
  "service": {
    "id": "newsapi",
    "name": "NewsAPI",
    "description_for_ai": "NewsAPI — real-time news aggregation from 150,000+ sources worldwide. Search articles by keyword, source, category, country, and language. Top headlines and archived articles. Free for development with 100 req/day. Perfect for news monitoring, sentiment analysis, content curation.",
    "url": "https://newsapi.org",
    "api_base": "https://newsapi.org/v2",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://newsapi.org/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "X-Api-Key: ...",
    "how_to_get": "Free key at https://newsapi.org/register",
    "cost": "Free: 100 req/day. Business from $449/month"
  },
  "capabilities": [
    {
      "id": "everything",
      "description_for_ai": "Search 80,000+ news sources for articles about any topic.",
      "intent": [
        "news search",
        "find news articles",
        "news API",
        "поиск новостей"
      ],
      "endpoint": "GET https://newsapi.org/v2/everything",
      "input": {
        "q": {
          "type": "string",
          "description": "Search query. Supports AND, OR, NOT and quotes: '\"bitcoin\" AND (crash OR rally)'",
          "required": true
        },
        "sources": {
          "type": "string",
          "description": "Comma-separated source IDs: bbc-news,cnn,reuters",
          "required": false
        },
        "language": {
          "type": "string",
          "description": "ar, de, en, es, fr, he, it, nl, no, pt, ru, sv, ud, zh",
          "default": "en"
        },
        "sortBy": {
          "type": "string",
          "description": "relevancy, popularity, publishedAt",
          "default": "publishedAt"
        },
        "from": {
          "type": "string",
          "description": "ISO 8601 date: 2024-01-01",
          "required": false
        },
        "to": {
          "type": "string",
          "required": false
        },
        "pageSize": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<article>",
        "fields": [
          "articles[0].title",
          "articles[0].description",
          "articles[0].source.name",
          "articles[0].url",
          "articles[0].publishedAt",
          "articles[0].author"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "top_headlines",
      "description_for_ai": "Get breaking news top headlines by country, category, or keyword.",
      "intent": [
        "top news",
        "breaking news",
        "headlines",
        "главные новости"
      ],
      "endpoint": "GET https://newsapi.org/v2/top-headlines",
      "input": {
        "country": {
          "type": "string",
          "description": "ISO country code: us, gb, de, ru, fr, cn, in, jp, au, ca",
          "required": false
        },
        "category": {
          "type": "string",
          "description": "business, entertainment, general, health, science, sports, technology",
          "required": false
        },
        "q": {
          "type": "string",
          "description": "Search within headlines",
          "required": false
        },
        "pageSize": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<article>",
        "fields": [
          "articles[0].title",
          "articles[0].description",
          "articles[0].source.name",
          "articles[0].url",
          "articles[0].publishedAt",
          "totalResults"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_sources",
      "description_for_ai": "Get list of available news sources filtered by category, language, country.",
      "intent": [
        "news sources",
        "available publishers",
        "media sources",
        "источники новостей"
      ],
      "endpoint": "GET https://newsapi.org/v2/sources",
      "input": {
        "category": {
          "type": "string",
          "description": "business, entertainment, general, health, science, sports, technology",
          "required": false
        },
        "language": {
          "type": "string",
          "required": false
        },
        "country": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<source>",
        "fields": [
          "sources[0].id",
          "sources[0].name",
          "sources[0].description",
          "sources[0].url",
          "sources[0].category",
          "sources[0].language"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "search_by_source",
      "description_for_ai": "Get latest articles from a specific news source.",
      "intent": [
        "BBC news",
        "CNN articles",
        "source articles",
        "новости конкретного источника"
      ],
      "endpoint": "GET https://newsapi.org/v2/everything",
      "input": {
        "sources": {
          "type": "string",
          "description": "Source ID from get_sources: bbc-news, the-verge, techcrunch",
          "required": true
        },
        "q": {
          "type": "string",
          "required": false
        },
        "pageSize": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<article>",
        "fields": [
          "articles[0].title",
          "articles[0].url",
          "articles[0].publishedAt",
          "articles[0].content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "monitor_topic",
      "description_for_ai": "Monitor news coverage of a topic over a time range. Useful for media analysis.",
      "intent": [
        "news monitoring",
        "press coverage",
        "media monitoring",
        "мониторинг новостей"
      ],
      "endpoint": "GET https://newsapi.org/v2/everything",
      "input": {
        "q": {
          "type": "string",
          "required": true
        },
        "from": {
          "type": "string",
          "description": "Start date YYYY-MM-DD",
          "required": true
        },
        "to": {
          "type": "string",
          "description": "End date YYYY-MM-DD",
          "required": true
        },
        "language": {
          "type": "string",
          "default": "en"
        },
        "sortBy": {
          "type": "string",
          "default": "publishedAt"
        },
        "pageSize": {
          "type": "integer",
          "default": 100
        }
      },
      "output": {
        "type": "list<article>",
        "fields": [
          "articles[0].title",
          "articles[0].source.name",
          "articles[0].publishedAt",
          "articles[0].url",
          "totalResults"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}