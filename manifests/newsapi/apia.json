{
  "apia": "1.0",
  "service": {
    "id": "newsapi",
    "name": "NewsAPI",
    "description_for_ai": "NewsAPI — real-time news aggregation from 150,000+ sources worldwide. Search articles by keyword, source, category, country, and language. Top headlines and archived articles. Free for development with 100 req/day. Perfect for news monitoring, sentiment analysis, content curation.",
    "url": "https://newsapi.org",
    "api_base": "https://newsapi.org/v2",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://newsapi.org/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "X-Api-Key: ...",
    "how_to_get": "Free key at https://newsapi.org/register",
    "cost": "Free: 100 req/day. Business from $449/month"
  },
  "capabilities": [
    {
      "id": "top_headlines",
      "description_for_ai": "Get breaking news headlines by country, category, or source.",
      "intent": [
        "top news",
        "breaking news",
        "headlines",
        "последние новости",
        "топ новости"
      ],
      "endpoint": "GET https://newsapi.org/v2/top-headlines",
      "input": {
        "country": {
          "type": "string",
          "description": "ae, ar, at, au, be, bg, br, ca, ch, cn, co, cu, cz, de, eg, fr, gb, gr, hk, hu, id, ie, il, in, it, jp, kr, lt, lv, ma, mx, my, ng, nl, no, nz, ph, pl, pt, ro, rs, ru, sa, se, sg, si, sk, th, tr, tw, ua, us, ve, za",
          "required": false
        },
        "category": {
          "type": "string",
          "description": "business, entertainment, general, health, science, sports, technology",
          "required": false
        },
        "sources": {
          "type": "string",
          "description": "Comma-separated source IDs. Cannot mix with country/category.",
          "required": false
        },
        "q": {
          "type": "string",
          "description": "Keywords to filter headlines",
          "required": false
        },
        "pageSize": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<article>",
        "fields": [
          "articles[0].title",
          "articles[0].source.name",
          "articles[0].author",
          "articles[0].publishedAt",
          "articles[0].url",
          "articles[0].description"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_news",
      "description_for_ai": "Search all news articles with keyword, date range, language, and source filters.",
      "intent": [
        "search news",
        "news articles",
        "find news about",
        "поиск новостей",
        "статьи про"
      ],
      "endpoint": "GET https://newsapi.org/v2/everything",
      "input": {
        "q": {
          "type": "string",
          "description": "Keywords: bitcoin, 'apple AND iphone', 'elon musk'",
          "required": true
        },
        "language": {
          "type": "string",
          "description": "ar, de, en, es, fr, he, it, nl, no, pt, ru, sv, ud, zh",
          "required": false
        },
        "from": {
          "type": "string",
          "description": "ISO 8601 date",
          "required": false
        },
        "to": {
          "type": "string",
          "required": false
        },
        "sortBy": {
          "type": "string",
          "description": "relevancy, popularity, publishedAt",
          "default": "publishedAt"
        },
        "pageSize": {
          "type": "integer",
          "default": 20
        },
        "sources": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<article>",
        "fields": [
          "articles[0].title",
          "articles[0].description",
          "articles[0].url",
          "articles[0].source.name",
          "articles[0].publishedAt",
          "totalResults"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_sources",
      "description_for_ai": "List available news sources filtered by category, language, or country.",
      "intent": [
        "news sources",
        "available publishers",
        "news websites",
        "источники новостей newsapi"
      ],
      "endpoint": "GET https://newsapi.org/v2/top-headlines/sources",
      "input": {
        "category": {
          "type": "string",
          "required": false
        },
        "language": {
          "type": "string",
          "required": false
        },
        "country": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<source>",
        "fields": [
          "sources[0].id",
          "sources[0].name",
          "sources[0].description",
          "sources[0].url",
          "sources[0].country"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "search_news_ru",
      "description_for_ai": "Поиск русскоязычных новостей на NewsAPI.",
      "intent": [
        "русские новости",
        "новости на русском",
        "поиск новостей russia",
        "Russian news"
      ],
      "endpoint": "GET https://newsapi.org/v2/everything",
      "input": {
        "q": {
          "type": "string",
          "required": true
        },
        "language": {
          "type": "string",
          "default": "ru"
        },
        "sortBy": {
          "type": "string",
          "default": "publishedAt"
        },
        "pageSize": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<article>",
        "fields": [
          "articles[0].title",
          "articles[0].url",
          "articles[0].source.name",
          "articles[0].publishedAt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}