{
  "apia": "1.0",
  "service": {
    "id": "newsapi",
    "name": "NewsAPI",
    "description_for_ai": "NewsAPI — real-time news aggregation from 150,000+ sources worldwide. Search articles by keyword, source, category, country, and language. Top headlines and archived articles. Free for development with 100 req/day. Perfect for news monitoring, sentiment analysis, content curation.",
    "url": "https://newsapi.org",
    "api_base": "https://newsapi.org/v2",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://newsapi.org/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "X-Api-Key: ...",
    "how_to_get": "Free key at https://newsapi.org/register",
    "cost": "Free: 100 req/day. Business from $449/month"
  },
  "capabilities": [
    {
      "id": "get_top_headlines",
      "description_for_ai": "Get top news headlines by country, category, or source.",
      "intent": [
        "top news",
        "breaking news",
        "headlines NewsAPI",
        "главные новости NewsAPI"
      ],
      "endpoint": "GET https://newsapi.org/v2/top-headlines",
      "input": {
        "country": {
          "type": "string",
          "description": "ISO 2-letter country: us, gb, ru, de, fr, cn",
          "required": false
        },
        "category": {
          "type": "string",
          "description": "business, entertainment, general, health, science, sports, technology",
          "required": false
        },
        "sources": {
          "type": "string",
          "description": "Comma-separated source IDs: bbc-news,cnn,reuters",
          "required": false
        },
        "q": {
          "type": "string",
          "description": "Keyword filter",
          "required": false
        },
        "pageSize": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<article>",
        "fields": [
          "articles[0].title",
          "articles[0].description",
          "articles[0].url",
          "articles[0].source.name",
          "articles[0].publishedAt",
          "articles[0].urlToImage"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_articles",
      "description_for_ai": "Search all news articles with keyword, source, date, and language filters.",
      "intent": [
        "search news",
        "news search",
        "find articles",
        "поиск новостей NewsAPI"
      ],
      "endpoint": "GET https://newsapi.org/v2/everything",
      "input": {
        "q": {
          "type": "string",
          "description": "Search query. Use AND, OR, NOT, quotes: +Apple -(iPhone OR Mac)",
          "required": true
        },
        "from": {
          "type": "string",
          "description": "YYYY-MM-DD start date (max 1 month for free)",
          "required": false
        },
        "to": {
          "type": "string",
          "required": false
        },
        "language": {
          "type": "string",
          "description": "ar, de, en, es, fr, he, it, nl, no, pt, ru, sv, ud, zh",
          "default": "en"
        },
        "sortBy": {
          "type": "string",
          "description": "relevancy, popularity, publishedAt",
          "default": "publishedAt"
        },
        "pageSize": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<article>",
        "fields": [
          "articles[0].title",
          "articles[0].url",
          "articles[0].source.name",
          "articles[0].publishedAt",
          "articles[0].content",
          "totalResults"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_sources",
      "description_for_ai": "Get all available news sources with their categories and countries.",
      "intent": [
        "news sources",
        "available sources",
        "source list",
        "источники новостей NewsAPI"
      ],
      "endpoint": "GET https://newsapi.org/v2/sources",
      "input": {
        "category": {
          "type": "string",
          "description": "Filter by category",
          "required": false
        },
        "language": {
          "type": "string",
          "required": false
        },
        "country": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<source>",
        "fields": [
          "sources[0].id",
          "sources[0].name",
          "sources[0].category",
          "sources[0].language",
          "sources[0].country",
          "sources[0].url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_by_domain",
      "description_for_ai": "Get articles from specific news domains.",
      "intent": [
        "domain news",
        "specific site news",
        "publisher articles",
        "новости с сайта"
      ],
      "endpoint": "GET https://newsapi.org/v2/everything",
      "input": {
        "domains": {
          "type": "string",
          "description": "Comma-separated: bbc.com,techcrunch.com,reuters.com",
          "required": true
        },
        "q": {
          "type": "string",
          "required": false
        },
        "pageSize": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<article>",
        "fields": [
          "articles[0].title",
          "articles[0].url",
          "articles[0].publishedAt",
          "articles[0].author"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "trending_search",
      "description_for_ai": "Find trending news articles sorted by popularity.",
      "intent": [
        "trending news",
        "popular articles",
        "viral news",
        "популярные новости"
      ],
      "endpoint": "GET https://newsapi.org/v2/everything",
      "input": {
        "q": {
          "type": "string",
          "required": true
        },
        "sortBy": {
          "type": "string",
          "default": "popularity"
        },
        "language": {
          "type": "string",
          "default": "en"
        },
        "pageSize": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<article>",
        "fields": [
          "articles[0].title",
          "articles[0].url",
          "articles[0].source.name",
          "articles[0].publishedAt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}