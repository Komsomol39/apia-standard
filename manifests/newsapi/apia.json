{
  "apia": "1.0",
  "service": {
    "id": "newsapi",
    "name": "NewsAPI",
    "description_for_ai": "Search news articles from 150,000+ sources worldwide in real-time. Current headlines, topic search, source filtering. Free: 100 requests/day. Use for news monitoring, topic research, current events.",
    "url": "https://newsapi.org",
    "api_base": "https://newsapi.org/v2",
    "category": "news",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://newsapi.org/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "X-Api-Key: ...",
    "how_to_get": "Free key at https://newsapi.org/register",
    "cost": "Free: 100 req/day. Business from $449/month"
  },
  "capabilities": [
    {
      "id": "search_everything",
      "description_for_ai": "Search all news articles by keyword, date range, language, source. Returns article title, description, URL, source, published date.",
      "intent": [
        "новости о",
        "news about",
        "press coverage",
        "find articles",
        "поиск новостей",
        "media monitoring",
        "articles about",
        "latest news on",
        "news search"
      ],
      "endpoint": "GET https://newsapi.org/v2/everything",
      "input": {
        "q": {
          "type": "string",
          "description": "Search keywords",
          "required": true
        },
        "language": {
          "type": "string",
          "description": "en, ru, de, fr, es, zh, ar etc.",
          "required": false
        },
        "from": {
          "type": "string",
          "description": "Date ISO 8601",
          "required": false
        },
        "to": {
          "type": "string",
          "description": "Date ISO 8601",
          "required": false
        },
        "sortBy": {
          "type": "string",
          "description": "relevancy, popularity, publishedAt",
          "default": "publishedAt"
        },
        "pageSize": {
          "type": "integer",
          "default": 20,
          "max": 100
        }
      },
      "output": {
        "type": "list<article>",
        "fields": [
          "title",
          "description",
          "url",
          "source.name",
          "publishedAt",
          "urlToImage"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "top_headlines",
      "description_for_ai": "Get top headlines from a country or category. Use for breaking news, top stories by category.",
      "intent": [
        "top stories",
        "latest headlines",
        "главные новости",
        "headlines",
        "daily news",
        "top news",
        "breaking news"
      ],
      "endpoint": "GET https://newsapi.org/v2/top-headlines",
      "input": {
        "country": {
          "type": "string",
          "description": "ISO 3166-1 2-letter code: us, ru, gb, de, fr",
          "required": false
        },
        "category": {
          "type": "string",
          "description": "business, entertainment, health, science, sports, technology",
          "required": false
        },
        "q": {
          "type": "string",
          "required": false,
          "description": "Search query or filter expression"
        },
        "pageSize": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<article>",
        "fields": [
          "title",
          "description",
          "url",
          "source.name",
          "publishedAt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}