{
  "apia": "1.0",
  "service": {
    "id": "pochta-russia",
    "name": "Почта России API",
    "description_for_ai": "API Почты России. Расчёт стоимости отправлений, создание заказов, отслеживание посылок. Охват всех населённых пунктов России. Используй для доставки в отдалённые регионы где нет других курьерских служб.",
    "url": "https://otpravka.pochta.ru",
    "api_base": "https://otpravka-api.pochta.ru",
    "category": "logistics_shipping",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://otpravka.pochta.ru/specification"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "login:password в base64 + токен авторизации",
    "how_to_get": "Личный кабинет otpravka.pochta.ru",
    "cost": "По тарифам Почты России"
  },
  "capabilities": [
    {
      "id": "calculate_rate",
      "description_for_ai": "Рассчитать стоимость и сроки доставки Почтой России по индексам.",
      "intent": [
        "почта России стоимость",
        "стоимость посылки",
        "рассчитать почту",
        "индекс отправления",
        "тариф почта"
      ],
      "endpoint": "POST https://otpravka-api.pochta.ru/1.0/tariff",
      "input": {
        "index-from": {
          "type": "string",
          "description": "Почтовый индекс отправителя",
          "required": true
        },
        "index-to": {
          "type": "string",
          "description": "Почтовый индекс получателя",
          "required": true
        },
        "mail-category": {
          "type": "string",
          "description": "ORDINARY=обычная, ORDERED=заказная, WITH_DECLARED_VALUE=с объявленной ценностью",
          "required": true
        },
        "mail-type": {
          "type": "string",
          "description": "POSTAL_PARCEL=посылка, ONLINE_PARCEL=онлайн-посылка, LETTER=письмо",
          "required": true
        },
        "mass": {
          "type": "integer",
          "description": "Масса в граммах",
          "required": true
        }
      },
      "output": {
        "type": "tariff",
        "fields": [
          "total-rate",
          "delivery-time.min-days",
          "delivery-time.max-days"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "track_shipment",
      "description_for_ai": "Отследить отправление Почты России по трек-номеру.",
      "intent": [
        "трек почта России",
        "отследить посылку почта",
        "где посылка",
        "трекинг Почта",
        "РПО трекинг"
      ],
      "endpoint": "GET https://otpravka-api.pochta.ru/1.0/tracking/single/{barcode}",
      "input": {
        "barcode": {
          "type": "string",
          "description": "Штриховой идентификатор (трек-номер) отправления",
          "required": true
        }
      },
      "output": {
        "type": "tracking",
        "fields": [
          "operationParameters.operDate",
          "operationParameters.operType.name",
          "address.index"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "auth": "Base64 encode login:password for Authorization header. Separate token for tracking API.",
    "index_lookup": "Look up postal index (индекс) by address at pochta.ru or via FIAS/КЛАДР APIs.",
    "mail_types": "LETTER=письмо, POSTAL_PARCEL=посылка, ONLINE_PARCEL=онлайн-посылка, BANDEROL=бандероль, EMS=ЕМС экспресс",
    "delivery_time": "Delivery times vary greatly in Russia. Estimated min/max days, not guaranteed."
  }
}