{
  "apia": "1.0",
  "service": {
    "id": "pochta-russia",
    "name": "Почта России API",
    "description_for_ai": "API Почты России. Расчёт стоимости отправлений, создание заказов, отслеживание посылок. Охват всех населённых пунктов России. Используй для доставки в отдалённые регионы где нет других курьерских служб.",
    "url": "https://otpravka.pochta.ru",
    "api_base": "https://otpravka-api.pochta.ru",
    "category": "logistics",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://otpravka.pochta.ru/specification"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "login:password в base64 + токен авторизации",
    "how_to_get": "Личный кабинет otpravka.pochta.ru",
    "cost": "По тарифам Почты России"
  },
  "capabilities": [
    {
      "id": "track_shipment",
      "description_for_ai": "Track Russian Post (Почта России) shipment by tracking number.",
      "intent": [
        "отследить почта россия",
        "трекинг почты",
        "где посылка почта",
        "track russian post"
      ],
      "endpoint": "https://otpravka-api.pochta.ru/1.0/tracking/single",
      "input": {
        "barcode": {
          "type": "string",
          "description": "Russian Post tracking number (14-char barcode) e.g. RA123456789RU",
          "required": true
        }
      },
      "output": {
        "type": "tracking",
        "fields": [
          "operationHistoryData.historyRecord[0].OperationParameters.OperType.Name",
          "historyRecord[0].AddressParameters.DestinationAddress.Description",
          "historyRecord[0].FinanceParameters.Payment"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "calculate_delivery",
      "description_for_ai": "Calculate Russian Post delivery cost and terms between postal codes.",
      "intent": [
        "тариф почта россия",
        "расчёт доставки почта",
        "стоимость отправки почта",
        "почта тариф"
      ],
      "endpoint": "https://tariff.pochta.ru/v2/calculate/tariff/multitype",
      "input": {
        "object": {
          "type": "integer",
          "description": "Mail type: 2010=Посылка, 2900=ЕМС, 3000=1й класс",
          "required": true
        },
        "from": {
          "type": "integer",
          "description": "Sender postal code (индекс отправителя)",
          "required": true
        },
        "to": {
          "type": "integer",
          "description": "Recipient postal code",
          "required": true
        },
        "weight": {
          "type": "integer",
          "description": "Weight in grams",
          "required": true
        },
        "sumoc": {
          "type": "integer",
          "description": "Declared value in kopecks (0 if no declared value)",
          "default": 0
        }
      },
      "output": {
        "type": "tariff",
        "fields": [
          "paynds (cost in kopecks)",
          "delivery.min",
          "delivery.max",
          "name"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "normalize_address",
      "description_for_ai": "Normalize and validate Russian postal address, get postal code.",
      "intent": [
        "нормализация адреса",
        "индекс по адресу",
        "почтовый индекс",
        "адрес ФИАС"
      ],
      "endpoint": "https://otpravka-api.pochta.ru/1.0/clean/address",
      "input": {
        "original-address": {
          "type": "string",
          "description": "Free-form Russian address",
          "required": true
        }
      },
      "output": {
        "type": "address",
        "fields": [
          "index",
          "region",
          "area",
          "place",
          "street",
          "house",
          "room",
          "quality-code"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_shipment",
      "description_for_ai": "Create a Russian Post shipment (форма ф7-п, ф7-в) and get print form.",
      "intent": [
        "создать отправление почта",
        "оформить посылку почта",
        "форма почта России"
      ],
      "endpoint": "POST https://otpravka-api.pochta.ru/1.0/shipment",
      "input": {
        "mail-type": {
          "type": "string",
          "description": "POSTAL_PARCEL, EMS, EMS_OPTIMAL, ONLINE_PARCEL",
          "required": true
        },
        "address-type-to": {
          "type": "string",
          "description": "DEFAULT, PO_BOX, DEMAND",
          "required": true
        },
        "mass": {
          "type": "integer",
          "description": "Weight in grams",
          "required": true
        },
        "recipient": {
          "type": "object",
          "description": "{name, address: {index, region, place, street, house, room}}",
          "required": true
        }
      },
      "output": {
        "type": "shipment",
        "fields": [
          "id",
          "barcode",
          "errors"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "auth": "Base64 encode login:password for Authorization header. Separate token for tracking API.",
    "index_lookup": "Look up postal index (индекс) by address at pochta.ru or via FIAS/КЛАДР APIs.",
    "mail_types": "LETTER=письмо, POSTAL_PARCEL=посылка, ONLINE_PARCEL=онлайн-посылка, BANDEROL=бандероль, EMS=ЕМС экспресс",
    "delivery_time": "Delivery times vary greatly in Russia. Estimated min/max days, not guaranteed."
  }
}