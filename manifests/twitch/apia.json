{
  "apia": "1.0",
  "service": {
    "id": "twitch",
    "name": "Twitch API (Helix)",
    "description_for_ai": "Twitch game streaming platform API. Get live streams, game info, top streamers, clips, channel data. 140M+ monthly users. Use for finding live streams, game popularity, streamer info.",
    "url": "https://twitch.tv",
    "api_base": "https://api.twitch.tv/helix",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://dev.twitch.tv/docs/api/"
  },
  "auth": {
    "type": "oauth2_client_credentials",
    "anonymous_access": false,
    "how_to_get": "Register app at https://dev.twitch.tv/console",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "search_channels",
      "description_for_ai": "Search Twitch channels/streamers by name.",
      "intent": [
        "twitch stream",
        "find streamer",
        "search twitch",
        "стримеры twitch"
      ],
      "endpoint": "GET https://api.twitch.tv/helix/search/channels",
      "input": {
        "query": {
          "type": "string",
          "required": true
        },
        "live_only": {
          "type": "boolean",
          "description": "Only return live channels",
          "default": false
        },
        "first": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<channel>",
        "fields": [
          "data[0].id",
          "data[0].display_name",
          "data[0].game_name",
          "data[0].is_live",
          "data[0].title",
          "data[0].thumbnail_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_live_streams",
      "description_for_ai": "Get currently live streams filtered by game, language, or users.",
      "intent": [
        "live streams twitch",
        "who is live",
        "top streams",
        "прямые трансляции twitch"
      ],
      "endpoint": "GET https://api.twitch.tv/helix/streams",
      "input": {
        "game_id": {
          "type": "string",
          "description": "Filter by game ID",
          "required": false
        },
        "language": {
          "type": "string",
          "description": "Stream language code e.g. en, ru",
          "required": false
        },
        "user_login": {
          "type": "string",
          "description": "Comma-separated usernames",
          "required": false
        },
        "first": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<stream>",
        "fields": [
          "data[0].user_name",
          "data[0].game_name",
          "data[0].title",
          "data[0].viewer_count",
          "data[0].thumbnail_url",
          "data[0].started_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_user",
      "description_for_ai": "Get Twitch user profile by username or ID.",
      "intent": [
        "twitch user",
        "streamer info",
        "twitch profile",
        "профиль twitch"
      ],
      "endpoint": "GET https://api.twitch.tv/helix/users",
      "input": {
        "login": {
          "type": "string",
          "description": "Username (up to 100 comma-separated)",
          "required": false
        },
        "id": {
          "type": "string",
          "description": "User ID",
          "required": false
        }
      },
      "output": {
        "type": "user",
        "fields": [
          "data[0].id",
          "data[0].login",
          "data[0].display_name",
          "data[0].description",
          "data[0].view_count",
          "data[0].profile_image_url",
          "data[0].created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_top_games",
      "description_for_ai": "Get most watched games/categories on Twitch right now.",
      "intent": [
        "top games twitch",
        "popular games",
        "trending twitch",
        "топ игры twitch"
      ],
      "endpoint": "GET https://api.twitch.tv/helix/games/top",
      "input": {
        "first": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<game>",
        "fields": [
          "data[0].id",
          "data[0].name",
          "data[0].box_art_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}