{
  "apia": "1.0",
  "service": {
    "id": "twitch",
    "name": "Twitch API (Helix)",
    "description_for_ai": "Twitch game streaming platform API. Get live streams, game info, top streamers, clips, channel data. 140M+ monthly users. Use for finding live streams, game popularity, streamer info.",
    "url": "https://twitch.tv",
    "api_base": "https://api.twitch.tv/helix",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://dev.twitch.tv/docs/api/"
  },
  "auth": {
    "type": "oauth2_client_credentials",
    "anonymous_access": false,
    "how_to_get": "Register app at https://dev.twitch.tv/console",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "get_streams",
      "description_for_ai": "Get live streams with viewer counts, game, title. Filter by game, language, or user.",
      "intent": [
        "twitch streams",
        "live streams",
        "popular streams twitch",
        "прямые трансляции twitch"
      ],
      "endpoint": "GET https://api.twitch.tv/helix/streams",
      "input": {
        "game_id": {
          "type": "string",
          "description": "Game ID to filter by",
          "required": false
        },
        "user_login": {
          "type": "string",
          "description": "Comma-separated streamer logins",
          "required": false
        },
        "language": {
          "type": "string",
          "description": "ISO 639-1 language code",
          "required": false
        },
        "first": {
          "type": "integer",
          "description": "Number of results 1-100",
          "default": 20
        },
        "after": {
          "type": "string",
          "description": "Pagination cursor",
          "required": false
        }
      },
      "output": {
        "type": "list<stream>",
        "fields": [
          "data[0].user_name",
          "data[0].game_name",
          "data[0].title",
          "data[0].viewer_count",
          "data[0].language",
          "data[0].thumbnail_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_user",
      "description_for_ai": "Get Twitch user profile by login name or ID.",
      "intent": [
        "twitch user",
        "streamer profile",
        "twitch channel info",
        "профиль twitch"
      ],
      "endpoint": "GET https://api.twitch.tv/helix/users",
      "input": {
        "login": {
          "type": "string",
          "description": "Comma-separated usernames (max 100)",
          "required": false
        },
        "id": {
          "type": "string",
          "description": "Comma-separated user IDs",
          "required": false
        }
      },
      "output": {
        "type": "list<user>",
        "fields": [
          "data[0].id",
          "data[0].login",
          "data[0].display_name",
          "data[0].description",
          "data[0].view_count",
          "data[0].profile_image_url",
          "data[0].broadcaster_type"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_clips",
      "description_for_ai": "Get clips from a broadcaster or game. Filter by date range.",
      "intent": [
        "twitch clips",
        "stream highlights",
        "viral twitch",
        "клипы twitch"
      ],
      "endpoint": "GET https://api.twitch.tv/helix/clips",
      "input": {
        "broadcaster_id": {
          "type": "string",
          "description": "Broadcaster's user ID",
          "required": false
        },
        "game_id": {
          "type": "string",
          "description": "Game ID to filter clips",
          "required": false
        },
        "first": {
          "type": "integer",
          "default": 20
        },
        "started_at": {
          "type": "string",
          "description": "ISO 8601 start date",
          "required": false
        },
        "ended_at": {
          "type": "string",
          "description": "ISO 8601 end date",
          "required": false
        }
      },
      "output": {
        "type": "list<clip>",
        "fields": [
          "data[0].id",
          "data[0].title",
          "data[0].view_count",
          "data[0].url",
          "data[0].broadcaster_name",
          "data[0].thumbnail_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_top_games",
      "description_for_ai": "Get most popular games/categories on Twitch right now by viewer count.",
      "intent": [
        "top games twitch",
        "popular games streaming",
        "trending games",
        "популярные игры twitch"
      ],
      "endpoint": "GET https://api.twitch.tv/helix/games/top",
      "input": {
        "first": {
          "type": "integer",
          "description": "Number of games 1-100",
          "default": 20
        },
        "after": {
          "type": "string",
          "description": "Pagination cursor",
          "required": false
        }
      },
      "output": {
        "type": "list<game>",
        "fields": [
          "data[0].id",
          "data[0].name",
          "data[0].box_art_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}