{
  "apia": "1.0",
  "service": {
    "id": "twitch",
    "name": "Twitch API (Helix)",
    "description_for_ai": "Twitch game streaming platform API. Get live streams, game info, top streamers, clips, channel data. 140M+ monthly users. Use for finding live streams, game popularity, streamer info.",
    "url": "https://twitch.tv",
    "api_base": "https://api.twitch.tv/helix",
    "category": "media_streaming",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://dev.twitch.tv/docs/api/"
  },
  "auth": {
    "type": "oauth2_client_credentials",
    "anonymous_access": false,
    "how_to_get": "Register app at https://dev.twitch.tv/console",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "get_streams",
      "description_for_ai": "Get currently live streams. Filter by game, language, or search by streamer name. Returns viewer count, title, thumbnail.",
      "intent": [
        "live streams",
        "twitch streams",
        "watch gaming",
        "who is streaming",
        "live now",
        "стримы"
      ],
      "endpoint": "GET https://api.twitch.tv/helix/streams",
      "input": {
        "game_id": {
          "type": "string",
          "description": "Game ID from get_games",
          "required": false
        },
        "user_login": {
          "type": "string",
          "description": "Streamer username",
          "required": false
        },
        "language": {
          "type": "string",
          "description": "Language filter e.g. en, ru, de",
          "required": false
        },
        "first": {
          "type": "integer",
          "description": "Number of results",
          "default": 20,
          "max": 100
        }
      },
      "output": {
        "type": "list<stream>",
        "fields": [
          "id",
          "user_name",
          "game_name",
          "title",
          "viewer_count",
          "started_at",
          "thumbnail_url",
          "language"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_games",
      "description_for_ai": "Search for games by name or get top games on Twitch right now.",
      "intent": [
        "top games on twitch",
        "twitch game id",
        "popular games"
      ],
      "endpoint": "GET https://api.twitch.tv/helix/games",
      "input": {
        "name": {
          "type": "string",
          "description": "Game name to search",
          "required": false
        },
        "id": {
          "type": "string",
          "description": "Game ID",
          "required": false
        }
      },
      "output": {
        "type": "list<game>",
        "fields": [
          "id",
          "name",
          "box_art_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}