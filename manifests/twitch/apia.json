{
  "apia": "1.0",
  "service": {
    "id": "twitch",
    "name": "Twitch API (Helix)",
    "description_for_ai": "Twitch game streaming platform API. Get live streams, game info, top streamers, clips, channel data. 140M+ monthly users. Use for finding live streams, game popularity, streamer info.",
    "url": "https://twitch.tv",
    "api_base": "https://api.twitch.tv/helix",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://dev.twitch.tv/docs/api/"
  },
  "auth": {
    "type": "oauth2_client_credentials",
    "anonymous_access": false,
    "how_to_get": "Register app at https://dev.twitch.tv/console",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "get_streams",
      "description_for_ai": "Get live streams on Twitch, filtered by game, language, or specific users.",
      "intent": [
        "Twitch live streams",
        "streams now",
        "who is live Twitch",
        "прямые эфиры Twitch"
      ],
      "endpoint": "GET https://api.twitch.tv/helix/streams",
      "input": {
        "game_id": {
          "type": "string",
          "description": "Filter by game/category ID",
          "required": false
        },
        "user_login": {
          "type": "array",
          "description": "Specific streamers to check",
          "required": false
        },
        "language": {
          "type": "string",
          "description": "ISO 639-1 language code",
          "required": false
        },
        "first": {
          "type": "integer",
          "description": "Max results 1-100",
          "default": 20
        }
      },
      "output": {
        "type": "list<stream>",
        "fields": [
          "data[0].user_name",
          "data[0].game_name",
          "data[0].title",
          "data[0].viewer_count",
          "data[0].started_at",
          "data[0].thumbnail_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_user",
      "description_for_ai": "Get Twitch user profile: display name, description, followers, broadcaster type.",
      "intent": [
        "Twitch user",
        "streamer info",
        "Twitch profile",
        "профиль Twitch"
      ],
      "endpoint": "GET https://api.twitch.tv/helix/users",
      "input": {
        "login": {
          "type": "array",
          "description": "Username(s) to look up",
          "required": false
        },
        "id": {
          "type": "array",
          "description": "User ID(s) to look up",
          "required": false
        }
      },
      "output": {
        "type": "list<user>",
        "fields": [
          "data[0].id",
          "data[0].login",
          "data[0].display_name",
          "data[0].description",
          "data[0].view_count",
          "data[0].broadcaster_type",
          "data[0].profile_image_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_games",
      "description_for_ai": "Get top games/categories on Twitch or search by name.",
      "intent": [
        "top games Twitch",
        "Twitch categories",
        "games list Twitch",
        "категории Twitch"
      ],
      "endpoint": "GET https://api.twitch.tv/helix/games/top",
      "input": {
        "first": {
          "type": "integer",
          "default": 20
        },
        "after": {
          "type": "string",
          "description": "Pagination cursor",
          "required": false
        }
      },
      "output": {
        "type": "list<game>",
        "fields": [
          "data[0].id",
          "data[0].name",
          "data[0].box_art_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_chat_message",
      "description_for_ai": "Send a chat message to a Twitch channel as a bot.",
      "intent": [
        "Twitch chat message",
        "bot message Twitch",
        "send chat Twitch",
        "сообщение в чат Twitch"
      ],
      "endpoint": "POST https://api.twitch.tv/helix/chat/messages",
      "input": {
        "broadcaster_id": {
          "type": "string",
          "description": "Channel owner user ID",
          "required": true
        },
        "sender_id": {
          "type": "string",
          "description": "Bot user ID",
          "required": true
        },
        "message": {
          "type": "string",
          "description": "Message text, max 500 chars",
          "required": true
        },
        "reply_parent_message_id": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "data[0].message_id",
          "data[0].is_sent"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_channel_info",
      "description_for_ai": "Get channel info: game, title, tags, subscriber count.",
      "intent": [
        "channel info Twitch",
        "stream info",
        "channel details",
        "информация о канале Twitch"
      ],
      "endpoint": "GET https://api.twitch.tv/helix/channels",
      "input": {
        "broadcaster_id": {
          "type": "string",
          "description": "Channel owner user ID",
          "required": true
        }
      },
      "output": {
        "type": "channel",
        "fields": [
          "data[0].broadcaster_name",
          "data[0].game_name",
          "data[0].title",
          "data[0].tags",
          "data[0].broadcaster_language"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_clips",
      "description_for_ai": "Get top clips from a Twitch channel or game.",
      "intent": [
        "Twitch clips",
        "best clips",
        "stream clips",
        "клипы Twitch"
      ],
      "endpoint": "GET https://api.twitch.tv/helix/clips",
      "input": {
        "broadcaster_id": {
          "type": "string",
          "description": "Get clips for this channel",
          "required": false
        },
        "game_id": {
          "type": "string",
          "description": "Get clips for this game",
          "required": false
        },
        "first": {
          "type": "integer",
          "default": 20
        },
        "started_at": {
          "type": "string",
          "description": "ISO 8601 date range start",
          "required": false
        }
      },
      "output": {
        "type": "list<clip>",
        "fields": [
          "data[0].id",
          "data[0].title",
          "data[0].view_count",
          "data[0].url",
          "data[0].thumbnail_url",
          "data[0].creator_name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}