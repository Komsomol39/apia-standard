{
  "apia": "1.0",
  "service": {
    "id": "hh-ru",
    "name": "HeadHunter (hh.ru)",
    "description_for_ai": "Крупнейшая российская биржа труда. Используй для поиска вакансий по ключевым словам, городу или координатам пользователя. Возвращает зарплату, работодателя, график работы, опыт. Не требует авторизации для поиска.",
    "url": "https://hh.ru",
    "api_base": "https://api.hh.ru",
    "category": "hr",
    "geo": [
      "RU",
      "BY",
      "KZ",
      "UA",
      "AZ",
      "GE",
      "KG",
      "UZ"
    ],
    "language": "ru",
    "docs": "https://github.com/hhru/api"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": true,
    "anonymous_capabilities": [
      "search_vacancies",
      "get_vacancy",
      "get_areas",
      "get_dictionaries"
    ],
    "auth_required_for": [
      "get_resumes",
      "apply_vacancy",
      "get_negotiations"
    ],
    "oauth_url": "https://hh.ru/oauth/authorize",
    "token_url": "https://hh.ru/oauth/token"
  },
  "capabilities": [
    {
      "id": "search_vacancies",
      "description_for_ai": "Поиск вакансий на hh.ru по тексту, городу, зарплате, опыту и типу занятости.",
      "intent": [
        "вакансии hh.ru",
        "работа hh",
        "найти вакансию",
        "job search hh.ru",
        "поиск работы"
      ],
      "endpoint": "GET https://api.hh.ru/vacancies",
      "input": {
        "text": {
          "type": "string",
          "description": "Ключевые слова для поиска в названии и описании вакансии",
          "required": false
        },
        "area": {
          "type": "integer",
          "description": "ID города. Москва=1, СПб=2, получить все города: GET /areas",
          "required": false
        },
        "salary": {
          "type": "integer",
          "description": "Желаемая зарплата (минимум)",
          "required": false
        },
        "currency": {
          "type": "string",
          "description": "Валюта зарплаты: RUR, USD, EUR",
          "default": "RUR"
        },
        "experience": {
          "type": "string",
          "description": "noExperience, between1And3, between3And6, moreThan6",
          "required": false
        },
        "employment": {
          "type": "string",
          "description": "full — полная, part — частичная, project, volunteer, probation",
          "required": false
        },
        "schedule": {
          "type": "string",
          "description": "fullDay, shift, flexible, remote, flyInFlyOut",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 20
        },
        "page": {
          "type": "integer",
          "default": 0
        }
      },
      "output": {
        "type": "list<vacancy>",
        "fields": [
          "items[0].id",
          "items[0].name",
          "items[0].area.name",
          "items[0].salary.from",
          "items[0].salary.to",
          "items[0].salary.currency",
          "items[0].employer.name",
          "items[0].alternate_url"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_vacancy",
      "description_for_ai": "Получить полное описание вакансии: требования, обязанности, условия, контакты работодателя.",
      "intent": [
        "вакансия hh",
        "описание вакансии",
        "job details hh.ru",
        "требования вакансии"
      ],
      "endpoint": "GET https://api.hh.ru/vacancies/{id}",
      "input": {
        "id": {
          "type": "string",
          "description": "ID вакансии из результатов поиска",
          "required": true
        }
      },
      "output": {
        "type": "vacancy",
        "fields": [
          "id",
          "name",
          "description",
          "salary",
          "employer.name",
          "experience.name",
          "schedule.name",
          "employment.name",
          "key_skills[0].name",
          "contacts.name"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "search_resumes",
      "description_for_ai": "Поиск резюме соискателей (только для работодателей с доступом к базе резюме).",
      "intent": [
        "поиск резюме",
        "кандидаты hh",
        "база резюме",
        "найти соискателя"
      ],
      "endpoint": "GET https://api.hh.ru/resumes",
      "input": {
        "text": {
          "type": "string",
          "required": false
        },
        "area": {
          "type": "integer",
          "required": false
        },
        "salary": {
          "type": "integer",
          "description": "Ожидаемая зарплата кандидата",
          "required": false
        },
        "experience": {
          "type": "string",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<resume>",
        "fields": [
          "items[0].id",
          "items[0].title",
          "items[0].area.name",
          "items[0].salary.amount",
          "items[0].experience[0].company",
          "items[0].alternate_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_areas",
      "description_for_ai": "Получить список регионов и городов с их ID для использования в поиске вакансий.",
      "intent": [
        "города hh",
        "регионы hh",
        "area ids hh",
        "список городов hh.ru"
      ],
      "endpoint": "GET https://api.hh.ru/areas",
      "input": {},
      "output": {
        "type": "list<area>",
        "fields": [
          "[0].id",
          "[0].name",
          "[0].areas[0].id (города в регионе)",
          "[0].areas[0].name"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_dictionaries",
      "description_for_ai": "Получить справочники значений: типы занятости, опыт, расписание, валюты.",
      "intent": [
        "справочники hh",
        "типы вакансий",
        "опыт работы значения",
        "hh dictionaries"
      ],
      "endpoint": "GET https://api.hh.ru/dictionaries",
      "input": {},
      "output": {
        "type": "dictionaries",
        "fields": [
          "experience[0].id",
          "experience[0].name",
          "employment[0].id",
          "schedule[0].id",
          "currency[0].code"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "geo_flow": "Если пользователь говорит 'рядом' — передай lat/lng. Если называет город — сначала get_areas чтобы найти area_id.",
    "salary_tip": "Пользователи часто говорят '50к' — конвертируй в рубли (50000).",
    "pagination": "По умолчанию 20 вакансий. Для большего используй per_page=100 и page."
  },
  "limits": {
    "requests_per_day": 1000,
    "commercial_use": false,
    "attribution_required": true,
    "contact": "api@hh.ru"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}