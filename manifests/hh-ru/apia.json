{
  "apia": "1.0",
  "service": {
    "id": "hh-ru",
    "name": "HeadHunter (hh.ru)",
    "description_for_ai": "Крупнейшая российская биржа труда. Используй для поиска вакансий по ключевым словам, городу или координатам пользователя. Возвращает зарплату, работодателя, график работы, опыт. Не требует авторизации для поиска.",
    "url": "https://hh.ru",
    "api_base": "https://api.hh.ru",
    "category": "employment",
    "geo": [
      "RU",
      "BY",
      "KZ",
      "UA",
      "AZ",
      "GE",
      "KG",
      "UZ"
    ],
    "language": "ru",
    "docs": "https://github.com/hhru/api"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": true,
    "anonymous_capabilities": [
      "search_vacancies",
      "get_vacancy",
      "get_areas",
      "get_dictionaries"
    ],
    "auth_required_for": [
      "get_resumes",
      "apply_vacancy",
      "get_negotiations"
    ],
    "oauth_url": "https://hh.ru/oauth/authorize",
    "token_url": "https://hh.ru/oauth/token"
  },
  "capabilities": [
    {
      "id": "search_vacancies",
      "description_for_ai": "Поиск вакансий по ключевому слову и геолокации. Основной метод для запросов типа 'найди работу Python-разработчика рядом со мной' или 'вакансии курьера в Казани с зарплатой от 50000'.",
      "intent": [
        "найти работу",
        "вакансии рядом",
        "поиск работы",
        "ищу работу",
        "найди вакансии",
        "работа в городе",
        "сколько платят",
        "вакансии с зарплатой"
      ],
      "endpoint": "GET https://api.hh.ru/vacancies",
      "input": {
        "text": {
          "type": "string",
          "description": "Поисковый запрос. Например: 'Python разработчик', 'курьер'",
          "required": false
        },
        "area": {
          "type": "integer",
          "description": "ID региона. Москва=1, СПб=2. Получить через get_areas",
          "required": false
        },
        "lat": {
          "type": "float",
          "description": "Широта пользователя для геопоиска",
          "required": false
        },
        "lng": {
          "type": "float",
          "description": "Долгота пользователя для геопоиска",
          "required": false
        },
        "salary": {
          "type": "integer",
          "description": "Желаемая зарплата в рублях",
          "required": false
        },
        "only_with_salary": {
          "type": "boolean",
          "description": "true — только вакансии с указанной зарплатой",
          "default": false
        },
        "experience": {
          "type": "string",
          "description": "noExperience, between1And3, between3And6, moreThan6",
          "required": false
        },
        "employment": {
          "type": "string",
          "description": "full, part, project, volunteer, probation",
          "required": false
        },
        "schedule": {
          "type": "string",
          "description": "fullDay, shift, flexible, remote, flyInFlyOut",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 20,
          "max": 100,
          "description": "Results per page. Check API docs for maximum allowed."
        },
        "page": {
          "type": "integer",
          "default": 0,
          "description": "Page number for pagination (1-indexed)"
        }
      },
      "output": {
        "type": "list<vacancy>",
        "fields": [
          "id",
          "name",
          "area.name",
          "salary.from",
          "salary.to",
          "salary.currency",
          "employer.name",
          "experience.name",
          "schedule.name",
          "url",
          "published_at"
        ]
      },
      "realtime": true,
      "requires_auth": false,
      "rate_limit": "1000/day"
    },
    {
      "id": "get_vacancy",
      "description_for_ai": "Полное описание вакансии по ID. Используй после search_vacancies когда пользователь хочет подробности: требования, описание, адрес офиса, контакты.",
      "intent": [
        "подробнее о вакансии",
        "что требуется",
        "описание вакансии",
        "адрес офиса"
      ],
      "endpoint": "GET https://api.hh.ru/vacancies/{vacancy_id}",
      "input": {
        "vacancy_id": {
          "type": "string",
          "description": "ID вакансии из search_vacancies",
          "required": true
        }
      },
      "output": {
        "type": "vacancy",
        "fields": [
          "name",
          "description",
          "key_skills",
          "employer.name",
          "employer.url",
          "salary",
          "experience",
          "schedule",
          "employment",
          "address.raw",
          "contacts",
          "published_at"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_areas",
      "description_for_ai": "Get hierarchical list of geographic areas available for job search: countries, regions, cities with their IDs.",
      "intent": [
        "найти ID города",
        "список городов",
        "регионы России"
      ],
      "endpoint": "GET https://api.hh.ru/areas",
      "input": {},
      "output": {
        "type": "list<area>",
        "fields": [
          "id",
          "name",
          "areas"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_dictionaries",
      "description_for_ai": "Get reference dictionaries: employment types, experience levels, salary currencies, schedule types, and other field options.",
      "intent": [
        "какие есть фильтры",
        "типы занятости",
        "варианты опыта"
      ],
      "endpoint": "GET https://api.hh.ru/dictionaries",
      "input": {},
      "output": {
        "type": "dictionaries",
        "fields": [
          "experience",
          "employment",
          "schedule",
          "currency"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_employer",
      "description_for_ai": "Информация о работодателе: описание, сайт, количество вакансий. Используй когда пользователь хочет узнать больше о компании.",
      "intent": [
        "что за компания",
        "о работодателе",
        "сайт компании"
      ],
      "endpoint": "GET https://api.hh.ru/employers/{employer_id}",
      "input": {
        "employer_id": {
          "type": "string",
          "description": "ID работодателя из данных вакансии",
          "required": true
        }
      },
      "output": {
        "type": "employer",
        "fields": [
          "name",
          "description",
          "site_url",
          "open_vacancies",
          "area.name"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "geo_flow": "Если пользователь говорит 'рядом' — передай lat/lng. Если называет город — сначала get_areas чтобы найти area_id.",
    "salary_tip": "Пользователи часто говорят '50к' — конвертируй в рубли (50000).",
    "pagination": "По умолчанию 20 вакансий. Для большего используй per_page=100 и page."
  },
  "limits": {
    "requests_per_day": 1000,
    "commercial_use": false,
    "attribution_required": true,
    "contact": "api@hh.ru"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}