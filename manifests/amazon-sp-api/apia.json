{
  "apia": "1.0",
  "service": {
    "id": "amazon-sp-api",
    "name": "Amazon Selling Partner API (SP-API)",
    "description_for_ai": "Amazon marketplace seller API. Manage listings, inventory, orders, pricing, FBA shipments, advertising. Access Amazon marketplace data for your seller account. 300M+ customers globally.",
    "url": "https://developer.amazonservices.com",
    "api_base": "https://sellingpartnerapi-na.amazon.com",
    "category": "ecommerce",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer-docs.amazon.com/sp-api/"
  },
  "auth": {
    "type": "oauth2_lwa",
    "anonymous_access": false,
    "how_to_get": "Register at https://developer-docs.amazon.com/sp-api/docs/registering-as-a-developer",
    "cost": "Free API. Amazon seller account required."
  },
  "capabilities": [
    {
      "id": "search_catalog_items",
      "description_for_ai": "Search Amazon product catalog by keywords, ASIN, EAN, UPC.",
      "intent": [
        "Amazon search",
        "product search Amazon",
        "ASIN lookup",
        "поиск товаров Amazon"
      ],
      "endpoint": "GET https://sellingpartnerapi-na.amazon.com/catalog/2022-04-01/items",
      "input": {
        "keywords": {
          "type": "array",
          "description": "Search keywords",
          "required": false
        },
        "identifiers": {
          "type": "array",
          "description": "ASINs, EANs, UPCs",
          "required": false
        },
        "identifiersType": {
          "type": "string",
          "description": "ASIN, EAN, UPC, GTIN, ISBN, JAN",
          "required": false
        },
        "marketplaceIds": {
          "type": "array",
          "description": "e.g. ATVPDKIKX0DER (US), A1F83G8C2ARO7P (UK)",
          "required": true
        },
        "includedData": {
          "type": "string",
          "description": "attributes, identifiers, images, productTypes, salesRanks, summaries",
          "required": false
        }
      },
      "output": {
        "type": "list<item>",
        "fields": [
          "items[0].asin",
          "items[0].summaries[0].itemName",
          "items[0].salesRanks[0].classificationRanks[0].rank"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_orders",
      "description_for_ai": "Get seller orders from Amazon Marketplace with status filtering.",
      "intent": [
        "Amazon orders",
        "seller orders Amazon",
        "order management",
        "заказы Amazon"
      ],
      "endpoint": "GET https://sellingpartnerapi-na.amazon.com/orders/v0/orders",
      "input": {
        "MarketplaceIds": {
          "type": "array",
          "description": "Marketplace IDs",
          "required": true
        },
        "CreatedAfter": {
          "type": "string",
          "description": "ISO 8601 date",
          "required": false
        },
        "OrderStatuses": {
          "type": "array",
          "description": "Pending, Unshipped, PartiallyShipped, Shipped, Canceled",
          "required": false
        },
        "MaxResultsPerPage": {
          "type": "integer",
          "default": 100
        }
      },
      "output": {
        "type": "list<order>",
        "fields": [
          "Orders[0].AmazonOrderId",
          "Orders[0].OrderStatus",
          "Orders[0].OrderTotal.Amount",
          "Orders[0].BuyerInfo.BuyerEmail",
          "Orders[0].PurchaseDate"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_inventory",
      "description_for_ai": "Get FBA inventory levels for seller SKUs.",
      "intent": [
        "Amazon inventory",
        "FBA stock",
        "inventory levels Amazon",
        "инвентарь Amazon FBA"
      ],
      "endpoint": "GET https://sellingpartnerapi-na.amazon.com/fba/inventory/v1/summaries",
      "input": {
        "granularityType": {
          "type": "string",
          "default": "Marketplace"
        },
        "granularityId": {
          "type": "string",
          "description": "Marketplace ID",
          "required": true
        },
        "marketplaceIds": {
          "type": "array",
          "required": true
        },
        "sellerSkus": {
          "type": "array",
          "description": "Filter by SKUs",
          "required": false
        }
      },
      "output": {
        "type": "list<inventory>",
        "fields": [
          "inventorySummaries[0].asin",
          "inventorySummaries[0].sellerSku",
          "inventorySummaries[0].inventoryDetails.fulfillableQuantity"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_pricing",
      "description_for_ai": "Get competitive pricing data for Amazon products.",
      "intent": [
        "Amazon pricing",
        "product price Amazon",
        "competitor price",
        "цена Amazon"
      ],
      "endpoint": "GET https://sellingpartnerapi-na.amazon.com/products/pricing/v0/competitivePrice",
      "input": {
        "Asin": {
          "type": "array",
          "description": "ASINs to price check",
          "required": true
        },
        "MarketplaceId": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<pricing>",
        "fields": [
          "Product[0].ASIN",
          "Product[0].CompetitivePricing.CompetitivePrices[0].Price.LandedPrice.Amount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_shipment",
      "description_for_ai": "Create an FBA shipment plan to Amazon fulfillment centers.",
      "intent": [
        "FBA shipment",
        "Amazon shipping",
        "send to Amazon warehouse",
        "отправить на Amazon FBA"
      ],
      "endpoint": "POST https://sellingpartnerapi-na.amazon.com/fba/inbound/v0/plans",
      "input": {
        "ShipFromAddress": {
          "type": "object",
          "description": "{Name, AddressLine1, City, StateOrProvinceCode, PostalCode, CountryCode}",
          "required": true
        },
        "InboundShipmentPlanRequestItems": {
          "type": "array",
          "description": "[{SellerSKU, ASIN, Condition, Quantity}]",
          "required": true
        },
        "LabelPrepPreference": {
          "type": "string",
          "description": "SELLER_LABEL or AMAZON_LABEL_ONLY",
          "required": true
        }
      },
      "output": {
        "type": "shipment_plan",
        "fields": [
          "InboundShipmentPlans[0].ShipmentId",
          "InboundShipmentPlans[0].DestinationFulfillmentCenterId"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "auth": "Requires LWA (Login with Amazon) OAuth. Get refresh token via Seller Central. Exchange for access token every hour.",
    "marketplaces": "US=ATVPDKIKX0DER, CA=A2EUQ1WTGCTBG2, UK=A1F83G8C2ARO7P, DE=A1PA6795UKMFR9, FR=A13V1IB3VIYZZH, JP=A1VC38T7YXB528",
    "throttling": "SP-API uses token bucket throttling. Rate varies by endpoint. Implement exponential backoff on 429s.",
    "sandbox": "Test with sandbox endpoint: https://sandbox.sellingpartnerapi-na.amazon.com"
  }
}