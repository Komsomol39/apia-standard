{
  "apia": "1.0",
  "service": {
    "id": "amazon-sp-api",
    "name": "Amazon Selling Partner API (SP-API)",
    "description_for_ai": "Amazon marketplace seller API. Manage listings, inventory, orders, pricing, FBA shipments, advertising. Access Amazon marketplace data for your seller account. 300M+ customers globally.",
    "url": "https://developer.amazonservices.com",
    "api_base": "https://sellingpartnerapi-na.amazon.com",
    "category": "ecommerce",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer-docs.amazon.com/sp-api/"
  },
  "auth": {
    "type": "oauth2_lwa",
    "anonymous_access": false,
    "how_to_get": "Register at https://developer-docs.amazon.com/sp-api/docs/registering-as-a-developer",
    "cost": "Free API. Amazon seller account required."
  },
  "capabilities": [
    {
      "id": "get_orders",
      "description_for_ai": "Get orders from Amazon seller account. Returns order status, items, shipping info.",
      "intent": [
        "amazon orders",
        "seller orders",
        "marketplace orders",
        "fulfillment orders",
        "Amazon sales"
      ],
      "endpoint": "GET https://sellingpartnerapi-na.amazon.com/orders/v0/orders",
      "input": {
        "MarketplaceIds": {
          "type": "string",
          "description": "Marketplace ID. US=ATVPDKIKX0DER, UK=A1F83G8C2ARO7P",
          "required": true
        },
        "CreatedAfter": {
          "type": "string",
          "description": "ISO 8601 date filter",
          "required": false
        },
        "OrderStatuses": {
          "type": "string",
          "description": "Pending, Unshipped, Shipped, Canceled",
          "required": false
        }
      },
      "output": {
        "type": "list<order>",
        "fields": [
          "Orders[0].AmazonOrderId",
          "Orders[0].OrderStatus",
          "Orders[0].OrderTotal",
          "Orders[0].ShipmentServiceLevelCategory",
          "Orders[0].BuyerInfo"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_catalog_item",
      "description_for_ai": "Get product details from Amazon catalog by ASIN.",
      "intent": [
        "product info Amazon",
        "ASIN details",
        "product listing",
        "Amazon catalog"
      ],
      "endpoint": "GET https://sellingpartnerapi-na.amazon.com/catalog/2022-04-01/items/{asin}",
      "input": {
        "asin": {
          "type": "string",
          "description": "Amazon ASIN",
          "required": true
        },
        "marketplaceIds": {
          "type": "string",
          "required": true
        },
        "includedData": {
          "type": "string",
          "description": "attributes, dimensions, images, productTypes, summaries",
          "required": false
        }
      },
      "output": {
        "type": "catalog_item",
        "fields": [
          "asin",
          "summaries[0].itemName",
          "summaries[0].brand",
          "summaries[0].manufacturer",
          "images[0].images[0].link"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "auth": "Requires LWA (Login with Amazon) OAuth. Get refresh token via Seller Central. Exchange for access token every hour.",
    "marketplaces": "US=ATVPDKIKX0DER, CA=A2EUQ1WTGCTBG2, UK=A1F83G8C2ARO7P, DE=A1PA6795UKMFR9, FR=A13V1IB3VIYZZH, JP=A1VC38T7YXB528",
    "throttling": "SP-API uses token bucket throttling. Rate varies by endpoint. Implement exponential backoff on 429s.",
    "sandbox": "Test with sandbox endpoint: https://sandbox.sellingpartnerapi-na.amazon.com"
  }
}