{
  "apia": "1.0",
  "service": {
    "id": "notion-api",
    "name": "Notion API",
    "description_for_ai": "Notion workspace API. Read and write pages, databases, blocks. Create documents, manage tasks, query databases. 30M+ users. Use for note-taking apps, project management, knowledge bases, documentation tools.",
    "url": "https://notion.so",
    "api_base": "https://api.notion.com/v1",
    "category": "productivity",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.notion.com/reference/intro"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer {token}",
    "how_to_get": "Create integration at https://www.notion.so/my-integrations",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "query_database",
      "description_for_ai": "Query a Notion database with filters and sorts. Returns pages matching criteria with all their properties. The database must be shared with your integration.",
      "intent": [
        "notion database query",
        "get notion records",
        "filter notion",
        "search notion database",
        "notion tasks",
        "notion projects",
        "notion CRM"
      ],
      "endpoint": "POST https://api.notion.com/v1/databases/{database_id}/query",
      "input": {
        "database_id": {
          "type": "string",
          "description": "Database ID from Notion URL (32-char hex or UUID format)",
          "required": true
        },
        "filter": {
          "type": "object",
          "description": "Filter object: {property: 'Status', select: {equals: 'Done'}} or {and: [{property: ...}, {property: ...}]} for multiple",
          "required": false
        },
        "sorts": {
          "type": "array",
          "description": "[{property: 'Created', direction: 'descending'}] or [{timestamp: 'created_time', direction: 'ascending'}]",
          "required": false
        },
        "page_size": {
          "type": "integer",
          "description": "Results per page, max 100",
          "default": 100
        },
        "start_cursor": {
          "type": "string",
          "description": "Pagination cursor from previous response's next_cursor",
          "required": false
        }
      },
      "output": {
        "type": "list<page>",
        "fields": [
          "results[0].id",
          "results[0].properties",
          "results[0].url",
          "has_more",
          "next_cursor"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_page",
      "description_for_ai": "Create a new page in a Notion database or as a subpage. Set properties and add content blocks.",
      "intent": [
        "create notion page",
        "add to notion database",
        "new notion entry",
        "write to notion",
        "add task notion"
      ],
      "endpoint": "POST https://api.notion.com/v1/pages",
      "input": {
        "parent": {
          "type": "object",
          "description": "{database_id: 'uuid'} to create in database, or {page_id: 'uuid'} for subpage",
          "required": true
        },
        "properties": {
          "type": "object",
          "description": "Page properties matching database schema. Title: {Name: {title: [{text: {content: 'My Page'}}]}}. Select: {Status: {select: {name: 'Done'}}}. Date: {Due: {date: {start: '2024-01-15'}}}",
          "required": true
        },
        "children": {
          "type": "array",
          "description": "Page content blocks: [{object: 'block', type: 'paragraph', paragraph: {rich_text: [{text: {content: 'Hello'}}]}}]",
          "required": false
        },
        "icon": {
          "type": "object",
          "description": "{type: 'emoji', emoji: '✅'} or {type: 'external', external: {url: 'https://...'}} — page icon",
          "required": false
        },
        "cover": {
          "type": "object",
          "description": "{type: 'external', external: {url: 'https://image.url'}} — page cover image",
          "required": false
        }
      },
      "output": {
        "type": "page",
        "fields": [
          "id",
          "url",
          "properties",
          "created_time"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search",
      "description_for_ai": "Search pages and databases in the Notion workspace by keyword. Returns titles and URLs of matching pages.",
      "intent": [
        "search notion",
        "find notion page",
        "look up note",
        "notion search"
      ],
      "endpoint": "POST https://api.notion.com/v1/search",
      "input": {
        "query": {
          "type": "string",
          "description": "Text to search for in page titles",
          "required": false
        },
        "filter": {
          "type": "object",
          "description": "{property: 'object', value: 'page'} to filter pages only, or 'database' for databases only",
          "required": false
        },
        "sort": {
          "type": "object",
          "description": "{direction: 'ascending'|'descending', timestamp: 'last_edited_time'}",
          "required": false
        },
        "page_size": {
          "type": "integer",
          "default": 20
        }
      },
      "output": {
        "type": "list<result>",
        "fields": [
          "results[0].object",
          "results[0].id",
          "results[0].url",
          "results[0].properties.title"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}