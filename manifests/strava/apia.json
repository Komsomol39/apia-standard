{
  "apia": "1.0",
  "service": {
    "id": "strava",
    "name": "Strava API",
    "description_for_ai": "Social fitness platform API. Access running, cycling, swimming activities. Segments, leaderboards, athlete stats, route data. Used by 120M+ athletes. Use for fitness apps, activity tracking, social fitness features.",
    "url": "https://strava.com",
    "api_base": "https://www.strava.com/api/v3",
    "category": "sports",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.strava.com/docs/reference/"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Register app at https://www.strava.com/settings/api",
    "cost": "Free: 100 req/15min, 1000 req/day"
  },
  "capabilities": [
    {
      "id": "get_activities",
      "description_for_ai": "Get athlete activities: runs, rides, swims with distance, pace, elevation, heart rate.",
      "intent": [
        "running activities",
        "strava workouts",
        "fitness activities",
        "my runs",
        "cycling data",
        "workout history"
      ],
      "endpoint": "GET https://www.strava.com/api/v3/athlete/activities",
      "input": {
        "before": {
          "type": "integer",
          "description": "Unix timestamp upper bound",
          "required": false
        },
        "after": {
          "type": "integer",
          "description": "Unix timestamp lower bound",
          "required": false
        },
        "page": {
          "type": "integer",
          "default": 1,
          "description": "Page number for pagination (1-indexed)"
        },
        "per_page": {
          "type": "integer",
          "default": 30,
          "max": 200,
          "description": "Results per page. Check API docs for maximum allowed."
        }
      },
      "output": {
        "type": "list<activity>",
        "fields": [
          "id",
          "name",
          "type",
          "distance",
          "moving_time",
          "elapsed_time",
          "total_elevation_gain",
          "average_speed",
          "average_heartrate",
          "start_date",
          "map.summary_polyline"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_activity",
      "description_for_ai": "Get detailed info about a specific Strava activity including splits, laps, best efforts.",
      "intent": [
        "activity details",
        "run details",
        "workout stats",
        "strava activity"
      ],
      "endpoint": "GET https://www.strava.com/api/v3/activities/{id}",
      "input": {
        "id": {
          "type": "integer",
          "required": true,
          "description": "Unique identifier"
        }
      },
      "output": {
        "type": "activity",
        "fields": [
          "name",
          "type",
          "distance",
          "moving_time",
          "average_speed",
          "average_heartrate",
          "max_heartrate",
          "calories",
          "splits_metric",
          "best_efforts"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_athlete_stats",
      "description_for_ai": "Get athlete all-time and recent stats: total distance, elevation, time for running/cycling/swimming.",
      "intent": [
        "total mileage",
        "lifetime stats",
        "running total",
        "athlete statistics"
      ],
      "endpoint": "GET https://www.strava.com/api/v3/athletes/{id}/stats",
      "input": {
        "id": {
          "type": "integer",
          "description": "Athlete ID from token",
          "required": true
        }
      },
      "output": {
        "type": "stats",
        "fields": [
          "all_run_totals.distance",
          "all_run_totals.elapsed_time",
          "all_ride_totals.distance",
          "recent_run_totals"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "distance": "Distance in meters — divide by 1000 for km or 1609.34 for miles.",
    "pace": "Speed in m/s — use 1000/(speed*60) for min/km pace."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}