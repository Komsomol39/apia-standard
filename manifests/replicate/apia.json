{
  "apia": "1.0",
  "service": {
    "id": "replicate",
    "name": "Replicate API",
    "description_for_ai": "Run 1000+ open-source AI models via API. Images, video, audio, text, 3D. Includes Flux, SDXL, Llama, Whisper, LLaVA and many more. Pay per second of compute. Best for accessing specialized models.",
    "url": "https://replicate.com",
    "api_base": "https://api.replicate.com/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://replicate.com/docs/reference/http"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Token r8_...",
    "how_to_get": "Register at https://replicate.com",
    "cost": "Pay per second. Varies by model."
  },
  "capabilities": [
    {
      "id": "run_model",
      "description_for_ai": "Run any Replicate ML model by name. Access 100,000+ models including Stable Diffusion, Llama, Whisper.",
      "intent": [
        "run ML model",
        "Replicate model",
        "AI model API",
        "запустить модель Replicate"
      ],
      "endpoint": "POST https://api.replicate.com/v1/predictions",
      "input": {
        "version": {
          "type": "string",
          "description": "Model version ID from Replicate: stability-ai/sdxl:7762fd07...",
          "required": true
        },
        "input": {
          "type": "object",
          "description": "Model-specific inputs (see model docs for parameters)",
          "required": true
        }
      },
      "output": {
        "type": "prediction",
        "fields": [
          "id",
          "status",
          "urls.get (poll URL)",
          "output (when complete)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_prediction",
      "description_for_ai": "Check status and get output of a Replicate prediction.",
      "intent": [
        "prediction status Replicate",
        "get model output",
        "poll prediction",
        "статус предсказания Replicate"
      ],
      "endpoint": "GET https://api.replicate.com/v1/predictions/{prediction_id}",
      "input": {
        "prediction_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "prediction",
        "fields": [
          "id",
          "status (starting/processing/succeeded/failed/canceled)",
          "output",
          "error",
          "metrics.predict_time"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_models",
      "description_for_ai": "Browse and search available models on Replicate.",
      "intent": [
        "Replicate models",
        "find AI model",
        "browse models",
        "модели Replicate"
      ],
      "endpoint": "GET https://api.replicate.com/v1/models",
      "input": {},
      "output": {
        "type": "list<model>",
        "fields": [
          "results[0].url",
          "results[0].owner",
          "results[0].name",
          "results[0].description",
          "results[0].run_count",
          "results[0].latest_version.id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "run_image_generation",
      "description_for_ai": "Generate images with SDXL or FLUX on Replicate.",
      "intent": [
        "generate image Replicate",
        "SDXL Replicate",
        "FLUX image",
        "генерация изображений Replicate"
      ],
      "endpoint": "POST https://api.replicate.com/v1/models/{owner}/{name}/predictions",
      "input": {
        "owner": {
          "type": "string",
          "description": "black-forest-labs for FLUX, stability-ai for SDXL",
          "required": true
        },
        "name": {
          "type": "string",
          "description": "flux-schnell, sdxl",
          "required": true
        },
        "input": {
          "type": "object",
          "description": "{prompt: 'text description', num_outputs: 1, width: 1024, height: 1024}",
          "required": true
        }
      },
      "output": {
        "type": "prediction",
        "fields": [
          "id",
          "status",
          "output (image URLs when complete)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "cancel_prediction",
      "description_for_ai": "Cancel a running prediction on Replicate.",
      "intent": [
        "cancel prediction",
        "stop model run",
        "отменить предсказание Replicate"
      ],
      "endpoint": "POST https://api.replicate.com/v1/predictions/{prediction_id}/cancel",
      "input": {
        "prediction_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "prediction",
        "fields": [
          "id",
          "status (canceled)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "popular_models": "black-forest-labs/flux-schnell (images), stability-ai/sdxl, meta/llama-3-8b-instruct, openai/whisper",
    "async": "Large models return prediction ID — poll GET /predictions/{id} for result."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}