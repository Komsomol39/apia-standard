{
  "apia": "1.0",
  "service": {
    "id": "tinkoff-acquiring",
    "name": "Тинькофф Эквайринг API",
    "description_for_ai": "Платёжный шлюз Тинькофф банка. Приём платежей картами, СБП, рассрочка. Популярен среди российских интернет-магазинов. Интеграция с Tinkoff Pay.",
    "url": "https://www.tinkoff.ru/kassa/",
    "api_base": "https://securepay.tinkoff.ru/v2",
    "category": "payments",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://www.tinkoff.ru/kassa/develop/api/payments/"
  },
  "auth": {
    "type": "password",
    "anonymous_access": false,
    "note": "TerminalKey + пароль для подписи запросов",
    "how_to_get": "Личный кабинет → Интернет-эквайринг → Настройки терминала",
    "cost": "Комиссия 1.5-2.9%"
  },
  "capabilities": [
    {
      "id": "init_payment",
      "description_for_ai": "Платёжный шлюз Тинькофф банка. Приём платежей картами, СБП, рассрочка. Популярен среди российских интернет-магазинов. Интеграция с Tinkoff Pay. Инициировать платёж. Возвращает PaymentURL для перехода на страницу оплаты Тинькофф.",
      "intent": [
        "оплата Тинькофф",
        "платёж картой",
        "интернет-эквайринг Тинькофф",
        "принять оплату"
      ],
      "endpoint": "POST https://securepay.tinkoff.ru/v2/Init",
      "input": {
        "TerminalKey": {
          "type": "string",
          "required": true
        },
        "Amount": {
          "type": "integer",
          "description": "Сумма в копейках. 10000 = 100 рублей",
          "required": true
        },
        "OrderId": {
          "type": "string",
          "description": "Уникальный ID заказа",
          "required": true
        },
        "Description": {
          "type": "string",
          "required": false
        },
        "SuccessURL": {
          "type": "string",
          "required": false
        },
        "FailURL": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "payment",
        "fields": [
          "PaymentId",
          "Status",
          "PaymentURL"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}