{
  "apia": "1.0",
  "service": {
    "id": "tinkoff-acquiring",
    "name": "Тинькофф Эквайринг API",
    "description_for_ai": "Платёжный шлюз Тинькофф банка для приёма онлайн-платежей. Поддерживает карты Visa/Mastercard/МИР, Tinkoff Pay, СБП (Система быстрых платежей), BNPL (купи сейчас, плати потом). Популярен среди российских интернет-магазинов и сервисов. Не требует абонентской платы.",
    "url": "https://www.tinkoff.ru/kassa/",
    "api_base": "https://securepay.tinkoff.ru/v2",
    "category": "finance",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://www.tinkoff.ru/kassa/develop/api/payments/"
  },
  "auth": {
    "type": "password",
    "anonymous_access": false,
    "note": "TerminalKey + пароль для подписи запросов",
    "how_to_get": "Личный кабинет → Интернет-эквайринг → Настройки терминала",
    "cost": "Комиссия 1.5-2.9%"
  },
  "capabilities": [
    {
      "id": "init_payment",
      "description_for_ai": "Initialize a Tinkoff payment and get a payment URL for the customer.",
      "intent": [
        "Tinkoff payment",
        "оплата Тинькофф",
        "платёж Тинькофф",
        "Tinkoff эквайринг"
      ],
      "endpoint": "POST https://securepay.tinkoff.ru/v2/Init",
      "input": {
        "TerminalKey": {
          "type": "string",
          "description": "Your terminal key",
          "required": true
        },
        "Amount": {
          "type": "integer",
          "description": "Amount in kopecks: 1000 = 10 rubles",
          "required": true
        },
        "OrderId": {
          "type": "string",
          "description": "Your unique order ID",
          "required": true
        },
        "Description": {
          "type": "string",
          "description": "Payment description shown to customer",
          "required": false
        },
        "CustomerKey": {
          "type": "string",
          "description": "Customer ID for recurring payments",
          "required": false
        },
        "Recurrent": {
          "type": "string",
          "description": "Y to setup recurring",
          "required": false
        }
      },
      "output": {
        "type": "payment",
        "fields": [
          "PaymentId",
          "Status",
          "PaymentURL (redirect customer here)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_payment_state",
      "description_for_ai": "Get current payment status.",
      "intent": [
        "payment status Tinkoff",
        "статус платежа Тинькофф",
        "проверить оплату Тинькофф"
      ],
      "endpoint": "POST https://securepay.tinkoff.ru/v2/GetState",
      "input": {
        "TerminalKey": {
          "type": "string",
          "required": true
        },
        "PaymentId": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "payment",
        "fields": [
          "PaymentId",
          "Status (NEW/FORM_SHOWED/3DS_CHECKING/CONFIRMED/REJECTED/REFUNDED)",
          "Amount",
          "OrderId"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "confirm_payment",
      "description_for_ai": "Confirm a two-step payment (authorize then confirm).",
      "intent": [
        "confirm payment Tinkoff",
        "двухэтапный платёж Тинькофф",
        "подтвердить платёж"
      ],
      "endpoint": "POST https://securepay.tinkoff.ru/v2/Confirm",
      "input": {
        "TerminalKey": {
          "type": "string",
          "required": true
        },
        "PaymentId": {
          "type": "string",
          "required": true
        },
        "Amount": {
          "type": "integer",
          "description": "Amount to confirm in kopecks",
          "required": false
        }
      },
      "output": {
        "type": "payment",
        "fields": [
          "PaymentId",
          "Status",
          "Success"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "refund",
      "description_for_ai": "Refund a Tinkoff payment fully or partially.",
      "intent": [
        "refund Tinkoff",
        "возврат Тинькофф",
        "отменить платёж Тинькофф"
      ],
      "endpoint": "POST https://securepay.tinkoff.ru/v2/Cancel",
      "input": {
        "TerminalKey": {
          "type": "string",
          "required": true
        },
        "PaymentId": {
          "type": "string",
          "required": true
        },
        "Amount": {
          "type": "integer",
          "description": "Partial refund amount in kopecks. Omit for full refund.",
          "required": false
        }
      },
      "output": {
        "type": "refund",
        "fields": [
          "PaymentId",
          "Status",
          "OriginalAmount",
          "NewAmount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "charge_recurring",
      "description_for_ai": "Charge a recurring payment using a saved customer token.",
      "intent": [
        "recurring payment Tinkoff",
        "повторный платёж Тинькофф",
        "рекуррентный платёж"
      ],
      "endpoint": "POST https://securepay.tinkoff.ru/v2/Charge",
      "input": {
        "TerminalKey": {
          "type": "string",
          "required": true
        },
        "PaymentId": {
          "type": "string",
          "description": "Payment ID from Init with Recurrent=Y",
          "required": true
        },
        "RebillId": {
          "type": "string",
          "description": "Token from previous payment notification",
          "required": true
        }
      },
      "output": {
        "type": "payment",
        "fields": [
          "PaymentId",
          "Status",
          "Amount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}