{
  "apia": "1.0",
  "service": {
    "id": "tinkoff-acquiring",
    "name": "Тинькофф Эквайринг API",
    "description_for_ai": "Платёжный шлюз Тинькофф банка для приёма онлайн-платежей. Поддерживает карты Visa/Mastercard/МИР, Tinkoff Pay, СБП (Система быстрых платежей), BNPL (купи сейчас, плати потом). Популярен среди российских интернет-магазинов и сервисов. Не требует абонентской платы.",
    "url": "https://www.tinkoff.ru/kassa/",
    "api_base": "https://securepay.tinkoff.ru/v2",
    "category": "finance",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://www.tinkoff.ru/kassa/develop/api/payments/"
  },
  "auth": {
    "type": "password",
    "anonymous_access": false,
    "note": "TerminalKey + пароль для подписи запросов",
    "how_to_get": "Личный кабинет → Интернет-эквайринг → Настройки терминала",
    "cost": "Комиссия 1.5-2.9%"
  },
  "capabilities": [
    {
      "id": "init_payment",
      "description_for_ai": "Инициировать платёж через Тинькофф эквайринг. Возвращает ссылку на страницу оплаты.",
      "intent": [
        "тинькофф эквайринг",
        "оплата тинькофф",
        "tinkoff payment",
        "платёж тинькофф банк"
      ],
      "endpoint": "POST https://securepay.tinkoff.ru/v2/Init",
      "input": {
        "TerminalKey": {
          "type": "string",
          "description": "Ключ терминала из личного кабинета",
          "required": true
        },
        "Amount": {
          "type": "integer",
          "description": "Сумма в копейках (100 = 1 рубль)",
          "required": true
        },
        "OrderId": {
          "type": "string",
          "description": "Уникальный идентификатор заказа в вашей системе",
          "required": true
        },
        "Description": {
          "type": "string",
          "description": "Описание заказа",
          "required": false
        },
        "SuccessURL": {
          "type": "string",
          "description": "URL для редиректа после успешной оплаты",
          "required": false
        },
        "FailURL": {
          "type": "string",
          "description": "URL для редиректа при отказе",
          "required": false
        },
        "Receipt": {
          "type": "object",
          "description": "{Email, Taxation: 'osn', Items: [{Name, Price, Quantity, Amount, Tax: 'vat20'}]}",
          "required": false
        }
      },
      "output": {
        "type": "payment",
        "fields": [
          "Success",
          "PaymentURL",
          "PaymentId",
          "Status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_payment_state",
      "description_for_ai": "Получить статус платежа по PaymentId.",
      "intent": [
        "статус платежа тинькофф",
        "проверить оплату тинькофф",
        "tinkoff payment status"
      ],
      "endpoint": "POST https://securepay.tinkoff.ru/v2/GetState",
      "input": {
        "TerminalKey": {
          "type": "string",
          "required": true
        },
        "PaymentId": {
          "type": "string",
          "description": "ID платежа из Init ответа",
          "required": true
        },
        "Token": {
          "type": "string",
          "description": "SHA-256 подпись запроса",
          "required": true
        }
      },
      "output": {
        "type": "payment",
        "fields": [
          "Success",
          "PaymentId",
          "Status",
          "Amount",
          "OrderId"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "cancel_payment",
      "description_for_ai": "Отменить платёж или выполнить возврат через Тинькофф эквайринг.",
      "intent": [
        "отмена тинькофф",
        "возврат тинькофф",
        "tinkoff refund",
        "cancel tinkoff payment"
      ],
      "endpoint": "POST https://securepay.tinkoff.ru/v2/Cancel",
      "input": {
        "TerminalKey": {
          "type": "string",
          "required": true
        },
        "PaymentId": {
          "type": "string",
          "required": true
        },
        "Amount": {
          "type": "integer",
          "description": "Сумма возврата в копейках. Если не указана — полный возврат.",
          "required": false
        },
        "Token": {
          "type": "string",
          "description": "SHA-256 подпись",
          "required": true
        }
      },
      "output": {
        "type": "cancel",
        "fields": [
          "Success",
          "PaymentId",
          "Status",
          "OriginalAmount",
          "NewAmount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "confirm_payment",
      "description_for_ai": "Подтвердить двухстадийный платёж (2-step). Списать предавторизованные средства.",
      "intent": [
        "подтвердить платёж тинькофф",
        "двухстадийная оплата",
        "confirm tinkoff",
        "capture tinkoff"
      ],
      "endpoint": "POST https://securepay.tinkoff.ru/v2/Confirm",
      "input": {
        "TerminalKey": {
          "type": "string",
          "required": true
        },
        "PaymentId": {
          "type": "string",
          "required": true
        },
        "Amount": {
          "type": "integer",
          "description": "Сумма для списания (может быть меньше авторизованной)",
          "required": false
        },
        "Token": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "confirm",
        "fields": [
          "Success",
          "PaymentId",
          "Status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}