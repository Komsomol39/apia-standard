{
  "apia": "1.0",
  "service": {
    "id": "open-trivia",
    "name": "Open Trivia Database API",
    "description_for_ai": "Free trivia questions API. 4000+ verified questions across 24 categories. Multiple difficulty levels. No API key needed. Use for quiz games, trivia apps, educational games.",
    "url": "https://opentdb.com",
    "api_base": "https://opentdb.com",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://opentdb.com/api_config.php"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free forever"
  },
  "capabilities": [
    {
      "id": "get_questions",
      "description_for_ai": "Get trivia questions by category, difficulty, and type.",
      "intent": [
        "trivia questions",
        "quiz questions",
        "general knowledge",
        "вопросы викторины"
      ],
      "endpoint": "GET https://opentdb.com/api.php",
      "input": {
        "amount": {
          "type": "integer",
          "description": "Number of questions 1-50",
          "default": 10
        },
        "category": {
          "type": "integer",
          "description": "9=General Knowledge, 10=Books, 11=Film, 12=Music, 17=Science, 21=Sports, 23=History, 27=Animals",
          "required": false
        },
        "difficulty": {
          "type": "string",
          "description": "easy, medium, hard",
          "required": false
        },
        "type": {
          "type": "string",
          "description": "multiple (multiple choice), boolean (True/False)",
          "required": false
        },
        "encode": {
          "type": "string",
          "description": "url3986 or base64 for special characters",
          "required": false
        }
      },
      "output": {
        "type": "list<question>",
        "fields": [
          "results[0].category",
          "results[0].type",
          "results[0].difficulty",
          "results[0].question",
          "results[0].correct_answer",
          "results[0].incorrect_answers"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_session_token",
      "description_for_ai": "Get a session token to avoid duplicate questions.",
      "intent": [
        "trivia session token",
        "no repeat questions",
        "unique trivia",
        "токен сессии викторины"
      ],
      "endpoint": "GET https://opentdb.com/api_token.php",
      "input": {
        "command": {
          "type": "string",
          "default": "request"
        }
      },
      "output": {
        "type": "token",
        "fields": [
          "token",
          "response_code",
          "response_message"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "reset_token",
      "description_for_ai": "Reset a session token to start getting all questions again.",
      "intent": [
        "reset trivia token",
        "restart trivia session",
        "new questions",
        "сброс токена викторины"
      ],
      "endpoint": "GET https://opentdb.com/api_token.php",
      "input": {
        "command": {
          "type": "string",
          "default": "reset"
        },
        "token": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "token",
        "fields": [
          "token",
          "response_code"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_categories",
      "description_for_ai": "Get all available trivia question categories.",
      "intent": [
        "trivia categories",
        "quiz categories",
        "question topics",
        "категории викторины"
      ],
      "endpoint": "GET https://opentdb.com/api_category.php",
      "input": {},
      "output": {
        "type": "list<category>",
        "fields": [
          "trivia_categories[0].id",
          "trivia_categories[0].name"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_category_count",
      "description_for_ai": "Get the number of questions available per category.",
      "intent": [
        "question count",
        "category stats",
        "trivia database size",
        "количество вопросов"
      ],
      "endpoint": "GET https://opentdb.com/api_count.php",
      "input": {
        "category": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "counts",
        "fields": [
          "category_question_count.total_question_count",
          "category_question_count.total_easy_question_count",
          "category_question_count.total_medium_question_count",
          "category_question_count.total_hard_question_count"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "shuffle": "Always shuffle incorrect_answers + correct_answer before presenting to user.",
    "html": "Questions contain HTML entities — decode before displaying."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}