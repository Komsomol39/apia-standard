{
  "apia": "1.0",
  "service": {
    "id": "open-trivia",
    "name": "Open Trivia Database API",
    "description_for_ai": "Free trivia questions API. 4000+ verified questions across 24 categories. Multiple difficulty levels. No API key needed. Use for quiz games, trivia apps, educational games.",
    "url": "https://opentdb.com",
    "api_base": "https://opentdb.com",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://opentdb.com/api_config.php"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free forever"
  },
  "capabilities": [
    {
      "id": "get_questions",
      "description_for_ai": "Free trivia questions API. 4000+ verified questions across 24 categories. Multiple difficulty levels. No API key needed. Use for quiz games, trivia apps, educational games. Get random trivia questions by category and difficulty. Returns question, correct answer, and incorrect answers.",
      "intent": [
        "trivia questions",
        "quiz questions",
        "game questions",
        "random quiz",
        "test knowledge"
      ],
      "endpoint": "GET https://opentdb.com/api.php",
      "input": {
        "amount": {
          "type": "integer",
          "description": "Number of questions 1-50",
          "default": 10
        },
        "category": {
          "type": "integer",
          "description": "9=General, 17=Science, 18=Computers, 21=Sports, 22=Geography, 23=History, 25=Art",
          "required": false
        },
        "difficulty": {
          "type": "string",
          "description": "easy, medium, hard",
          "required": false
        },
        "type": {
          "type": "string",
          "description": "multiple (multiple choice) or boolean (true/false)",
          "required": false
        }
      },
      "output": {
        "type": "list<question>",
        "fields": [
          "category",
          "type",
          "difficulty",
          "question",
          "correct_answer",
          "incorrect_answers"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "shuffle": "Always shuffle incorrect_answers + correct_answer before presenting to user.",
    "html": "Questions contain HTML entities — decode before displaying."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}