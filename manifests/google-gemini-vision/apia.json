{
  "apia": "1.0",
  "service": {
    "id": "google-gemini-vision",
    "name": "Gemini Vision API",
    "description_for_ai": "Google Gemini Vision API — multimodal AI for analyzing images, video, audio, and PDF documents. Describe scenes, extract text (OCR), identify objects, read charts, answer questions about visual content. Free tier: 1500 requests/day. Best for complex visual understanding tasks.",
    "url": "https://ai.google.dev",
    "api_base": "https://generativelanguage.googleapis.com/v1beta",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://ai.google.dev/gemini-api/docs/vision"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "how_to_get": "https://aistudio.google.com/app/apikey",
    "cost": "Free: 1500 req/day. Paid: $0.00025/image"
  },
  "capabilities": [
    {
      "id": "analyze_image",
      "description_for_ai": "Analyze any image: describe content, extract text (OCR), identify objects, read charts, answer questions about image. Send as URL or base64.",
      "intent": [
        "image recognition",
        "image Q&A",
        "анализ фото",
        "read photo",
        "what is in picture",
        "OCR",
        "analyze image",
        "извлечь текст из изображения",
        "image analysis",
        "read text from image",
        "what is in this image",
        "image understanding",
        "describe image",
        "что на изображении"
      ],
      "endpoint": "POST https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent",
      "input": {
        "model": {
          "type": "string",
          "default": "gemini-2.5-flash",
          "description": "AI/ML model identifier to use for this request"
        },
        "contents": {
          "type": "array",
          "description": "[{parts: [{text: prompt}, {inline_data: {mime_type: image/jpeg, data: base64}} or {file_data: {mime_type, file_uri}}]}]",
          "required": true
        },
        "generationConfig": {
          "type": "object",
          "required": false
        }
      },
      "output": {
        "type": "response",
        "fields": [
          "candidates[0].content.parts[0].text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "analyze_video",
      "description_for_ai": "Analyze video content: transcribe speech, describe scenes, answer questions about video. Upload to Google Files API first.",
      "intent": [
        "describe video",
        "video content AI",
        "video understanding",
        "analyze video",
        "video transcription",
        "video content"
      ],
      "endpoint": "POST https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent",
      "input": {
        "contents": {
          "type": "array",
          "description": "[{parts: [{text: prompt}, {file_data: {mime_type: video/mp4, file_uri: files/...}}]}]",
          "required": true
        }
      },
      "output": {
        "type": "response",
        "fields": [
          "candidates[0].content.parts[0].text"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "analyze_image",
      "description_for_ai": "Analyze images, PDFs, video frames with Gemini Vision. Describe, extract, or answer questions.",
      "intent": [
        "gemini vision",
        "analyze image google",
        "OCR google AI",
        "анализ изображения gemini"
      ],
      "endpoint": "POST https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent",
      "input": {
        "contents": {
          "type": "array",
          "description": "[{parts: [{inline_data: {mime_type: 'image/jpeg', data: 'base64'}}, {text: 'Describe this image'}]}]",
          "required": true
        }
      },
      "output": {
        "type": "text",
        "fields": [
          "candidates[0].content.parts[0].text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "extract_text_ocr",
      "description_for_ai": "Extract text from images and documents using Gemini Vision OCR.",
      "intent": [
        "OCR gemini",
        "extract text from image",
        "image text extraction",
        "OCR google"
      ],
      "endpoint": "POST https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent",
      "input": {
        "contents": {
          "type": "array",
          "description": "[{parts: [{inline_data: {mime_type: 'image/jpeg', data: 'base64'}}, {text: 'Extract all text from this image. Return just the text.'}]}]",
          "required": true
        }
      },
      "output": {
        "type": "text",
        "fields": [
          "candidates[0].content.parts[0].text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "compare_images",
      "description_for_ai": "Compare multiple images and describe similarities or differences with Gemini Vision.",
      "intent": [
        "compare images",
        "image comparison",
        "difference images",
        "сравнить изображения"
      ],
      "endpoint": "POST https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro:generateContent",
      "input": {
        "contents": {
          "type": "array",
          "description": "[{parts: [{inline_data: img1}, {inline_data: img2}, {text: 'Compare these images'}]}]",
          "required": true
        }
      },
      "output": {
        "type": "text",
        "fields": [
          "candidates[0].content.parts[0].text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}