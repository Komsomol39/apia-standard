{
  "apia": "1.0",
  "service": {
    "id": "wise",
    "name": "Wise (TransferWise) API",
    "description_for_ai": "International money transfers at real exchange rate. Send money to 80+ countries. Multi-currency accounts. Used for international payouts, freelancer payments, business transfers. Real exchange rate — no hidden fees.",
    "url": "https://wise.com",
    "api_base": "https://api.wise.com",
    "category": "payments_international",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.wise.com/api-docs/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "Wise Business account → API tokens",
    "cost": "0.4-2% transfer fee. No monthly fee."
  },
  "capabilities": [
    {
      "id": "get_exchange_rate",
      "description_for_ai": "Get real mid-market exchange rate between currencies. More accurate than bank rates.",
      "intent": [
        "real exchange rate",
        "mid-market rate",
        "transfer rate",
        "international rate",
        "wise rate",
        "курс перевода"
      ],
      "endpoint": "GET https://api.wise.com/v1/rates",
      "input": {
        "source": {
          "type": "string",
          "description": "Source currency code e.g. USD",
          "required": true
        },
        "target": {
          "type": "string",
          "description": "Target currency code e.g. EUR",
          "required": true
        }
      },
      "output": {
        "type": "rate",
        "fields": [
          "rate",
          "source",
          "target",
          "time"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_transfer_quote",
      "description_for_ai": "Get transfer fee and delivery time estimate for sending money internationally.",
      "intent": [
        "transfer fee",
        "how much to send",
        "international transfer cost",
        "wise quote"
      ],
      "endpoint": "POST https://api.wise.com/v3/quotes",
      "input": {
        "sourceCurrency": {
          "type": "string",
          "required": true
        },
        "targetCurrency": {
          "type": "string",
          "required": true
        },
        "sourceAmount": {
          "type": "number",
          "required": false
        },
        "targetAmount": {
          "type": "number",
          "required": false
        }
      },
      "output": {
        "type": "quote",
        "fields": [
          "id",
          "sourceCurrency",
          "targetCurrency",
          "sourceAmount",
          "targetAmount",
          "rate",
          "paymentOptions[0].fee.total",
          "paymentOptions[0].estimatedDelivery"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}