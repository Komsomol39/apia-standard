{
  "apia": "1.0",
  "service": {
    "id": "wise",
    "name": "Wise (TransferWise) API",
    "description_for_ai": "International money transfers at real exchange rate. Send money to 80+ countries. Multi-currency accounts. Used for international payouts, freelancer payments, business transfers. Real exchange rate — no hidden fees.",
    "url": "https://wise.com",
    "api_base": "https://api.wise.com",
    "category": "payments_international",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.wise.com/api-docs/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "Wise Business account → API tokens",
    "cost": "0.4-2% transfer fee. No monthly fee."
  },
  "capabilities": [
    {
      "id": "get_exchange_rate",
      "description_for_ai": "Get real mid-market exchange rate between two currencies. More accurate than bank rates, no markup applied.",
      "intent": [
        "real exchange rate",
        "mid-market rate",
        "transfer rate",
        "international rate",
        "wise rate",
        "курс перевода"
      ],
      "endpoint": "GET https://api.wise.com/v1/rates",
      "input": {
        "source": {
          "type": "string",
          "description": "Source currency ISO code: USD, EUR, GBP, RUB, CNY, JPY, AUD, CAD",
          "required": true
        },
        "target": {
          "type": "string",
          "description": "Target currency ISO code",
          "required": true
        },
        "time": {
          "type": "string",
          "description": "ISO 8601 datetime for historical rate lookup. Omit for current rate.",
          "required": false
        }
      },
      "output": {
        "type": "list<rate>",
        "fields": [
          "[0].rate",
          "[0].source",
          "[0].target",
          "[0].time"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_transfer_quote",
      "description_for_ai": "Get transfer fee and estimated delivery time for sending money internationally via Wise. Compares payment methods (bank transfer, card, etc.).",
      "intent": [
        "transfer fee",
        "how much to send",
        "international transfer cost",
        "wise quote"
      ],
      "endpoint": "POST https://api.wise.com/v3/quotes",
      "input": {
        "sourceCurrency": {
          "type": "string",
          "description": "Currency you're sending from: USD, EUR, GBP, etc.",
          "required": true
        },
        "targetCurrency": {
          "type": "string",
          "description": "Currency recipient will receive",
          "required": true
        },
        "sourceAmount": {
          "type": "number",
          "description": "Amount to send (in sourceCurrency). Provide either sourceAmount or targetAmount.",
          "required": false
        },
        "targetAmount": {
          "type": "number",
          "description": "Amount to deliver to recipient (in targetCurrency). Alternative to sourceAmount.",
          "required": false
        },
        "profile": {
          "type": "integer",
          "description": "Your Wise profile ID. Get via GET /v2/profiles. Personal vs business affects fees.",
          "required": false
        }
      },
      "output": {
        "type": "quote",
        "fields": [
          "id",
          "sourceCurrency",
          "targetCurrency",
          "sourceAmount",
          "targetAmount",
          "rate",
          "paymentOptions[0].payIn (BANK_TRANSFER/DEBIT_CARD/CREDIT_CARD)",
          "paymentOptions[0].fee.total",
          "paymentOptions[0].estimatedDelivery",
          "paymentOptions[0].price.total.value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}