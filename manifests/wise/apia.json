{
  "apia": "1.0",
  "service": {
    "id": "wise",
    "name": "Wise (TransferWise) API",
    "description_for_ai": "International money transfers at real exchange rate. Send money to 80+ countries. Multi-currency accounts. Used for international payouts, freelancer payments, business transfers. Real exchange rate — no hidden fees.",
    "url": "https://wise.com",
    "api_base": "https://api.wise.com",
    "category": "finance",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.wise.com/api-docs/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "Wise Business account → API tokens",
    "cost": "0.4-2% transfer fee. No monthly fee."
  },
  "capabilities": [
    {
      "id": "get_exchange_rate",
      "description_for_ai": "Get live exchange rate between two currencies. Wise uses mid-market rate (not inflated bank rate).",
      "intent": [
        "wise exchange rate",
        "currency rate",
        "transfer rate",
        "курс wise",
        "конвертация валют wise"
      ],
      "endpoint": "GET https://api.transferwise.com/v1/rates",
      "input": {
        "source": {
          "type": "string",
          "description": "Source currency ISO 4217: EUR, USD, GBP, RUB",
          "required": true
        },
        "target": {
          "type": "string",
          "description": "Target currency ISO 4217",
          "required": true
        },
        "time": {
          "type": "string",
          "description": "ISO 8601 datetime for historical rate. Omit for current rate.",
          "required": false
        }
      },
      "output": {
        "type": "rate",
        "fields": [
          "[0].rate",
          "[0].source",
          "[0].target",
          "[0].time"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "create_quote",
      "description_for_ai": "Get transfer quote showing exact amount received and fees. Required before creating transfer.",
      "intent": [
        "wise quote",
        "transfer estimate",
        "fee calculation wise",
        "расчёт перевода wise"
      ],
      "endpoint": "POST https://api.transferwise.com/v3/profiles/{profileId}/quotes",
      "input": {
        "sourceCurrency": {
          "type": "string",
          "required": true
        },
        "targetCurrency": {
          "type": "string",
          "required": true
        },
        "sourceAmount": {
          "type": "number",
          "description": "Amount in source currency. Use either sourceAmount or targetAmount.",
          "required": false
        },
        "targetAmount": {
          "type": "number",
          "description": "Desired target amount to receive",
          "required": false
        },
        "payOut": {
          "type": "string",
          "description": "BANK_TRANSFER, SWIFT, INTERAC, POLI",
          "default": "BANK_TRANSFER"
        }
      },
      "output": {
        "type": "quote",
        "fields": [
          "id",
          "sourceCurrency",
          "targetCurrency",
          "sourceAmount",
          "targetAmount",
          "rate",
          "fee",
          "paymentOptions[0].fee.total",
          "paymentOptions[0].estimatedDelivery"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_transfer",
      "description_for_ai": "Create an international transfer to a recipient account.",
      "intent": [
        "send money wise",
        "international transfer",
        "wire transfer wise",
        "перевести деньги wise"
      ],
      "endpoint": "POST https://api.transferwise.com/v1/transfers",
      "input": {
        "targetAccount": {
          "type": "integer",
          "description": "Recipient account ID from create_recipient",
          "required": true
        },
        "quoteUuid": {
          "type": "string",
          "description": "Quote ID from create_quote",
          "required": true
        },
        "customerTransactionId": {
          "type": "string",
          "description": "Your unique transfer ID (UUID)",
          "required": true
        },
        "details": {
          "type": "object",
          "description": "{reference: 'Invoice 123', transferPurpose: 'verification.transfers.purpose.pay.bills', sourceOfFunds: 'verification.source.of.funds.salary'}",
          "required": false
        }
      },
      "output": {
        "type": "transfer",
        "fields": [
          "id",
          "status",
          "reference",
          "created",
          "rate",
          "sourceValue",
          "targetValue"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_transfer_status",
      "description_for_ai": "Track a Wise transfer by ID. Returns current status and estimated delivery.",
      "intent": [
        "wise transfer status",
        "track transfer",
        "money sent wise",
        "статус перевода wise"
      ],
      "endpoint": "GET https://api.transferwise.com/v1/transfers/{transferId}",
      "input": {
        "transferId": {
          "type": "integer",
          "description": "Transfer ID from create_transfer",
          "required": true
        }
      },
      "output": {
        "type": "transfer",
        "fields": [
          "id",
          "status (incoming_payment_waiting|processing|funds_converted|outgoing_payment_sent|cancelled|bounced_back|funds_refunded)",
          "created",
          "estimatedDelivery"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}