{
  "apia": "1.0",
  "service": {
    "id": "wise",
    "name": "Wise (TransferWise) API",
    "description_for_ai": "International money transfers at real exchange rate. Send money to 80+ countries. Multi-currency accounts. Used for international payouts, freelancer payments, business transfers. Real exchange rate — no hidden fees.",
    "url": "https://wise.com",
    "api_base": "https://api.wise.com",
    "category": "finance",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.wise.com/api-docs/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "Wise Business account → API tokens",
    "cost": "0.4-2% transfer fee. No monthly fee."
  },
  "capabilities": [
    {
      "id": "get_exchange_rates",
      "description_for_ai": "Get real-time exchange rates from Wise. Very competitive rates with low fees.",
      "intent": [
        "Wise exchange rate",
        "transfer rate",
        "international transfer rate",
        "курс Wise"
      ],
      "endpoint": "GET https://api.transferwise.com/v1/rates",
      "input": {
        "source": {
          "type": "string",
          "description": "Source currency code: USD, EUR, GBP",
          "required": true
        },
        "target": {
          "type": "string",
          "description": "Target currency code",
          "required": true
        },
        "time": {
          "type": "string",
          "description": "ISO 8601 for historical rates. Omit for current.",
          "required": false
        }
      },
      "output": {
        "type": "rates",
        "fields": [
          "[0].rate",
          "[0].source",
          "[0].target",
          "[0].time"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_profiles",
      "description_for_ai": "Get personal and business profiles for the authenticated Wise user.",
      "intent": [
        "Wise profile",
        "account info Wise",
        "профиль Wise"
      ],
      "endpoint": "GET https://api.transferwise.com/v1/profiles",
      "input": {},
      "output": {
        "type": "list<profile>",
        "fields": [
          "[0].id",
          "[0].type (personal/business)",
          "[0].details.firstName",
          "[0].details.lastName",
          "[0].details.email"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_quote",
      "description_for_ai": "Create a transfer quote showing fees and exchange rate for an international payment.",
      "intent": [
        "Wise quote",
        "transfer quote",
        "money transfer cost",
        "стоимость перевода Wise"
      ],
      "endpoint": "POST https://api.transferwise.com/v3/profiles/{profileId}/quotes",
      "input": {
        "profileId": {
          "type": "integer",
          "required": true
        },
        "sourceCurrency": {
          "type": "string",
          "required": true
        },
        "targetCurrency": {
          "type": "string",
          "required": true
        },
        "sourceAmount": {
          "type": "number",
          "description": "Amount to send. Use either sourceAmount or targetAmount.",
          "required": false
        },
        "targetAmount": {
          "type": "number",
          "description": "Amount recipient gets.",
          "required": false
        }
      },
      "output": {
        "type": "quote",
        "fields": [
          "id",
          "rate",
          "fee.total",
          "fee.transferwise",
          "sourceAmount",
          "targetAmount",
          "paymentOptions[0].fee.total"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_recipient",
      "description_for_ai": "Add a bank account recipient for money transfers.",
      "intent": [
        "add recipient Wise",
        "bank account recipient",
        "transfer recipient",
        "получатель Wise"
      ],
      "endpoint": "POST https://api.transferwise.com/v1/accounts",
      "input": {
        "currency": {
          "type": "string",
          "required": true
        },
        "type": {
          "type": "string",
          "description": "iban, sort_code, swift_code, routing_number, etc.",
          "required": true
        },
        "profile": {
          "type": "integer",
          "description": "Profile ID",
          "required": true
        },
        "accountHolderName": {
          "type": "string",
          "required": true
        },
        "details": {
          "type": "object",
          "description": "{iban: 'DE89370400440532013000'} or {accountNumber, routingNumber} etc.",
          "required": true
        }
      },
      "output": {
        "type": "recipient",
        "fields": [
          "id",
          "currency",
          "accountHolderName",
          "details.iban"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_transfer",
      "description_for_ai": "Create a money transfer using a quote and recipient account.",
      "intent": [
        "send money Wise",
        "international transfer",
        "wire transfer Wise",
        "международный перевод Wise"
      ],
      "endpoint": "POST https://api.transferwise.com/v1/transfers",
      "input": {
        "targetAccount": {
          "type": "integer",
          "description": "Recipient account ID",
          "required": true
        },
        "quoteUuid": {
          "type": "string",
          "description": "Quote ID from create_quote",
          "required": true
        },
        "customerTransactionId": {
          "type": "string",
          "description": "Unique ID for idempotency",
          "required": true
        },
        "details": {
          "type": "object",
          "description": "{reference: 'Invoice 1234', transferPurpose: 'verification.transfers.purpose.pay.bills'}",
          "required": false
        }
      },
      "output": {
        "type": "transfer",
        "fields": [
          "id",
          "status",
          "reference",
          "rate",
          "created"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_transfer_status",
      "description_for_ai": "Track the status of a Wise money transfer.",
      "intent": [
        "transfer status Wise",
        "track payment",
        "wire status",
        "статус перевода Wise"
      ],
      "endpoint": "GET https://api.transferwise.com/v1/transfers/{transferId}",
      "input": {
        "transferId": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "transfer",
        "fields": [
          "id",
          "status",
          "sourceCurrency",
          "targetCurrency",
          "sourceValue",
          "targetValue",
          "rate",
          "created"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}