{
  "apia": "1.0",
  "service": {
    "id": "cbrf",
    "name": "Центральный Банк РФ API (ЦБ России)",
    "description_for_ai": "Официальные курсы валют Центрального Банка России. Бесплатно, без авторизации. Курсы ЦБ РФ на любую дату, ключевая ставка, статистика денежного обращения. Используй для официального курса валют в рублях.",
    "url": "https://cbr.ru",
    "api_base": "https://www.cbr.ru",
    "category": "finance",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://www.cbr.ru/development/"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Бесплатно"
  },
  "capabilities": [
    {
      "id": "get_daily_rates",
      "description_for_ai": "Get official Bank of Russia exchange rates for a specific date. Returns all currencies in XML or JSON.",
      "intent": [
        "курс ЦБ",
        "официальный курс",
        "курс доллара ЦБ",
        "курс рубля",
        "cbr rates"
      ],
      "endpoint": "GET https://www.cbr-xml-daily.ru/daily_json.js",
      "input": {},
      "output": {
        "type": "rates",
        "fields": [
          "Date",
          "Valute.USD.Value",
          "Valute.EUR.Value",
          "Valute.CNY.Value",
          "Valute.USD.CharCode",
          "Valute.USD.Name"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_historical_rates",
      "description_for_ai": "Get Bank of Russia rates for a specific past date.",
      "intent": [
        "исторический курс ЦБ",
        "курс на дату",
        "прошлый курс рубля"
      ],
      "endpoint": "GET https://www.cbr-xml-daily.ru/archive/{year}/{month}/{day}/daily_json.js",
      "input": {
        "year": {
          "type": "string",
          "description": "4-digit year e.g. 2024",
          "required": true
        },
        "month": {
          "type": "string",
          "description": "2-digit month e.g. 01",
          "required": true
        },
        "day": {
          "type": "string",
          "description": "2-digit day e.g. 15",
          "required": true
        }
      },
      "output": {
        "type": "historical_rates",
        "fields": [
          "Date",
          "Valute.USD.Value",
          "Valute.EUR.Value"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_key_rate",
      "description_for_ai": "Get current Bank of Russia key rate (ключевая ставка) history.",
      "intent": [
        "ключевая ставка",
        "ставка ЦБ",
        "процентная ставка ЦБ РФ",
        "key rate CBR"
      ],
      "endpoint": "GET https://api.cbr.ru/KeyRate",
      "input": {
        "date": {
          "type": "string",
          "description": "Date in DD.MM.YYYY format. Omit for current.",
          "required": false
        }
      },
      "output": {
        "type": "key_rate",
        "fields": [
          "KeyRate[0].Date",
          "KeyRate[0].Rate"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "convert_currency",
      "description_for_ai": "Convert an amount between any currencies using official CBR rates.",
      "intent": [
        "конвертация по курсу ЦБ",
        "перевести валюту ЦБ",
        "сколько долларов",
        "сколько рублей"
      ],
      "endpoint": "GET https://www.cbr-xml-daily.ru/daily_json.js",
      "input": {
        "from_currency": {
          "type": "string",
          "description": "Currency code e.g. USD, EUR, CNY, RUB",
          "required": true
        },
        "to_currency": {
          "type": "string",
          "description": "Target currency",
          "required": true
        },
        "amount": {
          "type": "number",
          "description": "Amount to convert",
          "required": true
        }
      },
      "output": {
        "type": "conversion",
        "fields": [
          "Calculated client-side using Valute rates"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "format": "API возвращает XML. Парсить поле Value — заменить запятую на точку для числа.",
    "json_alternative": "Неофициальные обёртки: api.exchangerate-api.com, https://www.cbr-xml-daily.ru/daily_json.js (JSON-версия, неофициальная)"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}