{
  "apia": "1.0",
  "service": {
    "id": "cbrf",
    "name": "Центральный Банк РФ API (ЦБ России)",
    "description_for_ai": "Официальные курсы валют Центрального Банка России. Бесплатно, без авторизации. Курсы ЦБ РФ на любую дату, ключевая ставка, статистика денежного обращения. Используй для официального курса валют в рублях.",
    "url": "https://cbr.ru",
    "api_base": "https://www.cbr.ru",
    "category": "finance",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://www.cbr.ru/development/"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Бесплатно"
  },
  "capabilities": [
    {
      "id": "get_daily_rates",
      "description_for_ai": "Получить официальные курсы валют ЦБ РФ на конкретную дату. Используй для курса доллара, евро и других валют к рублю по официальному курсу.",
      "intent": [
        "курс доллара",
        "курс евро",
        "официальный курс",
        "ЦБ РФ курс",
        "курс валют ЦБ",
        "курс на дату"
      ],
      "endpoint": "GET https://www.cbr.ru/scripts/XML_daily.asp",
      "input": {
        "date_req": {
          "type": "string",
          "description": "Дата в формате DD/MM/YYYY. Без параметра — сегодня.",
          "required": false
        }
      },
      "output": {
        "type": "xml",
        "fields": [
          "Valute[CharCode=USD].Value",
          "Valute[CharCode=EUR].Value",
          "Valute[CharCode=CNY].Value"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_key_rate",
      "description_for_ai": "Получить текущую ключевую ставку ЦБ РФ и историю её изменений.",
      "intent": [
        "ключевая ставка",
        "ставка ЦБ",
        "процентная ставка России",
        "ставка рефинансирования"
      ],
      "endpoint": "GET https://www.cbr.ru/hd_base/KeyRate/",
      "input": {},
      "output": {
        "type": "html",
        "fields": [
          "KeyRate table"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "format": "API возвращает XML. Парсить поле Value — заменить запятую на точку для числа.",
    "json_alternative": "Неофициальные обёртки: api.exchangerate-api.com, https://www.cbr-xml-daily.ru/daily_json.js (JSON-версия, неофициальная)"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}