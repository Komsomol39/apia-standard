{
  "apia": "1.0",
  "service": {
    "id": "shopify",
    "name": "Shopify API",
    "description_for_ai": "Power 4M+ online stores. Manage products, orders, customers, inventory, payments. Use to build Shopify apps, sync store data, automate order processing, manage products programmatically.",
    "url": "https://shopify.com",
    "api_base": "https://{shop}.myshopify.com/admin/api/2024-01",
    "category": "ecommerce",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://shopify.dev/docs/api"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Create Partner account at https://partners.shopify.com",
    "cost": "Free for apps. Shopify plans from $29/month"
  },
  "capabilities": [
    {
      "id": "get_products",
      "description_for_ai": "Get products from a Shopify store with prices, variants, inventory levels, and images. Use for product catalog display, inventory sync, price monitoring.",
      "intent": [
        "get products",
        "product list",
        "store inventory",
        "shopify products"
      ],
      "endpoint": "GET https://{shop}.myshopify.com/admin/api/2024-01/products.json",
      "input": {
        "limit": {
          "type": "integer",
          "description": "Products per page, max 250",
          "default": 50
        },
        "page_info": {
          "type": "string",
          "description": "Cursor for cursor-based pagination (from previous response Link header)",
          "required": false
        },
        "status": {
          "type": "string",
          "description": "active (published), archived, draft, or any",
          "default": "active"
        },
        "title": {
          "type": "string",
          "description": "Filter by exact title match",
          "required": false
        },
        "vendor": {
          "type": "string",
          "description": "Filter by product vendor/brand",
          "required": false
        },
        "product_type": {
          "type": "string",
          "description": "Filter by product type category",
          "required": false
        },
        "collection_id": {
          "type": "integer",
          "description": "Filter by collection/category ID",
          "required": false
        },
        "created_at_min": {
          "type": "string",
          "description": "ISO 8601 — return products created after this date",
          "required": false
        },
        "updated_at_min": {
          "type": "string",
          "description": "ISO 8601 — return products updated after this date",
          "required": false
        },
        "fields": {
          "type": "string",
          "description": "Comma-separated fields: id,title,variants,images,handle,product_type,vendor",
          "required": false
        }
      },
      "output": {
        "type": "list<product>",
        "fields": [
          "products[0].id",
          "products[0].title",
          "products[0].handle",
          "products[0].variants[0].price",
          "products[0].variants[0].inventory_quantity",
          "products[0].images[0].src",
          "products[0].product_type",
          "products[0].vendor"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_orders",
      "description_for_ai": "Get orders from Shopify store with customer info, line items, and fulfillment status. Use for order management, shipping, analytics.",
      "intent": [
        "get orders",
        "order list",
        "sales orders",
        "shopify orders"
      ],
      "endpoint": "GET https://{shop}.myshopify.com/admin/api/2024-01/orders.json",
      "input": {
        "status": {
          "type": "string",
          "description": "open (active), closed, cancelled, or any",
          "default": "open"
        },
        "fulfillment_status": {
          "type": "string",
          "description": "shipped, partial, unshipped, unfulfilled, or any",
          "required": false
        },
        "financial_status": {
          "type": "string",
          "description": "paid, unpaid, pending, refunded, voided, authorized, or any",
          "required": false
        },
        "limit": {
          "type": "integer",
          "description": "Orders per page, max 250",
          "default": 50
        },
        "created_at_min": {
          "type": "string",
          "description": "ISO 8601 date — return orders created after this",
          "required": false
        },
        "created_at_max": {
          "type": "string",
          "description": "ISO 8601 date — return orders created before this",
          "required": false
        },
        "fields": {
          "type": "string",
          "description": "Fields to return: id,name,total_price,financial_status,customer,line_items,shipping_address",
          "required": false
        }
      },
      "output": {
        "type": "list<order>",
        "fields": [
          "orders[0].id",
          "orders[0].name (#1001)",
          "orders[0].total_price",
          "orders[0].financial_status",
          "orders[0].fulfillment_status",
          "orders[0].customer.email",
          "orders[0].line_items[0].title",
          "orders[0].shipping_address"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}