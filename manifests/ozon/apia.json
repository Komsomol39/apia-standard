{
  "apia": "1.0",
  "service": {
    "id": "ozon",
    "name": "Ozon API (Россия)",
    "description_for_ai": "Крупнейший маркетплейс России. API для продавцов: управление товарами, заказами, ценами, FBO/FBS отгрузками, аналитикой. 50M+ покупателей. Обязателен для российских интернет-торговцев.",
    "url": "https://seller.ozon.ru",
    "api_base": "https://api-seller.ozon.ru",
    "category": "ecommerce",
    "geo": [
      "RU",
      "BY",
      "KZ"
    ],
    "language": "ru",
    "docs": "https://docs.ozon.ru/api/seller/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Client-Id + Api-Key",
    "how_to_get": "Личный кабинет продавца → Настройки → API ключи",
    "cost": "Бесплатно для продавцов Ozon"
  },
  "capabilities": [
    {
      "id": "get_products",
      "description_for_ai": "Получить список товаров продавца с ценами, остатками и статусами.",
      "intent": [
        "товары Ozon",
        "каталог продавца",
        "список продуктов",
        "управление ассортиментом"
      ],
      "endpoint": "POST https://api-seller.ozon.ru/v2/product/list",
      "input": {
        "filter": {
          "type": "object",
          "description": "{visibility: ALL|VISIBLE|HIDDEN, offer_id: []}",
          "required": false
        },
        "last_id": {
          "type": "string",
          "description": "Для пагинации",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 100
        }
      },
      "output": {
        "type": "list<product>",
        "fields": [
          "items[0].product_id",
          "items[0].offer_id",
          "items[0].name",
          "items[0].price",
          "items[0].stocks.present",
          "items[0].status.state"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_orders",
      "description_for_ai": "Get FBS (fulfilled by seller) orders from Ozon marketplace requiring packaging and shipping by seller.",
      "intent": [
        "заказы Ozon",
        "обработка заказов",
        "отгрузка",
        "FBS заказы"
      ],
      "endpoint": "POST https://api-seller.ozon.ru/v3/posting/fbs/list",
      "input": {
        "filter": {
          "type": "object",
          "description": "{status: awaiting_packaging, since: datetime, to: datetime}",
          "required": false
        },
        "dir": {
          "type": "string",
          "description": "ASC или DESC",
          "default": "ASC"
        },
        "limit": {
          "type": "integer",
          "default": 50
        }
      },
      "output": {
        "type": "list<order>",
        "fields": [
          "result.postings[0].posting_number",
          "result.postings[0].status",
          "result.postings[0].products",
          "result.postings[0].shipment_date"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "client_id": "Client-Id header = your Seller ID (numeric). Find in seller.ozon.ru → Settings → API.",
    "fbo_vs_fbs": "FBO = fulfilled by Ozon (storage at Ozon warehouse). FBS = fulfilled by seller (your warehouse). Different APIs.",
    "price_update": "Update prices via POST /v1/product/import/prices. Bulk update up to 1000 products per request.",
    "performance": "Product rating affects search position. Track via GET /v1/analytics/data."
  }
}