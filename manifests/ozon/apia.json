{
  "apia": "1.0",
  "service": {
    "id": "ozon",
    "name": "Ozon API (Россия)",
    "description_for_ai": "Крупнейший маркетплейс России. API для продавцов: управление товарами, заказами, ценами, FBO/FBS отгрузками, аналитикой. 50M+ покупателей. Обязателен для российских интернет-торговцев.",
    "url": "https://seller.ozon.ru",
    "api_base": "https://api-seller.ozon.ru",
    "category": "ecommerce",
    "geo": [
      "RU",
      "BY",
      "KZ"
    ],
    "language": "ru",
    "docs": "https://docs.ozon.ru/api/seller/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Client-Id + Api-Key",
    "how_to_get": "Личный кабинет продавца → Настройки → API ключи",
    "cost": "Бесплатно для продавцов Ozon"
  },
  "capabilities": [
    {
      "id": "list_products",
      "description_for_ai": "Get seller's product catalog from Ozon marketplace.",
      "intent": [
        "ozon products",
        "товары ozon",
        "каталог ozon",
        "продукты ozon"
      ],
      "endpoint": "POST https://api-seller.ozon.ru/v2/product/list",
      "input": {
        "filter": {
          "type": "object",
          "description": "{visibility: 'ALL'|'IN_SALE'|'NOT_ON_SALE', offer_id: ['sku1'], sku: [123456]}",
          "required": false
        },
        "last_id": {
          "type": "string",
          "description": "Pagination cursor from previous response",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 100
        }
      },
      "output": {
        "type": "list<product>",
        "fields": [
          "result.items[0].product_id",
          "result.items[0].offer_id",
          "result.items[0].name",
          "result.last_id",
          "result.total"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_product_info",
      "description_for_ai": "Get full product details from Ozon: price, description, attributes, category.",
      "intent": [
        "ozon product info",
        "ozon card",
        "карточка ozon",
        "информация о товаре ozon"
      ],
      "endpoint": "POST https://api-seller.ozon.ru/v2/product/info",
      "input": {
        "product_id": {
          "type": "integer",
          "description": "Ozon product ID",
          "required": false
        },
        "sku": {
          "type": "integer",
          "description": "Ozon SKU",
          "required": false
        },
        "offer_id": {
          "type": "string",
          "description": "Seller's article",
          "required": false
        }
      },
      "output": {
        "type": "product",
        "fields": [
          "result.id",
          "result.name",
          "result.offer_id",
          "result.price",
          "result.marketing_price",
          "result.stocks.present",
          "result.stocks.reserved"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_orders",
      "description_for_ai": "Get Ozon marketplace orders with shipment and payment status.",
      "intent": [
        "ozon orders",
        "заказы ozon",
        "ozon продажи"
      ],
      "endpoint": "POST https://api-seller.ozon.ru/v3/posting/fbs/list",
      "input": {
        "dir": {
          "type": "string",
          "description": "asc or desc",
          "default": "desc"
        },
        "filter": {
          "type": "object",
          "description": "{since: '2024-01-01T00:00:00.000Z', to: '2024-01-31T23:59:59.999Z', status: 'awaiting_deliver'}",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 50
        },
        "offset": {
          "type": "integer",
          "default": 0
        }
      },
      "output": {
        "type": "list<order>",
        "fields": [
          "result.postings[0].posting_number",
          "result.postings[0].order_id",
          "result.postings[0].status",
          "result.postings[0].products[0].name",
          "result.postings[0].ship_last_mile"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_price",
      "description_for_ai": "Update product prices on Ozon. Supports bulk update up to 1000 products.",
      "intent": [
        "ozon price update",
        "изменить цену ozon",
        "обновить цену ozon"
      ],
      "endpoint": "POST https://api-seller.ozon.ru/v1/product/import/prices",
      "input": {
        "prices": {
          "type": "array",
          "description": "[{product_id: 123, price: '999.99', old_price: '1299.99', price_strategy_enabled: false}] or use offer_id instead of product_id",
          "required": true
        }
      },
      "output": {
        "type": "list<result>",
        "fields": [
          "result[0].product_id",
          "result[0].updated",
          "result[0].errors"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_analytics",
      "description_for_ai": "Get sales analytics: revenue, orders, returns per product on Ozon.",
      "intent": [
        "ozon analytics",
        "ozon продажи статистика",
        "ozon выручка"
      ],
      "endpoint": "POST https://api-seller.ozon.ru/v1/analytics/data",
      "input": {
        "date_from": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "date_to": {
          "type": "string",
          "required": true
        },
        "metrics": {
          "type": "array",
          "description": "['revenue', 'ordered_units', 'returns', 'cancellations', 'hits_view_item']",
          "required": true
        },
        "dimension": {
          "type": "array",
          "description": "['sku', 'day', 'month']",
          "required": true
        }
      },
      "output": {
        "type": "analytics",
        "fields": [
          "result.data[0].dimensions",
          "result.data[0].metrics"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "client_id": "Client-Id header = your Seller ID (numeric). Find in seller.ozon.ru → Settings → API.",
    "fbo_vs_fbs": "FBO = fulfilled by Ozon (storage at Ozon warehouse). FBS = fulfilled by seller (your warehouse). Different APIs.",
    "price_update": "Update prices via POST /v1/product/import/prices. Bulk update up to 1000 products per request.",
    "performance": "Product rating affects search position. Track via GET /v1/analytics/data."
  }
}