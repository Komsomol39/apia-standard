{
  "apia": "1.0",
  "service": {
    "id": "typeform",
    "name": "Typeform API",
    "description_for_ai": "Create and manage beautiful forms and surveys. Retrieve form responses. Used for lead capture, surveys, quizzes, registrations. Typeform forms have high completion rates.",
    "url": "https://typeform.com",
    "api_base": "https://api.typeform.com",
    "category": "productivity",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.typeform.com/developers/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "Get token at https://admin.typeform.com/account#/section/tokens",
    "cost": "Free: 10 responses/month. Basic: $25/month unlimited"
  },
  "capabilities": [
    {
      "id": "list_forms",
      "description_for_ai": "List all Typeform forms in the workspace.",
      "intent": [
        "typeform forms",
        "list forms",
        "my forms typeform",
        "формы typeform"
      ],
      "endpoint": "GET https://api.typeform.com/forms",
      "input": {
        "page": {
          "type": "integer",
          "default": 1
        },
        "page_size": {
          "type": "integer",
          "default": 10
        },
        "search": {
          "type": "string",
          "required": false
        },
        "workspace_id": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<form>",
        "fields": [
          "items[0].id",
          "items[0].title",
          "items[0].type",
          "items[0]._links.display",
          "items[0].settings.is_public"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_responses",
      "description_for_ai": "Get form responses with answers, submission time, and metadata.",
      "intent": [
        "typeform responses",
        "form answers",
        "survey results typeform",
        "ответы typeform"
      ],
      "endpoint": "GET https://api.typeform.com/forms/{form_id}/responses",
      "input": {
        "form_id": {
          "type": "string",
          "required": true
        },
        "page_size": {
          "type": "integer",
          "description": "Max 1000",
          "default": 25
        },
        "since": {
          "type": "string",
          "description": "ISO 8601 date filter",
          "required": false
        },
        "until": {
          "type": "string",
          "required": false
        },
        "completed": {
          "type": "boolean",
          "description": "Only completed submissions",
          "required": false
        }
      },
      "output": {
        "type": "list<response>",
        "fields": [
          "items[0].response_id",
          "items[0].answers[0].field.title",
          "items[0].answers[0].text",
          "items[0].submitted_at",
          "items[0].score"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_form",
      "description_for_ai": "Create a Typeform form programmatically with questions and logic.",
      "intent": [
        "create form typeform",
        "build form",
        "new survey typeform",
        "создать форму typeform"
      ],
      "endpoint": "POST https://api.typeform.com/forms",
      "input": {
        "title": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "array",
          "description": "[{type: short_text, title: 'Your name'}, {type: multiple_choice, title: 'How did you hear?', properties: {choices: [{label: 'Google'}, {label: 'Friend'}]}}]",
          "required": true
        },
        "settings": {
          "type": "object",
          "description": "{is_public: true, language: 'en', progress_bar: 'percentage'}",
          "required": false
        }
      },
      "output": {
        "type": "form",
        "fields": [
          "id",
          "title",
          "_links.display (form URL)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_form",
      "description_for_ai": "Get a Typeform form definition including all fields, logic, and settings.",
      "intent": [
        "get form typeform",
        "form definition",
        "form schema typeform",
        "структура формы typeform"
      ],
      "endpoint": "GET https://api.typeform.com/forms/{form_id}",
      "input": {
        "form_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "form",
        "fields": [
          "id",
          "title",
          "fields",
          "logic",
          "settings",
          "_links.display"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "workspace": "Form responses are workspace-specific. Get workspace ID from account settings.",
    "webhooks": "Set up form webhooks for real-time submissions: POST /forms/{id}/webhooks with payload_fields.",
    "hidden_fields": "Pass hidden: {ref: 'value'} in create_form to pre-populate fields from URL params. Useful for user tracking.",
    "score": "For quiz forms, calculated.score contains total quiz score. Set correct_choice on question options."
  }
}