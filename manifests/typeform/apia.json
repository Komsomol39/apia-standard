{
  "apia": "1.0",
  "service": {
    "id": "typeform",
    "name": "Typeform API",
    "description_for_ai": "Create and manage beautiful forms and surveys. Retrieve form responses. Used for lead capture, surveys, quizzes, registrations. Typeform forms have high completion rates.",
    "url": "https://typeform.com",
    "api_base": "https://api.typeform.com",
    "category": "productivity",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.typeform.com/developers/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "Get token at https://admin.typeform.com/account#/section/tokens",
    "cost": "Free: 10 responses/month. Basic: $25/month unlimited"
  },
  "capabilities": [
    {
      "id": "get_responses",
      "description_for_ai": "Get form responses from a Typeform form.",
      "intent": [
        "Typeform responses",
        "form submissions",
        "survey answers",
        "ответы Typeform"
      ],
      "endpoint": "GET https://api.typeform.com/forms/{form_id}/responses",
      "input": {
        "form_id": {
          "type": "string",
          "required": true
        },
        "page_size": {
          "type": "integer",
          "default": 25
        },
        "sort": {
          "type": "string",
          "description": "submitted_at,desc or submitted_at,asc",
          "default": "submitted_at,desc"
        },
        "since": {
          "type": "string",
          "description": "ISO 8601 date filter",
          "required": false
        },
        "until": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "responses",
        "fields": [
          "items[0].response_id",
          "items[0].submitted_at",
          "items[0].answers[0].field.ref",
          "items[0].answers[0].text",
          "total_items"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_forms",
      "description_for_ai": "List all Typeform forms in your account.",
      "intent": [
        "Typeform forms",
        "my forms",
        "list surveys",
        "список форм Typeform"
      ],
      "endpoint": "GET https://api.typeform.com/forms",
      "input": {
        "search": {
          "type": "string",
          "description": "Filter by form title",
          "required": false
        },
        "page": {
          "type": "integer",
          "default": 1
        },
        "page_size": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<form>",
        "fields": [
          "items[0].id",
          "items[0].title",
          "items[0].type",
          "items[0].created_at",
          "items[0].total_visits",
          "items[0].submitted"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_form",
      "description_for_ai": "Get a Typeform form structure with all fields and settings.",
      "intent": [
        "form structure Typeform",
        "form fields",
        "survey questions",
        "структура формы Typeform"
      ],
      "endpoint": "GET https://api.typeform.com/forms/{form_id}",
      "input": {
        "form_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "form",
        "fields": [
          "id",
          "title",
          "fields[0].id",
          "fields[0].type",
          "fields[0].title",
          "fields[0].properties",
          "settings",
          "total_visits",
          "submitted"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_form",
      "description_for_ai": "Create a new Typeform form with fields.",
      "intent": [
        "create form Typeform",
        "new survey",
        "build form Typeform",
        "создать форму Typeform"
      ],
      "endpoint": "POST https://api.typeform.com/forms",
      "input": {
        "title": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "array",
          "description": "[{type: 'short_text', title: 'Your name?', ref: 'name_field'}, {type: 'multiple_choice', title: 'Choose:', choices: [{label: 'A'}, {label: 'B'}]}]",
          "required": true
        },
        "settings": {
          "type": "object",
          "description": "{language: 'en', redirect_after_submit_url: 'https://...'}",
          "required": false
        }
      },
      "output": {
        "type": "form",
        "fields": [
          "id",
          "title",
          "_links.display (form URL)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "delete_response",
      "description_for_ai": "Delete specific responses from a Typeform form by response IDs.",
      "intent": [
        "delete response Typeform",
        "remove submission",
        "GDPR delete",
        "удалить ответ Typeform"
      ],
      "endpoint": "DELETE https://api.typeform.com/forms/{form_id}/responses",
      "input": {
        "form_id": {
          "type": "string",
          "required": true
        },
        "included_response_ids": {
          "type": "string",
          "description": "Comma-separated response IDs",
          "required": true
        }
      },
      "output": {
        "type": "status",
        "fields": [
          "204 No Content on success"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "workspace": "Form responses are workspace-specific. Get workspace ID from account settings.",
    "webhooks": "Set up form webhooks for real-time submissions: POST /forms/{id}/webhooks with payload_fields.",
    "hidden_fields": "Pass hidden: {ref: 'value'} in create_form to pre-populate fields from URL params. Useful for user tracking.",
    "score": "For quiz forms, calculated.score contains total quiz score. Set correct_choice on question options."
  }
}