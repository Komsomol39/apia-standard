{
  "apia": "1.0",
  "service": {
    "id": "planet-labs",
    "name": "Planet Labs API",
    "description_for_ai": "Daily satellite imagery of the entire Earth. 3-5m resolution, updated daily. Used for agriculture monitoring, deforestation tracking, disaster response. Commercial service with free education tier.",
    "url": "https://planet.com",
    "api_base": "https://api.planet.com/data/v1",
    "category": "maps",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.planet.com/docs/apis/data/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "Register at https://www.planet.com/explorer/ — free education/research access available",
    "cost": "Free education tier. Commercial from custom pricing"
  },
  "capabilities": [
    {
      "id": "search_items",
      "description_for_ai": "Search Planet satellite imagery catalog by area, date, and satellite type.",
      "intent": [
        "satellite imagery Planet",
        "satellite search",
        "Earth observation",
        "поиск спутниковых снимков Planet"
      ],
      "endpoint": "POST https://api.planet.com/data/v1/quick-search",
      "input": {
        "item_types": {
          "type": "array",
          "description": "PSScene (PlanetScope daily), SkySatCollect, Landsat8L1G, Sentinel2L1C",
          "required": true
        },
        "filter": {
          "type": "object",
          "description": "{type: 'AndFilter', config: [{type: 'GeometryFilter', field_name: 'geometry', config: {type: 'Polygon', coordinates: [[[...]]]}}]}",
          "required": true
        }
      },
      "output": {
        "type": "list<item>",
        "fields": [
          "features[0].id",
          "features[0].properties.item_type",
          "features[0].properties.acquired",
          "features[0].properties.cloud_cover",
          "features[0].geometry.coordinates"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_item",
      "description_for_ai": "Get metadata and asset download links for a specific Planet image.",
      "intent": [
        "Planet image details",
        "satellite image metadata",
        "download satellite",
        "метаданные снимка Planet"
      ],
      "endpoint": "GET https://api.planet.com/data/v1/item-types/{item_type}/items/{item_id}",
      "input": {
        "item_type": {
          "type": "string",
          "required": true
        },
        "item_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "item",
        "fields": [
          "id",
          "properties.acquired",
          "properties.cloud_cover",
          "properties.sun_elevation",
          "properties.satellite_id",
          "_links.assets"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "activate_asset",
      "description_for_ai": "Activate a Planet satellite image asset for download.",
      "intent": [
        "activate Planet asset",
        "prepare download",
        "activate satellite image",
        "активировать снимок Planet"
      ],
      "endpoint": "POST https://api.planet.com/data/v1/item-types/{item_type}/items/{item_id}/assets/{asset_type}/activate",
      "input": {
        "item_type": {
          "type": "string",
          "required": true
        },
        "item_id": {
          "type": "string",
          "required": true
        },
        "asset_type": {
          "type": "string",
          "description": "ortho_analytic_4b, ortho_visual, ortho_udm2",
          "required": true
        }
      },
      "output": {
        "type": "status",
        "fields": [
          "202 Accepted (activation queued)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_asset_status",
      "description_for_ai": "Check if a Planet image asset is ready for download.",
      "intent": [
        "asset download status",
        "image ready Planet",
        "download ready?",
        "готовность снимка Planet"
      ],
      "endpoint": "GET https://api.planet.com/data/v1/item-types/{item_type}/items/{item_id}/assets",
      "input": {
        "item_type": {
          "type": "string",
          "required": true
        },
        "item_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "assets",
        "fields": [
          "ortho_analytic_4b.status (inactive/activating/active)",
          "ortho_analytic_4b.location (download URL when active)",
          "ortho_analytic_4b.expires_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_order",
      "description_for_ai": "Order Planet imagery: clip, reproject, and bundle for download.",
      "intent": [
        "order Planet imagery",
        "satellite data order",
        "image processing Planet",
        "заказ снимков Planet"
      ],
      "endpoint": "POST https://api.planet.com/compute/ops/orders/v2",
      "input": {
        "name": {
          "type": "string",
          "required": true
        },
        "products": {
          "type": "array",
          "description": "[{item_ids: ['...'], item_type: 'PSScene', product_bundle: 'analytic_sr_udm2'}]",
          "required": true
        },
        "tools": {
          "type": "array",
          "description": "Processing tools: [{type: 'clip', parameters: {aoi: {...geojson}}}, {type: 'reproject', parameters: {projection: 'EPSG:4326'}}]",
          "required": false
        }
      },
      "output": {
        "type": "order",
        "fields": [
          "id",
          "state",
          "created_on",
          "_links.results"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "free_tier": "Education and research accounts get free access. Apply at https://www.planet.com/markets/education-and-research/",
    "cloud_cover": "Filter cloud_cover lte 0.1 for 10% or less cloud cover for usable imagery."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}