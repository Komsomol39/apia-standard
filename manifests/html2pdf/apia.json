{
  "apia": "1.0",
  "service": {
    "id": "html2pdf",
    "name": "HTML/CSS to PDF API (pdfcrowd)",
    "description_for_ai": "Convert HTML content or any URL to PDF with high-fidelity rendering. Supports JavaScript, CSS, custom headers/footers. Used for invoice generation, reports, document export. Multiple providers available (pdfcrowd API shown).",
    "url": "https://pdfcrowd.com",
    "api_base": "https://api.pdfcrowd.com/convert",
    "category": "utilities",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://pdfcrowd.com/api/"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "how_to_get": "Register at https://pdfcrowd.com — 200 pages free trial",
    "cost": "Basic: $9/month 3000 pages. Business: $29/month"
  },
  "capabilities": [
    {
      "id": "url_to_pdf",
      "description_for_ai": "Convert any URL to PDF. Renders JavaScript and CSS fully. Returns binary PDF. Use for generating PDF versions of web pages or web apps.",
      "intent": [
        "convert to PDF",
        "URL to PDF",
        "web page PDF",
        "generate PDF",
        "print to PDF",
        "create PDF"
      ],
      "endpoint": "POST https://api.pdfcrowd.com/convert/24.04/html/",
      "input": {
        "source_url": {
          "type": "string",
          "description": "Full URL to convert: https://example.com/invoice/123. Page must be publicly accessible.",
          "required": true
        },
        "page_size": {
          "type": "string",
          "description": "Paper size: A4, A3, A5, Letter, Legal, Tabloid",
          "default": "A4"
        },
        "orientation": {
          "type": "string",
          "description": "Page orientation: portrait or landscape",
          "default": "portrait"
        },
        "margin_top": {
          "type": "string",
          "description": "Top margin with unit: 10mm, 1cm, 0.5in",
          "default": "10mm"
        },
        "margin_bottom": {
          "type": "string",
          "description": "Bottom margin",
          "default": "10mm"
        },
        "margin_left": {
          "type": "string",
          "description": "Left margin",
          "default": "10mm"
        },
        "margin_right": {
          "type": "string",
          "description": "Right margin",
          "default": "10mm"
        },
        "javascript_delay": {
          "type": "integer",
          "description": "Wait time in ms for JavaScript to execute before capture. Use for SPAs.",
          "default": 0
        },
        "no_background": {
          "type": "boolean",
          "description": "Remove background colors and images for print-friendly output",
          "default": false
        }
      },
      "output": {
        "type": "binary",
        "fields": [
          "PDF binary content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "html_to_pdf",
      "description_for_ai": "Convert HTML string directly to PDF. Best for template-based documents like invoices, contracts, receipts.",
      "intent": [
        "HTML to PDF",
        "invoice PDF",
        "template to PDF",
        "generate document"
      ],
      "endpoint": "POST https://api.pdfcrowd.com/convert/24.04/html/",
      "input": {
        "source": {
          "type": "string",
          "description": "Complete HTML document as string. Include inline CSS for best results.",
          "required": true
        },
        "page_size": {
          "type": "string",
          "description": "Paper size: A4, Letter, etc.",
          "default": "A4"
        },
        "orientation": {
          "type": "string",
          "description": "portrait or landscape",
          "default": "portrait"
        }
      },
      "output": {
        "type": "binary",
        "fields": [
          "PDF binary content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "html_to_pdf",
      "description_for_ai": "Convert HTML string or URL to PDF.",
      "intent": [
        "html to pdf",
        "webpage to PDF",
        "convert HTML PDF",
        "конвертировать HTML в PDF"
      ],
      "endpoint": "POST https://api.html2pdf.app/v1/generate",
      "input": {
        "html": {
          "type": "string",
          "description": "HTML content to convert",
          "required": false
        },
        "url": {
          "type": "string",
          "description": "URL to convert to PDF",
          "required": false
        },
        "marginTop": {
          "type": "number",
          "default": 0
        },
        "marginBottom": {
          "type": "number",
          "default": 0
        }
      },
      "output": {
        "type": "pdf",
        "fields": [
          "PDF binary content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "url_to_pdf",
      "description_for_ai": "Convert any web URL to PDF document.",
      "intent": [
        "url to PDF",
        "webpage PDF",
        "website to PDF",
        "сайт в PDF"
      ],
      "endpoint": "POST https://api.html2pdf.app/v1/generate",
      "input": {
        "url": {
          "type": "string",
          "description": "Full URL to convert e.g. https://example.com",
          "required": true
        },
        "format": {
          "type": "string",
          "description": "A4, A3, Letter, Legal",
          "default": "A4"
        },
        "landscape": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "pdf",
        "fields": [
          "PDF binary"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "set_options",
      "description_for_ai": "Convert HTML to PDF with advanced options: page size, margins, headers/footers.",
      "intent": [
        "PDF settings",
        "custom PDF",
        "PDF options html2pdf",
        "настройки PDF"
      ],
      "endpoint": "POST https://api.html2pdf.app/v1/generate",
      "input": {
        "html": {
          "type": "string",
          "required": true
        },
        "format": {
          "type": "string",
          "description": "A4, Letter",
          "default": "A4"
        },
        "headerTemplate": {
          "type": "string",
          "required": false
        },
        "footerTemplate": {
          "type": "string",
          "required": false
        },
        "printBackground": {
          "type": "boolean",
          "default": true
        }
      },
      "output": {
        "type": "pdf",
        "fields": [
          "PDF binary"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}