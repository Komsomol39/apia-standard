{
  "apia": "1.0",
  "service": {
    "id": "qr-code-api",
    "name": "QR Code APIs (goqr.me)",
    "description_for_ai": "Free QR code generation. Create QR codes for URLs, text, contacts, WiFi credentials. No API key needed. Returns PNG image.",
    "url": "https://goqr.me/api",
    "api_base": "https://api.qrserver.com/v1",
    "category": "utilities",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://goqr.me/api/doc/create-qr-code/"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "generate_qr",
      "description_for_ai": "Generate a QR code image from any URL or text.",
      "intent": [
        "generate QR code",
        "create QR",
        "QR code image",
        "создать QR код"
      ],
      "endpoint": "GET https://api.qr-code-generator.com/v1/create",
      "input": {
        "qr_code_text": {
          "type": "string",
          "description": "URL or text to encode",
          "required": true
        },
        "image_format": {
          "type": "string",
          "description": "PNG, JPEG, SVG",
          "default": "PNG"
        },
        "image_width_x": {
          "type": "integer",
          "description": "Width in pixels",
          "default": 300
        },
        "qr_code_margin": {
          "type": "integer",
          "description": "White border size",
          "default": 1
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "Binary image data (PNG/SVG)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "generate_qr_url",
      "description_for_ai": "Generate a QR code via URL parameters (no auth required for basic).",
      "intent": [
        "QR code URL",
        "free QR code",
        "quick QR",
        "QR по URL"
      ],
      "endpoint": "GET https://api.qrserver.com/v1/create-qr-code/",
      "input": {
        "data": {
          "type": "string",
          "description": "Text to encode (URL-encoded)",
          "required": true
        },
        "size": {
          "type": "string",
          "description": "WxH in pixels: 300x300",
          "default": "300x300"
        },
        "format": {
          "type": "string",
          "description": "png, svg, gif, eps",
          "default": "png"
        },
        "ecc": {
          "type": "string",
          "description": "Error correction: L M Q H",
          "default": "L"
        },
        "color": {
          "type": "string",
          "description": "Foreground color hex without #: 000000",
          "required": false
        },
        "bgcolor": {
          "type": "string",
          "description": "Background color hex: ffffff",
          "required": false
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "Binary QR image"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "decode_qr",
      "description_for_ai": "Decode/read a QR code from an image URL.",
      "intent": [
        "decode QR code",
        "read QR",
        "scan QR",
        "расшифровать QR код"
      ],
      "endpoint": "GET https://api.qrserver.com/v1/read-qr-code/",
      "input": {
        "fileurl": {
          "type": "string",
          "description": "URL of image containing QR code",
          "required": true
        }
      },
      "output": {
        "type": "decoded",
        "fields": [
          "[0].symbol[0].data (decoded text)",
          "[0].symbol[0].type",
          "[0].symbol[0].error"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "generate_with_logo",
      "description_for_ai": "Generate a QR code with a custom logo in the center.",
      "intent": [
        "QR code with logo",
        "branded QR",
        "QR with image",
        "QR с логотипом"
      ],
      "endpoint": "POST https://api.qr-code-generator.com/v1/create",
      "input": {
        "qr_code_text": {
          "type": "string",
          "required": true
        },
        "qr_code_logo": {
          "type": "string",
          "description": "Logo image URL",
          "required": true
        },
        "image_format": {
          "type": "string",
          "default": "PNG"
        },
        "image_width_x": {
          "type": "integer",
          "default": 500
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "PNG binary with centered logo"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "generate_vcard_qr",
      "description_for_ai": "Generate a QR code containing contact information (vCard).",
      "intent": [
        "vCard QR code",
        "contact QR",
        "business card QR",
        "QR для контакта"
      ],
      "endpoint": "GET https://api.qrserver.com/v1/create-qr-code/",
      "input": {
        "data": {
          "type": "string",
          "description": "vCard data: BEGIN:VCARD\\nVERSION:3.0\\nFN:John Doe\\nTEL:+1234567890\\nEMAIL:john@example.com\\nEND:VCARD",
          "required": true
        },
        "size": {
          "type": "string",
          "default": "300x300"
        },
        "format": {
          "type": "string",
          "default": "png"
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "QR code image with vCard data"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "embed": "Direct GET URL can be used as img src: https://api.qrserver.com/v1/create-qr-code/?data=https://example.com&size=200x200",
    "wifi": "For WiFi QR: data=WIFI:T:WPA;S:NetworkName;P:Password;;",
    "vcard": "For contact: data=BEGIN:VCARD\\nVERSION:3.0\\nFN:Name\\nTEL:+1234\\nEND:VCARD"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}