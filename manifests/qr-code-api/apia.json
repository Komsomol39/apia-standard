{
  "apia": "1.0",
  "service": {
    "id": "qr-code-api",
    "name": "QR Code APIs (goqr.me)",
    "description_for_ai": "Free QR code generation. Create QR codes for URLs, text, contacts, WiFi credentials. No API key needed. Returns PNG image.",
    "url": "https://goqr.me/api",
    "api_base": "https://api.qrserver.com/v1",
    "category": "utilities",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://goqr.me/api/doc/create-qr-code/"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "generate_qr",
      "description_for_ai": "Generate a QR code image for any text, URL, or data.",
      "intent": [
        "generate QR code",
        "QR code maker",
        "create QR",
        "создать QR код"
      ],
      "endpoint": "GET https://api.qrserver.com/v1/create-qr-code/",
      "input": {
        "data": {
          "type": "string",
          "description": "Content to encode: URL, text, phone number, vCard",
          "required": true
        },
        "size": {
          "type": "string",
          "description": "WxH pixels: 300x300, 500x500, 1000x1000",
          "default": "300x300"
        },
        "format": {
          "type": "string",
          "description": "png, jpg, gif, svg",
          "default": "png"
        },
        "ecc": {
          "type": "string",
          "description": "Error correction: L, M, Q, H",
          "default": "L"
        },
        "color": {
          "type": "string",
          "description": "Hex foreground: 000000 (black)",
          "default": "000000"
        },
        "bgcolor": {
          "type": "string",
          "description": "Hex background: ffffff (white)",
          "default": "ffffff"
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "QR code image binary"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "generate_qr_with_logo",
      "description_for_ai": "Generate a QR code with a logo/image in the center.",
      "intent": [
        "QR code with logo",
        "branded QR code",
        "custom QR",
        "QR код с логотипом"
      ],
      "endpoint": "GET https://api.qrserver.com/v1/create-qr-code/",
      "input": {
        "data": {
          "type": "string",
          "required": true
        },
        "size": {
          "type": "string",
          "default": "500x500"
        },
        "ecc": {
          "type": "string",
          "description": "Use H for logo (30% data recovery)",
          "default": "H"
        },
        "margin": {
          "type": "integer",
          "description": "Quiet zone in pixels",
          "default": 10
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "QR code PNG/SVG"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "generate_svg_qr",
      "description_for_ai": "Generate a scalable SVG QR code.",
      "intent": [
        "SVG QR code",
        "vector QR",
        "scalable QR code",
        "SVG QR код"
      ],
      "endpoint": "GET https://api.qrserver.com/v1/create-qr-code/",
      "input": {
        "data": {
          "type": "string",
          "required": true
        },
        "format": {
          "type": "string",
          "default": "svg"
        },
        "size": {
          "type": "string",
          "default": "300x300"
        }
      },
      "output": {
        "type": "svg",
        "fields": [
          "SVG XML content"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "read_qr",
      "description_for_ai": "Decode/read a QR code from an image URL.",
      "intent": [
        "read QR code",
        "decode QR",
        "scan QR code",
        "считать QR код"
      ],
      "endpoint": "GET https://api.qrserver.com/v1/read-qr-code/",
      "input": {
        "fileurl": {
          "type": "string",
          "description": "URL of image containing QR code",
          "required": true
        }
      },
      "output": {
        "type": "decoded",
        "fields": [
          "[0].symbol[0].data",
          "[0].symbol[0].type"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "bulk_qr_codes",
      "description_for_ai": "Generate multiple QR codes in a batch.",
      "intent": [
        "batch QR codes",
        "multiple QR generate",
        "bulk QR creation",
        "генерация QR пакетом"
      ],
      "endpoint": "GET https://api.qrserver.com/v1/create-qr-code/",
      "input": {
        "data": {
          "type": "string",
          "description": "Data to encode (one at a time — call repeatedly for bulk)",
          "required": true
        },
        "size": {
          "type": "string",
          "default": "300x300"
        },
        "format": {
          "type": "string",
          "description": "png, svg",
          "default": "png"
        },
        "color": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "QR code image"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "embed": "Direct GET URL can be used as img src: https://api.qrserver.com/v1/create-qr-code/?data=https://example.com&size=200x200",
    "wifi": "For WiFi QR: data=WIFI:T:WPA;S:NetworkName;P:Password;;",
    "vcard": "For contact: data=BEGIN:VCARD\\nVERSION:3.0\\nFN:Name\\nTEL:+1234\\nEND:VCARD"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}