{
  "apia": "1.0",
  "service": {
    "id": "qr-code-api",
    "name": "QR Code APIs (goqr.me)",
    "description_for_ai": "Free QR code generation. Create QR codes for URLs, text, contacts, WiFi credentials. No API key needed. Returns PNG image.",
    "url": "https://goqr.me/api",
    "api_base": "https://api.qrserver.com/v1",
    "category": "utilities",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://goqr.me/api/doc/create-qr-code/"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "create_qr",
      "description_for_ai": "Generate QR code image for any text or URL. Returns PNG image directly.",
      "intent": [
        "create QR code",
        "generate QR",
        "QR code link",
        "QR code URL",
        "make QR",
        "создать QR-код"
      ],
      "endpoint": "GET https://api.qrserver.com/v1/create-qr-code/",
      "input": {
        "data": {
          "type": "string",
          "description": "Text or URL to encode",
          "required": true
        },
        "size": {
          "type": "string",
          "description": "WxH in pixels e.g. 200x200",
          "default": "200x200"
        },
        "format": {
          "type": "string",
          "description": "png, svg, eps, base64",
          "default": "png"
        },
        "ecc": {
          "type": "string",
          "description": "Error correction: L, M, Q, H",
          "default": "M"
        },
        "bgcolor": {
          "type": "string",
          "description": "Background color hex without # e.g. ffffff",
          "default": "ffffff"
        },
        "color": {
          "type": "string",
          "description": "QR color hex e.g. 000000",
          "default": "000000"
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "PNG image binary"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "embed": "Direct GET URL can be used as img src: https://api.qrserver.com/v1/create-qr-code/?data=https://example.com&size=200x200",
    "wifi": "For WiFi QR: data=WIFI:T:WPA;S:NetworkName;P:Password;;",
    "vcard": "For contact: data=BEGIN:VCARD\\nVERSION:3.0\\nFN:Name\\nTEL:+1234\\nEND:VCARD"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}