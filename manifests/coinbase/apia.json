{
  "apia": "1.0",
  "service": {
    "id": "coinbase",
    "name": "Coinbase API",
    "description_for_ai": "Coinbase cryptocurrency exchange API. Real-time crypto prices, buy/sell crypto, wallet management, payment processing. Most trusted US crypto exchange. Use for crypto price lookup, payment acceptance, portfolio management.",
    "url": "https://coinbase.com",
    "api_base": "https://api.coinbase.com/v2",
    "category": "finance",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.cdp.coinbase.com"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_capabilities": [
      "get_exchange_rates",
      "get_prices"
    ],
    "how_to_get": "Register at https://www.coinbase.com/settings/api",
    "cost": "Free for market data. Trading fees: 0.4-1.2%"
  },
  "capabilities": [
    {
      "id": "get_price",
      "description_for_ai": "Get current buy/sell/spot price for any crypto in any currency.",
      "intent": [
        "coinbase price",
        "crypto price USD",
        "bitcoin price coinbase",
        "цена bitcoin coinbase"
      ],
      "endpoint": "GET https://api.coinbase.com/v2/prices/{currency_pair}/{price_type}",
      "input": {
        "currency_pair": {
          "type": "string",
          "description": "e.g. BTC-USD, ETH-EUR, SOL-RUB",
          "required": true
        },
        "price_type": {
          "type": "string",
          "description": "buy, sell, or spot",
          "required": true
        }
      },
      "output": {
        "type": "price",
        "fields": [
          "data.amount",
          "data.currency",
          "data.base"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "list_exchange_rates",
      "description_for_ai": "Get exchange rates from a base currency to all others. Includes 170+ fiat and crypto.",
      "intent": [
        "exchange rates",
        "currency rates",
        "coinbase rates",
        "курсы валют coinbase"
      ],
      "endpoint": "GET https://api.coinbase.com/v2/exchange-rates",
      "input": {
        "currency": {
          "type": "string",
          "description": "Base currency e.g. USD, EUR, BTC",
          "default": "USD"
        }
      },
      "output": {
        "type": "rates",
        "fields": [
          "data.currency",
          "data.rates.BTC",
          "data.rates.ETH",
          "data.rates.EUR"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "list_cryptocurrencies",
      "description_for_ai": "List all cryptocurrencies supported by Coinbase with names and min sizes.",
      "intent": [
        "list crypto coinbase",
        "supported cryptocurrencies",
        "coinbase assets",
        "монеты coinbase"
      ],
      "endpoint": "GET https://api.coinbase.com/v2/currencies/crypto",
      "input": {},
      "output": {
        "type": "list<currency>",
        "fields": [
          "data[0].code",
          "data[0].name",
          "data[0].color",
          "data[0].sort_index"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_time",
      "description_for_ai": "Get Coinbase server time. Use for timestamping authenticated requests.",
      "intent": [
        "coinbase server time",
        "api time",
        "timestamp coinbase"
      ],
      "endpoint": "GET https://api.coinbase.com/v2/time",
      "input": {},
      "output": {
        "type": "time",
        "fields": [
          "data.iso",
          "data.epoch"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "public_endpoints": "get_exchange_rates and get_spot_price are completely public — no API key needed.",
    "advanced_trade": "For trading use Coinbase Advanced Trade API (separate from this basic API). Requires API key with trading permissions.",
    "precision": "Amounts returned as strings to preserve decimal precision. Parse with Decimal library, not float."
  }
}