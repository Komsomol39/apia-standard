{
  "apia": "1.0",
  "service": {
    "id": "coinbase",
    "name": "Coinbase API",
    "description_for_ai": "Coinbase cryptocurrency exchange API. Real-time crypto prices, buy/sell crypto, wallet management, payment processing. Most trusted US crypto exchange. Use for crypto price lookup, payment acceptance, portfolio management.",
    "url": "https://coinbase.com",
    "api_base": "https://api.coinbase.com/v2",
    "category": "finance",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.cdp.coinbase.com"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": true,
    "anonymous_capabilities": [
      "get_exchange_rates",
      "get_prices"
    ],
    "how_to_get": "Register at https://www.coinbase.com/settings/api",
    "cost": "Free for market data. Trading fees: 0.4-1.2%"
  },
  "capabilities": [
    {
      "id": "get_spot_price",
      "description_for_ai": "Get current spot price for a cryptocurrency pair.",
      "intent": [
        "crypto price Coinbase",
        "BTC price",
        "coin price",
        "цена криптовалюты Coinbase"
      ],
      "endpoint": "GET https://api.coinbase.com/v2/prices/{currency_pair}/spot",
      "input": {
        "currency_pair": {
          "type": "string",
          "description": "e.g. BTC-USD, ETH-EUR, SOL-USDT",
          "required": true
        }
      },
      "output": {
        "type": "price",
        "fields": [
          "data.amount",
          "data.currency",
          "data.base"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_accounts",
      "description_for_ai": "Get all cryptocurrency wallet accounts and balances.",
      "intent": [
        "Coinbase balance",
        "crypto wallet",
        "account balance Coinbase",
        "кошелёк Coinbase"
      ],
      "endpoint": "GET https://api.coinbase.com/v2/accounts",
      "input": {
        "limit": {
          "type": "integer",
          "default": 25
        }
      },
      "output": {
        "type": "list<account>",
        "fields": [
          "data[0].id",
          "data[0].name",
          "data[0].currency",
          "data[0].balance.amount",
          "data[0].balance.currency"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_address",
      "description_for_ai": "Generate a crypto receive address for an account.",
      "intent": [
        "receive crypto",
        "deposit address",
        "crypto address",
        "адрес для получения крипто"
      ],
      "endpoint": "POST https://api.coinbase.com/v2/accounts/{account_id}/addresses",
      "input": {
        "account_id": {
          "type": "string",
          "required": true
        },
        "name": {
          "type": "string",
          "description": "Label for the address",
          "required": false
        }
      },
      "output": {
        "type": "address",
        "fields": [
          "data.id",
          "data.address",
          "data.name",
          "data.network",
          "data.uri_scheme"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_transactions",
      "description_for_ai": "List transactions for a Coinbase account.",
      "intent": [
        "Coinbase transactions",
        "crypto history",
        "transaction list",
        "история транзакций Coinbase"
      ],
      "endpoint": "GET https://api.coinbase.com/v2/accounts/{account_id}/transactions",
      "input": {
        "account_id": {
          "type": "string",
          "required": true
        },
        "limit": {
          "type": "integer",
          "default": 25
        },
        "order": {
          "type": "string",
          "description": "asc or desc",
          "default": "desc"
        }
      },
      "output": {
        "type": "list<transaction>",
        "fields": [
          "data[0].id",
          "data[0].type",
          "data[0].status",
          "data[0].amount.amount",
          "data[0].amount.currency",
          "data[0].created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_money",
      "description_for_ai": "Send cryptocurrency to an address or email.",
      "intent": [
        "send crypto",
        "transfer crypto",
        "crypto payment Coinbase",
        "отправить крипто Coinbase"
      ],
      "endpoint": "POST https://api.coinbase.com/v2/accounts/{account_id}/transactions",
      "input": {
        "account_id": {
          "type": "string",
          "required": true
        },
        "type": {
          "type": "string",
          "default": "send"
        },
        "to": {
          "type": "string",
          "description": "Crypto address or email",
          "required": true
        },
        "amount": {
          "type": "string",
          "description": "Amount to send",
          "required": true
        },
        "currency": {
          "type": "string",
          "description": "Currency code: BTC, ETH, USDT",
          "required": true
        },
        "description": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "transaction",
        "fields": [
          "data.id",
          "data.status",
          "data.amount.amount",
          "data.network.hash"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_exchange_rates",
      "description_for_ai": "Get exchange rates for a currency against all others.",
      "intent": [
        "exchange rates",
        "crypto rates",
        "convert currency",
        "курсы валют Coinbase"
      ],
      "endpoint": "GET https://api.coinbase.com/v2/exchange-rates",
      "input": {
        "currency": {
          "type": "string",
          "description": "Base currency: USD, EUR, BTC, ETH",
          "default": "USD"
        }
      },
      "output": {
        "type": "rates",
        "fields": [
          "data.currency",
          "data.rates.BTC",
          "data.rates.ETH",
          "data.rates.EUR"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "public_endpoints": "get_exchange_rates and get_spot_price are completely public — no API key needed.",
    "advanced_trade": "For trading use Coinbase Advanced Trade API (separate from this basic API). Requires API key with trading permissions.",
    "precision": "Amounts returned as strings to preserve decimal precision. Parse with Decimal library, not float."
  }
}