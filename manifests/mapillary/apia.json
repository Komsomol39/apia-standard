{
  "apia": "1.0",
  "service": {
    "id": "mapillary",
    "name": "Mapillary API (Meta)",
    "description_for_ai": "Crowdsourced street-level imagery. 2B+ photos from 200+ countries. Access street photos, map features (signs, lanes, surfaces), traffic signs, sequence data. Free for developers. Use for street view, autonomous driving data, map enrichment.",
    "url": "https://mapillary.com",
    "api_base": "https://graph.mapillary.com",
    "category": "maps",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.mapillary.com/developer/api-documentation"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "access_token",
    "param_location": "query",
    "how_to_get": "Register at https://www.mapillary.com/app/settings/developers",
    "cost": "Free for non-commercial"
  },
  "capabilities": [
    {
      "id": "search_images",
      "description_for_ai": "Search Mapillary street-level images by location, date, or sequence.",
      "intent": [
        "street photos Mapillary",
        "street view Mapillary",
        "location images",
        "уличные фото Mapillary"
      ],
      "endpoint": "GET https://graph.mapillary.com/images",
      "input": {
        "bbox": {
          "type": "string",
          "description": "West,South,East,North: -73.96,40.74,-73.95,40.75",
          "required": true
        },
        "limit": {
          "type": "integer",
          "default": 10
        },
        "start_captured_at": {
          "type": "string",
          "description": "ISO 8601 datetime",
          "required": false
        },
        "end_captured_at": {
          "type": "string",
          "required": false
        },
        "fields": {
          "type": "string",
          "description": "id,captured_at,geometry,computed_geometry,thumb_256_url",
          "required": false
        }
      },
      "output": {
        "type": "list<image>",
        "fields": [
          "data[0].id",
          "data[0].captured_at",
          "data[0].geometry.coordinates",
          "data[0].thumb_256_url",
          "data[0].thumb_1024_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_image_details",
      "description_for_ai": "Get full metadata for a Mapillary image: location, camera, sequence.",
      "intent": [
        "image details Mapillary",
        "street photo metadata",
        "photo location data",
        "метаданные фото Mapillary"
      ],
      "endpoint": "GET https://graph.mapillary.com/{image_id}",
      "input": {
        "image_id": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "id,captured_at,geometry,altitude,thumb_original_url,sequence,compass_angle",
          "required": false
        }
      },
      "output": {
        "type": "image",
        "fields": [
          "id",
          "captured_at",
          "geometry.coordinates",
          "altitude",
          "compass_angle",
          "thumb_original_url",
          "sequence"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_map_features",
      "description_for_ai": "Get detected map features (traffic signs, fire hydrants, etc.) in an area.",
      "intent": [
        "map features Mapillary",
        "detected objects",
        "traffic signs",
        "объекты на карте Mapillary"
      ],
      "endpoint": "GET https://graph.mapillary.com/map_features",
      "input": {
        "bbox": {
          "type": "string",
          "required": true
        },
        "values": {
          "type": "string",
          "description": "Object types: trafficsign, object--fire-hydrant, etc.",
          "required": false
        },
        "fields": {
          "type": "string",
          "default": "id,object_value,geometry,images"
        }
      },
      "output": {
        "type": "list<feature>",
        "fields": [
          "data[0].id",
          "data[0].object_value",
          "data[0].geometry.coordinates",
          "data[0].images.data[0].id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_sequence",
      "description_for_ai": "Get all images in a Mapillary sequence (driving route).",
      "intent": [
        "image sequence Mapillary",
        "route photos",
        "driving sequence",
        "последовательность Mapillary"
      ],
      "endpoint": "GET https://graph.mapillary.com/sequences/{sequence_id}",
      "input": {
        "sequence_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "sequence",
        "fields": [
          "id",
          "captured_at",
          "creator_username",
          "geometry.type",
          "image_count"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_organization_stats",
      "description_for_ai": "Get image contribution statistics for a Mapillary organization.",
      "intent": [
        "Mapillary organization",
        "contribution stats",
        "image count",
        "статистика Mapillary"
      ],
      "endpoint": "GET https://graph.mapillary.com/organizations/{organization_id}",
      "input": {
        "organization_id": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "string",
          "default": "id,name,description,image_count"
        }
      },
      "output": {
        "type": "organization",
        "fields": [
          "id",
          "name",
          "description",
          "image_count"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}