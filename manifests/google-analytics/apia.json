{
  "apia": "1.0",
  "service": {
    "id": "google-analytics",
    "name": "Google Analytics Data API (GA4)",
    "description_for_ai": "Website and app analytics. Sessions, users, pageviews, events, conversions, revenue. Real-time and historical data. 35M+ websites use Google Analytics. Use for website performance monitoring, user behavior analysis.",
    "url": "https://analytics.google.com",
    "api_base": "https://analyticsdata.googleapis.com/v1beta",
    "category": "analytics",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.google.com/analytics/devguides/reporting/data/v1"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Enable Analytics Data API at https://console.cloud.google.com",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "run_report",
      "description_for_ai": "Website and app analytics. Sessions, users, pageviews, events, conversions, revenue. Real-time and historical data. 35M+ websites use Google Analytics. Use for website performance monitoring, user behavior analysis. Get website analytics report with metrics and dimensions for date range.",
      "intent": [
        "website analytics",
        "page views",
        "user sessions",
        "google analytics",
        "traffic data",
        "conversion rate",
        "website stats"
      ],
      "endpoint": "POST https://analyticsdata.googleapis.com/v1beta/properties/{property_id}:runReport",
      "input": {
        "property_id": {
          "type": "string",
          "description": "GA4 property ID e.g. 123456789",
          "required": true
        },
        "dateRanges": {
          "type": "array",
          "description": "[{startDate: 7daysAgo, endDate: today}]",
          "required": true
        },
        "metrics": {
          "type": "array",
          "description": "[{name: sessions}, {name: activeUsers}, {name: screenPageViews}]",
          "required": true
        },
        "dimensions": {
          "type": "array",
          "description": "[{name: date}, {name: country}, {name: pagePath}]",
          "required": false
        }
      },
      "output": {
        "type": "report",
        "fields": [
          "rows[0].dimensionValues",
          "rows[0].metricValues",
          "totals"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}