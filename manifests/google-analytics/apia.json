{
  "apia": "1.0",
  "service": {
    "id": "google-analytics",
    "name": "Google Analytics Data API (GA4)",
    "description_for_ai": "Website and app analytics. Sessions, users, pageviews, events, conversions, revenue. Real-time and historical data. 35M+ websites use Google Analytics. Use for website performance monitoring, user behavior analysis.",
    "url": "https://analytics.google.com",
    "api_base": "https://analyticsdata.googleapis.com/v1beta",
    "category": "analytics",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.google.com/analytics/devguides/reporting/data/v1"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Enable Analytics Data API at https://console.cloud.google.com",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "run_report",
      "description_for_ai": "Run a custom analytics report for a GA4 property. Get sessions, users, revenue, page views.",
      "intent": [
        "Google Analytics report",
        "GA4 data",
        "website analytics",
        "Google Analytics данные"
      ],
      "endpoint": "POST https://analyticsdata.googleapis.com/v1beta/properties/{property}/runReport",
      "input": {
        "property": {
          "type": "string",
          "description": "properties/{property_id}",
          "required": true
        },
        "dimensions": {
          "type": "array",
          "description": "[{name: 'date'}, {name: 'sessionSource'}, {name: 'country'}, {name: 'deviceCategory'}]",
          "required": false
        },
        "metrics": {
          "type": "array",
          "description": "[{name: 'sessions'}, {name: 'activeUsers'}, {name: 'screenPageViews'}, {name: 'totalRevenue'}]",
          "required": true
        },
        "dateRanges": {
          "type": "array",
          "description": "[{startDate: '2024-01-01', endDate: '2024-01-31'}] or use 'today', '7daysAgo', '30daysAgo'",
          "required": true
        },
        "limit": {
          "type": "integer",
          "default": 1000
        }
      },
      "output": {
        "type": "report",
        "fields": [
          "rows[0].dimensionValues[0].value",
          "rows[0].metricValues[0].value",
          "totals[0].metricValues[0].value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "realtime_report",
      "description_for_ai": "Get real-time analytics data: active users right now, traffic sources.",
      "intent": [
        "realtime analytics",
        "active users now",
        "live traffic",
        "активные пользователи сейчас GA4"
      ],
      "endpoint": "POST https://analyticsdata.googleapis.com/v1beta/properties/{property}/runRealtimeReport",
      "input": {
        "property": {
          "type": "string",
          "required": true
        },
        "dimensions": {
          "type": "array",
          "description": "[{name: 'country'}, {name: 'unifiedScreenName'}]",
          "required": false
        },
        "metrics": {
          "type": "array",
          "description": "[{name: 'activeUsers'}]",
          "required": true
        }
      },
      "output": {
        "type": "realtime",
        "fields": [
          "rows[0].dimensionValues[0].value",
          "rows[0].metricValues[0].value",
          "minuteRanges[0].minutesAgo"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_metadata",
      "description_for_ai": "Get all available dimensions and metrics for a GA4 property.",
      "intent": [
        "GA4 dimensions metrics",
        "available metrics",
        "analytics dimensions",
        "метрики GA4"
      ],
      "endpoint": "GET https://analyticsdata.googleapis.com/v1beta/properties/{property}/metadata",
      "input": {
        "property": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "metadata",
        "fields": [
          "dimensions[0].apiName",
          "dimensions[0].description",
          "metrics[0].apiName",
          "metrics[0].description"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "funnel_report",
      "description_for_ai": "Run a funnel analysis report to understand conversion steps.",
      "intent": [
        "funnel analysis GA4",
        "conversion funnel",
        "analytics funnel",
        "воронка конверсий GA4"
      ],
      "endpoint": "POST https://analyticsdata.googleapis.com/v1beta/properties/{property}/runFunnelReport",
      "input": {
        "property": {
          "type": "string",
          "required": true
        },
        "funnel": {
          "type": "object",
          "description": "{steps: [{name: 'Step 1', filterExpression: {eventFilter: {eventName: 'view_item'}}}, {name: 'Step 2', filterExpression: {eventFilter: {eventName: 'add_to_cart'}}}]}",
          "required": true
        },
        "dateRanges": {
          "type": "array",
          "required": true
        }
      },
      "output": {
        "type": "funnel",
        "fields": [
          "funnelTable.rows[0].dimensionValues[0].value",
          "funnelTable.rows[0].metricValues[0].value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "cohort_report",
      "description_for_ai": "Run a cohort analysis to track user retention over time.",
      "intent": [
        "cohort analysis GA4",
        "user retention",
        "cohort report",
        "когортный анализ GA4"
      ],
      "endpoint": "POST https://analyticsdata.googleapis.com/v1beta/properties/{property}/runReport",
      "input": {
        "property": {
          "type": "string",
          "required": true
        },
        "cohortSpec": {
          "type": "object",
          "description": "{cohorts: [{name: 'cohort1', dateRange: {startDate: '2024-01-01', endDate: '2024-01-07'}}], cohortsRange: {granularity: 'WEEKLY', endOffset: 4}}",
          "required": true
        },
        "metrics": {
          "type": "array",
          "description": "[{name: 'cohortRetentionRate'}, {name: 'cohortActiveUsers'}]",
          "required": true
        }
      },
      "output": {
        "type": "cohort",
        "fields": [
          "rows[0].dimensionValues[0].value (cohort)",
          "rows[0].metricValues[0].value (retention rate)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}