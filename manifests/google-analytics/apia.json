{
  "apia": "1.0",
  "service": {
    "id": "google-analytics",
    "name": "Google Analytics Data API (GA4)",
    "description_for_ai": "Website and app analytics. Sessions, users, pageviews, events, conversions, revenue. Real-time and historical data. 35M+ websites use Google Analytics. Use for website performance monitoring, user behavior analysis.",
    "url": "https://analytics.google.com",
    "api_base": "https://analyticsdata.googleapis.com/v1beta",
    "category": "analytics",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.google.com/analytics/devguides/reporting/data/v1"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Enable Analytics Data API at https://console.cloud.google.com",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "run_report",
      "description_for_ai": "Run a GA4 analytics report for pages, sessions, users, revenue.",
      "intent": [
        "Google Analytics report",
        "GA4 data",
        "website traffic",
        "данные Google Analytics"
      ],
      "endpoint": "POST https://analyticsdata.googleapis.com/v1beta/properties/{property}/runReport",
      "input": {
        "property": {
          "type": "string",
          "description": "GA4 property ID: 'properties/123456789'",
          "required": true
        },
        "dateRanges": {
          "type": "array",
          "description": "[{startDate: '7daysAgo', endDate: 'today'}]",
          "required": true
        },
        "dimensions": {
          "type": "array",
          "description": "[{name: 'pagePath'}, {name: 'country'}, {name: 'deviceCategory'}]",
          "required": false
        },
        "metrics": {
          "type": "array",
          "description": "[{name: 'sessions'}, {name: 'users'}, {name: 'bounceRate'}, {name: 'totalRevenue'}]",
          "required": true
        },
        "dimensionFilter": {
          "type": "object",
          "description": "Filter rows",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 100
        }
      },
      "output": {
        "type": "report",
        "fields": [
          "rows[0].dimensionValues[0].value",
          "rows[0].metricValues[0].value",
          "rowCount",
          "totals[0].metricValues[0].value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "run_realtime_report",
      "description_for_ai": "Get real-time analytics data from GA4 (active users in last 30 minutes).",
      "intent": [
        "real-time analytics",
        "active users",
        "live traffic",
        "реальное время аналитика"
      ],
      "endpoint": "POST https://analyticsdata.googleapis.com/v1beta/properties/{property}/runRealtimeReport",
      "input": {
        "property": {
          "type": "string",
          "required": true
        },
        "dimensions": {
          "type": "array",
          "description": "[{name: 'country'}, {name: 'pagePath'}]",
          "required": false
        },
        "metrics": {
          "type": "array",
          "description": "[{name: 'activeUsers'}]",
          "required": true
        }
      },
      "output": {
        "type": "realtime_report",
        "fields": [
          "rows[0].dimensionValues[0].value",
          "rows[0].metricValues[0].value",
          "totals[0].metricValues[0].value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_properties",
      "description_for_ai": "List GA4 properties in your Google Analytics account.",
      "intent": [
        "GA4 properties",
        "Analytics properties",
        "my websites GA4",
        "свойства Google Analytics"
      ],
      "endpoint": "GET https://analyticsadmin.googleapis.com/v1beta/properties",
      "input": {
        "filter": {
          "type": "string",
          "description": "parent:accounts/ACCOUNT_ID",
          "required": false
        },
        "pageSize": {
          "type": "integer",
          "default": 50
        }
      },
      "output": {
        "type": "list<property>",
        "fields": [
          "properties[0].name",
          "properties[0].displayName",
          "properties[0].industryCategory",
          "properties[0].timeZone"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "run_funnel_report",
      "description_for_ai": "Run a GA4 funnel analysis to track conversion steps.",
      "intent": [
        "funnel analytics",
        "conversion funnel GA4",
        "user journey analytics",
        "воронка конверсии GA4"
      ],
      "endpoint": "POST https://analyticsdata.googleapis.com/v1alpha/properties/{property}/runFunnelReport",
      "input": {
        "property": {
          "type": "string",
          "required": true
        },
        "dateRanges": {
          "type": "array",
          "required": true
        },
        "funnel": {
          "type": "object",
          "description": "{steps: [{name: 'Session Start', filterExpression: {funnel...}}, ...]}",
          "required": true
        }
      },
      "output": {
        "type": "funnel",
        "fields": [
          "funnelTable.rows[0].dimensionValues",
          "funnelTable.rows[0].metricValues"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "run_pivot_report",
      "description_for_ai": "Run a pivot table report in GA4 for multi-dimensional analysis.",
      "intent": [
        "pivot report GA4",
        "advanced analytics",
        "GA4 pivot",
        "сводная таблица GA4"
      ],
      "endpoint": "POST https://analyticsdata.googleapis.com/v1beta/properties/{property}/runPivotReport",
      "input": {
        "property": {
          "type": "string",
          "required": true
        },
        "dateRanges": {
          "type": "array",
          "required": true
        },
        "pivots": {
          "type": "array",
          "description": "[{fieldNames: ['country'], limit: 5, orderBys: [{metric: {metricName: 'sessions'}, desc: true}]}]",
          "required": true
        },
        "dimensions": {
          "type": "array",
          "required": true
        },
        "metrics": {
          "type": "array",
          "required": true
        }
      },
      "output": {
        "type": "pivot_report",
        "fields": [
          "pivotHeaders",
          "rows[0].dimensionValues",
          "rows[0].metricValues"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "batch_run_reports",
      "description_for_ai": "Run multiple GA4 reports in a single request (up to 5 reports).",
      "intent": [
        "batch reports GA4",
        "multiple reports",
        "bulk analytics",
        "пакетные отчёты GA4"
      ],
      "endpoint": "POST https://analyticsdata.googleapis.com/v1beta/properties/{property}:batchRunReports",
      "input": {
        "property": {
          "type": "string",
          "required": true
        },
        "requests": {
          "type": "array",
          "description": "Array of report request objects, same format as run_report",
          "required": true
        }
      },
      "output": {
        "type": "list<report>",
        "fields": [
          "reports[0].rows",
          "reports[0].rowCount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}