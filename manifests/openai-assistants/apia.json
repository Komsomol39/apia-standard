{
  "apia": "1.0",
  "service": {
    "id": "openai-assistants",
    "name": "OpenAI Assistants API",
    "description_for_ai": "Build AI assistants with persistent memory, file search, and code execution. Assistants maintain conversation history, can search uploaded documents (RAG), and run Python code. Use for document Q&A chatbots, coding assistants, data analysis bots.",
    "url": "https://openai.com",
    "api_base": "https://api.openai.com/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.openai.com/docs/assistants/overview"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "OpenAI API key",
    "cost": "Same as underlying model + $0.10/GB/day file storage"
  },
  "capabilities": [
    {
      "id": "create_assistant",
      "description_for_ai": "Create an OpenAI Assistant with custom instructions, tools, and knowledge files.",
      "intent": [
        "create assistant OpenAI",
        "AI assistant setup",
        "custom GPT API",
        "создать ассистента OpenAI"
      ],
      "endpoint": "POST https://api.openai.com/v1/assistants",
      "input": {
        "name": {
          "type": "string",
          "required": true
        },
        "instructions": {
          "type": "string",
          "description": "System prompt for the assistant",
          "required": false
        },
        "model": {
          "type": "string",
          "description": "gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo",
          "required": true
        },
        "tools": {
          "type": "array",
          "description": "[{type: 'code_interpreter'}, {type: 'file_search'}, {type: 'function', function: {name, description, parameters}}]",
          "required": false
        },
        "tool_resources": {
          "type": "object",
          "description": "{file_search: {vector_store_ids: [...]}, code_interpreter: {file_ids: [...]}}",
          "required": false
        }
      },
      "output": {
        "type": "assistant",
        "fields": [
          "id",
          "name",
          "model",
          "instructions",
          "tools"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_thread",
      "description_for_ai": "Create a conversation thread for an OpenAI Assistant. Threads hold messages.",
      "intent": [
        "create thread OpenAI",
        "start conversation",
        "new thread",
        "новый тред OpenAI"
      ],
      "endpoint": "POST https://api.openai.com/v1/threads",
      "input": {
        "messages": {
          "type": "array",
          "description": "Optional initial messages: [{role: 'user', content: 'Hello'}]",
          "required": false
        }
      },
      "output": {
        "type": "thread",
        "fields": [
          "id",
          "object",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "add_message",
      "description_for_ai": "Add a user message to an OpenAI Assistants thread.",
      "intent": [
        "add message thread",
        "send message assistant",
        "user message thread",
        "добавить сообщение OpenAI"
      ],
      "endpoint": "POST https://api.openai.com/v1/threads/{thread_id}/messages",
      "input": {
        "thread_id": {
          "type": "string",
          "required": true
        },
        "role": {
          "type": "string",
          "default": "user"
        },
        "content": {
          "type": "string or array",
          "description": "Text or array of content blocks with file attachments",
          "required": true
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "id",
          "thread_id",
          "role",
          "content[0].text.value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "run_thread",
      "description_for_ai": "Run an assistant on a thread to generate a response.",
      "intent": [
        "run assistant",
        "generate response",
        "execute assistant",
        "запустить ассистента OpenAI"
      ],
      "endpoint": "POST https://api.openai.com/v1/threads/{thread_id}/runs",
      "input": {
        "thread_id": {
          "type": "string",
          "required": true
        },
        "assistant_id": {
          "type": "string",
          "required": true
        },
        "instructions": {
          "type": "string",
          "description": "Override assistant instructions for this run",
          "required": false
        },
        "additional_messages": {
          "type": "array",
          "required": false
        }
      },
      "output": {
        "type": "run",
        "fields": [
          "id",
          "status (queued/in_progress/completed/failed)",
          "thread_id",
          "assistant_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_messages",
      "description_for_ai": "Get all messages from an OpenAI Assistants thread.",
      "intent": [
        "get messages thread",
        "conversation history",
        "thread messages",
        "сообщения треда OpenAI"
      ],
      "endpoint": "GET https://api.openai.com/v1/threads/{thread_id}/messages",
      "input": {
        "thread_id": {
          "type": "string",
          "required": true
        },
        "limit": {
          "type": "integer",
          "default": 20
        },
        "order": {
          "type": "string",
          "description": "asc or desc",
          "default": "asc"
        }
      },
      "output": {
        "type": "list<message>",
        "fields": [
          "data[0].id",
          "data[0].role",
          "data[0].content[0].text.value",
          "data[0].created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "upload_file",
      "description_for_ai": "Upload a file to use with OpenAI Assistants for file_search or code_interpreter.",
      "intent": [
        "upload file OpenAI",
        "assistant file",
        "document assistant",
        "файл ассистента OpenAI"
      ],
      "endpoint": "POST https://api.openai.com/v1/files",
      "input": {
        "file": {
          "type": "file",
          "description": "Document, code, or data file",
          "required": true
        },
        "purpose": {
          "type": "string",
          "description": "assistants or fine-tune or vision",
          "default": "assistants"
        }
      },
      "output": {
        "type": "file",
        "fields": [
          "id",
          "filename",
          "bytes",
          "created_at",
          "purpose"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "flow": "1) Create assistant once. 2) Create thread per user. 3) Add messages to thread. 4) Create run → poll until completed → get messages.",
    "vs_chat": "Assistants: persistent memory, file search, code execution. Chat Completions: simpler, cheaper, more control."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}