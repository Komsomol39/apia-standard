{
  "apia": "1.0",
  "service": {
    "id": "openai-assistants",
    "name": "OpenAI Assistants API",
    "description_for_ai": "Build AI assistants with persistent memory, file search, and code execution. Assistants maintain conversation history, can search uploaded documents (RAG), and run Python code. Use for document Q&A chatbots, coding assistants, data analysis bots.",
    "url": "https://openai.com",
    "api_base": "https://api.openai.com/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.openai.com/docs/assistants/overview"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "OpenAI API key",
    "cost": "Same as underlying model + $0.10/GB/day file storage"
  },
  "capabilities": [
    {
      "id": "create_assistant",
      "description_for_ai": "Create an AI assistant with instructions, tools (code_interpreter, file_search), and model.",
      "intent": [
        "create chatbot",
        "AI assistant",
        "document Q&A bot",
        "code assistant",
        "RAG assistant"
      ],
      "endpoint": "POST https://api.openai.com/v1/assistants",
      "input": {
        "name": {
          "type": "string",
          "required": true,
          "description": "Name identifier"
        },
        "instructions": {
          "type": "string",
          "description": "System prompt for the assistant",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "AI/ML model identifier to use for this request"
        },
        "tools": {
          "type": "array",
          "description": "[{type: code_interpreter}, {type: file_search}]",
          "required": false
        },
        "tool_resources": {
          "type": "object",
          "description": "Attach vector stores for file search",
          "required": false
        }
      },
      "output": {
        "type": "assistant",
        "fields": [
          "id",
          "name",
          "model",
          "tools"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "run_thread",
      "description_for_ai": "Send a message to an assistant thread and get response. Handles multi-turn conversation with memory.",
      "intent": [
        "chat with assistant",
        "send message",
        "assistant response",
        "conversation",
        "Q&A"
      ],
      "endpoint": "POST https://api.openai.com/v1/threads/{thread_id}/runs",
      "input": {
        "thread_id": {
          "type": "string",
          "required": true
        },
        "assistant_id": {
          "type": "string",
          "required": true
        },
        "additional_instructions": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "run",
        "fields": [
          "id",
          "status",
          "thread_id"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "flow": "1) Create assistant once. 2) Create thread per user. 3) Add messages to thread. 4) Create run → poll until completed → get messages.",
    "vs_chat": "Assistants: persistent memory, file search, code execution. Chat Completions: simpler, cheaper, more control."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}