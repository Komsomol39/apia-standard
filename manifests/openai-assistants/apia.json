{
  "apia": "1.0",
  "service": {
    "id": "openai-assistants",
    "name": "OpenAI Assistants API",
    "description_for_ai": "Build AI assistants with persistent memory, file search, and code execution. Assistants maintain conversation history, can search uploaded documents (RAG), and run Python code. Use for document Q&A chatbots, coding assistants, data analysis bots.",
    "url": "https://openai.com",
    "api_base": "https://api.openai.com/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://platform.openai.com/docs/assistants/overview"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "OpenAI API key",
    "cost": "Same as underlying model + $0.10/GB/day file storage"
  },
  "capabilities": [
    {
      "id": "create_assistant",
      "description_for_ai": "Create an OpenAI Assistant with instructions, tools (code_interpreter, file_search, custom functions), and knowledge files.",
      "intent": [
        "create assistant openai",
        "build AI agent",
        "custom GPT API",
        "создать ассистента openai"
      ],
      "endpoint": "POST https://api.openai.com/v1/assistants",
      "input": {
        "model": {
          "type": "string",
          "description": "gpt-4o, gpt-4o-mini",
          "required": true
        },
        "name": {
          "type": "string",
          "required": false
        },
        "instructions": {
          "type": "string",
          "description": "System prompt / role for the assistant",
          "required": false
        },
        "tools": {
          "type": "array",
          "description": "[{type: code_interpreter}, {type: file_search}, {type: function, function: {name, description, parameters}}]",
          "required": false
        },
        "tool_resources": {
          "type": "object",
          "description": "{file_search: {vector_store_ids: ['vs_xxx']}} to add knowledge base",
          "required": false
        },
        "temperature": {
          "type": "float",
          "required": false
        }
      },
      "output": {
        "type": "assistant",
        "fields": [
          "id",
          "name",
          "model",
          "instructions",
          "tools",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_thread_and_run",
      "description_for_ai": "Create a thread and run an assistant in one call. The simplest way to get a response from an assistant.",
      "intent": [
        "run assistant openai",
        "assistant response",
        "chat with assistant",
        "запустить ассистента openai"
      ],
      "endpoint": "POST https://api.openai.com/v1/threads/runs",
      "input": {
        "assistant_id": {
          "type": "string",
          "required": true
        },
        "thread": {
          "type": "object",
          "description": "{messages: [{role: user, content: 'Your question here'}]}",
          "required": true
        },
        "instructions": {
          "type": "string",
          "description": "Override assistant instructions for this run",
          "required": false
        }
      },
      "output": {
        "type": "run",
        "fields": [
          "id",
          "thread_id",
          "status",
          "assistant_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_messages",
      "description_for_ai": "Get messages from a thread after a run completes. Poll run status first.",
      "intent": [
        "get assistant messages",
        "assistant reply",
        "thread messages openai",
        "ответ ассистента"
      ],
      "endpoint": "GET https://api.openai.com/v1/threads/{thread_id}/messages",
      "input": {
        "thread_id": {
          "type": "string",
          "required": true
        },
        "limit": {
          "type": "integer",
          "default": 20
        },
        "order": {
          "type": "string",
          "description": "asc or desc",
          "default": "asc"
        }
      },
      "output": {
        "type": "list<message>",
        "fields": [
          "data[0].role",
          "data[0].content[0].text.value",
          "data[0].created_at",
          "data[0].run_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "upload_file",
      "description_for_ai": "Upload a file to use as knowledge base for an assistant via file_search.",
      "intent": [
        "upload file assistant",
        "assistant knowledge",
        "file search openai",
        "загрузить файл ассистенту"
      ],
      "endpoint": "POST https://api.openai.com/v1/files",
      "input": {
        "file": {
          "type": "file",
          "description": "File to upload: PDF, DOCX, TXT, CSV, MD, etc.",
          "required": true
        },
        "purpose": {
          "type": "string",
          "description": "assistants (for knowledge base) or fine-tune",
          "required": true
        }
      },
      "output": {
        "type": "file",
        "fields": [
          "id",
          "filename",
          "bytes",
          "purpose",
          "status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "flow": "1) Create assistant once. 2) Create thread per user. 3) Add messages to thread. 4) Create run → poll until completed → get messages.",
    "vs_chat": "Assistants: persistent memory, file search, code execution. Chat Completions: simpler, cheaper, more control."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}