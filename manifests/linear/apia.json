{
  "apia": "1.0",
  "service": {
    "id": "linear",
    "name": "Linear API",
    "description_for_ai": "Modern issue tracker loved by engineering teams. Issues, projects, cycles (sprints), roadmaps, automations. GraphQL API. Used by Vercel, Retool, Loom. Fast and developer-friendly.",
    "url": "https://linear.app",
    "api_base": "https://api.linear.app/graphql",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.linear.app/docs/graphql/working-with-the-graphql-api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: {api_key}",
    "how_to_get": "Settings → API → Personal API keys",
    "cost": "Free: 250 issues. Pro: $8/user/month"
  },
  "capabilities": [
    {
      "id": "list_issues",
      "description_for_ai": "List issues in Linear. Filter by team, project, assignee, state, priority.",
      "intent": [
        "Linear issues",
        "bug list Linear",
        "tasks Linear",
        "задачи Linear"
      ],
      "endpoint": "POST https://api.linear.app/graphql",
      "input": {
        "query": {
          "type": "graphql",
          "description": "GraphQL query: { issues(filter: {team: {name: {eq: \"Engineering\"}}, state: {name: {eq: \"In Progress\"}}}) { nodes { id title state { name } assignee { name } priority createdAt } } }",
          "required": true
        }
      },
      "output": {
        "type": "list<issue>",
        "fields": [
          "id",
          "title",
          "state.name",
          "assignee.name",
          "priority",
          "createdAt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_issue",
      "description_for_ai": "Create a new issue in Linear with title, description, assignee, and priority.",
      "intent": [
        "create issue Linear",
        "new task Linear",
        "bug report Linear",
        "создать задачу Linear"
      ],
      "endpoint": "POST https://api.linear.app/graphql",
      "input": {
        "mutation": {
          "type": "graphql",
          "description": "mutation { issueCreate(input: {teamId: \"team-id\", title: \"Title\", description: \"Markdown desc\", assigneeId: \"user-id\", priority: 1, labelIds: [\"label-id\"]}) { success issue { id identifier title url } } }",
          "required": true
        }
      },
      "output": {
        "type": "issue",
        "fields": [
          "issueCreate.success",
          "issueCreate.issue.id",
          "issueCreate.issue.identifier",
          "issueCreate.issue.url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_issue",
      "description_for_ai": "Update issue state, assignee, priority, or description.",
      "intent": [
        "update issue Linear",
        "close issue Linear",
        "assign issue Linear",
        "обновить задачу Linear"
      ],
      "endpoint": "POST https://api.linear.app/graphql",
      "input": {
        "mutation": {
          "type": "graphql",
          "description": "mutation { issueUpdate(id: \"issue-id\", input: {stateId: \"done-state-id\", assigneeId: \"user-id\"}) { success } }",
          "required": true
        }
      },
      "output": {
        "type": "update",
        "fields": [
          "issueUpdate.success"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_teams",
      "description_for_ai": "List all teams in the Linear workspace.",
      "intent": [
        "Linear teams",
        "workspace teams",
        "команды Linear"
      ],
      "endpoint": "POST https://api.linear.app/graphql",
      "input": {
        "query": {
          "type": "graphql",
          "description": "{ teams { nodes { id name description members { nodes { name } } } } }",
          "required": true
        }
      },
      "output": {
        "type": "list<team>",
        "fields": [
          "id",
          "name",
          "description"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_issues",
      "description_for_ai": "Search issues by keyword across all teams.",
      "intent": [
        "search Linear",
        "find issue",
        "issue search",
        "поиск задач Linear"
      ],
      "endpoint": "POST https://api.linear.app/graphql",
      "input": {
        "query": {
          "type": "graphql",
          "description": "{ issueSearch(query: \"search term\", last: 20) { nodes { id title state { name } assignee { name } url } } }",
          "required": true
        }
      },
      "output": {
        "type": "list<issue>",
        "fields": [
          "id",
          "title",
          "state.name",
          "url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_project",
      "description_for_ai": "Create a new project in Linear to group related issues.",
      "intent": [
        "create project Linear",
        "new project",
        "project Linear",
        "проект Linear"
      ],
      "endpoint": "POST https://api.linear.app/graphql",
      "input": {
        "mutation": {
          "type": "graphql",
          "description": "mutation { projectCreate(input: {name: \"Project name\", description: \"Markdown desc\", teamIds: [\"team-id\"], targetDate: \"2024-12-31\"}) { success project { id name url } } }",
          "required": true
        }
      },
      "output": {
        "type": "project",
        "fields": [
          "projectCreate.project.id",
          "projectCreate.project.name",
          "projectCreate.project.url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "graphql": "Linear uses GraphQL only. All queries and mutations go to same endpoint.",
    "priority": "0=No priority, 1=Urgent, 2=High, 3=Medium, 4=Low"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}