{
  "apia": "1.0",
  "service": {
    "id": "linear",
    "name": "Linear API",
    "description_for_ai": "Modern issue tracker loved by engineering teams. Issues, projects, cycles (sprints), roadmaps, automations. GraphQL API. Used by Vercel, Retool, Loom. Fast and developer-friendly.",
    "url": "https://linear.app",
    "api_base": "https://api.linear.app/graphql",
    "category": "developer_project",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.linear.app/docs/graphql/working-with-the-graphql-api"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: {api_key}",
    "how_to_get": "Settings → API → Personal API keys",
    "cost": "Free: 250 issues. Pro: $8/user/month"
  },
  "capabilities": [
    {
      "id": "get_issues",
      "description_for_ai": "Get issues from Linear workspace with filters. Returns title, status, assignee, priority, team.",
      "intent": [
        "linear issues",
        "tasks",
        "project issues",
        "sprint tasks",
        "engineering tasks"
      ],
      "endpoint": "POST https://api.linear.app/graphql",
      "input": {
        "query": {
          "type": "string",
          "description": "GraphQL query for issues",
          "required": true
        }
      },
      "output": {
        "type": "list<issue>",
        "fields": [
          "id",
          "title",
          "state.name",
          "assignee.name",
          "priority",
          "team.name",
          "createdAt"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_issue",
      "description_for_ai": "Create new Linear issue.",
      "intent": [
        "create linear issue",
        "new task",
        "add to linear"
      ],
      "endpoint": "POST https://api.linear.app/graphql",
      "input": {
        "mutation": {
          "type": "string",
          "description": "GraphQL mutation: mutation { issueCreate(input: {title, teamId, description, priority}) { issue { id title } } }",
          "required": true
        }
      },
      "output": {
        "type": "issue",
        "fields": [
          "id",
          "title",
          "url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "graphql": "Linear uses GraphQL only. All queries and mutations go to same endpoint.",
    "priority": "0=No priority, 1=Urgent, 2=High, 3=Medium, 4=Low"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}