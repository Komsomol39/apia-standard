{
  "apia": "1.0",
  "service": {
    "id": "discord",
    "name": "Discord API",
    "description_for_ai": "Discord API — messaging platform with 500M+ registered users popular in gaming, tech, and communities. Create bots, manage servers, send messages, handle slash commands. Webhooks for integrations. Free bot hosting and unlimited messages. Rich embed support with buttons and select menus.",
    "url": "https://discord.com",
    "api_base": "https://discord.com/api/v10",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://discord.com/developers/docs/intro"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "how_to_get": "Create app at https://discord.com/developers/applications → Bot → Token. Free.",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "send_message",
      "description_for_ai": "Send a message to a Discord channel. Supports text, embeds, file attachments, and components (buttons).",
      "intent": [
        "send discord message",
        "discord notify",
        "post in discord",
        "discord channel message",
        "отправить в discord"
      ],
      "endpoint": "POST https://discord.com/api/v10/channels/{channel_id}/messages",
      "input": {
        "channel_id": {
          "type": "string",
          "required": true
        },
        "content": {
          "type": "string",
          "description": "Message text, max 2000 chars",
          "required": false
        },
        "embeds": {
          "type": "array",
          "description": "[{title, description, color: 0x00ff00, fields: [{name, value, inline}], footer: {text}, timestamp}]",
          "required": false
        },
        "components": {
          "type": "array",
          "description": "Action rows with buttons",
          "required": false
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "id",
          "channel_id",
          "content",
          "timestamp",
          "author.username"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_channel",
      "description_for_ai": "Create a text, voice, or category channel in a Discord server (guild).",
      "intent": [
        "create discord channel",
        "new channel discord",
        "discord category",
        "voice channel",
        "создать канал discord"
      ],
      "endpoint": "POST https://discord.com/api/v10/guilds/{guild_id}/channels",
      "input": {
        "guild_id": {
          "type": "string",
          "required": true
        },
        "name": {
          "type": "string",
          "description": "Channel name (lowercase, hyphens)",
          "required": true
        },
        "type": {
          "type": "integer",
          "description": "0=text, 2=voice, 4=category, 5=announcement, 15=forum",
          "default": 0
        },
        "parent_id": {
          "type": "string",
          "description": "Category channel ID",
          "required": false
        },
        "topic": {
          "type": "string",
          "description": "Channel description",
          "required": false
        },
        "permission_overwrites": {
          "type": "array",
          "description": "Role/user permission overrides",
          "required": false
        }
      },
      "output": {
        "type": "channel",
        "fields": [
          "id",
          "name",
          "type",
          "guild_id",
          "parent_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_guild_members",
      "description_for_ai": "List members of a Discord server with roles, nicknames, and join dates.",
      "intent": [
        "discord members",
        "server members",
        "guild members",
        "who is in server",
        "участники discord"
      ],
      "endpoint": "GET https://discord.com/api/v10/guilds/{guild_id}/members",
      "input": {
        "guild_id": {
          "type": "string",
          "required": true
        },
        "limit": {
          "type": "integer",
          "description": "1-1000",
          "default": 100
        },
        "after": {
          "type": "string",
          "description": "User ID for pagination",
          "required": false
        }
      },
      "output": {
        "type": "list<member>",
        "fields": [
          "[0].user.id",
          "[0].user.username",
          "[0].nick",
          "[0].roles",
          "[0].joined_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "add_role",
      "description_for_ai": "Add a role to a guild member.",
      "intent": [
        "add role discord",
        "give role",
        "assign role",
        "discord role",
        "выдать роль discord"
      ],
      "endpoint": "PUT https://discord.com/api/v10/guilds/{guild_id}/members/{user_id}/roles/{role_id}",
      "input": {
        "guild_id": {
          "type": "string",
          "required": true
        },
        "user_id": {
          "type": "string",
          "required": true
        },
        "role_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "204 No Content on success"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_webhook",
      "description_for_ai": "Create a webhook for a channel to receive external notifications (CI/CD, monitoring, etc.).",
      "intent": [
        "discord webhook",
        "notification webhook",
        "channel webhook",
        "integration discord",
        "вебхук discord"
      ],
      "endpoint": "POST https://discord.com/api/v10/channels/{channel_id}/webhooks",
      "input": {
        "channel_id": {
          "type": "string",
          "required": true
        },
        "name": {
          "type": "string",
          "description": "Webhook display name",
          "required": true
        },
        "avatar": {
          "type": "string",
          "description": "Avatar image URL",
          "required": false
        }
      },
      "output": {
        "type": "webhook",
        "fields": [
          "id",
          "token",
          "url",
          "channel_id",
          "name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_messages",
      "description_for_ai": "Get message history from a Discord channel.",
      "intent": [
        "discord history",
        "channel messages",
        "read discord",
        "message history",
        "история discord"
      ],
      "endpoint": "GET https://discord.com/api/v10/channels/{channel_id}/messages",
      "input": {
        "channel_id": {
          "type": "string",
          "required": true
        },
        "limit": {
          "type": "integer",
          "description": "1-100",
          "default": 50
        },
        "before": {
          "type": "string",
          "description": "Message ID — get messages before this",
          "required": false
        },
        "after": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<message>",
        "fields": [
          "[0].id",
          "[0].content",
          "[0].author.username",
          "[0].timestamp",
          "[0].attachments"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "add_reaction",
      "description_for_ai": "Add an emoji reaction to a message.",
      "intent": [
        "react discord",
        "discord emoji reaction",
        "add reaction",
        "emoji message",
        "реакция discord"
      ],
      "endpoint": "PUT https://discord.com/api/v10/channels/{channel_id}/messages/{message_id}/reactions/{emoji}/@me",
      "input": {
        "channel_id": {
          "type": "string",
          "required": true
        },
        "message_id": {
          "type": "string",
          "required": true
        },
        "emoji": {
          "type": "string",
          "description": "Unicode emoji (👍) or custom emoji format (name:id)",
          "required": true
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "204 No Content on success"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "webhook_simplest": "For one-way notifications use send_webhook — no OAuth, no bot setup. Get webhook URL from channel Settings → Integrations → Webhooks.",
    "embed_color": "Embed color is an integer. Blue=3447003, Green=5763719, Red=15548997, Yellow=16705372. Convert hex to decimal.",
    "channel_id": "Right-click any channel in Discord → Copy Channel ID (need Developer Mode enabled in Discord settings).",
    "rate_limits": "Discord has per-channel rate limits (5 req/5 sec). Space out messages to avoid 429 errors.",
    "openclaw": "OpenClaw community lives on Discord — this API is how OpenClaw bots post to channels."
  },
  "limits": {
    "messages_per_5sec_per_channel": 5,
    "commercial_use": true,
    "attribution_required": false,
    "cost": "Free"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}