{
  "apia": "1.0",
  "service": {
    "id": "rest-countries",
    "name": "RestCountries API",
    "description_for_ai": "Free country data API. 250 countries with name, capital, population, area, currency, languages, flag, borders, timezone, calling code. No API key needed. Use for country info, flags, geographic data.",
    "url": "https://restcountries.com",
    "api_base": "https://restcountries.com/v3.1",
    "category": "maps",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://restcountries.com/#about-project"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free forever"
  },
  "capabilities": [
    {
      "id": "get_country",
      "description_for_ai": "Get all info about a country: population, area, capital, currency, languages, flag emoji, borders.",
      "intent": [
        "country info",
        "capital city",
        "country population",
        "currency of",
        "flag of country",
        "official language",
        "информация о стране",
        "столица"
      ],
      "endpoint": "GET https://restcountries.com/v3.1/name/{name}",
      "input": {
        "name": {
          "type": "string",
          "description": "Country name e.g. Germany, Russia, Japan",
          "required": true
        },
        "fullText": {
          "type": "boolean",
          "description": "true for exact match only",
          "required": false
        }
      },
      "output": {
        "type": "list<country>",
        "fields": [
          "name.common",
          "name.official",
          "capital",
          "population",
          "area",
          "currencies",
          "languages",
          "flag",
          "borders",
          "timezones",
          "callingCodes"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_by_code",
      "description_for_ai": "Get country by ISO alpha-2 or alpha-3 code.",
      "intent": [
        "country by code",
        "ISO code lookup",
        "country code"
      ],
      "endpoint": "GET https://restcountries.com/v3.1/alpha/{code}",
      "input": {
        "code": {
          "type": "string",
          "description": "ISO 3166-1 alpha-2 (RU, DE, US) or alpha-3 (RUS, DEU, USA)",
          "required": true
        }
      },
      "output": {
        "type": "country",
        "fields": [
          "name.common",
          "capital",
          "population",
          "currencies",
          "languages",
          "flag"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_country",
      "description_for_ai": "Get detailed info about a country: capital, population, currencies, languages, flag.",
      "intent": [
        "country info",
        "country details",
        "country data",
        "информация о стране"
      ],
      "endpoint": "GET https://restcountries.com/v3.1/name/{name}",
      "input": {
        "name": {
          "type": "string",
          "description": "Country name in English",
          "required": true
        },
        "fullText": {
          "type": "boolean",
          "description": "Exact name match",
          "default": false
        }
      },
      "output": {
        "type": "list<country>",
        "fields": [
          "[0].name.common",
          "[0].capital[0]",
          "[0].population",
          "[0].area",
          "[0].currencies",
          "[0].languages",
          "[0].flags.svg"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_by_code",
      "description_for_ai": "Get country by ISO 3166-1 alpha-2 or alpha-3 code.",
      "intent": [
        "country by code",
        "ISO country code",
        "страна по коду ISO"
      ],
      "endpoint": "GET https://restcountries.com/v3.1/alpha/{code}",
      "input": {
        "code": {
          "type": "string",
          "description": "2-letter (RU, US, DE) or 3-letter (RUS, USA) code",
          "required": true
        }
      },
      "output": {
        "type": "country",
        "fields": [
          "name.common",
          "capital",
          "population",
          "currencies",
          "languages",
          "region",
          "subregion"
        ]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_by_region",
      "description_for_ai": "Get all countries in a continent/region.",
      "intent": [
        "countries by region",
        "Europe countries",
        "African countries",
        "страны по региону"
      ],
      "endpoint": "GET https://restcountries.com/v3.1/region/{region}",
      "input": {
        "region": {
          "type": "string",
          "description": "Africa, Americas, Asia, Europe, Oceania, Antarctic",
          "required": true
        }
      },
      "output": {
        "type": "list<country>",
        "fields": [
          "[0].name.common",
          "[0].capital[0]",
          "[0].population",
          "[0].flags.svg"
        ]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "by_code": "get_by_code is faster for known countries. get_country (by name) does fuzzy matching.",
    "fields_filter": "Add ?fields=name,capital,population to get only needed fields and reduce response size.",
    "languages": "Returns languages as object: {eng: 'English', fra: 'French'}. Key is 3-letter ISO 639-3 code.",
    "cca2": "cca2 = ISO 3166-1 alpha-2 (RU, US). cca3 = alpha-3 (RUS, USA). ccn3 = numeric (643, 840)."
  }
}