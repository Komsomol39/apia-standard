{"apia":"1.0","service":{"id":"greenhouse","name":"Greenhouse Recruiting API","description_for_ai":"Applicant tracking system (ATS). Manage job postings, candidates, interviews, offers. Used by 7000+ companies including Airbnb, DoorDash. Use for recruiting automation, candidate pipeline management.","url":"https://greenhouse.io","api_base":"https://harvest.greenhouse.io/v1","category":"hr_recruiting","geo":["GLOBAL"],"language":"en","docs":"https://developers.greenhouse.io/harvest.html"},"auth":{"type":"basic_auth","anonymous_access":false,"note":"API key as username, empty password","how_to_get":"Configure → Dev Center → API Credential Management","cost":"Enterprise pricing. Demo available"},"capabilities":[{"id":"list_jobs","description_for_ai":"Get all open job postings with departments, locations, and application URLs.","intent":["job openings","career positions","open roles","hiring","job listings","vacancy list"],"endpoint":"GET https://harvest.greenhouse.io/v1/jobs","input":{"status":{"type":"string","description":"open, closed, draft","default":"open"},"per_page":{"type":"integer","default":100}},"output":{"type":"list<job>","fields":["id","name","status","departments[0].name","offices[0].name","job_posts[0].title","created_at"]},"realtime":true,"requires_auth":true},{"id":"get_candidates","description_for_ai":"Get candidate profiles with application status, resume, interviews.","intent":["candidates","applicants","job applications","hiring pipeline","recruiting funnel"],"endpoint":"GET https://harvest.greenhouse.io/v1/candidates","input":{"job_id":{"type":"integer","required":false},"status":{"type":"string","description":"active, rejected","required":false},"per_page":{"type":"integer","default":100}},"output":{"type":"list<candidate>","fields":["id","first_name","last_name","email_addresses[0].value","applications[0].status","applications[0].current_stage.name","applications[0].applied_at"]},"realtime":true,"requires_auth":true}],"meta":{"apia_version":"1