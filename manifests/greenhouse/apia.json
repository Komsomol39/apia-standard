{
  "apia": "1.0",
  "service": {
    "id": "greenhouse",
    "name": "Greenhouse Recruiting API",
    "description_for_ai": "Applicant tracking system (ATS). Manage job postings, candidates, interviews, offers. Used by 7000+ companies including Airbnb, DoorDash. Use for recruiting automation, candidate pipeline management.",
    "url": "https://greenhouse.io",
    "api_base": "https://harvest.greenhouse.io/v1",
    "category": "hr",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.greenhouse.io/harvest.html"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "API key as username, empty password",
    "how_to_get": "Configure → Dev Center → API Credential Management",
    "cost": "Enterprise pricing. Demo available"
  },
  "capabilities": [
    {
      "id": "list_jobs",
      "description_for_ai": "List open job positions in Greenhouse ATS.",
      "intent": [
        "greenhouse jobs",
        "open positions",
        "job listings HR",
        "вакансии greenhouse"
      ],
      "endpoint": "GET https://harvest.greenhouse.io/v1/jobs",
      "input": {
        "per_page": {
          "type": "integer",
          "default": 100
        },
        "page": {
          "type": "integer",
          "default": 1
        },
        "requisition_id": {
          "type": "string",
          "required": false
        },
        "status": {
          "type": "string",
          "description": "open, closed, draft",
          "required": false
        }
      },
      "output": {
        "type": "list<job>",
        "fields": [
          "[0].id",
          "[0].name",
          "[0].status",
          "[0].departments[0].name",
          "[0].offices[0].name",
          "[0].opened_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_candidates",
      "description_for_ai": "List or search candidates in Greenhouse with their application status.",
      "intent": [
        "candidates greenhouse",
        "applicants list",
        "job candidates",
        "кандидаты greenhouse"
      ],
      "endpoint": "GET https://harvest.greenhouse.io/v1/candidates",
      "input": {
        "per_page": {
          "type": "integer",
          "default": 100
        },
        "job_id": {
          "type": "integer",
          "description": "Filter by job",
          "required": false
        },
        "email": {
          "type": "string",
          "description": "Search by email",
          "required": false
        },
        "created_after": {
          "type": "string",
          "description": "ISO 8601",
          "required": false
        }
      },
      "output": {
        "type": "list<candidate>",
        "fields": [
          "[0].id",
          "[0].first_name",
          "[0].last_name",
          "[0].email_addresses[0].value",
          "[0].applications[0].status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_candidate",
      "description_for_ai": "Add a new candidate to Greenhouse ATS.",
      "intent": [
        "add candidate greenhouse",
        "create applicant",
        "new candidate HR",
        "добавить кандидата"
      ],
      "endpoint": "POST https://harvest.greenhouse.io/v1/candidates",
      "input": {
        "first_name": {
          "type": "string",
          "required": true
        },
        "last_name": {
          "type": "string",
          "required": true
        },
        "email_addresses": {
          "type": "array",
          "description": "[{value: 'candidate@example.com', type: 'work'}]",
          "required": false
        },
        "phone_numbers": {
          "type": "array",
          "description": "[{value: '+1234567890', type: 'mobile'}]",
          "required": false
        },
        "addresses": {
          "type": "array",
          "required": false
        },
        "linkedin_url": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "candidate",
        "fields": [
          "id",
          "first_name",
          "last_name",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "move_application",
      "description_for_ai": "Move a candidate application to a different stage in the hiring pipeline.",
      "intent": [
        "move candidate stage",
        "advance application",
        "pipeline stage greenhouse",
        "перенести кандидата greenhouse"
      ],
      "endpoint": "POST https://harvest.greenhouse.io/v1/applications/{application_id}/move",
      "input": {
        "application_id": {
          "type": "integer",
          "required": true
        },
        "from_stage_id": {
          "type": "integer",
          "required": true
        },
        "to_stage_id": {
          "type": "integer",
          "description": "Get stage IDs from GET /v1/jobs/{job_id}/stages",
          "required": true
        }
      },
      "output": {
        "type": "application",
        "fields": [
          "id",
          "status",
          "current_stage.name",
          "applied_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}