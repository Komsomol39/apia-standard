{
  "apia": "1.0",
  "service": {
    "id": "greenhouse",
    "name": "Greenhouse Recruiting API",
    "description_for_ai": "Applicant tracking system (ATS). Manage job postings, candidates, interviews, offers. Used by 7000+ companies including Airbnb, DoorDash. Use for recruiting automation, candidate pipeline management.",
    "url": "https://greenhouse.io",
    "api_base": "https://harvest.greenhouse.io/v1",
    "category": "hr",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.greenhouse.io/harvest.html"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "API key as username, empty password",
    "how_to_get": "Configure → Dev Center → API Credential Management",
    "cost": "Enterprise pricing. Demo available"
  },
  "capabilities": [
    {
      "id": "list_jobs",
      "description_for_ai": "Get all job postings in Greenhouse ATS with department, location, and status. Use for job board integration and recruiting pipeline overview.",
      "intent": [
        "job openings",
        "career positions",
        "open roles",
        "hiring",
        "job listings",
        "vacancy list"
      ],
      "endpoint": "GET https://harvest.greenhouse.io/v1/jobs",
      "input": {
        "status": {
          "type": "string",
          "description": "open (active), closed, or draft",
          "default": "open"
        },
        "department_id": {
          "type": "integer",
          "description": "Filter by department ID. Get IDs from GET /departments.",
          "required": false
        },
        "office_id": {
          "type": "integer",
          "description": "Filter by office/location ID",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "description": "Results per page, max 500",
          "default": 100
        },
        "page": {
          "type": "integer",
          "description": "Page number for pagination",
          "default": 1
        }
      },
      "output": {
        "type": "list<job>",
        "fields": [
          "id",
          "name",
          "status",
          "departments[0].name",
          "offices[0].name",
          "job_posts[0].title",
          "job_posts[0].external_url",
          "created_at",
          "opened_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_candidates",
      "description_for_ai": "Get job applicant profiles with application status, current stage, and contact info. Use for recruiting pipeline management.",
      "intent": [
        "candidates",
        "applicants",
        "job applications",
        "hiring pipeline",
        "recruiting funnel"
      ],
      "endpoint": "GET https://harvest.greenhouse.io/v1/candidates",
      "input": {
        "job_id": {
          "type": "integer",
          "description": "Filter candidates by specific job ID",
          "required": false
        },
        "status": {
          "type": "string",
          "description": "active (in pipeline), hired, rejected. Default returns active.",
          "required": false
        },
        "created_after": {
          "type": "string",
          "description": "ISO 8601 date — return candidates created after this date",
          "required": false
        },
        "updated_after": {
          "type": "string",
          "description": "ISO 8601 date — return candidates updated after this date",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "description": "Results per page, max 500",
          "default": 100
        },
        "page": {
          "type": "integer",
          "description": "Page number",
          "default": 1
        }
      },
      "output": {
        "type": "list<candidate>",
        "fields": [
          "id",
          "first_name",
          "last_name",
          "email_addresses[0].value",
          "phone_numbers[0].value",
          "applications[0].status",
          "applications[0].current_stage.name",
          "applications[0].job.name",
          "applications[0].applied_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}