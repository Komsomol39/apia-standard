{
  "apia": "1.0",
  "service": {
    "id": "google-vision",
    "name": "Google Cloud Vision API",
    "description_for_ai": "Analyze images with Google AI. Detect objects, faces, text (OCR), logos, landmarks, explicit content, colors. Very accurate OCR for documents. 1000 units free/month.",
    "url": "https://cloud.google.com/vision",
    "api_base": "https://vision.googleapis.com/v1",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://cloud.google.com/vision/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Enable Vision API at https://console.cloud.google.com",
    "cost": "Free: 1000 units/month. Then $1.50/1000 for labels, $3.50/1000 for OCR"
  },
  "capabilities": [
    {
      "id": "detect_labels",
      "description_for_ai": "Detect objects and scenes in images with Google Vision API.",
      "intent": [
        "image labels Google",
        "object detection",
        "what is in image Google",
        "распознавание объектов Google Vision"
      ],
      "endpoint": "POST https://vision.googleapis.com/v1/images:annotate",
      "input": {
        "requests": {
          "type": "array",
          "description": "[{image: {content: 'base64' or source: {imageUri: 'gs://...'}}, features: [{type: 'LABEL_DETECTION', maxResults: 10}]}]",
          "required": true
        }
      },
      "output": {
        "type": "annotations",
        "fields": [
          "responses[0].labelAnnotations[0].description",
          "responses[0].labelAnnotations[0].score",
          "responses[0].labelAnnotations[0].topicality"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "text_detection",
      "description_for_ai": "Extract text from images using Google Vision OCR. Supports 50+ languages.",
      "intent": [
        "OCR Google",
        "read image text",
        "extract text photo",
        "OCR Google Vision"
      ],
      "endpoint": "POST https://vision.googleapis.com/v1/images:annotate",
      "input": {
        "requests": {
          "type": "array",
          "description": "[{image: {content: 'base64'}, features: [{type: 'TEXT_DETECTION'}]}]",
          "required": true
        }
      },
      "output": {
        "type": "text",
        "fields": [
          "responses[0].textAnnotations[0].description (full text)",
          "responses[0].textAnnotations[0].boundingPoly",
          "responses[0].fullTextAnnotation.pages[0].blocks"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "face_detection",
      "description_for_ai": "Detect faces and analyze emotions, headwear, and facial landmarks.",
      "intent": [
        "face detection Google",
        "facial analysis",
        "emotion detection photo",
        "определение эмоций Google Vision"
      ],
      "endpoint": "POST https://vision.googleapis.com/v1/images:annotate",
      "input": {
        "requests": {
          "type": "array",
          "description": "[{image: {content: 'base64'}, features: [{type: 'FACE_DETECTION', maxResults: 10}]}]",
          "required": true
        }
      },
      "output": {
        "type": "faces",
        "fields": [
          "responses[0].faceAnnotations[0].joyLikelihood",
          "responses[0].faceAnnotations[0].sorrowLikelihood",
          "responses[0].faceAnnotations[0].angerLikelihood",
          "responses[0].faceAnnotations[0].boundingPoly"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "safe_search",
      "description_for_ai": "Detect adult, violent, or racy content in images for content moderation.",
      "intent": [
        "safe search Google",
        "NSFW detection",
        "image moderation Google",
        "модерация фото Google Vision"
      ],
      "endpoint": "POST https://vision.googleapis.com/v1/images:annotate",
      "input": {
        "requests": {
          "type": "array",
          "description": "[{image: {content: 'base64'}, features: [{type: 'SAFE_SEARCH_DETECTION'}]}]",
          "required": true
        }
      },
      "output": {
        "type": "safe_search",
        "fields": [
          "responses[0].safeSearchAnnotation.adult (VERY_UNLIKELY to VERY_LIKELY)",
          "safeSearchAnnotation.violence",
          "safeSearchAnnotation.racy",
          "safeSearchAnnotation.medical"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "landmark_detection",
      "description_for_ai": "Identify famous landmarks and locations in photos.",
      "intent": [
        "landmark detection",
        "identify place photo",
        "famous landmark recognition",
        "определение достопримечательности Google Vision"
      ],
      "endpoint": "POST https://vision.googleapis.com/v1/images:annotate",
      "input": {
        "requests": {
          "type": "array",
          "description": "[{image: {content: 'base64'}, features: [{type: 'LANDMARK_DETECTION'}]}]",
          "required": true
        }
      },
      "output": {
        "type": "landmarks",
        "fields": [
          "responses[0].landmarkAnnotations[0].description",
          "responses[0].landmarkAnnotations[0].score",
          "responses[0].landmarkAnnotations[0].locations[0].latLng"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "feature_types": "LABEL_DETECTION=general labels, TEXT_DETECTION=OCR, DOCUMENT_TEXT_DETECTION=structured OCR, FACE_DETECTION=faces, OBJECT_LOCALIZATION=bounding boxes, LOGO_DETECTION=brand logos, LANDMARK_DETECTION=places, SAFE_SEARCH_DETECTION=explicit content",
    "vs_gemini": "For complex image understanding use Gemini Vision. For specific tasks (OCR, logos, explicit detection) use Vision API."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}