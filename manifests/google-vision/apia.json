{
  "apia": "1.0",
  "service": {
    "id": "google-vision",
    "name": "Google Cloud Vision API",
    "description_for_ai": "Analyze images with Google AI. Detect objects, faces, text (OCR), logos, landmarks, explicit content, colors. Very accurate OCR for documents. 1000 units free/month.",
    "url": "https://cloud.google.com/vision",
    "api_base": "https://vision.googleapis.com/v1",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://cloud.google.com/vision/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Enable Vision API at https://console.cloud.google.com",
    "cost": "Free: 1000 units/month. Then $1.50/1000 for labels, $3.50/1000 for OCR"
  },
  "capabilities": [
    {
      "id": "detect_labels",
      "description_for_ai": "Detect objects and labels in an image. Returns descriptions like 'Dog', 'Beach', 'Sunset'.",
      "intent": [
        "image labels",
        "detect objects",
        "image recognition",
        "распознавание объектов Google Vision"
      ],
      "endpoint": "POST https://vision.googleapis.com/v1/images:annotate",
      "input": {
        "image": {
          "type": "object",
          "description": "{content: 'BASE64'} or {source: {imageUri: 'https://...' or 'gs://...'}}",
          "required": true
        },
        "features": {
          "type": "array",
          "description": "[{type: 'LABEL_DETECTION', maxResults: 10}]",
          "required": true
        }
      },
      "output": {
        "type": "labels",
        "fields": [
          "responses[0].labelAnnotations[0].description",
          "responses[0].labelAnnotations[0].score (0-1)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "ocr",
      "description_for_ai": "Extract text from images (OCR). Supports printed and handwritten text in 50+ languages.",
      "intent": [
        "OCR",
        "extract text from image",
        "text recognition",
        "распознавание текста OCR Google"
      ],
      "endpoint": "POST https://vision.googleapis.com/v1/images:annotate",
      "input": {
        "image": {
          "type": "object",
          "description": "{content: 'BASE64'} or {source: {imageUri: '...'}}",
          "required": true
        },
        "features": {
          "type": "array",
          "description": "[{type: 'TEXT_DETECTION'}] for simple OCR or [{type: 'DOCUMENT_TEXT_DETECTION'}] for documents/PDFs",
          "required": true
        }
      },
      "output": {
        "type": "text",
        "fields": [
          "responses[0].fullTextAnnotation.text",
          "responses[0].textAnnotations[0].description",
          "responses[0].textAnnotations[0].boundingPoly"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_faces",
      "description_for_ai": "Detect faces in images with emotion likelihood and face position.",
      "intent": [
        "face detection",
        "facial recognition",
        "emotions in image",
        "обнаружение лиц Google Vision"
      ],
      "endpoint": "POST https://vision.googleapis.com/v1/images:annotate",
      "input": {
        "image": {
          "type": "object",
          "required": true
        },
        "features": {
          "type": "array",
          "description": "[{type: 'FACE_DETECTION', maxResults: 10}]",
          "required": true
        }
      },
      "output": {
        "type": "faces",
        "fields": [
          "responses[0].faceAnnotations[0].joyLikelihood",
          "responses[0].faceAnnotations[0].sorrowLikelihood",
          "responses[0].faceAnnotations[0].boundingPoly",
          "responses[0].faceAnnotations[0].detectionConfidence"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "safe_search",
      "description_for_ai": "Detect explicit, violent, or inappropriate content in images.",
      "intent": [
        "safe search",
        "content moderation image",
        "explicit content detection",
        "модерация изображений Google"
      ],
      "endpoint": "POST https://vision.googleapis.com/v1/images:annotate",
      "input": {
        "image": {
          "type": "object",
          "required": true
        },
        "features": {
          "type": "array",
          "description": "[{type: 'SAFE_SEARCH_DETECTION'}]",
          "required": true
        }
      },
      "output": {
        "type": "safe_search",
        "fields": [
          "responses[0].safeSearchAnnotation.adult (VERY_LIKELY/LIKELY/POSSIBLE/UNLIKELY/VERY_UNLIKELY)",
          "responses[0].safeSearchAnnotation.violence",
          "responses[0].safeSearchAnnotation.racy"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_logos",
      "description_for_ai": "Detect company and product logos in images.",
      "intent": [
        "logo detection",
        "brand recognition",
        "company logo",
        "обнаружение логотипов Google Vision"
      ],
      "endpoint": "POST https://vision.googleapis.com/v1/images:annotate",
      "input": {
        "image": {
          "type": "object",
          "required": true
        },
        "features": {
          "type": "array",
          "description": "[{type: 'LOGO_DETECTION', maxResults: 5}]",
          "required": true
        }
      },
      "output": {
        "type": "logos",
        "fields": [
          "responses[0].logoAnnotations[0].description (company name)",
          "responses[0].logoAnnotations[0].score",
          "responses[0].logoAnnotations[0].boundingPoly"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "batch_annotate",
      "description_for_ai": "Run multiple detection types on multiple images in one request.",
      "intent": [
        "batch image analysis",
        "multiple images Vision",
        "bulk image analysis",
        "пакетный анализ изображений Google"
      ],
      "endpoint": "POST https://vision.googleapis.com/v1/images:annotate",
      "input": {
        "requests": {
          "type": "array",
          "description": "[{image: {...}, features: [{type: 'LABEL_DETECTION'}, {type: 'TEXT_DETECTION'}, {type: 'SAFE_SEARCH_DETECTION'}]}]",
          "required": true
        }
      },
      "output": {
        "type": "list<annotation>",
        "fields": [
          "responses[0].labelAnnotations",
          "responses[0].textAnnotations",
          "responses[0].safeSearchAnnotation"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "feature_types": "LABEL_DETECTION=general labels, TEXT_DETECTION=OCR, DOCUMENT_TEXT_DETECTION=structured OCR, FACE_DETECTION=faces, OBJECT_LOCALIZATION=bounding boxes, LOGO_DETECTION=brand logos, LANDMARK_DETECTION=places, SAFE_SEARCH_DETECTION=explicit content",
    "vs_gemini": "For complex image understanding use Gemini Vision. For specific tasks (OCR, logos, explicit detection) use Vision API."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}