{
  "apia": "1.0",
  "service": {
    "id": "wikipedia",
    "name": "Wikipedia REST API",
    "description_for_ai": "Free encyclopedic knowledge API. Get article summaries, full content, search Wikipedia. Covers 60M+ articles in 300+ languages. No API key needed. Use for factual questions, biographical info, historical events, scientific concepts.",
    "url": "https://wikipedia.org",
    "api_base": "https://en.wikipedia.org/api/rest_v1",
    "category": "science",
    "geo": [
      "GLOBAL"
    ],
    "language": "multilingual",
    "docs": "https://en.wikipedia.org/api/rest_v1/"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "note": "Completely free, no API key, no registration. Just call the endpoints."
  },
  "capabilities": [
    {
      "id": "search_articles",
      "description_for_ai": "Search Wikipedia articles by keyword.",
      "intent": [
        "search Wikipedia",
        "find article",
        "Wikipedia search",
        "поиск Wikipedia"
      ],
      "endpoint": "GET https://en.wikipedia.org/w/api.php?action=query&list=search",
      "input": {
        "srsearch": {
          "type": "string",
          "description": "Search query",
          "required": true
        },
        "srlimit": {
          "type": "integer",
          "default": 10
        },
        "srnamespace": {
          "type": "integer",
          "description": "0 for articles",
          "default": 0
        }
      },
      "output": {
        "type": "list<result>",
        "fields": [
          "query.search[0].title",
          "query.search[0].snippet",
          "query.search[0].pageid",
          "query.search[0].timestamp"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_article_summary",
      "description_for_ai": "Get a concise summary of a Wikipedia article.",
      "intent": [
        "Wikipedia summary",
        "article summary",
        "quick fact",
        "краткое содержание Wikipedia"
      ],
      "endpoint": "GET https://en.wikipedia.org/api/rest_v1/page/summary/{title}",
      "input": {
        "title": {
          "type": "string",
          "description": "Article title: Albert_Einstein, Python_(programming_language)",
          "required": true
        }
      },
      "output": {
        "type": "summary",
        "fields": [
          "title",
          "extract (summary text)",
          "description",
          "thumbnail.source",
          "content_urls.desktop.page"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_article_content",
      "description_for_ai": "Get full text content of a Wikipedia article in wikitext or HTML.",
      "intent": [
        "Wikipedia article",
        "article content",
        "full article Wikipedia",
        "статья Wikipedia"
      ],
      "endpoint": "GET https://en.wikipedia.org/w/api.php?action=query&prop=extracts",
      "input": {
        "titles": {
          "type": "string",
          "required": true
        },
        "exintro": {
          "type": "boolean",
          "description": "Only return intro section",
          "default": false
        },
        "explaintext": {
          "type": "boolean",
          "description": "Return plain text (not HTML)",
          "default": true
        }
      },
      "output": {
        "type": "article",
        "fields": [
          "query.pages[0].title",
          "query.pages[0].extract (article text)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_page_images",
      "description_for_ai": "Get images from a Wikipedia article.",
      "intent": [
        "Wikipedia images",
        "article images",
        "photo Wikipedia",
        "изображения Wikipedia"
      ],
      "endpoint": "GET https://en.wikipedia.org/w/api.php?action=query&prop=images",
      "input": {
        "titles": {
          "type": "string",
          "required": true
        },
        "imlimit": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<image>",
        "fields": [
          "query.pages[0].images[0].title"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_random_article",
      "description_for_ai": "Get a random Wikipedia article.",
      "intent": [
        "random Wikipedia",
        "random article",
        "discover Wikipedia",
        "случайная статья Wikipedia"
      ],
      "endpoint": "GET https://en.wikipedia.org/api/rest_v1/page/random/summary",
      "input": {},
      "output": {
        "type": "summary",
        "fields": [
          "title",
          "extract",
          "description",
          "content_urls.desktop.page"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_featured_article",
      "description_for_ai": "Get Wikipedia's featured article and news for a specific date.",
      "intent": [
        "Wikipedia featured",
        "article of the day",
        "Wikipedia news",
        "статья дня Wikipedia"
      ],
      "endpoint": "GET https://en.wikipedia.org/api/rest_v1/feed/featured/{year}/{month}/{day}",
      "input": {
        "year": {
          "type": "string",
          "description": "4-digit year",
          "required": true
        },
        "month": {
          "type": "string",
          "description": "2-digit month",
          "required": true
        },
        "day": {
          "type": "string",
          "description": "2-digit day",
          "required": true
        }
      },
      "output": {
        "type": "feed",
        "fields": [
          "tfa.title (featured article)",
          "tfa.extract",
          "news[0].story",
          "image.title"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "language_tip": "Change {lang} in URL for different languages. Russian: ru.wikipedia.org, German: de.wikipedia.org, Chinese: zh.wikipedia.org.",
    "title_format": "Use underscores instead of spaces in titles. URL-encode special characters.",
    "extract_length": "Summary extract is usually 1-3 paragraphs — perfect for quick answers without token bloat.",
    "search_first": "If unsure of exact title, always search first then get_summary with the correct title.",
    "free_forever": "Wikipedia API is free, unlimited, and will never require a credit card."
  },
  "limits": {
    "requests_per_day": "unlimited",
    "commercial_use": true,
    "attribution_required": true,
    "attribution_text": "Data from Wikipedia under CC BY-SA license",
    "license": "CC BY-SA 4.0"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}