{
  "apia": "1.0",
  "service": {
    "id": "wikipedia",
    "name": "Wikipedia REST API",
    "description_for_ai": "Free encyclopedic knowledge API. Get article summaries, full content, search Wikipedia. Covers 60M+ articles in 300+ languages. No API key needed. Use for factual questions, biographical info, historical events, scientific concepts.",
    "url": "https://wikipedia.org",
    "api_base": "https://en.wikipedia.org/api/rest_v1",
    "category": "science",
    "geo": [
      "GLOBAL"
    ],
    "language": "multilingual",
    "docs": "https://en.wikipedia.org/api/rest_v1/"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "note": "Completely free, no API key, no registration. Just call the endpoints."
  },
  "capabilities": [
    {
      "id": "search",
      "description_for_ai": "Search Wikipedia articles by keyword. Returns titles and snippets.",
      "intent": [
        "wikipedia search",
        "wiki article",
        "encyclopedia search",
        "поиск wikipedia"
      ],
      "endpoint": "GET https://en.wikipedia.org/w/api.php",
      "input": {
        "action": {
          "type": "string",
          "default": "query"
        },
        "list": {
          "type": "string",
          "default": "search"
        },
        "srsearch": {
          "type": "string",
          "description": "Search query",
          "required": true
        },
        "srlimit": {
          "type": "integer",
          "default": 10
        },
        "srprop": {
          "type": "string",
          "description": "snippet, size, timestamp",
          "default": "snippet"
        },
        "utf8": {
          "type": "integer",
          "default": 1
        },
        "format": {
          "type": "string",
          "default": "json"
        }
      },
      "output": {
        "type": "search",
        "fields": [
          "query.search[0].title",
          "query.search[0].snippet",
          "query.search[0].pageid",
          "query.searchinfo.totalhits"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_summary",
      "description_for_ai": "Get a concise article summary from Wikipedia REST API. Faster than full page parse.",
      "intent": [
        "wikipedia summary",
        "article summary",
        "wiki intro",
        "краткое содержание wikipedia"
      ],
      "endpoint": "GET https://en.wikipedia.org/api/rest_v1/page/summary/{title}",
      "input": {
        "title": {
          "type": "string",
          "description": "Article title (URL encoded). Use exact title from search results.",
          "required": true
        },
        "redirect": {
          "type": "boolean",
          "description": "Follow redirects",
          "default": true
        }
      },
      "output": {
        "type": "summary",
        "fields": [
          "title",
          "extract",
          "thumbnail.source",
          "content_urls.desktop.page",
          "description"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_page_content",
      "description_for_ai": "Get full Wikipedia article content as wikitext or HTML.",
      "intent": [
        "wikipedia article content",
        "full wiki page",
        "read wikipedia",
        "текст статьи wikipedia"
      ],
      "endpoint": "GET https://en.wikipedia.org/w/api.php",
      "input": {
        "action": {
          "type": "string",
          "default": "query"
        },
        "titles": {
          "type": "string",
          "description": "Article title",
          "required": true
        },
        "prop": {
          "type": "string",
          "description": "extracts for HTML text, revisions for wikitext",
          "default": "extracts"
        },
        "exintro": {
          "type": "boolean",
          "description": "Only intro section",
          "default": false
        },
        "explaintext": {
          "type": "boolean",
          "description": "Plain text without HTML",
          "default": true
        },
        "format": {
          "type": "string",
          "default": "json"
        }
      },
      "output": {
        "type": "page",
        "fields": [
          "query.pages.{pageid}.title",
          "query.pages.{pageid}.extract"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_in_language",
      "description_for_ai": "Get Wikipedia article in a specific language.",
      "intent": [
        "wikipedia in russian",
        "wiki auf deutsch",
        "wikipedia lang",
        "wikipedia на русском"
      ],
      "endpoint": "GET https://{lang}.wikipedia.org/api/rest_v1/page/summary/{title}",
      "input": {
        "lang": {
          "type": "string",
          "description": "Language code: en, ru, de, fr, es, zh, ja, ar, pt, it",
          "required": true
        },
        "title": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "summary",
        "fields": [
          "title",
          "extract",
          "description",
          "content_urls.desktop.page"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "language_tip": "Change {lang} in URL for different languages. Russian: ru.wikipedia.org, German: de.wikipedia.org, Chinese: zh.wikipedia.org.",
    "title_format": "Use underscores instead of spaces in titles. URL-encode special characters.",
    "extract_length": "Summary extract is usually 1-3 paragraphs — perfect for quick answers without token bloat.",
    "search_first": "If unsure of exact title, always search first then get_summary with the correct title.",
    "free_forever": "Wikipedia API is free, unlimited, and will never require a credit card."
  },
  "limits": {
    "requests_per_day": "unlimited",
    "commercial_use": true,
    "attribution_required": true,
    "attribution_text": "Data from Wikipedia under CC BY-SA license",
    "license": "CC BY-SA 4.0"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}