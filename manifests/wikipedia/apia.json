{
  "apia": "1.0",
  "service": {
    "id": "wikipedia",
    "name": "Wikipedia REST API",
    "description_for_ai": "Free encyclopedic knowledge API. Get article summaries, full content, search Wikipedia. Covers 60M+ articles in 300+ languages. No API key needed. Use for factual questions, biographical info, historical events, scientific concepts.",
    "url": "https://wikipedia.org",
    "api_base": "https://en.wikipedia.org/api/rest_v1",
    "category": "science",
    "geo": [
      "GLOBAL"
    ],
    "language": "multilingual",
    "docs": "https://en.wikipedia.org/api/rest_v1/"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "note": "Completely free, no API key, no registration. Just call the endpoints."
  },
  "capabilities": [
    {
      "id": "search",
      "description_for_ai": "Search Wikipedia articles by keyword. Returns titles and snippets.",
      "intent": [
        "search Wikipedia",
        "find article",
        "Wikipedia search",
        "поиск Википедия"
      ],
      "endpoint": "GET https://en.wikipedia.org/w/api.php",
      "input": {
        "action": {
          "type": "string",
          "default": "query"
        },
        "list": {
          "type": "string",
          "default": "search"
        },
        "srsearch": {
          "type": "string",
          "description": "Search query",
          "required": true
        },
        "srlimit": {
          "type": "integer",
          "default": 10
        },
        "format": {
          "type": "string",
          "default": "json"
        },
        "utf8": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<article>",
        "fields": [
          "query.search[0].title",
          "query.search[0].snippet",
          "query.search[0].pageid",
          "query.searchinfo.totalhits"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_summary",
      "description_for_ai": "Get a Wikipedia page summary (intro paragraph) for any article.",
      "intent": [
        "wikipedia summary",
        "article intro",
        "topic summary",
        "краткое описание Wikipedia"
      ],
      "endpoint": "GET https://en.wikipedia.org/api/rest_v1/page/summary/{title}",
      "input": {
        "title": {
          "type": "string",
          "description": "Article title (use underscores for spaces: Albert_Einstein)",
          "required": true
        },
        "redirect": {
          "type": "boolean",
          "default": true
        }
      },
      "output": {
        "type": "summary",
        "fields": [
          "title",
          "extract (plain text intro)",
          "description",
          "thumbnail.source",
          "content_urls.desktop.page"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_article_content",
      "description_for_ai": "Get the full text content of a Wikipedia article.",
      "intent": [
        "wikipedia article",
        "full article text",
        "Wikipedia content",
        "полный текст Wikipedia"
      ],
      "endpoint": "GET https://en.wikipedia.org/w/api.php",
      "input": {
        "action": {
          "type": "string",
          "default": "query"
        },
        "prop": {
          "type": "string",
          "default": "extracts"
        },
        "titles": {
          "type": "string",
          "description": "Article title",
          "required": true
        },
        "explaintext": {
          "type": "boolean",
          "description": "Return plain text instead of HTML",
          "default": true
        },
        "exintro": {
          "type": "boolean",
          "description": "Only return intro section",
          "default": false
        },
        "format": {
          "type": "string",
          "default": "json"
        }
      },
      "output": {
        "type": "article",
        "fields": [
          "query.pages.{pageid}.title",
          "query.pages.{pageid}.extract (plain text)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_random_article",
      "description_for_ai": "Get a random Wikipedia article.",
      "intent": [
        "random Wikipedia",
        "random article",
        "discover Wikipedia",
        "случайная статья Wikipedia"
      ],
      "endpoint": "GET https://en.wikipedia.org/api/rest_v1/page/random/summary",
      "input": {},
      "output": {
        "type": "summary",
        "fields": [
          "title",
          "extract",
          "description",
          "thumbnail.source",
          "content_urls.desktop.page"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_in_other_languages",
      "description_for_ai": "Get a Wikipedia article in another language.",
      "intent": [
        "Wikipedia in Russian",
        "Wikipedia другой язык",
        "translate Wikipedia",
        "Википедия на русском"
      ],
      "endpoint": "GET https://{lang}.wikipedia.org/api/rest_v1/page/summary/{title}",
      "input": {
        "lang": {
          "type": "string",
          "description": "Language code: ru, de, fr, es, zh, ja, ar",
          "required": true
        },
        "title": {
          "type": "string",
          "description": "Article title in that language or use lang links API first",
          "required": true
        }
      },
      "output": {
        "type": "summary",
        "fields": [
          "title",
          "extract",
          "content_urls.desktop.page"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "language_tip": "Change {lang} in URL for different languages. Russian: ru.wikipedia.org, German: de.wikipedia.org, Chinese: zh.wikipedia.org.",
    "title_format": "Use underscores instead of spaces in titles. URL-encode special characters.",
    "extract_length": "Summary extract is usually 1-3 paragraphs — perfect for quick answers without token bloat.",
    "search_first": "If unsure of exact title, always search first then get_summary with the correct title.",
    "free_forever": "Wikipedia API is free, unlimited, and will never require a credit card."
  },
  "limits": {
    "requests_per_day": "unlimited",
    "commercial_use": true,
    "attribution_required": true,
    "attribution_text": "Data from Wikipedia under CC BY-SA license",
    "license": "CC BY-SA 4.0"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}