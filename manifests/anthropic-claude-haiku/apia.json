{
  "apia": "1.0",
  "service": {
    "id": "anthropic-claude-haiku",
    "name": "Claude Haiku 4.5 (Fast/Cheap)",
    "description_for_ai": "Anthropic fastest and cheapest Claude model. Best for high-volume classification, extraction, summarization, simple Q&A. Near-instant responses. Use when speed and cost matter more than maximum capability.",
    "url": "https://anthropic.com",
    "api_base": "https://api.anthropic.com/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.anthropic.com/en/docs/models-overview"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "x-api-key: sk-ant-...",
    "how_to_get": "https://console.anthropic.com",
    "cost": "$0.80/$4 per 1M tokens — cheapest Anthropic model"
  },
  "capabilities": [
    {
      "id": "chat",
      "description_for_ai": "Fast, low-cost chat with Claude 3 Haiku. Best for high-volume tasks.",
      "intent": [
        "Claude Haiku",
        "fast chat claude",
        "cheap inference",
        "быстрый Claude Haiku"
      ],
      "endpoint": "POST https://api.anthropic.com/v1/messages",
      "input": {
        "model": {
          "type": "string",
          "default": "claude-haiku-4-5"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "max_tokens": {
          "type": "integer",
          "default": 1024
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "content[0].text",
          "usage.input_tokens",
          "usage.output_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "classify",
      "description_for_ai": "Use Claude Haiku for fast text classification tasks.",
      "intent": [
        "classify text haiku",
        "fast classification",
        "label text",
        "классификация текста Claude Haiku"
      ],
      "endpoint": "POST https://api.anthropic.com/v1/messages",
      "input": {
        "model": {
          "type": "string",
          "default": "claude-haiku-4-5"
        },
        "messages": {
          "type": "array",
          "description": "[{role: 'user', content: 'Classify as positive/negative: [text]'}]",
          "required": true
        },
        "max_tokens": {
          "type": "integer",
          "default": 50
        }
      },
      "output": {
        "type": "classification",
        "fields": [
          "content[0].text (label)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "extract_data",
      "description_for_ai": "Use Claude Haiku to extract structured data from text cheaply and fast.",
      "intent": [
        "extract data haiku",
        "parse text AI",
        "information extraction",
        "извлечение данных Claude Haiku"
      ],
      "endpoint": "POST https://api.anthropic.com/v1/messages",
      "input": {
        "model": {
          "type": "string",
          "default": "claude-haiku-4-5"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "max_tokens": {
          "type": "integer",
          "default": 500
        }
      },
      "output": {
        "type": "extraction",
        "fields": [
          "content[0].text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "summarize",
      "description_for_ai": "Summarize text with Claude Haiku — low cost, high speed.",
      "intent": [
        "summarize haiku",
        "fast summary",
        "brief summary",
        "краткое содержание Claude Haiku"
      ],
      "endpoint": "POST https://api.anthropic.com/v1/messages",
      "input": {
        "model": {
          "type": "string",
          "default": "claude-haiku-4-5"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "max_tokens": {
          "type": "integer",
          "default": 300
        }
      },
      "output": {
        "type": "summary",
        "fields": [
          "content[0].text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "translate",
      "description_for_ai": "Translate text using Claude Haiku — cheap and fast for bulk translation.",
      "intent": [
        "translate haiku",
        "AI translation claude",
        "bulk translate",
        "перевод Claude Haiku"
      ],
      "endpoint": "POST https://api.anthropic.com/v1/messages",
      "input": {
        "model": {
          "type": "string",
          "default": "claude-haiku-4-5"
        },
        "messages": {
          "type": "array",
          "description": "[{role: 'user', content: 'Translate to French: [text]'}]",
          "required": true
        },
        "max_tokens": {
          "type": "integer",
          "default": 500
        }
      },
      "output": {
        "type": "translation",
        "fields": [
          "content[0].text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "vs_sonnet": "Use Haiku for: classification, routing, short extraction, simple Q&A. Use Sonnet for: complex reasoning, long documents, coding.",
    "speed": "Haiku responds in ~0.5s vs ~2s for Sonnet. Great for real-time applications."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}