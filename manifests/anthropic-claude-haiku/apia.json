{
  "apia": "1.0",
  "service": {
    "id": "anthropic-claude-haiku",
    "name": "Claude Haiku 4.5 (Fast/Cheap)",
    "description_for_ai": "Anthropic fastest and cheapest Claude model. Best for high-volume classification, extraction, summarization, simple Q&A. Near-instant responses. Use when speed and cost matter more than maximum capability.",
    "url": "https://anthropic.com",
    "api_base": "https://api.anthropic.com/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.anthropic.com/en/docs/models-overview"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "x-api-key: sk-ant-...",
    "how_to_get": "https://console.anthropic.com",
    "cost": "$0.80/$4 per 1M tokens — cheapest Anthropic model"
  },
  "capabilities": [
    {
      "id": "chat",
      "description_for_ai": "Send a message to Claude Haiku and get a fast, cost-effective response.",
      "intent": [
        "Claude Haiku chat",
        "fast AI response",
        "cheap AI",
        "Claude Haiku"
      ],
      "endpoint": "POST https://api.anthropic.com/v1/messages",
      "input": {
        "model": {
          "type": "string",
          "default": "claude-haiku-4-5"
        },
        "messages": {
          "type": "array",
          "description": "[{role: 'user', content: 'Hello!'}]",
          "required": true
        },
        "max_tokens": {
          "type": "integer",
          "default": 1024
        },
        "system": {
          "type": "string",
          "description": "System prompt",
          "required": false
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "content[0].text",
          "usage.input_tokens",
          "usage.output_tokens",
          "stop_reason"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "classify",
      "description_for_ai": "Use Claude Haiku for fast, cheap text classification.",
      "intent": [
        "text classification Claude",
        "classify with AI",
        "category detection",
        "классификация Claude Haiku"
      ],
      "endpoint": "POST https://api.anthropic.com/v1/messages",
      "input": {
        "model": {
          "type": "string",
          "default": "claude-haiku-4-5"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "max_tokens": {
          "type": "integer",
          "default": 256
        },
        "system": {
          "type": "string",
          "description": "Instructions: 'Classify the user message as positive/negative/neutral. Reply with one word only.'"
        }
      },
      "output": {
        "type": "classification",
        "fields": [
          "content[0].text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "extract_data",
      "description_for_ai": "Use Claude Haiku to extract structured data from unstructured text.",
      "intent": [
        "data extraction Claude",
        "parse text AI",
        "extract JSON Claude",
        "извлечение данных Claude"
      ],
      "endpoint": "POST https://api.anthropic.com/v1/messages",
      "input": {
        "model": {
          "type": "string",
          "default": "claude-haiku-4-5"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "max_tokens": {
          "type": "integer",
          "default": 1024
        },
        "system": {
          "type": "string",
          "description": "Extraction instructions with JSON schema"
        }
      },
      "output": {
        "type": "json",
        "fields": [
          "content[0].text (JSON string to parse)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "summarize",
      "description_for_ai": "Use Claude Haiku to summarize text cheaply and quickly.",
      "intent": [
        "summarize Claude Haiku",
        "text summary AI",
        "cheap summary",
        "резюме Claude Haiku"
      ],
      "endpoint": "POST https://api.anthropic.com/v1/messages",
      "input": {
        "model": {
          "type": "string",
          "default": "claude-haiku-4-5"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "max_tokens": {
          "type": "integer",
          "default": 512
        }
      },
      "output": {
        "type": "summary",
        "fields": [
          "content[0].text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "stream_response",
      "description_for_ai": "Stream Claude Haiku responses token by token for real-time output.",
      "intent": [
        "stream Claude Haiku",
        "streaming AI",
        "real time tokens",
        "стриминг Claude Haiku"
      ],
      "endpoint": "POST https://api.anthropic.com/v1/messages",
      "input": {
        "model": {
          "type": "string",
          "default": "claude-haiku-4-5"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "max_tokens": {
          "type": "integer",
          "default": 1024
        },
        "stream": {
          "type": "boolean",
          "default": true
        }
      },
      "output": {
        "type": "stream",
        "fields": [
          "SSE events: content_block_delta.delta.text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "vs_sonnet": "Use Haiku for: classification, routing, short extraction, simple Q&A. Use Sonnet for: complex reasoning, long documents, coding.",
    "speed": "Haiku responds in ~0.5s vs ~2s for Sonnet. Great for real-time applications."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}