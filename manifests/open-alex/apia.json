{
  "apia": "1.0",
  "service": {
    "id": "open-alex",
    "name": "OpenAlex API",
    "description_for_ai": "Completely free and open academic knowledge graph. 250M+ research works, 260M authors, 100K+ institutions, 50K+ journals. Free and open alternative to Web of Science and Scopus. Citation graphs, co-authorship networks.",
    "url": "https://openalex.org",
    "api_base": "https://api.openalex.org",
    "category": "science",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.openalex.org/"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "note": "Add email as param for polite pool: ?mailto=you@email.com",
    "cost": "Free forever — open data"
  },
  "capabilities": [
    {
      "id": "search_works",
      "description_for_ai": "Search 250M+ academic papers, articles, books, datasets. Free alternative to Semantic Scholar.",
      "intent": [
        "search papers openalex",
        "academic search",
        "research works",
        "научные статьи openalex"
      ],
      "endpoint": "GET https://api.openalex.org/works",
      "input": {
        "search": {
          "type": "string",
          "description": "Keyword search across title, abstract, full text",
          "required": false
        },
        "filter": {
          "type": "string",
          "description": "Pipe-separated: publication_year:2024, type:article, open_access.is_oa:true, cited_by_count:>100, authorships.institutions.country_code:US",
          "required": false
        },
        "sort": {
          "type": "string",
          "description": "cited_by_count:desc, publication_date:desc, relevance_score:desc",
          "default": "relevance_score:desc"
        },
        "per_page": {
          "type": "integer",
          "default": 25
        },
        "page": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<work>",
        "fields": [
          "results[0].id",
          "results[0].title",
          "results[0].doi",
          "results[0].publication_year",
          "results[0].cited_by_count",
          "results[0].open_access.oa_url"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_work",
      "description_for_ai": "Get full metadata for a paper: abstract, authors, citations, open access URL.",
      "intent": [
        "paper details openalex",
        "article metadata",
        "doi lookup",
        "детали статьи openalex"
      ],
      "endpoint": "GET https://api.openalex.org/works/{id}",
      "input": {
        "id": {
          "type": "string",
          "description": "OpenAlex ID (W...) or DOI: doi:10.1038/nature12373",
          "required": true
        }
      },
      "output": {
        "type": "work",
        "fields": [
          "id",
          "title",
          "abstract",
          "doi",
          "publication_year",
          "cited_by_count",
          "authorships[0].author.display_name",
          "open_access.oa_url"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "search_authors",
      "description_for_ai": "Search researchers and authors by name. Get their h-index, citations, affiliations.",
      "intent": [
        "find researcher",
        "author search openalex",
        "scientist profile",
        "поиск автора openalex"
      ],
      "endpoint": "GET https://api.openalex.org/authors",
      "input": {
        "search": {
          "type": "string",
          "required": true
        },
        "filter": {
          "type": "string",
          "description": "last_known_institution.country_code:US, works_count:>50",
          "required": false
        }
      },
      "output": {
        "type": "list<author>",
        "fields": [
          "results[0].id",
          "results[0].display_name",
          "results[0].works_count",
          "results[0].cited_by_count",
          "results[0].h_index",
          "results[0].last_known_institution.display_name"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "search_institutions",
      "description_for_ai": "Search universities and research institutions.",
      "intent": [
        "institution search openalex",
        "university research",
        "поиск университет openalex"
      ],
      "endpoint": "GET https://api.openalex.org/institutions",
      "input": {
        "search": {
          "type": "string",
          "required": true
        },
        "filter": {
          "type": "string",
          "description": "country_code:RU, type:education",
          "required": false
        }
      },
      "output": {
        "type": "list<institution>",
        "fields": [
          "results[0].id",
          "results[0].display_name",
          "results[0].country_code",
          "results[0].works_count",
          "results[0].cited_by_count"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_work",
      "description_for_ai": "Get detailed info about a scientific publication by DOI or OpenAlex ID.",
      "intent": [
        "paper details",
        "publication info",
        "academic paper",
        "научная статья openalex"
      ],
      "endpoint": "GET https://api.openalex.org/works/{id}",
      "input": {
        "id": {
          "type": "string",
          "description": "OpenAlex ID (W1234) or DOI (https://doi.org/...)",
          "required": true
        }
      },
      "output": {
        "type": "work",
        "fields": [
          "id",
          "title",
          "authorships[0].author.display_name",
          "cited_by_count",
          "open_access.oa_url",
          "abstract_inverted_index"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "free": "Completely free, no key needed. Add ?mailto=your@email.com to get into polite pool with higher rate limits.",
    "abstract": "Abstracts stored as inverted index. Convert with: words = {pos: word for word, positions in abstract_inverted_index.items() for pos in positions}; text = join(words[i] for i in sorted(words))"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}