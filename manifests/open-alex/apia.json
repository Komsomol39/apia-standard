{
  "apia": "1.0",
  "service": {
    "id": "open-alex",
    "name": "OpenAlex API",
    "description_for_ai": "Completely free and open academic knowledge graph. 250M+ research works, 260M authors, 100K+ institutions, 50K+ journals. Free and open alternative to Web of Science and Scopus. Citation graphs, co-authorship networks.",
    "url": "https://openalex.org",
    "api_base": "https://api.openalex.org",
    "category": "science_research",
    "geo": ["GLOBAL"],
    "language": "en",
    "docs": "https://docs.openalex.org/"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "note": "Add email as param for polite pool: ?mailto=you@email.com",
    "cost": "Free forever — open data"
  },
  "capabilities": [
    {
      "id": "search_works",
      "description_for_ai": "Search research works: papers, books, datasets, dissertations. Filter by year, institution, topic, citations count.",
      "intent": ["academic papers", "research works", "citations", "scholarly articles", "academic search", "open access papers"],
      "endpoint": "GET https://api.openalex.org/works",
      "input": {
        "search": {"type": "string", "description": "Full-text search query", "required": false},
        "filter": {"type": "string", "description": "publication_year:2023, type:journal-article, open_access.is_oa:true, cited_by_count:>100", "required": false},
        "sort": {"type": "string", "description": "cited_by_count:desc, publication_date:desc", "required": false},
        "per_page": {"type": "integer", "default": 25},
        "page": {"type": "integer", "default": 1}
      },
      "output": {
        "type": "list<work>",
        "fields": ["id", "title", "publication_year", "cited_by_count", "open_access.is_oa", "open_access.oa_url", "authorships[0].author.display_name"]
      },
      "realtime": false,
      "requires_auth": false
    },
    {
      "id": "get_institution",
      "description_for_ai": "Get information about a research institution: papers count, citation metrics, top researchers.",
      "intent": ["university research", "institution papers", "MIT research", "academic institution"],
      "endpoint": "GET https://api.openalex.org/institutions",
      "input": {
        "search": {"type": "string", "description": "Institution name", "required": false},
        "filter": {"type": "string", "description": "country_code:RU for Russian institutions", "required": false}
      },
      "output": {
        "type": "list<institution>",
        "fields": ["id", "display_name", "country_code", "type", "works_count", "cited_by_count", "homepage_url"]
      },
      "realtime": false,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "free": "Completely free, no key needed. Add ?mailto=your@email.com to get into polite pool with higher rate limits.",
    "abstract": "Abstracts stored as inverted index. Convert with: words = {pos: word for word, positions in abstract_inverted_index.items() for pos in positions}; text = join(words[i] for i in sorted(words))"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}