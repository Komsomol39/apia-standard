{
  "apia": "1.0",
  "service": {
    "id": "jira",
    "name": "Jira API (Atlassian)",
    "description_for_ai": "Issue and project tracking. Create, update, search issues. Sprints, boards, epics, comments, attachments. Used by 65K+ companies. Use for software project management, bug tracking, agile workflows.",
    "url": "https://atlassian.com/software/jira",
    "api_base": "https://{domain}.atlassian.net/rest/api/3",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.atlassian.com/cloud/jira/platform/rest/v3/intro/"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "Use email + API token. Get token at https://id.atlassian.com/manage-profile/security/api-tokens",
    "how_to_get": "https://id.atlassian.com/manage-profile/security/api-tokens",
    "cost": "Free: 10 users. Standard: $8.15/user/month"
  },
  "capabilities": [
    {
      "id": "search_issues",
      "description_for_ai": "Search Jira issues using JQL (Jira Query Language). Filter by project, status, assignee, sprint, priority, labels.",
      "intent": [
        "jira search",
        "find issues",
        "jira query",
        "sprint issues",
        "задачи jira"
      ],
      "endpoint": "GET https://{domain}.atlassian.net/rest/api/3/search",
      "input": {
        "jql": {
          "type": "string",
          "description": "JQL query: 'project=MYPROJ AND status=Open', 'assignee=currentUser() AND sprint in openSprints()', 'priority=High ORDER BY created DESC'",
          "required": true
        },
        "maxResults": {
          "type": "integer",
          "default": 20
        },
        "startAt": {
          "type": "integer",
          "default": 0
        },
        "fields": {
          "type": "array",
          "description": "['summary', 'status', 'assignee', 'priority', 'created', 'description']",
          "required": false
        }
      },
      "output": {
        "type": "list<issue>",
        "fields": [
          "issues[0].id",
          "issues[0].key",
          "issues[0].fields.summary",
          "issues[0].fields.status.name",
          "issues[0].fields.assignee.displayName",
          "issues[0].fields.priority.name",
          "total"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_issue",
      "description_for_ai": "Create a new Jira issue (bug, story, task, epic) with description, priority, labels, components, and assignee.",
      "intent": [
        "create jira issue",
        "new ticket",
        "report bug jira",
        "create story",
        "создать задачу jira"
      ],
      "endpoint": "POST https://{domain}.atlassian.net/rest/api/3/issue",
      "input": {
        "fields": {
          "type": "object",
          "description": "{project: {key: 'PROJ'}, summary: 'Issue title', issuetype: {name: 'Bug'|'Story'|'Task'|'Epic'}, description: {type: 'doc', version: 1, content: [{type: 'paragraph', content: [{type: 'text', text: 'Description'}]}]}, priority: {name: 'High'|'Medium'|'Low'}, assignee: {id: 'user_id'}, labels: ['frontend', 'urgent']}",
          "required": true
        }
      },
      "output": {
        "type": "issue",
        "fields": [
          "id",
          "key",
          "self"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_issue",
      "description_for_ai": "Update Jira issue fields: change status (via transitions), update summary, description, priority, assignee.",
      "intent": [
        "update jira issue",
        "change status jira",
        "edit ticket",
        "assign issue",
        "обновить задачу jira"
      ],
      "endpoint": "PUT https://{domain}.atlassian.net/rest/api/3/issue/{issueKey}",
      "input": {
        "issueKey": {
          "type": "string",
          "description": "Issue key e.g. PROJ-123",
          "required": true
        },
        "fields": {
          "type": "object",
          "description": "{summary: 'New title', priority: {name: 'High'}, assignee: {id: 'user_id'}, labels: ['bug']}",
          "required": true
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "204 No Content on success"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "transition_issue",
      "description_for_ai": "Move a Jira issue to a different status (To Do → In Progress → Done). Get available transitions first.",
      "intent": [
        "move issue jira",
        "change status",
        "close ticket",
        "done jira",
        "перевести задачу jira"
      ],
      "endpoint": "POST https://{domain}.atlassian.net/rest/api/3/issue/{issueKey}/transitions",
      "input": {
        "issueKey": {
          "type": "string",
          "required": true
        },
        "transition": {
          "type": "object",
          "description": "{id: 'transition_id'}. Get IDs from GET /issue/{key}/transitions",
          "required": true
        }
      },
      "output": {
        "type": "empty",
        "fields": [
          "204 No Content on success"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "add_comment",
      "description_for_ai": "Add a comment to a Jira issue. Supports @mentions and rich text.",
      "intent": [
        "comment jira",
        "add comment issue",
        "reply jira",
        "комментарий jira"
      ],
      "endpoint": "POST https://{domain}.atlassian.net/rest/api/3/issue/{issueKey}/comment",
      "input": {
        "issueKey": {
          "type": "string",
          "required": true
        },
        "body": {
          "type": "object",
          "description": "{type: 'doc', version: 1, content: [{type: 'paragraph', content: [{type: 'text', text: 'Your comment'}]}]}",
          "required": true
        }
      },
      "output": {
        "type": "comment",
        "fields": [
          "id",
          "author.displayName",
          "created",
          "body"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_issue",
      "description_for_ai": "Get full Jira issue details including all fields, comments, attachments, sub-tasks, and linked issues.",
      "intent": [
        "get issue jira",
        "issue details",
        "ticket info jira",
        "issue data",
        "детали задачи jira"
      ],
      "endpoint": "GET https://{domain}.atlassian.net/rest/api/3/issue/{issueKey}",
      "input": {
        "issueKey": {
          "type": "string",
          "description": "Issue key e.g. PROJ-123",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "Comma-separated: summary,description,status,assignee,priority,comment,attachment",
          "required": false
        },
        "expand": {
          "type": "string",
          "description": "renderedFields,names,changelog",
          "required": false
        }
      },
      "output": {
        "type": "issue",
        "fields": [
          "id",
          "key",
          "fields.summary",
          "fields.status.name",
          "fields.description",
          "fields.comments.comments",
          "fields.assignee.displayName"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_projects",
      "description_for_ai": "List all accessible Jira projects with keys and leads.",
      "intent": [
        "jira projects",
        "project list",
        "all projects",
        "проекты jira"
      ],
      "endpoint": "GET https://{domain}.atlassian.net/rest/api/3/project/search",
      "input": {
        "maxResults": {
          "type": "integer",
          "default": 50
        },
        "startAt": {
          "type": "integer",
          "default": 0
        },
        "query": {
          "type": "string",
          "description": "Filter by project name",
          "required": false
        }
      },
      "output": {
        "type": "list<project>",
        "fields": [
          "values[0].id",
          "values[0].key",
          "values[0].name",
          "values[0].projectTypeKey",
          "values[0].lead.displayName"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "auth": "Use API token (not password): id.atlassian.com/manage-profile/security/api-tokens. Format: email:token in base64.",
    "jql_examples": "Useful JQL: 'project=MYPROJ AND status!=Done ORDER BY created DESC', 'assignee=currentUser() AND sprint in openSprints()'",
    "pagination": "Use maxResults and startAt for pagination. Total in response.total field.",
    "custom_fields": "Custom fields have IDs like customfield_10001. Get full list via GET /rest/api/3/field"
  }
}