{
  "apia": "1.0",
  "service": {
    "id": "jira",
    "name": "Jira API (Atlassian)",
    "description_for_ai": "Issue and project tracking. Create, update, search issues. Sprints, boards, epics, comments, attachments. Used by 65K+ companies. Use for software project management, bug tracking, agile workflows.",
    "url": "https://atlassian.com/software/jira",
    "api_base": "https://{domain}.atlassian.net/rest/api/3",
    "category": "developer_project",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developer.atlassian.com/cloud/jira/platform/rest/v3/intro/"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "Use email + API token. Get token at https://id.atlassian.com/manage-profile/security/api-tokens",
    "how_to_get": "https://id.atlassian.com/manage-profile/security/api-tokens",
    "cost": "Free: 10 users. Standard: $8.15/user/month"
  },
  "capabilities": [
    {
      "id": "search_issues",
      "description_for_ai": "Search Jira issues using JQL (Jira Query Language). Find bugs, tasks, stories by project, status, assignee.",
      "intent": [
        "jira issues",
        "find bugs",
        "project tasks",
        "sprint issues",
        "open tickets",
        "search jira"
      ],
      "endpoint": "GET https://{domain}.atlassian.net/rest/api/3/search",
      "input": {
        "jql": {
          "type": "string",
          "description": "JQL query e.g. project=MYPROJECT AND status=Open AND assignee=currentUser()",
          "required": true
        },
        "maxResults": {
          "type": "integer",
          "default": 50
        },
        "fields": {
          "type": "string",
          "description": "Comma-separated fields: summary,status,assignee,priority,created,updated",
          "required": false
        }
      },
      "output": {
        "type": "list<issue>",
        "fields": [
          "issues[0].key",
          "issues[0].fields.summary",
          "issues[0].fields.status.name",
          "issues[0].fields.assignee.displayName",
          "issues[0].fields.priority.name"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_issue",
      "description_for_ai": "Create a new Jira issue: bug, task, story, epic.",
      "intent": [
        "create issue",
        "new bug",
        "add task",
        "create ticket",
        "report bug"
      ],
      "endpoint": "POST https://{domain}.atlassian.net/rest/api/3/issue",
      "input": {
        "project_key": {
          "type": "string",
          "description": "Project key e.g. MYPROJ",
          "required": true
        },
        "summary": {
          "type": "string",
          "required": true
        },
        "issue_type": {
          "type": "string",
          "description": "Bug, Task, Story, Epic",
          "default": "Task"
        },
        "description": {
          "type": "object",
          "description": "Atlassian Document Format content",
          "required": false
        },
        "priority": {
          "type": "string",
          "description": "Highest, High, Medium, Low, Lowest",
          "required": false
        },
        "assignee_id": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "issue",
        "fields": [
          "id",
          "key",
          "self"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}