{
  "apia": "1.0",
  "service": {
    "id": "sendbird",
    "name": "Sendbird Chat API",
    "description_for_ai": "In-app messaging platform. Real-time chat channels, group channels, moderation, push notifications, message history. Used by Reddit, Delivery Hero, Khanmigo. Use for building chat features in apps.",
    "url": "https://sendbird.com",
    "api_base": "https://api-{app_id}.sendbird.com/v3",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://sendbird.com/docs/chat/platform-api/v3/overview"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Api-Token: {master_api_token}",
    "how_to_get": "Register at https://dashboard.sendbird.com",
    "cost": "Free: 1000 MAU. Starter: $399/month"
  },
  "capabilities": [
    {
      "id": "send_message",
      "description_for_ai": "Send a message to a Sendbird channel or group chat.",
      "intent": [
        "send message Sendbird",
        "chat message",
        "Sendbird message",
        "сообщение Sendbird"
      ],
      "endpoint": "POST https://api-{APP_ID}.sendbird.com/v3/group_channels/{channel_url}/messages",
      "input": {
        "APP_ID": {
          "type": "string",
          "required": true
        },
        "channel_url": {
          "type": "string",
          "required": true
        },
        "message_type": {
          "type": "string",
          "description": "MESG (text), FILE, ADMM (admin)",
          "default": "MESG"
        },
        "message": {
          "type": "string",
          "required": true
        },
        "user_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "message_id",
          "message",
          "user.user_id",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_channel",
      "description_for_ai": "Create a Sendbird group channel for users.",
      "intent": [
        "create channel Sendbird",
        "new chat Sendbird",
        "group chat",
        "создать канал Sendbird"
      ],
      "endpoint": "POST https://api-{APP_ID}.sendbird.com/v3/group_channels",
      "input": {
        "APP_ID": {
          "type": "string",
          "required": true
        },
        "user_ids": {
          "type": "array",
          "description": "User IDs to invite",
          "required": true
        },
        "name": {
          "type": "string",
          "required": false
        },
        "channel_url": {
          "type": "string",
          "description": "Custom channel URL (optional)",
          "required": false
        },
        "is_distinct": {
          "type": "boolean",
          "description": "Reuse existing channel with same users",
          "default": false
        }
      },
      "output": {
        "type": "channel",
        "fields": [
          "channel_url",
          "name",
          "member_count",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_messages",
      "description_for_ai": "Get messages from a Sendbird channel.",
      "intent": [
        "list messages Sendbird",
        "chat history",
        "message history",
        "история сообщений Sendbird"
      ],
      "endpoint": "GET https://api-{APP_ID}.sendbird.com/v3/group_channels/{channel_url}/messages",
      "input": {
        "APP_ID": {
          "type": "string",
          "required": true
        },
        "channel_url": {
          "type": "string",
          "required": true
        },
        "message_ts": {
          "type": "integer",
          "description": "Millisecond timestamp to get messages around",
          "required": true
        },
        "prev_limit": {
          "type": "integer",
          "default": 15
        },
        "next_limit": {
          "type": "integer",
          "default": 0
        }
      },
      "output": {
        "type": "list<message>",
        "fields": [
          "messages[0].message_id",
          "messages[0].message",
          "messages[0].user.user_id",
          "messages[0].created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_user",
      "description_for_ai": "Create a new Sendbird user.",
      "intent": [
        "create user Sendbird",
        "register user Sendbird",
        "new user chat",
        "создать пользователя Sendbird"
      ],
      "endpoint": "POST https://api-{APP_ID}.sendbird.com/v3/users",
      "input": {
        "APP_ID": {
          "type": "string",
          "required": true
        },
        "user_id": {
          "type": "string",
          "required": true
        },
        "nickname": {
          "type": "string",
          "required": true
        },
        "profile_url": {
          "type": "string",
          "description": "Avatar image URL",
          "required": false
        }
      },
      "output": {
        "type": "user",
        "fields": [
          "user_id",
          "nickname",
          "access_token",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "moderate_message",
      "description_for_ai": "Delete or report a message for moderation in Sendbird.",
      "intent": [
        "delete message Sendbird",
        "moderate chat",
        "remove message",
        "модерация Sendbird"
      ],
      "endpoint": "DELETE https://api-{APP_ID}.sendbird.com/v3/group_channels/{channel_url}/messages/{message_id}",
      "input": {
        "APP_ID": {
          "type": "string",
          "required": true
        },
        "channel_url": {
          "type": "string",
          "required": true
        },
        "message_id": {
          "type": "integer",
          "required": true
        }
      },
      "output": {
        "type": "status",
        "fields": [
          "200 OK on success"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "app_id": "App ID from Sendbird Dashboard. Replace {app_id} in base URL: api-{APP_ID}.sendbird.com",
    "master_token": "Master API Token from Dashboard → Settings → General → API tokens. Use for server-side calls.",
    "user_tokens": "For client-side: generate per-user session tokens via POST /v3/users/{user_id}/token. Expire after 1 day by default.",
    "channel_types": "group_channels for private group chat, open_channels for public/stream chat (like Twitch chat)."
  }
}