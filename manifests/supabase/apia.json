{
  "apia": "1.0",
  "service": {
    "id": "supabase",
    "name": "Supabase API",
    "description_for_ai": "Open-source Firebase alternative. Postgres database, Auth, Storage, Realtime subscriptions, Edge Functions — all in one. Free tier: 500MB database, 1GB storage. Use for backend-as-a-service, user auth, file storage.",
    "url": "https://supabase.com",
    "api_base": "https://{project_id}.supabase.co",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://supabase.com/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "apikey: your-anon-key",
    "how_to_get": "Create project at https://supabase.com — free tier available",
    "cost": "Free: 500MB DB, 1GB storage. Pro: $25/month"
  },
  "capabilities": [
    {
      "id": "query_database",
      "description_for_ai": "Query PostgreSQL database using REST API. Filter, sort, select columns, paginate.",
      "intent": [
        "supabase query",
        "database query",
        "fetch rows supabase",
        "запрос базы supabase"
      ],
      "endpoint": "GET https://{project_id}.supabase.co/rest/v1/{table}",
      "input": {
        "table": {
          "type": "string",
          "description": "Table name",
          "required": true
        },
        "select": {
          "type": "string",
          "description": "Columns: *, id,name,email, or related: *, profile(*)",
          "default": "*"
        },
        "filter": {
          "type": "string",
          "description": "Append as query params: ?status=eq.active&age=gte.18&name=ilike.*john*",
          "required": false
        },
        "order": {
          "type": "string",
          "description": "?order=created_at.desc.nullslast",
          "required": false
        },
        "limit": {
          "type": "integer",
          "description": "?limit=10",
          "default": 20
        },
        "offset": {
          "type": "integer",
          "description": "?offset=20 for pagination",
          "default": 0
        }
      },
      "output": {
        "type": "list<row>",
        "fields": [
          "[0].id",
          "[0] (all selected columns)",
          "Content-Range header for total count"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "insert_row",
      "description_for_ai": "Insert one or multiple rows into a Supabase table.",
      "intent": [
        "insert row supabase",
        "add data supabase",
        "create record supabase",
        "добавить запись supabase"
      ],
      "endpoint": "POST https://{project_id}.supabase.co/rest/v1/{table}",
      "input": {
        "table": {
          "type": "string",
          "required": true
        },
        "data": {
          "type": "object or array",
          "description": "Single object or array of objects. Column names as keys. Omit id for auto-generate.",
          "required": true
        },
        "prefer": {
          "type": "string",
          "description": "return=representation to get inserted rows back",
          "required": false
        }
      },
      "output": {
        "type": "inserted",
        "fields": [
          "[0].id",
          "[0] (all columns if Prefer: return=representation)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_row",
      "description_for_ai": "Update rows matching a filter in Supabase table.",
      "intent": [
        "update supabase",
        "edit row supabase",
        "patch record supabase",
        "обновить запись supabase"
      ],
      "endpoint": "PATCH https://{project_id}.supabase.co/rest/v1/{table}?{filter}",
      "input": {
        "table": {
          "type": "string",
          "required": true
        },
        "filter": {
          "type": "string",
          "description": "Query params to filter: id=eq.123 or status=eq.active",
          "required": true
        },
        "data": {
          "type": "object",
          "description": "Fields to update",
          "required": true
        }
      },
      "output": {
        "type": "updated",
        "fields": [
          "Updated rows if Prefer: return=representation"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "auth_signup",
      "description_for_ai": "Register a new user with email and password. Returns session tokens.",
      "intent": [
        "supabase signup",
        "register user",
        "create account supabase",
        "регистрация supabase"
      ],
      "endpoint": "POST https://{project_id}.supabase.co/auth/v1/signup",
      "input": {
        "email": {
          "type": "string",
          "required": true
        },
        "password": {
          "type": "string",
          "required": true
        },
        "data": {
          "type": "object",
          "description": "Additional user metadata",
          "required": false
        }
      },
      "output": {
        "type": "session",
        "fields": [
          "user.id",
          "user.email",
          "session.access_token",
          "session.refresh_token",
          "session.expires_in"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "project": "Replace {project_id} with your project reference ID from supabase.com dashboard URL.",
    "anon_key": "Use anon key for client-side (public) access with Row Level Security. Use service_role key server-side only.",
    "rls": "Enable Row Level Security (RLS) on tables! Without it, anyone with anon key can read/write all data.",
    "realtime": "Subscribe to changes: supabase.channel('changes').on('postgres_changes', {table: 'messages'}, callback).subscribe()"
  }
}