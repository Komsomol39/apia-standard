{
  "apia": "1.0",
  "service": {
    "id": "supabase",
    "name": "Supabase API",
    "description_for_ai": "Open-source Firebase alternative. Postgres database, Auth, Storage, Realtime subscriptions, Edge Functions — all in one. Free tier: 500MB database, 1GB storage. Use for backend-as-a-service, user auth, file storage.",
    "url": "https://supabase.com",
    "api_base": "https://{project_id}.supabase.co",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://supabase.com/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "apikey: your-anon-key",
    "how_to_get": "Create project at https://supabase.com — free tier available",
    "cost": "Free: 500MB DB, 1GB storage. Pro: $25/month"
  },
  "capabilities": [
    {
      "id": "query_data",
      "description_for_ai": "Query Supabase PostgreSQL database via REST API. Filter, sort, paginate, join tables.",
      "intent": [
        "Supabase query",
        "database query",
        "get records Supabase",
        "PostgreSQL REST",
        "запрос Supabase"
      ],
      "endpoint": "GET https://{project}.supabase.co/rest/v1/{table}",
      "input": {
        "table": {
          "type": "string",
          "description": "Table name",
          "required": true
        },
        "select": {
          "type": "string",
          "description": "Columns to return: *, id,name, or foreign keys: id,users(name)",
          "default": "*"
        },
        "filter": {
          "type": "string",
          "description": "Append as query param: ?status=eq.active&age=gte.18 (operators: eq, neq, gt, gte, lt, lte, like, ilike, in, is)",
          "required": false
        },
        "order": {
          "type": "string",
          "description": "column.asc or column.desc",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 100
        },
        "offset": {
          "type": "integer",
          "default": 0
        }
      },
      "output": {
        "type": "list<record>",
        "fields": [
          "array of records with selected columns"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "insert_data",
      "description_for_ai": "Insert one or multiple rows into a Supabase table.",
      "intent": [
        "insert Supabase",
        "add record",
        "create row",
        "insert database",
        "вставить данные Supabase"
      ],
      "endpoint": "POST https://{project}.supabase.co/rest/v1/{table}",
      "input": {
        "table": {
          "type": "string",
          "required": true
        },
        "data": {
          "type": "object or array",
          "description": "{column: value} or [{...}, {...}] for bulk insert",
          "required": true
        },
        "select": {
          "type": "string",
          "description": "Return inserted data: * or specific columns",
          "required": false
        }
      },
      "output": {
        "type": "list<record>",
        "fields": [
          "inserted record(s) if select header provided"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_data",
      "description_for_ai": "Update rows matching a filter in a Supabase table.",
      "intent": [
        "update Supabase",
        "edit record",
        "update row database",
        "обновить данные Supabase"
      ],
      "endpoint": "PATCH https://{project}.supabase.co/rest/v1/{table}?{filter}",
      "input": {
        "table": {
          "type": "string",
          "required": true
        },
        "filter": {
          "type": "string",
          "description": "?id=eq.123 or ?status=eq.pending",
          "required": true
        },
        "data": {
          "type": "object",
          "description": "Fields to update: {status: 'active'}",
          "required": true
        }
      },
      "output": {
        "type": "list<record>",
        "fields": [
          "updated records"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "auth_sign_up",
      "description_for_ai": "Register a new user with email and password in Supabase Auth.",
      "intent": [
        "user registration Supabase",
        "sign up",
        "create user Supabase",
        "аутентификация Supabase"
      ],
      "endpoint": "POST https://{project}.supabase.co/auth/v1/signup",
      "input": {
        "email": {
          "type": "string",
          "required": true
        },
        "password": {
          "type": "string",
          "required": true
        },
        "data": {
          "type": "object",
          "description": "Extra user metadata",
          "required": false
        }
      },
      "output": {
        "type": "auth",
        "fields": [
          "user.id",
          "user.email",
          "session.access_token",
          "session.refresh_token"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "storage_upload",
      "description_for_ai": "Upload files to Supabase Storage. Supports any file type.",
      "intent": [
        "upload file Supabase",
        "Supabase storage",
        "store file",
        "хранилище файлов Supabase"
      ],
      "endpoint": "POST https://{project}.supabase.co/storage/v1/object/{bucket}/{path}",
      "input": {
        "bucket": {
          "type": "string",
          "description": "Storage bucket name",
          "required": true
        },
        "path": {
          "type": "string",
          "description": "File path in bucket e.g. images/avatar.jpg",
          "required": true
        },
        "file": {
          "type": "binary",
          "description": "File content",
          "required": true
        },
        "contentType": {
          "type": "string",
          "description": "MIME type e.g. image/jpeg",
          "required": false
        }
      },
      "output": {
        "type": "upload",
        "fields": [
          "Id",
          "Key"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "rpc_function",
      "description_for_ai": "Call a PostgreSQL function (stored procedure) via Supabase RPC.",
      "intent": [
        "Supabase function",
        "RPC call",
        "stored procedure",
        "вызов функции Supabase"
      ],
      "endpoint": "POST https://{project}.supabase.co/rest/v1/rpc/{function_name}",
      "input": {
        "function_name": {
          "type": "string",
          "description": "Name of the PostgreSQL function",
          "required": true
        },
        "params": {
          "type": "object",
          "description": "Function parameters as key-value",
          "required": false
        }
      },
      "output": {
        "type": "any",
        "fields": [
          "function return value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "project": "Replace {project_id} with your project reference ID from supabase.com dashboard URL.",
    "anon_key": "Use anon key for client-side (public) access with Row Level Security. Use service_role key server-side only.",
    "rls": "Enable Row Level Security (RLS) on tables! Without it, anyone with anon key can read/write all data.",
    "realtime": "Subscribe to changes: supabase.channel('changes').on('postgres_changes', {table: 'messages'}, callback).subscribe()"
  }
}