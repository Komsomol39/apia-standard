{
  "apia": "1.0",
  "service": {
    "id": "supabase",
    "name": "Supabase API",
    "description_for_ai": "Open-source Firebase alternative. Postgres database, Auth, Storage, Realtime subscriptions, Edge Functions — all in one. Free tier: 500MB database, 1GB storage. Use for backend-as-a-service, user auth, file storage.",
    "url": "https://supabase.com",
    "api_base": "https://{project_id}.supabase.co",
    "category": "developer_backend",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://supabase.com/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "apikey: your-anon-key",
    "how_to_get": "Create project at https://supabase.com — free tier available",
    "cost": "Free: 500MB DB, 1GB storage. Pro: $25/month"
  },
  "capabilities": [
    {
      "id": "query_database",
      "description_for_ai": "Query Supabase Postgres database via REST API. Filter rows, select columns, join tables, paginate results. Requires Row Level Security to be configured.",
      "intent": [
        "query database",
        "get records",
        "insert data",
        "update record",
        "database query",
        "PostgreSQL REST"
      ],
      "endpoint": "GET https://{project_id}.supabase.co/rest/v1/{table}",
      "input": {
        "table": {
          "type": "string",
          "description": "Table name to query e.g. 'users', 'products', 'orders'",
          "required": true
        },
        "select": {
          "type": "string",
          "description": "Columns to return: '*' for all, or 'id,name,email' for specific. Support joins: 'id,profiles(avatar_url)'",
          "default": "*"
        },
        "filter": {
          "type": "string",
          "description": "URL query filter params appended: ?column=eq.value, ?age=gt.18, ?name=ilike.*john*, ?status=in.(active,pending)",
          "required": false
        },
        "order": {
          "type": "string",
          "description": "Sort: column.asc or column.desc e.g. 'created_at.desc'",
          "required": false
        },
        "limit": {
          "type": "integer",
          "description": "Max rows to return",
          "required": false
        },
        "offset": {
          "type": "integer",
          "description": "Rows to skip for pagination",
          "required": false
        },
        "count": {
          "type": "string",
          "description": "exact or estimated — adds total count to response headers",
          "required": false
        }
      },
      "output": {
        "type": "list<row>",
        "fields": [
          "Array of row objects with requested columns",
          "Content-Range header for total count when count param set"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "auth_signup",
      "description_for_ai": "Register new user with email and password. Returns user object and session token.",
      "intent": [
        "register user",
        "sign up",
        "create account",
        "user registration"
      ],
      "endpoint": "POST https://{project_id}.supabase.co/auth/v1/signup",
      "input": {
        "email": {
          "type": "string",
          "required": true
        },
        "password": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "auth",
        "fields": [
          "user.id",
          "user.email",
          "session.access_token"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "storage_upload",
      "description_for_ai": "Upload a file to a Supabase Storage bucket. Returns the file path. Make bucket public or use signed URLs for access.",
      "intent": [
        "upload file",
        "store image",
        "file storage",
        "upload document"
      ],
      "endpoint": "POST https://{project_id}.supabase.co/storage/v1/object/{bucket}/{path}",
      "input": {
        "bucket": {
          "type": "string",
          "required": true
        },
        "path": {
          "type": "string",
          "required": true
        },
        "file": {
          "type": "binary",
          "required": true
        }
      },
      "output": {
        "type": "upload",
        "fields": [
          "Key"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "project": "Replace {project_id} with your project reference ID from supabase.com dashboard URL.",
    "anon_key": "Use anon key for client-side (public) access with Row Level Security. Use service_role key server-side only.",
    "rls": "Enable Row Level Security (RLS) on tables! Without it, anyone with anon key can read/write all data.",
    "realtime": "Subscribe to changes: supabase.channel('changes').on('postgres_changes', {table: 'messages'}, callback).subscribe()"
  }
}