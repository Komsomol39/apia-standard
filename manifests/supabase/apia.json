{
  "apia": "1.0",
  "service": {
    "id": "supabase",
    "name": "Supabase API",
    "description_for_ai": "Open-source Firebase alternative. Postgres database, Auth, Storage, Realtime subscriptions, Edge Functions — all in one. Free tier: 500MB database, 1GB storage. Use for backend-as-a-service, user auth, file storage.",
    "url": "https://supabase.com",
    "api_base": "https://{project_id}.supabase.co",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://supabase.com/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "apikey: your-anon-key",
    "how_to_get": "Create project at https://supabase.com — free tier available",
    "cost": "Free: 500MB DB, 1GB storage. Pro: $25/month"
  },
  "capabilities": [
    {
      "id": "select_rows",
      "description_for_ai": "Query rows from a Supabase (PostgreSQL) table with filters, ordering, and pagination.",
      "intent": [
        "supabase query",
        "select data",
        "database query supabase",
        "получить данные supabase"
      ],
      "endpoint": "GET https://{project}.supabase.co/rest/v1/{table}",
      "input": {
        "table": {
          "type": "string",
          "required": true
        },
        "select": {
          "type": "string",
          "description": "Column selection: *, id,name,email or nested: id,posts(title,body)",
          "default": "*"
        },
        "filter": {
          "type": "string",
          "description": "Query param filter: ?status=eq.active&age=gt.18. Operators: eq, neq, gt, gte, lt, lte, like, ilike, in, is",
          "required": false
        },
        "order": {
          "type": "string",
          "description": "?order=created_at.desc",
          "required": false
        },
        "limit": {
          "type": "integer",
          "description": "?limit=20",
          "required": false
        },
        "offset": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "list<row>",
        "fields": [
          "[0].id",
          "[0].all requested columns"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "insert_rows",
      "description_for_ai": "Insert one or more rows into a Supabase table.",
      "intent": [
        "insert supabase",
        "add row database",
        "create record supabase",
        "добавить запись supabase"
      ],
      "endpoint": "POST https://{project}.supabase.co/rest/v1/{table}",
      "input": {
        "table": {
          "type": "string",
          "required": true
        },
        "data": {
          "type": "object or array",
          "description": "{column: value} or [{...}, {...}] for batch insert",
          "required": true
        },
        "prefer": {
          "type": "string",
          "description": "Set to 'return=representation' to get inserted rows back",
          "required": false
        }
      },
      "output": {
        "type": "inserted_row",
        "fields": [
          "id",
          "created_at",
          "all columns"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_rows",
      "description_for_ai": "Update rows matching a filter. ALWAYS include a filter to avoid updating all rows.",
      "intent": [
        "update supabase",
        "edit row database",
        "update record",
        "обновить запись supabase"
      ],
      "endpoint": "PATCH https://{project}.supabase.co/rest/v1/{table}",
      "input": {
        "table": {
          "type": "string",
          "required": true
        },
        "filter": {
          "type": "string",
          "description": "REQUIRED: ?id=eq.123. Without filter ALL rows are updated!",
          "required": true
        },
        "data": {
          "type": "object",
          "description": "{column: new_value}",
          "required": true
        }
      },
      "output": {
        "type": "updated_row",
        "fields": [
          "id",
          "updated columns"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "call_rpc",
      "description_for_ai": "Call a PostgreSQL function (stored procedure) via Supabase RPC. Use for complex queries, business logic, or secure operations.",
      "intent": [
        "supabase function",
        "rpc supabase",
        "stored procedure",
        "функция supabase"
      ],
      "endpoint": "POST https://{project}.supabase.co/rest/v1/rpc/{function_name}",
      "input": {
        "function_name": {
          "type": "string",
          "description": "PostgreSQL function name",
          "required": true
        },
        "params": {
          "type": "object",
          "description": "Function parameters as JSON object",
          "required": false
        }
      },
      "output": {
        "type": "any",
        "fields": [
          "function return value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "project": "Replace {project_id} with your project reference ID from supabase.com dashboard URL.",
    "anon_key": "Use anon key for client-side (public) access with Row Level Security. Use service_role key server-side only.",
    "rls": "Enable Row Level Security (RLS) on tables! Without it, anyone with anon key can read/write all data.",
    "realtime": "Subscribe to changes: supabase.channel('changes').on('postgres_changes', {table: 'messages'}, callback).subscribe()"
  }
}