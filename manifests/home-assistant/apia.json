{
  "apia": "1.0",
  "service": {
    "id": "home-assistant",
    "name": "Home Assistant REST API",
    "description_for_ai": "Open-source home automation platform. Control 3000+ smart home devices: lights, switches, sensors, climate, media players, locks. Local API via REST. The most popular self-hosted smart home platform.",
    "url": "https://home-assistant.io",
    "api_base": "http://{ha_host}:8123/api",
    "category": "iot",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.home-assistant.io/docs/api/rest/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer {long_lived_token}",
    "how_to_get": "Profile → Long-Lived Access Tokens → Create Token",
    "cost": "Free — self-hosted"
  },
  "capabilities": [
    {
      "id": "get_states",
      "description_for_ai": "Get current state of all or specific entities: lights, sensors, switches, locks, climate.",
      "intent": [
        "home status",
        "device status",
        "smart home state",
        "is light on",
        "temperature sensor",
        "house status"
      ],
      "endpoint": "GET http://{ha_host}:8123/api/states",
      "input": {
        "entity_id": {
          "type": "string",
          "description": "Optional specific entity e.g. light.living_room, sensor.temperature",
          "required": false
        }
      },
      "output": {
        "type": "list<state>",
        "fields": [
          "entity_id",
          "state",
          "attributes.friendly_name",
          "attributes.brightness",
          "attributes.temperature",
          "last_changed"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "call_service",
      "description_for_ai": "Call Home Assistant service to control any device. Most powerful method — covers all automations.",
      "intent": [
        "turn on light",
        "control thermostat",
        "lock door",
        "play music",
        "set temperature",
        "включить устройство"
      ],
      "endpoint": "POST http://{ha_host}:8123/api/services/{domain}/{service}",
      "input": {
        "domain": {
          "type": "string",
          "description": "Device domain: light, switch, climate, media_player, lock, cover",
          "required": true
        },
        "service": {
          "type": "string",
          "description": "Service: turn_on, turn_off, toggle, set_temperature, lock, unlock",
          "required": true
        },
        "entity_id": {
          "type": "string",
          "description": "Target entity e.g. light.kitchen",
          "required": true
        },
        "brightness": {
          "type": "integer",
          "description": "For lights: 0-255",
          "required": false
        },
        "temperature": {
          "type": "float",
          "description": "Randomness 0.0-1.0: lower=deterministic, higher=creative",
          "required": false
        }
      },
      "output": {
        "type": "list<state>",
        "fields": [
          "entity_id",
          "state",
          "attributes"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_history",
      "description_for_ai": "Get historical state data for entities over a time period.",
      "intent": [
        "sensor history",
        "temperature history",
        "device history",
        "when was light on"
      ],
      "endpoint": "GET http://{ha_host}:8123/api/history/period/{start_time}",
      "input": {
        "start_time": {
          "type": "string",
          "description": "ISO 8601 start time",
          "required": true
        },
        "filter_entity_id": {
          "type": "string",
          "description": "Specific entity ID",
          "required": false
        },
        "end_time": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<history>",
        "fields": [
          "entity_id",
          "state",
          "last_changed",
          "attributes"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "call_service",
      "description_for_ai": "Call a Home Assistant service: turn on/off lights, set thermostat, play media.",
      "intent": [
        "control device home assistant",
        "turn on light",
        "home automation",
        "управление устройством home assistant"
      ],
      "endpoint": "POST https://{ha_url}/api/services/{domain}/{service}",
      "input": {
        "domain": {
          "type": "string",
          "description": "light, switch, climate, media_player, script, automation",
          "required": true
        },
        "service": {
          "type": "string",
          "description": "turn_on, turn_off, toggle, set_temperature, play_media",
          "required": true
        },
        "entity_id": {
          "type": "string",
          "description": "Entity to control: light.living_room",
          "required": false
        },
        "extra_data": {
          "type": "object",
          "description": "Service-specific params: {brightness: 200} or {temperature: 22}",
          "required": false
        }
      },
      "output": {
        "type": "list<state>",
        "fields": [
          "[0].entity_id",
          "[0].state",
          "[0].attributes"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_history",
      "description_for_ai": "Get state history for Home Assistant entities over a time range.",
      "intent": [
        "home assistant history",
        "sensor history",
        "state log HA",
        "история состояний home assistant"
      ],
      "endpoint": "GET https://{ha_url}/api/history/period/{start_time}",
      "input": {
        "start_time": {
          "type": "string",
          "description": "ISO 8601 start",
          "required": true
        },
        "entity_id": {
          "type": "string",
          "description": "Filter by entity",
          "required": false
        },
        "end_time": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "history",
        "fields": [
          "[[{entity_id, state, last_changed}]]"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "domains": "Common domains: light, switch, climate, media_player, lock, cover, sensor, binary_sensor, input_boolean",
    "local": "Local network only. For remote access use Home Assistant Cloud (Nabu Casa) or VPN.",
    "nabu_casa": "With Nabu Casa subscription get remote URL: https://{id}.ui.nabu.casa/api"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}