{
  "apia": "1.0",
  "service": {
    "id": "netlify",
    "name": "Netlify API",
    "description_for_ai": "Jamstack hosting platform. Deploy static sites, Next.js, Gatsby. Edge functions, serverless, forms, auth, split testing. Free tier very generous. Used by 3M+ developers. Use for frontend deployment, static hosting.",
    "url": "https://netlify.com",
    "api_base": "https://api.netlify.com/api/v1",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://open-api.netlify.com/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer {token}",
    "how_to_get": "User Settings → Applications → New access token",
    "cost": "Free: 100GB bandwidth, 300 build min/month. Pro: $19/month"
  },
  "capabilities": [
    {
      "id": "list_sites",
      "description_for_ai": "List all Netlify sites in your account.",
      "intent": [
        "Netlify sites",
        "list deployments",
        "my sites Netlify",
        "список сайтов Netlify"
      ],
      "endpoint": "GET https://api.netlify.com/api/v1/sites",
      "input": {
        "per_page": {
          "type": "integer",
          "default": 25
        },
        "page": {
          "type": "integer",
          "default": 1
        },
        "filter": {
          "type": "string",
          "description": "all, owner, collaborator, contributor",
          "default": "all"
        }
      },
      "output": {
        "type": "list<site>",
        "fields": [
          "[0].id",
          "[0].name",
          "[0].custom_domain",
          "[0].url",
          "[0].deploy_url",
          "[0].published_deploy.published_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_deploy",
      "description_for_ai": "Trigger a new deployment for a Netlify site.",
      "intent": [
        "deploy Netlify",
        "trigger build",
        "redeploy site",
        "деплой Netlify"
      ],
      "endpoint": "POST https://api.netlify.com/api/v1/sites/{site_id}/deploys",
      "input": {
        "site_id": {
          "type": "string",
          "required": true
        },
        "title": {
          "type": "string",
          "description": "Deploy title/message",
          "required": false
        },
        "clear_cache": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "deploy",
        "fields": [
          "id",
          "state",
          "url",
          "created_at",
          "deploy_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_deploy",
      "description_for_ai": "Get status and details of a specific Netlify deployment.",
      "intent": [
        "deploy status Netlify",
        "build status",
        "deployment info",
        "статус деплоя Netlify"
      ],
      "endpoint": "GET https://api.netlify.com/api/v1/deploys/{deploy_id}",
      "input": {
        "deploy_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "deploy",
        "fields": [
          "id",
          "state",
          "error_message",
          "created_at",
          "published_at",
          "deploy_time",
          "url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "set_env_var",
      "description_for_ai": "Set environment variables for a Netlify site.",
      "intent": [
        "set env var Netlify",
        "environment variables",
        "site config Netlify",
        "переменные окружения Netlify"
      ],
      "endpoint": "PATCH https://api.netlify.com/api/v1/accounts/{account_id}/env",
      "input": {
        "account_id": {
          "type": "string",
          "required": true
        },
        "site_id": {
          "type": "string",
          "description": "Target site (omit for account-level)",
          "required": false
        },
        "env_vars": {
          "type": "array",
          "description": "[{key: 'API_KEY', values: [{value: 'abc123', context: 'production'}]}]",
          "required": true
        }
      },
      "output": {
        "type": "list<env_var>",
        "fields": [
          "[0].key",
          "[0].values[0].context",
          "[0].values[0].value"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "lock_deploy",
      "description_for_ai": "Lock a deploy to production so future builds don't auto-publish, or unlock it.",
      "intent": [
        "lock deploy Netlify",
        "freeze production",
        "publish control Netlify",
        "заморозить деплой Netlify"
      ],
      "endpoint": "POST https://api.netlify.com/api/v1/deploys/{deploy_id}/lock",
      "input": {
        "deploy_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "deploy",
        "fields": [
          "id",
          "locked",
          "state"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "auth": "Create personal access token at app.netlify.com/user/applications/personal. Bearer token in header.",
    "site_id": "Get site ID from site settings or from list_sites response id field.",
    "deploy_hooks": "Set up deploy hooks in UI for triggering builds from external systems (webhooks).",
    "env_vars": "Manage environment variables via PATCH /api/v1/sites/{site_id} with build_settings.env object."
  }
}