{
  "apia": "1.0",
  "service": {
    "id": "netlify",
    "name": "Netlify API",
    "description_for_ai": "Jamstack hosting platform. Deploy static sites, Next.js, Gatsby. Edge functions, serverless, forms, auth, split testing. Free tier very generous. Used by 3M+ developers. Use for frontend deployment, static hosting.",
    "url": "https://netlify.com",
    "api_base": "https://api.netlify.com/api/v1",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://open-api.netlify.com/"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer {token}",
    "how_to_get": "User Settings → Applications → New access token",
    "cost": "Free: 100GB bandwidth, 300 build min/month. Pro: $19/month"
  },
  "capabilities": [
    {
      "id": "list_sites",
      "description_for_ai": "List all Netlify sites with deployment status and URLs.",
      "intent": [
        "netlify sites",
        "list sites netlify",
        "deployed sites",
        "сайты netlify"
      ],
      "endpoint": "GET https://api.netlify.com/api/v1/sites",
      "input": {
        "filter": {
          "type": "string",
          "description": "all, owner, guest",
          "default": "all"
        },
        "per_page": {
          "type": "integer",
          "default": 20
        },
        "page": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "list<site>",
        "fields": [
          "[0].id",
          "[0].name",
          "[0].url",
          "[0].ssl_url",
          "[0].published_deploy.state",
          "[0].published_deploy.published_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "deploy_site",
      "description_for_ai": "Trigger a new deployment for an existing Netlify site.",
      "intent": [
        "deploy netlify",
        "redeploy site",
        "trigger build netlify",
        "задеплоить netlify"
      ],
      "endpoint": "POST https://api.netlify.com/api/v1/sites/{site_id}/deploys",
      "input": {
        "site_id": {
          "type": "string",
          "required": true
        },
        "clear_cache": {
          "type": "boolean",
          "description": "Clear build cache before deploying",
          "default": false
        },
        "title": {
          "type": "string",
          "description": "Deploy title/message",
          "required": false
        }
      },
      "output": {
        "type": "deploy",
        "fields": [
          "id",
          "state",
          "url",
          "deploy_url",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_deploys",
      "description_for_ai": "Get deploy history for a site with status and timestamps.",
      "intent": [
        "netlify deploy history",
        "deployment log netlify",
        "netlify builds",
        "история деплоев netlify"
      ],
      "endpoint": "GET https://api.netlify.com/api/v1/sites/{site_id}/deploys",
      "input": {
        "site_id": {
          "type": "string",
          "required": true
        },
        "per_page": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<deploy>",
        "fields": [
          "[0].id",
          "[0].state",
          "[0].created_at",
          "[0].published_at",
          "[0].error_message",
          "[0].commit_ref"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "update_env_vars",
      "description_for_ai": "Set or update environment variables for a Netlify site.",
      "intent": [
        "netlify env vars",
        "environment variables netlify",
        "set secrets netlify",
        "переменные окружения netlify"
      ],
      "endpoint": "PATCH https://api.netlify.com/api/v1/sites/{site_id}",
      "input": {
        "site_id": {
          "type": "string",
          "required": true
        },
        "build_settings": {
          "type": "object",
          "description": "{env: {MY_VAR: 'value', API_KEY: 'secret'}}",
          "required": true
        }
      },
      "output": {
        "type": "site",
        "fields": [
          "id",
          "name",
          "build_settings.env"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "auth": "Create personal access token at app.netlify.com/user/applications/personal. Bearer token in header.",
    "site_id": "Get site ID from site settings or from list_sites response id field.",
    "deploy_hooks": "Set up deploy hooks in UI for triggering builds from external systems (webhooks).",
    "env_vars": "Manage environment variables via PATCH /api/v1/sites/{site_id} with build_settings.env object."
  }
}