{
  "apia": "1.0",
  "service": {
    "id": "google-gemini-pro",
    "name": "Gemini 2.5 Pro API",
    "description_for_ai": "Google most powerful Gemini model. 1M token context window, best reasoning, code and math. Outperforms GPT-4o on many benchmarks. Use when maximum quality needed: complex analysis, large codebase review, long document processing.",
    "url": "https://ai.google.dev",
    "api_base": "https://generativelanguage.googleapis.com/v1beta",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://ai.google.dev/gemini-api/docs/models"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "https://aistudio.google.com/app/apikey",
    "cost": "$1.25/$10 per 1M tokens (under 200K context). $2.50/$15 over 200K."
  },
  "capabilities": [
    {
      "id": "generate_content",
      "description_for_ai": "High-quality text generation with Gemini 1.5 Pro. Best for complex reasoning, long documents, code.",
      "intent": [
        "Gemini Pro",
        "best AI Google",
        "complex reasoning",
        "качественная генерация Gemini Pro"
      ],
      "endpoint": "POST https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro:generateContent",
      "input": {
        "contents": {
          "type": "array",
          "required": true
        },
        "systemInstruction": {
          "type": "object",
          "required": false
        },
        "generationConfig": {
          "type": "object",
          "description": "{temperature, maxOutputTokens, topK, topP}",
          "required": false
        }
      },
      "output": {
        "type": "response",
        "fields": [
          "candidates[0].content.parts[0].text",
          "usageMetadata"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "long_context",
      "description_for_ai": "Process up to 1 million tokens with Gemini 1.5 Pro. Analyze entire codebases, books, or long documents.",
      "intent": [
        "long document",
        "analyze codebase",
        "book summary",
        "million tokens",
        "длинный контекст Gemini"
      ],
      "endpoint": "POST https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro:generateContent",
      "input": {
        "contents": {
          "type": "array",
          "description": "Supports very long texts — up to 1M tokens context window",
          "required": true
        },
        "generationConfig": {
          "type": "object",
          "required": false
        }
      },
      "output": {
        "type": "response",
        "fields": [
          "candidates[0].content.parts[0].text",
          "usageMetadata.promptTokenCount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "code_generation",
      "description_for_ai": "Generate, review, and debug code with Gemini Pro. Supports all major languages.",
      "intent": [
        "code generation Gemini",
        "write code AI",
        "code review AI",
        "генерация кода Gemini"
      ],
      "endpoint": "POST https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro:generateContent",
      "input": {
        "contents": {
          "type": "array",
          "required": true
        },
        "generationConfig": {
          "type": "object",
          "description": "{temperature: 0, responseMimeType: 'text/plain'}",
          "required": false
        }
      },
      "output": {
        "type": "response",
        "fields": [
          "candidates[0].content.parts[0].text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "multimodal_analysis",
      "description_for_ai": "Analyze images, audio, video, and documents together in a single prompt with Gemini Pro.",
      "intent": [
        "multimodal AI",
        "image and text",
        "video analysis",
        "мультимодальный анализ Gemini"
      ],
      "endpoint": "POST https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro:generateContent",
      "input": {
        "contents": {
          "type": "array",
          "description": "Mix text, images (base64/URL), audio, video in parts array",
          "required": true
        }
      },
      "output": {
        "type": "response",
        "fields": [
          "candidates[0].content.parts[0].text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "grounding_with_search",
      "description_for_ai": "Enable Gemini Pro to search Google and ground its answers in real-time web results.",
      "intent": [
        "Gemini with search",
        "grounded AI",
        "real-time knowledge",
        "актуальная информация Gemini"
      ],
      "endpoint": "POST https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro:generateContent",
      "input": {
        "contents": {
          "type": "array",
          "required": true
        },
        "tools": {
          "type": "array",
          "description": "[{google_search: {}}] — enables web grounding",
          "required": true
        }
      },
      "output": {
        "type": "response",
        "fields": [
          "candidates[0].content.parts[0].text",
          "candidates[0].groundingMetadata.searchEntryPoint"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "context_window": "1M tokens = ~750K words = entire novel or codebase. Pass entire files without chunking.",
    "vs_flash": "gemini-2.5-flash for high volume cheap tasks. gemini-2.5-pro for best quality when it matters."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}