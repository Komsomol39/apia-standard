{
  "apia": "1.0",
  "service": {
    "id": "mistral",
    "name": "Mistral AI API",
    "description_for_ai": "European AI company with strong open-weight models. Best for: code generation (Codestral), multilingual European tasks, cost-efficient production. OpenAI-compatible API. Mistral Small is one of the cheapest quality models. Strong on French, German, Spanish, Italian.",
    "url": "https://mistral.ai",
    "api_base": "https://api.mistral.ai/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.mistral.ai"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer ...",
    "how_to_get": "Register at https://console.mistral.ai — free tier available",
    "cost": "Mistral Small 3.1: $0.10/$0.30 per 1M tokens. Mistral Large 3: $2/$6. Codestral: $0.30/$0.90"
  },
  "capabilities": [
    {
      "id": "chat",
      "description_for_ai": "Chat with Mistral AI models. Strong at coding, math, multilingual including French. Open weights available.",
      "intent": [
        "mistral chat",
        "ask mistral",
        "mistral AI",
        "european AI",
        "спросить mistral"
      ],
      "endpoint": "POST https://api.mistral.ai/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "description": "mistral-large-latest (best), mistral-small-latest (fast), codestral-latest (code)",
          "required": true
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "temperature": {
          "type": "float",
          "default": 0.7
        },
        "max_tokens": {
          "type": "integer",
          "required": false
        },
        "stream": {
          "type": "boolean",
          "default": false
        },
        "tools": {
          "type": "array",
          "description": "Function calling tools",
          "required": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "usage.total_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "embeddings",
      "description_for_ai": "Generate text embeddings with Mistral. Good multilingual support.",
      "intent": [
        "mistral embeddings",
        "semantic search mistral",
        "vectors mistral"
      ],
      "endpoint": "POST https://api.mistral.ai/v1/embeddings",
      "input": {
        "model": {
          "type": "string",
          "default": "mistral-embed"
        },
        "input": {
          "type": "array",
          "description": "List of strings to embed",
          "required": true
        }
      },
      "output": {
        "type": "embeddings",
        "fields": [
          "data[0].embedding",
          "usage.total_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "fim_completion",
      "description_for_ai": "Fill-in-the-middle code completion. Give prefix and suffix, Mistral fills the middle. Ideal for code editing.",
      "intent": [
        "code completion",
        "fill in the middle",
        "code suggestion",
        "автодополнение кода mistral"
      ],
      "endpoint": "POST https://api.mistral.ai/v1/fim/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "codestral-latest"
        },
        "prompt": {
          "type": "string",
          "description": "Code before the cursor",
          "required": true
        },
        "suffix": {
          "type": "string",
          "description": "Code after the cursor",
          "required": false
        },
        "max_tokens": {
          "type": "integer",
          "required": false
        },
        "temperature": {
          "type": "float",
          "default": 0.0
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_models",
      "description_for_ai": "List available Mistral models and their capabilities.",
      "intent": [
        "mistral models",
        "available models",
        "список моделей mistral"
      ],
      "endpoint": "GET https://api.mistral.ai/v1/models",
      "input": {},
      "output": {
        "type": "list<model>",
        "fields": [
          "data[0].id",
          "data[0].capabilities.completion_chat",
          "data[0].capabilities.fine_tuning"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "openai_compat": "100% OpenAI-compatible. Change base URL to https://api.mistral.ai/v1 and swap model names. Same SDK works.",
    "model_choice": "mistral-small-latest for high-volume cheap tasks. mistral-large-latest for complex reasoning. codestral-latest for code.",
    "european_strength": "Mistral models are trained with stronger European language data — prefer over OpenAI for French/German/Spanish/Italian tasks.",
    "open_source": "Mistral 7B and Mixtral 8x7B are open-weight and can be self-hosted. API is for managed hosting."
  },
  "limits": {
    "commercial_use": true,
    "attribution_required": false
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}