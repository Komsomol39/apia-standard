{
  "apia": "1.0",
  "service": {
    "id": "mistral",
    "name": "Mistral AI API",
    "description_for_ai": "European AI company with strong open-weight models. Best for: code generation (Codestral), multilingual European tasks, cost-efficient production. OpenAI-compatible API. Mistral Small is one of the cheapest quality models. Strong on French, German, Spanish, Italian.",
    "url": "https://mistral.ai",
    "api_base": "https://api.mistral.ai/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.mistral.ai"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer ...",
    "how_to_get": "Register at https://console.mistral.ai — free tier available",
    "cost": "Mistral Small 3.1: $0.10/$0.30 per 1M tokens. Mistral Large 3: $2/$6. Codestral: $0.30/$0.90"
  },
  "capabilities": [
    {
      "id": "chat_completion",
      "description_for_ai": "Generate text with Mistral models. Efficient European AI with strong multilingual support.",
      "intent": [
        "Mistral AI",
        "French AI",
        "European AI",
        "chat completion Mistral",
        "Mistral чат"
      ],
      "endpoint": "POST https://api.mistral.ai/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "description": "mistral-large-latest (best), mistral-small-latest (cheap), open-mistral-nemo (free tier)",
          "required": true
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "temperature": {
          "type": "float",
          "default": 0.7
        },
        "max_tokens": {
          "type": "integer",
          "required": false
        },
        "stream": {
          "type": "boolean",
          "default": false
        },
        "response_format": {
          "type": "object",
          "description": "{type: 'json_object'}",
          "required": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "usage"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "function_calling",
      "description_for_ai": "Use Mistral with tool/function calling for agentic workflows.",
      "intent": [
        "Mistral tools",
        "function calling Mistral",
        "agent Mistral",
        "инструменты Mistral"
      ],
      "endpoint": "POST https://api.mistral.ai/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "required": true
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "tools": {
          "type": "array",
          "description": "[{type: 'function', function: {name, description, parameters}}]",
          "required": true
        },
        "tool_choice": {
          "type": "string",
          "description": "auto, any, none",
          "default": "auto"
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.tool_calls[0].function.name",
          "choices[0].message.tool_calls[0].function.arguments"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "embeddings",
      "description_for_ai": "Generate text embeddings with Mistral Embed model.",
      "intent": [
        "Mistral embeddings",
        "text embeddings",
        "RAG Mistral",
        "семантический поиск Mistral"
      ],
      "endpoint": "POST https://api.mistral.ai/v1/embeddings",
      "input": {
        "model": {
          "type": "string",
          "default": "mistral-embed"
        },
        "input": {
          "type": "array",
          "description": "Array of strings to embed",
          "required": true
        }
      },
      "output": {
        "type": "embeddings",
        "fields": [
          "data[0].embedding",
          "usage.total_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "code_generation",
      "description_for_ai": "Use Codestral or Mistral for code generation, completion, and review.",
      "intent": [
        "code Mistral",
        "Codestral",
        "write code Mistral",
        "код Mistral"
      ],
      "endpoint": "POST https://api.mistral.ai/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "description": "codestral-latest for code-specific tasks",
          "required": true
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "temperature": {
          "type": "float",
          "description": "Use 0.0-0.2 for code generation",
          "default": 0.0
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "fim_completion",
      "description_for_ai": "Fill-in-the-middle code completion with Codestral. Provides prefix and suffix, Codestral fills the middle.",
      "intent": [
        "code completion",
        "fill in middle",
        "FIM Codestral",
        "дополнение кода Mistral"
      ],
      "endpoint": "POST https://codestral.mistral.ai/v1/fim/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "codestral-latest"
        },
        "prompt": {
          "type": "string",
          "description": "Code before the cursor",
          "required": true
        },
        "suffix": {
          "type": "string",
          "description": "Code after the cursor",
          "required": false
        },
        "temperature": {
          "type": "float",
          "default": 0.0
        },
        "max_tokens": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_models",
      "description_for_ai": "List all available Mistral models.",
      "intent": [
        "Mistral models",
        "available models",
        "список моделей Mistral"
      ],
      "endpoint": "GET https://api.mistral.ai/v1/models",
      "input": {},
      "output": {
        "type": "list<model>",
        "fields": [
          "data[0].id",
          "data[0].created"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "openai_compat": "100% OpenAI-compatible. Change base URL to https://api.mistral.ai/v1 and swap model names. Same SDK works.",
    "model_choice": "mistral-small-latest for high-volume cheap tasks. mistral-large-latest for complex reasoning. codestral-latest for code.",
    "european_strength": "Mistral models are trained with stronger European language data — prefer over OpenAI for French/German/Spanish/Italian tasks.",
    "open_source": "Mistral 7B and Mixtral 8x7B are open-weight and can be self-hosted. API is for managed hosting."
  },
  "limits": {
    "commercial_use": true,
    "attribution_required": false
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}