{
  "apia": "1.0",
  "service": {
    "id": "mailgun",
    "name": "Mailgun API",
    "description_for_ai": "Email API for developers. Send, receive, track emails. Email validation, inbox placement testing. 5000 emails/month free for 3 months. High deliverability. Used by GitHub, Stripe, Lyft. Use for transactional email at scale.",
    "url": "https://mailgun.com",
    "api_base": "https://api.mailgun.net/v3",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://documentation.mailgun.com/"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "api as username, API key as password",
    "how_to_get": "Register at https://mailgun.com",
    "cost": "Free: 5000 emails/month 3 months. Then $15/month 50K emails"
  },
  "capabilities": [
    {
      "id": "send_email",
      "description_for_ai": "Send transactional email via Mailgun. Supports HTML/text, attachments, and scheduling.",
      "intent": [
        "send email Mailgun",
        "transactional email",
        "email API",
        "отправить письмо Mailgun"
      ],
      "endpoint": "POST https://api.mailgun.net/v3/{domain}/messages",
      "input": {
        "domain": {
          "type": "string",
          "required": true
        },
        "from": {
          "type": "string",
          "description": "Sender: Name <email@domain.com>",
          "required": true
        },
        "to": {
          "type": "string or array",
          "description": "Recipient(s)",
          "required": true
        },
        "subject": {
          "type": "string",
          "required": true
        },
        "text": {
          "type": "string",
          "description": "Plain text body",
          "required": false
        },
        "html": {
          "type": "string",
          "description": "HTML body",
          "required": false
        },
        "o:tag": {
          "type": "array",
          "description": "Tags for tracking: ['transactional', 'password_reset']",
          "required": false
        },
        "o:deliverytime": {
          "type": "string",
          "description": "Schedule: 'Thu, 13 Jan 2024 12:00:00 UTC'",
          "required": false
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "id",
          "message"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_events",
      "description_for_ai": "Get email delivery events: delivered, failed, opened, clicked, unsubscribed.",
      "intent": [
        "email events Mailgun",
        "delivery status",
        "email tracking",
        "статус доставки Mailgun"
      ],
      "endpoint": "GET https://api.mailgun.net/v3/{domain}/events",
      "input": {
        "domain": {
          "type": "string",
          "required": true
        },
        "event": {
          "type": "string",
          "description": "accepted, rejected, delivered, failed, opened, clicked, unsubscribed, complained",
          "required": false
        },
        "recipient": {
          "type": "string",
          "description": "Filter by email address",
          "required": false
        },
        "begin": {
          "type": "string",
          "description": "Start datetime",
          "required": false
        },
        "end": {
          "type": "string",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 100
        }
      },
      "output": {
        "type": "list<event>",
        "fields": [
          "items[0].event",
          "items[0].recipient",
          "items[0].message.headers.message-id",
          "items[0].timestamp"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "validate_email",
      "description_for_ai": "Validate an email address to check if it's real and deliverable.",
      "intent": [
        "email validation",
        "validate email",
        "check email",
        "проверить email Mailgun"
      ],
      "endpoint": "GET https://api.mailgun.net/v4/address/validate",
      "input": {
        "address": {
          "type": "string",
          "description": "Email address to validate",
          "required": true
        }
      },
      "output": {
        "type": "validation",
        "fields": [
          "address",
          "is_valid",
          "mailbox_verification",
          "did_you_mean",
          "risk (low/medium/high)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "manage_suppression",
      "description_for_ai": "Manage unsubscribes, bounces, and complaints (suppression list).",
      "intent": [
        "unsubscribes Mailgun",
        "suppression list",
        "bounced emails",
        "список отписок Mailgun"
      ],
      "endpoint": "GET https://api.mailgun.net/v3/{domain}/unsubscribes",
      "input": {
        "domain": {
          "type": "string",
          "required": true
        },
        "limit": {
          "type": "integer",
          "default": 100
        }
      },
      "output": {
        "type": "list<suppression>",
        "fields": [
          "items[0].address",
          "items[0].tag",
          "items[0].created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_mailing_list",
      "description_for_ai": "Create a mailing list for sending to multiple recipients.",
      "intent": [
        "mailing list Mailgun",
        "email list",
        "create list Mailgun",
        "список рассылки Mailgun"
      ],
      "endpoint": "POST https://api.mailgun.net/v3/lists",
      "input": {
        "address": {
          "type": "string",
          "description": "List email: mylist@domain.com",
          "required": true
        },
        "name": {
          "type": "string",
          "required": false
        },
        "description": {
          "type": "string",
          "required": false
        },
        "access_level": {
          "type": "string",
          "description": "readonly, members, everyone",
          "default": "readonly"
        }
      },
      "output": {
        "type": "list",
        "fields": [
          "list.address",
          "list.name",
          "list.members_count"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}