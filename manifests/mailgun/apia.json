{
  "apia": "1.0",
  "service": {
    "id": "mailgun",
    "name": "Mailgun API",
    "description_for_ai": "Email API for developers. Send, receive, track emails. Email validation, inbox placement testing. 5000 emails/month free for 3 months. High deliverability. Used by GitHub, Stripe, Lyft. Use for transactional email at scale.",
    "url": "https://mailgun.com",
    "api_base": "https://api.mailgun.net/v3",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://documentation.mailgun.com/"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "api as username, API key as password",
    "how_to_get": "Register at https://mailgun.com",
    "cost": "Free: 5000 emails/month 3 months. Then $15/month 50K emails"
  },
  "capabilities": [
    {
      "id": "send_email",
      "description_for_ai": "Send email via Mailgun. Reliable transactional email with tracking and analytics.",
      "intent": [
        "send email mailgun",
        "mailgun email",
        "transactional mail",
        "отправить письмо mailgun"
      ],
      "endpoint": "POST https://api.mailgun.net/v3/{domain}/messages",
      "input": {
        "domain": {
          "type": "string",
          "description": "Your Mailgun domain e.g. mg.example.com",
          "required": true
        },
        "from": {
          "type": "string",
          "description": "Sender: Name <from@domain.com>",
          "required": true
        },
        "to": {
          "type": "string",
          "description": "Recipient email(s), comma-separated",
          "required": true
        },
        "subject": {
          "type": "string",
          "required": true
        },
        "html": {
          "type": "string",
          "description": "HTML email body",
          "required": false
        },
        "text": {
          "type": "string",
          "description": "Plain text body",
          "required": false
        },
        "cc": {
          "type": "string",
          "required": false
        },
        "bcc": {
          "type": "string",
          "required": false
        },
        "h:X-Mailgun-Variables": {
          "type": "string",
          "description": "JSON string of custom tracking variables",
          "required": false
        }
      },
      "output": {
        "type": "send_result",
        "fields": [
          "id",
          "message"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_events",
      "description_for_ai": "Get email event logs: delivered, opened, clicked, bounced, complained.",
      "intent": [
        "mailgun events",
        "email logs",
        "delivery tracking",
        "события mailgun"
      ],
      "endpoint": "GET https://api.mailgun.net/v3/{domain}/events",
      "input": {
        "domain": {
          "type": "string",
          "required": true
        },
        "event": {
          "type": "string",
          "description": "delivered, opened, clicked, bounced, complained, unsubscribed, rejected",
          "required": false
        },
        "begin": {
          "type": "string",
          "description": "RFC 2822 or Unix timestamp",
          "required": false
        },
        "end": {
          "type": "string",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 100
        }
      },
      "output": {
        "type": "list<event>",
        "fields": [
          "items[0].event",
          "items[0].recipient",
          "items[0].timestamp",
          "items[0].message.headers.subject"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "validate_email",
      "description_for_ai": "Validate an email address — check if it's real, deliverable, and not disposable.",
      "intent": [
        "validate email",
        "email check",
        "email verification",
        "проверить email",
        "валидация email"
      ],
      "endpoint": "GET https://api.mailgun.net/v4/address/validate",
      "input": {
        "address": {
          "type": "string",
          "description": "Email address to validate",
          "required": true
        }
      },
      "output": {
        "type": "validation",
        "fields": [
          "address",
          "is_valid",
          "reason",
          "is_disposable_address",
          "is_role_address",
          "result"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "add_mailing_list_member",
      "description_for_ai": "Add a subscriber to a Mailgun mailing list.",
      "intent": [
        "mailing list mailgun",
        "add subscriber",
        "email list",
        "список рассылки mailgun"
      ],
      "endpoint": "POST https://api.mailgun.net/v3/lists/{address}/members",
      "input": {
        "address": {
          "type": "string",
          "description": "Mailing list address e.g. list@mg.example.com",
          "required": true
        },
        "member_address": {
          "type": "string",
          "description": "Subscriber email",
          "required": true
        },
        "name": {
          "type": "string",
          "required": false
        },
        "subscribed": {
          "type": "boolean",
          "default": true
        },
        "upsert": {
          "type": "boolean",
          "description": "Update if exists",
          "default": true
        }
      },
      "output": {
        "type": "member",
        "fields": [
          "member.address",
          "member.subscribed"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}