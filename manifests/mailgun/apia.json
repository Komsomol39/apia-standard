{
  "apia": "1.0",
  "service": {
    "id": "mailgun",
    "name": "Mailgun API",
    "description_for_ai": "Email API for developers. Send, receive, track emails. Email validation, inbox placement testing. 5000 emails/month free for 3 months. High deliverability. Used by GitHub, Stripe, Lyft. Use for transactional email at scale.",
    "url": "https://mailgun.com",
    "api_base": "https://api.mailgun.net/v3",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://documentation.mailgun.com/"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "api as username, API key as password",
    "how_to_get": "Register at https://mailgun.com",
    "cost": "Free: 5000 emails/month 3 months. Then $15/month 50K emails"
  },
  "capabilities": [
    {
      "id": "send_email",
      "description_for_ai": "Send email via Mailgun. Supports HTML, attachments, templates, tags, and scheduled delivery.",
      "intent": [
        "send email mailgun",
        "transactional email",
        "email delivery mailgun",
        "отправить email mailgun"
      ],
      "endpoint": "POST https://api.mailgun.net/v3/{domain}/messages",
      "input": {
        "from": {
          "type": "string",
          "description": "Sender: Name <email@domain.com>",
          "required": true
        },
        "to": {
          "type": "string",
          "description": "Comma-separated recipients",
          "required": true
        },
        "subject": {
          "type": "string",
          "required": true
        },
        "text": {
          "type": "string",
          "description": "Plain text body",
          "required": false
        },
        "html": {
          "type": "string",
          "description": "HTML body",
          "required": false
        },
        "cc": {
          "type": "string",
          "required": false
        },
        "bcc": {
          "type": "string",
          "required": false
        },
        "o:tag": {
          "type": "string",
          "description": "Tag for tracking (max 3)",
          "required": false
        },
        "o:deliverytime": {
          "type": "string",
          "description": "RFC 2822 future time for scheduled send",
          "required": false
        }
      },
      "output": {
        "type": "result",
        "fields": [
          "id",
          "message"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_events",
      "description_for_ai": "Get email event log: delivered, opened, clicked, bounced, complained.",
      "intent": [
        "mailgun events",
        "email tracking",
        "delivery events",
        "события mailgun"
      ],
      "endpoint": "GET https://api.mailgun.net/v3/{domain}/events",
      "input": {
        "domain": {
          "type": "string",
          "required": true
        },
        "event": {
          "type": "string",
          "description": "accepted, rejected, delivered, failed, opened, clicked, unsubscribed, complained",
          "required": false
        },
        "recipient": {
          "type": "string",
          "description": "Filter by recipient email",
          "required": false
        },
        "begin": {
          "type": "string",
          "description": "Start time",
          "required": false
        },
        "end": {
          "type": "string",
          "required": false
        },
        "limit": {
          "type": "integer",
          "default": 100
        }
      },
      "output": {
        "type": "events",
        "fields": [
          "items[0].event",
          "items[0].recipient",
          "items[0].timestamp",
          "items[0].message.headers.subject"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "manage_mailing_list",
      "description_for_ai": "Create or get a Mailgun mailing list for bulk email management.",
      "intent": [
        "mailing list mailgun",
        "email list",
        "bulk email group",
        "список рассылки mailgun"
      ],
      "endpoint": "POST https://api.mailgun.net/v3/lists",
      "input": {
        "address": {
          "type": "string",
          "description": "List email address: devs@mg.yourdomain.com",
          "required": true
        },
        "description": {
          "type": "string",
          "required": false
        },
        "access_level": {
          "type": "string",
          "description": "readonly (members only), members (anyone can post), everyone",
          "default": "readonly"
        }
      },
      "output": {
        "type": "list",
        "fields": [
          "list.address",
          "list.members_count",
          "list.access_level"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "validate_email",
      "description_for_ai": "Validate email address: check MX records, syntax, catch-all, and mailbox existence.",
      "intent": [
        "validate email mailgun",
        "email validation",
        "check email exists",
        "проверить email mailgun"
      ],
      "endpoint": "GET https://api.mailgun.net/v4/address/validate",
      "input": {
        "address": {
          "type": "string",
          "description": "Email address to validate",
          "required": true
        },
        "provider_lookup": {
          "type": "boolean",
          "description": "Check actual mailbox existence (slower)",
          "default": false
        }
      },
      "output": {
        "type": "validation",
        "fields": [
          "address",
          "is_disposable_address",
          "is_role_address",
          "reason",
          "result (deliverable|undeliverable|catch_all|unknown)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}