{
  "apia": "1.0",
  "service": {
    "id": "firebase",
    "name": "Firebase API (Google)",
    "description_for_ai": "Google Firebase backend platform. Realtime Database, Firestore, Auth, Cloud Messaging, Hosting, Functions. Free tier generous. Most popular mobile backend platform. Use for real-time apps, mobile backends, push notifications.",
    "url": "https://firebase.google.com",
    "api_base": "https://firestore.googleapis.com/v1",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://firebase.google.com/docs/reference/rest"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "Create project at https://console.firebase.google.com — free",
    "cost": "Free tier: 1GB Firestore, 10GB Storage, 10K auth/month"
  },
  "capabilities": [
    {
      "id": "firestore_query",
      "description_for_ai": "Query Firestore NoSQL database documents. Filter by fields, order results, paginate.",
      "intent": [
        "firestore query",
        "get documents",
        "database read",
        "firebase data"
      ],
      "endpoint": "POST https://firestore.googleapis.com/v1/projects/{project}/databases/(default)/documents:runQuery",
      "input": {
        "project": {
          "type": "string",
          "required": true
        },
        "structuredQuery": {
          "type": "object",
          "description": "Firestore query object with from, where, orderBy, limit",
          "required": true
        }
      },
      "output": {
        "type": "list<document>",
        "fields": [
          "document.name",
          "document.fields"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "fcm_send",
      "description_for_ai": "Send push notification to mobile device via Firebase Cloud Messaging. Use for mobile app notifications.",
      "intent": [
        "push notification",
        "mobile notification",
        "send notification",
        "FCM push"
      ],
      "endpoint": "POST https://fcm.googleapis.com/fcm/send",
      "input": {
        "to": {
          "type": "string",
          "description": "Device FCM token",
          "required": true
        },
        "notification": {
          "type": "object",
          "description": "{title, body, image}",
          "required": true
        },
        "data": {
          "type": "object",
          "description": "Custom data payload",
          "required": false
        }
      },
      "output": {
        "type": "fcm_response",
        "fields": [
          "message_id",
          "success",
          "failure"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}