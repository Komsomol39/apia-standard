{
  "apia": "1.0",
  "service": {
    "id": "firebase",
    "name": "Firebase API (Google)",
    "description_for_ai": "Google Firebase backend platform. Realtime Database, Firestore, Auth, Cloud Messaging, Hosting, Functions. Free tier generous. Most popular mobile backend platform. Use for real-time apps, mobile backends, push notifications.",
    "url": "https://firebase.google.com",
    "api_base": "https://firestore.googleapis.com/v1",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://firebase.google.com/docs/reference/rest"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "Create project at https://console.firebase.google.com — free",
    "cost": "Free tier: 1GB Firestore, 10GB Storage, 10K auth/month"
  },
  "capabilities": [
    {
      "id": "get_document",
      "description_for_ai": "Get a Firestore document by path. Returns document fields.",
      "intent": [
        "firebase get document",
        "firestore read",
        "get firebase data",
        "читать firebase"
      ],
      "endpoint": "GET https://firestore.googleapis.com/v1/projects/{project}/databases/(default)/documents/{collection}/{document}",
      "input": {
        "project": {
          "type": "string",
          "description": "Firebase project ID",
          "required": true
        },
        "collection": {
          "type": "string",
          "description": "Collection name e.g. users",
          "required": true
        },
        "document": {
          "type": "string",
          "description": "Document ID",
          "required": true
        }
      },
      "output": {
        "type": "document",
        "fields": [
          "name",
          "fields (map of field values)",
          "createTime",
          "updateTime"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "set_document",
      "description_for_ai": "Create or overwrite a Firestore document. Use PATCH to merge/update specific fields.",
      "intent": [
        "firebase write",
        "firestore create document",
        "save to firebase",
        "записать в firebase"
      ],
      "endpoint": "PATCH https://firestore.googleapis.com/v1/projects/{project}/databases/(default)/documents/{collection}/{document}",
      "input": {
        "project": {
          "type": "string",
          "required": true
        },
        "collection": {
          "type": "string",
          "required": true
        },
        "document": {
          "type": "string",
          "required": true
        },
        "fields": {
          "type": "object",
          "description": "Document fields in Firestore format: {name: {stringValue: 'John'}, age: {integerValue: 30}}",
          "required": true
        },
        "updateMask.fieldPaths": {
          "type": "array",
          "description": "Field paths to update (for partial update). Omit to replace entire document.",
          "required": false
        }
      },
      "output": {
        "type": "document",
        "fields": [
          "name",
          "fields",
          "updateTime"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "query_collection",
      "description_for_ai": "Query Firestore collection with filters, ordering, and limits.",
      "intent": [
        "firebase query",
        "firestore query",
        "filter collection firebase",
        "запрос firestore"
      ],
      "endpoint": "POST https://firestore.googleapis.com/v1/projects/{project}/databases/(default)/documents:runQuery",
      "input": {
        "project": {
          "type": "string",
          "required": true
        },
        "structuredQuery": {
          "type": "object",
          "description": "{from: [{collectionId: 'users'}], where: {fieldFilter: {field: {fieldPath: 'status'}, op: 'EQUAL', value: {stringValue: 'active'}}}, orderBy: [{field: {fieldPath: 'createdAt'}, direction: 'DESCENDING'}], limit: 10}",
          "required": true
        }
      },
      "output": {
        "type": "list<document>",
        "fields": [
          "[0].document.name",
          "[0].document.fields"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_notification",
      "description_for_ai": "Send Firebase Cloud Messaging (FCM) push notification to mobile device, topic, or device group.",
      "intent": [
        "push notification firebase",
        "FCM send",
        "mobile notification",
        "пуш уведомление firebase"
      ],
      "endpoint": "POST https://fcm.googleapis.com/v1/projects/{project}/messages:send",
      "input": {
        "project": {
          "type": "string",
          "required": true
        },
        "message": {
          "type": "object",
          "description": "{token: 'device_token' or topic: '/topics/news', notification: {title: 'Title', body: 'Message'}, data: {key: 'value'}, android: {priority: 'high'}, apns: {headers: {'apns-priority': '10'}}}",
          "required": true
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "name (message resource name)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}