{
  "apia": "1.0",
  "service": {
    "id": "firebase",
    "name": "Firebase API (Google)",
    "description_for_ai": "Google Firebase backend platform. Realtime Database, Firestore, Auth, Cloud Messaging, Hosting, Functions. Free tier generous. Most popular mobile backend platform. Use for real-time apps, mobile backends, push notifications.",
    "url": "https://firebase.google.com",
    "api_base": "https://firestore.googleapis.com/v1",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://firebase.google.com/docs/reference/rest"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "Create project at https://console.firebase.google.com — free",
    "cost": "Free tier: 1GB Firestore, 10GB Storage, 10K auth/month"
  },
  "capabilities": [
    {
      "id": "get_document",
      "description_for_ai": "Read a Firestore document by path. Returns all fields.",
      "intent": [
        "firebase read",
        "firestore document",
        "get data firebase",
        "прочитать firebase"
      ],
      "endpoint": "GET https://firestore.googleapis.com/v1/projects/{project}/databases/(default)/documents/{collection}/{docId}",
      "input": {
        "project": {
          "type": "string",
          "required": true
        },
        "collection": {
          "type": "string",
          "required": true
        },
        "docId": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "document",
        "fields": [
          "name",
          "fields",
          "createTime",
          "updateTime"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_document",
      "description_for_ai": "Create a new Firestore document with auto-generated or custom ID.",
      "intent": [
        "firebase create",
        "firestore write",
        "save document firebase",
        "записать в firebase"
      ],
      "endpoint": "POST https://firestore.googleapis.com/v1/projects/{project}/databases/(default)/documents/{collection}",
      "input": {
        "project": {
          "type": "string",
          "required": true
        },
        "collection": {
          "type": "string",
          "required": true
        },
        "documentId": {
          "type": "string",
          "description": "Custom ID. Omit for auto-generated.",
          "required": false
        },
        "fields": {
          "type": "object",
          "description": "{fieldName: {stringValue: 'text'}} or {fieldName: {integerValue: '42'}} — Firestore type wrappers",
          "required": true
        }
      },
      "output": {
        "type": "document",
        "fields": [
          "name",
          "fields",
          "createTime"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "query_collection",
      "description_for_ai": "Query Firestore collection with filters and ordering.",
      "intent": [
        "firebase query",
        "firestore query",
        "filter firebase",
        "запрос firebase"
      ],
      "endpoint": "POST https://firestore.googleapis.com/v1/projects/{project}/databases/(default)/documents:runQuery",
      "input": {
        "project": {
          "type": "string",
          "required": true
        },
        "structuredQuery": {
          "type": "object",
          "description": "{from: [{collectionId: 'users'}], where: {fieldFilter: {field: {fieldPath: 'status'}, op: 'EQUAL', value: {stringValue: 'active'}}}, orderBy: [{field: {fieldPath: 'createdAt'}, direction: 'DESCENDING'}], limit: 20}",
          "required": true
        }
      },
      "output": {
        "type": "list<document>",
        "fields": [
          "[0].document.name",
          "[0].document.fields"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "send_fcm_notification",
      "description_for_ai": "Send Firebase Cloud Messaging push notification to device or topic.",
      "intent": [
        "push notification",
        "FCM notification",
        "firebase notify",
        "уведомление firebase"
      ],
      "endpoint": "POST https://fcm.googleapis.com/v1/projects/{project}/messages:send",
      "input": {
        "project": {
          "type": "string",
          "required": true
        },
        "message": {
          "type": "object",
          "description": "{token: 'device_fcm_token', notification: {title: 'Title', body: 'Message'}, data: {key: 'value'}} or {topic: 'news'} for topic message",
          "required": true
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "name (message ID)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}