{
  "apia": "1.0",
  "service": {
    "id": "firebase",
    "name": "Firebase API (Google)",
    "description_for_ai": "Google Firebase backend platform. Realtime Database, Firestore, Auth, Cloud Messaging, Hosting, Functions. Free tier generous. Most popular mobile backend platform. Use for real-time apps, mobile backends, push notifications.",
    "url": "https://firebase.google.com",
    "api_base": "https://firestore.googleapis.com/v1",
    "category": "devtools",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://firebase.google.com/docs/reference/rest"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "how_to_get": "Create project at https://console.firebase.google.com — free",
    "cost": "Free tier: 1GB Firestore, 10GB Storage, 10K auth/month"
  },
  "capabilities": [
    {
      "id": "firestore_query",
      "description_for_ai": "Query Firestore NoSQL database. Filter, order, limit collections.",
      "intent": [
        "Firestore query",
        "Firebase database",
        "get documents",
        "Firebase запрос",
        "база данных Firebase"
      ],
      "endpoint": "POST https://firestore.googleapis.com/v1/projects/{project}/databases/(default)/documents:runQuery",
      "input": {
        "structuredQuery": {
          "type": "object",
          "description": "{from: [{collectionId: 'users'}], where: {fieldFilter: {field: {fieldPath: 'status'}, op: 'EQUAL', value: {stringValue: 'active'}}}, orderBy: [{field: {fieldPath: 'created'}, direction: 'DESCENDING'}], limit: 20}",
          "required": true
        }
      },
      "output": {
        "type": "list<document>",
        "fields": [
          "[0].document.name",
          "[0].document.fields"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "firestore_write",
      "description_for_ai": "Create or update a Firestore document.",
      "intent": [
        "write Firebase",
        "create document Firestore",
        "save data Firebase",
        "записать Firebase"
      ],
      "endpoint": "PATCH https://firestore.googleapis.com/v1/projects/{project}/databases/(default)/documents/{collection}/{docId}",
      "input": {
        "collection": {
          "type": "string",
          "required": true
        },
        "docId": {
          "type": "string",
          "description": "Document ID. Auto-generated if omitted (use POST)",
          "required": true
        },
        "fields": {
          "type": "object",
          "description": "{fieldName: {stringValue: 'text'} or {integerValue: 42} or {booleanValue: true}}",
          "required": true
        }
      },
      "output": {
        "type": "document",
        "fields": [
          "name",
          "fields",
          "createTime",
          "updateTime"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "auth_verify_token",
      "description_for_ai": "Verify a Firebase ID token from a client. Use on your backend to authenticate Firebase users.",
      "intent": [
        "verify Firebase token",
        "authenticate Firebase user",
        "Firebase auth backend",
        "верификация Firebase токена"
      ],
      "endpoint": "GET https://oauth2.googleapis.com/tokeninfo?id_token={token}",
      "input": {
        "id_token": {
          "type": "string",
          "description": "Firebase ID token from client",
          "required": true
        }
      },
      "output": {
        "type": "token_info",
        "fields": [
          "sub (user ID)",
          "email",
          "email_verified",
          "exp"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "send_fcm_notification",
      "description_for_ai": "Send push notifications to mobile/web apps via Firebase Cloud Messaging.",
      "intent": [
        "push notification",
        "FCM notification",
        "Firebase push",
        "пуш уведомление Firebase"
      ],
      "endpoint": "POST https://fcm.googleapis.com/v1/projects/{project}/messages:send",
      "input": {
        "message": {
          "type": "object",
          "description": "{token: 'device_token', notification: {title: 'Hello', body: 'Message'}, data: {key: 'value'}} or {topic: 'all_users'} or {condition: \"'sports' in topics\"}",
          "required": true
        }
      },
      "output": {
        "type": "message",
        "fields": [
          "name (message ID)"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "remote_config",
      "description_for_ai": "Get Remote Config parameters to control app behavior without releasing a new version.",
      "intent": [
        "Firebase remote config",
        "feature flags",
        "app configuration",
        "удалённая конфигурация Firebase"
      ],
      "endpoint": "GET https://firebaseremoteconfig.googleapis.com/v1/projects/{project}/remoteConfig",
      "input": {},
      "output": {
        "type": "config",
        "fields": [
          "parameters.parameterName.defaultValue.value",
          "conditions"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "realtime_database",
      "description_for_ai": "Read or write to Firebase Realtime Database. Data syncs in real-time across all clients.",
      "intent": [
        "Firebase realtime database",
        "sync data",
        "real-time data Firebase",
        "реалтайм база Firebase"
      ],
      "endpoint": "GET https://{project}.firebaseio.com/{path}.json",
      "input": {
        "path": {
          "type": "string",
          "description": "Database path e.g. /users/uid123",
          "required": true
        },
        "auth": {
          "type": "string",
          "description": "Auth token or API key as query param",
          "required": false
        },
        "orderBy": {
          "type": "string",
          "description": "Sort by '$key', '$value', or child key",
          "required": false
        },
        "limitToLast": {
          "type": "integer",
          "description": "Get last N items",
          "required": false
        }
      },
      "output": {
        "type": "data",
        "fields": [
          "JSON object at path"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}