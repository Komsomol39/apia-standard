{
  "apia": "1.0",
  "service": {
    "id": "freshdesk",
    "name": "Freshdesk API",
    "description_for_ai": "Customer support helpdesk. Tickets, agents, contacts, knowledge base, reports. Free plan available. Used by 68K+ companies. Alternative to Zendesk. Use for customer support management, ticket automation.",
    "url": "https://freshdesk.com",
    "api_base": "https://{domain}.freshdesk.com/api/v2",
    "category": "support",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.freshdesk.com/api/"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "API key as username, X as password",
    "how_to_get": "Profile → API Key",
    "cost": "Free: 10 agents. Growth: $18/agent/month"
  },
  "capabilities": [
    {
      "id": "list_tickets",
      "description_for_ai": "List customer support tickets with filters by status, priority, and agent.",
      "intent": [
        "freshdesk tickets",
        "support queue",
        "customer tickets",
        "тикеты freshdesk"
      ],
      "endpoint": "GET https://{domain}.freshdesk.com/api/v2/tickets",
      "input": {
        "filter": {
          "type": "string",
          "description": "new_and_my_open, watching, spam, deleted",
          "required": false
        },
        "requester_id": {
          "type": "integer",
          "required": false
        },
        "order_by": {
          "type": "string",
          "description": "created_at, due_by, updated_at, status",
          "default": "created_at"
        },
        "order_type": {
          "type": "string",
          "description": "asc or desc",
          "default": "desc"
        },
        "per_page": {
          "type": "integer",
          "default": 30
        }
      },
      "output": {
        "type": "list<ticket>",
        "fields": [
          "[0].id",
          "[0].subject",
          "[0].status",
          "[0].priority",
          "[0].requester_id",
          "[0].created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_ticket",
      "description_for_ai": "Create a support ticket. Assign priority, status, tags, and CC recipients.",
      "intent": [
        "create freshdesk ticket",
        "new support ticket",
        "создать обращение freshdesk"
      ],
      "endpoint": "POST https://{domain}.freshdesk.com/api/v2/tickets",
      "input": {
        "subject": {
          "type": "string",
          "required": true
        },
        "description": {
          "type": "string",
          "description": "HTML body of the ticket",
          "required": true
        },
        "email": {
          "type": "string",
          "description": "Requester email",
          "required": true
        },
        "priority": {
          "type": "integer",
          "description": "1=Low, 2=Medium, 3=High, 4=Urgent",
          "default": 2
        },
        "status": {
          "type": "integer",
          "description": "2=Open, 3=Pending, 4=Resolved, 5=Closed",
          "default": 2
        },
        "tags": {
          "type": "array",
          "required": false
        }
      },
      "output": {
        "type": "ticket",
        "fields": [
          "id",
          "subject",
          "status",
          "priority",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_reply",
      "description_for_ai": "Reply to a Freshdesk ticket as an agent.",
      "intent": [
        "reply freshdesk",
        "ticket reply",
        "agent response",
        "ответить freshdesk"
      ],
      "endpoint": "POST https://{domain}.freshdesk.com/api/v2/tickets/{ticket_id}/reply",
      "input": {
        "ticket_id": {
          "type": "integer",
          "required": true
        },
        "body": {
          "type": "string",
          "description": "Reply body in HTML",
          "required": true
        },
        "cc_emails": {
          "type": "array",
          "description": "Additional CC recipients",
          "required": false
        }
      },
      "output": {
        "type": "reply",
        "fields": [
          "id",
          "body",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_ticket",
      "description_for_ai": "Get full ticket details including conversation history.",
      "intent": [
        "ticket details freshdesk",
        "get ticket",
        "ticket info",
        "детали тикета freshdesk"
      ],
      "endpoint": "GET https://{domain}.freshdesk.com/api/v2/tickets/{id}",
      "input": {
        "id": {
          "type": "integer",
          "required": true
        },
        "include": {
          "type": "string",
          "description": "conversations, requester, company, stats",
          "required": false
        }
      },
      "output": {
        "type": "ticket",
        "fields": [
          "id",
          "subject",
          "description",
          "status",
          "priority",
          "conversations[0].body"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "auth": "API key as username in HTTP Basic auth, any string as password. Get key: Profile Settings → Your API Key",
    "domain": "Replace {domain} with your Freshdesk subdomain e.g. mycompany.freshdesk.com",
    "free_plan": "Free plan: up to 10 agents. All standard API endpoints available on free plan.",
    "search": "Use GET /api/v2/search/tickets?query='status:2 AND priority:3' for complex filtering with Freshdesk Query Language."
  }
}