{
  "apia": "1.0",
  "service": {
    "id": "freshdesk",
    "name": "Freshdesk API",
    "description_for_ai": "Customer support helpdesk. Tickets, agents, contacts, knowledge base, reports. Free plan available. Used by 68K+ companies. Alternative to Zendesk. Use for customer support management, ticket automation.",
    "url": "https://freshdesk.com",
    "api_base": "https://{domain}.freshdesk.com/api/v2",
    "category": "support",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.freshdesk.com/api/"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "API key as username, X as password",
    "how_to_get": "Profile → API Key",
    "cost": "Free: 10 agents. Growth: $18/agent/month"
  },
  "capabilities": [
    {
      "id": "list_tickets",
      "description_for_ai": "List Freshdesk support tickets with filters.",
      "intent": [
        "Freshdesk tickets",
        "support tickets",
        "customer issues Freshdesk",
        "заявки Freshdesk"
      ],
      "endpoint": "GET https://{domain}.freshdesk.com/api/v2/tickets",
      "input": {
        "filter": {
          "type": "string",
          "description": "new_and_my_open, watching, spam, deleted",
          "required": false
        },
        "requester_id": {
          "type": "integer",
          "required": false
        },
        "priority": {
          "type": "integer",
          "description": "1=low 2=medium 3=high 4=urgent",
          "required": false
        },
        "status": {
          "type": "integer",
          "description": "2=open 3=pending 4=resolved 5=closed",
          "required": false
        },
        "per_page": {
          "type": "integer",
          "default": 30
        }
      },
      "output": {
        "type": "list<ticket>",
        "fields": [
          "[0].id",
          "[0].subject",
          "[0].status",
          "[0].priority",
          "[0].requester_id",
          "[0].created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_ticket",
      "description_for_ai": "Create a new support ticket in Freshdesk.",
      "intent": [
        "create ticket Freshdesk",
        "new support request",
        "support issue Freshdesk",
        "создать заявку Freshdesk"
      ],
      "endpoint": "POST https://{domain}.freshdesk.com/api/v2/tickets",
      "input": {
        "subject": {
          "type": "string",
          "required": true
        },
        "description": {
          "type": "string",
          "required": true
        },
        "email": {
          "type": "string",
          "description": "Requester email",
          "required": true
        },
        "priority": {
          "type": "integer",
          "description": "1-4",
          "default": 2
        },
        "status": {
          "type": "integer",
          "description": "2=open 3=pending",
          "default": 2
        },
        "tags": {
          "type": "array",
          "required": false
        }
      },
      "output": {
        "type": "ticket",
        "fields": [
          "id",
          "subject",
          "status",
          "priority",
          "requester_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "reply_ticket",
      "description_for_ai": "Add a reply or note to a Freshdesk ticket.",
      "intent": [
        "reply Freshdesk",
        "ticket reply",
        "add note Freshdesk",
        "ответить на заявку Freshdesk"
      ],
      "endpoint": "POST https://{domain}.freshdesk.com/api/v2/tickets/{ticket_id}/reply",
      "input": {
        "ticket_id": {
          "type": "integer",
          "required": true
        },
        "body": {
          "type": "string",
          "description": "HTML reply body",
          "required": true
        },
        "from_email": {
          "type": "string",
          "required": false
        },
        "cc_emails": {
          "type": "array",
          "required": false
        }
      },
      "output": {
        "type": "reply",
        "fields": [
          "id",
          "body_text",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_contacts",
      "description_for_ai": "List customer contacts in Freshdesk.",
      "intent": [
        "Freshdesk contacts",
        "customers list",
        "contact database",
        "клиенты Freshdesk"
      ],
      "endpoint": "GET https://{domain}.freshdesk.com/api/v2/contacts",
      "input": {
        "page": {
          "type": "integer",
          "default": 1
        },
        "per_page": {
          "type": "integer",
          "default": 30
        }
      },
      "output": {
        "type": "list<contact>",
        "fields": [
          "[0].id",
          "[0].name",
          "[0].email",
          "[0].phone",
          "[0].company_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "create_contact",
      "description_for_ai": "Create a new customer contact in Freshdesk.",
      "intent": [
        "add contact Freshdesk",
        "new customer Freshdesk",
        "create contact",
        "добавить клиента Freshdesk"
      ],
      "endpoint": "POST https://{domain}.freshdesk.com/api/v2/contacts",
      "input": {
        "name": {
          "type": "string",
          "required": true
        },
        "email": {
          "type": "string",
          "required": false
        },
        "phone": {
          "type": "string",
          "required": false
        },
        "company_id": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "contact",
        "fields": [
          "id",
          "name",
          "email",
          "created_at"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_ticket_stats",
      "description_for_ai": "Get ticket volume and resolution stats for a Freshdesk account.",
      "intent": [
        "Freshdesk analytics",
        "ticket stats",
        "support metrics",
        "статистика Freshdesk"
      ],
      "endpoint": "GET https://{domain}.freshdesk.com/api/v2/reports/overview",
      "input": {},
      "output": {
        "type": "stats",
        "fields": [
          "new_tickets",
          "open_tickets",
          "pending_tickets",
          "resolved_tickets",
          "closed_tickets"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  },
  "agent_hints": {
    "auth": "API key as username in HTTP Basic auth, any string as password. Get key: Profile Settings → Your API Key",
    "domain": "Replace {domain} with your Freshdesk subdomain e.g. mycompany.freshdesk.com",
    "free_plan": "Free plan: up to 10 agents. All standard API endpoints available on free plan.",
    "search": "Use GET /api/v2/search/tickets?query='status:2 AND priority:3' for complex filtering with Freshdesk Query Language."
  }
}