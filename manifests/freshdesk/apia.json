{
  "apia": "1.0",
  "service": {
    "id": "freshdesk",
    "name": "Freshdesk API",
    "description_for_ai": "Customer support helpdesk. Tickets, agents, contacts, knowledge base, reports. Free plan available. Used by 68K+ companies. Alternative to Zendesk. Use for customer support management, ticket automation.",
    "url": "https://freshdesk.com",
    "api_base": "https://{domain}.freshdesk.com/api/v2",
    "category": "customer_support",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.freshdesk.com/api/"
  },
  "auth": {
    "type": "basic_auth",
    "anonymous_access": false,
    "note": "API key as username, X as password",
    "how_to_get": "Profile → API Key",
    "cost": "Free: 10 agents. Growth: $18/agent/month"
  },
  "capabilities": [
    {
      "id": "create_ticket",
      "description_for_ai": "Create a support ticket. Assign priority, type, and agent.",
      "intent": [
        "support ticket",
        "customer issue",
        "help request",
        "create ticket",
        "customer complaint"
      ],
      "endpoint": "POST https://{domain}.freshdesk.com/api/v2/tickets",
      "input": {
        "subject": {
          "type": "string",
          "required": true
        },
        "description": {
          "type": "string",
          "required": true
        },
        "email": {
          "type": "string",
          "description": "Customer email",
          "required": true
        },
        "priority": {
          "type": "integer",
          "description": "1=Low, 2=Medium, 3=High, 4=Urgent",
          "default": 2
        },
        "status": {
          "type": "integer",
          "description": "2=Open, 3=Pending, 4=Resolved, 5=Closed",
          "default": 2
        },
        "type": {
          "type": "string",
          "description": "Question, Incident, Problem, Feature Request, Refund",
          "required": false
        }
      },
      "output": {
        "type": "ticket",
        "fields": [
          "id",
          "subject",
          "status",
          "priority",
          "created_at",
          "responder_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_tickets",
      "description_for_ai": "Get support tickets with filters.",
      "intent": [
        "open tickets",
        "support queue",
        "pending tickets",
        "agent workload"
      ],
      "endpoint": "GET https://{domain}.freshdesk.com/api/v2/tickets",
      "input": {
        "filter": {
          "type": "string",
          "description": "new_and_my_open, watching, spam, deleted",
          "required": false
        },
        "order_by": {
          "type": "string",
          "description": "created_at, updated_at, due_by",
          "default": "created_at"
        },
        "order_type": {
          "type": "string",
          "description": "asc or desc",
          "default": "desc"
        },
        "per_page": {
          "type": "integer",
          "default": 30
        }
      },
      "output": {
        "type": "list<ticket>",
        "fields": [
          "id",
          "subject",
          "status",
          "priority",
          "created_at",
          "updated_at",
          "requester_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}