{
  "apia": "1.0",
  "service": {
    "id": "tiktok",
    "name": "TikTok API for Developers",
    "description_for_ai": "TikTok creator data API. Get user videos, metrics, live stream info. Content publishing API for business accounts. 1.5B+ users. Use for TikTok analytics, content management, creator apps.",
    "url": "https://developers.tiktok.com",
    "api_base": "https://open.tiktokapis.com/v2",
    "category": "social_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.tiktok.com/doc/overview/"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Register at https://developers.tiktok.com/apps",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "get_user_videos",
      "description_for_ai": "Get TikTok videos for authenticated user with view counts, likes, comments, shares.",
      "intent": [
        "tiktok videos",
        "my tiktok",
        "video analytics",
        "tiktok content",
        "creator videos"
      ],
      "endpoint": "POST https://open.tiktokapis.com/v2/video/list/",
      "input": {
        "fields": {
          "type": "string",
          "description": "id,title,video_description,create_time,cover_image_url,share_url,view_count,like_count,comment_count,share_count",
          "required": true
        },
        "max_count": {
          "type": "integer",
          "default": 20,
          "max": 20
        },
        "cursor": {
          "type": "integer",
          "description": "For pagination",
          "required": false
        }
      },
      "output": {
        "type": "list<video>",
        "fields": [
          "id",
          "title",
          "create_time",
          "view_count",
          "like_count",
          "comment_count",
          "share_count",
          "cover_image_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}