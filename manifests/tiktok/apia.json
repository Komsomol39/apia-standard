{
  "apia": "1.0",
  "service": {
    "id": "tiktok",
    "name": "TikTok API for Developers",
    "description_for_ai": "TikTok creator data API. Get user videos, metrics, live stream info. Content publishing API for business accounts. 1.5B+ users. Use for TikTok analytics, content management, creator apps.",
    "url": "https://developers.tiktok.com",
    "api_base": "https://open.tiktokapis.com/v2",
    "category": "social",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.tiktok.com/doc/overview/"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Register at https://developers.tiktok.com/apps",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "get_user_info",
      "description_for_ai": "Get TikTok user profile: followers, following, likes count, bio.",
      "intent": [
        "tiktok user profile",
        "tiktok account info",
        "followers tiktok",
        "профиль tiktok"
      ],
      "endpoint": "GET https://open.tiktokapis.com/v2/user/info/",
      "input": {
        "fields": {
          "type": "string",
          "description": "Comma-separated: open_id, union_id, avatar_url, display_name, bio_description, profile_deep_link, is_verified, follower_count, following_count, likes_count, video_count",
          "required": true
        }
      },
      "output": {
        "type": "user",
        "fields": [
          "data.user.display_name",
          "data.user.follower_count",
          "data.user.following_count",
          "data.user.likes_count",
          "data.user.bio_description",
          "data.user.is_verified"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_videos",
      "description_for_ai": "Get list of TikTok videos from the authenticated user.",
      "intent": [
        "tiktok videos",
        "user tiktok posts",
        "my tiktok videos",
        "видео tiktok"
      ],
      "endpoint": "POST https://open.tiktokapis.com/v2/video/list/",
      "input": {
        "fields": {
          "type": "string",
          "description": "id, create_time, cover_image_url, share_url, video_description, duration, height, width, title, like_count, comment_count, share_count, view_count",
          "required": true
        },
        "max_count": {
          "type": "integer",
          "description": "Max videos per page 1-20",
          "default": 10
        },
        "cursor": {
          "type": "integer",
          "description": "Pagination cursor",
          "required": false
        }
      },
      "output": {
        "type": "list<video>",
        "fields": [
          "data.videos[0].id",
          "data.videos[0].title",
          "data.videos[0].view_count",
          "data.videos[0].like_count",
          "data.videos[0].share_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_videos",
      "description_for_ai": "Search TikTok videos by keyword. Returns public videos with engagement data.",
      "intent": [
        "search tiktok",
        "tiktok search",
        "find tiktok video",
        "поиск tiktok"
      ],
      "endpoint": "POST https://open.tiktokapis.com/v2/video/search/",
      "input": {
        "query": {
          "type": "string",
          "description": "Search keyword",
          "required": true
        },
        "max_count": {
          "type": "integer",
          "default": 20
        },
        "cursor": {
          "type": "integer",
          "required": false
        },
        "fields": {
          "type": "string",
          "description": "id,create_time,cover_image_url,share_url,video_description,duration,like_count,comment_count,view_count",
          "required": false
        }
      },
      "output": {
        "type": "list<video>",
        "fields": [
          "data.videos[0].video_description",
          "data.videos[0].view_count",
          "data.videos[0].like_count",
          "data.videos[0].share_url"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_video_insights",
      "description_for_ai": "Get detailed analytics for a TikTok video: views, likes, comments, shares, reach, impressions.",
      "intent": [
        "tiktok analytics",
        "video performance tiktok",
        "tiktok insights",
        "аналитика tiktok видео"
      ],
      "endpoint": "POST https://open.tiktokapis.com/v2/video/query/",
      "input": {
        "filters": {
          "type": "object",
          "description": "{video_ids: ['7123456789012345678']}",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "id,like_count,comment_count,share_count,view_count,reach,impressions,video_duration,average_time_watched",
          "required": true
        }
      },
      "output": {
        "type": "list<video>",
        "fields": [
          "data.videos[0].view_count",
          "data.videos[0].like_count",
          "data.videos[0].reach",
          "data.videos[0].average_time_watched"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}