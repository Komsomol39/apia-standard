{
  "apia": "1.0",
  "service": {
    "id": "youtube-analytics",
    "name": "YouTube Analytics API",
    "description_for_ai": "YouTube Analytics Data API — deep performance insights for YouTube channels. Views, watch time, revenue, subscriber changes, demographics, traffic sources, device types. Historical data from channel creation. Free for authenticated channel owners. Essential for YouTube content strategy.",
    "url": "https://youtube.com",
    "api_base": "https://youtubeanalytics.googleapis.com/v2",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.google.com/youtube/analytics/"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Enable YouTube Analytics API at https://console.cloud.google.com",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "get_channel_stats",
      "description_for_ai": "Get channel analytics: views, watch time, subscribers gained, estimated revenue.",
      "intent": [
        "youtube analytics",
        "channel stats",
        "video performance",
        "аналитика youtube"
      ],
      "endpoint": "GET https://youtubeanalytics.googleapis.com/v2/reports",
      "input": {
        "ids": {
          "type": "string",
          "description": "channel==MINE or channel==UCxxxxx",
          "default": "channel==MINE"
        },
        "startDate": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "endDate": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "metrics": {
          "type": "string",
          "description": "views,estimatedMinutesWatched,averageViewDuration,subscribersGained,subscribersLost,likes,dislikes,shares,estimatedRevenue",
          "required": true
        },
        "dimensions": {
          "type": "string",
          "description": "day, month, video, country, ageGroup, gender, liveOrOnDemand",
          "required": false
        }
      },
      "output": {
        "type": "report",
        "fields": [
          "columnHeaders[0].name",
          "rows[0] (array of metric values)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_top_videos",
      "description_for_ai": "Get top performing videos by views, watch time, or revenue in a date range.",
      "intent": [
        "top videos youtube",
        "best videos analytics",
        "most viewed",
        "топ видео youtube аналитика"
      ],
      "endpoint": "GET https://youtubeanalytics.googleapis.com/v2/reports",
      "input": {
        "ids": {
          "type": "string",
          "default": "channel==MINE"
        },
        "startDate": {
          "type": "string",
          "required": true
        },
        "endDate": {
          "type": "string",
          "required": true
        },
        "metrics": {
          "type": "string",
          "default": "views,estimatedMinutesWatched,averageViewDuration,subscribersGained"
        },
        "dimensions": {
          "type": "string",
          "default": "video"
        },
        "sort": {
          "type": "string",
          "description": "-views (desc by views), -estimatedMinutesWatched",
          "default": "-views"
        },
        "maxResults": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "report",
        "fields": [
          "rows[0][0] (video_id)",
          "rows[0][1] (views)",
          "rows[0][2] (watch_time_min)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_audience",
      "description_for_ai": "Get audience demographics: age groups, gender, countries of your channel viewers.",
      "intent": [
        "youtube audience",
        "viewer demographics",
        "who watches",
        "аудитория youtube"
      ],
      "endpoint": "GET https://youtubeanalytics.googleapis.com/v2/reports",
      "input": {
        "ids": {
          "type": "string",
          "default": "channel==MINE"
        },
        "startDate": {
          "type": "string",
          "required": true
        },
        "endDate": {
          "type": "string",
          "required": true
        },
        "metrics": {
          "type": "string",
          "default": "viewerPercentage"
        },
        "dimensions": {
          "type": "string",
          "description": "ageGroup,gender or country",
          "default": "ageGroup,gender"
        }
      },
      "output": {
        "type": "demographics",
        "fields": [
          "rows[0] (ageGroup, gender, viewerPercentage)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "get_traffic_sources",
      "description_for_ai": "Get where viewers come from: search, suggested videos, external, notifications.",
      "intent": [
        "traffic sources youtube",
        "how people find videos",
        "discovery analytics",
        "источники трафика youtube"
      ],
      "endpoint": "GET https://youtubeanalytics.googleapis.com/v2/reports",
      "input": {
        "ids": {
          "type": "string",
          "default": "channel==MINE"
        },
        "startDate": {
          "type": "string",
          "required": true
        },
        "endDate": {
          "type": "string",
          "required": true
        },
        "metrics": {
          "type": "string",
          "default": "views,estimatedMinutesWatched"
        },
        "dimensions": {
          "type": "string",
          "default": "insightTrafficSourceType"
        }
      },
      "output": {
        "type": "traffic",
        "fields": [
          "rows[0][0] (source type)",
          "rows[0][1] (views)",
          "rows[0][2] (watch time)"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}