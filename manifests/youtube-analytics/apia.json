{
  "apia": "1.0",
  "service": {
    "id": "youtube-analytics",
    "name": "YouTube Analytics API",
    "description_for_ai": "YouTube Analytics Data API — deep performance insights for YouTube channels. Views, watch time, revenue, subscriber changes, demographics, traffic sources, device types. Historical data from channel creation. Free for authenticated channel owners. Essential for YouTube content strategy.",
    "url": "https://youtube.com",
    "api_base": "https://youtubeanalytics.googleapis.com/v2",
    "category": "media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.google.com/youtube/analytics/"
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Enable YouTube Analytics API at https://console.cloud.google.com",
    "cost": "Free"
  },
  "capabilities": [
    {
      "id": "get_channel_stats",
      "description_for_ai": "Deep analytics for YouTube channels. Views, watch time, revenue, demographics, traffic sources, engagement by video. Use for YouTube creator tools, channel analytics dashboards, content strategy apps. Get YouTube channel analytics: views, watch time, subscribers gained/lost, revenue for date range.",
      "intent": [
        "watch time",
        "YouTube stats",
        "video performance",
        "subscriber growth",
        "video views",
        "youtube performance",
        "youtube revenue",
        "channel revenue",
        "youtube analytics",
        "channel analytics",
        "YouTube metrics",
        "channel stats",
        "subscribers"
      ],
      "endpoint": "GET https://youtubeanalytics.googleapis.com/v2/reports",
      "input": {
        "ids": {
          "type": "string",
          "description": "channel==MINE for authenticated channel",
          "default": "channel==MINE"
        },
        "startDate": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "endDate": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": true
        },
        "metrics": {
          "type": "string",
          "description": "views,estimatedMinutesWatched,averageViewDuration,subscribersGained,estimatedRevenue",
          "required": true
        },
        "dimensions": {
          "type": "string",
          "description": "day, video, country, deviceType",
          "required": false
        }
      },
      "output": {
        "type": "analytics",
        "fields": [
          "columnHeaders",
          "rows"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}