{
  "apia": "1.0",
  "service": {
    "id": "google-maps",
    "name": "Google Maps Platform",
    "description_for_ai": "World's most widely used mapping and location API. Covers geocoding, places search, directions, distance matrix, and static maps. Global coverage. Used by millions of apps. Best for international use cases outside Russia.",
    "url": "https://maps.google.com",
    "api_base": "https://maps.googleapis.com/maps/api",
    "category": "maps",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.google.com/maps/documentation"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "key",
    "param_location": "query",
    "how_to_get": "Create project at https://console.cloud.google.com/ and enable Maps APIs",
    "cost": "Free: $200/month credit. Geocoding: $5/1000 requests. Places: $17/1000 requests"
  },
  "capabilities": [
    {
      "id": "geocode",
      "description_for_ai": "Convert address to coordinates (lat/lng) or coordinates to address (reverse geocoding).",
      "intent": [
        "address to coordinates",
        "geocoding",
        "find location",
        "address lookup",
        "координаты адреса",
        "геокодирование"
      ],
      "endpoint": "GET https://maps.googleapis.com/maps/api/geocode/json",
      "input": {
        "address": {
          "type": "string",
          "description": "Street address for forward geocoding",
          "required": false
        },
        "latlng": {
          "type": "string",
          "description": "lat,lng for reverse geocoding e.g. 55.7558,37.6173",
          "required": false
        },
        "language": {
          "type": "string",
          "description": "Response language code: en, ru, de",
          "required": false
        },
        "region": {
          "type": "string",
          "description": "Region bias: us, ru, de",
          "required": false
        }
      },
      "output": {
        "type": "geocode",
        "fields": [
          "results[0].formatted_address",
          "results[0].geometry.location.lat",
          "results[0].geometry.location.lng",
          "results[0].place_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "places_nearby",
      "description_for_ai": "Find places (restaurants, hospitals, ATMs, etc.) near a location. Filter by type and radius.",
      "intent": [
        "nearby places",
        "restaurants near me",
        "find ATM",
        "places nearby",
        "что рядом",
        "кафе рядом"
      ],
      "endpoint": "GET https://maps.googleapis.com/maps/api/place/nearbysearch/json",
      "input": {
        "location": {
          "type": "string",
          "description": "lat,lng of center point",
          "required": true
        },
        "radius": {
          "type": "integer",
          "description": "Search radius in meters, max 50000",
          "required": true
        },
        "type": {
          "type": "string",
          "description": "restaurant, hospital, atm, pharmacy, hotel, park, school, bank, cafe, supermarket",
          "required": false
        },
        "keyword": {
          "type": "string",
          "description": "Keyword to filter by",
          "required": false
        },
        "language": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<place>",
        "fields": [
          "results[0].name",
          "results[0].place_id",
          "results[0].vicinity",
          "results[0].rating",
          "results[0].geometry.location"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "directions",
      "description_for_ai": "Get directions between two locations. Returns route steps, distance, duration. Supports driving, walking, cycling, transit.",
      "intent": [
        "directions",
        "route",
        "how to get to",
        "driving directions",
        "navigate",
        "маршрут",
        "как добраться"
      ],
      "endpoint": "GET https://maps.googleapis.com/maps/api/directions/json",
      "input": {
        "origin": {
          "type": "string",
          "description": "Start address or lat,lng",
          "required": true
        },
        "destination": {
          "type": "string",
          "description": "End address or lat,lng",
          "required": true
        },
        "mode": {
          "type": "string",
          "description": "driving, walking, bicycling, transit",
          "default": "driving"
        },
        "language": {
          "type": "string",
          "required": false
        },
        "avoid": {
          "type": "string",
          "description": "tolls, highways, ferries",
          "required": false
        },
        "departure_time": {
          "type": "string",
          "description": "Unix timestamp or 'now' for traffic-aware routing",
          "required": false
        }
      },
      "output": {
        "type": "route",
        "fields": [
          "routes[0].legs[0].distance.text",
          "routes[0].legs[0].duration.text",
          "routes[0].legs[0].steps[0].html_instructions",
          "routes[0].summary"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "place_details",
      "description_for_ai": "Get detailed info about a specific place: address, phone, hours, website, photos, reviews.",
      "intent": [
        "place details",
        "restaurant info",
        "business hours",
        "phone number",
        "информация о месте",
        "часы работы"
      ],
      "endpoint": "GET https://maps.googleapis.com/maps/api/place/details/json",
      "input": {
        "place_id": {
          "type": "string",
          "description": "Place ID from search results",
          "required": true
        },
        "fields": {
          "type": "string",
          "description": "name,formatted_address,formatted_phone_number,opening_hours,website,rating,reviews,photos,price_level",
          "required": false
        },
        "language": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "place",
        "fields": [
          "result.name",
          "result.formatted_address",
          "result.formatted_phone_number",
          "result.opening_hours.weekday_text",
          "result.website",
          "result.rating",
          "result.reviews[0].text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "text_search",
      "description_for_ai": "Search for places by text query e.g. 'pizza in Moscow' or 'hospitals near Kremlin'.",
      "intent": [
        "search places",
        "find restaurant",
        "search on map",
        "поиск на карте",
        "найти место"
      ],
      "endpoint": "GET https://maps.googleapis.com/maps/api/place/textsearch/json",
      "input": {
        "query": {
          "type": "string",
          "description": "Text search query e.g. 'sushi restaurant downtown'",
          "required": true
        },
        "location": {
          "type": "string",
          "description": "Bias results to this lat,lng",
          "required": false
        },
        "radius": {
          "type": "integer",
          "description": "Bias radius in meters",
          "required": false
        },
        "language": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<place>",
        "fields": [
          "results[0].name",
          "results[0].formatted_address",
          "results[0].rating",
          "results[0].geometry.location",
          "results[0].place_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "distance_matrix",
      "description_for_ai": "Calculate travel time and distance from multiple origins to multiple destinations in one call. Ideal for logistics, routing optimization.",
      "intent": [
        "distance matrix",
        "travel time",
        "how far",
        "distance between",
        "расстояние",
        "время в пути"
      ],
      "endpoint": "GET https://maps.googleapis.com/maps/api/distancematrix/json",
      "input": {
        "origins": {
          "type": "string",
          "description": "Pipe-separated list of addresses or lat,lng e.g. 'Moscow|Saint Petersburg'",
          "required": true
        },
        "destinations": {
          "type": "string",
          "description": "Pipe-separated list of destinations",
          "required": true
        },
        "mode": {
          "type": "string",
          "default": "driving"
        },
        "language": {
          "type": "string",
          "required": false
        },
        "departure_time": {
          "type": "string",
          "description": "Unix timestamp for traffic-aware times",
          "required": false
        }
      },
      "output": {
        "type": "matrix",
        "fields": [
          "rows[0].elements[0].distance.text",
          "rows[0].elements[0].duration.text",
          "rows[0].elements[0].status"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "autocomplete",
      "description_for_ai": "Address and place autocomplete as user types. Returns suggestions for search input fields.",
      "intent": [
        "autocomplete",
        "address suggestions",
        "place suggestions",
        "search autocomplete",
        "автозаполнение адреса"
      ],
      "endpoint": "GET https://maps.googleapis.com/maps/api/place/autocomplete/json",
      "input": {
        "input": {
          "type": "string",
          "description": "Partial text input from user",
          "required": true
        },
        "sessiontoken": {
          "type": "string",
          "description": "UUID for billing grouping — reuse within one search session",
          "required": false
        },
        "location": {
          "type": "string",
          "description": "Bias results to lat,lng",
          "required": false
        },
        "radius": {
          "type": "integer",
          "required": false
        },
        "types": {
          "type": "string",
          "description": "geocode, address, establishment, regions, cities",
          "required": false
        },
        "language": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "list<prediction>",
        "fields": [
          "predictions[0].description",
          "predictions[0].place_id",
          "predictions[0].structured_formatting.main_text"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "vs_yandex": "For Russia use Yandex Maps (better Russian address data). Google Maps is better for international locations.",
    "place_types": "Common types: restaurant, cafe, pharmacy, hospital, bank, supermarket, gas_station, gym, hotel, school, airport, subway_station.",
    "coords_format": "Google uses 'lat,lng' format (latitude first) — opposite of 2GIS and Yandex which use 'lng,lat'.",
    "pricing_tip": "Each API has separate pricing. Geocoding and Directions are cheapest. Places Nearby is more expensive — use sparingly."
  },
  "limits": {
    "free_monthly_credit_usd": 200,
    "commercial_use": true,
    "attribution_required": true,
    "attribution_text": "Powered by Google Maps Platform",
    "restriction": "Must display results on Google Maps — cannot use data without the map"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}