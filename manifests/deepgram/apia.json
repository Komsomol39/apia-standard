{
  "apia": "1.0",
  "service": {
    "id": "deepgram",
    "name": "Deepgram API",
    "description_for_ai": "Deepgram — leading real-time speech-to-text API. Transcribe audio 40x faster than real-time with 90%+ accuracy. Supports 40+ languages, speaker diarization, sentiment analysis, topic detection. $200 free credit on signup. Used by NASA, Spotify, Twilio.",
    "url": "https://deepgram.com",
    "api_base": "https://api.deepgram.com/v1",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.deepgram.com/reference/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Token {api_key}",
    "how_to_get": "Register at https://console.deepgram.com — $200 free credit",
    "cost": "$0.0043/min pre-recorded. $0.0059/min real-time"
  },
  "capabilities": [
    {
      "id": "transcribe_prerecorded",
      "description_for_ai": "Transcribe pre-recorded audio with Deepgram. Extremely fast and accurate.",
      "intent": [
        "transcribe Deepgram",
        "speech to text Deepgram",
        "audio transcription",
        "транскрипция Deepgram"
      ],
      "endpoint": "POST https://api.deepgram.com/v1/listen",
      "input": {
        "url": {
          "type": "string",
          "description": "Audio URL (or send binary in body)",
          "required": true
        },
        "model": {
          "type": "string",
          "description": "nova-2 (best), nova-2-meeting, nova-2-phone, base, enhanced",
          "default": "nova-2"
        },
        "language": {
          "type": "string",
          "description": "en, es, fr, de, ja, ko, ru, zh, ar (auto-detected if omitted)",
          "required": false
        },
        "smart_format": {
          "type": "boolean",
          "description": "Automatic punctuation, capitalization, numbers",
          "default": true
        },
        "diarize": {
          "type": "boolean",
          "description": "Speaker diarization",
          "default": false
        },
        "punctuate": {
          "type": "boolean",
          "default": true
        }
      },
      "output": {
        "type": "transcript",
        "fields": [
          "results.channels[0].alternatives[0].transcript",
          "results.channels[0].alternatives[0].confidence",
          "results.channels[0].alternatives[0].words[0].word",
          "results.channels[0].alternatives[0].words[0].start"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "real_time_transcription",
      "description_for_ai": "Stream real-time audio for live transcription via WebSocket.",
      "intent": [
        "live transcription Deepgram",
        "real time STT",
        "streaming transcription",
        "потоковая транскрипция Deepgram"
      ],
      "endpoint": "WebSocket wss://api.deepgram.com/v1/listen",
      "input": {
        "encoding": {
          "type": "string",
          "description": "linear16, flac, mulaw, amr-nb, amr-wb, opus, speex, alaw, g729",
          "required": true
        },
        "sample_rate": {
          "type": "integer",
          "description": "Audio sample rate in Hz",
          "required": true
        },
        "channels": {
          "type": "integer",
          "description": "Number of channels",
          "default": 1
        }
      },
      "output": {
        "type": "stream<transcript>",
        "fields": [
          "channel.alternatives[0].transcript",
          "channel.alternatives[0].confidence",
          "is_final"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "text_to_speech",
      "description_for_ai": "Generate natural speech from text with Deepgram Aura TTS.",
      "intent": [
        "text to speech Deepgram",
        "Deepgram TTS",
        "voice synthesis",
        "синтез речи Deepgram"
      ],
      "endpoint": "POST https://api.deepgram.com/v1/speak",
      "input": {
        "text": {
          "type": "string",
          "description": "Text to synthesize",
          "required": true
        },
        "model": {
          "type": "string",
          "description": "aura-asteria-en (female), aura-orion-en (male), aura-luna-en, aura-zeus-en, aura-arcas-en",
          "default": "aura-asteria-en"
        },
        "encoding": {
          "type": "string",
          "description": "linear16, mulaw, alaw, mp3, opus, flac",
          "default": "mp3"
        }
      },
      "output": {
        "type": "audio",
        "fields": [
          "audio binary stream"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "summarize_audio",
      "description_for_ai": "Transcribe and summarize audio content in one request with Deepgram.",
      "intent": [
        "summarize audio Deepgram",
        "audio summary",
        "meeting notes AI",
        "резюме аудио Deepgram"
      ],
      "endpoint": "POST https://api.deepgram.com/v1/listen?summarize=v2",
      "input": {
        "url": {
          "type": "string",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "nova-2"
        }
      },
      "output": {
        "type": "summary",
        "fields": [
          "results.summary.short (text summary)",
          "results.channels[0].alternatives[0].transcript"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_intent",
      "description_for_ai": "Detect topics and classify intent in transcribed audio.",
      "intent": [
        "intent detection audio",
        "topic detection",
        "call intent",
        "намерение в аудио Deepgram"
      ],
      "endpoint": "POST https://api.deepgram.com/v1/listen?detect_topics=true",
      "input": {
        "url": {
          "type": "string",
          "required": true
        },
        "model": {
          "type": "string",
          "default": "nova-2"
        }
      },
      "output": {
        "type": "topics",
        "fields": [
          "results.topics.segments[0].topics[0].topic",
          "results.topics.segments[0].topics[0].confidence_score"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "detect_language",
      "description_for_ai": "Auto-detect the language of audio content.",
      "intent": [
        "detect language Deepgram",
        "audio language detection",
        "what language is spoken",
        "определить язык в аудио Deepgram"
      ],
      "endpoint": "POST https://api.deepgram.com/v1/listen?detect_language=true",
      "input": {
        "url": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "language",
        "fields": [
          "results.channels[0].detected_language",
          "results.channels[0].language_probability"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}