{
  "apia": "1.0",
  "service": {
    "id": "deepgram",
    "name": "Deepgram API",
    "description_for_ai": "Deepgram — leading real-time speech-to-text API. Transcribe audio 40x faster than real-time with 90%+ accuracy. Supports 40+ languages, speaker diarization, sentiment analysis, topic detection. $200 free credit on signup. Used by NASA, Spotify, Twilio.",
    "url": "https://deepgram.com",
    "api_base": "https://api.deepgram.com/v1",
    "category": "ai_media",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.deepgram.com/reference/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Token {api_key}",
    "how_to_get": "Register at https://console.deepgram.com — $200 free credit",
    "cost": "$0.0043/min pre-recorded. $0.0059/min real-time"
  },
  "capabilities": [
    {
      "id": "transcribe_audio",
      "description_for_ai": "Fast, accurate audio transcription with Deepgram Nova-3. Best speed/accuracy ratio. $0.0043/min.",
      "intent": [
        "transcribe audio Deepgram",
        "speech to text fast",
        "audio transcription",
        "транскрибация Deepgram"
      ],
      "endpoint": "POST https://api.deepgram.com/v1/listen",
      "input": {
        "url": {
          "type": "string",
          "description": "Public audio URL (use body for file upload)",
          "required": false
        },
        "model": {
          "type": "string",
          "description": "nova-3 (best), nova-2, enhanced, base",
          "default": "nova-3"
        },
        "language": {
          "type": "string",
          "description": "en, ru, de, fr, es, etc. or multi for multilingual",
          "default": "en"
        },
        "smart_format": {
          "type": "boolean",
          "description": "Intelligent punctuation, numbers, dates",
          "default": true
        },
        "diarize": {
          "type": "boolean",
          "description": "Speaker identification",
          "default": false
        },
        "punctuate": {
          "type": "boolean",
          "default": true
        },
        "paragraphs": {
          "type": "boolean",
          "description": "Add paragraphs to output",
          "default": false
        },
        "summarize": {
          "type": "boolean",
          "description": "Auto summary",
          "default": false
        }
      },
      "output": {
        "type": "transcript",
        "fields": [
          "results.channels[0].alternatives[0].transcript",
          "results.channels[0].alternatives[0].words[0].word",
          "results.channels[0].alternatives[0].words[0].start",
          "metadata.duration"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "realtime_transcription",
      "description_for_ai": "Real-time streaming transcription over WebSocket. Ultra-low latency <300ms.",
      "intent": [
        "live transcription",
        "real-time STT",
        "streaming transcription",
        "потоковая транскрипция Deepgram"
      ],
      "endpoint": "WSS wss://api.deepgram.com/v1/listen",
      "input": {
        "model": {
          "type": "string",
          "default": "nova-3"
        },
        "encoding": {
          "type": "string",
          "description": "linear16, flac, mulaw, amr-nb, amr-wb, opus, speex, g729",
          "required": true
        },
        "sample_rate": {
          "type": "integer",
          "required": true
        },
        "channels": {
          "type": "integer",
          "default": 1
        }
      },
      "output": {
        "type": "realtime_transcript",
        "fields": [
          "channel.alternatives[0].transcript",
          "is_final",
          "speech_final"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "text_to_speech",
      "description_for_ai": "Convert text to speech with Deepgram Aura. Low-latency streaming TTS.",
      "intent": [
        "TTS Deepgram",
        "text to speech fast",
        "voice synthesis Deepgram",
        "синтез речи Deepgram"
      ],
      "endpoint": "POST https://api.deepgram.com/v1/speak",
      "input": {
        "text": {
          "type": "string",
          "required": true
        },
        "model": {
          "type": "string",
          "description": "aura-2-en-v1 (recommended), aura-asteria-en, aura-orion-en, aura-helios-en",
          "default": "aura-2-en-v1"
        },
        "encoding": {
          "type": "string",
          "description": "mp3, opus, linear16, mulaw, alaw, flac",
          "default": "mp3"
        },
        "container": {
          "type": "string",
          "description": "mp3, wav, ogg, none",
          "default": "mp3"
        }
      },
      "output": {
        "type": "audio",
        "fields": [
          "audio binary stream"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "audio_intelligence",
      "description_for_ai": "Analyze audio for topics, sentiment, summaries, and entities.",
      "intent": [
        "audio analysis",
        "topic detection audio",
        "sentiment analysis audio",
        "анализ аудио Deepgram"
      ],
      "endpoint": "POST https://api.deepgram.com/v1/listen",
      "input": {
        "url": {
          "type": "string",
          "required": true
        },
        "topics": {
          "type": "boolean",
          "description": "Topic detection",
          "default": true
        },
        "sentiment": {
          "type": "boolean",
          "description": "Sentiment analysis",
          "default": true
        },
        "summarize": {
          "type": "boolean",
          "default": true
        },
        "detect_entities": {
          "type": "boolean",
          "default": true
        }
      },
      "output": {
        "type": "analysis",
        "fields": [
          "results.topics.segments[0].topics[0].topic",
          "results.sentiments.average.sentiment",
          "results.summary.result"
        ]
      },
      "realtime": false,
      "requires_auth": true
    },
    {
      "id": "manage_models",
      "description_for_ai": "List available Deepgram models and check usage/balance.",
      "intent": [
        "Deepgram models",
        "available models STT",
        "API usage Deepgram",
        "модели Deepgram"
      ],
      "endpoint": "GET https://api.deepgram.com/v1/projects/{project_id}/balances",
      "input": {
        "project_id": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "balance",
        "fields": [
          "balances[0].balance",
          "balances[0].units",
          "balances[0].purchase_order_id"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}