{
  "apia": "1.0",
  "service": {
    "id": "deepgram",
    "name": "Deepgram API",
    "description_for_ai": "Deepgram — leading real-time speech-to-text API. Transcribe audio 40x faster than real-time with 90%+ accuracy. Supports 40+ languages, speaker diarization, sentiment analysis, topic detection. $200 free credit on signup. Used by NASA, Spotify, Twilio.",
    "url": "https://deepgram.com",
    "api_base": "https://api.deepgram.com/v1",
    "category": "ai_speech",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://developers.deepgram.com/reference/"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "header": "Authorization: Token {api_key}",
    "how_to_get": "Register at https://console.deepgram.com — $200 free credit",
    "cost": "$0.0043/min pre-recorded. $0.0059/min real-time"
  },
  "capabilities": [
    {
      "id": "transcribe_url",
      "description_for_ai": "AI-powered speech-to-text with real-time streaming. 40+ languages, speaker diarization, sentiment analysis, topic detection, summarization. Used by Twilio, NASA, Spotify. $200 free credit. Transcribe audio from URL. Returns text with timestamps, confidence, speaker labels.",
      "intent": [
        "speech recognition",
        "voice to text",
        "transcribe audio",
        "audio transcription",
        "real-time transcription",
        "podcast transcript",
        "meeting transcription",
        "convert speech",
        "speech to text",
        "транскрибация"
      ],
      "endpoint": "POST https://api.deepgram.com/v1/listen",
      "input": {
        "url": {
          "type": "string",
          "description": "Public URL to audio file",
          "required": true
        },
        "model": {
          "type": "string",
          "description": "nova-2 (best), base, enhanced",
          "default": "nova-2"
        },
        "language": {
          "type": "string",
          "default": "en",
          "description": "Language code: en, ru, de, fr, es, zh, ja, ko, pt"
        },
        "punctuate": {
          "type": "boolean",
          "default": true
        },
        "diarize": {
          "type": "boolean",
          "description": "Identify different speakers",
          "default": false
        },
        "summarize": {
          "type": "string",
          "description": "v2 for AI summary",
          "required": false
        },
        "detect_topics": {
          "type": "boolean",
          "default": false
        },
        "sentiment": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "transcription",
        "fields": [
          "results.channels[0].alternatives[0].transcript",
          "results.channels[0].alternatives[0].words",
          "results.summary.short",
          "results.topics"
        ]
      },
      "realtime": false,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}