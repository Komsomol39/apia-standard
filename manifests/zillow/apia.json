{
  "apia": "1.0",
  "service": {
    "id": "zillow",
    "name": "Zillow API (Bridge Interactive)",
    "description_for_ai": "Zillow Real Estate API via Bridge Interactive. US property database with 135M+ homes — Zestimate home values, listing prices, sold data, rental estimates. Neighborhood data, school ratings, walk scores. Used by mortgage lenders, real estate platforms, and investment tools.",
    "url": "https://zillow.com",
    "api_base": "https://api.bridgedataoutput.com/api/v2/zora/core",
    "category": "real_estate",
    "geo": [
      "US"
    ],
    "language": "en",
    "docs": "https://bridgedataoutput.com/docs"
  },
  "auth": {
    "type": "apikey",
    "anonymous_access": false,
    "param_name": "access_token",
    "param_location": "query",
    "how_to_get": "Register at https://www.zillow.com/howto/api/APIOverview.htm or via Bridge Interactive",
    "cost": "Free tier available"
  },
  "capabilities": [
    {
      "id": "search_properties",
      "description_for_ai": "Search home listings on Zillow by location.",
      "intent": [
        "zillow search",
        "homes for sale zillow",
        "real estate zillow",
        "поиск недвижимости zillow"
      ],
      "endpoint": "GET https://zillow-com1.p.rapidapi.com/propertyExtendedSearch",
      "input": {
        "location": {
          "type": "string",
          "description": "City/state: 'Austin, TX' or ZIP: '78701'",
          "required": true
        },
        "status_type": {
          "type": "string",
          "description": "ForSale, RecentlySold, ForRent",
          "default": "ForSale"
        },
        "home_type": {
          "type": "string",
          "description": "Houses, Apartments, Condos, Townhomes",
          "required": false
        },
        "minPrice": {
          "type": "integer",
          "required": false
        },
        "maxPrice": {
          "type": "integer",
          "required": false
        },
        "beds_min": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "list<property>",
        "fields": [
          "props[0].zpid",
          "props[0].address",
          "props[0].price",
          "props[0].beds",
          "props[0].baths",
          "props[0].livingArea",
          "props[0].imgSrc"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_property_details",
      "description_for_ai": "Get full Zillow property details: price history, Zestimate, tax history.",
      "intent": [
        "zillow property details",
        "home info zillow",
        "zestimate",
        "детали дома zillow"
      ],
      "endpoint": "GET https://zillow-com1.p.rapidapi.com/property",
      "input": {
        "zpid": {
          "type": "string",
          "description": "Zillow Property ID",
          "required": true
        }
      },
      "output": {
        "type": "property",
        "fields": [
          "zpid",
          "address.streetAddress",
          "zestimate",
          "rentZestimate",
          "bedrooms",
          "bathrooms",
          "livingArea",
          "yearBuilt",
          "description"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_price_history",
      "description_for_ai": "Get sale and price history for a Zillow property.",
      "intent": [
        "zillow price history",
        "home sale history",
        "property prices",
        "история цен zillow"
      ],
      "endpoint": "GET https://zillow-com1.p.rapidapi.com/priceHistory",
      "input": {
        "zpid": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<sale>",
        "fields": [
          "priceHistory[0].date",
          "priceHistory[0].price",
          "priceHistory[0].event",
          "priceHistory[0].source"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_similar_homes",
      "description_for_ai": "Get similar home listings to a Zillow property.",
      "intent": [
        "similar homes zillow",
        "comparable sales",
        "homes like this",
        "похожие дома zillow"
      ],
      "endpoint": "GET https://zillow-com1.p.rapidapi.com/similarProperties",
      "input": {
        "zpid": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "list<property>",
        "fields": [
          "results[0].zpid",
          "results[0].address",
          "results[0].price",
          "results[0].beds",
          "results[0].baths"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_market_trends",
      "description_for_ai": "Get local housing market trends for a ZIP code or city.",
      "intent": [
        "housing market zillow",
        "real estate trends",
        "market data zillow",
        "рынок недвижимости zillow"
      ],
      "endpoint": "GET https://zillow-com1.p.rapidapi.com/marketTrends",
      "input": {
        "regionId": {
          "type": "string",
          "required": false
        },
        "zip": {
          "type": "string",
          "required": false
        }
      },
      "output": {
        "type": "trends",
        "fields": [
          "medianSalePrice",
          "medianListPrice",
          "medianPricePerSqft",
          "daysToClose",
          "inventoryCount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}