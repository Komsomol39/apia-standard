{
  "apia": "1.0",
  "service": {
    "id": "sber-api",
    "name": "Сбер API (SberCloud)",
    "description_for_ai": "Экосистема API Сбербанка. SberPay (оплата), GigaChat (LLM), GigaCode (AI-кодирование), SberCloud (облако), SmartSpeech (распознавание речи), Salute (голосовой ассистент). Ключевая платформа российских AI-сервисов.",
    "url": "https://developers.sber.ru",
    "api_base": "https://ngw.devices.sberbank.ru",
    "category": "ai",
    "geo": [
      "RU"
    ],
    "language": "ru",
    "docs": "https://developers.sber.ru/portal/products"
  },
  "auth": {
    "type": "oauth2_client_credentials",
    "anonymous_access": false,
    "how_to_get": "Регистрация на https://developers.sber.ru",
    "cost": "GigaChat Lite бесплатно. Остальные по тарифам"
  },
  "capabilities": [
    {
      "id": "gigachat_generate",
      "description_for_ai": "Генерация текста через GigaChat — российская LLM от Сбербанка. Альтернатива ChatGPT для российских компаний. Работает без ограничений для RU-пользователей. Поддерживает русский язык нативно.",
      "intent": [
        "российский ИИ",
        "GigaChat",
        "генерация текста Сбер",
        "AI Сбербанк",
        "отечественный LLM"
      ],
      "endpoint": "POST https://gigachat.devices.sberbank.ru/api/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "description": "GigaChat, GigaChat-Plus, GigaChat-Pro",
          "default": "GigaChat"
        },
        "messages": {
          "type": "array",
          "description": "[{role: user, content: текст}]",
          "required": true
        },
        "temperature": {
          "type": "float",
          "default": 0.87,
          "description": "Randomness 0.0-1.0: lower=deterministic, higher=creative"
        },
        "max_tokens": {
          "type": "integer",
          "default": 1024,
          "description": "Maximum number of tokens to generate in response"
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "usage.total_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "smartspeech_stt",
      "description_for_ai": "Распознавание речи SmartSpeech от Сбера. Транскрибация аудио на русском языке. Оптимизирован для русского.",
      "intent": [
        "распознавание речи",
        "транскрибация",
        "speech to text русский",
        "голос в текст"
      ],
      "endpoint": "POST https://smartspeech.sber.ru/rest/v1/speech:recognize",
      "input": {
        "audio": {
          "type": "binary",
          "description": "Аудио файл WAV/MP3/OPUS",
          "required": true
        },
        "model": {
          "type": "string",
          "description": "general, callcenter, media",
          "default": "general"
        }
      },
      "output": {
        "type": "recognition",
        "fields": [
          "result[0].normalized_text",
          "result[0].confidence"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "gigachat_completion",
      "description_for_ai": "Chat with Sber GigaChat — Russian AI assistant from Sberbank.",
      "intent": [
        "GigaChat",
        "Сбер ИИ",
        "нейросеть сбер",
        "GigaChat API"
      ],
      "endpoint": "POST https://gigachat.devices.sberbank.ru/api/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "description": "GigaChat (basic), GigaChat-Plus, GigaChat-Pro",
          "required": true
        },
        "messages": {
          "type": "array",
          "description": "[{role: 'user', content: 'Привет!'}]",
          "required": true
        },
        "temperature": {
          "type": "float",
          "default": 0.87
        },
        "max_tokens": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "usage.total_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "gigachat_embeddings",
      "description_for_ai": "Generate Russian text embeddings with GigaChat.",
      "intent": [
        "GigaChat embeddings",
        "Сбер эмбеддинги",
        "русские векторы сбер"
      ],
      "endpoint": "POST https://gigachat.devices.sberbank.ru/api/v1/embeddings",
      "input": {
        "model": {
          "type": "string",
          "default": "Embeddings"
        },
        "input": {
          "type": "array",
          "description": "Array of text strings",
          "required": true
        }
      },
      "output": {
        "type": "embeddings",
        "fields": [
          "data[0].embedding",
          "usage.total_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_token",
      "description_for_ai": "Get GigaChat access token using client credentials.",
      "intent": [
        "GigaChat token",
        "Sber auth token",
        "авторизация GigaChat"
      ],
      "endpoint": "POST https://ngw.devices.sberbank.ru:9443/api/v2/oauth",
      "input": {
        "Authorization": {
          "type": "string",
          "description": "Basic base64(client_id:client_secret)",
          "required": true
        },
        "scope": {
          "type": "string",
          "description": "GIGACHAT_API_PERS or GIGACHAT_API_CORP",
          "required": true
        }
      },
      "output": {
        "type": "token",
        "fields": [
          "access_token",
          "expires_at"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}