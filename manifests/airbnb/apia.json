{
  "apia": "1.0",
  "service": {
    "id": "airbnb",
    "name": "Airbnb API",
    "description_for_ai": "Vacation rental and short-term accommodation platform. 7M+ listings in 220+ countries. Unique stays: houses, apartments, villas, treehouses. Official API very restricted — primarily for property managers and analytics partners.",
    "url": "https://airbnb.com",
    "api_base": "https://api.airbnb.com/v2",
    "category": "transport",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://www.airbnb.com/partner",
    "access_note": "⚠️ Very restricted API. Primarily for property management systems. Most features require partnership agreement."
  },
  "auth": {
    "type": "oauth2",
    "anonymous_access": false,
    "how_to_get": "Apply at https://www.airbnb.com/partner — requires business justification",
    "cost": "Partnership agreement required"
  },
  "capabilities": [
    {
      "id": "search_listings",
      "description_for_ai": "Search Airbnb listings by location, dates, and guests. Note: unofficial API.",
      "intent": [
        "search Airbnb",
        "find accommodation",
        "Airbnb rentals",
        "поиск Airbnb"
      ],
      "endpoint": "GET https://api.airbnb.com/v2/search_results",
      "input": {
        "location": {
          "type": "string",
          "required": true
        },
        "checkin": {
          "type": "string",
          "description": "YYYY-MM-DD",
          "required": false
        },
        "checkout": {
          "type": "string",
          "required": false
        },
        "guests": {
          "type": "integer",
          "default": 1
        },
        "price_min": {
          "type": "integer",
          "required": false
        },
        "price_max": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "list<listing>",
        "fields": [
          "search_results[0].listing.id",
          "search_results[0].listing.name",
          "search_results[0].listing.picture_url",
          "search_results[0].pricing_quote.rate.amount"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_listing",
      "description_for_ai": "Get full Airbnb listing details: description, photos, amenities, host.",
      "intent": [
        "listing details Airbnb",
        "property Airbnb",
        "accommodation details",
        "объявление Airbnb"
      ],
      "endpoint": "GET https://api.airbnb.com/v2/listings/{listing_id}",
      "input": {
        "listing_id": {
          "type": "integer",
          "required": true
        },
        "_format": {
          "type": "string",
          "default": "v1_legacy_long"
        }
      },
      "output": {
        "type": "listing",
        "fields": [
          "listing.id",
          "listing.name",
          "listing.description",
          "listing.amenities",
          "listing.person_capacity",
          "listing.star_rating"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "check_availability",
      "description_for_ai": "Check availability and pricing for an Airbnb listing.",
      "intent": [
        "Airbnb availability",
        "check dates",
        "listing price",
        "доступность Airbnb"
      ],
      "endpoint": "GET https://api.airbnb.com/v2/calendar_days",
      "input": {
        "listing_id": {
          "type": "integer",
          "required": true
        },
        "start_date": {
          "type": "string",
          "required": true
        },
        "end_date": {
          "type": "string",
          "required": true
        }
      },
      "output": {
        "type": "calendar",
        "fields": [
          "calendar_days[0].date",
          "calendar_days[0].available",
          "calendar_days[0].price.local_price",
          "calendar_days[0].price.local_currency"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_reviews",
      "description_for_ai": "Get guest reviews for an Airbnb listing.",
      "intent": [
        "Airbnb reviews",
        "guest reviews",
        "ratings Airbnb",
        "отзывы Airbnb"
      ],
      "endpoint": "GET https://api.airbnb.com/v2/reviews",
      "input": {
        "listing_id": {
          "type": "integer",
          "required": true
        },
        "_limit": {
          "type": "integer",
          "default": 7
        },
        "_offset": {
          "type": "integer",
          "default": 0
        }
      },
      "output": {
        "type": "list<review>",
        "fields": [
          "reviews[0].id",
          "reviews[0].comments",
          "reviews[0].reviewer_name",
          "reviews[0].created_at",
          "reviews[0].rating"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "get_host_listings",
      "description_for_ai": "Get all listings by a specific Airbnb host.",
      "intent": [
        "host listings Airbnb",
        "host properties",
        "by host Airbnb",
        "листинги хоста Airbnb"
      ],
      "endpoint": "GET https://api.airbnb.com/v2/listings",
      "input": {
        "user_id": {
          "type": "integer",
          "description": "Host user ID",
          "required": true
        },
        "_limit": {
          "type": "integer",
          "default": 10
        }
      },
      "output": {
        "type": "list<listing>",
        "fields": [
          "listings[0].id",
          "listings[0].name",
          "listings[0].city",
          "listings[0].person_capacity",
          "listings[0].star_rating"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "alternative": "For public Airbnb data consider RapidAPI scrapers or AirDNA for analytics. Official API is very restricted."
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}