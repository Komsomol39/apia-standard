{
  "apia": "1.0",
  "service": {
    "id": "openstreetmap-overpass",
    "name": "OpenStreetMap Overpass API",
    "description_for_ai": "Query OpenStreetMap data using Overpass QL. Find any geographic features: restaurants, hospitals, bus stops, parks, buildings, roads. Most detailed free map data. No API key needed.",
    "url": "https://overpass-api.de",
    "api_base": "https://overpass-api.de/api",
    "category": "maps",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://wiki.openstreetmap.org/wiki/Overpass_API"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free — please respect rate limits"
  },
  "capabilities": [
    {
      "id": "query_overpass",
      "description_for_ai": "Run an Overpass QL query to extract OpenStreetMap data: POIs, roads, buildings.",
      "intent": [
        "overpass query",
        "OSM data",
        "map data query",
        "запрос overpass OSM"
      ],
      "endpoint": "POST https://overpass-api.de/api/interpreter",
      "input": {
        "data": {
          "type": "string",
          "description": "Overpass QL query. Example: [out:json];node[amenity=cafe](51.5,−0.2,51.6,−0.1);out body;",
          "required": true
        }
      },
      "output": {
        "type": "osm_data",
        "fields": [
          "elements[0].type",
          "elements[0].id",
          "elements[0].lat",
          "elements[0].lon",
          "elements[0].tags.name",
          "elements[0].tags.amenity"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "find_pois",
      "description_for_ai": "Find Points of Interest around coordinates: cafes, restaurants, ATMs, hospitals.",
      "intent": [
        "find POI",
        "nearby places OSM",
        "points of interest",
        "достопримечательности OSM"
      ],
      "endpoint": "POST https://overpass-api.de/api/interpreter",
      "input": {
        "lat": {
          "type": "float",
          "required": true
        },
        "lon": {
          "type": "float",
          "required": true
        },
        "radius": {
          "type": "integer",
          "description": "Search radius in meters",
          "default": 500
        },
        "amenity": {
          "type": "string",
          "description": "OSM amenity: cafe, restaurant, atm, hospital, pharmacy, school, parking",
          "required": true
        }
      },
      "output": {
        "type": "list<node>",
        "fields": [
          "elements[0].lat",
          "elements[0].lon",
          "elements[0].tags.name",
          "elements[0].tags.opening_hours",
          "elements[0].tags.phone"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_building",
      "description_for_ai": "Get OSM building footprints and information for an area.",
      "intent": [
        "building OSM",
        "building footprints",
        "architecture data",
        "здания OSM"
      ],
      "endpoint": "POST https://overpass-api.de/api/interpreter",
      "input": {
        "bbox": {
          "type": "string",
          "description": "south,west,north,east bounding box",
          "required": true
        }
      },
      "output": {
        "type": "list<way>",
        "fields": [
          "elements[0].tags.building",
          "elements[0].tags.name",
          "elements[0].tags.addr:street",
          "elements[0].tags.addr:housenumber",
          "elements[0].nodes"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_roads",
      "description_for_ai": "Get road/path network data from OpenStreetMap Overpass.",
      "intent": [
        "roads OSM",
        "street data",
        "highway network",
        "дороги OSM Overpass"
      ],
      "endpoint": "POST https://overpass-api.de/api/interpreter",
      "input": {
        "bbox": {
          "type": "string",
          "required": true
        },
        "highway": {
          "type": "string",
          "description": "motorway, trunk, primary, secondary, residential, footway, cycleway",
          "required": false
        }
      },
      "output": {
        "type": "list<way>",
        "fields": [
          "elements[0].tags.highway",
          "elements[0].tags.name",
          "elements[0].tags.maxspeed",
          "elements[0].tags.lanes",
          "elements[0].nodes"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "count_features",
      "description_for_ai": "Count OSM features in an area (e.g., how many cafes in a city).",
      "intent": [
        "count features OSM",
        "feature statistics",
        "how many OSM",
        "подсчёт объектов OSM"
      ],
      "endpoint": "POST https://overpass-api.de/api/interpreter",
      "input": {
        "query": {
          "type": "string",
          "description": "[out:json];area[name='Berlin']->.a;node[amenity=cafe](area.a);out count;",
          "required": true
        }
      },
      "output": {
        "type": "count",
        "fields": [
          "elements[0].tags.total"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "query_template": "[out:json];node[KEY=VALUE](around:RADIUS_M,LAT,LON);out body; — finds nodes with tag near point",
    "common_amenities": "restaurant, cafe, hospital, pharmacy, school, bank, atm, parking, fuel, supermarket, bus_stop",
    "radius": "around:500 = 500 meters. Use larger radius for sparse areas.",
    "slow": "Complex queries can take 30+ seconds. Add timeout: [out:json][timeout:60]"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}