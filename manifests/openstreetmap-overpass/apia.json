{
  "apia": "1.0",
  "service": {
    "id": "openstreetmap-overpass",
    "name": "OpenStreetMap Overpass API",
    "description_for_ai": "Query OpenStreetMap data using Overpass QL. Find any geographic features: restaurants, hospitals, bus stops, parks, buildings, roads. Most detailed free map data. No API key needed.",
    "url": "https://overpass-api.de",
    "api_base": "https://overpass-api.de/api",
    "category": "maps",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://wiki.openstreetmap.org/wiki/Overpass_API"
  },
  "auth": {
    "type": "none",
    "anonymous_access": true,
    "cost": "Free — please respect rate limits"
  },
  "capabilities": [
    {
      "id": "query_pois",
      "description_for_ai": "Find points of interest (cafes, hospitals, schools) using Overpass API.",
      "intent": [
        "find POI OpenStreetMap",
        "nearby places OSM",
        "Overpass query",
        "поиск мест OpenStreetMap"
      ],
      "endpoint": "POST https://overpass-api.de/api/interpreter",
      "input": {
        "data": {
          "type": "string",
          "description": "Overpass QL query. Example: [out:json]; node[amenity=cafe](52.5,13.3,52.6,13.4); out; — finds cafes in Berlin bbox",
          "required": true
        }
      },
      "output": {
        "type": "list<element>",
        "fields": [
          "elements[0].type",
          "elements[0].id",
          "elements[0].lat",
          "elements[0].lon",
          "elements[0].tags.name",
          "elements[0].tags.amenity",
          "elements[0].tags.opening_hours"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "query_by_bbox",
      "description_for_ai": "Get all features in a bounding box from OpenStreetMap.",
      "intent": [
        "bbox query OSM",
        "area features",
        "map data bbox",
        "данные по области OSM"
      ],
      "endpoint": "POST https://overpass-api.de/api/interpreter",
      "input": {
        "data": {
          "type": "string",
          "description": "[out:json]; (node(52.5,13.3,52.6,13.4); way(52.5,13.3,52.6,13.4); relation(52.5,13.3,52.6,13.4);); out body;",
          "required": true
        }
      },
      "output": {
        "type": "osm_data",
        "fields": [
          "elements (nodes, ways, relations with tags)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "find_by_name",
      "description_for_ai": "Search for a place or feature by name using Overpass.",
      "intent": [
        "search by name OSM",
        "find place name",
        "named feature OSM",
        "поиск по названию OSM"
      ],
      "endpoint": "POST https://overpass-api.de/api/interpreter",
      "input": {
        "data": {
          "type": "string",
          "description": "[out:json]; node[name='Central Park'](40.7,-74.1,40.8,-73.9); out; — search in bbox with name",
          "required": true
        }
      },
      "output": {
        "type": "list<element>",
        "fields": [
          "elements[0].id",
          "elements[0].lat",
          "elements[0].lon",
          "elements[0].tags.name",
          "elements[0].tags"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_road_network",
      "description_for_ai": "Get road/street network data in an area.",
      "intent": [
        "road network OSM",
        "streets data",
        "highway data",
        "дорожная сеть OSM"
      ],
      "endpoint": "POST https://overpass-api.de/api/interpreter",
      "input": {
        "data": {
          "type": "string",
          "description": "[out:json]; way[highway](52.5,13.3,52.6,13.4); out geom;",
          "required": true
        }
      },
      "output": {
        "type": "ways",
        "fields": [
          "elements[0].id",
          "elements[0].tags.highway",
          "elements[0].tags.name",
          "elements[0].geometry (lat/lon array)"
        ]
      },
      "realtime": true,
      "requires_auth": false
    },
    {
      "id": "get_relations",
      "description_for_ai": "Get OSM relations (bus routes, administrative boundaries) in an area.",
      "intent": [
        "OSM relations",
        "bus routes OSM",
        "administrative boundary",
        "маршруты OSM"
      ],
      "endpoint": "POST https://overpass-api.de/api/interpreter",
      "input": {
        "data": {
          "type": "string",
          "description": "[out:json]; relation[type=route][route=bus](52.5,13.3,52.6,13.4); out body;",
          "required": true
        }
      },
      "output": {
        "type": "relations",
        "fields": [
          "elements[0].id",
          "elements[0].tags.name",
          "elements[0].tags.route",
          "elements[0].members[0].ref",
          "elements[0].members[0].role"
        ]
      },
      "realtime": true,
      "requires_auth": false
    }
  ],
  "agent_hints": {
    "query_template": "[out:json];node[KEY=VALUE](around:RADIUS_M,LAT,LON);out body; — finds nodes with tag near point",
    "common_amenities": "restaurant, cafe, hospital, pharmacy, school, bank, atm, parking, fuel, supermarket, bus_stop",
    "radius": "around:500 = 500 meters. Use larger radius for sparse areas.",
    "slow": "Complex queries can take 30+ seconds. Add timeout: [out:json][timeout:60]"
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}