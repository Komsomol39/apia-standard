{
  "apia": "1.0",
  "service": {
    "id": "xai-grok",
    "name": "xAI Grok API",
    "description_for_ai": "Elon Musk xAI Grok models. Cheapest frontier-quality API in 2026 ($0.20/$0.50 per 1M tokens). Real-time X (Twitter) data access. OpenAI-compatible. Best for: cost-sensitive high-volume tasks, real-time social media analysis, X platform integration.",
    "url": "https://x.ai",
    "api_base": "https://api.x.ai/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.x.ai/api"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer xai-...",
    "how_to_get": "Register at https://console.x.ai — $25 free monthly credit",
    "cost": "Grok 4.1: $0.20/$0.50 per 1M tokens. Grok 4: $3/$15 per 1M tokens"
  },
  "capabilities": [
    {
      "id": "chat_completion",
      "description_for_ai": "Chat with Grok AI. Supports real-time web knowledge, reasoning, and function calling.",
      "intent": [
        "ask Grok",
        "Grok AI",
        "xAI chat",
        "Grok chatbot",
        "спросить Grok"
      ],
      "endpoint": "POST https://api.x.ai/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "description": "grok-2-latest (best), grok-2-mini (fast)",
          "required": true
        },
        "messages": {
          "type": "array",
          "description": "[{role: system|user|assistant, content: string}]",
          "required": true
        },
        "temperature": {
          "type": "float",
          "default": 0.7
        },
        "max_tokens": {
          "type": "integer",
          "required": false
        },
        "stream": {
          "type": "boolean",
          "default": false
        },
        "tools": {
          "type": "array",
          "required": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "usage.prompt_tokens",
          "usage.completion_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "real_time_knowledge",
      "description_for_ai": "Query Grok with access to real-time web and X/Twitter data. Grok knows current events without search tools.",
      "intent": [
        "current events Grok",
        "real-time AI",
        "news AI",
        "актуальные новости Grok",
        "текущие события"
      ],
      "endpoint": "POST https://api.x.ai/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "grok-2-latest"
        },
        "messages": {
          "type": "array",
          "description": "Ask about current events, X posts, trending topics — Grok has live knowledge",
          "required": true
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "vision",
      "description_for_ai": "Analyze images with Grok. Pass image URL or base64.",
      "intent": [
        "Grok vision",
        "analyze image Grok",
        "image understanding xAI",
        "анализ изображения Grok"
      ],
      "endpoint": "POST https://api.x.ai/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "grok-2-vision-latest"
        },
        "messages": {
          "type": "array",
          "description": "[{role: 'user', content: [{type: 'image_url', image_url: {url: '...'}}, {type: 'text', text: 'question'}]}]",
          "required": true
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "embeddings",
      "description_for_ai": "Generate text embeddings with xAI. Compatible with OpenAI embedding format.",
      "intent": [
        "xAI embeddings",
        "Grok embeddings",
        "text embeddings",
        "эмбеддинги xAI"
      ],
      "endpoint": "POST https://api.x.ai/v1/embeddings",
      "input": {
        "model": {
          "type": "string",
          "default": "v1"
        },
        "input": {
          "type": "string or array",
          "required": true
        }
      },
      "output": {
        "type": "embeddings",
        "fields": [
          "data[0].embedding",
          "usage.total_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "function_calling",
      "description_for_ai": "Use Grok with function/tool calling. Compatible with OpenAI tools format.",
      "intent": [
        "Grok tools",
        "function calling Grok",
        "agent Grok",
        "инструменты Grok"
      ],
      "endpoint": "POST https://api.x.ai/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "required": true
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "tools": {
          "type": "array",
          "description": "[{type: 'function', function: {name, description, parameters}}]",
          "required": true
        },
        "tool_choice": {
          "type": "string",
          "description": "auto, required, none",
          "default": "auto"
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.tool_calls[0].function.name",
          "choices[0].message.tool_calls[0].function.arguments"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_models",
      "description_for_ai": "List available Grok models.",
      "intent": [
        "Grok models",
        "xAI models",
        "available models xAI",
        "модели Grok"
      ],
      "endpoint": "GET https://api.x.ai/v1/models",
      "input": {},
      "output": {
        "type": "list<model>",
        "fields": [
          "data[0].id",
          "data[0].owned_by",
          "data[0].created"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "price_tip": "Grok 4.1 Mini at $0.20/$0.50 per 1M tokens is among cheapest frontier models — ideal for classification, extraction, high-volume tasks.",
    "openai_compat": "100% OpenAI SDK compatible. Change base_url to https://api.x.ai/v1 and model name. Same code works.",
    "live_search": "Unique feature: Grok can search X (Twitter) in real-time. Ideal for monitoring brand mentions, trending topics.",
    "free_credit": "$25 free monthly credit — generous for testing.",
    "context": "grok-4 has 1M token context window."
  },
  "limits": {
    "free_monthly_credit_usd": 25,
    "commercial_use": true,
    "attribution_required": false
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}