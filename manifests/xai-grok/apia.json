{
  "apia": "1.0",
  "service": {
    "id": "xai-grok",
    "name": "xAI Grok API",
    "description_for_ai": "Elon Musk xAI Grok models. Cheapest frontier-quality API in 2026 ($0.20/$0.50 per 1M tokens). Real-time X (Twitter) data access. OpenAI-compatible. Best for: cost-sensitive high-volume tasks, real-time social media analysis, X platform integration.",
    "url": "https://x.ai",
    "api_base": "https://api.x.ai/v1",
    "category": "ai",
    "geo": [
      "GLOBAL"
    ],
    "language": "en",
    "docs": "https://docs.x.ai/api"
  },
  "auth": {
    "type": "bearer_token",
    "anonymous_access": false,
    "header": "Authorization: Bearer xai-...",
    "how_to_get": "Register at https://console.x.ai — $25 free monthly credit",
    "cost": "Grok 4.1: $0.20/$0.50 per 1M tokens. Grok 4: $3/$15 per 1M tokens"
  },
  "capabilities": [
    {
      "id": "chat",
      "description_for_ai": "Chat with Grok — xAI's model trained on real-time X/Twitter data. Best for current events, news, and up-to-date information.",
      "intent": [
        "ask grok",
        "grok ai",
        "xai model",
        "real-time AI",
        "спросить grok"
      ],
      "endpoint": "POST https://api.x.ai/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "description": "grok-2-latest (best), grok-2-mini (fast)",
          "required": true
        },
        "messages": {
          "type": "array",
          "description": "[{role: system|user|assistant, content: string}]",
          "required": true
        },
        "temperature": {
          "type": "float",
          "default": 1.0
        },
        "max_tokens": {
          "type": "integer",
          "required": false
        },
        "stream": {
          "type": "boolean",
          "default": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "choices[0].finish_reason",
          "usage.total_tokens"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "search_web",
      "description_for_ai": "Search the web using Grok with live internet access. Returns answers grounded in current web content.",
      "intent": [
        "web search grok",
        "current events",
        "latest news",
        "real-time search",
        "поиск в интернете grok"
      ],
      "endpoint": "POST https://api.x.ai/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "grok-2-latest"
        },
        "messages": {
          "type": "array",
          "required": true
        },
        "search_parameters": {
          "type": "object",
          "description": "{mode: 'on', sources: [{type: 'web'}], max_search_results: 5, return_citations: true}",
          "required": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content",
          "citations"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "vision",
      "description_for_ai": "Analyze images with Grok Vision. Describe, extract text, answer questions about images.",
      "intent": [
        "image analysis grok",
        "grok vision",
        "describe image",
        "анализ фото grok"
      ],
      "endpoint": "POST https://api.x.ai/v1/chat/completions",
      "input": {
        "model": {
          "type": "string",
          "default": "grok-2-vision-latest"
        },
        "messages": {
          "type": "array",
          "description": "[{role: user, content: [{type: image_url, image_url: {url: 'https://...'}}, {type: text, text: 'Describe this'}]}]",
          "required": true
        },
        "max_tokens": {
          "type": "integer",
          "required": false
        }
      },
      "output": {
        "type": "completion",
        "fields": [
          "choices[0].message.content"
        ]
      },
      "realtime": true,
      "requires_auth": true
    },
    {
      "id": "list_models",
      "description_for_ai": "List available xAI Grok models.",
      "intent": [
        "grok models",
        "available models xai",
        "список моделей grok"
      ],
      "endpoint": "GET https://api.x.ai/v1/models",
      "input": {},
      "output": {
        "type": "list<model>",
        "fields": [
          "data[0].id",
          "data[0].created",
          "data[0].owned_by"
        ]
      },
      "realtime": true,
      "requires_auth": true
    }
  ],
  "agent_hints": {
    "price_tip": "Grok 4.1 Mini at $0.20/$0.50 per 1M tokens is among cheapest frontier models — ideal for classification, extraction, high-volume tasks.",
    "openai_compat": "100% OpenAI SDK compatible. Change base_url to https://api.x.ai/v1 and model name. Same code works.",
    "live_search": "Unique feature: Grok can search X (Twitter) in real-time. Ideal for monitoring brand mentions, trending topics.",
    "free_credit": "$25 free monthly credit — generous for testing.",
    "context": "grok-4 has 1M token context window."
  },
  "limits": {
    "free_monthly_credit_usd": 25,
    "commercial_use": true,
    "attribution_required": false
  },
  "meta": {
    "apia_version": "1.0",
    "manifest_author": "APIA community",
    "last_verified": "2026-06-14"
  }
}